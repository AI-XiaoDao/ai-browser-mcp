    常量 读取中 <公开 类型 = 整数 值 = 20033 注释 = "读取中" @自动生成 = "mfc">
    常量 重新加载 <公开 类型 = 整数 值 = 20035 注释 = "重新加载" @自动生成 = "mfc">
    常量 忽略缓存重新加载 <公开 类型 = 整数 值 = 20036 注释 = "忽略缓存重新加载" @自动生成 = "mfc">
    常量 停止加载 <公开 类型 = 整数 值 = 20037 注释 = "停止加载" @自动生成 = "mfc">
    常量 浏览器HOST <公开 类型 = 整数 值 = 20003 注释 = "浏览器HOST" @自动生成 = "mfc">
    常量 关闭浏览器 <公开 类型 = 整数 值 = 20052 注释 = "关闭浏览器" @自动生成 = "mfc">
    常量 尝试关闭 <公开 类型 = 整数 值 = 20053 注释 = "尝试关闭" @自动生成 = "mfc">
    常量 打开开发者工具 <公开 类型 = 整数 值 = 20004 注释 = "打开开发者工具" @自动生成 = "mfc">
    常量 关闭开发者工具 <公开 类型 = 整数 值 = 20065 注释 = "关闭开发者工具" @自动生成 = "mfc">
