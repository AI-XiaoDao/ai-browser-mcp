<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 浏览器容器 <公开 @全局类 = 真>
{
    变量 浏览器 <公开 静态 类型 = 类_FBrowser_浏览器 "">
    变量 浏览器数组 <公开 静态 类型 = 对象数组类>
    变量 ""
    变量 ""
    变量 全局静态类测试 <公开 静态 类型 = 类_FBrowser_资源过滤器测试>
    变量 ""
}

类 启动类 <公开 基础类 = 窗口程序类>
{
    变量 主窗口对象 <公开 类型 = 我的主窗口 标题 = "我的主窗口">
    变量 ""

    方法 启动方法 <公开 类型 = 整数>
    {
        FBrowserVIP注册.VIP注册_置授权码 ("696A27C14BC7EA0C2707F022AA35E7F97DF811A1551455082C3EE28022FF03E2")
        变量 设置 <类型 = FBrowser_初始化配置>
        设置.缓存目录 = 取运行目录 () + "\\CacheData\\GlobalData"

        设置.本地化语言 = "zh-CN"
        设置.接收语言清单 = "zh-CN,zh,en"
        设置.启用系统消息循环 = 真
        设置.启用离屏渲染 = 假

        设置.保留Session = 真
        设置.日志目录 = 取运行目录 () + "\\log.txt"
        设置.日志模式 = 日志级别.致命

        // 多进程模式,以自身作为执行进程,也就是相关渲染、GPU的进程,也可不设置将会以内置默认exe作为执行进程
        // 设置.执行进程 = 取运行目录 () + 取执行文件名 ()



        变量 初始化事件 <类型 = 类_FBrowser_事件智能指针>
        初始化事件.创建 (类_FBrowser_自定义初始化事件)
        如果真 (FBrowser_初始化 (设置, 初始化事件) == 假)
        {
            返回 (0)

        }


        主窗口对象.创建主窗口 ()
        返回 (1)
    }
}

类 菜单 <基础类 = 菜单类 隐藏值属性 = "0"
        @设计内容 = "1\n0\n浏览器测试\n浏览器测试\n20000\n\n\n0\n0\n0\n0\n0\n1\n是否能后退\n是否能后退\n20029\n\n\n0\n0\n0\n0\n0\n1\n后退\n后退\n20030\n\n\n0\n0\n0\n0\n0\n1\n是否能前进\n是否能前进\n20031\n\n\n0\n0\n0\n0\n0\n1\n前进\n前进\n20032\n\n\n0\n0\n0\n0\n0\n1\n读取中\n读取中\n20033\n\n\n0\n0\n0\n0\n0\n1\n重新加载\n重新加载\n20035\n\n\n0\n0\n0\n0\n0\n1\n忽略缓存重新加载\n忽略缓存重新加载\n20036\n\n\n0\n0\n0\n0\n0\n1\n停止加载\n停止加载\n20037\n\n\n0\n0\n0\n0\n0\n0\n浏览器HOST\n浏览器HOST\n20003\n\n\n0\n0\n0\n0\n0\n1\n关闭浏览器\n关闭浏览器\n20052\n\n\n0\n0\n0\n0\n0\n1\n尝试关闭\n尝试关闭\n20053\n\n\n0\n0\n0\n0\n0\n1\n打开开发者工具\n打开开发者工具\n20004\n\n\n0\n0\n0\n0\n0\n1\n关闭开发者工具\n关闭开发者工具\n20065\n\n\n0\n0\n0\n0\n0\n0\n框架测试\n框架测试\n20005\n\n\n0\n0\n0\n0\n0\n1\n载入地址\n载入地址\n20010\n\n\n0\n0\n0\n0\n0\n1\n载入数据\n载入数据\n20011\n\n\n0\n0\n0\n0\n0">
{
