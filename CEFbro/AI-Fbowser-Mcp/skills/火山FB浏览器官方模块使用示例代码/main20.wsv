类 我的主窗口 <基础类 = 窗口 注释 = "样例主窗口" @视窗.布局 = "client_size = \"1131, 769\"" 最大化按钮 = 真 最小化按钮 = 真 标题 = "JS交互测试窗口" 可否移动 = 真 随意移动 = 真
        窗口边框 = 普通可调边框>
{
    变量 时钟1 <类型 = 时钟 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"253, 256, 26, 26\"">
    变量 窗口菜单 <类型 = 菜单>
    变量 ""
    变量 ""

    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 注释 = "当本组件及其中所有子组件均被创建完毕后发送此事件.">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        变量 窗口信息 <类型 = FBrowser_窗口信息>
        变量 浏览器配置 <类型 = FBrowser_浏览器配置>
        变量 请求环境配置 <类型 = FBrowser_请求环境配置>
        变量 ""
        窗口信息.父窗口句柄 = 取窗口句柄 ()
        窗口信息.横坐标 = 0
        窗口信息.纵坐标 = 0
        窗口信息.宽度 = 宽度
        窗口信息.高度 = 高度

        变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
        浏览器事件.创建 (类_FBrowser_自定义浏览器事件)
        FBrowser_创建浏览器 ("https://www.baidu.com", 窗口信息, 浏览器配置, , , 浏览器事件, , )

        置实例菜单 (窗口菜单)

        返回 (0)
    }

    方法 我的主窗口_位置被改变 <接收事件 类型 = 整数 注释 = "当本组件的位置被改变后发送此事件">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        我的主窗口_尺寸被改变 (来源对象, 标记值)
        返回 (0)
    }

    方法 我的主窗口_尺寸被改变 <接收事件 类型 = 整数 注释 = "当本组件的尺寸被改变后发送此事件">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        变量 浏览器 <类型 = 类_FBrowser_浏览器>
        如果 (浏览器容器.浏览器数组.取成员数 () > 0)
        {
            浏览器 = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 0, 类_FBrowser_浏览器)
            浏览器.移动窗口 (0, 0, 取用户区宽度 (), 取用户区高度 (), 假)

        }

        返回 (0)
    }

    方法 我的主窗口_接收到命令 <接收事件 类型 = 整数 注释 = "当本窗口上的菜单项(包括弹出子菜单)/工具条按钮被单击或者对应快捷键被按下时,发送此事件." 返回值注释 = "所通知的对应命令被处理返回1,否则返回0.">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 命令代码 <类型 = 整数 注释 = "  提供所对应命令的ID值,对于菜单项或其快捷键来说,就是对应菜单项设计时提供的引用常量ID值," 注释 = "对于工具条来说,就是对应按钮设计时提供的引用常量ID值.">
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        变量 frame <类型 = 类_FBrowser_框架>

        browser = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 0, 类_FBrowser_浏览器)
        frame = browser.取主框架 ()

        如果 (命令代码 == 菜单.是否能后退)
        {
            调试输出 (browser.可否后退 ())
        }
        否则 (命令代码 == 菜单.后退)
        {
            browser.后退 ()
        }
        否则 (命令代码 == 菜单.是否能前进)
        {
            调试输出 (browser.可否前进 ())
        }
        否则 (命令代码 == 菜单.前进)
        {
            browser.前进 ()
        }
        否则 (命令代码 == 菜单.读取中)
        {
            调试输出 (browser.是否读取中 ())
        }
        否则 (命令代码 == 菜单.重新加载)
        {
            browser.重新载入 ()
        }
        否则 (命令代码 == 菜单.忽略缓存重新加载)
        {
            browser.重新载入_忽略缓存 ()
        }
        否则 (命令代码 == 菜单.停止加载)
        {
            browser.停止载入 ()
        }
        否则 (命令代码 == 菜单.关闭浏览器)  // host
        {
            browser.关闭浏览器 (真)
        }
        否则 (命令代码 == 菜单.尝试关闭)
        {
            调试输出 (browser.尝试关闭浏览器 ())
        }
        否则 (命令代码 == 菜单.打开开发者工具)
        {
            变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
            浏览器事件.创建 (类_FBrowser_自定义浏览器事件)
            browser.打开开发者工具 ("开发者工具", 0, 0, 0, 1024, 800, , , 浏览器事件, )

        }
        否则 (命令代码 == 菜单.关闭开发者工具)
        {
            browser.关闭开发者工具 ()
        }

        否则 (命令代码 == 菜单.载入地址)
        {
            变量 地址 <类型 = 文本型>

            输入框 (地址, "输入网址", "输入框", "https://www.qq.com")
            frame.载入地址 (地址)

        }
        否则 (命令代码 == 菜单.载入数据)
        {
            调试输出 ("还未实现")
        }





        返回 (0)
    }

    方法 时钟_周期事件 <接收事件 类型 = 整数 注释 = "每当经过了指定的时钟周期,将发送本事件.">
    参数 来源对象 <类型 = 时钟 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {

        变量 browser <类型 = 类_FBrowser_浏览器>
        变量 frame <类型 = 类_FBrowser_框架>

        browser = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 0, 类_FBrowser_浏览器)
        变量 框架名数组 <类型 = 文本数组类>

        框架名数组 = browser.取框架名称 ().到火山文本数组 ()
        变量 i <类型 = 整数 值 = 0>

        计次循环 (框架名数组.取成员数 ())
        {
            调试输出 ("取框架名测试", browser.取框架_名称 (框架名数组.取成员 (i)).取框架名 ())
            i = i + 1


        }

        // frame = browser.取主框架 ()


        // frame.载入地址 ("https://www.baidu.com")

        返回 (0)
    }

    方法 窗口_将被销毁 <接收事件 类型 = 整数 注释 = "当本组件被销毁前发送此事件">
    参数 来源对象 <类型 = 窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        FBrowser_关闭 ()
        返回 (0)
    }
}
