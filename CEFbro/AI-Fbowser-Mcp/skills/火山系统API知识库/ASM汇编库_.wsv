    方法 跳转 <公开 静态 注释 = " 本语句的前后面必须跟随一个\"标签\"语句" 折叠 @嵌入式方法 = "">
    参数 标识符 <类型 = 文本型 注释 = "必须和\"标签\"语句的参数一致" 编辑时信息 = "17553E, 0, 0, 0" @需求类型 = 立即数或常量>
    {
        @ goto @pvpt<标识符>;
    }

    方法 标签 <公开 静态 注释 = "本语句的前后面必须跟随一个\"跳转\"语句,否则是无效的" 折叠 @嵌入式方法 = "has_loop_body = true">
    参数 标识符 <类型 = 文本型 注释 = "设置跳转标识符" @需求类型 = 立即数或常量>
    {
        @ @pvpt<标识符>:
    }

    #

    方法 暂停 <公开 静态 注释 = "易语言的暂停命令，相当于在程序代码中设置断点" 折叠 折叠2 @嵌入式方法 = "" @视窗.需求目标平台 = @"64位平台">
    {
        @ DebugBreak();
    }

    方法 __readfsbyte <公开 静态 类型 = 字节 注释 = " x86 FS段开头的偏移量指定位置读取内存" @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readfsbyte(@<offset>)
    }

    方法 __readfsword <公开 静态 类型 = 短整数 注释 = "x86  FS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readfsword(@<offset>)
    }

    方法 __readfsdword <公开 静态 类型 = 整数 注释 = "x86  FS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readfsdword(@<offset>)
    }

    方法 __readfsqword <公开 静态 类型 = 变整数 注释 = "x86  FS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readfsqword(@<offset>)
    }

    方法 __readgsbyte <公开 静态 类型 = 字节 注释 = "x64  GS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readgsbyte(@<offset>)
    }

    方法 __readgsword <公开 静态 类型 = 短整数 注释 = "x64  GS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readgsword(@<offset>)
    }

    方法 __readgsdword <公开 静态 类型 = 整数 注释 = "x64  GS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readgsdword(@<offset>)
    }

    方法 __readgsqword <公开 静态 类型 = 变整数 注释 = "x64  GS段开头的偏移指定位置读取内存" 折叠 @嵌入式方法 = "">
    参数 offset <类型 = 长整数>
    {
        @ __readgsqword(@<offset>)
    }

    方法 __nop <公开 静态 注释 = "在当前语句填入nop代码" 折叠 @嵌入式方法 = "">
    {
        @ __nop()
    }

    方法 调试器输出 <公开 静态 注释 = "配合dbgview可俘获信息，必须编译出来才可以，调试版和发布版都支持" @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 标识 <类型 = 文本型 注释 = "字符串：%s  字符串" 注释 = "字  符：%c  字符形式输出" 注释 = "整  型：%d  十进制" 注释 = "        %o  八进制 输出无0"
            注释 = "        %x  十六进制 输出无0x" 注释 = "指  针：%p  输出指针的值" 注释 = "浮点型：%f  默认六位小数" 注释 = "双精度(double型)为%lf，单精度(float型)为%f"
            编辑时信息 = "168872, 0, 0, 0" @输出名 = "strOutputString" @默认值 = "%d">
    参数 欲输出的变量 <编辑时信息 = "168872, 0, 0, 0" @需求类型 = 可写入变量 @可扩展 = "" @匹配类型 = 通用型>
    {
        @ @dt<ASM调试编译_>::OutputDebugStringExW((const wchar_t *)(_CT ("调试输出：") + @<标识>).GetText (),@<欲输出的变量>);

    }
}

类 内存函数类 <基础类 = 对象类 折叠 折叠2 @视窗.外部头文件 = "..\\..\\sys\\memory_module\\include\\MemoryModule.h"
        @视窗.外部源文件 = "..\\..\\sys\\memory_module\\include\\MemoryModule.c">
{
    方法 置函数地址 <公开 静态 类型 = 内存函数类 注释 = "设置被对象中所指定的函数调用地址." @嵌入式方法 = "">
    参数 函数地址 <类型 = 变整数 注释 = "欲调用的函数地址,函数地址必须自行保证安全及正确性.">
    {
        @ @dt<内存函数类>(@<函数地址>)
    }

    方法 取函数地址 <公开 静态 类型 = 变整数 注释 = "获取本对象中所指定的函数调用地址." @嵌入式方法 = "">
    参数 欲操作的对象 <类型 = 内存函数类>
    {
        @ (@dt<变整数>)@<欲操作的对象>.m_data
    }

    方法 调用函数 <公开 静态 注释 = "执行本对象中所指定的函数.本方法用作执行有参数且有返回值的函数." @嵌入式方法 = "">
    参数 欲操作的对象 <类型 = 内存函数类>
    参数 返回值类型 <注释 = "调用函数地址时的返回值类型,返回值类型必须对应本对象中的函数声明." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    参数 附加参数 <注释 = "调用函数地址时的附加参数,参数数量及参数数据类型必须对应本对象中的函数声明." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((@pdt<返回值类型>(WINAPI *)(@pdt_list<附加参数>))@<欲操作的对象>.m_data)(@<附加参数>)
    }

    方法 调用无参数函数 <公开 静态 注释 = "执行本对象中所指定的函数.本方法用作执行无参数但有返回值的函数." @嵌入式方法 = "">
    参数 欲操作的对象 <类型 = 内存函数类>
    参数 返回值类型 <注释 = "调用函数地址时的返回值类型,返回值类型必须对应本对象中的函数声明." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    {
        @ ((@pdt<返回值类型>(WINAPI *)())@<欲操作的对象>.m_data)()
    }

    方法 调用无返回值函数 <公开 静态 注释 = "执行本对象中所指定的函数.本方法用作执行无返回值但有参数的函数." @嵌入式方法 = "">
    参数 欲操作的对象 <类型 = 内存函数类>
    参数 附加参数 <注释 = "调用函数地址时的附加参数,参数数量及参数数据类型必须对应本对象中的函数声明." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((VOID(WINAPI *)(@pdt_list<附加参数>))@<欲操作的对象>.m_data)(@<附加参数>)
    }

    方法 调用无参数及返回值函数 <公开 静态 注释 = "执行本对象中所指定的函数.本方法用作执行无参数且无返回值的函数." @嵌入式方法 = "">
    参数 欲操作的对象 <类型 = 内存函数类>
    {
        @ ((VOID(WINAPI *)())@<欲操作的对象>.m_data)()
    }

    # @begin
    # <> <include>
    #     @sn<current_class>(@dt<变整数> data){
    #         assert(data != NULL);
    #         m_data = data;
    #     }
    #     @dt<变整数> m_data = NULL;
    # <> </include>
    # @end
}

类 内存模块类 <基础类 = 对象类 折叠 折叠2 @视窗.外部头文件 = "..\\..\\sys\\memory_module\\include\\MemoryModule.h"
        @视窗.外部源文件 = "..\\..\\sys\\memory_module\\include\\MemoryModule.c">
{
    方法 从内存加载 <公开 静态 类型 = 变整数 注释 = "从内存加载具有指定大小的EXE/DLL文件." 注释 = "注意: 如果加载的EXE完成运行,本进程也将终止." 返回值注释 = "成功返回模块句柄,失败返回0."
            @嵌入式方法 = "">
    参数 内存指针 <类型 = 变整数 注释 = "欲加载的模块数据指针">
    参数 指针长度 <类型 = 整数 注释 = "欲加载的模块数据指针大小">
    {
        @ (@dt<变整数>)MemoryLoadLibrary((const void *)@<内存指针>, (size_t)@<指针长度>)
    }

    方法 从文件加载 <公开 静态 类型 = 变整数 注释 = "从文件加载具有指定大小的EXE/DLL文件." 注释 = "注意: 如果加载的EXE完成运行,本进程也将终止." 返回值注释 = "成功返回模块句柄,失败返回0."
            @禁止流程检查 = 真>
    参数 文件名称 <类型 = 文本型 注释 = "欲加载的模块文件名称">
    {
        返回 (内存模块类.从字节集加载 (火山.基本.磁盘操作类.读入文件 (文件名称)))
    }

    方法 从字节集加载 <公开 静态 类型 = 变整数 注释 = "从字节集加载具有指定大小的EXE/DLL文件." 注释 = "注意: 如果加载的EXE完成运行,本进程也将终止." 返回值注释 = "成功返回模块句柄,失败返回0."
            @禁止流程检查 = 真>
    参数 模块数据 <类型 = 字节集类 注释 = "欲加载的模块数据">
    {
        返回 (内存模块类.从内存加载 (模块数据.取字节集指针 (), 模块数据.取字节集长度 ()))
    }

    方法 取函数 <公开 静态 类型 = 内存函数类 注释 = "从模块句柄中获取函数调用对象" 返回值注释 = "成功与否可调用当前返回值对象中的\"取函数地址()\"命令获取,如果失败此函数必定返回0." @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    参数 函数名称 <类型 = 文本型 注释 = "函数导出时的名称">
    {
        @ @dt<内存函数类>((@dt<变整数>)MemoryGetProcAddress((HMEMORYMODULE)@<模块句柄>, (LPCSTR)@<火山.基本.文本类.文本到多字节>(@<函数名称>, TRUE).GetPtr()))
    }

    方法 取函数2 <公开 静态 类型 = 内存函数类 注释 = "从模块句柄中获取函数调用对象" 返回值注释 = "成功与否可调用当前返回值对象中的\"取函数地址()\"命令获取,如果失败此函数必定返回0." @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    参数 函数名称或序索引 <类型 = 变整数 注释 = "函数导出时的序数值或多字节文本指针,如果为序索引,索引值从1开始.">
    {
        @ @dt<内存函数类>((@dt<变整数>)MemoryGetProcAddress((HMEMORYMODULE)@<模块句柄>, reinterpret_cast<LPCSTR>(@<函数名称或序索引>)))
    }

    方法 运行程序 <公开 静态 类型 = 整数 注释 = "执行入口点(仅限EXE).只有当EXE已加载到正确的基址或可以重新定位时(即链接器未剥离重新定位信息),才能执行入口点."
            注释 = "重要提示:调用此函数不会返回,即一旦加载的EXE完成运行,进程将终止." 返回值注释 = "如果无法执行入口点,则返回负值." @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    {
        @ (@dt<整数>)MemoryCallEntryPoint((HMEMORYMODULE)@<模块句柄>)
    }

    方法 释放模块 <公开 静态 注释 = "释放已加载的模块句柄" @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    {
        @ MemoryFreeLibrary((HMEMORYMODULE)@<模块句柄>);
    }

    方法 取资源数据尺寸 <公开 静态 类型 = 整数 注释 = "获取资源的大小(以字节为单位)" 返回值注释 = "成功返回数据尺寸,失败返回0" @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    参数 资源句柄 <类型 = 变整数 注释 = "模块句柄在\"寻找资源()\"\"..等资源相关命令中返回了此句柄.">
    {
        @ (@dt<整数>)MemorySizeofResource((HMEMORYMODULE)@<模块句柄>, (HMEMORYRSRC)@<资源句柄>)
    }

    方法 加载资源 <公开 静态 类型 = 变整数 注释 = "加载寻找到的资源" 返回值注释 = "成功返回数据指针,失败返回0" @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    参数 资源句柄 <类型 = 变整数 注释 = "模块句柄在\"寻找资源()\"\"..等资源相关命令中返回了此句柄.">
    {
        @ (@dt<变整数>)MemoryLoadResource((HMEMORYMODULE)@<模块句柄>, (HMEMORYRSRC)@<资源句柄>)
    }

    方法 加载文本资源 <公开 静态 类型 = 整数 注释 = "获取模块中的文本资源" 返回值注释 = "如加载失败则返回0" @嵌入式方法 = "">
    参数 模块句柄 <类型 = 变整数 注释 = "模块句柄在\"从内存加载()\"、\"从文件加载()\"..等加载相关命令中返回了此句柄.">
    参数 资源标识 <类型 = 整数 注释 = "文本资源索引标识,如:1,10,20...">
    参数 返回值 <类型 = 文本型 注释 = "结果存放的变量,此变量必须确保要有足够的缓冲区存放可能返回的文本资源." @需求类型 = 可写入变量>
    {
        @ (@dt<整数>)MemoryLoadString((HMEMORYMODULE)@<模块句柄>, (UINT)@<资源标识>, MEMORY_MODULE_STRING_POINTER_WITH_SIZE_ARGS(@<返回值>))
    }

    # @ <include>
    # @ #define MEMORY_MODULE_STRING_POINTER_WITH_SIZE_ARGS(str) (LPTSTR)str.GetText(), (int)(str.GetLength() * sizeof(TCHAR))
    # @ </include>
}
