    方法 add_eax <公开 类型 = 字节集类 注释 = "对应OD汇编指令 ADD EAX,1">
    参数 常数 <类型 = 整数>
    {
        变量 ret <类型 = 字节集类>
        如果 (常数 <= 127 && 常数 >= -128)
        {
            添加字节集 (ret, 创建字节集 (131, 192))
            添加字节集 (ret, Int2Hex (常数, 2))
        }
        否则
        {
            添加字节集 (ret, 创建字节集 (5))
            添加字节集 (ret, Int2Hex (常数, 8))

        }
        添加字节集 (asm代码, ret)
        返回 (ret)


    }

