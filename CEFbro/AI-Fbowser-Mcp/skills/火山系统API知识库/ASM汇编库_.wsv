类 Aam汇编类2_ <公开 折叠 折叠2 @全局类 = 真 @输出名 = "L_Asm">
{
    变量 XEDParseAssemb64 <静态 类型 = 字节集类 @视窗.值文件 = "asm\\Disassembly64.dll">
    变量 XEDParseAssemb32 <静态 类型 = 字节集类 @视窗.值文件 = "asm\\Disassembly32.dll">
    变量 BeaEngine <静态 类型 = 文本型>

    方法 AsmBegin <公开 静态 折叠>
    {
        BeaEngine = ""
    }

    方法 Asm <公开 静态 折叠>
    参数 汇编代码 <类型 = 文本型>
    {
        BeaEngine = BeaEngine + 汇编代码 + "\r\n"
    }

    方法 AsmCode <公开 静态 类型 = 字节集类 折叠>
    参数 目标平台 <类型 = 逻辑型 注释 = "假：32位，真：64位，默认64" @默认值 = 真>
    {

        变量 内存地址 <类型 = 变整数>
        变量 模块句柄 <类型 = 变整数>
        变量 字节长度 <类型 = 整数>
        变量 字节集 <类型 = 字节集类>
        内存地址 = 分配内存 (取文本长度 (BeaEngine) * 2)
        如果 (为64位程序 ())
        {
            模块句柄 = 内存模块类.从内存加载 (XEDParseAssemb64.取字节集指针 (), XEDParseAssemb64.取字节集长度 () + 1)
        }
        否则
        {
            模块句柄 = 内存模块类.从内存加载 (XEDParseAssemb32.取字节集指针 (), XEDParseAssemb32.取字节集长度 () + 1)
        }
        字节长度 = 内存模块类.取函数 (模块句柄, "XEDParseAssemb").调用函数 (整数, 文本到多字节 (BeaEngine, 真).取字节集指针 (), 内存地址, 目标平台)
        字节集 = 指针到字节集 (内存地址, 字节长度)
        内存模块类.释放模块 (模块句柄)
        释放内存 (内存地址)
        返回 (字节集)
    }

    方法 AsmCall <公开 静态 类型 = 变整数 注释 = "call" 折叠 @输出名 = "AsmCall" @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "自身句柄写-1" @输出名 = "handle" @默认值 = -1>
    参数 汇编代码 <类型 = 字节集类 @输出名 = "code">
    {
        @  INT_P ret = NULL;
        如果 (取字节集长度 (汇编代码) != 0)
        {
            @  DWORD length = (INT)code.GetSize ();
            @  LPVOID address = ::VirtualAllocEx ((HANDLE)handle, NULL, length, 4096, 64);
            @  ::WriteProcessMemory((HANDLE)handle,(LPVOID)address,(LPCVOID)(INT_P)code.GetPtr (),(INT)code.GetSize (),NULL);
            @  HANDLE thread = ::CreateRemoteThread ((HANDLE)handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
            @  ::WaitForSingleObject (thread, -1);
            @  ::GetExitCodeThread( thread, (LPDWORD)&ret);
            @  ::VirtualFreeEx ((HANDLE)handle, address, length, 16384);
            @  ::CloseHandle (thread);
        }
        @  return ret;
    }

    方法 转换_字节集到汇编 <公开 静态 类型 = 文本型 折叠>
    参数 字节集 <类型 = 字节集类>
    参数 目标平台 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 内存地址 <类型 = 变整数>
        变量 模块句柄 <类型 = 变整数>
        变量 字节长度 <类型 = 整数>
        变量 汇编代码 <类型 = 文本型>
        内存地址 = 分配内存 (取字节集长度 (字节集) * 8)
        如果 (为64位程序 ())
        {
            模块句柄 = 内存模块类.从内存加载 (XEDParseAssemb64.取字节集指针 (), XEDParseAssemb64.取字节集长度 () + 1)
        }
        否则
        {
            模块句柄 = 内存模块类.从内存加载 (XEDParseAssemb32.取字节集指针 (), XEDParseAssemb32.取字节集长度 () + 1)
        }
        字节长度 = 内存模块类.取函数 (模块句柄, "XEDParseAssemb2").调用函数 (整数, 内存地址, 字节集.取字节集指针 (), 字节集.取字节集长度 (), 目标平台)
        汇编代码 = 多字节指针到文本 (内存地址)
        内存模块类.释放模块 (模块句柄)
        释放内存 (内存地址)
        返回 (汇编代码)


    }

    #
}

类 ASM调试编译_ <公开 注释 = "编译器函数" 注释 = "普通用户可以忽略" 折叠 折叠2 @全局类 = 真 @视窗.外部头文件 = "intrin.h">
{

    # @begin
    # <> <include>
    # public:
    #     static void OutputDebugStringExW(const wchar_t *strOutputString, ...);
