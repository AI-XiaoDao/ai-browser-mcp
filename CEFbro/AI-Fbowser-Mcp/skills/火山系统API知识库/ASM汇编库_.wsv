    方法 mov_ecx_ptr_eax_add <公开 类型 = 字节集类 注释 = "对应OD汇编指令 MOV ECX,DWORD PTR DS:[EAX+1]">
    参数 参数 <类型 = 整数>
    {
        变量 ret <类型 = 字节集类>

        如果 (参数 <= 127 && 参数 >= -128)
        {
            添加字节集 (ret, 创建字节集 (139, 72))
            添加字节集 (ret, Int2Hex (参数, 2))
        }
        否则
        {
            添加字节集 (ret, 创建字节集 (139, 136))
            添加字节集 (ret, Int2Hex (参数, 8))
        }
        添加字节集 (asm代码, ret)
        返回 (ret)





    }

