    方法 add_eax_常数 <公开 类型 = 字节集类 注释 = "对应OD汇编指令 ADD EAX,1">
    参数 参数 <类型 = 整数>
    {
        变量 ret <类型 = 字节集类>
        如果 (参数 <= 127 && 参数 >= -128)
        {
            添加字节集 (ret, 创建字节集 (131, 192))
            添加字节集 (ret, 取指定字节集 (参数))
        }
        否则
        {
            添加字节集 (ret, 创建字节集 (5))
            添加字节集 (ret, 取指定字节集 (参数))
        }
        添加字节集 (asm代码, ret)
        返回 (ret)





    }

    方法 add_ecx_常数 <公开 类型 = 字节集类 注释 = "对应OD汇编指令 ADD ECX,1">
    参数 参数 <类型 = 整数>
    {
        变量 ret <类型 = 字节集类>
        如果 (参数 <= 127 && 参数 >= -128)
        {
            添加字节集 (ret, 创建字节集 (131, 193))
            添加字节集 (ret, 取指定字节集 (参数))
        }
        否则
        {
            添加字节集 (ret, 创建字节集 (129, 193))
            添加字节集 (ret, 取指定字节集 (参数))
        }
        添加字节集 (asm代码, ret)
