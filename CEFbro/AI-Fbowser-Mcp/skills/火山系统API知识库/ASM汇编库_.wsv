    方法 取call返回值 <公开 注释 = "先取出call的返回值，再用读call返回值把数值读出来">
    参数 进程句柄 <类型 = 变整数>
    参数 寄存器 <类型 = 文本型 注释 = "默认为ECX,可填写：EBX,ECX,EDX,ESI,EDI" @默认值 = 空对象>
    {
        地址 = 内存_申请内存 (进程句柄, 4, )
        如果真 (寄存器 == 空对象)
        {
            寄存器 = "ECX"
        }
        如果 (到大写 (寄存器) == "EBX")
        {
            mov_ebx_常数 ((整数)地址)
            mov_ptr_ebx_add_eax (0)
        }
        否则 (到大写 (寄存器) == "ECX")
        {
            mov_ecx_常数 ((整数)地址)
            mov_ptr_ecx_add_eax (0)
        }
        否则 (到大写 (寄存器) == "EDX")
        {
            mov_edx_常数 ((整数)地址)
            mov_ptr_edx_add_eax (0)
        }
        否则 (到大写 (寄存器) == "ESI")
        {
            mov_esi_常数 ((整数)地址)
            mov_ptr_esi_add_eax (0)
        }
        否则 (到大写 (寄存器) == "EDI")
        {
            mov_edi_常数 ((整数)地址)
            mov_ptr_edi_add_eax (0)

        }




    }

    方法 读call返回值 <公开 类型 = 整数 注释 = "配合取call返回值一起使用">
    参数 进程句柄 <类型 = 变整数>
    {
        变量 内存地址 <类型 = 整数>
        内存地址 = 内存_读整数型 (进程句柄, 地址, 8)
        内存_释放内存 (进程句柄, 地址)
        返回 (内存地址)



    }

    方法 取寄存器值 <公开 类型 = 整数 注释 = "返回当前方法内指定寄存器的数值，在dll里面使用">
    参数 寄存器 <类型 = 整数 注释 = "EAX=1,ECX=2,EDX=3,EBX=4,esp=5,ebp=6,esi=7,edi=8">
    {
        变量 ret <类型 = 整数>
        如果 (寄存器 == 1)
        {
            置入代码 (137, 69, 252)
            返回 (ret)
        }
        否则 (寄存器 == 2)
        {
            置入代码 (137, 77, 252)
            返回 (ret)
        }
        否则 (寄存器 == 3)
        {
            置入代码 (137, 85, 252)
            返回 (ret)
        }
        否则 (寄存器 == 4)
        {
            置入代码 (137, 93, 252)
            返回 (ret)
        }
        否则 (寄存器 == 5)
        {
            置入代码 (137, 101, 252)
            返回 (ret)
        }
        否则 (寄存器 == 6)
        {
            置入代码 (137, 109, 252)
            返回 (ret)
        }
        否则 (寄存器 == 7)
        {
            置入代码 (137, 117, 252)
            返回 (ret)
        }
        否则 (寄存器 == 8)
        {
            置入代码 (137, 125, 252)
            返回 (ret)

        }
        返回 (0)


    }

