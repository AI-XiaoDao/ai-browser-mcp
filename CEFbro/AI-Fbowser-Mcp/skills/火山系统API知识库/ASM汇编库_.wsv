        }
        返回 (假)




    }

    方法 call <公开 类型 = 字节集类>
    参数 参_修改地址 <类型 = 变整数>
    参数 参_目标地址 <类型 = 变整数>
    {
        变量 局_临时整数 <类型 = 变整数>
        变量 局_返回值 <类型 = 字节集类>
        局_临时整数 = 参_目标地址 - 参_修改地址 - 5
        局_返回值 = 创建字节集 (232)
        添加字节集 (局_返回值, 到字节集 (局_临时整数))
        返回 (局_返回值)


    }

    方法 内存_申请内存 <静态 类型 = 变整数 注释 = "成功返回指针" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 内存长度 <类型 = 变整数 注释 = "要申请的内存长度,尽量填4096的倍数吧,因为不足4096时系统自动以此倍数值来分配的">
    参数 保护属性 <类型 = 变整数 注释 = "2=只读，4=可读写，64=可读写运行，默认=64( PAGE_READWRITE)" @默认值 = 64>
    {
        @ return (INT_P)VirtualAllocEx((HANDLE)@<进程句柄>,(LPVOID)NULL,@<内存长度>,MEM_COMMIT,(DWORD)@<保护属性>);
    }

    方法 内存_读变整数 <静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "ReadProcessMemory" @视窗.输入 = "kernel32.dll">
    参数 进程句柄 <类型 = 变整数>
    参数 读取地址 <类型 = 变整数>
    参数 读到内容 <类型 = 变整数 "">
    参数 读取字节数 <类型 = 字节>
    参数 数据实际大小 <类型 = 变整数>

    方法 内存_释放内存 <静态 类型 = 逻辑型 注释 = "成功返回真，失败返回假" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 @输出名 = "hProcess">
    参数 内存地址 <类型 = 变整数 @输出名 = "address">
    {
        返回 (ZwFreeVirtualMemory (进程句柄, 取变量地址 (内存地址), 0, 32768) == 假)
    }

    方法 内存_写字节集 <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 写到地址 <类型 = 变整数 注释 = "写到地址">
    参数 写入数据 <类型 = 字节集类 注释 = "写入数据">
    {
        变量 缓冲区 <类型 = 变整数>
        变量 ret <类型 = 逻辑型>
        ret = ZwWriteVirtualMemory (进程句柄, 写到地址, 取字节集指针 (写入数据), 取字节集长度 (写入数据), 取变量地址 (缓冲区))
        返回 (取反 (ret))
    }

    方法 内存_读字节集 <静态 类型 = 字节集类 注释 = "读取成功返回读取的字节集，否则返回空字节集。" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 读取地址 <类型 = 变整数 注释 = "读取地址">
    参数 读取长度 <类型 = 整数 注释 = "读取长度，默认十六个字节">
    {
        变量 字节集 <类型 = 字节集类>
        变量 缓冲区 <类型 = 变整数>
        字节集 = 取空白字节集 (读取长度)
        如果真 (ZwReadVirtualMemory (进程句柄, 读取地址, 取字节集指针 (字节集), 读取长度, 取变量地址 (缓冲区)) == 假)
        {
            返回 (字节集)

        }
        返回 (到字节集 (-1))

    }

    方法 内存_读整数型 <静态 类型 = 整数 注释 = "读取成功返回读取的数值，否则返回-1。" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 读取地址 <类型 = 变整数 注释 = "读取地址">
    参数 读取长度 <类型 = 整数 注释 = "读出的数据大小">
    {
        变量 字节集 <类型 = 字节集类>
        字节集 = 取空白字节集 (读取长度)
        字节集 = 内存_读字节集 (进程句柄, 读取地址, 读取长度)
        返回 (取字节集数据 (字节集, , 整数))
    }

