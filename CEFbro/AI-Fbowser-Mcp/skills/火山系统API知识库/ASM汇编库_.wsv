    方法 je <公开 类型 = 字节集类>
    参数 参_修改地址 <类型 = 变整数>
    参数 参_目标地址 <类型 = 变整数>
    {
        变量 局_距离 <类型 = 变整数>
        变量 局_返回值 <类型 = 字节集类>
        局_距离 = 参_目标地址 - 参_修改地址
        如果 (局_距离 - 2 >= -128 && 局_距离 - 2 <= 127)
        {
            局_返回值 = 创建字节集 (116)
            添加字节集 (局_返回值, 到字节集 ((字节)局_距离 - 2))
        }
        否则
        {
            局_返回值 = 创建字节集 (15, 132)
            添加字节集 (局_返回值, 到字节集 (局_距离 - 6))

        }
        添加字节集 (asm代码, 局_返回值)
        返回 (局_返回值)





    }

    方法 push <公开 类型 = 字节集类 注释 = "对应OD汇编指令 PUSH 1">
    参数 常数 <类型 = 整数>
