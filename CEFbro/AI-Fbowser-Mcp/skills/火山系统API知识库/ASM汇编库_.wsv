<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <注释 = "本库来自于“恒通小助手”" @文档 = "category = \"ASM汇编库\"">

类 ASM汇编类_ <公开 注释 = "支持32位、64位" 折叠>
{
    变量 asm代码 <类型 = 字节集类 @输出名 = "Asmcode">
    变量 地址 <类型 = 变整数 @输出名 = "Address">

    #

    方法 调用函数 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 进程ID <类型 = 变整数 @输出名 = "ProcessID">
    参数 汇编代码 <类型 = 字节集类 @输出名 = "code">
    {
        @   HANDLE handle = OpenProcess (PROCESS_ALL_ACCESS, false, ProcessID);
        @   INT_P ret = NULL;
        @   if (handle != NULL)
        @   {
        @      DWORD length = (INT)code.GetSize ();
        @      LPVOID address = VirtualAllocEx (handle, NULL, length, 4096, 64);
        @      WriteProcessMemory(handle,(LPVOID)address,(LPCVOID)(INT_P)code.GetPtr (),(INT)code.GetSize (),NULL);
        @      HANDLE thread = CreateRemoteThread (handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
        @      ResumeThread (thread);
        @      WaitForSingleObject (thread, -1);
        @      GetExitCodeThread( thread, (LPDWORD)&ret);
        @      VirtualFreeEx (handle, address, length, 16384);
        @      CloseHandle (thread);
        @      CloseHandle (handle);
        @   }
        @  return ret;
    }

    方法 调用函数2 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 @输出名 = "handle">
    参数 汇编代码 <类型 = 字节集类 @输出名 = "code">
    {
        @  INT_P ret = NULL;
        @  DWORD length = (INT)code.GetSize ();
        @  LPVOID address = VirtualAllocEx ((HANDLE)handle, NULL, length, 4096, 64);
        @  WriteProcessMemory((HANDLE)handle,(LPVOID)address,(LPCVOID)(INT_P)code.GetPtr (),(INT)code.GetSize (),NULL);
        @  HANDLE thread = CreateRemoteThread ((HANDLE)handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
        @  WaitForSingleObject (thread, -1);
        @  GetExitCodeThread( thread, (LPDWORD)&ret);
        @  VirtualFreeEx ((HANDLE)handle, address, length, 16384);
        @  CloseHandle (thread);
        @  return ret;
    }

    方法 调用函数3 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 @输出名 = "handle">
    参数 汇编代码 <类型 = 字节集类 @输出名 = "code">
    参数 内存地址 <类型 = 变整数 @输出名 = "address">
    {
        内存_写字节集 (进程句柄, 内存地址, 汇编代码)

        @  INT_P ret = NULL;
        @  HANDLE thread = CreateRemoteThread ((HANDLE)handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
        @  WaitForSingleObject (thread, -1);
        @  GetExitCodeThread( thread, (LPDWORD)&ret);
        @  CloseHandle (thread);
        @  return ret;



    }

    方法 调用函数4 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 @输出名 = "handle">
    参数 调用地址 <类型 = 变整数 @输出名 = "address">
    {
        @  INT_P ret = NULL;
        @  HANDLE thread = CreateRemoteThread ((HANDLE)handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
        @  WaitForSingleObject (thread, -1);
        @  GetExitCodeThread( thread, (LPDWORD)&ret);
        @  CloseHandle (thread);
        @  return ret;
    }

    方法 调用函数5 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 @输出名 = "handle">
    参数 汇编代码 <类型 = 字节集类 @输出名 = "code">
    {
        @  INT_P ret = NULL;
        @  FARPROC Farproc = GetProcAddress (GetModuleHandle (_T("user32.dll")), "CallWindowProc");
        @  DWORD length = (INT)code.GetSize ();
        @  LPVOID address = VirtualAllocEx ((HANDLE)handle, NULL, length, 4096, 64);
        @  WriteProcessMemory((HANDLE)handle,(LPVOID)address,(LPCVOID)(INT_P)code.GetPtr (),(INT)code.GetSize (),NULL);
        @  HANDLE thread = CreateRemoteThread ((HANDLE)handle, NULL, NULL, (LPTHREAD_START_ROUTINE)address, NULL, NULL, NULL);
        @  WaitForSingleObject (thread, -1);
        @  GetExitCodeThread( thread, (LPDWORD)&ret);
        @  VirtualFreeEx ((HANDLE)handle, address, length, 16384);
        @  CloseHandle (thread);
        @  return ret;


    }

    方法 置代码 <公开 注释 = "放在最前面，清空上一次的字节集" 折叠>
    {
        asm代码.清空字节集 ()
    }

    方法 Int2Hex <公开 类型 = 字节集类 注释 = "公用转换">
    参数 Value <类型 = 整数>
    参数 n <类型 = 整数>
    {
        变量 临时文本 <类型 = 文本型>
        变量 结果 <类型 = 文本型>
        变量 计次变量 <类型 = 整数>
        变量 还原后的字节集 <类型 = 字节集类>
        临时文本 = 取文本右边 ("0000000" + 取十六进制文本 (Value, ), n)
        循环 (0, 取文本长度 (临时文本) / 2, 计次变量, 1)
        {
            结果 = 结果 + 取文本中间 (临时文本, 取文本长度 (临时文本) - 1 - 2 * 计次变量 - 1, 2)
        }
        还原后的字节集 = 字节集还原 (结果)
        返回 (还原后的字节集)

    }

    方法 字节集还原 <公开 类型 = 字节集类>
    参数 十六进制字节码 <类型 = 文本型>
    参数 是否替换 <类型 = 逻辑型 @默认值 = 假>
    {

        变量 返回的字节集 <类型 = 字节集类>
        变量 计次变量 <类型 = 整数>
        变量 返回的十进制 <类型 = 整数>
        变量 临时变量 <类型 = 文本型>
        变量 分割的文本 <类型 = 文本数组类>
        如果真 (是否替换 == 假)
        {
            是否替换 = 真
        }
        返回的字节集 = 取空白字节集 (0)
        临时变量 = 十六进制字节码
        如果 (是否替换 == 真)
        {
            子文本替换 (临时变量, ",", "", , , 真)
            子文本替换 (临时变量, "{", "", , , 真)
            子文本替换 (临时变量, "}", "", , , 真)
            循环 (1, 取文本长度 (十六进制字节码), 计次变量, 2)
            {
                返回的十进制 = 多元取十进制 (取文本中间 (十六进制字节码, 计次变量 - 1, 2), 0)
                添加字节集 (返回的字节集, 取字节集左边 (到字节集 (返回的十进制), 1))
            }
        }
        否则
        {
            子文本替换 (临时变量, "{", "", , , 真)
            子文本替换 (临时变量, "}", "", , , 真)
            分割文本 (临时变量, ",", 分割的文本, 假, 假)
            循环 (1, 分割的文本.取成员数 (), 计次变量, 2)
            {
                返回的十进制 = 文本到整数 (分割的文本.取成员 (计次变量))
                添加字节集 (返回的字节集, 取字节集左边 (到字节集 (返回的十进制), 1))
            }
        }
        返回 (返回的字节集)


    }

    方法 多元取十进制 <公开 类型 = 整数>
    参数 传入的字节 <类型 = 文本型>
    参数 字节位置 <类型 = 整数 @默认值 = -1>
    {
        变量 返回的结果 <类型 = 整数>
        变量 文本长度 <类型 = 整数>
        变量 循环变量 <类型 = 整数>
        变量 文本中间 <类型 = 文本型>
        变量 对应代码 <类型 = 整数>


        传入的字节 = 到小写 (传入的字节)
        如果真 (字节位置 == -1)
        {
            字节位置 = 1
        }
        返回的结果 = 0
        如果真 (字节位置 == 0)
        {
            文本长度 = 取文本长度 (传入的字节)
            循环 (1, 文本长度 + 1, 循环变量, 1)
            {
                文本中间 = 取文本中间 (传入的字节, 文本长度 - 循环变量, 1)
                如果真 (取代码_ (文本中间, 0) <= 取代码_ ("f", 0) && 取代码_ (文本中间, 0) >= 取代码_ ("a", 0) || 取代码_ (文本中间, 0) <= 取代码_ ("F", 0) && 取代码_ (文本中间, 0) >= 取代码_ ("A", 0))
                {
                    如果真 (取代码_ (文本中间, ) >= 取代码_ ("A", ) && 取代码_ (文本中间, ) <= 取代码_ ("F", ))
                    {
                        对应代码 = 取代码_ (文本中间, ) - 取代码_ ("A", ) + 10
                    }
                    如果真 (取代码_ (文本中间, ) >= 取代码_ ("a", ) && 取代码_ (文本中间, ) <= 取代码_ ("f", ))
                    {
                        对应代码 = 取代码_ (文本中间, ) - 取代码_ ("a", ) + 10
                    }
                }
                如果真 (取代码_ (文本中间, ) <= 取代码_ ("9", ) && 取代码_ (文本中间, ) >= 取代码_ ("0", ))
                {
                    对应代码 = 文本到整数 (文本中间)
                }
                返回的结果 = 返回的结果 + (整数)(求次方 (16, 循环变量 - 1) * 对应代码)
                // 循环尾
            }
        }
        如果真 (字节位置 == 1)
        {
            返回的结果 = 文本到整数 (传入的字节)
        }
        如果真 (字节位置 == 2)
        {
            文本长度 = 取文本长度 (传入的字节)
            循环变量 = 0
            循环 (1, 文本长度 + 1, 循环变量, 1)
            {
                文本中间 = 取文本中间 (传入的字节, 文本长度 - 循环变量 + 1, 1)
                如果真 (取代码_ (文本中间, ) <= 取代码_ ("7", ) && 取代码_ (文本中间, ) >= 取代码_ ("0", ))
                {
                    对应代码 = 文本到整数 (文本中间)
                }
                返回的结果 = 返回的结果 + (整数)(求次方 (8, 循环变量 - 1) * 对应代码)
            }
        }
        如果真 (字节位置 == 3)
        {
            文本长度 = 取文本长度 (传入的字节)
            循环变量 = 0
            循环 (1, 文本长度 + 1, 循环变量, 1)
            {
                文本中间 = 取文本中间 (传入的字节, 文本长度 - 循环变量 + 1, 1)
                如果真 (取代码_ (文本中间, ) <= 取代码_ ("1", ) && 取代码_ (文本中间, ) >= 取代码_ ("0", ))
                {
                    对应代码 = 文本到整数 (文本中间)
                }
                返回的结果 = 返回的结果 + (整数)(求次方 (2, 循环变量 - 1) * 对应代码)
                // 循环尾
            }
        }
        返回 (返回的结果)



    }

