    方法 取焦点元素 <公开 类型 = 逻辑型 折叠>
    参数 参数_焦点元素 <类型 = Accessible无障碍类_>
    {
        变量 var <类型 = COM变体型>
        如果 (m_id == 0)
        {
            <> var = m_self.读属性 ("accFocus", COM变体型, 取空基本对象 ())
            如果 (var.取类型 () == COM变体类型.空)
            {
                返回 (假)
            }
            如果 (var.取类型 () == COM变体类型.COM对象)
            {
                参数_焦点元素.创建自对象 (var.取COM对象2 (COM对象类))
            }
            否则
            {
                参数_焦点元素.创建自ID (var.取值 (整数, ), m_self)
            }
        }
        否则
        {
            <> var = m_parent.读属性 ("accFocus", COM变体型, 取空基本对象 ())
            如果 (var.取类型 () == COM变体类型.空)
            {
                返回 (假)
            }
            如果 (var.取类型 () == COM变体类型.COM对象)
            {
                参数_焦点元素.创建自对象 (var.取COM对象2 (COM对象类))
            }
            否则
            {
                参数_焦点元素.创建自ID (var.取值 (整数, ), m_parent)
            }
        }
        返回 (取反 (参数_焦点元素.是否空 ()))
    }

