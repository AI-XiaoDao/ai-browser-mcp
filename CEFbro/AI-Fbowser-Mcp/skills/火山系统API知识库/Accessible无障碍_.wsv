    方法 取角色文本 <公开 类型 = 文本型 折叠>
    {
        @ DWORD roleId;
        @ VARIANT varChild, varResult;
        @ varChild.vt = VT_I4;
        如果 (m_id != 0)
        {
            @ varChild.lVal = @<m_id>;
            @ ((IAccessible*)@<m_parent>.m_pUnknownObject)->get_accRole(varChild, &varResult);
            @ roleId = varResult.lVal;
            @ UINT roleLength;
            @ roleLength = GetRoleText(roleId, NULL, 0);
            @ CVolMem text;
            @ text.Alloc(roleLength * 2 + 2, TRUE);
            @ GetRoleText(roleId, (LPWSTR)text.GetPtr(), roleLength + 1);
            @ return @an<CVolString> ((LPCWSTR)text.GetPtr(), roleLength);
        }
        否则
        {
            @ varChild.lVal = CHILDID_SELF;
            @ ((IAccessible*)@<m_self>.m_pUnknownObject)->get_accRole(varChild, &varResult);
            @ roleId = varResult.lVal;
            @ UINT roleLength;
            @ roleLength = GetRoleText(roleId, NULL, 0);
            @ CVolMem text;
            @ text.Alloc(roleLength * 2 + 2, TRUE);
            @ GetRoleText(roleId, (LPWSTR)text.GetPtr(), roleLength + 1);
            @ return @an<CVolString> ((LPCWSTR)text.GetPtr(), roleLength);
        }
        返回 ("")
    }

