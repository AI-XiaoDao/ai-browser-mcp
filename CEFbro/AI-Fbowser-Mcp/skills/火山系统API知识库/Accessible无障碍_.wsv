    方法 取位置 <公开 折叠>
    参数 控件位置 <类型 = 矩形类>
    {
        @ long pxLeft = 0;
        @ long pyTop = 0;
        @ long pcxWidth = 0;
        @ long pcyHeight = 0;
        @ VARIANT varChild;
        @ varChild.vt = VT_I4;
        如果 (m_id != 0)
        {
            @ varChild.lVal = @<m_id>;
            @ ((IAccessible*)@<m_parent>.m_pUnknownObject)->accLocation(&pxLeft, &pyTop, &pcxWidth, &pcyHeight, varChild);
            @ @<控件位置.左边> = pxLeft;
            @ @<控件位置.顶边> = pyTop;
            @ @<控件位置.右边> = pxLeft + pcxWidth;
            @ @<控件位置.底边> = pyTop + pcyHeight;
        }
        否则
        {
            @ varChild.lVal = CHILDID_SELF;
            @ ((IAccessible*)@<m_self>.m_pUnknownObject)->accLocation(&pxLeft, &pyTop, &pcxWidth, &pcyHeight, varChild);
            @ @<控件位置.左边> = pxLeft;
            @ @<控件位置.顶边> = pyTop;
            @ @<控件位置.右边> = pxLeft + pcxWidth;
            @ @<控件位置.底边> = pyTop + pcyHeight;
        }
    }

    方法 导航 <公开 类型 = 逻辑型 折叠>
    参数 参数_标志 <类型 = 整数>
    参数 参数_开始元素 <类型 = Accessible无障碍类_>
    参数 参数_返回元素 <类型 = Accessible无障碍类_>
    {
        变量 varStart <类型 = COM变体型>
        变量 varEnd <类型 = COM变体型>
        varStart = 参数_开始元素.到变体型 ()
        如果 (m_id != 0)
        {
            varEnd = m_parent.方法 ("accNavigate", COM变体型, 参数_标志, varStart)
            如果 (varEnd.取类型 () == COM变体类型.COM对象)
            {
                参数_返回元素.创建自对象 (varEnd.取COM对象2 (COM对象类))
            }
            否则
            {
                参数_返回元素.创建自ID (varEnd.取值 (整数), m_parent)
            }
        }
        否则
        {
            varEnd = m_self.方法 ("accNavigate", COM变体型, 参数_标志, varStart)
            如果 (varEnd.取类型 () == COM变体类型.COM对象)
            {
                参数_返回元素.创建自对象 (varEnd.取COM对象2 (COM对象类))
            }
            否则
            {
                参数_返回元素.创建自ID (varEnd.取值 (整数), m_self)
            }
        }
        返回 (取反 (参数_返回元素.是否空 ()))
    }

    方法 命中测试 <公开 类型 = 逻辑型 折叠>
    参数 参数_左边 <类型 = 整数>
    参数 参数_顶边 <类型 = 整数>
    参数 参数_元素 <类型 = Accessible无障碍类_>
    {
        变量 var <类型 = COM变体型>
        如果 (m_id != 0)
        {
            <> var = m_parent.方法 ("accHitTest", COM变体型, 参数_左边, 参数_顶边)
        }
        否则
        {
            <> var = m_self.方法 ("accHitTest", COM变体型, 参数_左边, 参数_顶边)
        }
        如果真 (var.取类型 () == COM变体类型.空)
        {
            返回 (假)
        }
        如果真 (var.取类型 () == COM变体类型.整数值)
        {
            如果 (var.取值 (整数) == 0)
            {
                参数_元素.创建自对象 (m_self)
            }
            否则
            {
                参数_元素.创建自ID (var.取值 (整数, ), m_self)
            }
            返回 (真)
        }
        如果真 (var.取类型 () == COM变体类型.COM对象)
        {
            参数_元素.创建自对象 (var.取COM对象2 (COM对象类, ))
            返回 (真)
        }
        返回 (假)
    }

    方法 执行默认动作 <公开 折叠 @禁止流程检查 = 真>
    {
        变量 var <类型 = COM变体型>
        如果 (m_id != 0)
        {
            var.赋值 (m_id, )
            m_parent.无返回值方法 ("accDoDefaultAction", var)
        }
        否则
        {
            var.赋值 (0, )
            m_self.无返回值方法 ("accDoDefaultAction", var)
        }


        // @     HRESULT hr;
