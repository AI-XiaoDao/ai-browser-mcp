    方法 取窗口句柄 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    {
        @ IAccessible* pAccessible = nullptr;
        @ IUnknown* pUnknown = nullptr;
        @ if(@<m_id>!=0){
        @     pUnknown = @<m_parent>.m_pUnknownObject;
        @ }
        @ else {
        @     pUnknown = @<m_self>.m_pUnknownObject;
        @ }
        @ if (pUnknown != nullptr){
        @     HRESULT hr = pUnknown->QueryInterface(IID_IAccessible, (void**)&pAccessible);
        @     if (FAILED(hr) || pAccessible == nullptr){
        @         return -1;
        @     }
        @ }
        @ HWND hwnd = nullptr;
        @ if (pAccessible != nullptr){
        @     HRESULT hr = WindowFromAccessibleObject(pAccessible, &hwnd);
        @     if (FAILED(hr) || hwnd == nullptr){
        @         return -1;
        @     }
        @     pAccessible->Release();
        @ }
        @ return (INT_PTR)hwnd;
    }

