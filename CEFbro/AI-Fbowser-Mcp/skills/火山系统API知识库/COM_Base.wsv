<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"windows.COM基础\"" @视窗.外部头文件 = "<OAIdl.h>">

# @begin
#
# //=======
# // 以下几个宏，适用场景，， 条件一，必须自己手动生成 tli 和tlh文件 必须有这两个东西才能调用
#
# // 这个是用于 通过  xxx.yyy , IXXXXPtr 这两个参数来创建对象的 tlh 里面有
# // ProgID_or_REFCLSID  Microsoft.FeedsManager 或者是  __uuidof(WinHttp::WinHttpRequest)
# // _VOL_COM_TLI_DATATYPE_SMARTPTR_T  WinHttp::IWinHttpRequestPtr
# @def_macro define_vol_use_System_com_ProgID(ProgID_or_REFCLSID,_VOL_COM_TLI_DATATYPE_SMARTPTR_T) \
# <> <include>    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_T m_pvObject; \
# BOOL Init(BOOL bMutiThread = TRUE)    \
# {    \
#  HRESULT hr = S_OK;    \
#  if(bMutiThread)        \
#      hr = ::CoInitialize(nullptr);    \
#  else                    \
#      hr = ::CoInitializeEx(0, COINIT_MULTITHREADED);    \
#  hr = m_pvObject.CreateInstance(ProgID_or_REFCLSID);     \ 
#  return hr == S_OK?TRUE:FALSE;    \
# }    \
# VOID Unit()    \
# {    \
#     CoUninitialize();    \
# }    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_T pdata()    \
# {    \
#     return m_pvObject;    \
# }    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_T GetComObjPtr() \
# {    \
#     return m_pvObject;    \
# }    \
# <> </include> 
#
#
# //_REFCLSID   如果你的是大漠 你可以写 __uuidof(Dm::dmsoft)
# // _VOL_COM_TLI_DATATYPE_SMARTPTR_ 智能指针 如果你的是大漠，你可以写 Dm::IdmsoftPtr 或者 Idmsoft* 建议一般写Dm::IdmsoftPtr 因为这个无需调用 realse(); 
# @def_macro define_vol_use_com_with_registered_tlh_X86_X64(_ProgID_or_REFCLSID_X86,_ProgID_or_REFCLSID_X64,_VOL_COM_TLI_DATATYPE_SMARTPTR_X86,_VOL_COM_TLI_DATATYPE_SMARTPTR_X64) \
# <> <include>    \
# #ifdef _VOL_X64    \
#     @m<define_vol_use_System_com_ProgID>(_ProgID_or_REFCLSID_X64,_VOL_COM_TLI_DATATYPE_SMARTPTR_X64)    \
# #else    \
#     @m<define_vol_use_System_com_ProgID>(_ProgID_or_REFCLSID_X86,_VOL_COM_TLI_DATATYPE_SMARTPTR_X86)    \
# #endif    
#
#
#
# //=======
#
# //这种是用于 obj->GetObjectptr() 返回值为 IDispatchPtr 这种类型的   可以参考 msfeeds 里面有这个宏
# //这种 一般用在声明一个类，然后设置其构造函数，从而达到   @dt<数据类型>( ppvObject->GetObject()  ) 这种效果
# @def_macro vol_define_IDispatchPtr_Construct(_VOL_COM_TLI_DATATYPE_SMARTPTR_T,_IDispatchPtr) \
# <> <include> \
# void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) \
# {    \
#     m_ppObject = objCopyFrom.m_ppObject;    \
# }    \
# @sn<current_class>(_IDispatchPtr ptr) \
# {    \
#     m_ppObject = (_VOL_COM_TLI_DATATYPE_SMARTPTR_T)ptr;    \
# }    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_T m_ppObject;    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_T GetComObjPtr()    \
# {    \
#     return m_ppObject;    \
# }    \
# <> </include>
#
# @def_macro vol_define_sys_com_obj_point(ObjectTypePoint) \
# <> <include>    \
# ObjectTypePoint m_pvObject; \
# ObjectTypePoint GetObjectPoint()    {    return m_pvObject;    } \
# <> </include>
#
#
# //免注册调用系列宏======
# //同样必须 有 tli和tlh 文件
#
# //这个宏
# //@def_macro  define_LoadComDll_GetInterfacePtr(_T_REFCLSID_,_T_IID,_VOL_COM_TLI_DATATYPE_SMARTPTR_)
#
#
#
# //_T_REFCLSID_   如果你的是大漠 你可以写 __uuidof(Dm::dmsoft)   //类
# // _T_IID        如果你的是大漠 你可以写 __uuidof(Dm::Idmsoft)  //接口
# // _VOL_COM_TLI_DATATYPE_SMARTPTR_ 智能指针 如果你的是大漠，你可以写 Dm::IdmsoftPtr 或者 Idmsoft* 建议一般写Dm::IdmsoftPtr 因为这个无需调用 realse(); 
# @def_macro define_vol_use_com_without_register2(_T_REFCLSID_,_T_IID,_VOL_COM_TLI_DATATYPE_SMARTPTR_) \
# <> <include>    \
# BOOL Init(LPCTSTR lpszDLLFile,BOOL bMutiThread = TRUE)    \
# {    \
#  HRESULT hr = S_OK;    \
#  if(bMutiThread)        \
#      hr = ::CoInitialize(nullptr);    \
#  else                    \
#      hr = ::CoInitializeEx(0, COINIT_MULTITHREADED);    \
#   typedef HRESULT(__stdcall* pDllGetClassObject)(REFCLSID, REFIID, void**);    \
#   HMODULE hdllInst = LoadLibrary(lpszDLLFile);    \
#   if (hdllInst)    \
#   {    \
#    pDllGetClassObject fnDllGetClassObject = (pDllGetClassObject)GetProcAddress(hdllInst, "DllGetClassObject");    \
#    if (fnDllGetClassObject != 0)    \
#    {    \
#     HRESULT hr = (fnDllGetClassObject)(_T_REFCLSID_, IID_IClassFactory, (LPVOID*)&pClassFactory);    \
#     if (SUCCEEDED(hr) && (pClassFactory != NULL))    \
#     {    \
#        return  pClassFactory->CreateInstance(NULL, _T_IID, (void**)&m_pvObject) == S_OK ? TRUE:FALSE;    \
#      }    \
#    }    \
#   }    \
#  return FALSE;    \
# }    \
# VOID Unit()    \
# {    \
#     if (pClassFactory) pClassFactory->Release();    \
#     if (hdllInst)    FreeLibrary(hdllInst);    \
#     CoUninitialize();    \
# }    \
# _VOL_COM_TLI_DATATYPE_SMARTPTR_ GetComObjPtr() \
# {    \
#     return m_pvObject;    \
# }    \
#  HMODULE hdllInst;    \
#  IClassFactory* pClassFactory;    \
#  _VOL_COM_TLI_DATATYPE_SMARTPTR_ m_pvObject;    \
# <> </include>
#
#
# @def_macro define_vol_use_com_without_register_X86_X64(_REFCLSID_X86,_REFCLSID_X64,_IID_X86,_IID_X64,_VOL_COM_TLI_DATATYPE_SMARTPTR_X86,_VOL_COM_TLI_DATATYPE_SMARTPTR_X64) \
# <> <include>    \
# #ifdef _VOL_X64    \
#     #define _T_REFCLSID                 _REFCLSID_X64    \
#     #define _T_IID                    _IID_X64            \
#     #define _T_VOL_COM_TLI_DATATYPE_SMARTPTR_     _VOL_COM_TLI_DATATYPE_SMARTPTR_X64    \
# #else    \
#     #define _T_REFCLSID                 _REFCLSID_X86    \
#     #define _T_IID                    _IID_X86            \
#     #define _T_VOL_COM_TLI_DATATYPE_SMARTPTR_     _VOL_COM_TLI_DATATYPE_SMARTPTR_X86    \
# #endif    \
#     @m<define_vol_use_com_without_register2>(_T_REFCLSID,_T_IID,_T_VOL_COM_TLI_DATATYPE_SMARTPTR_)    \
# <> </include>    \
#
# <> </include>
#
#
#
#
#
# @end

类 IStream <公开 折叠>
{

    # @ @m<vol_define_sys_com_obj_point>(IStream*)

    方法 Seek <公开 类型 = 整数 @嵌入式方法 = "">
    参数 dlibMove <类型 = 长整数 注释 = "/* [in] */ LARGE_INTEGER dlibMove,">
    参数 dwOrigin <类型 = 整数 注释 = "/* [in] */ DWORD dwOrigin,">
    参数 输出_libNewPosition <类型 = 长整数 注释 = "/* [annotation] */  ULARGE_INTEGER *plibNewPosition">
    {
        @ @sn<this>.GetObjectPoint()->Seek((LARGE_INTEGER)@<dlibMove>,@<dwOrigin>,&@<输出_libNewPosition>)
    }

    方法 SetSize <公开 类型 = 整数 @嵌入式方法 = "">
    参数 libNewSize <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER libNewSize">
    {
        @ @sn<this>.GetObjectPoint()->SetSize((LARGE_INTEGER)@<libNewSize>)
    }

    方法 CopyTo <公开 类型 = 整数 @嵌入式方法 = "">
    参数 pstm <类型 = IStream 注释 = "/* [annotation][unique][in] */ _In_  IStream *pstm,">
    参数 cb <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER cb,">
    参数 输出_pcbRead <类型 = 长整数 注释 = "/* [annotation] */ _Out_opt_  ULARGE_INTEGER *pcbRead,">
    参数 输出_pcbWritten <类型 = 长整数 注释 = "_Out_opt_  ULARGE_INTEGER *pcbWritten)">
    {
        @ @sn<this>.GetObjectPoint()->CopyTo(@<pstm>.GetObjectPoint(),(LARGE_INTEGER)@<cb>,(ULARGE_INTEGER *)&@<输出_pcbRead>,(ULARGE_INTEGER *)&@<输出_pcbWritten>)
    }

    方法 Commit <公开 类型 = 整数 @嵌入式方法 = "">
    参数 grfCommitFlags <类型 = 整数 注释 = " /* [in] */ DWORD grfCommitFlags">
    {
        @ @sn<this>.GetObjectPoint()->SetSize((DWORD)@<grfCommitFlags>)
    }

    方法 Revert <公开 @嵌入式方法 = "">
    {
        @ @sn<this>.GetObjectPoint()->Revert()
    }

    方法 LockRegion <公开 类型 = 整数 @嵌入式方法 = "">
    参数 libOffset <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER libOffset,">
    参数 cb <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER cb,">
    参数 dwLockType <类型 = 整数 注释 = "/* [in] */ DWORD dwLockType">
    {
        @ @sn<this>.GetObjectPoint()->LockRegion((ULARGE_INTEGER)@<libOffset>,(ULARGE_INTEGER)@<cb>,(DWORD)@<dwLockType>)
    }

    方法 UnlockRegion <公开 类型 = 整数 @嵌入式方法 = "">
    参数 libOffset <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER libOffset,">
    参数 cb <类型 = 长整数 注释 = "/* [in] */ ULARGE_INTEGER cb,">
    参数 dwLockType <类型 = 长整数 注释 = "/* [in] */ DWORD dwLockType">
    {
        @ @sn<this>.GetObjectPoint()->LockRegion((ULARGE_INTEGER)@<libOffset>,(ULARGE_INTEGER)@<cb>,(DWORD)@<dwLockType>)
    }

    方法 "//Stat" <公开 类型 = 整数 @嵌入式方法 = "">
    参数 pstatstg <注释 = "/* [out] */ __RPC__out STATSTG *pstatstg,">
    参数 grfStatFlag <类型 = 整数 注释 = "/* [in] */ DWORD grfStatFlag">
    {
        @ @sn<this>.GetObjectPoint()->Stat(@<pstatstg>.pdata(),@<grfStatFlag>)
    }

    方法 Clone <公开 类型 = 整数 @嵌入式方法 = "">
    参数 ppstm <类型 = IStream 注释 = " /* [out] */ __RPC__deref_out_opt IStream **ppstm">
    {
        @ @sn<this>.GetObjectPoint()->Clone(&@<ppstm>.GetObjectPoint())
    }

    #
}

