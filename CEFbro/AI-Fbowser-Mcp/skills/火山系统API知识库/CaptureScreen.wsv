类 高速截图类 <公开 注释 = "注意，只支持Win8系统以上版本，然后好像只能再线程中用。。。再ui线程中好像截图得不到指针">
{

    # @begin
    # <> <include>
    # void* m_pData;
    # void* GetData()
    # {
    #     return m_pData;
    # }
    # void SetData(void* pData)
    # {
    #     m_pData = pData;
    # }
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ SetData( DXGICapture_new() );
    }

    方法 类_清理
    {
        @ DXGICapture_delete(GetData());
    }

    方法 创建 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ DXGICapture_Init(@sn<this>.GetData())

    }

    方法 销毁 <公开 @嵌入式方法 = "">
    {
        @ DXGICapture_UnInit(@sn<this>.GetData())
    }

    方法 快照 <公开 类型 = 字节集类 注释 = "快照整个屏幕 得到的只是像素数据 ARGB 四个通道的像素数据" @禁止流程检查 = 真>
    {
        @ BOOL bOK = DXGICapture_CaptureImage(GetData());
        @ if(!bOK) return CVolMem();
        @ void* pData = DXGICapture_GetBuffer(GetData());
        @ if(!pData) return CVolMem();
        @ return CVolMem(pData,DXGICapture_GetBufferSize(GetData()));
    }

    方法 快照返回指针 <公开 类型 = 变整数 注释 = "快照整个屏幕 得到的只是像素数据 ARGB 四个通道的像素数据" @禁止流程检查 = 真>
    {
        @ BOOL bOK = DXGICapture_CaptureImage(GetData());
        @ if(!bOK) return NULL;
        @ void* pData = DXGICapture_GetBuffer(GetData());
        @ if(!pData) return NULL;
        @ return (INT_P)pData;
    }

    方法 取快照指针大小 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ DXGICapture_GetBufferSize(@sn<this>.GetData())
    }

    #
}

类 快照D3D类 <公开 折叠>
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     D3DShotTool_CopyConstruct(m_data,objCopyFrom.m_data);
    # }
    # void SetData(void* pData)
    # {
    #     m_data = pData;
    # }
    # void* GetData()
    # {
    #     return m_data;
    # }
    # void* m_data;
    # <> </include>
    # @end

    方法 类_初始化 <折叠>
    {
        @ SetData(D3DShotTool_new ());
    }

    方法 类_清理 <折叠>
    {
        @ D3DShotTool_delete(GetData());
    }

    方法 创建 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ D3DShotTool_Create(@sn<this>.GetData(),(HWND)@<窗口句柄>)

    }

    方法 销毁 <公开 @嵌入式方法 = "">
    {
        @ D3DShotTool_Destory(@sn<this>.GetData())
    }

    方法 取位图数据 <公开 类型 = 字节集类 注释 = "得到的是一个32位位图 文件的数据" @禁止流程检查 = 真>
    参数 横向位置 <类型 = 整数 @默认值 = 0>
    参数 纵向位置 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "表示 窗口句柄 宽度" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "表示 窗口句柄 宽度" @默认值 = 0>
    参数 是否反向 <类型 = 逻辑型 @默认值 = 真>
    {
        @ void* pBuffer = NULL;
        @ int nBufferSize = 0;
        @ D3DShotTool_GetBMP(GetData(),@<横向位置>,@<纵向位置>,@<宽度>,@<高度>,&pBuffer,&nBufferSize,@<是否反向>);
        @ if(!pBuffer)
        @   return CVolMem();
        @ CVolMem mem((const char*)pBuffer,nBufferSize);
        @ return mem;

    }

    方法 取像素数据 <公开 类型 = 字节集类 注释 = "得到的是像素数据" @禁止流程检查 = 真>
    参数 横向位置 <类型 = 整数 @默认值 = 0>
    参数 纵向位置 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "表示 窗口句柄 宽度" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "表示 窗口句柄 宽度" @默认值 = 0>
    {
        @ void* pBuffer = NULL;
        @ int nBufferSize = 0;
        @ D3DShotTool_GetPix(GetData(),@<横向位置>,@<纵向位置>,@<宽度>,@<高度>,&pBuffer,&nBufferSize);
        @ if(!pBuffer)
        @   return CVolMem();
        @ CVolMem mem((const char*)pBuffer,nBufferSize);
        @ return mem;

    }

    #
}
