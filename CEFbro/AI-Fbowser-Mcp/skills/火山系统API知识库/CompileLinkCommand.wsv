类 ______条件编译 <公开 注释 = "这个一般用途有两个，第一，比如免费版和付费版软件，某些功能不编译进去，第二，系统定义的一些宏，可以用，" 折叠 @全局类 = 真>
{
    方法 条件编译_用户定义 <公开 静态 @嵌入式方法 = "name = \"voldefine\"\r\nno_end_sem = true">
    参数 条件 <@匹配类型 = 所有类型>
    {
        @ #define vol_condithion_@<条件>
    }

    方法 条件编译_如果用户定义 <公开 静态
            @嵌入式方法 = "name = \"volifdef\"\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nhas_body = true\r\nnext  = \"volelse,volendif\"">
    参数 条件 <@匹配类型 = 所有类型>
    {
        @ #ifdef vol_condithion_@<条件>
    }

    方法 条件编译_如果已定义宏 <公开 静态
            @嵌入式方法 = "name = \"volifdef_noPre\"\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nhas_body = true\r\nnext  = \"volelse,volendif\"">
    参数 条件 <@匹配类型 = 所有类型>
    {
        @ #ifdef @<条件>
    }

    方法 条件编译_否则 <公开 静态
            @嵌入式方法 = "name = \"volelse\"\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nhas_body = true\r\nnext  = \"volendif\"\r\nprev = \"volifdef,volifdef_noPre\"">
    {
        @ #else
    }

    方法 条件编译_结束 <公开 静态 @嵌入式方法 = "name = \"volendif\"\r\nprev = \"volelse,volifdef,volifdef_noPre\"\r\nno_end_sem = true">
    {
        @ #endif
    }

    #
}

类 "//条件编译测试"
{
    方法 开始测试 <公开 类型 = 整数 折叠>
    {
        // 在此处填入自己的代码
        条件编译_用户定义 (宏编译条件常量类.正式版)

        条件编译_如果用户定义 (宏编译条件常量类.正式版)
        {

            调试输出 ("正式版")

        }
        条件编译_否则 ()
        {

            调试输出 ("测试版")

        }
        条件编译_结束 ()


        条件编译_如果已定义宏 (宏定义_WIN64 ())
        {


            调试输出 ("64")

        }
        条件编译_否则 ()
        {

            调试输出 ("32")

        }
        条件编译_结束 ()



        返回 (0)
    }

    方法 宏定义_WIN64 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    {
        @ _WIN64
    }
}

类 "//宏编译条件常量类" <公开 注释 = "条件编译测试 用到的常量" 折叠 @常量类 = 整数>
{
    常量 正式版 <公开 值 = 1>
    常量 测试版 <公开 值 = 2>
    常量 调试版 <公开 值 = 3>

    #
}
