    方法 取时间戳间隔 <公开 静态 类型 = 长整数 注释 = "会用 时间戳2  -  时间戳1" 折叠>
    参数 时间戳1 <类型 = 长整数>
    参数 时间戳2 <类型 = 长整数>
    参数 间隔常量 <类型 = 时间间隔常量>
    {

        变量 临时时间戳1 <类型 = 长整数>
        变量 临时时间戳2 <类型 = 长整数>

        如果 (时间戳1 > 999999999)
        {
            临时时间戳1 = 时间戳1 / 1000
        }
        否则
        {
            临时时间戳1 = 时间戳1
        }

        如果 (时间戳2 > 999999999)
        {
            临时时间戳2 = 时间戳2 / 1000
        }
        否则
        {
            临时时间戳2 = 时间戳2
        }

        如果 (间隔常量 == 时间间隔常量.分)
        {
            返回 (秒转分钟 (临时时间戳2 - 临时时间戳1))
        }
        否则 (间隔常量 == 时间间隔常量.时)
        {
            返回 (秒转小时 (临时时间戳2 - 临时时间戳1))
        }
        否则 (间隔常量 == 时间间隔常量.秒)
        {
            返回 (临时时间戳2 - 临时时间戳1)
        }
        否则 (间隔常量 == 时间间隔常量.日)
        {
            返回 (秒转天 (临时时间戳2 - 临时时间戳1))
        }

        返回 (0)

    }

    方法 取时间戳间隔_格式化文本 <公开 静态 类型 = 文本型 注释 = "只支持10位的时间戳   时间戳2  -  时间戳1" 折叠>
    参数 时间戳1 <类型 = 长整数>
    参数 时间戳2 <类型 = 长整数>
    {
        返回 (秒格式化 (时间戳2 - 时间戳1))

    }

    方法 秒格式化 <公开 静态 类型 = 文本型 折叠>
    参数 秒 <类型 = 长整数>
    {
        变量 余数 <类型 = 长整数>
        变量 天 <类型 = 长整数>
        变量 小时 <类型 = 长整数>
        变量 分钟 <类型 = 长整数>
        变量 秒钟 <类型 = 长整数>
        余数 = 秒
        天 = 余数 / (1 * 24 * 60 * 60)
        余数 = 余数 % (1 * 24 * 60 * 60)
        小时 = 余数 / (1 * 60 * 60)
        余数 = 余数 % (1 * 60 * 60)
        分钟 = 余数 / 60
        余数 = 余数 % 60
        秒钟 = 余数
        返回 (到文本 (天) + "天" + 到文本 (小时) + "时" + 到文本 (分钟) + "分" + 到文本 (秒钟) + "秒")




    }

    方法 秒转天 <公开 静态 类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / (1 * 24 * 60 * 60))
    }

    方法 秒转小时 <公开 静态 类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
