    方法 时间戳转时间 <公开 静态 类型 = 文本型 注释 = "只支持10位时间戳" 折叠 @禁止流程检查 = 真>
    参数 时间戳 <类型 = 长整数>
    参数 时间格式 <类型 = 文本型 @默认值 = "%Y-%m-%d %H:%M:%S">
    {
        @ const TCHAR* lpFormat = (const TCHAR*)@<时间格式>;
        @ time_t t = @<时间戳>;
        @  TCHAR str_time[100];
        @  struct tm* local_time = localtime(&t);
        @  _tcsftime(str_time, sizeof(str_time), lpFormat, local_time);
        @ return str_time;

    }

    方法 取格林时间 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @  time_t rawTime;
        @     struct tm* timeInfo;
        @     TCHAR szTemp[30]={0};
        @     time(&rawTime);
        @     timeInfo = gmtime(&rawTime);
        @  _tcsftime(szTemp,sizeof(szTemp),_T("%a, %d %b %Y %H:%M:%S GMT"),timeInfo);
        @ return szTemp; 


    }

    方法 取格林时间时间戳 <公开 静态 类型 = 长整数 注释 = "10位" 折叠 @禁止流程检查 = 真>
    {
