    方法 时间_生成时间戳 <公开 静态 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数>
    参数 日 <类型 = 整数>
    参数 时 <类型 = 整数>
    参数 分 <类型 = 整数>
    参数 秒 <类型 = 整数>
    {
        @     tm tm_; 
        @     tm_.tm_year = @<年> - 1900;                 // 年,由于tm结构体存储的是从1900年开始的时间,所以tm_year为int临时变量减去1900。
        @     tm_.tm_mon = @<月> - 1;                    // 月,由于tm结构体的月份存储范围为0-11,所以tm_mon为int临时变量减去1。
        @     tm_.tm_mday = @<日>;                         // 日。
        @     tm_.tm_hour = @<时>;                        // 时。
        @     tm_.tm_min = @<分>;                       // 分。
        @     tm_.tm_sec = @<秒>;                       // 秒。
        @     tm_.tm_isdst = 0;                          // 非夏令时。
        @     time_t t_ = mktime(&tm_);                  // 将tm结构体转换成time_t格式。
        @   return t_;
    }

    方法 时间_日期时间转时间戳 <公开 静态 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 年月日时分秒 <类型 = 文本型 注释 = "2020-07-19 13:14:00">
    参数 格式 <类型 = 文本型 注释 = "%d-%d-%d %d:%d:%d" @默认值 = "%d-%d-%d %d:%d:%d">
    {
        @     const TCHAR *cha = (const TCHAR*)@<年月日时分秒>;             // 将string转换成char*。
        @      const TCHAR *pFormat = (const TCHAR*)@<格式>;
        @     tm tm_;                                    // 定义tm结构体。
        @     int year, month, day, hour, minute, second;// 定义时间的各个int临时变量。
        @     swscanf(cha, pFormat, &year, &month, &day, &hour, &minute, &second);// 将string存储的日期时间,转换为int临时变量。
        @     tm_.tm_year = year - 1900;                 // 年,由于tm结构体存储的是从1900年开始的时间,所以tm_year为int临时变量减去1900。
        @     tm_.tm_mon = month - 1;                    // 月,由于tm结构体的月份存储范围为0-11,所以tm_mon为int临时变量减去1。
        @     tm_.tm_mday = day;                         // 日。
        @     tm_.tm_hour = hour;                        // 时。
        @     tm_.tm_min = minute;                       // 分。
        @     tm_.tm_sec = second;                       // 秒。
        @     tm_.tm_isdst = 0;                          // 非夏令时。
        @     time_t t_ = mktime(&tm_);                  // 将tm结构体转换成time_t格式。
        @     return t_;                                 // 返回值。

    }

    方法 时间_取时间间隔f <公开 静态 类型 = 长整数>
    参数 参数时间1 <类型 = 文本型 注释 = "\"2020-7-22 16:54:25\"">
    参数 参数时间2 <类型 = 文本型 注释 = "\"2020-7-23 16:54:25\"">
    参数 间隔常量 <类型 = 时间间隔常量>
    参数 时间格式1 <类型 = 文本型 注释 = "参数1 和参数2的格式  %d-%d-%d %d:%d:%d" @默认值 = "%u-%u-%u %u:%u:%u">
    参数 时间格式2 <类型 = 文本型 注释 = "参数1 和参数2的格式  %d-%d-%d %d:%d:%d" @默认值 = "%u-%u-%u %u:%u:%u">
    {
        变量 时间1 <类型 = 长整数>
