        时间1 = 时间_日期时间转时间戳 (参数时间1, 时间格式1)
        时间2 = 时间_日期时间转时间戳 (参数时间2, 时间格式2)
        // 调试输出 (时间1, 时间2)
        返回 (时间_取时间戳间隔f (时间1, 时间2, 间隔常量))
    }

    方法 时间_取时间间隔_格式文本 <公开 静态 类型 = 文本型 注释 = "格式化后的文本位  1天10时10分10秒" 折叠>
    参数 参数时间1 <类型 = 文本型 注释 = "\"2020-7-22 16:54:25\"">
    参数 参数时间2 <类型 = 文本型 注释 = "\"2020-7-23 16:54:25\"">
    参数 时间格式1 <类型 = 文本型 注释 = "参数1 和参数2的格式  %d-%d-%d %d:%d:%d" @默认值 = "%d-%d-%d %d:%d:%d">
    参数 时间格式2 <类型 = 文本型 注释 = "参数1 和参数2的格式  %d-%d-%d %d:%d:%d" @默认值 = "%d-%d-%d %d:%d:%d">
    {
        变量 时间差 <类型 = 长整数>
        时间差 = 时间_取时间间隔f (参数时间1, 参数时间2, 时间间隔常量.秒, 时间格式1, 时间格式2)
        返回 (秒格式化 (时间差))

    }

    方法 时间_取时间戳间隔f <公开 静态 类型 = 长整数 注释 = "会用 时间戳2  -  时间戳1">
    参数 时间戳1 <类型 = 长整数>
    参数 时间戳2 <类型 = 长整数>
    参数 间隔常量 <类型 = 时间间隔常量>
    {

        变量 临时时间戳1 <类型 = 长整数>
        变量 临时时间戳2 <类型 = 长整数>

        如果 (时间戳1 > 9999999999)
        {
            临时时间戳1 = 时间戳1 / 1000
        }
        否则
        {
            临时时间戳1 = 时间戳1
        }

        如果 (时间戳2 > 9999999999)
        {
            临时时间戳2 = 时间戳2 / 1000
        }
        否则
        {
            临时时间戳2 = 时间戳2
        }

        如果 (间隔常量 == 时间间隔常量.分)
        {
            返回 (秒转分钟 (临时时间戳2 - 临时时间戳1))
        }
        否则 (间隔常量 == 时间间隔常量.时)
        {
            返回 (秒转小时 (临时时间戳2 - 临时时间戳1))
        }
        否则 (间隔常量 == 时间间隔常量.秒)
        {
            // 调试输出 ("000", 临时时间戳2, 临时时间戳1)

            返回 (临时时间戳2 - 临时时间戳1)
        }
        否则 (间隔常量 == 时间间隔常量.日)
        {
            返回 (秒转天 (临时时间戳2 - 临时时间戳1))
        }

        返回 (0)

    }

    方法 时间_取时间戳间隔_格式化文本 <类型 = 文本型 注释 = "只支持10位的时间戳   时间戳2  -  时间戳1" 折叠>
    参数 时间戳1 <类型 = 长整数>
    参数 时间戳2 <类型 = 长整数>
    {
        返回 (秒格式化 (时间戳2 - 时间戳1))

    }

    方法 秒格式化 <静态 类型 = 文本型 折叠>
    参数 秒 <类型 = 长整数>
    {
        变量 余数 <类型 = 长整数>
        变量 天 <类型 = 长整数>
        变量 小时 <类型 = 长整数>
        变量 分钟 <类型 = 长整数>
        变量 秒钟 <类型 = 长整数>
        余数 = 秒
        天 = 余数 / (1 * 24 * 60 * 60)
        余数 = 余数 % (1 * 24 * 60 * 60)
        小时 = 余数 / (1 * 60 * 60)
        余数 = 余数 % (1 * 60 * 60)
        分钟 = 余数 / 60
        余数 = 余数 % 60
        秒钟 = 余数
        返回 (到文本 (天) + "天" + 到文本 (小时) + "时" + 到文本 (分钟) + "分" + 到文本 (秒钟) + "秒")




    }

    方法 秒转天 <静态 类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / (1 * 24 * 60 * 60))
    }

    方法 秒转小时 <静态 类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / (1 * 60 * 60))
    }

    方法 秒转分钟 <静态 类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / 60)


    }

    方法 时间_是否已经过了24点 <公开 静态 类型 = 逻辑型 注释 = "函数必须 隔一段时间调用一次，比如隔一秒，一分钟或者更长时间 调用一次">
    {
        变量 最后一次星期几 <静态 类型 = 整数 值 = -1>
        如果 (最后一次星期几 == -1)
        {
            最后一次星期几 = 时间_取星期几 ()
            返回 (假)
        }

        如果 (最后一次星期几 != 时间_取星期几 ())
        {
            最后一次星期几 = 时间_取星期几 ()
            返回 (真)
        }

        返回 (假)



    }
}

类 时间_全局类 <公开>
{
    方法 取现行时间戳13位_文本 <公开 静态 类型 = 文本型 注释 = "13位 到毫秒" 折叠 @禁止流程检查 = 真>
    {
