    方法 时间_时间戳转时间 <公开 静态 类型 = 文本型 注释 = "只支持10位时间戳" 折叠 @禁止流程检查 = 真>
    参数 时间戳 <类型 = 长整数>
    参数 时间格式 <类型 = 文本型 @默认值 = "%Y-%m-%d %H:%M:%S">
    {
        @ const TCHAR* lpFormat = (const TCHAR*)@<时间格式>;
        @ time_t t = @<时间戳>;
        @  TCHAR str_time[100];
        @  struct tm* local_time = localtime(&t);
        @  _tcsftime(str_time, sizeof(str_time), lpFormat, local_time);
        @ return str_time;

    }

    方法 时间_取格林时间f <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @  time_t rawTime;
        @     struct tm* timeInfo;
        @     TCHAR szTemp[30]={0};
        @     time(&rawTime);
        @     timeInfo = gmtime(&rawTime);
        @  _tcsftime(szTemp,sizeof(szTemp),_T("%a, %d %b %Y %H:%M:%S GMT"),timeInfo);
        @ return szTemp; 


    }

    方法 时间_取格林时间时间戳 <公开 静态 类型 = 长整数 注释 = "10位" 折叠 @禁止流程检查 = 真>
    {
        @  time_t rawTime;
        @     struct tm* timeInfo;
        @     TCHAR szTemp[30]={0};
        @     time(&rawTime);
        @     timeInfo = gmtime(&rawTime);
        @  return   mktime(timeInfo);

    }

    方法 时间_格林时间转时间戳 <公开 静态 类型 = 长整数>
    参数 格林时间文本 <类型 = 文本型 注释 = "必须时这种格式 Thu, 23 Jul 2020 06:04:11 GMT 其他格式解析不了">
    参数 是否转换成北京时间 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 临时文本 <类型 = 文本型>
        // Tue May 07 2019 10:20:56 GMT+0800 (中国标准时间)
        // Thu, 23 Jul 2020 06:04:11 GMT
        // 如果有 +0800 先体会掉

        // 星期一 Mon.(全称Monday)
        // 星期二 Tues.(全称Tuesday)
        // 星期三 Wed.(全称Wednesday)
        // 星期四 Thur.(全称Thursday)
        // 星期五 Fri.(全称Friday)
        // 星期六 Sat.(全程Saturday)
        // 星期日 Sun.(全称Sunday)
        临时文本 = 格林时间文本

        // 第一步 去掉星期几
        子文本替换 (临时文本, "Mon", "")
        子文本替换 (临时文本, "Tue", "")
        子文本替换 (临时文本, "Wed", "")
        子文本替换 (临时文本, "Thu", "")
        子文本替换 (临时文本, "Fri", "")
        子文本替换 (临时文本, "Sat", "")
        子文本替换 (临时文本, "Sun", "")

        // 如果有逗号 就去掉
        子文本替换 (临时文本, ",", "")

        // 处理月份
        子文本替换 (临时文本, "Jan", "01")
        子文本替换 (临时文本, "Feb", "02")
        子文本替换 (临时文本, "Mar", "03")
        子文本替换 (临时文本, "Apr", "04")
        子文本替换 (临时文本, "May", "05")
        子文本替换 (临时文本, "Jun", "06")
        子文本替换 (临时文本, "Jul", "07")
        子文本替换 (临时文本, "Aug", "08")
        子文本替换 (临时文本, "Sep", "09")
        子文本替换 (临时文本, "Oct", "10")
        子文本替换 (临时文本, "Nov", "11")
        子文本替换 (临时文本, "Dec", "12")

        // 处理GMT 字符串
        子文本替换 (临时文本, "GMT", "")

        // 去掉加东八区
        子文本替换 (临时文本, "+0800", "")

        // 如果有 PM 和 AM 也要干掉
        子文本替换 (临时文本, "AM", "", 0, -1, 假)
        子文本替换 (临时文本, "PM", "", 0, -1, 假)


        删首尾空 (临时文本)


        // 得到  23 Jul 2020 06:04:11
        如果 (是否转换成北京时间)
        {
            返回 (_时间_格林时间转北京时间戳 (临时文本) + 8 * 60 * 60)
        }
        否则
        {
            返回 (_时间_格林时间转北京时间戳 (临时文本))
        }










    }

    方法 时间_格林时间转北京时间 <公开 静态 类型 = 文本型>
    参数 格林时间文本 <类型 = 文本型 注释 = "必须时这种格式 Thu, 23 Jul 2020 06:04:11 GMT">
    参数 北京时间格式 <类型 = 文本型 @默认值 = "%Y-%m-%d %H:%M:%S">
    {
        变量 时间戳 <类型 = 长整数>
        // 'Tue May 07 2019 10:20:56 GMT+0800
        时间戳 = 时间_格林时间转时间戳 (格林时间文本, 真)
        返回 (时间_时间戳转时间 (时间戳, 北京时间格式))





    }

    方法 _时间_格林时间转北京时间戳 <静态 类型 = 长整数 @禁止流程检查 = 真>
    参数 年月日时分秒 <类型 = 文本型 注释 = "23 Jul 2020 06:04:11">
    参数 格式 <类型 = 文本型 注释 = "%d %d %d %d:%d:%d" @默认值 = "%d %d %d %d:%d:%d">
    {
        @     const TCHAR *cha = (const TCHAR*)@<年月日时分秒>;             // 将string转换成char*。
        @      const TCHAR *pFormat = (const TCHAR*)@<格式>;
        @     tm tm_;                                    // 定义tm结构体。
        @     int year, month, day, hour, minute, second;// 定义时间的各个int临时变量。
        @     swscanf(cha, pFormat, &day, &month, &year, &hour, &minute, &second);// 将string存储的日期时间,转换为int临时变量。
        @     tm_.tm_year = year - 1900;                 // 年,由于tm结构体存储的是从1900年开始的时间,所以tm_year为int临时变量减去1900。
        @     tm_.tm_mon = month - 1;                    // 月,由于tm结构体的月份存储范围为0-11,所以tm_mon为int临时变量减去1。
        @     tm_.tm_mday = day;                         // 日。
        @     tm_.tm_hour = hour;                        // 时。
        @     tm_.tm_min = minute;                       // 分。
        @     tm_.tm_sec = second;                       // 秒。
        @     tm_.tm_isdst = 0;                          // 非夏令时。
        @     time_t t_ = mktime(&tm_);                  // 将tm结构体转换成time_t格式。
        @     return t_;                                 // 返回值。

    }

    方法 时间_取年月日 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 格式 <类型 = 文本型 @默认值 = "%u-%u-%u">
    {
        @  TCHAR szBuffer[256];
        @  SYSTEMTIME st;
        @  ::GetLocalTime(&st);
        @  ::wsprintf(szBuffer, @<格式>,
        @   st.wYear, st.wMonth, st.wDay);
        @ return szBuffer;


    }

