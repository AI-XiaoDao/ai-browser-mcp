    #
    #

    方法 字节集到十进制文本_无符号 <公开 静态 类型 = 文本型>
    参数 要格式化的数据 <类型 = 字节集类>
    参数 分隔符 <类型 = 文本型 @默认值 = ",">
    {
        变量 格式化后的文本 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 字节集长度 <类型 = 整数>
        变量 c <类型 = 字节>
        置文本预分配字符数 (格式化后的文本, 取字节集长度 (要格式化的数据) * 4)
        字节集长度 = 要格式化的数据.取字节集长度 ()
        循环 (0, 字节集长度, i)
        {
            c = 要格式化的数据.取字节集数据 (i, 字节)
            如果 (i + 1 == 字节集长度)
            {
                加入格式文本 (格式化后的文本, "%u", 字节到无符号整数 (c))
            }
            否则
            {
                加入格式文本 (格式化后的文本, "%u%s", 字节到无符号整数 (c), 分隔符)
            }
        }
        返回 (格式化后的文本)



    }

    方法 十进制文本到字节集 <公开 静态 类型 = 字节集类>
    参数 十进制文本 <类型 = 文本型 注释 = "类似这样 1,2,3 或者 -1,-2,3 可以处理有符号和无符号">
    参数 分隔符 <类型 = 文本型 @默认值 = ",">
    {
        变量 文本数组 <类型 = 文本数组类>
        变量 返回值 <类型 = 字节集类>
        变量 字节值 <类型 = 字节>
        分割子文本 (十进制文本, 分隔符, 文本数组)
        返回值.置字节集预分配尺寸 (文本数组.取成员数 ())

        文本数组.枚举循环 ()
        {
            字节值 = (字节)文本到整数 (文本数组.取枚举值 ())
            返回值.添加值到字节集 (字节值)
        }
        返回 (返回值)

    }

    方法 字节到无符号整数 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 数据 <类型 = 字节>
    {
        @ (unsigned char)@<数据>
    }

    方法 字节集到十进制文本_有符号 <公开 静态 类型 = 文本型 折叠>
    参数 要格式化的数据 <类型 = 字节集类>
    {
        变量 格式化后的文本 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 字节集长度 <类型 = 整数>
        置文本预分配字符数 (格式化后的文本, 取字节集长度 (要格式化的数据) * 4)
        字节集长度 = 要格式化的数据.取字节集长度 ()
        循环 (0, 字节集长度, i)
        {
            如果 (i + 1 == 字节集长度)
            {
                加入格式文本 (格式化后的文本, "%d", 要格式化的数据.取字节集数据 (i, 字节))
            }
            否则
            {
                加入格式文本 (格式化后的文本, "%d,", 要格式化的数据.取字节集数据 (i, 字节))
            }
        }
        返回 (格式化后的文本)

    }

    #
}
