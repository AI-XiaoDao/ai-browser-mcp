<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" @文档 = "category = \"windows.编码转换\"">

类 代码页常量 <公开 @常量类 = 整数>
{
    常量 CP_ACP <公开 值 = @CP_ACP 注释 = " ANSI code page">
    常量 CP_MACCP <公开 值 = @CP_MACCP 注释 = " Macintosh code page">
    常量 CP_OEMCP <公开 值 = @CP_OEMCP 注释 = " OEM code page">
    常量 CP_SYMBOL <公开 值 = @CP_SYMBOL 注释 = "Windows 2000/XP: Symbol code page (42)">
    常量 CP_THREAD_ACP <公开 值 = @CP_THREAD_ACP 注释 = " Windows 2000/XP: The current thread\'s ANSI code page">
    常量 CP_UTF7 <公开 值 = @CP_UTF7 注释 = " Windows 98/Me, Windows NT 4.0 and later: Translate using UTF-7">
    常量 CP_UTF8 <值 = @CP_UTF8 注释 = " Windows 98/Me, Windows NT 4.0 and later: Translate using UTF-8."
            注释 = " When this is set, dwFlags must be zero.">
}

类 ______编码转换辅助函数base64 <公开 注释 = "https://github.com/littlstar/b64.c" @全局类 = 真 @视窗.外部头文件 = "Encodec\\b64.c-master\\b64.h"
        @视窗.外部源文件 = "Encodec\\b64.c-master\\buffer.c\nEncodec\\b64.c-master\\decode.c\nEncodec\\b64.c-master\\encode.c">
{
    方法 编码_BASE64编码 <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        变量 字节集指针 <类型 = 变整数>
        变量 字节集长度 <类型 = 整数>
        字节集指针 = 数据.取字节集指针 ()
        字节集长度 = 数据.取字节集长度 ()
        @ size_t desLen = 0;
        @ char* lpText = b64_encode((const unsigned char *)@<字节集指针>,@<字节集长度>,&desLen);
        @ CVolString str(lpText);
        @ free(lpText);
        @ return str;
    }

    方法 编码_BASE64解码 <公开 静态 类型 = 字节集类 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        变量 ASCII文本 <类型 = 字节集类>
        ASCII文本 = 编码_Unicode转Ascii (数据, 取文本长度 (数据))
        变量 字节集指针 <类型 = 变整数>
        变量 字节集长度 <类型 = 整数>
        字节集指针 = ASCII文本.取字节集指针 ()
        字节集长度 = ASCII文本.取字节集长度 ()
        @  size_t nDecSize = 0;
        @  unsigned char * lpBuffer = b64_decode_ex((const char *)@<字节集指针>,@<字节集长度>,&nDecSize);
        @ CVolMem mem(lpBuffer,nDecSize);
        @ free(lpBuffer);
        @ return mem;




    }

    方法 编码_BASE64编码Ex <公开 静态 类型 = 字节集类 注释 = "直接返回 多字节集的文本" @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        变量 字节集指针 <类型 = 变整数>
        变量 字节集长度 <类型 = 整数>
        变量 ""
        字节集指针 = 数据.取字节集指针 ()
        字节集长度 = 数据.取字节集长度 ()
        @ size_t desLen = 0;
        @ char* lpText = b64_encode((const unsigned char *)@<字节集指针>,@<字节集长度>,&desLen);
        @ CVolMem str(lpText,desLen);
        @ free(lpText);
        @ return str;
    }

    方法 编码_BASE64解码Ex <公开 静态 类型 = 字节集类 注释 = "直接从多字节集文本解码" @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        变量 字节集指针 <类型 = 变整数>
        变量 字节集长度 <类型 = 整数>
        字节集指针 = 数据.取字节集指针 ()
        字节集长度 = 数据.取字节集长度 ()
        @  size_t nDecSize = 0;
        @  unsigned char * lpBuffer = b64_decode_ex((const char *)@<字节集指针>,@<字节集长度>,&nDecSize);
        @ CVolMem mem(lpBuffer,nDecSize);
        @ free(lpBuffer);
        @ return mem;




    }

    #
    #
}

类 ______编码转换辅助函数 <公开 注释 = "https://blog.csdn.net/yf210yf/article/details/7850472" @全局类 = 真 @禁止继承 = 真 @禁止创建对象 = 真
        @视窗.外部头文件 = "Encodec\\EncodecTest\\Encodec.h" @视窗.外部源文件 = "Encodec\\EncodecTest\\Encodec.cpp">
{

    #

    方法 _编码_GB2312转Unicode_从指针 <公开 静态 类型 = 文本型 注释 = "的ascii字符串，必须指定长度" 折叠 @禁止流程检查 = 真>
    参数 lpMultiByteStr <类型 = 变整数>
    参数 cbMultiByte <类型 = 整数 注释 = "如果为-1，则系统会自动计算 lpMultiByteStr 指向的文本长度" 注释 = "如果为-1 ，那么lpMultiByteStr 指向的必须是以0结尾的字符串"
            注释 = "否则会不准确，比如你申请了4个字节内存，读取了4个字符，" 注释 = "此时系统内部无法判断你这个到底是多长的字符串，就会出去乱码" @默认值 = -1>
    {
        @  int textlen = 0;
        @  wchar_t * result;
        @  textlen = MultiByteToWideChar(936, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,NULL,0 );  
        @  result = (wchar_t *)malloc((textlen+1)*sizeof(wchar_t));
        @  result[textlen] = L'\0';
        @  MultiByteToWideChar(936, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,result,textlen);  
        @  @an<CVolString> str = result;
        @  free (result);
        @ return str;
    }

    方法 _编码_Uicode转GB2312_从指针 <公开 静态 类型 = 字节集类 折叠>
    参数 lpWideCharStr <类型 = 变整数>
    参数 cchWideChar <类型 = 整数 @默认值 = -1>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( 936,0,(LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,NULL, 0, NULL, NULL );
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( 936, 0, (LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,(LPSTR)@<MemBuf>.GetPtr(),  @<textlen>, NULL, NULL );
        返回 (MemBuf)

    }

    #

    方法 _编码_Big5转Unicode_从指针 <公开 静态 类型 = 文本型 注释 = "的ascii字符串，必须指定长度" 折叠 @禁止流程检查 = 真>
    参数 lpMultiByteStr <类型 = 变整数>
    参数 cbMultiByte <类型 = 整数 注释 = "如果为-1，则系统会自动计算 lpMultiByteStr 指向的文本长度" 注释 = "如果为-1 ，那么lpMultiByteStr 指向的必须是以0结尾的字符串"
            注释 = "否则会不准确，比如你申请了4个字节内存，读取了4个字符，" 注释 = "此时系统内部无法判断你这个到底是多长的字符串，就会出去乱码" @默认值 = -1>
    {
        @  int textlen = 0;
        @  wchar_t * result;
        @  textlen = MultiByteToWideChar(950, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,NULL,0 );  
        @  result = (wchar_t *)malloc((textlen+1)*sizeof(wchar_t));
        @  result[textlen] = L'\0';
        @  MultiByteToWideChar(950, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,result,textlen);  
        @  @an<CVolString> str = result;
        @  free (result);
        @ return str;
    }

    方法 _编码_Uicode转Big5_从指针 <公开 静态 类型 = 字节集类 折叠>
    参数 lpWideCharStr <类型 = 变整数>
    参数 cchWideChar <类型 = 整数 @默认值 = -1>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( 950,0,(LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,NULL, 0, NULL, NULL );
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( 950, 0, (LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,(LPSTR)@<MemBuf>.GetPtr(),  @<textlen>, NULL, NULL );
        返回 (MemBuf)

    }

    #
    #
    #

    方法 _编码_utf8转Unicode_从指针 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 lpMultiByteStr <类型 = 变整数>
    参数 cbMultiByte <类型 = 整数 注释 = "如果为-1，则系统会自动计算 lpMultiByteStr 指向的文本长度" 注释 = "如果为-1 必须是以0结尾的字符串" @默认值 = -1>
    {
        // int MultiByteToWideChar(
        // UINT CodePage,         // code page
        // DWORD dwFlags,         // character-type options
        // LPCSTR lpMultiByteStr, // string to map
        // int cbMultiByte,       // number of bytes in string
        // LPWSTR lpWideCharStr,  // wide-character buffer
        // int cchWideChar        // size of buffer);
        @  int textlen = 0;
        @  wchar_t* result;
        @  textlen = ::MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,NULL,0 );  
        @  result =  new wchar_t[textlen+1];
        @  textlen = ::MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,result,textlen);
        @  result[textlen] = L'\0';
        @  @an<CVolString> str(result);
        @  delete [] result;
        @  result = NULL;
        @  free (result);
        @ return str;
    }

    方法 _编码_Ascii转Unicode_从指针 <公开 静态 类型 = 文本型 注释 = "的ascii字符串，必须指定长度" 折叠 @禁止流程检查 = 真>
    参数 lpMultiByteStr <类型 = 变整数>
    参数 cbMultiByte <类型 = 整数 注释 = "如果为-1，则系统会自动计算 lpMultiByteStr 指向的文本长度" 注释 = "如果为-1 ，那么lpMultiByteStr 指向的必须是以0结尾的字符串"
            注释 = "否则会不准确，比如你申请了4个字节内存，读取了4个字符，" 注释 = "此时系统内部无法判断你这个到底是多长的字符串，就会出去乱码" @默认值 = -1>
    {
        @  int textlen = 0;
        @  wchar_t * result;
        @  textlen = MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,NULL,0 );  
        @  result = (wchar_t *)malloc((textlen+1)*sizeof(wchar_t));
        @  result[textlen] = L'\0';
        @  MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<lpMultiByteStr>,@<cbMultiByte>,result,textlen);  
        @  @an<CVolString> str = result;
        @  free (result);
        @ return str;

    }

    方法 _编码_Unicode转Utf8_从指针 <公开 静态 类型 = 字节集类 注释 = "结尾带0" 折叠 "">
    参数 lpWideCharStr <类型 = 变整数>
    参数 cchWideChar <类型 = 整数 注释 = "当此参数为-1的时候，结尾会默认带0" @默认值 = -1>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( CP_UTF8,0,(LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,    NULL, 0, NULL, NULL );
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( CP_UTF8, 0, (LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,(LPSTR) @<MemBuf>.GetPtr(),  @<textlen>, NULL, NULL );
        返回 (MemBuf)

    }

    方法 _编码_Uicode转Ascii_从指针 <公开 静态 类型 = 字节集类 折叠>
    参数 lpWideCharStr <类型 = 变整数>
    参数 cchWideChar <类型 = 整数 @默认值 = -1>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( CP_ACP,0,(LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,NULL, 0, NULL, NULL );
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( CP_ACP, 0, (LPCWSTR)@<lpWideCharStr>,@<cchWideChar>,(LPSTR)@<MemBuf>.GetPtr(),  @<textlen>, NULL, NULL );
        返回 (MemBuf)

    }

    # //上面的是基础函数
    #

    方法 编码_utf8转Unicode <公开 静态 类型 = 文本型 折叠>
    参数 要转换的数据 <类型 = 字节集类>
    {
        返回 (_编码_utf8转Unicode_从指针 (取字节集指针 (要转换的数据)))
    }

