            }
        }
    }

    方法 置页面边距 <公开 注释 = "4个页面边距设置.边距的设置均以磅为单位.与打印相关." 注释 = "注意：打印机设置中没有任何打印机时,会使页面纸张大小设置失败.">
    参数 左 <类型 = 小数 @默认值 = 50.4>
    参数 右 <类型 = 小数 @默认值 = 50.4>
    参数 上 <类型 = 小数 @默认值 = 54>
    参数 下 <类型 = 小数 @默认值 = 54>
    参数 纸张大小 <类型 = Excel纸张大小 注释 = "Excel纸张大小*.某些打印机可能不支持列出的所有纸张大小." @默认值 = Excel纸张大小.不改变>
    {
        变量 pagesetup <类型 = COM对象类>
        pagesetup = Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类)  // 返回一个 页面设置对象,该对象包含指定对象的所有页面设置.
        pagesetup.写属性 ("LeftMargin", 左)
        pagesetup.写属性 ("RightMargin", 右)
        pagesetup.写属性 ("TopMargin", 上)
        pagesetup.写属性 ("BottomMargin", 下)
        如果 (纸张大小 != Excel纸张大小.不改变)
        {
            pagesetup.写属性 ("PaperSize", 纸张大小)
        }
    }

