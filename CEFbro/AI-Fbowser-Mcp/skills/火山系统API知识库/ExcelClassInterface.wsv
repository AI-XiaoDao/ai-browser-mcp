    }

    方法 取单元格 <公开 类型 = Excel单元格 注释 = "以绝对引用或相对引用的形式返回一个\"Excel单元格\"对象,它表示一个单元格或单元格区域.">
    参数 区域1 <类型 = 文本型 注释 = "使用一个参数时,则是用作区域引用,如\"A1:I10\".使用两个参数时,则为始端单元格,如\"A1\".">
    参数 区域2 <类型 = 文本型 注释 = "定义属性返回的区域终端单元格,如\"I10\"." @默认值 = "">
    {
        变量 局_单元格 <类型 = Excel单元格>
        如果 (区域2 == "")
        {
            局_单元格.置对象 (Worksheet对象.读对象型属性 ("Range", COM对象类, 区域1))
        }
        否则
        {
            局_单元格.置对象 (Worksheet对象.读对象型属性 ("Range", COM对象类, 区域1, 区域2))
        }
        返回 (局_单元格)
    }

    方法 取单元格1 <公开 类型 = Excel单元格 注释 = "以行列索引作为参数返回\"Excel单元格\"对象,它表示一个单元格或单元格区域.">
    参数 从列索引 <类型 = 整数 注释 = "开始单元格所在的列索引,索引值从1开始." "">
    参数 从行索引 <类型 = 整数 注释 = "开始单元格所在的行索引,索引值从1开始." "">
    参数 到列索引 <类型 = 整数 注释 = "终端单元格所在的列索引,索引值从1开始.">
    参数 到行索引 <类型 = 整数 注释 = "终端单元格所在的行索引,索引值从1开始.">
    {
        变量 区域1 <类型 = 文本型>
        变量 区域2 <类型 = 文本型>
        区域1 = 数字转列名 (从列索引) + 到文本 (从行索引)
        区域2 = 数字转列名 (到列索引) + 到文本 (到行索引)
        返回 (取单元格 (区域1, 区域2))
    }

    方法 列名转数字 <公开 类型 = 整数 注释 = "将工作表列字母转换为列索引">
    参数 列字母 <类型 = 文本型 注释 = "列字母,支持字母大小写">
    {
        变量 列索引 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 结果文本 <类型 = 整数 值 = 0>
        变量 列字母_字节集 <类型 = 字节集类>
        列字母 = 到大写 (列字母)  // 将列字母转换到大写以兼容字母大小写
        长度 = 取文本长度 (列字母)  // 取列字母长度 当多Z列后AA所以有长度
        列字母_字节集 = 文本到字节集 (列字母)  // 转换到字节集
        计次循环 (长度)
        {
            列索引 = (整数)列字母_字节集.取字节集数据 (取循环索引 () * 2, 字节) - 64  // 取出字节整数值计算出列索引,如A字节整数值为65,65-64,刚好为索引1.
            结果文本 = 取整 (结果文本 + 列索引 * 求次方 (26, 长度 - 取循环索引 () - 1))
        }
        返回 (结果文本)
    }

    方法 数字转列名 <公开 类型 = 文本型 注释 = "将工作表列索引转换为列字母">
    参数 列索引 <类型 = 整数 注释 = "列索引">
    {
        变量 商位值 <类型 = 整数 值 = 0>
        变量 余位值 <类型 = 整数 值 = 0>
        变量 字母1 <类型 = 文本型>
        变量 字母2 <类型 = 文本型>
        变量 临时列索引 <类型 = 整数>
        变量 结果文本 <类型 = 文本型>
        如果 (列索引 > 26)  // 26为26个字母数量(A-Z)
        {
            临时列索引 = 列索引
            判断循环 (真)
            {
                商位值 = (临时列索引 - 1) / 26  // 求商,决定第一位
                余位值 = (临时列索引 - 1) % 26 + 1  // 求余,决定第二位
                字母2 = 到文本 ((字符)(64 + 余位值))
                如果 (商位值 > 26)  // 需要继续计算下一位字母
                {
                    临时列索引 = 商位值
                    结果文本 = 字母2 + 结果文本
                }
                否则
                {
                    字母1 = 到文本 ((字符)(64 + 商位值))
                    结果文本 = 字母1 + 字母2 + 结果文本
                    跳出循环
                }
            }
        }
        否则
        {
            结果文本 = 到文本 ((字符)(64 + 列索引))
        }
        返回 (结果文本)
    }

    方法 取已用单元格 <公开 类型 = Excel单元格 注释 = "返回\"Excel单元格\"对象,该对象代表指定Excel工作表上的已用区域.此为只读属性.">
