<火山程序 类型 = "通常" 版本 = 1 />

包 火山.Excel2021支持库 <@视窗.外部头文件 = "lib\\Excelconstant.h">

类 Excel打开方式 <公开 注释 = "指定文件打开时的处理方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 正常 <公开 值 = @xlNormalLoad 注释 = "正常打开工作簿">
    常量 尝试修复 <公开 值 = @xlRepairFile 注释 = "Excel尝试修复工作簿">
    常量 尝试恢复 <公开 值 = @xlExtractData 注释 = "Excel尝试恢复工作簿中的数据">
}

类 Excel编码 <公开 注释 = "指定用什么编码方式打开文本文件.以下罗列互联网编码格式." @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 苹果系统 <公开 值 = @xlMacintosh 注释 = "苹果系统">
    常量 DOS系统 <公开 值 = @xlMSDOS 注释 = "DOS系统">
    常量 WIN系统 <公开 值 = @xlWindows 注释 = "WIN系统">
    常量 泰文 <公开 值 = @windows874 注释 = "泰文(Windows)">
    常量 日文 <公开 值 = @iso2022jp 注释 = "日文(Shift-JIS)">
    常量 简体中文 <公开 值 = @gb2312 注释 = "简体中文(GB2312)">
    常量 韩语 <公开 值 = @ksc56011987 注释 = "韩语韩语">
    常量 繁体中文 <公开 值 = @big5 注释 = "繁体中文(Big5)">
    常量 中欧 <公开 值 = @windows1250 注释 = "中欧字符(Windows)">
    常量 西里尔文 <公开 值 = @windows1251 注释 = "西里尔文(Windows)">
    常量 西欧 <公开 值 = @windows1252 注释 = "西欧(Windows)">
    常量 希腊 <公开 值 = @windows1253 注释 = "希腊语(Windows)">
    常量 土耳其 <公开 值 = @windows1254 注释 = "土耳其语(Windows)">
    常量 希伯来文 <公开 值 = @windows1255 注释 = "希伯来文(Windows)">
    常量 阿拉伯文 <公开 值 = @windows1256 注释 = "阿拉伯文(Windows)">
    常量 波罗的海 <公开 值 = @windows1257 注释 = "波罗的海字符(Windows)">
    常量 越南 <公开 值 = @windows1258 注释 = "越南语(Windows)">
    常量 ASCII <公开 值 = @ASCII 注释 = "US-ASCII">
    常量 拉丁文 <公开 值 = @iso88593 注释 = "拉丁文3(ISO)">
    常量 塞瑞利克 <公开 值 = @iso88595 注释 = "塞瑞利克字符(ISO)">
    常量 阿拉伯语 <公开 值 = @iso88596 注释 = "阿拉伯语(ISO)">
    常量 日语 <公开 值 = @eucjp 注释 = "日语(EUC)">
    常量 朝鲜 <公开 值 = @euckr 注释 = "朝鲜语(EUC)">
    常量 简体中文HZ <公开 值 = @hzgb2312 注释 = "简体中文(HZ)">
    常量 UTF7 <公开 值 = @excel_utf7 注释 = "Unicode(UTF-7)">
    常量 UTF8 <公开 值 = @excel_utf8 注释 = "Unicode(UTF-8)">
}

类 Excel查询类型 <公开 注释 = "指定打开数据库时查询命令的类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 OLAP <公开 值 = @xlCmdCube 注释 = "包含一个OLAP数据源多维数据集名称">
    常量 SQL语句 <公开 值 = @xlCmdSql 注释 = "包含一个SQL语句">
    常量 数据表名 <公开 值 = @xlCmdTable 注释 = "包含用于访问OLE DB数据源的表名称">
    常量 命令文本 <公开 值 = @xlCmdDefault 注释 = "包含OLE DB提供程序可识别的命令文本">
    常量 列表指针 <公开 值 = @xlCmdList 注释 = "包含指向列表数据的指针">
    常量 表集名 <公开 值 = @xlCmdTableCollection 注释 = "包含表集合的名称">
    常量 Excel公式 <公开 值 = @xlCmdExcel 注释 = "包含一个Excel公式">
    常量 DAX公式 <公开 值 = @xlCmdDAX 注释 = "包含DAX公式(数据分析)表达式">
}

类 Excel数据库形式 <公开 注释 = "指定从数据库返回数据的格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 查询表形式 <公开 值 = @xlQueryTable 注释 = "以查询表的形式返回数据">
    常量 透视表形式 <公开 值 = @xlPivotTableReport 注释 = "以数据透视表的形式返回数据">
}

类 ExcelXML打开方式 <公开 注释 = "指定Exce打开XML数据文件的方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 提示选择 <公开 值 = @xlXmlLoadPromptUser 注释 = "提示用户选择打开文件的方式">
    常量 展开内容 <公开 值 = @xlXmlLoadOpenXml 注释 = "打开XML数据文件,文件的内容将展开.">
    常量 置XML表中 <公开 值 = @xlXmlLoadImportToList 注释 = "将XML数据文件的内容置于XML表中">
    常量 任务窗格中 <公开 值 = @xlXmlLoadMapXml 注释 = "在\"XML结构\"任务窗格中显示XML数据文件的架构">
}

类 Excel水平对齐 <公开 注释 = "指定对象的水平对齐方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 居中 <公开 值 = @xlHAlignCenter 注释 = "居中">
    常量 跨列居中 <公开 值 = @xlHAlignCenterAcrossSelection 注释 = "跨列居中">
    常量 分散 <公开 值 = @xlHAlignDistributed 注释 = "分散对齐">
    常量 填充 <公开 值 = @xlHAlignFill 注释 = "填充">
    常量 按类型 <公开 值 = @xlHAlignGeneral 注释 = "按数据类型对齐">
    常量 两端 <公开 值 = @xlHAlignJustify 注释 = "两端对齐">
    常量 靠左 <公开 值 = @xlHAlignLeft 注释 = "靠左">
    常量 靠右 <公开 值 = @xlHAlignRight 注释 = "靠右">
}

类 Excel垂直对齐 <公开 注释 = "指定对象的垂直对齐方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 靠下 <公开 值 = @xlVAlignBottom 注释 = "向下">
    常量 居中 <公开 值 = @xlVAlignCenter 注释 = "居中">
    常量 分散 <公开 值 = @xlVAlignDistributed 注释 = "分散对齐">
    常量 两端 <公开 值 = @xlVAlignJustify 注释 = "两端对齐">
    常量 靠上 <公开 值 = @xlVAlignTop 注释 = "靠上">
}

类 Excel填充类型 <公开 注释 = "根据源区域的内容,指定目标区域的填充方式." @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 值和格式 <公开 值 = @xlFillDefault 注释 = "Excel确定用于填充目标区域的值和格式">
    常量 复制 <公开 值 = @xlFillCopy 注释 = "将源区域的值和格式复制到目标区域,如有必要可重复执行">
    常量 扩展 <公开 值 = @xlFillSeries 注释 = "将源区域中的值扩展到目标区域中,形式为系列(如,\"1,2\"扩展为\"3,4,5\").格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 格式 <公开 值 = @xlFillFormats 注释 = "只将源区域的格式复制到目标区域,如有必要可重复执行.">
    常量 值 <公开 值 = @xlFillValues 注释 = "只将源区域的值复制到目标区域,如有必要可重复执行.">
    常量 星期格式 <公开 值 = @xlFillDays 注释 = "将星期中每天的名称从源区域扩展到目标区域中.格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 工作周格式 <公开 值 = @xlFillWeekdays 注释 = "将工作周每天的名称从源区域扩展到目标区域中.格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 月格式 <公开 值 = @xlFillMonths 注释 = "将月名称从源区域扩展到目标区域中.格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 年格式 <公开 值 = @xlFillYears 注释 = "将年从源区域扩展到目标区域中.格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 值加法 <公开 值 = @xlLinearTrend
            注释 = "将数值从源区域扩展到目标区域中,假定数字之间是加法关系(如,\"1,2,\"扩展为\"3,4,5\",假定每个数字都是前一个数字加上某个值的结果).格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 值乘法 <公开 值 = @xlGrowthTrend
            注释 = "将数值从源区域扩展到目标区域中,假定源区域的数字之间是乘法关系(如,\"1,2,\"扩展为\"4,8,16\",假定每个数字都是前一个数字乘以某个值的结果).格式从源区域复制到目标区域,如有必要可重复执行.">
    常量 重复先前格式 <公开 值 = @xlFlashFill 注释 = "根据检测到的先前用户操作的模式,将值从源区域扩展到目标区域,如有必要可重复执行.">
}

类 Excel区域类型 <公开 注释 = "指定区域值数据类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 默认 <公开 值 = @xlRangeValueDefault 注释 = "默认值.如果指定的\"活动单元格\"对象为空,则返回值为空.如果Excel单元格包含多个单元格,则返回值的数组.">
    常量 XML电子表格 <公开 值 = @xlRangeValueXMLSpreadsheet 注释 = "以XML电子表格格式返回指定的\"活动单元格\"对象的值、格式、公式和名称.">
    常量 XML记录集 <公开 值 = @xlRangeValueMSPersistXML 注释 = "以XML格式返回指定的\"活动单元格\"对象的记录集表示形式">
}

类 Excel表类型 <公开 注释 = "指定工作表类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 图表 <公开 值 = @xlChart 注释 = "图表">
    常量 对话框工作表 <公开 值 = @xlDialogSheet 注释 = "对话框工作表">
    常量 国际宏工作表 <公开 值 = @xlExcel4IntlMacroSheet 注释 = "Excel版本4国际宏工作表">
    常量 宏工作表 <公开 值 = @xlExcel4MacroSheet 注释 = "Excel版本4宏工作表">
    常量 工作表 <公开 值 = @xlWorksheet 注释 = "工作表">
}

类 Excel复制类型 <公开 注释 = "指定区域" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 内容和格式 <公开 值 = @xlFillWithAll 注释 = "复制内容和格式">
    常量 内容 <公开 值 = @xlFillWithContents 注释 = "仅复制内容">
    常量 格式 <公开 值 = @xlFillWithFormats 注释 = "仅复制格式">
}

类 Excel窗口状态 <公开 注释 = "指定窗口的状态" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 最大化 <公开 值 = @xlMaximized 注释 = "窗口最大化">
    常量 最小化 <公开 值 = @xlMinimized 注释 = "窗口最小化">
    常量 正常 <公开 值 = @xlNormal 注释 = "窗口正常状态">
}

类 Excel文件格式 <公开 注释 = "指定保存工作表时的文件格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 常规工作簿 <公开 值 = @xlWorkbookNormal 注释 = "常规工作簿 扩展名 *.xls">
    常量 当前平台文本 <公开 值 = @xlCurrentPlatformText 注释 = "当前平台文本 扩展名 *.txt">
    常量 DB4格式 <公开 值 = @xlDBF4 注释 = "Dbase 4 格式 扩展名 *.dbf">
    常量 模板 <公开 值 = @xlTemplate8 注释 = "模板 8 扩展名 *.xlt">
    常量 外接程序2003 <公开 值 = @xlAddIn 注释 = "Excel 97-2003 外接程序 扩展名 *.xla">
    常量 符号链接 <公开 值 = @xlSYLK 注释 = "符号链接格式 扩展名 *.slk">
    常量 TXT文本 <公开 值 = @xlTextWindows 注释 = "Windows 文本 扩展名 *.txt">
    常量 WindowsCSV <公开 值 = @xlCSVWindows 注释 = "Windows CSV 扩展名 *.csv">
    常量 版本3 <公开 值 = @xlExcel3 注释 = "Excel 版本 3.0(1990) 扩展名 *.xls">
    常量 版本4 <公开 值 = @xlExcel4 注释 = "Excel 版本 4.0(1992) 扩展名 *.xls">
    常量 版本4工作簿 <公开 值 = @xlExcel4Workbook 注释 = "Excel 版本 4.0 工作簿格式(1992) 扩展名 *.xlw">
    常量 打印机文本 <公开 值 = @xlTextPrinter 注释 = "打印机文本 扩展名 *.prn">
    常量 版本7 <公开 值 = @xlExcel7 注释 = "Excel 95(版本 7.0) 扩展名 *.xls">
    常量 版本5 <公开 值 = @xlExcel5 注释 = "Excel 版本 5.0(1994) 扩展名 *.xls">
    常量 Unicode文本 <公开 值 = @xlUnicodeText 注释 = "Unicode 文本 扩展名 无文件扩展名;*.txt">
    常量 版本95和97 <公开 值 = @xlExcel9795 注释 = "Excel 版本 95 和 97 扩展名 *.xls">
    常量 HTML <公开 值 = @xlHtml 注释 = "HTML 格式 扩展名 *.htm;*.html">
    常量 Web档案 <公开 值 = @xlWebArchive 注释 = "Web 档案 扩展名 *.mh;*.mhtml">
    常量 XML电子表格 <公开 值 = @xlXMLSpreadsheet 注释 = "XML 电子表格 扩展名 *.xml">
    常量 二进制工作簿 <公开 值 = @xlExcel12 注释 = "Excel 二进制工作簿 扩展名 *.xlsb">
    常量 默认工作簿 <公开 值 = @xlWorkbookDefault 注释 = "默认工作簿 扩展名 *.xlsx">
    常量 XML工作簿 <公开 值 = @xlOpenXMLWorkbook 注释 = "Open XML 工作簿 扩展名 *.xlsx">
    常量 XML工作簿宏 <公开 值 = @xlOpenXMLWorkbookMacroEnabled 注释 = "启用 Open XML 工作簿宏 扩展名 *.xlsm">
    常量 XML模板宏 <公开 值 = @xlOpenXMLTemplateMacroEnabled 注释 = "启用 Open XML 模板宏 扩展名 *.xltm">
    常量 XML模板 <公开 值 = @xlOpenXMLTemplate 注释 = "Open XML 模板 扩展名 *.xltx">
    常量 XML外接程序 <公开 值 = @xlOpenXMLAddIn 注释 = "Open XML 外接程序 扩展名 *.xlam">
    常量 工作簿2003 <公开 值 = @xlExcel8 注释 = "Excel 97-2003 工作簿 扩展名 *.xls">
    常量 CSV <公开 值 = @xlCSV 注释 = "CSV 扩展名 *.csv">
    常量 电子表格 <公开 值 = @xlOpenDocumentSpreadsheet 注释 = "OpenDocument 电子表格 扩展名 *.ods">
    常量 UTF8_CSV <公开 值 = @xlCSVUTF8 注释 = "UTF8 CSV 扩展名 *.csv">
    常量 DB2 <公开 值 = @xlDBF2 注释 = "Dbase 2 格式 扩展名 *.dbf">
    常量 DB3 <公开 值 = @xlDBF3 注释 = "Dbase 3 格式 扩展名 *.dbf">
    常量 数据交换 <公开 值 = @xlDIF 注释 = "数据交换格式 扩展名 *.dif">
}

类 Excel访问模式 <公开 注释 = "指定\"另存为\"函数的访问模式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 默认值 <公开 值 = @xlNoChange 注释 = "默认值(不更改访问模式)">
    常量 共享列表 <公开 值 = @xlShared 注释 = "共享列表">
    常量 独占 <公开 值 = @xlExclusive 注释 = "独占模式">
}

类 Excel冲突方式 <公开 注释 = "指定更新共享工作簿时解决冲突的方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 弹对话框 <公开 值 = @xlUserResolution 注释 = "弹出对话框请求用户解决冲突">
    常量 总是接受 <公开 值 = @xlLocalSessionChanges 注释 = "总是接受本地用户所做的更改">
    常量 总是拒绝 <公开 值 = @xlOtherSessionChanges 注释 = "总是拒绝本地用户所做的更改">
}

类 Excel格式 <公开 注释 = "单元格格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 常规 <公开 值 = 1 注释 = "G/通用格式">
    常量 日期 <公开 值 = 2 注释 = "yyyy-mm-dd">
    常量 时间 <公开 值 = 3 注释 = "yyyy-mm-dd hh:mm:ss 2019-12-08 18:34:33">
    常量 百分比 <公开 值 = 4 注释 = "0.00%">
    常量 文本 <公开 值 = 5 注释 = "@">
    常量 数值 <公开 值 = 6 注释 = "根据指定小数位及千分位变化">
    常量 货币 <公开 值 = 7 注释 = "¥#,##0.00;¥-#,##0.00">
    常量 科学记数 <公开 值 = 8 注释 = "0.00E+00">
    常量 自定义 <公开 值 = 9 注释 = "自定义">
}

类 Excel搜索类型 <公开 注释 = "指定要搜索的数据的类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
