    }

    方法 数据间隔 <公开 属性读 类型 = 整数 注释 = "返回三维图表中数据系列之间的距离,以标记宽度的百分比表示.范围介于0到500之间.">
    {
        返回 (Chart对象.读无参数属性 ("GapDepth", 整数))
    }

    方法 数据间隔 <公开 属性写 注释 = "设置三维图表中数据系列之间的距离,以标记宽度的百分比表示.本属性的值必须介于0到500之间.">
    参数 所欲设置的值 <类型 = 整数 注释 = "取值范围:0到500">
    {
        Chart对象.写属性 ("GapDepth", 所欲设置的值)
    }

    方法 置数据区域 <公开 注释 = "为指定图表设置源数据区域.来源于某个工作表中某个区域中的数据.">
    参数 工作表 <类型 = Excel工作表 注释 = "数据来源的工作表.">
    参数 区域 <类型 = 文本型 注释 = "包含源数据的区域.如;\"A1:I10\".">
    参数 绘制方式 <类型 = 整数 注释 = "指定数据绘制方式.可以是下列的常量:" 注释 = "1 数据系列在列中." 注释 = "2 数据系列在行中." @默认值 = 2>
    {
        变量 COM变体 <类型 = COM变体型>
        COM变体 = 工作表.取对象 ().读属性 ("Range", COM变体型, 区域)  // 设置工作表中的区域作为数据.
        Chart对象.无返回值方法 ("SetSourceData", COM变体, 绘制方式)
    }
}
