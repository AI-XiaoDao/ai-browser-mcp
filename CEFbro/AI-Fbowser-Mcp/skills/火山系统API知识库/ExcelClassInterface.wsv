    方法 工作表选区改变 <公开 定义事件 类型 = 整数 注释 = "任一工作表上的选定区域发生更改时,将发生此事件" "">
    参数 参_Excel工作表 <类型 = Excel工作表 注释 = "新选定区域所在的工作表">
    参数 参_Excel单元格 <类型 = Excel单元格 注释 = "新选定的区域">

    方法 工作表内容改变 <公开 定义事件 类型 = 整数 注释 = "当用户或外部链接更改了任何工作表中的单元格时发生此事件" "">
    参数 参_Excel工作表 <类型 = Excel工作表 注释 = "更改的区域发生所在的工作表">
    参数 参_Excel单元格 <类型 = Excel单元格 注释 = "更改的区域">

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出.事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        变量 局_返回值 <类型 = 整数 值 = 0>
        如果 (来源对象 == Application事件)
        {
            如果 (事件方法ID == 1567)  // 工作簿被打开
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为被打开的工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                工作簿被打开 (局_Excel工作簿)
            }
            如果 (事件方法ID == 1570)  // 工作簿即将关闭
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作簿对象, )  // 第二个参数为被打开的工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿即将关闭 (局_Excel工作簿)
                事件参数.取成员 (0).赋值 (选择 (局_返回值 == 1, 真, 假), )
                局_返回值 = 0
            }
            如果 (事件方法ID == 1571)  // 工作簿即将保存
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为被打开的工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿即将保存 (局_Excel工作簿)
                事件参数.取成员 (2).赋值 (选择 (局_返回值 == 1, 真, 假), )  // 第三个参数设置是否保存工作簿
                局_返回值 = 0
            }
            如果 (事件方法ID == 2911)  // 工作簿被保存
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作簿对象, )  // 第二个参数为被打开的工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿被保存 (局_Excel工作簿, 事件参数.取成员 (0).取值 (逻辑型, ))
            }
            如果 (事件方法ID == 1572)  // 工作簿即将打印
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作簿对象, )  // 第二个参数为被打开的工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿即将打印 (局_Excel工作簿)
                事件参数.取成员 (0).赋值 (选择 (局_返回值 == 1, 真, 假), )
                局_返回值 = 0
            }
            如果 (事件方法ID == 1573)  // 工作簿新建工作表
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 工作簿对象 <类型 = COM对象类>
                变量 工作表对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作簿对象, )  // 第二个参数为新工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                事件参数.取成员 (0).取COM对象 (工作表对象, )  // 第一个参数为新工作表对象
                局_Excel工作表.置对象 (工作表对象)
                局_返回值 = 工作簿新建工作表 (局_Excel工作簿, 局_Excel工作表)
            }
            如果 (事件方法ID == 2912)  // 工作簿新建图表
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 局_Excel图表 <类型 = Excel图表>
                变量 工作簿对象 <类型 = COM对象类>
                变量 工作表对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为新工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                事件参数.取成员 (1).取COM对象 (工作表对象, )  // 第二个参数为新工作表对象
                局_Excel图表.置对象 (工作表对象)
                局_返回值 = 工作簿新建图表 (局_Excel工作簿, 局_Excel图表)
            }
            如果 (事件方法ID == 1565)  // 新建工作簿
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为新工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 新建工作簿 (局_Excel工作簿)
            }
            如果 (事件方法ID == 1568)  // 工作簿被激活
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿被激活 (局_Excel工作簿)
            }
            如果 (事件方法ID == 1569)  // 工作簿反激活
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 工作簿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作簿对象, )  // 第一个参数为工作簿对象
                局_Excel工作簿.置对象 (工作簿对象)
                局_返回值 = 工作簿反激活 (局_Excel工作簿)
            }
            如果 (事件方法ID == 1564)  // 工作表内容改变
            {
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 局_Excel单元格 <类型 = Excel单元格>
                变量 工作表对象 <类型 = COM对象类>
                变量 单元格对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作表对象, )  // 第一个参数为工作表对象
                局_Excel工作表.置对象 (工作表对象)
                事件参数.取成员 (0).取COM对象 (单元格对象, )  // 第一个参数为单元格对象
                局_Excel单元格.置对象 (单元格对象)
                局_返回值 = 工作表内容改变 (局_Excel工作表, 局_Excel单元格)
            }
            如果 (事件方法ID == 3079)  // 工作表即将删除
            {
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 工作表对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作表对象, )  // 第一个参数为工作表对象
                局_Excel工作表.置对象 (工作表对象)
                局_返回值 = 工作表即将删除 (局_Excel工作表)
            }
            如果 (事件方法ID == 1561)  // 工作表被激活
            {
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 工作表对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作表对象, )  // 第一个参数为工作表对象
                局_Excel工作表.置对象 (工作表对象)
                局_返回值 = 工作表被激活 (局_Excel工作表)
            }
            如果 (事件方法ID == 1562)  // 工作表反激活
            {
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 工作表对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (工作表对象, )  // 第一个参数为工作表对象
                局_Excel工作表.置对象 (工作表对象)
                局_返回值 = 工作表反激活 (局_Excel工作表)
            }
            如果 (事件方法ID == 1558)  // 工作表选区改变
            {
                变量 局_Excel工作表 <类型 = Excel工作表>
                变量 局_Excel单元格 <类型 = Excel单元格>
                变量 工作表对象 <类型 = COM对象类>
                变量 单元格对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (工作表对象, )  // 第二个参数为工作表对象
                局_Excel工作表.置对象 (工作表对象)
                事件参数.取成员 (0).取COM对象 (单元格对象, )  // 第一个参数为单元格对象
                局_Excel单元格.置对象 (单元格对象)
                局_返回值 = 工作表选区改变 (局_Excel工作表, 局_Excel单元格)
            }
            如果 (事件方法ID == 1556)  // 窗口被激活
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 事件对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (事件对象, )  // 第二个参数为工作簿对象
                局_Excel工作簿.置对象 (事件对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第一个参数为windows对象
                局_返回值 = 窗口被激活 (局_Excel工作簿, windows对象)
            }
            如果 (事件方法ID == 1557)  // 窗口反激活
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 事件对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (事件对象, )  // 第二个参数为工作簿对象
                局_Excel工作簿.置对象 (事件对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第一个参数为windows对象
                局_返回值 = 窗口反激活 (局_Excel工作簿, windows对象)
            }
            如果 (事件方法ID == 1554)  // 窗口尺寸被改变
            {
                变量 局_Excel工作簿 <类型 = Excel工作簿>
                变量 事件对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (事件对象, )  // 第二个参数为工作簿对象
                局_Excel工作簿.置对象 (事件对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第一个参数为windows对象
                局_返回值 = 窗口尺寸被改变 (局_Excel工作簿, windows对象)
            }
        }
        返回 (局_返回值)
    }

    方法 退出 <公开 注释 = "退出Excel应用程序.">
    {
        Application对象.无参数及返回值方法 ("Quit")
    }

    方法 弹出对话框 <公开 类型 = 文本型 注释 = "显示用于用户输入的对话框.返回在对话框中输入的信息.">
    参数 提示消息 <类型 = 文本型 注释 = "要在对话框中显示的消息.最大长度为255个字符,否则不会出现提示,并返回错误2015." @默认值 = "消息">
    参数 标题 <类型 = 文本型 注释 = "输入框的标题." @默认值 = "输入">
    参数 默认文本 <类型 = 文本型 注释 = "指定在对话框最初显示时文本框中显示的值.如果省略此参数,即表示将文本框留空." @默认值 = "">
    参数 X坐标 <类型 = 整数 注释 = "指定对话框相对于屏幕左上角的X坐标(以磅为单位)" @默认值 = 0>
    参数 Y坐标 <类型 = 整数 注释 = "指定对话框相对于屏幕左上角的Y坐标(以磅为单位)" @默认值 = 0>
    {
        变量 COM变体 <类型 = COM变体型>
        返回 (Application对象.方法 ("InputBox", 文本型, 提示消息, 标题, 默认文本, X坐标, Y坐标, COM变体, COM变体, 2))
    }

    方法 版本 <公开 属性读 类型 = 文本型 注释 = "Excel 版本号,与Office版本对应如下:" 注释 = "1.0----Office 1.0" 注释 = "5.0----Office 4.2."
            注释 = "7.0----Office 95." 注释 = "8.0----Office 97." 注释 = "9.0----Office 2000." 注释 = "10.0----Office XP/2002."
            注释 = "11.0----Office XP/2003." 注释 = "12.0----Office XP/2007." 注释 = "14.0----Office 2010." 注释 = "15.0----Office 2013."
            注释 = "16.0----Office 2016." 注释 = "16.0----Office 2021." "">
    {
        返回 (Application对象.读无参数属性 ("Version", 文本型))
    }

    方法 工作簿集 <公开 属性读 类型 = Excel工作簿集 注释 = "返回一个\"工作簿\"集合,该集合代表所有打开的工作簿.此为只读属性." "">
