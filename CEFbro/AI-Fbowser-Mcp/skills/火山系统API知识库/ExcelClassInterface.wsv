}

类 Excel程序 <公开 注释 = "代表整个Excel应用程序">
{
    变量 Application对象 <类型 = COM对象类>
    变量 Application事件 <类型 = COM对象事件类>

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建Excel对象" 返回值注释 = "成功返回真." 返回值注释 = "失败返回假,没有安装 Microsoft Office Excel 程序." "">
    {
        返回 (Application对象.创建 ("Excel.Application", ""))
    }

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Application对象 <类型 = COM对象类>
    {
        Application对象 = 参_Application对象
        返回 (Application对象.是否为空 () == 假)
    }

    方法 获取 <公开 类型 = 逻辑型 注释 = "获取当前操作系统中已经存在的\"Excel对象\"填入本对象中,本对象中的原有内容将被覆盖.">
    {
        返回 (Application对象.获取 ("Excel.Application"))
    }

    方法 注册事件 <公开 类型 = 逻辑型 注释 = "使用定义事件前需先运行一次注册事件,在\"创建\"方法成功后执行.">
    {
        返回 (Application事件.挂接 (Application对象, "{00024413-0000-0000-C000-000000000046}"))
    }

    方法 工作簿被打开 <公开 定义事件 类型 = 整数 注释 = "当打开一个工作簿时发生此事件">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "被打开的工作簿">

    方法 工作簿即将保存 <公开 定义事件 类型 = 整数 注释 = "在保存打开的工作簿之前发生" 返回值注释 = "如果返回值为1,表示过程完成后工作簿不会保存." "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "正在保存的工作簿">

    方法 工作簿被保存 <公开 定义事件 类型 = 整数 注释 = "保存工作簿之后发生此事件" "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "正在保存的工作簿">
    参数 是否成功 <类型 = 逻辑型 注释 = "如果为真,则表示保存操作成功,反之则表示失败.">

    方法 工作簿即将关闭 <公开 定义事件 类型 = 整数 注释 = "当任一打开的工作簿关闭之前立即发生此事件" 返回值注释 = "如果返回值为1,表示过程完成后工作簿不会关闭." "">
    参数 参_Excel工作簿 <类型 = Excel工作簿>

    方法 新建工作簿 <公开 定义事件 类型 = 整数 注释 = "当新建一个工作簿时发生此事件" "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "新工作簿">

    方法 工作簿被激活 <公开 定义事件 类型 = 整数 注释 = "当激活任一工作簿时发生此事件" "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "激活的工作簿">

    方法 工作簿反激活 <公开 定义事件 类型 = 整数 注释 = "当打开的工作簿转为非活动状态时发生此事件" "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "非活动工作簿">

    方法 工作簿即将打印 <公开 定义事件 类型 = 整数 注释 = "在打印任一打开的工作簿之前发生此事件" 返回值注释 = "如果返回值为1,则该过程完成后将不打印工作簿." "">
    参数 参_Excel工作簿 <类型 = Excel工作簿 注释 = "被打印的工作簿">

