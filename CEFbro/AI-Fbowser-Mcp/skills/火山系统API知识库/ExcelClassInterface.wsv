    }

    方法 打印方向 <公开 属性写 注释 = "设置纵向或横向打印模式">
    参数 所欲设置的值 <类型 = 整数 注释 = "1 纵向模式;2 横向模式.">
    {
        Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("Orientation", 所欲设置的值)
    }

    方法 置页眉标题 <公开 注释 = "设置工作表页面页眉上的标题及标题文本对齐方式.与打印相关.">
    参数 标题 <类型 = 文本型>
    参数 位置 <类型 = 整数 注释 = "0 左;1 中;2 右.">
    {
        变量 页面设置 <类型 = COM对象类>
        变量 变体标题 <类型 = COM变体型>
        页面设置 = Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类)  // 返回一 个 页面设置对象,该对象包含指定对象的所有页面设置.此为只读属性.
        变体标题.赋值 (标题, )
        分支判断 (位置)
        {
            分支 (0)
            {
                页面设置.写属性 ("LeftHeader", 变体标题)  // 靠左.
                跳出分支 ()
            }
            分支 (1)
            {
                页面设置.写属性 ("CenterHeader", 变体标题)  // 居中.
                跳出分支 ()
            }
            分支 (2)
            {
                页面设置.写属性 ("RightHeader", 变体标题)  // 靠右.
            }
        }
    }

    方法 置页脚标题 <公开 注释 = "设置工作表页面页脚上的标题及标题文本对齐方式.与打印相关.">
    参数 标题 <类型 = 文本型>
    参数 位置 <类型 = 整数 注释 = "0 左;1 中;2 右.">
    {
        变量 pagesetup <类型 = COM对象类>
        变量 变体标题 <类型 = COM变体型>
        pagesetup = Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类)  // 返回一 个 页面设置对象,该对象包含指定对象的所有页面设置.此为只读属性.
        变体标题.赋值 (标题, )
        分支判断 (位置)
        {
            分支 (0)
            {
                pagesetup.写属性 ("LeftFooter", 变体标题)  // 靠左.
                跳出分支 ()
            }
            分支 (1)
            {
                pagesetup.写属性 ("CenterFooter", 变体标题)  // 居中.
                跳出分支 ()
            }
            分支 (2)
            {
