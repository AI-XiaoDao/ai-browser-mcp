    方法 取文本 <公开 类型 = 文本型 注释 = "对所选区域中的某个单元格以文本格式读取">
    参数 列序号 <类型 = 整数 注释 = "相对于区域列序号从1开始">
    参数 行序号 <类型 = 整数 注释 = "相对于区域行序号从1开始">
    {
        返回 (Range对象.读属性 ("Item", 文本型, 行序号, 列序号))
    }

    方法 置文本 <公开 注释 = "对所选区域中的某个单元格以文本格式写入">
    参数 列序号 <类型 = 整数 注释 = "相对于区域列序号从1开始" "">
    参数 行序号 <类型 = 整数 注释 = "相对于区域行序号从1开始" "">
    参数 所欲设置的值 <类型 = 文本型 注释 = "欲设置单元格的文本" "">
    {
        Range对象.写属性 ("Item", 行序号, 列序号, 所欲设置的值)
    }

    方法 公式 <公开 属性读 类型 = 文本型 注释 = "返回一个\"文本型\"值,它以 A1 样式表示法表示对象的隐式交叉公式,如\"=$A$4+$A$10\".">
    {
        返回 (Range对象.读无参数属性 ("Formula", 文本型))
    }

    方法 公式 <公开 属性写 注释 = "设置一个\"文本型\"值,它以 A1 样式表示法表示对象的隐式交叉公式,如\"=$A$4+$A$10\".">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Range对象.写属性 ("Formula", 所欲设置的值)
    }

    方法 取格式 <公开 类型 = 文本型 注释 = "以采用用户语言字符串的形式返回一个\"文本\"值,它代表对象的格式代码.如果指定区域中的所有单元格的数字格式不一致,则此属性将返回空文本.">
    {
        返回 (Range对象.读无参数属性 ("NumberFormatLocal", 文本型))
    }

    方法 置格式 <公开 注释 = "以采用用户语言字符串的形式设置一个\"文本\"值,它代表对象的格式代码." 编辑时信息 = "10EA99, 0, 0, 0">
    参数 格式 <类型 = Excel格式 注释 = "Excel格式.*." 编辑时信息 = "10EA99, 0, 0, 0" @默认值 = Excel格式.常规>
    参数 数值位数 <类型 = 整数 注释 = "当格式为\"数值\"时参数有效." 编辑时信息 = "10EA99, 0, 0, 0" @默认值 = 0>
    参数 数值千分位 <类型 = 逻辑型 注释 = "当格式为\"数值\"时参数有效,它代表是否设置千分位.为真时 千分位用逗号隔开." 编辑时信息 = "10EA99, 0, 0, 0" @默认值 = 假>
    参数 自定义格式文本 <类型 = 文本型 注释 = "当格式为\"自定义\"时参数有效,如yyyy/mm/dd." 编辑时信息 = "10EA99, 0, 0, 0" @默认值 = "">
    {
        如果 (格式 == Excel格式.常规)
        {
            Range对象.写属性 ("NumberFormatLocal", "G/通用格式")
        }
        否则 (格式 == Excel格式.日期)
        {
            Range对象.写属性 ("NumberFormatLocal", "yyyy/m/d")
        }
        否则 (格式 == Excel格式.时间)
        {
            Range对象.写属性 ("NumberFormatLocal", "yyyy-mm-dd hh:mm:ss")
        }
        否则 (格式 == Excel格式.百分比)
        {
            Range对象.写属性 ("NumberFormatLocal", "0.00%")
        }
        否则 (格式 == Excel格式.文本)
        {
            Range对象.写属性 ("NumberFormatLocal", "@")
        }
        否则 (格式 == Excel格式.数值)  // 格式为数值型时 设置小数点位数和千分位
        {
            变量 零 <类型 = 文本型 值 = "" 注释 = "根据数值位数补零">
            如果 (数值千分位)
            {
                如果 (数值位数 == 0)
                {
                    Range对象.写属性 ("NumberFormatLocal", "#,##0_);[红色](#,##0)")
                }
                否则
                {
                    计次循环 (数值位数)
                    {
                        零 = 零 + "0"
                    }
                    Range对象.写属性 ("NumberFormatLocal", "#,##0." + 零 + "_);[红色](#,##0." + 零 + ")")
                }
            }
            否则
            {
                如果 (数值位数 == 0)
                {
                    Range对象.写属性 ("NumberFormatLocal", "0_);[红色](0)")
                }
                否则
                {
                    计次循环 (数值位数)
                    {
                        零 = 零 + "0"
                    }
                    Range对象.写属性 ("NumberFormatLocal", "0." + 零 + "_);[红色](0." + 零 + ")")
                }
            }
        }
        否则 (格式 == Excel格式.货币)
        {
            Range对象.写属性 ("NumberFormatLocal", "¥#,##0.00;¥-#,##0.00")
        }
        否则 (格式 == Excel格式.科学记数)
        {
            Range对象.写属性 ("NumberFormatLocal", "0.00E+00")
        }
        否则 (格式 == Excel格式.自定义)
        {
            Range对象.写属性 ("NumberFormatLocal", 自定义格式文本)
        }
    }

    方法 置区域 <公开 注释 = "重新设置该单元格所在工作表的区域.">
    参数 区域1 <类型 = 文本型 注释 = "使用一个参数时,则是用作区域引用,如\"A1:I10\"或\"$A$1:$I$10\".使用两个参数时,则为始端单元格,如\"A1\"或\"$A$1\".">
    参数 区域2 <类型 = 文本型 注释 = "定义属性返回的区域终端单元格,如\"I10\"或\"$A$10\"." @默认值 = "">
    {
        如果 (区域2 == "")
        {
            置对象 (Range对象.读无参数对象型属性 ("Parent", COM对象类).读对象型属性 ("Range", COM对象类, 区域1))
        }
        否则
        {
            置对象 (Range对象.读无参数对象型属性 ("Parent", COM对象类).读对象型属性 ("Range", COM对象类, 区域1, 区域2))
        }
    }

    方法 置边框 <公开 注释 = "向区域或向区域内每个单元格添加边框,并设置新边框样式." 编辑时信息 = "10FFEF, 0, 0, 0">
    参数 线条样式 <类型 = Excel线条样式 注释 = "Excel线条样式.*,指定边框线条样式." 编辑时信息 = "10FFEF, 0, 0, 0" @默认值 = Excel线条样式.实线>
    参数 边框粗细 <类型 = Excel边框粗细 注释 = "Excel边框粗细.*,边框粗细." 编辑时信息 = "10FFEF, 0, 0, 0" @默认值 = Excel边框粗细.细>
    参数 边框颜色 <类型 = 整数 注释 = "边框颜色,以\"RGB\"值表示,默认为黑色." 编辑时信息 = "10FFEF, 0, 0, 0" @默认值 = 0>
    参数 区域 <类型 = 逻辑型 注释 = "如果为真,则 向区域添加边框;如果为假,则向区域内每个单元格添加边框." @默认值 = 假>
    {
        如果 (区域)
        {
            变量 COM变体 <类型 = COM变体型>
            Range对象.无返回值方法 ("BorderAround", 线条样式, 边框粗细, COM变体, 边框颜色)  // 向区域添加边框
        }
        否则
        {
            变量 Borders <类型 = COM对象类>
            Borders = Range对象.读无参数对象型属性 ("Borders", COM对象类)  // 区域内单元格集合
            Borders.写属性 ("Weight", 边框粗细)  // 表格线宽度
            Borders.写属性 ("Color", 边框颜色)  // 表格线颜色
            Borders.写属性 ("LineStyle", 线条样式)  // 线条样式
        }
    }

    方法 置边框线条 <公开 注释 = "向区域添加线条,并设置线条样式.">
    参数 边框 <类型 = Excel边框 注释 = "Excel边框.*,它代表单元格区域或样式的边框之一." @默认值 = Excel边框.底部>
    参数 边框宽度 <类型 = Excel边框粗细 注释 = "Excel边框粗细.*,它代表边框的粗细." @默认值 = Excel边框粗细.细>
    参数 边框颜色 <类型 = 整数 注释 = "以\"RGB\"值表示.默认为黑色." @默认值 = 0>
    参数 线条样式 <类型 = Excel线条样式 注释 = "Excel线条样式.*,它代表边框的线条样式." @默认值 = Excel线条样式.实线>
    {
        变量 Borders <类型 = COM对象类>
        变量 Border <类型 = COM对象类>
        Borders = Range对象.读无参数对象型属性 ("Borders", COM对象类)
        Border = Borders.读对象型属性 ("Item", COM对象类, 边框)
        Border.写属性 ("Weight", 边框宽度)
        Border.写属性 ("Color", 边框颜色)
        Border.写属性 ("LineStyle", 线条样式)
    }
}

类 Excel图表 <公开 注释 = "代表工作表类中的嵌入式图表.">
{
    变量 Chart对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Chart对象 <类型 = COM对象类>
    {
        Chart对象 = 参_Chart对象
        返回 (Chart对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的对象.与\"COM对象\"数据类型兼容,可交互操作." "">
