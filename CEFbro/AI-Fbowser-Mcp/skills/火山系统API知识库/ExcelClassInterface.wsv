    常量 划线后两点 <公开 值 = @xlDashDotDot 注释 = "划线后跟两个点">
}

类 Excel边框粗细 <公开 注释 = "指定某一区域周围的边框的粗细" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 中 <公开 值 = @xlMedium 注释 = "中">
    常量 最细 <公开 值 = @xlHairline 注释 = "细线(最细的边框)">
    常量 细 <公开 值 = @xlThin 注释 = "细">
    常量 粗 <公开 值 = @xlThick 注释 = "粗(最宽的边框)">
}

类 Excel边框 <公开 注释 = "指定要检索的边框" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 左上到右下 <公开 值 = @xlDiagonalDown 注释 = "从区域每个单元格的左上角到右下角的边框">
    常量 左下到右上 <公开 值 = @xlDiagonalUp 注释 = "从区域内每个单元格的左下角到右上角的边框">
    常量 左边 <公开 值 = @xlEdgeLeft 注释 = "区域左边缘的边框">
    常量 顶部 <公开 值 = @xlEdgeTop 注释 = "区域顶部的边框">
    常量 底部 <公开 值 = @xlEdgeBottom 注释 = "区域底部的边框">
    常量 右边 <公开 值 = @xlEdgeRight 注释 = "区域右边缘的边框">
    常量 垂直 <公开 值 = @xlInsideVertical 注释 = "区域中所有单元格的垂直边框(区域以外的边框除外)">
    常量 水平 <公开 值 = @xlInsideHorizontal 注释 = "区域中所有单元格的水平边框(区域以外的边框除外)">
}

类 Excel下划线 <公开 注释 = "指定应用于字体的下划线类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 无 <公开 值 = @xlUnderlineStyleNone 注释 = "无下划线">
    常量 双 <公开 值 = @xlUnderlineStyleDouble 注释 = "双下划线">
    常量 单 <公开 值 = @xlUnderlineStyleSingle 注释 = "单下划线">
    常量 单分开 <公开 值 = @xlUnderlineStyleSingleAccounting 注释 = "与字体分开的单条下划线">
    常量 双分开 <公开 值 = @xlUnderlineStyleDoubleAccounting 注释 = "与字体分开的两条细下划线">
}

