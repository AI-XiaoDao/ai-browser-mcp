类 Excel粘贴格式 <公开 注释 = "指定要粘贴的区域格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 值 <公开 值 = @xlPasteValues 注释 = "粘贴值">
    常量 批注 <公开 值 = @xlPasteComments 注释 = "粘贴批注">
    常量 公式 <公开 值 = @xlPasteFormulas 注释 = "粘贴公式">
    常量 源格式 <公开 值 = @xlPasteFormats 注释 = "粘贴复制的源格式">
    常量 全部内容 <公开 值 = @xlPasteAll 注释 = "粘贴全部内容">
    常量 粘贴有效性 <公开 值 = @xlPasteValidation 注释 = "粘贴有效性">
    常量 边框外全部 <公开 值 = @xlPasteAllExceptBorders 注释 = "粘贴除边框外的全部内容">
    常量 列宽 <公开 值 = @xlPasteColumnWidths 注释 = "粘贴复制的列宽">
    常量 公式和数字 <公开 值 = @xlPasteFormulasAndNumberFormats 注释 = "粘贴公式和数字格式">
    常量 值和数字 <公开 值 = @xlPasteValuesAndNumberFormats 注释 = "粘贴值和数字格式">
    常量 源主题粘贴 <公开 值 = @xlPasteAllUsingSourceTheme 注释 = "使用源主题粘贴全部内容">
    常量 粘贴所有 <公开 值 = @xlPasteAllMergingConditionalFormats 注释 = "将粘贴所有内容,并且将合并条件格式.">
}

类 Excel计算方式 <公开 注释 = "指定如何使用工作表上的目标单元格计算数值数据" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 不计算 <公开 值 = @xlPasteSpecialOperationNone 注释 = "粘贴操作中不执行任何计算">
    常量 相加 <公开 值 = @xlPasteSpecialOperationAdd 注释 = "复制的数据将与到目标单元格中的值相加">
    常量 相减 <公开 值 = @xlPasteSpecialOperationSubtract 注释 = "复制的数据将从目标单元格中的值中减去">
    常量 相乘 <公开 值 = @xlPasteSpecialOperationMultiply 注释 = "复制的数据将乘以目标单元格中的值">
    常量 相除 <公开 值 = @xlPasteSpecialOperationDivide 注释 = "复制的数据将除以目标单元格中的值">
}

类 Excel宏类型 <公开 @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 模块 <公开 值 = @vbext_ct_StdModule 注释 = "模块">
    常量 类模块 <公开 值 = @vbext_ct_ClassModule 注释 = "类模块">
    常量 窗口 <公开 值 = @vbext_ct_MSForm 注释 = "Microsoft 窗体">
    常量 设计器 <公开 值 = @vbext_ct_ActiveXDesigner 注释 = "ActiveX 设计器">
