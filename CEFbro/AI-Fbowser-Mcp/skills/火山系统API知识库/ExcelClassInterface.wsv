    {
        变量 局_单元格 <类型 = Excel单元格>
        局_单元格.置对象 (Application对象.读对象型属性 ("Range", COM对象类, 单元格))
        Application对象.读无参数对象型属性 ("Speech", COM对象类).无返回值方法 ("Speak", 局_单元格.内容)
    }

    方法 活动图表 <公开 属性读 类型 = Excel图表 注释 = "返回一个\"Excel图表\"类,代表 (图表或图表工作表中的活动) .嵌入式图表在被选中或激活时被认为是活动的.当没有图表处于活动状态时,此属性返回空对象.">
    {
        变量 局_Excel图表 <类型 = Excel图表>
        局_Excel图表.置对象 (Application对象.读无参数对象型属性 ("ActiveChart", COM对象类))
        返回 (局_Excel图表)
    }

    方法 图表集数量 <公开 属性读 类型 = 整数 注释 = "表活动工作簿中所有的图表工作表的数量.">
    {
        返回 (Application对象.读无参数对象型属性 ("Charts", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 启动路径 <公开 属性读 类型 = 文本型 注释 = "返回替换启动文件夹的名称">
    {
        返回 (Application对象.读无参数属性 ("AltStartupPath", 文本型))
    }

    方法 启动路径 <公开 属性写 注释 = "设置替换启动文件夹的名称">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Application对象.写属性 ("AltStartupPath", 所欲设置的值)
    }

    方法 自动超链接 <公开 属性读 类型 = 逻辑型 注释 = "如果按照键入的内容自动设置超链接的格式,则该值为真(默认).如果不按照键入的内容自动设置超链接的格式,则该值为假.">
    {
        返回 (Application对象.读无参数属性 ("AutoFormatAsYouTypeReplaceHyperlinks", 逻辑型))
    }

    方法 自动超链接 <公开 属性写 注释 = "如果设置为真,则表示按照键入的内容自动设置超链接的格式.如果设置为假,则表示不按照键入的内容自动设置超链接的格式.注意：只影响设置后输入数据超链接状态.">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Application对象.写属性 ("AutoFormatAsYouTypeReplaceHyperlinks", 所欲设置的值)
    }

    方法 单元格拖放 <公开 属性读 类型 = 逻辑型 注释 = "返回是否启用单元格拖放功能">
    {
        返回 (Application对象.读无参数属性 ("CellDragAndDrop", 逻辑型))
    }

    方法 单元格拖放 <公开 属性写 注释 = "设置是否启用单元格拖放功能">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Application对象.写属性 ("CellDragAndDrop", 所欲设置的值)
    }

    方法 小数分隔符 <公开 属性读 类型 = 文本型 注释 = "返回将用于小数分隔符的字符">
    {
        返回 (Application对象.读无参数属性 ("DecimalSeparator", 文本型))
    }

    方法 小数分隔符 <公开 属性写 注释 = "设置将用于小数分隔符的字符">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Application对象.写属性 ("DecimalSeparator", 所欲设置的值)
    }

    方法 千位分隔符 <公开 属性读 类型 = 文本型 注释 = "返回将用于千位分隔符的字符">
    {
        返回 (Application对象.读无参数属性 ("ThousandsSeparator", 文本型))
    }

    方法 千位分隔符 <公开 属性写 注释 = "设置将用于千位分隔符的字符">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Application对象.写属性 ("ThousandsSeparator", 所欲设置的值)
    }

    方法 自定义分隔符 <公开 属性读 类型 = 逻辑型 注释 = "返回是否启用自定义分隔符,返回真,则表示系统分隔符已启用.">
    {
        返回 (Application对象.读无参数属性 ("UseSystemSeparators", 逻辑型))
    }

    方法 自定义分隔符 <公开 属性写 注释 = "设置是否启用自定义分隔符,如果设置为真,则表示启用系统分隔符.">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Application对象.写属性 ("UseSystemSeparators", 所欲设置的值)
    }

    方法 内部版本 <公开 属性读 类型 = 整数 注释 = "返回Excel内部版本号" "">
    {
        返回 (Application对象.读无参数属性 ("Build", 整数))
    }

    方法 智能图表数量 <公开 属性读 类型 = 整数 注释 = "返回应用程序中当前智能图表集合数量">
    {
        返回 (Application对象.读无参数对象型属性 ("SmartArtLayouts", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取图表 <公开 类型 = Excel图表 注释 = "取活动工作簿中的图表工作表">
    参数 索引号 <类型 = 整数 注释 = "二选一,对象的索引号.从1开始,表示图表在图表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.当\"索引号\"不为0时忽略该参数." @默认值 = "">
    {
        变量 局_图表对象 <类型 = COM对象类>
        变量 局_Excel图表 <类型 = Excel图表>
        如果 (索引号 == 0)
        {
            局_图表对象 = Application对象.读无参数对象型属性 ("Charts", COM对象类).读对象型属性 ("Item", COM对象类, 名称)  // 从图表名取出
        }
        否则
        {
            局_图表对象 = Application对象.读无参数对象型属性 ("Charts", COM对象类).读对象型属性 ("Item", COM对象类, 索引号)  // 从图表索引号取出
        }
        局_Excel图表.置对象 (局_图表对象)
        返回 (局_Excel图表)
    }
}

类 Excel宏 <公开 注释 = "代表VB宏对象">
{
    变量 VBComponents对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_VBComponents对象 <类型 = COM对象类 注释 = "VBComponents对象">
    {
        VBComponents对象 = 参_VBComponents对象
        返回 (VBComponents对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的VB宏对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (VBComponents对象)
    }

    方法 工作区数量 <公开 属性读 类型 = 整数 注释 = "获取宏工作区数量" "">
    {
        返回 (VBComponents对象.读无参数属性 ("Count", 整数))
    }

    方法 取工作区名称 <公开 类型 = 文本型 注释 = "取宏工作区对象名称" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号,从1开始.">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("Name", 文本型))
    }

    方法 取工作区类型 <公开 类型 = Excel宏类型 注释 = "取宏工作区对象类型" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数属性 ("Type", Excel宏类型))
    }

    方法 插入行代码 <公开 注释 = "在指定工作区对应行增加代码,原代码后移.增加代码不理会和判断插入处代码的内容.当指定行大于最后一行行号时,在最后一行的后面插入." "">
    参数 区名 <类型 = 文本型>
    参数 行号 <类型 = 整数>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("InsertLines", 行号, 代码内容)
    }

    方法 添加代码 <公开 注释 = "在指定工作区第一个过程前面的行开始增加代码,原代码后移." "">
    参数 区名 <类型 = 文本型>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("AddFromString", 代码内容)
    }

    方法 添加模块 <公开>
    参数 模块名称 <类型 = 文本型 @默认值 = "">
    参数 类型 <类型 = Excel宏类型 @默认值 = Excel宏类型.模块>
    {
        变量 局_模块对象 <类型 = COM对象类>
        局_模块对象 = VBComponents对象.方法 ("Add", COM对象类, 类型)
        如果 (模块名称 != "")
        {
            局_模块对象.写属性 ("Name", 模块名称)
        }
    }

    方法 取代码行数 <公开 类型 = 整数 注释 = "获取工作区代码总行数" "">
    参数 区名 <类型 = 文本型>
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("CountOfLines", 整数))
    }

    方法 取代码内容 <公开 类型 = 文本型 注释 = "获取工作区宏代码内容" "">
    参数 区名 <类型 = 文本型 注释 = "对象名称,如模块名称.">
    参数 开始行 <类型 = 整数 注释 = "欲取出代码区开始行">
    参数 结束行 <类型 = 整数 注释 = "欲取出代码区结束行">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读属性 ("Lines", 文本型, 开始行, 结束行))
    }

    方法 移除模块 <公开 注释 = "根据宏模块名称移除宏模块">
    参数 模块名 <类型 = 文本型 @默认值 = "">
    {
        变量 COM变体 <类型 = COM变体型>
        COM变体 = VBComponents对象.方法 ("Item", COM变体型, 模块名)  // 根据名称取出对象
        VBComponents对象.无返回值方法 ("Remove", COM变体)
    }

    方法 导入文件 <公开 注释 = "将VB宏代码文件导入宏工作区中" "">
    参数 文件名 <类型 = 文本型 注释 = "欲导入的宏文件">
    {
        VBComponents对象.无返回值方法 ("Import", 文件名)
    }
}

类 Excel工作簿集 <公开 注释 = "当前在Excel程序内打开的所有Excel工作簿集合">
{
    变量 Workbooks对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 集合对象 <类型 = COM对象类 注释 = "Workbooks集合">
    {
        Workbooks对象 = 集合对象
        返回 (Workbooks对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (Workbooks对象)
    }

    方法 新建工作簿 <公开 类型 = Excel工作簿 注释 = "新建一个工作簿.新工作簿将成为活动工作簿.">
    参数 模板 <类型 = 文本型 注释 = "确定如何创建新工作簿.如果此参数为指定现有Excel文件名的字符串,那么创建新工作簿将以该指定的文件作为模板." 注释 = "如果省略此参数,将根据工作表数目设置添加对应空白工作表数量."
            @默认值 = "">
    参数 工作表数目 <类型 = 整数 注释 = "自动插入到新工作簿中的工作表数目" @默认值 = 1>
    {
        变量 局_工作簿 <类型 = Excel工作簿>
        Workbooks对象.读无参数属性 ("Parent", COM对象类).写属性 ("SheetsInNewWorkbook", 工作表数目)
        局_工作簿.置对象 (Workbooks对象.对象型方法 ("Add", COM对象类, 模板))
        返回 (局_工作簿)
    }

    方法 关闭 <公开 注释 = "关闭所有工作簿">
    {
        Workbooks对象.无参数及返回值方法 ("Close")
    }

    方法 打开 <公开 注释 = "打开一个工作簿" "">
    参数 文件名 <类型 = 文本型 注释 = "要打开的工作簿的文件名">
    参数 只读模式 <类型 = 逻辑型 注释 = "如果为真,则以只读模式打开工作簿." @默认值 = 假>
    参数 密码 <类型 = 文本型 注释 = "包含打开受保护工作簿所需密码的字符串.如果省略此参数并且工作簿需要密码,则会提示用户输入密码." @默认值 = "">
    参数 写权限密码 <类型 = 文本型 注释 = "包含写入写保护的工作簿所需密码的字符串.如果省略此参数并且工作簿需要密码,则将提示用户输入密码." @默认值 = "">
    参数 显示建议消息 <类型 = 逻辑型 注释 = "当该工作簿以建议只读选项保存时,如果该选项为真,则不让程序显示只读的建议消息." @默认值 = 假>
    参数 分隔符 <类型 = 整数 注释 = "1 TAB;2 逗号;3 空格;4 分号;5 不使用分隔符;6 自定义.此参数指定要用作分隔符的字符." @默认值 = 5>
    参数 自定义分隔符 <类型 = 文本型 注释 = "如果文件是文本文件且分隔符参数为6自定义时,此参数指定要用作分隔符的字符.如分隔符字符串长度大于1,只使用字符串的第一个字符." @默认值 = "">
    参数 可视 <类型 = 逻辑型 注释 = "如果版本号4.0程序,则此参数为真时可打开该外接程序以使其成为可见窗口.如果此参数为假或被省略,则以隐藏方式打开外接程序,并且无法设为可见.此选项不适用于在版本号5.0或更高版本中创建的加载项."
            @默认值 = 假>
    参数 请求通知 <类型 = 逻辑型 注释 = "当文件不能以可读写模式打开时,如果此参数为真,则可将该文件添加到文件通知列表.程序将以只读模式打开该文件并轮询文件通知列表,并在文件可用时向用户发出通知.如果此参数为假或省略,则不会请求通知."
            @默认值 = 假>
    参数 添加到使用列表 <类型 = 逻辑型 注释 = "如果为真,则将该工作簿添加到最近使用的文件列表中." @默认值 = 假>
    参数 打开方式 <类型 = Excel打开方式 注释 = "Excel打开方式.*" @默认值 = Excel打开方式.正常>
    {
        变量 COM变体 <类型 = COM变体型>
        Workbooks对象.无返回值方法 ("Open", 文件名, 0, 只读模式, 分隔符, 密码, 写权限密码, 显示建议消息, COM变体, 自定义分隔符, 可视, 请求通知, COM变体, 添加到使用列表, 假, 打开方式)
    }

    方法 打开文本文件 <公开 注释 = "新建一个带有工作表的工作簿并打开一个文本文件将数据填充到工作表中" "">
    参数 文件名 <类型 = 文本型 注释 = "要打开文本文件的文件名">
    参数 编码 <类型 = Excel编码 注释 = "Excel编码.*,指定的文本文件来源编码方式." @默认值 = Excel编码.UTF8>
    参数 行号 <类型 = 整数 注释 = "文本文件分析开始处的行号" @默认值 = 1>
    参数 文本识别符 <类型 = 整数 注释 = "1 双引号(\");2 单引号 (\');-4142 无分隔符." @默认值 = -4142>
    参数 分隔符 <类型 = 整数 注释 = "1 TAB;2 逗号;3 空格;4 分号;5 不使用分隔符;6 自定义.此参数指定要用作分隔符的字符." @默认值 = 5>
    参数 自定义分隔符 <类型 = 文本型 注释 = "如果文件是文本文件且分隔符参数为6自定义时,此参数指定要用作分隔符的字符.如分隔符字符串长度大于1,只使用字符串的第一个字符." @默认值 = "">
    参数 连续分隔符 <类型 = 逻辑型 注释 = "如果为真,则将连续分隔符视为一个分隔符." @默认值 = 假>
    {
        变量 COM变体 <类型 = COM变体型>
        Workbooks对象.无返回值方法 ("OpenText", 文件名, 编码, 行号, 1, 文本识别符, 连续分隔符, 选择 (分隔符 == 1, 真, 假), 选择 (分隔符 == 4, 真, 假), 选择 (分隔符 == 2, 真, 假), 选择 (分隔符 == 3, 真, 假), 选择 (分隔符 == 6, 真, 假), 自定义分隔符)
    }

    方法 打开数据库 <公开 类型 = Excel工作表 注释 = "打开一个数据库到工作表中">
    参数 文件名 <类型 = 文本型 注释 = "包含数据库的位置和文件名的连接字符串" "">
    参数 查询命令 <类型 = 文本型 注释 = "查询的命令文本" @默认值 = "">
    参数 查询类型 <类型 = Excel查询类型 注释 = "Excel查询类型.*,查询的命令类型" @默认值 = Excel查询类型.命令文本>
    参数 后台查询 <类型 = 逻辑型 注释 = "真,表示将在后台(异步)执行查询." @默认值 = 假>
    参数 返回格式 <类型 = Excel数据库形式 注释 = "Excel数据库形式.*,设置以数据透视表或查询表的形式返回数据." @默认值 = Excel数据库形式.查询表形式>
    {
        变量 局_工作表 <类型 = Excel工作表>
        局_工作表.置对象 (Workbooks对象.对象型方法 ("OpenDatabase", COM对象类, 文件名, 查询命令, 查询类型, 后台查询, 返回格式))
        返回 (局_工作表)
    }

    方法 打开XML文件 <公开 类型 = Excel工作表 注释 = "打开一个XML数据文件.返回一个Excel工作表类.">
    参数 文件名 <类型 = 文本型 注释 = "要打开的文件名">
    参数 XML打开方式 <类型 = ExcelXML打开方式 注释 = "ExcelXML打开方式.*,指定Excel打开XML数据文件的方式." @默认值 = ExcelXML打开方式.提示选择>
    {
        变量 局_工作表 <类型 = Excel工作表>
        局_工作表.置对象 (Workbooks对象.方法 ("OpenXML", COM对象类, 文件名, 0, XML打开方式))
        返回 (局_工作表)
    }

    方法 工作簿数量 <公开 属性读 类型 = 整数 注释 = "返回集合中对象的数量">
    {
        返回 (Workbooks对象.读无参数属性 ("Count", 整数))
    }

    方法 取工作簿 <公开 类型 = Excel工作簿 注释 = "从工作簿集合中返回一个工作簿">
    参数 索引号 <类型 = 整数 注释 = "二选一,从1开始,对象在工作簿集合的索引号.为0时.忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.当\"索引号\"不为0时.忽略该参数." @默认值 = "">
    {
        变量 局_WorkBook <类型 = Excel工作簿>
        如果 (索引号 == 0)
        {
            如果 (名称 != "")  // 名称不为空时根据名称取出工作簿
            {
                局_WorkBook.置对象 (Workbooks对象.读对象型属性 ("Item", COM对象类, 名称))  // 使用名称
            }
        }
        否则
        {
            局_WorkBook.置对象 (Workbooks对象.读对象型属性 ("Item", COM对象类, 索引号))  // 使用索引号
        }
        返回 (局_WorkBook)
    }
}

类 Excel工作簿 <公开 注释 = "代表一个Excel工作簿">
{
    变量 Workbook对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Workbook对象 <类型 = COM对象类>
    {
        Workbook对象 = 参_Workbook对象
        返回 (Workbook对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (Workbook对象)
    }

    方法 关闭 <公开 注释 = "关闭对象">
    参数 保存更改 <类型 = 逻辑型 注释 = "如果工作簿无更改,则忽略该参数.如果工作簿存在更改且其在其他打开的窗口中显示,则忽略此参数." 注释 = "如果工作簿中有改动且工作簿未显示在任何其他打开的窗口中,则由此参数指定是否应保存更改."
            注释 = "如果设为真,则保存对工作簿所做的更改." 注释 = "如果还没有与工作簿关联的文件名,则使用保存文件名.如果省略保存文件名,则要求用户提供文件名." @默认值 = 假>
    参数 保存文件名 <类型 = 文本型 注释 = "保存此文件名下的更改" @默认值 = "">
    {
        Workbook对象.无返回值方法 ("Close", 保存更改, 保存文件名)
    }

    方法 激活 <公开 注释 = "激活该工作簿,全其成为活动工作簿">
    {
        Workbook对象.无参数及返回值方法 ("Activate")
    }

    方法 添加到收藏夹 <公开 注释 = "将工作簿或超链接的快捷方式添加到\"收藏夹\"文件夹">
    {
        Workbook对象.无参数及返回值方法 ("AddToFavorites")
    }

    方法 另存为 <公开 注释 = "将工作簿保存到其他位置" 编辑时信息 = "152A95, 0, 0, 0">
    参数 保存文件名 <类型 = 文本型 注释 = "一个表示要保存文件的文件名的字符串.可包含完整路径,如果不指定路径,程序将文件保存到当前文件夹中." 编辑时信息 = "152A95, 0, 0, 0" "">
    参数 文件格式 <类型 = Excel文件格式 注释 = "Excel文件格式.*,保存文件时使用的文件格式.有关有效选项的列表,对于现有文件,默认采用上一次指定的文件格式;对于新文件,默认采用当前所用Excel版本的格式."
            编辑时信息 = "152A95, 0, 0, 0" @默认值 = Excel文件格式.默认工作簿>
    参数 密码 <类型 = 文本型 注释 = "它是一个区分大小写的字符串(最长不超过15个字符),用于指定文件的保护密码." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = "">
    参数 写权限密码 <类型 = 文本型 注释 = "一个表示文件写保护密码的字符串.如果文件保存时带有密码,但打开文件时不输入密码,则该文件以只读方式打开." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = "">
    参数 只读方式 <类型 = 逻辑型 注释 = "如果为真,则在打开文件时显示一条消息,提示该文件以只读方式打开." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = 假>
    参数 创建备份文件 <类型 = 逻辑型 注释 = "如果为真,则创建备份文件." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = 假>
    参数 访问模式 <类型 = Excel访问模式 注释 = "Excel访问模式.*,工作簿的访问模式." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = Excel访问模式.默认值>
    参数 冲突方式 <类型 = Excel冲突方式 注释 = "Excel冲突方式.*,用于确定该方法在保存工作簿时如何解决冲突.如果省略此参数,则显示冲突处理对话框." 编辑时信息 = "152A95, 0, 0, 0"
            @默认值 = Excel冲突方式.弹对话框>
    参数 添加到使用列表 <类型 = 逻辑型 注释 = "如果为真,则将该工作簿添加到最近使用的文件列表中." @默认值 = 假>
    {
        Workbook对象.无返回值方法 ("SaveAs", 保存文件名, 文件格式, 密码, 写权限密码, 只读方式, 创建备份文件, 访问模式, 冲突方式, 添加到使用列表)
    }

    方法 保存 <公开 注释 = "保存对指定工作簿所做的更改">
    {
        Workbook对象.无参数及返回值方法 ("Save")
    }

    方法 工作表集 <公开 属性读 类型 = Excel工作表集 注释 = "返回一个\"Excel工作表集\"类,该集合代表指定工作簿中所有的工作表.">
    {
        变量 局_工作表集 <类型 = Excel工作表集>
        局_工作表集.置对象 (Workbook对象.读无参数对象型属性 ("Sheets", COM对象类))
        返回 (局_工作表集)
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "返回对象名称">
    {
        返回 (Workbook对象.读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "设置对象名称">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Workbook对象.写属性 ("Name", 所欲设置的值)
    }

    方法 宏 <公开 属性读 类型 = Excel宏 注释 = "返回工作簿中的VB宏项目">
    {
        变量 局_Excel宏 <类型 = Excel宏>
        变量 局_宏工作区对象 <类型 = COM对象类>
        局_宏工作区对象 = Workbook对象.读无参数对象型属性 ("VBProject", COM对象类).读无参数对象型属性 ("VBComponents", COM对象类)
        局_Excel宏.置对象 (局_宏工作区对象)
        返回 (局_Excel宏)
    }

    方法 密码 <公开 属性读 类型 = 文本型 注释 = "返回在打开指定工作簿时必须提供的密码">
    {
        返回 (Workbook对象.读无参数属性 ("PassExcel", 文本型))
    }

    方法 密码 <公开 属性写 注释 = "设置在打开指定工作簿时必须提供的密码">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Workbook对象.写属性 ("PassExcel", 所欲设置的值)
    }

    方法 写权限密码 <公开 属性读 类型 = 文本型 注释 = "返回在写入工作簿时必须提供的密码">
    {
        返回 (Workbook对象.读无参数属性 ("WritePassExcel", 文本型))
    }

    方法 写权限密码 <公开 属性写 注释 = "设置在写入工作簿时必须提供的密码">
