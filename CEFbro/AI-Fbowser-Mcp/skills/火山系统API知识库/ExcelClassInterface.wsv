    方法 缩进 <公开 属性读 类型 = 逻辑型 注释 = "返回单元格中的文本对齐方式设置为水平或垂直方向的文本是否自动缩进">
    {
        返回 (Range对象.读无参数属性 ("AddIndent", 逻辑型))
    }

    方法 缩进 <公开 属性写 注释 = "设置单元格中的文本对齐方式设置为水平或垂直方向的文本是否自动缩进">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Range对象.写属性 ("AddIndent", 所欲设置的值)
    }

    方法 自适应列宽 <公开 属性读 类型 = 逻辑型 注释 = "返回文本是否自动缩小以适应可用列宽">
    {
