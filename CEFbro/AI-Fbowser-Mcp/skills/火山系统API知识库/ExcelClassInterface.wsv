    {
        Workbook对象.写属性 ("WritePassExcel", 所欲设置的值)
    }
}

类 Excel工作表集 <公开 注释 = "指定的或活动工作簿中所有工作表的集合,包含工作表类和图表类集合.">
{
    变量 Sheets对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Sheets对象 <类型 = COM对象类>
    {
        Sheets对象 = 参_Sheets对象
        返回 (Sheets对象.是否为空 () == 假)
    }

    方法 删除工作表 <公开 注释 = "删除工作表集合中的某个工作表">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示工作表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.当\"索引号\"不为0时忽略该参数." @默认值 = "">
    {
        如果 (索引号 == 0)
        {
            Sheets对象.读对象型属性 ("Item", COM对象类, 名称).无参数及返回值方法 ("Delete")  // 名称取工作表
        }
        否则
        {
            Sheets对象.读对象型属性 ("Item", COM对象类, 索引号).无参数及返回值方法 ("Delete")  // 索引号取工作表
        }
    }

    方法 打印 <公开 注释 = "打印对象.\"开始页号\"和\"终止页号\"的说明中的\"页面\"是指打印的页面,而不是工作表或工作簿中的整个页面.">
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号.如果值为-1时,则省略此参数,则从起始位置开始打印." @默认值 = -1>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号.如果值为-1时,则省略此参数,则打印至最后一页." @默认值 = -1>
    参数 打印份数 <类型 = 整数 注释 = "打印份数.如果值为-1时,则省略此参数,则只打印一份." @默认值 = -1>
    参数 打印前预览 <类型 = 逻辑型 注释 = "如果为真,将在打印对象之前调用打印预览.如果为假,则立即打印对象." @默认值 = 假>
    参数 活动打印机 <类型 = 文本型 注释 = "设置活动打印机的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    参数 输出文件 <类型 = 逻辑型 注释 = "如果为真,则打印到文件.如果未指定\"输出文件名\",将提示用户输入输出文件的名称." @默认值 = 假>
    参数 逐份打印 <类型 = 逻辑型 注释 = "如果为真,则逐份打印多个副本." @默认值 = 真>
    参数 输出文件名 <类型 = 文本型 注释 = "如果\"输出文件\"设置为真,则此参数指定要打印到的文件的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    参数 区域打印 <类型 = 逻辑型 注释 = "如果为真,则忽略打印区域并打印整个对象." @默认值 = 真>
    {
        变量 局_开始页号 <类型 = COM变体型>
        变量 局_终止页号 <类型 = COM变体型>
        变量 局_打印份数 <类型 = COM变体型>
        变量 局_活动打印机 <类型 = COM变体型>
        变量 局_输出文件名 <类型 = COM变体型>
        如果 (开始页号 != -1)
        {
            局_开始页号.赋值 (开始页号)
        }
        如果 (终止页号 != -1)
        {
            局_终止页号.赋值 (终止页号)
        }
        如果 (打印份数 != -1)
        {
            局_打印份数.赋值 (打印份数, )
        }
        如果 (活动打印机 != "")
        {
            局_活动打印机.赋值 (活动打印机, )
        }
        如果 (输出文件名 != "")
        {
            局_输出文件名.赋值 (输出文件名, )
        }
        Sheets对象.无返回值方法 ("PrintOut", 局_开始页号, 局_终止页号, 局_打印份数, 打印前预览, 局_活动打印机, 输出文件, 逐份打印, 局_输出文件名, 区域打印)
    }

    方法 打印预览 <公开 注释 = "按对象打印后的外观效果显示对象的预览">
    参数 更改边距和设置选项 <类型 = 逻辑型 注释 = "指定用户是否可更改边距和打印预览中可用的其他页面设置选项" @默认值 = 假>
    {
        Sheets对象.无返回值方法 ("PrintPreview", 更改边距和设置选项)
    }

    方法 选择对象 <公开 注释 = "选择对象">
    参数 替换指定对象 <类型 = 逻辑型 注释 = "为当前所选内容替换为指定的对象.如果为假,则扩展当前选定内容以包括任何以前选定的对象和指定的对象." @默认值 = 假>
    {
        Sheets对象.无返回值方法 ("Select", 替换指定对象)
    }

    方法 复制工作表 <公开 类型 = 逻辑型 注释 = "将工作表复制到工作簿中的其他位置.如没有指定要复制到哪个表前或后.则新建一个工作簿,复制到新建的工作簿中.">
    参数 索引号 <类型 = 整数 注释 = "与\"名称\"二选一,对象的索引号.从1开始,表示工作表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "与\"索引号\"二选一,对象的名称.当\"索引号\"不为0时,忽略该参数." @默认值 = "">
    参数 到表索引 <类型 = 整数 注释 = "与\"到表名\"二选一,从1开始,在其之前或之后复制工作表的工作表索引.当值为0时,忽略该参数." @默认值 = 0>
    参数 到表名 <类型 = 文本型 注释 = "与\"到表索引\"二选一,在其之前或之后复制工作表的工作表名称.当表\"索引\"不为0时,忽略该参数." @默认值 = "">
    参数 到表前后 <类型 = 逻辑型 注释 = "如果为真,表示复制\"到表索引\"或\"到表名\"前的位置;如果为假,表示复制\"到表索引\"或\"到表名\"后的位置." @默认值 = 假>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 操作结果 <类型 = 逻辑型>
        如果 (索引号 == 0 && 名称 == "")  // 没有要复制的对象,直接返回假.
        {
            返回 (假)
        }
        如果 (到表索引 == 0 && 到表名 == "")  // 没有指定要复制到哪个表前或后.则新建一个工作簿,复制到新建的工作簿中.
        {
            返回 (取工作表 (索引号, 名称).取对象 ().无参数及返回值方法 ("Copy"))
        }
        如果 (到表前后)
        {
            操作结果 = 取工作表 (索引号, 名称).取对象 ().无返回值方法 ("Copy", 取工作表变体型 (到表索引, 到表名))  // 复制到指定表前
        }
        否则
        {
            操作结果 = 取工作表 (索引号, 名称).取对象 ().无返回值方法 ("Copy", COM变体, 取工作表变体型 (到表索引, 到表名))  // 复制到指定表后
        }
        返回 (操作结果)
    }

    方法 移动工作表 <公开 类型 = 逻辑型 注释 = "将工作表移动到工作簿中的其他位置.如没有指定要移动到哪个表前或后.则新建一个工作簿,移动到新建的工作簿中.">
    参数 索引号 <类型 = 整数 注释 = "与\"名称\"二选一,对象的索引号.从1开始,表示工作表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "与\"索引号\"二选一,对象的名称.当\"索引号\"不为0时,忽略该参数." @默认值 = "">
    参数 到表索引 <类型 = 整数 注释 = "与\"到表名\"二选一,从1开始,在其之前或之后移动工作表的工作表索引.为0时忽略该参数." @默认值 = 0>
    参数 到表名 <类型 = 文本型 注释 = "与\"到表索引\"二选一,在其之前或之后移动工作表的工作表名称.当\"到表索引\"不为0时,忽略该参数." @默认值 = "">
    参数 到表前后 <类型 = 逻辑型 注释 = "如果为真,表示移动\"到表索引\"或\"到表名\"前的位置;如果为假,表示移动\"到表索引\"或\"到表名\"后的位置." @默认值 = 假>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 操作结果 <类型 = 逻辑型>
        如果 (索引号 == 0 && 名称 == "")  // 没有要移动的对象 直接返回假.
        {
            返回 (假)
        }
        如果 (到表索引 == 0 && 到表名 == "")  // 没有指定要移动到哪个表前或后.则新建一个工作簿,移动到新建的工作簿中.
        {
            返回 (取工作表 (索引号, 名称).取对象 ().无参数及返回值方法 ("Move"))
        }
        如果 (到表前后)
        {
            操作结果 = 取工作表 (索引号, 名称).取对象 ().无返回值方法 ("Move", 取工作表变体型 (到表索引, 到表名))  // 移动到指定表前
        }
        否则
        {
            操作结果 = 取工作表 (索引号, 名称).取对象 ().无返回值方法 ("Move", COM变体, 取工作表变体型 (到表索引, 到表名))  // 移动到指定表后
        }
        返回 (操作结果)
    }

    方法 工作表数量 <公开 属性读 类型 = 整数 注释 = "返回一个\"整数\"值,它代表集合中对象的数量.">
    {
        返回 (Sheets对象.读无参数属性 ("Count", 整数))
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的对象.与\"COM对象\"数据类型兼容,可交互操作.">
    {
        返回 (Sheets对象)
    }

    方法 新建工作表 <公开 类型 = Excel工作表 注释 = "创建新的工作表、图表或宏工作表.新工作表成为活动工作表.如果同时省略 到表索引 和 到表名,则新工作表插入到活动工作表之前.">
    参数 到表索引 <类型 = 整数 注释 = "与\"到表名\"二选一,从1开始,在其之前或之后新建工作表的工作表索引.为0时,忽略该参数." @默认值 = 0>
    参数 到表名 <类型 = 文本型 注释 = "与\"到表索引\"二选一,在其之前或之后新建工作表的工作表名称.当\"表索引\"不为0时,忽略该参数." @默认值 = "">
    参数 到表前后 <类型 = 逻辑型 注释 = "如果为真,表示新建\"到表索引\"或\"到表名\"前的位置;如果为假,表示新建\"到表索引\"或\"到表名\"后的位置." @默认值 = 假>
    参数 工作表数 <类型 = 整数 注释 = "要添加的工作表数" @默认值 = 1>
    参数 工作表类型 <类型 = Excel表类型 注释 = "Excel表类型.*,指定工作表类型." @默认值 = Excel表类型.工作表>
    {
        变量 局_工作表 <类型 = Excel工作表>
        变量 表_COM变体 <类型 = COM变体型>
        变量 COM变体 <类型 = COM变体型>
        如果 (到表索引 != 0 || 到表名 != "")
        {
            表_COM变体 = 取工作表变体型 (到表索引, 到表名)  // 取表变体型作为参数
        }
        如果 (到表前后)
        {
            局_工作表.置对象 (Sheets对象.对象型方法 ("Add", COM对象类, 表_COM变体, COM变体, 工作表数, 工作表类型))  // 新建到指定表前
        }
        否则
        {
            局_工作表.置对象 (Sheets对象.对象型方法 ("Add", COM对象类, COM变体, 表_COM变体, 工作表数, 工作表类型))  // 新建到指定表后
        }
        返回 (局_工作表)
    }

    方法 取工作表 <公开 类型 = Excel工作表 注释 = "从工作表集合中返回一个工作表对象.">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示工作表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.当\"索引号\"不为0时,忽略该参数." @默认值 = "">
    {
        变量 局_工作表 <类型 = Excel工作表>
        如果 (索引号 == 0)
        {
            局_工作表.置对象 (Sheets对象.读对象型属性 ("Item", COM对象类, 名称))  // 名称取工作表
        }
        否则
        {
            局_工作表.置对象 (Sheets对象.读对象型属性 ("Item", COM对象类, 索引号))  // 索引号取工作表
        }
        返回 (局_工作表)
    }

    方法 取图表 <公开 类型 = Excel图表 注释 = "从工作表集合中返回一个图表对象">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示图表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.当\"索引号\"不为0时,忽略该参数." @默认值 = "">
    {
        变量 局_图表 <类型 = Excel图表>
        如果 (索引号 == 0)
        {
            局_图表.置对象 (Sheets对象.读对象型属性 ("Item", COM对象类, 名称))  // 名称取工作表
        }
        否则
        {
            局_图表.置对象 (Sheets对象.读对象型属性 ("Item", COM对象类, 索引号))  // 索引号取工作表
        }
        返回 (局_图表)
    }

    方法 取工作表变体型 <类型 = COM变体型 注释 = "从工作表集合中返回一个工作表变体型.不公开,当工作表需要作为参数时使用.">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示工作表在工作表集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.当\"索引号\"不为0时,忽略该参数." @默认值 = "">
    {
        变量 局_COM变体 <类型 = COM变体型>
        如果 (索引号 == 0)
        {
            局_COM变体 = Sheets对象.读属性 ("Item", COM变体型, 名称)  // 名称取工作表
        }
        否则
        {
            局_COM变体 = Sheets对象.读属性 ("Item", COM变体型, 索引号)  // 索引号取工作表
        }
        返回 (局_COM变体)
    }
}

类 Excel工作表 <公开 注释 = "代表一个Excel工作表">
{
    变量 Worksheet对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
