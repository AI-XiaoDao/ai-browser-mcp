    方法 添加图片 <公开 注释 = "添加一幅硬盘中的图片文件">
    参数 文件名 <类型 = 文本型 注释 = "要创建图片的文件.">
    参数 链接到文件 <类型 = 逻辑型 注释 = "若指定为真,就建立图片与其源文件之间的链接.若指定为假,就使图片成为与其源文件的相互独立的复制品.">
    参数 全部保存 <类型 = 逻辑型 注释 = "若为真,则将链接图片和插入图片的文档全部保存;若为假,则只在文档中保存链接信息.如果链接到文件为假,则本参数必须为真">
    参数 左边 <类型 = 小数 注释 = "图片左上角相对于文档左上角的位置(以磅为单位).">
    参数 顶边 <类型 = 小数 注释 = "图片左上角相对于文档顶部的位置(以磅为单位).">
    参数 宽度 <类型 = 小数 注释 = "图片的宽度,-1 表示保留现有文件的宽度." @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "图片的高度,-1 表示保留现有文件的高度." @默认值 = -1>
    {
        Worksheet对象.读无参数对象型属性 ("Shapes", COM对象类).无返回值方法 ("AddPicture", 文件名, 链接到文件, 全部保存, 左边, 顶边, 宽度, 高度)
    }

    方法 保护 <公开 注释 = "保护工作表">
    参数 密码 <类型 = 文本型 注释 = "指定保护工作表的区分大小写密码的字符串.如果指定密码对工作表保护,忘记密码,则无法解除对工作表的保护." @默认值 = "">
    参数 保护单元格 <类型 = 逻辑型 注释 = "如果为真,则保护形状.默认值为真." @默认值 = 真>
    参数 解除单元格 <类型 = 逻辑型 注释 = "如果为真,则保护内容.对于图表,这将保护整个图表.对于工作表,这将保护锁定单元格.默认值为真." @默认值 = 真>
    参数 保护方案 <类型 = 逻辑型 注释 = "如果为真,则保护方案.此参数仅对工作表有效.默认值为真." @默认值 = 真>
    参数 保护界面 <类型 = 逻辑型 注释 = "如果为真,则保护用户界面,但不保护宏.如果省略此参数,保护将应用于宏和用户界面." @默认值 = 假>
    参数 设置单元格 <类型 = 逻辑型 注释 = "如果为真,则允许用户格式化受保护工作表上的任何单元格.默认值为假." @默认值 = 假>
    参数 设置列格式 <类型 = 逻辑型 注释 = "如果为真,则允许用户格式化受保护工作表上的任何列.默认值为假." @默认值 = 假>
    参数 设置行格式 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上设置任何行的格式.默认值为假." @默认值 = 假>
    参数 插入列 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护工作表上插入列.默认值为假." @默认值 = 假>
    参数 插入行 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护工作表上插入行.默认值为假." @默认值 = 假>
    参数 插入超链接 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上插入超链接.默认值为假." @默认值 = 假>
    参数 删除列 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上删除列,其中要删除的列中的每个单元格都处于解锁状态.默认值为假." @默认值 = 假>
    参数 删除行 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上删除行,其中要删除的行中的每个单元格都处于解锁状态.默认值为假." @默认值 = 假>
    参数 排序 <类型 = 逻辑型 注释 = "如果为真,则允许用户对受保护工作表进行排序.排序范围内的每个单元都必须处于解锁或不受保护的状态.默认值为假." @默认值 = 假>
    参数 使用筛选 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上设置筛选.用户可以更改筛选条件,但无法启用或禁用自动筛选.用户可以在现有自动筛选上设置筛选.默认值为假." @默认值 = 假>
    参数 使用透视表 <类型 = 逻辑型 注释 = "如果为真,则允许用户在受保护的工作表上使用数据透视表.默认值为假." @默认值 = 假>
    {
        Worksheet对象.无返回值方法 ("Protect", 密码, 保护单元格, 解除单元格, 保护方案, 保护界面, 设置单元格, 设置列格式, 设置行格式, 插入列, 插入行, 插入超链接, 删除列, 删除行, 排序, 使用筛选, 使用透视表)
    }

    方法 解除保护 <公开 注释 = "解除工作表保护">
    参数 密码 <类型 = 文本型 注释 = "指定保护工作表的区分大小写密码的字符串.如果忘记密码,则无法解除对工作表的保护." @默认值 = "">
    {
        Worksheet对象.无返回值方法 ("Unprotect", 密码)
    }

    方法 置背景图 <公开 注释 = "为工作表设置背景图形">
    参数 文件名 <类型 = 文本型 注释 = "要创建图片的文件.">
    {
        Worksheet对象.无返回值方法 ("SetBackgroundPicture", 文件名)
    }

    方法 取图表 <公开 类型 = Excel图表 注释 = "返回\"Excel图表\",代表从工作表中所有图表集合根据索引号取出其中一个图表.">
    参数 索引号 <类型 = 整数 注释 = "从1开始.">
    {
        变量 局_图表 <类型 = Excel图表>
        变量 COM对象 <类型 = COM对象类>
        COM对象 = Worksheet对象.对象型方法 ("ChartObjects", COM对象类, 索引号).读无参数对象型属性 ("Chart", COM对象类)  // 从工作表中的所有图表集合中根据索引号取出图表对象.
        局_图表.置对象 (COM对象)
        返回 (局_图表)
    }

    方法 添加图表 <公开 类型 = Excel图表 注释 = "在工作表中添加一个\"Excel图表\".并返回所添加Excel图表.">
    参数 左边 <类型 = 小数 注释 = "新对象的左边坐标,相对于工作表上单元格A1的左上角或图表的左上角.">
    参数 顶边 <类型 = 小数 注释 = "新对象的顶边坐标,相对于工作表上单元格A1的左上角或图表的左上角.">
    参数 宽度 <类型 = 小数 注释 = "以磅为单位给出新对象的宽度大小.">
    参数 高度 <类型 = 小数 注释 = "以磅为单位给出新对象的高度大小.">
    {
        变量 COM对象 <类型 = COM对象类>
        变量 局_图表 <类型 = Excel图表>
        COM对象 = Worksheet对象.无参数对象型方法 ("ChartObjects", COM对象类).对象型方法 ("Add", COM对象类, 左边, 顶边, 宽度, 高度)  // 添加图表并取出图表对象.
        局_图表.置对象 (COM对象.读无参数对象型属性 ("Chart", COM对象类))
        返回 (局_图表)
    }

    方法 图表总数 <公开 属性读 类型 = 整数 注释 = "在工作表中所有嵌入式图表的数量">
    {
        返回 (Worksheet对象.无参数对象型方法 ("ChartObjects", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 置图表打印 <公开 注释 = "设置当打印工作表时是否连同嵌入的图表一起打印">
    参数 是否打印 <类型 = 逻辑型>
    参数 索引号 <类型 = 整数 注释 = "工作表中的图表集合的索引号." 注释 = "为0时表示对所有图表进行设置," @默认值 = 0>
    {
        如果 (索引号 != 0)  // 只设置其中的某个图表是否打印
        {
            Worksheet对象.对象型方法 ("ChartObjects", COM对象类, 索引号).写属性 ("PrintObject", 是否打印)
        }
        否则
        {
            计次循环 (图表总数)  // 设置所有图表是否打印
            {
                Worksheet对象.对象型方法 ("ChartObjects", COM对象类, 取循环索引 () + 1).写属性 ("PrintObject", 是否打印)
            }
        }
    }
}

类 Excel单元格 <公开 注释 = "代表某一单元格、某一行、某一列、某一选定区域(该区域可包含一个或若干连续单元格区域),或者某一三维区域.">
{
    变量 Range对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Range对象 <类型 = COM对象类>
    {
        Range对象 = 参_Range对象
        返回 (Range对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Excel提供的对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (Range对象)
    }

    方法 分列 <公开 注释 = "将包含文本的一列单元格分解为若干列">
    参数 区域 <类型 = 文本型 注释 = "指定放置结果的位置,如果该区域大于一个单元格,则使用左上角的单元格.">
    参数 文本识别符 <类型 = 整数 注释 = "1 双引号(\");2 单引号 (\');-4142 无分隔符." @默认值 = -4142>
    参数 分隔符 <类型 = 整数 注释 = "1 TAB;2 逗号;3 空格;4 分号;5 不使用分隔符;6 自定义.此参数指定要用作分隔符的字符." @默认值 = 5>
    参数 自定义分隔符 <类型 = 文本型 注释 = "如果文件是文本文件且分隔符参数为6自定义时,此参数指定要用作分隔符的字符.如分隔符字符串长度大于1,只使用字符串的第一个字符." @默认值 = "">
    参数 连续分隔符 <类型 = 逻辑型 注释 = "如果为真,则将连续分隔符视为一个分隔符." @默认值 = 假>
    {
        变量 局_区域变体 <类型 = COM变体型>
        局_区域变体 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 区域)  // 取出用于放置结果位置的变体型
        Range对象.无返回值方法 ("TextToColumns", 局_区域变体, 1, 文本识别符, 连续分隔符, 选择 (分隔符 == 1, 真, 假), 选择 (分隔符 == 4, 真, 假), 选择 (分隔符 == 2, 真, 假), 选择 (分隔符 == 3, 真, 假), 选择 (分隔符 == 6, 真, 假), 自定义分隔符)
    }

    方法 插入列 <公开 注释 = "往区域始点到终点插入与对应空列数">
    参数 插入方式 <类型 = Excel插入方式 注释 = "Excel插入方式.*" @默认值 = Excel插入方式.向右>
    {
        Range对象.读无参数对象型属性 ("Columns", COM对象类).无返回值方法 ("Insert", 插入方式)
    }

    方法 插入行 <公开 注释 = "往区域始点到终点插入对应空行数">
    参数 插入方式 <类型 = Excel插入方式 注释 = "Excel插入方式.*" @默认值 = Excel插入方式.向下>
    {
        Range对象.读无参数对象型属性 ("Rows", COM对象类).无返回值方法 ("Insert", 插入方式)
    }

    方法 选定 <公开 注释 = "要选择单元格或单元格区域.使用激活单元格方法前需要先执行选定.">
    {
        Range对象.无参数及返回值方法 ("Select")
    }

    方法 激活 <公开 注释 = "激活单个单元格,该单元格必须处于当前选定区域内.若要选择单元格区域,请使用\"选定\"方法.">
    {
        Range对象.无参数及返回值方法 ("Activate")
    }

    方法 清除内容 <公开 注释 = "清除整个对象内容">
    {
        Range对象.无参数及返回值方法 ("Clear")
    }

    方法 清除格式 <公开 注释 = "清除对象的格式设置">
    {
        Range对象.无参数及返回值方法 ("ClearFormats")
    }

    方法 清空 <公开 注释 = "清理区域中的公式和值">
    {
        Range对象.无参数及返回值方法 ("ClearContents")
    }

    方法 删除 <公开 注释 = "删除单元格.可设置删除移位方式.">
    参数 移位方式 <类型 = Excel移动方式 注释 = "Excel移动方式.*" @默认值 = Excel移动方式.向左>
    {
        Range对象.无返回值方法 ("Delete", 移位方式)
    }

    方法 插入 <公开 注释 = "插入单元格.可设置插入移动方向.">
    参数 插入方式 <类型 = Excel插入方式 注释 = "Excel插入方式.*" @默认值 = Excel插入方式.向下>
    参数 复制源 <类型 = 整数 注释 = "指定从何处复制插入单元格的格式." 注释 = "0 从上方和/或左侧单元格复制." 注释 = "1 从下方和/或右侧单元格复制." @默认值 = 0>
    {
        Range对象.无返回值方法 ("Insert", 插入方式, 复制源)
    }

    方法 复制 <公开 注释 = "将区域复制到指定的区域或剪贴板">
    参数 复制到新区域 <类型 = 文本型 注释 = "指定要将指定区域复制到的新区域.默认为空文本时,将区域复制到剪贴板." @默认值 = "">
    {
        如果 (复制到新区域 == "")
        {
            Range对象.无参数及返回值方法 ("Copy")  // 复制到剪贴板
        }
        否则
        {
            Range对象.无返回值方法 ("Copy", Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 复制到新区域))  // 复制到新区域
        }
    }

    方法 剪切 <公开 注释 = "将区域剪切到指定的区域或剪贴板">
    参数 剪切到新区域 <类型 = 文本型 注释 = "指定要将指定区域剪切到的新区域.默认为空文本时,将区域剪切到剪贴板." @默认值 = "">
    {
        如果 (剪切到新区域 == "")
        {
            Range对象.无参数及返回值方法 ("Cut")  // 复制到剪贴板
        }
        否则
        {
            Range对象.无返回值方法 ("Cut", Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 剪切到新区域))  // 剪切到新区域
        }
    }

    方法 粘贴 <公开 注释 = "将\"剪贴板\"中的内容粘贴到工作表上,可以实现跨表粘贴.">
    参数 粘贴到新区域 <类型 = 文本型 注释 = "指定要将\"剪贴板\"中的内容粘贴到的新区域.默认为空文本时,则将\"剪贴板\"中的内容粘贴到当前选定区域." @默认值 = "">
    {
        如果 (粘贴到新区域 == "")
        {
            Range对象.无参数及返回值方法 ("PasteSpecial")  // 将"剪贴板"中的内容粘贴到当前选定区域
        }
        否则
        {
            变量 局_新区域变体 <类型 = COM变体型>
            局_新区域变体 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 粘贴到新区域)  // 取出要粘贴区域的变体型
            Range对象.读无参数对象型属性 ("Parent", COM对象类).无返回值方法 ("Paste", 局_新区域变体)  // 将"剪贴板"中的内容粘贴到新区域
        }
    }

    方法 选择性粘贴 <公开 注释 = "粘贴已复制到指定范围区域中">
    参数 粘贴格式 <类型 = Excel粘贴格式 注释 = "Excel粘贴格式.*,要粘贴的格式." @默认值 = Excel粘贴格式.全部内容>
    参数 计算方式 <类型 = Excel计算方式 注释 = "Excel计算方式.*,粘贴操作计算方式." @默认值 = Excel计算方式.不计算>
    参数 空白处理 <类型 = 逻辑型 注释 = "如果为真,则不将剪贴板上区域中的空白单元格粘贴到目标区域中." @默认值 = 假>
    参数 交换行列 <类型 = 逻辑型 注释 = "如果为真,则粘贴区域时转置行和列." @默认值 = 假>
    {
        Range对象.无返回值方法 ("PasteSpecial", 粘贴格式, 计算方式, 空白处理, 交换行列)
    }

    方法 替换 <公开 类型 = 逻辑型 注释 = "返回\"逻辑型\",它表示指定区域内单元格中的字符.使用此方法不会更改选中范围或活动单元格.">
    参数 查找文本 <类型 = 文本型 注释 = "要搜索区域中字符串.">
    参数 替换文本 <类型 = 文本型 注释 = "替换字符串.">
    参数 全字符匹配 <类型 = 逻辑型 注释 = "如果为真,则匹配全字符匹配;如果为假,则部份匹配." @默认值 = 真>
    参数 逐行搜索 <类型 = 逻辑型 注释 = "如果为真,则搜索行,然后移到下一行;如果为假,则向下搜索列,然后移到下一列." @默认值 = 真>
    参数 区分大小写 <类型 = 逻辑型 注释 = "如果为真,则搜索区分大小写." @默认值 = 假>
    参数 区分全角半角 <类型 = 逻辑型 注释 = "只有在已选择或安装双字节语言支持时,才能使用此参数.如果为真,则双字节字符仅匹配双字节字符.如果为假,则双字节字符匹配其单字节等效字符." @默认值 = 假>
    {
        返回 (Range对象.方法 ("Replace", 逻辑型, 查找文本, 替换文本, 选择 (全字符匹配, 1, 2), 选择 (逐行搜索, 1, 2), 区分大小写, 区分全角半角))
    }

    方法 合并 <公开 注释 = "从指定的多个单元格对象创建合并的单元格">
    参数 合并行 <类型 = 逻辑型 注释 = "如果设置为真,则将指定区域中每一行的单元格合并为一个单独的合并单元格." @默认值 = 假>
    {
        Range对象.无返回值方法 ("Merge", 合并行)
    }

    方法 解除合并 <公开 注释 = "从指定的合并多个单元格区域分解为独立的单元格">
    {
        Range对象.无参数及返回值方法 ("UnMerge")
    }

    方法 打印 <公开 注释 = "打印对象.\"开始页号\"和\"终止页号\"的说明中的\"页面\"是指打印的页面,而不是工作表或工作簿中的整个页面.">
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号.如果值为-1时,则省略此参数,则从起始位置开始打印." @默认值 = -1>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号.如果值为-1时,则省略此参数,则打印至最后一页." @默认值 = -1>
    参数 打印份数 <类型 = 整数 注释 = "打印份数.如果值为-1时,则省略此参数,则只打印一份." @默认值 = -1>
    参数 打印前预览 <类型 = 逻辑型 注释 = "如果为真,将在打印对象之前调用打印预览.如果为假,则立即打印对象." @默认值 = 假>
    参数 活动打印机 <类型 = 文本型 注释 = "设置活动打印机的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    参数 输出文件 <类型 = 逻辑型 注释 = "如果为真,则打印到文件.如果未指定\"输出文件名\",将提示用户输入输出文件的名称." @默认值 = 假>
    参数 逐份打印 <类型 = 逻辑型 注释 = "如果为真,则逐份打印多个副本." @默认值 = 真>
    参数 输出文件名 <类型 = 文本型 注释 = "如果\"输出文件\"设置为真,则此参数指定要打印到的文件的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    {
        变量 局_开始页号 <类型 = COM变体型>
        变量 局_终止页号 <类型 = COM变体型>
        变量 局_打印份数 <类型 = COM变体型>
        变量 局_活动打印机 <类型 = COM变体型>
        变量 局_输出文件名 <类型 = COM变体型>
        如果 (开始页号 != -1)
        {
            局_开始页号.赋值 (开始页号)
        }
        如果 (终止页号 != -1)
        {
            局_终止页号.赋值 (终止页号)
        }
        如果 (打印份数 != -1)
        {
            局_打印份数.赋值 (打印份数, )
        }
        如果 (活动打印机 != "")
        {
            局_活动打印机.赋值 (活动打印机, )
        }
        如果 (输出文件名 != "")
        {
            局_输出文件名.赋值 (输出文件名, )
        }
        Range对象.无返回值方法 ("PrintOut", 局_开始页号, 局_终止页号, 局_打印份数, 打印前预览, 局_活动打印机, 输出文件, 逐份打印, 局_输出文件名)
    }

    方法 打印预览 <公开 注释 = "按对象打印后的外观效果显示对象的预览">
    参数 更改边距和设置选项 <类型 = 逻辑型 注释 = "指定用户是否可更改边距和打印预览中可用的其他页面设置选项" @默认值 = 假>
    {
        Range对象.无返回值方法 ("PrintPreview", 更改边距和设置选项)
    }

    方法 排序 <公开 注释 = "对单元格区域进行排序">
    参数 字段1 <类型 = 文本型 注释 = "指定第一排序字段,作为区域名称(字符串);确定要排序的值.包含标题时,例如\"订单编号\";不包含标题时指定列字母,例如\"A1\"" @默认值 = "">
    参数 升序1 <类型 = 逻辑型 注释 = "确定\"字段1\"中指定的值的排序次序.参数默认值为\"真\"按升序排序,为\"假\"时按降序排序." @默认值 = 真>
    参数 方式1 <类型 = 逻辑型 注释 = "指定\"字段1\"中所指定区域中的文本的排序方式;参数默认值为\"真\"分别对数字和文本数据进行排序.为\"假\"时将文本作为数字型数据进行排序." @默认值 = 真>
    参数 字段2 <类型 = 文本型 注释 = "第二排序字段;对数据透视表进行排序时不能使用.包含标题时,例如\"订单编号\";不包含标题时指定列字母,例如\"A1\"" @默认值 = "">
    参数 升序2 <类型 = 逻辑型 注释 = "确定\"字段2\"中指定的值的排序次序.参数默认值为\"真\"按升序排序,为\"假\"时按降序排序." @默认值 = 真>
    参数 方式2 <类型 = 逻辑型 注释 = "指定\"字段2\"中所指定区域中的文本的排序方式;参数默认值为\"真\"分别对数字和文本数据进行排序.为\"假\"时将文本作为数字型数据进行排序." @默认值 = 真>
    参数 字段3 <类型 = 文本型 注释 = "第三排序字段;对数据透视表进行排序时不能使用.包含标题时,例如\"订单编号\";不包含标题时指定列字母,例如\"A1\"" @默认值 = "">
    参数 升序3 <类型 = 逻辑型 注释 = "确定\"字段3\"中指定的值的排序次序.参数默认值为\"真\"按升序排序,为\"假\"时按降序排序." @默认值 = 真>
    参数 方式3 <类型 = 逻辑型 注释 = "指定\"字段3\"中所指定区域中的文本的排序方式;参数默认值为\"真\"分别对数字和文本数据进行排序.为\"假\"时将文本作为数字型数据进行排序." @默认值 = 真>
    参数 包含标题 <类型 = 逻辑型 注释 = "指定第一行是否包含标题信息.为\"真\"时按区域第一行标题进行排序." @默认值 = 假>
    参数 区分大小写 <类型 = 逻辑型 注释 = "设置为真,则执行区分大小写的排序,设置为假,则执行不区分大小写的排序;不能用于数据透视表." @默认值 = 假>
    参数 按行 <类型 = 逻辑型 注释 = "指定排序方向.参数默认值为\"真\",按行排序,为\"假\"时按列排序." @默认值 = 真>
    参数 按拼音 <类型 = 逻辑型 注释 = "指定排序方法.参数默认值为\"真\",按字符的汉语拼音顺序排序,为\"假\"时按每个字符的笔划数排序." @默认值 = 真>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 字段1变体 <类型 = COM变体型>
        变量 字段2变体 <类型 = COM变体型>
        变量 字段3变体 <类型 = COM变体型>
        如果 (包含标题 == 真)
        {
            字段1变体.赋值 (字段1, )
            字段2变体.赋值 (字段2, )
            字段3变体.赋值 (字段3, )
        }
        否则
        {
            如果 (字段1 != "")
            {
                字段1变体 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 字段1)  // 取所在工作表对应字段1作为参数
            }
            如果 (字段2 != "")
            {
                字段2变体 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 字段2)  // 取所在工作表对应字段2作为参数
            }
            如果 (字段3 != "")
            {
                字段3变体 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 字段3)  // 取所在工作表对应字段3作为参数
            }
        }
        Range对象.无返回值方法 ("Sort", 字段1变体, 选择 (升序1, 1, 2), COM变体, 字段2变体, 选择 (升序2, 1, 2), 字段3变体, 选择 (升序3, 1, 2), 选择 (包含标题, 0, 1), COM变体, 区分大小写, 选择 (按行, 1, 2), 选择 (按拼音, 1, 2), 选择 (方式1, 0, 1), 选择 (方式2, 0, 1), 选择 (方式3, 0, 1))
    }

    方法 搜索 <公开 类型 = 文本型 注释 = "在区域中查找特定信息,代表搜索结果以字母加数字表示第几列第几行." 注释 = "注意,搜索方向是以当前位置的上一个或下一个开始.若要继续查找,可使用搜索下一个,搜索上一个命令.">
    参数 搜索文本 <类型 = 文本型 注释 = "要搜索的数据.可为字符串或任意Excel表数据类型." 编辑时信息 = "B9549, 0, 0, 0" "">
    参数 开始单元格 <类型 = 文本型 注释 = "例A1要在其后开始搜索的单元格.请注意,该参数必须是区域内的单个单元格." 注释 = "搜索在此单元格之后开始;在方法回绕到此单元格之前,不会搜索指定的单元格."
            注释 = "如果未指定此参数,搜索将在区域左上角的单元格后面开始." 编辑时信息 = "B9549, 0, 0, 0" @默认值 = "">
    参数 搜索类型 <类型 = Excel搜索类型 注释 = "Excel搜索类型.*,指定要搜索的类型." 编辑时信息 = "B9549, 0, 0, 0" @默认值 = Excel搜索类型.值>
    参数 全字符匹配 <类型 = 逻辑型 注释 = "如果为真,则全字符匹配;如果为假,则部份匹配." 编辑时信息 = "B9549, 0, 0, 0" @默认值 = 假>
    参数 按行搜索 <类型 = 逻辑型 注释 = "如果为真,则搜索行,然后移到下一行;如果为假,则向下搜索列,然后移到下一列." @默认值 = 真>
    参数 往下搜索 <类型 = 逻辑型 注释 = "如果为真,则在区域中搜索下一匹配值;如果为假,则在区域中搜索上一匹配值." 编辑时信息 = "B9549, 0, 0, 0" @默认值 = 真>
    参数 区分大小写 <类型 = 逻辑型 注释 = "如果为真,则搜索区分大小写." 编辑时信息 = "B9549, 0, 0, 0" @默认值 = 假>
    参数 区分全角半角 <类型 = 逻辑型 注释 = "只有在已选择或安装双字节语言支持时,才能使用此参数.如果为真,则双字节字符仅匹配双字节字符.如果为假,则双字节字符匹配其单字节等效字符." @默认值 = 假>
    {
        变量 局_单元格 <类型 = COM变体型>
        如果 (开始单元格 != "")  // 开始单元格不为空
        {
            局_单元格 = Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 开始单元格)
        }
        返回 (Range对象.对象型方法 ("Find", COM对象类, 搜索文本, 局_单元格, 搜索类型, 选择 (全字符匹配, 1, 2), 选择 (按行搜索, 1, 2), 选择 (往下搜索, 1, 2), 区分大小写, 区分全角半角).读属性 ("Address", 文本型, 假, 假))  // Address属性使返回变成单元格对应序号如"A1"
    }

    方法 搜索下一个 <公开 类型 = 文本型 注释 = "搜索方法开始的搜索.查找匹配相同条件的下一个单元格,并返回表示该单元格的单元格对象.该操作不影响选定内容和活动单元格">
    参数 开始单元格 <类型 = 文本型 注释 = "指定一个单元格,查找将从该单元格之后开始.">
    {
        返回 (Range对象.对象型方法 ("FindNext", COM对象类, Range对象.读无参数对象型属性 ("Parent", COM对象类).读属性 ("Range", COM变体型, 开始单元格)).读属性 ("Address", 文本型, 假, 假))
    }

    方法 搜索上一个 <公开 类型 = 文本型 注释 = "搜索方法开始的搜索.查找匹配相同条件的上一个单元格,并返回表示该单元格的单元格对象.该操作不影响选定内容和活动单元格.">
