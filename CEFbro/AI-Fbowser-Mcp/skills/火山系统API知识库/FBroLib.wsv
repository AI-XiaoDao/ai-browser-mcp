        返回 (假)
    }

    方法 取字符串 <公开 类型 = 文本型 注释 = "英语名：GetCommandLineString 说明：" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsCommandLine_GetString(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取程序 <公开 类型 = 文本型 注释 = "英语名：GetProgram 说明：取出执行程序名，包含路径" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsCommandLine_GetProgram(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 置程序 <公开 注释 = "英语名：SetProgram" @禁止流程检查 = 真>
    参数 程序名 <类型 = 文本型 注释 = "带路径">
    {
