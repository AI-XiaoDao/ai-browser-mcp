    方法 进程间消息_取渲染进程ID清单 <公开 类型 = 整数数组类 注释 = "取可以通讯的渲染进程数" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) { int size=FBroHsSocketServer_GetProcessIDCountByBrowser(m_class);
        @ if(size>0) {DWORD * temparray = new DWORD[size]; FBroHsSocketServer_GetProcessIDListByBrowser(m_class,temparray);
        @ @dt<整数数组类> temp;temp.data ().Append ((int *)temparray, size); delete[] temparray;return temp;}
        @ }return @dt<整数数组类>();
    }

