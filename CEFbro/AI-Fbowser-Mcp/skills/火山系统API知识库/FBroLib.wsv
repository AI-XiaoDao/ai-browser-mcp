    }

    方法 是否存在某项 <公开 类型 = 逻辑型 注释 = "英语名：HasSwitch 说明：name前面不用加\"--\"" @禁止流程检查 = 真>
    参数 项目名 <类型 = 文本型>
    {
        @ if(IsEmpty()) return false;
        @ bool retbool = FBroHsCommandLine_HasSwitche(m_class,@<项目名>.GetText());
        @ return retbool;
    }

    方法 取项值 <公开 类型 = 文本型 注释 = "英语名：GetSwitchValue 说明：name前面不用加\"--\"" @禁止流程检查 = 真>
    参数 项目名 <类型 = 文本型>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsCommandLine_GetSwitchValue(m_class,@<项目名>.GetText());
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 置值 <公开 注释 = "英语名：AppendSwitch 说明：value默认前面要加\"--\"">
    参数 值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_AppendSwitch(m_class,@<值>.GetText());
    }

    方法 置项值 <公开 注释 = "英语名：AppendSwitchWithValue 说明：name默认前面要加\"--\"">
    参数 项目名 <类型 = 文本型>
    参数 项目值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_AppendSwitchWithValue(m_class,@<项目名>.GetText(),@<项目值>.GetText());
    }

    方法 是否存在额外参数 <公开 类型 = 逻辑型 注释 = "英语名：HasArguments 说明：判断是否存在额外参数 Get the remaining command line arguments" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsCommandLine_HasArguments(m_class)
    }

    方法 取额外参数 <公开 类型 = 文本型 注释 = "英语名：GetArguments 说明：取出额外参数  Add an argument to the end of the command line" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsCommandLine_GetArguments(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 置额外参数 <公开 注释 = "英语名：AppendArgument 说明：设置额外参数 Add an argument to the end of the command line" @禁止流程检查 = 真>
    参数 参数文本 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_AppendArgument(m_class,@<参数文本>.GetText());

    }

    方法 插入值 <公开
            注释 = "英语名：PrependWrapper 说明：在当前命令之间插入值 Insert a command before the current command. Common for debuggers, like \"valgrind\" or \"gdb --args\".">
    参数 值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_AppendArgument(m_class,@<值>.GetText());

    }

    方法 启用单进程模式 <公开 注释 = "命令行--single-process，只为了方便多进程模拟调试，仅调试模式下有用，单进程模式存在各种问题，不建议发布软件使用">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableSingleProcess (m_class);

    }

    方法 启用摄像头 <公开 注释 = "命令行enable-media-stream,允许浏览使用摄像头">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableMediaStream (m_class);

    }

    方法 启用跨框架操作模式 <公开 注释 = "跨框架操作，解除框架和框架直接不能直接操作的限制，存在不安全性">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableCrossFrame (m_class);

    }

    方法 启用录音 <公开 注释 = "命令行：enable-speech-input,允许浏览使用话筒">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableSpeechInput (m_class);

    }

    方法 启用自动播放 <公开 注释 = "命令行：autoplay-poliey，支持绝对部分视频网站自动播放视频，各别有限制的除外">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableAutoplayPoliey (m_class);

    }

    方法 启用无头模式 <公开 注释 = "命令行：--headless，无头模式">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_EnableAutoplayPoliey (m_class);

    }

    方法 设置远程调试端口 <公开 注释 = "命令行：--remote-debugging-port">
    参数 端口号 <类型 = 整数>
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_SetRemoteDebuggingPort (m_class, @<端口号>);

    }

    方法 禁用GPU <公开 注释 = "禁用后，网页渲染将由CPU处理，会提高CPU占用，不兼容的显卡只能禁用GPU否者网页可能渲染失败">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_DisableGpu (m_class);

    }

    方法 禁用GPU缓存 <公开 注释 = "禁止GPU创建缓存文件及文件夹">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_DisableGpuCache (m_class);

    }

    方法 忽略GPU禁用清单 <公开 注释 = "内核内置不兼容部分显卡，设置后忽略内核这个设置，能有效解决部分显卡不兼容的问题，但因为部分显卡本身太老或驱动问题，忽略了也没用，只有禁用GPU">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_DisableGpuBlockList (m_class);

    }

    方法 设置全局代理 <公开 注释 = "设置全局代理，只能设置一个，如果需要认证则需要设置账号密码；不支持带账号密码的S5代理，如要使用带账号密码的S5代理，请使用“VIP_高级_设置全局代理”">
    参数 代理地址 <类型 = 文本型 注释 = "要区分大小写，不要有空格，否则地址错误将会设置失败">
    参数 代理账号 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_SetProxy (m_class,@<代理地址>.GetText(),@<代理账号>.GetText(),@<代理密码>.GetText());

    }

    方法 VIP_高级_设置全局代理 <公开 注释 = "设置全局代理，只能设置一个，如果需要认证则需要设置账号密码；带账号密码的S5代理，需赞助会员才可使用">
    参数 代理地址 <类型 = 文本型 注释 = "要区分大小写，不要有空格，否则地址错误将会设置失败">
    参数 代理账号 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 关闭S5错误提示 <类型 = 逻辑型 注释 = "关闭S5代理错误弹窗提示，默认为假，为真关闭提示" @默认值 = 假>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()){
        @     FBroHsVIPCommandLine_SetProxy (m_class,@<代理地址>.GetText(),@<代理账号>.GetText(),@<代理密码>.GetText());
        @ }


    }

    方法 禁用代理 <公开 注释 = "命令行：--no-proxy-server，禁止使用代理和系统的自动检测代理功能">
    {
        @ if(IsEmpty()) return;
        @ FBroHsCommandLine_DisableProxy (m_class);

    }
}

