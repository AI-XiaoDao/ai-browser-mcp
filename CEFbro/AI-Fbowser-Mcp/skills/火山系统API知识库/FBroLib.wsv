类 类_FBrowser_用户额外配置 <公开 "">
{

    # @begin
    # <> <include>
    # CefRefPtr<FBroUseExtraData> m_class;
    # inline_ @sn<current_class> (CefRefPtr<FBroUseExtraData> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<FBroUseExtraData> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 置事件 <公开 注释 = "如果不设置则采用默认当前设置的事件">
    参数 浏览器事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_浏览器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；">
    参数 禁用事件 <类型 = FBrowser_禁用事件 注释 = "即将打开新窗口的浏览器器事件开关，可关闭某些不必要的事件加载，合理设置可提高加载速度" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<浏览器事件>.GetPtr(),BroEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ FBroHsUseExtraData_SetEvent(m_class,static_cast<FBroHsBroEvent*>(@<浏览器事件>.GetPtr()));
        @ FBroHsUseExtraData_SetEventDisableControlData(m_class,@<禁用事件>.ToFBroData());

    }

    方法 置标识 <公开 注释 = "如果不设置则采用默认当前设置的用户标识">
    参数 标识 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsUseExtraData_SetUserFlagData(m_class,@<标识>.GetText());

    }

    方法 取标识 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsUseExtraData_GetUserFlagData(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 置额外信息 <公开>
    参数 额外信息 <类型 = 类_FBrowser_字典值>
    {
        @ if(IsEmpty()) return;
        @ FBroHsUseExtraData_SetExtraInfoData(m_class,@<额外信息>.m_class);

    }

    方法 取额外信息 <公开 类型 = 类_FBrowser_字典值 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return @dt<类_FBrowser_字典值>();
        @ return @dt<类_FBrowser_字典值>(FBroHsUseExtraData_GetExtraInfoData(m_class));
    }
}

类 类_FBrowser_URL请求 <公开>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefURLRequest> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefURLRequest> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefURLRequest> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 取请求 <公开 类型 = 类_FBrowser_请求 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return @dt<类_FBrowser_请求>();
        @ return @dt<类_FBrowser_请求>(FBroHsURLRequest_GetRequest(m_class));

    }

    方法 取请求状态码 <公开 类型 = URL请求状态 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return 0;
        @ return FBroHsURLRequest_GetRequestStatus(m_class);
    }

    方法 取请求错误码 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return 0;
        @ return FBroHsURLRequest_GetRequestError(m_class);
    }

    方法 取响应 <公开 类型 = 类_FBrowser_响应 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return @dt<类_FBrowser_响应>();
        @ return @dt<类_FBrowser_响应>(FBroHsURLRequest_GetResponse(m_class));
    }

    方法 是否带缓存响应 <公开 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return @dt<类_FBrowser_响应>(FBroHsURLRequest_ResponseWasCached(m_class));

    }

    方法 取消 <公开>
    {
        @ if(!IsEmpty()) FBroHsURLRequest_Cancel(m_class);
    }

