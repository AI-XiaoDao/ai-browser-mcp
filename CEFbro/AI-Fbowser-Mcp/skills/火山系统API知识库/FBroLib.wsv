    方法 访问DOM对象 <公开 注释 = "VisitDOM，只能在渲染进程中调用" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；">
    参数 DOM回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_DOM回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty ()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<DOM回调>.GetPtr(),DOMVisitorType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsDOMVisitor> tempclass = static_cast<FBroHsDOMVisitor*>(@<DOM回调>.GetPtr());
        @ FBroHsBrowserFrame_VisitDOM(m_class,tempclass);


    }

    方法 创建URL请求 <公开 注释 = "使用当前环境创建URL请求">
    参数 请求 <类型 = 类_FBrowser_请求 注释 = "要请求的数据，用于设置请求地址，类型等参数">
    参数 URL请求事件 <类型 = 类_FBrowser_事件智能指针 注释 = "获取数据和状态的异步回调。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_URL请求事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 标识 <类型 = 长整数 注释 = "标识，传递给事件的标识，执行请求触发的事件的标识参数" @默认值 = 0>
    {
        @ if(IsEmpty ()) return;

        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<URL请求事件>.GetPtr(),URLRequestClientType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsURLRequestClient> tempclass = static_cast<FBroHsURLRequestClient*>(@<URL请求事件>.GetPtr());
        @ FBroHsBrowserFrame_CreateURLRequest(m_class,@<请求>.m_class,tempclass,@<标识>);



    }
}

类 类_FBrowser_命令行 <公开 @输出名 = "FBroCommandLine" @全局类 = 真 "">
{

    # @begin
    # <> <include>
    # CefRefPtr<CefCommandLine> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefCommandLine> object) : @sn<current_class> () { m_class = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefCommandLine> object) { m_class = object; }
    # <> </include>
    # @end

    方法 FBrowser_命令行_创建 <公开 静态 类型 = 类_FBrowser_命令行 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_命令行>(FBroHsCommandLine_CreateCommandLine());

    }

    方法 FBrowser_命令行_取全局 <公开 静态 类型 = 类_FBrowser_命令行 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_命令行>(FBroHsCommandLine_GetGlobalCommandLine());
    }

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    #

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "英语名：IsValid 说明：当前对象是否为空" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) return FBroHsCommandLine_IsValid(m_class);
        返回 (假)
    }

    #

    方法 是否只读 <公开 类型 = 逻辑型 注释 = "英语名：IsReadOnly 说明：" @禁止流程检查 = 真>
    {
