    方法 离屏渲染_拖动进入 <公开 注释 = "英文名：DragTargetDragEnter"
            注释 = "说明：Call this method when the user drags the mouse into the web view (before calling DragTargetDragOver/DragTargetLeave/DragTargetDrop)."
            注释 = "|drag_data| should not contain file contents as this type of data is not allowed to be dragged into the web view."
            注释 = " File contents can be removed using CefDragData::ResetFileContents (for example, if |drag_data| comes from CefRenderHandler::StartDragging)."
            注释 = "This method is only used when window rendering is disabled.">
    参数 拖拽数据 <类型 = 类_FBrowser_拖拽数据 注释 = "drag_data">
    参数 鼠标事件 <类型 = FBrowser_鼠标事件>
    参数 拖动操作类型 <类型 = 整数 注释 = "参考：拖动操作.xxxx">
    {
        @ if(!IsEmpty()) FBroHsBrowserHost_DragTargetDragEnter(m_class,@<拖拽数据>.m_class,@<鼠标事件>.m_data,@<拖动操作类型>);


    }

    方法 离屏渲染_拖动移动 <公开 注释 = "英文名：DragTargetDragOver"
            注释 = "说明：Call this method each time the mouse is moved across the web view during a drag operation (after calling DragTargetDragEnter and before calling DragTargetDragLeave/DragTargetDrop)."
            注释 = "This method is only used when window rendering is disabled.">
    参数 鼠标事件 <类型 = FBrowser_鼠标事件>
    参数 拖动操作类型 <类型 = 整数 注释 = "参考：拖动操作.xxxx">
