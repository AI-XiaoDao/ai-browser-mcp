        @ _FBRO_CHECK_EVENT_TYPE(@<字符串回调>.GetPtr(),StringVisitorType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsStringVisitor> tempclass = static_cast<FBroHsStringVisitor*>(@<字符串回调>.GetPtr());
        @ FBroHsBrowserFrame_GetText(m_class,tempclass); 


    }

