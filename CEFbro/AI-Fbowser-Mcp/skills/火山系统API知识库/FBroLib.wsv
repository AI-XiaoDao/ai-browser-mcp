类 类_FBrowser_V8环境 <公开 注释 = "只能在渲染进程中使用" @输出名 = "FBroV8Context" @全局类 = 真>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefV8Context> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefV8Context> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefV8Context> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end
    #

    方法 FBrowser_V8_注册JS扩展 <公开 静态 类型 = 长整数 返回值注释 = "成功返回事件标识ID" @禁止流程检查 = 真>
    参数 扩展名 <类型 = 文本型>
    参数 扩展JS代码 <类型 = 文本型>
    参数 处理回调事件 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_V8处理程序”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<处理回调事件>.GetPtr(),V8HandlerType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsV8Handler> tempclass=static_cast<FBroHsV8Handler*>(@<处理回调事件>.GetPtr());
        @ return (INT64)FBroHsRegisterExtension(@<扩展名>.GetText(),@<扩展JS代码>.GetText(),tempclass);


    }

    方法 FBrowser_V8环境_取当前环境 <公开 静态 类型 = 类_FBrowser_V8环境 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_V8环境>(FBroHsV8Context_GetCurrentContext());
    }

    方法 FBrowser_V8环境_取运行环境 <公开 静态 类型 = 类_FBrowser_V8环境 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_V8环境>(FBroHsV8Context_GetEnteredContext());

    }

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
