    {
        变量 size <类型 = 整数>
        size = 取数据大小 ()
        变量 bytes <类型 = 字节集类>
        bytes = 取字节集数据 (size)
        如果 (是否为UTF8)
        {
            返回 (UTF8到文本 (bytes))
        }
        否则
        {
            返回 (字节集到文本 (bytes))

        }

    }
}

