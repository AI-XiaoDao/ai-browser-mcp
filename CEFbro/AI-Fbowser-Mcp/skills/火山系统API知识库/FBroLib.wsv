    }

    方法 源码视图 <公开
            注释 = "英文名:ViewSource  说明：Save this frame\'s HTML source to a temporary file and open it in the default text viewing application.">
    {
        @ if(IsEmpty()) return ;
        @ FBroHsBrowserFrame_ViewSource(m_class);
    }

    方法 载入地址 <公开 注释 = "英文名:LoadURL 说明：Load the specified |url|">
    参数 地址 <类型 = 文本型>
    {
        @ if(IsEmpty()) return ;
        @ FBroHsBrowserFrame_LoadURL(m_class,@<地址>.GetText());
    }

    方法 取源码_异步 <公开 注释 = "英文名:GetSource 说明：异步取出当前框架源码，返回源码在回调函数中获取" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；">
    参数 字符串回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_字符串回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<字符串回调>.GetPtr(),StringVisitorType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsStringVisitor> tempclass = static_cast<FBroHsStringVisitor*>(@<字符串回调>.GetPtr());
        @ FBroHsBrowserFrame_GetSource(m_class,tempclass);


    }

    方法 取文本_异步 <公开 注释 = "英文名:GetText 说明：异步取出当前框架文本，返回文本在回调函数中获取" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；">
    参数 字符串回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_字符串回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
