    {
        @ if(IsEmpty ()) return 0;
        @ return FBroHsBrowserHost_GetRuntimeStyle(m_class);
    }
}

类 类_FBrowser_基础框架 <@输出名 = "FBroBaseFrame" "">
{

    # @begin
    # <> <include>
    # CefRefPtr<CefFrame> m_class;
    # @sn<current_class> (CefRefPtr<CefFrame> object) : @sn<current_class> () { m_class = object;}
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set(CefRefPtr<CefFrame> object) { m_class = object; }
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "英文名:IsValid" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsBrowserFrame_IsValid(m_class);
    }

    方法 取地址 <公开 类型 = 文本型 注释 = "英文名:GetURL 说明：取当前框架地址" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsBrowserFrame_GetURL(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取框架名 <公开 类型 = 文本型 注释 = "英文名：GetName 说明：为空为主框架" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsBrowserFrame_GetName(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 是否为主框架 <公开 类型 = 逻辑型 注释 = "英文名：IsMain 说明：" 折叠 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsBrowserFrame_IsMain(m_class);
    }

    方法 是否为焦点框架 <公开 类型 = 逻辑型 注释 = "英文名：IsFocused 说明：" 折叠 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsBrowserFrame_IsFocused(m_class);
    }

    方法 取框架ID <公开 类型 = 文本型 注释 = "英文名：GetIdentifier" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsBrowserFrame_GetIdentifier(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 执行JS代码 <公开 折叠>
    参数 执行代码 <类型 = 文本型>
    参数 脚本地址 <类型 = 文本型 注释 = "用于返回执行错误" @默认值 = "">
    参数 开始行 <类型 = 整数 注释 = "执行错误开始行" @默认值 = 0>
    {
        @ if(IsEmpty()) return;
        @ FBroHsBrowserFrame_ExecuteJavaScript(m_class,@<执行代码>.GetText(),@<脚本地址>.GetText(),@<开始行>);
    }

    方法 执行JS代码_带返回值 <公开 折叠>
    参数 执行代码 <类型 = 文本型>
    参数 脚本地址 <类型 = 文本型 注释 = "用于返回执行错误" @默认值 = "">
    参数 开始行 <类型 = 整数 注释 = "执行错误开始行" @默认值 = 0>
    参数 结果回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_JS回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<结果回调>.GetPtr(),JsCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsJsCallback> tempclass=static_cast<FBroHsJsCallback*>(@<结果回调>.GetPtr());
        @ FBroHsBrowserFrame_ExecuteJavaScriptToHasReturn(m_class,@<执行代码>.GetText(),@<脚本地址>.GetText(),@<开始行>,tempclass);

    }

    方法 取浏览器 <公开 类型 = 类_FBrowser_浏览器 注释 = "GetBrowser" 折叠 @禁止流程检查 = 真>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_浏览器>(FBroHsBrowserFrame_GetBrowser(m_class));
        @ return @dt<类_FBrowser_浏览器>();
    }

    方法 取填表框架 <公开 类型 = 类_FBrowser_填表框架 注释 = "取出当前填表框架，如果已经是填表框架了，调用相当于复制了一份" @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_填表框架>(m_class);
    }

    方法 取框架 <公开 类型 = 类_FBrowser_框架 注释 = "取出当前框架，如果当前已经是框架了，调用相当于复制了一份" @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_框架>(m_class);
    }

    #
}

类 类_FBrowser_框架 <公开 基础类 = 类_FBrowser_基础框架 @输出名 = "FBroFrame" "">
{

    # @begin
    # <> <include>
    # @sn<current_class> (CefRefPtr<CefFrame> object): @sn<base_class>(object){@sn<current_class> ();}
    # <> </include>
    # @end

    方法 撤销 <公开 注释 = "英文名:Undo 说明：Execute chax in this frame.">
    {
        @ if(IsEmpty()) return ;
