<火山程序 类型 = "通常" 版本 = 1 />

包 FBrowser.浏览器 <注释 = "" 注释 = "" 注释 = "浏览器各主要功能合集"
        @视窗.外部库.win32 = "src\\env\\lib\\FBrowserCEF3lib.lib\r\nsrc\\env\\lib\\FBrowserVIP.lib\r\nsrc\\env\\lib\\libcef.lib"
        "@视窗.外部库.win32-debug" = "src\\env\\lib\\debug\\libcef_dll_wrapper.lib"
        "@视窗.外部库.win32-release" = "src\\env\\lib\\release\\libcef_dll_wrapper.lib" "" @视窗.附属文件.win32 = "src\\CEFLib\\" ""
        @视窗.外部库.x64 = "src\\env\\lib64\\FBrowserCEF3lib.lib\r\nsrc\\env\\lib64\\FBrowserVIP.lib\r\nsrc\\env\\lib64\\libcef.lib"
        "@视窗.外部库.x64-debug" = "src\\env\\lib64\\debug\\libcef_dll_wrapper.lib"
        "@视窗.外部库.x64-release" = "src\\env\\lib64\\release\\libcef_dll_wrapper.lib" "" @视窗.附属文件.x64 = "src\\CEFLib64\\" ""
        @视窗.头文件搜寻目录 = "src\\FBrowserCEF3lib\\" "" @视窗.外部头文件 = "src\\FBroBaseDis.h" "" @视窗.附加编译参数.release = "cpp:/O2 /Ot" ""
        @视窗.附加编译参数 = "cpp:/std:c++17" @视窗.附加编译参数 = "link:/LARGEADDRESSAWARE" @视窗.附加编译参数.x64 = "link:/STACK:\"0x800000\""
        @视窗.附加编译参数.win32 = "link:/STACK:\"0x400000\"">

类 FBrowser初始化控制 <公开 @全局类 = 真>
{
    常量 模块名 <类型 = 文本型 值 = "FBrowesCEF3lib">
    常量 模块中文名 <类型 = 文本型 值 = "浮点CEF3浏览器框架">
    常量 版本号 <类型 = 文本型 值 = "V4.0.0">
    常量 模块作者 <类型 = 文本型 值 = "ベ時間の加速度＆奔跑ミ">
    常量 交流群 <类型 = 文本型 值 = "559152068，730122631">
    常量 官方论坛 <类型 = 文本型 值 = "https://bbs.fbrowser.site/">
    常量 在线文档 <类型 = 文本型 值 = "https://bbs.fbrowser.site/forum.php?mod=forumdisplay&fid=3">
    常量 在线视频 <类型 = 文本型 值 = "https://bbs.fbrowser.site/forum.php?mod=forumdisplay&fid=4">

    变量 是否为VIP <公开 静态 类型 = 逻辑型 值 = 假>

    方法 启用自带调试提示 <公开 静态 注释 = "仅调试模式下有用，启用模块类调试输出提示，一般指事件类初始化和销毁内部的只在调试模式下显示的提示信息；" 注释 = "全部类初始化在全局所以该设置屏蔽不到已经初始化的事件类，只能屏蔽设置后的；"
            注释 = "当然你也可以把他放在第一个加载的事件类的初始化里面，这样后面的信息就都可以屏蔽">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ #ifdef _DEBUG 
        @ FBroDebugMessage::CloseMessage(!@<是否启用>);
        @ #endif

    }

    方法 初始化调试信息显示 <静态>
    {
        如果真 (是否为调试版 ())
        {
            调试输出 ("【FBrowser初始化】**********************************************************************************")
            调试输出 ("【FBrowser初始化】模块名：" + 模块名)
            调试输出 ("【FBrowser初始化】中文名：" + 模块中文名)

            调试输出 ("【FBrowser初始化】版本：" + FBrowser_取版本号 ())

            调试输出 ("【FBrowser初始化】作者：" + 模块作者)
            调试输出 ("【FBrowser初始化】交流群：" + 交流群)
            调试输出 ("【FBrowser初始化】官方论坛：" + 官方论坛)
            调试输出 ("【FBrowser初始化】文档教程：" + 在线文档)
            调试输出 ("【FBrowser初始化】视频教程：" + 在线视频)
            调试输出 ("【FBrowser初始化】机器码：" + VIP注册_取机器码 ())

            如果 (是否为VIP == 假)
            {
                调试输出 ("【FBrowser初始化】当前版本：免费版")
            }
            否则
            {

                调试输出 ("【FBrowser初始化】当前版本：火山VIP版")
                调试输出 ("【FBrowserVIP注册】尊敬的VIP用户：感谢您的使用，使用过程中如有任何问题，请与作者联系")

                // 如果真 (取运行目录 () != 取当前目录 ())
                {
                    // 复制文件 ("FLicence", 取运行目录 () + "\\FLicence", 文件覆盖模式.覆盖)  // 将授权文件复制到运行目录,方便VS调试

                }

                变量 VIP注册码类型 <类型 = 文本型>
                VIP注册码类型 = VIP注册_取注册码类型 ()
                变量 VIP开始时间 <类型 = 文本型>
                VIP开始时间 = VIP注册_取开始时间 ()
                变量 VIP到期时间 <类型 = 文本型>
                VIP到期时间 = VIP注册_取到期时间 ()

                调试输出 ("【FBrowserVIP注册】注册类型：" + VIP注册码类型)
                调试输出 ("【FBrowserVIP注册】开始时间：" + VIP开始时间)
                调试输出 ("【FBrowserVIP注册】到期时间：" + VIP到期时间)
                调试输出 ("【FBrowserVIP注册】剩余天数：" + 到文本 (四舍五入 (取时间间隔 (到时间 (VIP到期时间, ), 取现行时间 (), 时间字段类型.日), 0)))
                调试输出 ("【FBrowserVIP注册】注册版本：" + VIP注册_取注册版本 ())
                调试输出 ("【FBrowserVIP注册】注册功能：" + VIP注册_取注册功能 ())
                调试输出 ("【FBrowserVIP注册】目标平台：" + VIP注册_取目标系统平台 ())


            }

            调试输出 ("【FBrowser初始化】**********************************************************************************")

        }
    }

    方法 FBrowser_初始化 <公开 静态 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 基础设置 <类型 = FBrowser_初始化配置 注释 = "如果不设置执行进程，则默认使用FBrowserCEF3Subprocess.exe当执行进程">
    参数 初始化事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_应用事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；">
    {

        如果真 (基础设置.执行进程 == "")
        {
            基础设置.执行进程 = 取运行目录 () + "FBroSubprocess.exe"

        }

        初始化调试信息显示 ()

        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<初始化事件>.GetPtr(),InitEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ return FBroHsInitPro(@<基础设置>.ToFBroData(),static_cast<FBroHsInitEvent*>(@<初始化事件>.GetPtr()),1024);

    }

    方法 FBrowser_关闭 <公开 静态 注释 = "Shutdown 程序结束的时候调用，关闭释放浏览器全部资源，只有多进程模式下才会完全释放">
    参数 结束程序 <类型 = 逻辑型 注释 = "为真结束当前程序" @默认值 = 假>
    {
        // @ FBroVIPControl_Close ();
        @ FBroShutdown(@<结束程序>);

    }

    方法 FBrowser_消息循环_执行 <公开 静态 注释 = "DoMessageLoopWork">
    {
        @ FBroDoMessageLoopWork();

    }

    方法 FBrowser_消息循环_运行 <公开 静态 注释 = "RunMessageLoop">
    {
        @ FBroRunMessageLoop();

    }

    方法 FBrowser_消息循环_退出 <公开 静态 注释 = "QuitMessageLoop">
    {
        @ FBroQuitMessageLoop();

    }

    方法 FBrowser_消息循环_设置系统模式 <公开 静态 注释 = "SetOSModalLoop">
    参数 系统模式 <类型 = 逻辑型>
    {
        @ FBroSetOSModalLoop(@<系统模式>)

    }

    方法 FBrowser_自定义方案_注册 <公开 静态 注释 = "设置自定义方案，设置后通过自定义方案地址访问,例如fbrowser://test fbrowser为方案名，test为域名" 注释 = "PS：用在初始化之后"
            注释 = "使用完后通过调用\"FBrowser_自定义方案_清理\"释放" @禁止流程检查 = 真>
    参数 方案名 <类型 = 文本型>
    参数 域名 <类型 = 文本型>
    参数 资源处理器 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_资源处理器”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；">
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<资源处理器>.GetPtr(),ResourceHandlerType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsResourceHandler> tempclass=static_cast<FBroHsResourceHandler*>(@<资源处理器>.GetPtr());
        @ FBroHsRegisterSchemeHandlerFactory(@<方案名>.GetText(),@<域名>.GetText(),tempclass);

    }

    方法 FBrowser_自定义方案_清理 <公开 静态 注释 = "只能执行一次，多次执行只会最后一个生效">
    {
        @ FBroClearSchemeHandlerFactories();

    }

    方法 FBrowser_初始化_设置守护 <静态 注释 = "弃用，设置系统内部守护线程，必须在初始化之前设置，主进程设置后子进程不需要再设置，用于子进程判断主进程异常退出，子进程自动结束，避免进程残留，"
            注释 = "开启会占用一定的CPU资源，请合理设置">
    参数 循环周期 <类型 = 整数 注释 = "单位：毫秒；设置为-1使用默认值，默认值为10秒；0为不开启守护进程，大于0则为守护进程判断周期时间">
    {
        @ FBroSetIsLiveMainProcessCycleTime(@<循环周期>);
    }

    方法 FBrowser_初始化_设置内存释放 <静态 注释 = "弃用，用于设置系统内部内存释放线程，必须在初始化之前设置，主进程设置后子进程不需要再设置，"
            注释 = "当子进程或者主进程内存超过设置阈值是将系统不用内存压缩到虚拟内存中，达到降低内存占用的功能，合理设置可避免易语言进程内存占用过大导致的崩溃！"
            注释 = "重点提示：有的内存占用是因为开发者申请内存未释放照成，这种情况最好从源头查找原因，该功能只为辅助，代码不规范异常操作导致的崩溃，它救不了你">
    参数 循环周期 <类型 = 整数 注释 = "单位：毫秒；设置为-1使用默认值，默认值为1秒；0为不开启守护进程，大于0则为释放内存判断周期时间">
    参数 内存阈值 <类型 = 整数 注释 = "当内存超过多少时，执行内存释放，注意不要设置太小，不然老是在压缩内存反而降低效率">
    {
        @ FBroSetReleaseMemoryCycleTime(@<循环周期>);FBroSetMaxReleaseMemory(@<内存阈值>);

    }

    方法 FBrowser_初始化_设置V8环境默认堆栈大小 <公开 静态 注释 = "设置浏览器所创建的渲染进程V8环境的堆栈默认值，必须在初始化之前设置，只针对渲染进程；"
            注释 = "如果出现渲染进程因堆栈大小不足导致的崩溃，可通过扩展最大值得以缓解；但如果代码不规范（比如JS只申请不释放，乱使用循环导致的内存溢出，这个只能缓解过多后该崩溃还是得崩溃，所以一点要注意检测JS相关代码是否规范）;"
            注释 = "设置成功后可通过js命令window.performance.memory查看">
    参数 初始尺寸 <类型 = 整数 注释 = "单位：MB；一般不做修改，不设置或者设置为0及为内核的默认值；" 注释 = "据资料介绍，谷歌内核该值默认为4MB" @默认值 = 0>
    参数 最大尺寸 <类型 = 整数 注释 = "单位：MB；不设置或者设置为0及为内核的默认值；32位程序允许最大值不能超过4000MB"
            注释 = "据资料介绍，谷歌内核该值32位系统默认为1G；64位系统内存小于16G为2G，内存大于16G为4G；" @默认值 = 0>
    {
        @ FBroSetV8DefaultsHeapSize(@<初始尺寸>,@<最大尺寸>);

    }

    方法 FBrowser_内存_压缩清理 <公开 静态 注释 = "压缩清理内存，执行该命令后会触发V8的GC回收和压缩现有内存到虚拟内存，达到节约内存的目的；"
            注释 = "重点提示：有的内存占用是因为开发者申请内存未释放照成，这种情况最好从源头查找原因，该功能只为辅助，代码不规范异常操作导致的崩溃，它救不了你，"
            注释 = "如果是大型网页建议使用64位版本，或通过“FBrowser_初始化_设置V8环境默认堆栈大小”命令和精益工具开启大内存支持，32位程序默认情况下经过测试最大在2G左右">
    {
        @ FBroClearWorkingAndV8Memory();
    }

    方法 FBrowser_JS交互_注册 <公开 静态 注释 = "FBroQueryFunctions" 注释 = "注意：静态事件和动态事件只能设置一个，优先静态事件有效；采用动态事件可实现事件的动态多态操作，更加灵活；">
    参数 JS执行函数名 <类型 = 文本型 注释 = "js_query_function，详见text.html调用JS例子中的doQuery">
    参数 JS退出函数名 <类型 = 文本型 注释 = "js_cancel_function，详见text.html调用JS例子中的doQueryCancel" "">
    参数 JS交互事件 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_JS交互事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ _FBRO_CHECK_EVENT_TYPE(@<JS交互事件>.GetPtr(),QueryHandlerType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ FBroHsQueryFunctions(@<JS执行函数名>.GetText(),@<JS退出函数名>.GetText(),static_cast<FBroHsQueryHandler*>(@<JS交互事件>.GetPtr()));

    }

    方法 FBrowser_JS交互_删除 <公开 静态>
    参数 JS执行函数名 <类型 = 文本型>
    {
        @ FBroHsDeleteQueryFunctions(@<JS执行函数名>.GetText());


    }

    方法 FBrowser_进程_取当前进程类型 <公开 静态 类型 = 整数 返回值注释 = "参考：进程类型." @禁止流程检查 = 真>
    {
        @ return FBroGetProcessType();

    }

    方法 FBrowser_创建URL请求 <公开 静态 注释 = "使用当前环境创建URL请求" @禁止流程检查 = 真>
    参数 请求 <类型 = 类_FBrowser_请求 注释 = "要请求的数据的，用于设置请求地址，类型等参数">
    参数 请求环境 <类型 = 类_FBrowser_请求环境 注释 = "为空为全局环境" @默认值 = 空对象>
    参数 URL请求事件 <类型 = 类_FBrowser_事件智能指针 注释 = "获取数据和状态的异步回调。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_URL请求事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 标识 <类型 = 长整数 注释 = "标识，传递给事件的标识，执行请求触发的事件的标识参数" @默认值 = 0>
    {

        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<URL请求事件>.GetPtr(),URLRequestClientType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ CefRefPtr<FBroHsURLRequestClient> tempclass = static_cast<FBroHsURLRequestClient*>(@<URL请求事件>.GetPtr());
        @ FBroHsURLRequest_Create(@<请求>.m_class,@<请求环境>.m_class,tempclass,@<标识>);
    }

    方法 FBrowser_取版本号 <公开 静态 类型 = 文本型 注释 = "取当前版本号" @禁止流程检查 = 真>
    {
        @ std::wstringstream ws;
        @ ws << FBroHsVersion_GetMain() << "." << FBroHsVersion_GetEdit() << "." << FBroHsVersion_GetDedug();
        @ return CVolString(ws.str().c_str());


    }

    方法 FBrowser_取初始化缓存目录 <公开 静态 类型 = 文本型 注释 = "取出初始化设置的真实缓存路径" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsGetSetCachePath();
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 FBrowser_设置程序DPI模式 <公开 静态 类型 = 逻辑型 注释 = "设置当前程序的DPI感知模式,在程序入口初始化之前调用" @禁止流程检查 = 真>
    参数 DPI模式 <类型 = DPI模式 注释 = "参考：DPI模式.">
    {
        @ return FBroHsSetProcessDPI(@<DPI模式>);
    }
}

类 类_FBrowser_事件智能指针 <公开 注释 = "事件智能指针，方便动态创建事件指针，智能指针会在引用完毕后自动释放所创建的指针，无需手动释放" @全局类 = 真>
{

    # @begin
    # <> <include>
    # public:
    # CefRefPtr<FBroBaseEvent> m_class = nullptr;
    # inline_ @sn<current_class> (CefRefPtr<FBroBaseEvent> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # FBroBaseEvent* GetPtr(){return m_class.get();};
    # <> </include>
    # @end

    方法 FBrowser创建事件智能指针 <公开 静态 类型 = 类_FBrowser_事件智能指针 注释 = "创建继承事件相关类的智能指针，智能指针会在引用完毕后自动释放所创建的指针" @嵌入式方法 = "">
    参数 数据类型 <类型 = 对象类 注释 = "需要创建的指针类型，必须是继承事件或者回调的类，否则会出错" @需求类型 = 数据类型>
    {
        @ @dt<类_FBrowser_事件智能指针>(new @<数据类型>())
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "判断当前设置的事件指针是否为空" @禁止流程检查 = 真>
    {
        @ return !m_class || !m_class.get();
    }

    方法 创建 <公开 注释 = "创建继承事件相关类的智能指针，智能指针会在引用完毕后自动释放所创建的指针,如果原本存在值，再次创建会覆盖原值" @嵌入式方法 = "">
    参数 数据类型 <类型 = 对象类 注释 = "创建的类型必须是继承事件或者回调的子类" @需求类型 = 数据类型>
    {
        @ @sn<this>.m_class = static_cast<@<数据类型>*>(new @<数据类型>());
    }

    方法 引用 <公开 注释 = "引用已经创建的事件数据指针，事件数据指针必须是用NEW创建，或者是本类方法的创建方法创建，否则将会出错" @嵌入式方法 = "">
    参数 数据指针 <类型 = 变整数 注释 = "数据指针和下面的数据类型必须相匹配，否则将会出错">
    参数 数据类型 <类型 = 对象类 注释 = "引用的指针数据类型，必须是事件或者回调类" @需求类型 = 数据类型>
    {
        @ @sn<this>.m_class = static_cast<@<数据类型>*>((HANDLE)@<数据指针>);
    }

    方法 取指针 <公开 类型 = 变整数 注释 = "取出当前事件的指针" 注释 = "注意：" 注释 = "1.此操作存在一定的不安全性，如果对指针不熟悉不建议使用！！！！！！！！！"
            注释 = "2.取出的指针将会脱离智能指针的控制，如果智能指针引用完毕释放了，取出来的指针自行没做处理清空，将变成野指针，再次调用就会出现异常" @禁止流程检查 = 真 @嵌入式方法 = "">
    参数 数据类型 <类型 = 对象类 注释 = "要取出的指针数据类型，必须和当前设置的指针数据类型一样，否则将出错" @需求类型 = 数据类型>
    {
        @ (@dt<变整数>)((HANDLE)(static_cast<@<数据类型>*>(@sn<this>.m_class.get())))
    }

    方法 取执行类 <公开 注释 = "取出当前智能指针保存的对应数据类型的执行类" @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 数据类型 <类型 = 对象类 注释 = "需要返回的指针类型，类指针和数据类型必须匹配，否则可能会出错" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ *static_cast<@<数据类型> *>(@sn<this>.m_class.get()) 

    }

    方法 取事件数据类型 <公开 类型 = 事件数据类型 注释 = "取出当前事件的类型" @禁止流程检查 = 真>
    {
        @ return m_class ? m_class->type_ : FBroBaseEventType::BEGIN;
    }

    方法 释放 <公开 注释 = "如果没有采用全局或者存在循环引用无法释放的问题，不用刻意取释放，智能指针会在引用完毕后自动释放">
    {
        @ if(m_class) {m_class=nullptr;}
    }

    方法 置空 <公开>
    {
        @ m_class=nullptr;
    }

    #
}

类 FBrowser类辅助 <公开 @全局类 = 真>
{
    方法 FBrowser创建类指针 <静态 类型 = 变整数 注释 = "弃用， 通过NEW创建动态类，创建后需释放,如果创建后传递为智能指针，会自动释放，不用手动释放" @嵌入式方法 = "">
    参数 数据类型 <类型 = 对象类 注释 = "需要创建的指针类型" @需求类型 = 数据类型>
    {
        @ (@dt<变整数>)(HANDLE)(new @<数据类型>())
    }

    方法 FBrowser取执行类 <静态 注释 = "弃用，将指针转换成可以执行的类" 注释 = "注意：如果将返回的类赋值给一个新变量，修改了新变量的值，"
            注释 = "需要将新变量通过\"FBrowser设置类\"设置回去，才会对原值生效，懂指针的都知道这是为什么!" @禁止流程检查 = 真 @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 类指针 <类型 = 变整数 注释 = "类指针">
    参数 数据类型 <类型 = 对象类 注释 = "需要返回的指针类型，类指针和数据类型必须匹配，否则可能会出错" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ *static_cast<@<数据类型> *>((HANDLE)@<类指针>) 
    }

    方法 FBrowser释放类 <静态 注释 = "弃用，释放通过\"FBrowser创建类指针\"创建的类" @禁止流程检查 = 真 @嵌入式方法 = "">
    参数 类指针 <类型 = 变整数 注释 = "类指针">
    参数 数据类型 <类型 = 对象类 注释 = "需要释放的指针值类型" @需求类型 = 数据类型>
    {
        @ delete static_cast<@<数据类型> *>((HANDLE)@<类指针>)

    }

    方法 FBrowser释放当前类 <静态 注释 = "弃用，释放当前位置所在的类，必须在类中使用且是通过\"FBrowser创建类指针\"创建的类！" 注释 = "类被释放后将无法继续使用" @禁止流程检查 = 真 @嵌入式方法 = "">
    {
        @ delete this
    }

    方法 FBrowser设置类 <静态 注释 = "弃用，设置类指针的值" @禁止流程检查 = 真 @嵌入式方法 = "">
    参数 类指针 <类型 = 变整数 注释 = "类指针">
    参数 值指针 <类型 = 对象类 注释 = "要设置的值">
    参数 数据类型 <类型 = 对象类 注释 = "需要设置指针值类型" @需求类型 = 数据类型>
    {
        @ * static_cast<@<数据类型> *>((HANDLE)@<类指针>)=((@<数据类型>)@<值指针>)
    }

    #
}

类 FBrowser辅助功能 <公开 @全局类 = 真>
{
    方法 FBrowser_Parser_Base64编码 <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ CefRefPtr<FBroString> temp = FBroHsBase64Encode(@<数据>.GetText());
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 FBrowser_Parser_Base64解码 <公开 静态 类型 = 类_FBrowser_字节集 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ return @dt<类_FBrowser_字节集>(FBroHsBase64Decode(@<数据>.GetText()));

    }

    方法 FBrowser_Parser_取数据URI <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 mimetype <类型 = 文本型>
    参数 数据 <类型 = 文本型>
    {
        @ CefRefPtr<FBroString> temp = FBroHsGetDataURI(@<mimetype>.GetText(),@<数据>.GetText());
        @ return FBroUnit::FBroStringToCWString(temp);


    }

    方法 FBrowser_Parser_URI编码 <公开 静态 类型 = 文本型
            注释 = "Escapes characters in |text| which are unsuitable for use as a query parameter value."
            注释 = "Everything except alphanumerics and -_.!~*\'() will be converted to \"%XX\"."
            注释 = "If |use_plus| is true spaces will change to \"+\"."
            注释 = "The result is basically the same as encodeURIComponent in Javacript." @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型 注释 = "text">
    参数 use_plus <类型 = 逻辑型>
    {
        @ CefRefPtr<FBroString> temp = FBroHsURIEncode(@<数据>.GetText(),@<use_plus>);
        @ return FBroUnit::FBroStringToCWString(temp);


    }

    方法 FBrowser_Parser_URI解码 <公开 静态 类型 = 文本型 注释 = "Unescapes |text| and returns the result."
            注释 = "Unescaping consists of looking for the exact pattern \"%XX\" where each X is a hex digit and converting to the character with the numerical value of those digits (e.g. \"i%20=%203%3b\" unescapes to \"i = 3;\")."
            注释 = "If |convert_to_utf8| is true this function will attempt to interpret the initial decoded result as UTF-8."
            注释 = "If the result is convertable into UTF-8 it will be returned as converted. Otherwise the initial decoded result will be returned."
            注释 = "The |unescape_rule| parameter supports further customization the decoding process." @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型 注释 = "text">
    参数 convert_to_utf8 <类型 = 逻辑型>
    参数 unescape_rule <类型 = 逻辑型 注释 = "参考：URI保留规则. 位标识操作">
    {
        @ CefRefPtr<FBroString> temp = FBroHsURIDecode(@<数据>.GetText(),@<convert_to_utf8>,@<unescape_rule>);
        @ return FBroUnit::FBroStringToCWString(temp);


    }

    方法 FBrowser_Parser_解析JSON <公开 静态 类型 = 类_FBrowser_值
            注释 = "Parses the specified |json_string| and returns a dictionary or list representation."
            注释 = "If JSON parsing fails this method returns NULL." @禁止流程检查 = 真>
    参数 json_string <类型 = 文本型>
    参数 options <类型 = 整数 注释 = "参考：JSON解析.*">
    {
        @ return @dt<类_FBrowser_值>(FBroHsParseJSON(@<json_string>.GetText(),@<options>));

    }

    方法 FBrowser_Parser_字节值解析为JSON <公开 静态 类型 = 类_FBrowser_值 注释 = "FBroHsParseJSON_BinaryValue" @禁止流程检查 = 真>
    参数 字节值 <类型 = 类_FBrowser_字节集>
    参数 options <类型 = 整数 注释 = "参考：JSON解析.*">
    {
        @ return @<字节值>.m_class?@dt<类_FBrowser_值>(FBroHsParseJSON_BinaryValue(@<字节值>.m_class,@<options>)):@dt<类_FBrowser_值>();
    }

    方法 FBrowser_Parser_写入JSON <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 node <类型 = 类_FBrowser_值>
    参数 options <类型 = 整数 注释 = "参考：JSON解析.*">
    {
        @ CefRefPtr<FBroString> temp = FBroHsWriteJSON(@<node>.m_class,@<options>);
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 FBrowser_清理全局缓存 <公开 静态
            注释 = "非cef自带功能，FBrowser特有内核实现功能，清理浏览器缓存，支持占用状态下清理appcache,cache_storage,cookies,indexeddb,local_storage,service_workers,websql">
    参数 源地址 <类型 = 文本型
            注释 = "留空则为当前origin域，前面必须含http(s)，根域名不能包含网址后的路径。例如：\"https://www.baidu.com/s?ie=utf-8&f=8\"则填\"https://www.baidu.com"
            @默认值 = "">
    参数 清理对象 <类型 = 长整数
            注释 = "参考：清理缓存.xxxx    要清理什么缓存，可单个单个清理，也可一起清理，多个模式，用\"位或\"添加。例如：位或 (#清理缓存_Appcache, #清理缓存_Cookies，#清理缓存_LocalStorage)"
            @默认值 = 清理缓存.全部>
    参数 存储类型 <类型 = 长整数 注释 = "参考：缓存类型.xxxx    要清理缓存的类型" @默认值 = 缓存类型.全部>
    参数 结果回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_清理缓存回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<结果回调>.GetPtr(),ClearCacheCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsClearCacheCallback> callback = static_cast<FBroHsClearCacheCallback*>(@<结果回调>.GetPtr());
        @ FBroHsBrowser_ClearGlobalCacheData(@<源地址>.GetText(),(unsigned long)@<清理对象>,(unsigned long)@<存储类型>,callback);


    }

    方法 FBrowser_浏览器_通过ID取浏览器 <公开 静态 类型 = 类_FBrowser_浏览器 注释 = "通过浏览器ID取出浏览器类，ID由浏览器类取ID获得，如果获取失败将返回一个空浏览器，注意判断" @禁止流程检查 = 真>
    参数 浏览器ID <类型 = 整数>
    {
        @ return @dt<类_FBrowser_浏览器>(FBroHsBrowserListControl_GetBrowserFromID(@<浏览器ID>));
    }

    方法 FBrowser_浏览器_通过序号取浏览器 <公开 静态 类型 = 类_FBrowser_浏览器 注释 = " 通过内置浏览器清单的顺序号获取浏览器类，如果获取失败将返回一个空浏览器，注意判断" @禁止流程检查 = 真>
    参数 序号 <类型 = 整数 注释 = "从0开始">
    {
        @ return @dt<类_FBrowser_浏览器>(FBroHsBrowserListControl_GetBrowserFromIndex(@<序号>));

    }

    方法 FBrowser_浏览器_通过窗口句柄取浏览器 <公开 静态 类型 = 类_FBrowser_浏览器 注释 = " 通过浏览器的窗口句柄取浏览器，注意这里是浏览器的窗口句柄，不是浏览器父窗口的句柄" @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return @dt<类_FBrowser_浏览器>(FBroHsBrowserListControl_GetBrowserFromWindowHandle((HWND)@<窗口句柄>));

    }

    方法 FBrowser_浏览器_通过用户标识取浏览器 <公开 静态 类型 = 类_FBrowser_浏览器 注释 = "通过浏览器标识取出浏览器类，浏览器标识为创建浏览器的时候设置，如果获取失败将返回一个空浏览器，注意判断"
            @禁止流程检查 = 真>
    参数 用户标识 <类型 = 文本型>
    {
        @ return @dt<类_FBrowser_浏览器>(FBroHsBrowserListControl_GetBrowserFromFlag(@<用户标识>.GetText()));
    }

    方法 FBrowser_浏览器_取数量 <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return FBroHsBrowserListControl_GetBrowserCount();
    }

    方法 FBrowser_浏览器_取ID清单 <公开 静态 类型 = 类_FBrowser_列表值 注释 = "返回全部浏览器ID清单，返回值为一个保存整数的清单列表值" @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_列表值>(FBroHsBrowserListControl_GetBrowserIDList());
    }

    方法 FBrowser_浏览器_取用户标识清单 <公开 静态 类型 = 类_FBrowser_列表值 注释 = "返回全部浏览器标识清单，浏览器标识为创建浏览器的时候设置，返回值为一个保存文本的清单列表值" @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_列表值>(FBroHsBrowserListControl_GetBrowserFlagList());
    }

    方法 异常收集回调模板函数 <静态 类型 = 整数 @禁止流程检查 = 真>
    参数 异常记录文件 <类型 = 文本型 注释 = "生成的异常文件">
    参数 异常数据 <类型 = 变整数 注释 = "_EXCEPTION_POINTERS* 类型指针数据">
    {
        @ return EXCEPTION_EXECUTE_HANDLER;

    }

    方法 FBrowser_启用异常收集 <公开 静态 注释 = "火山版本内置已经设置了，所有这个没用" @嵌入式方法 = "">
    参数 异常信息文件名 <类型 = 文本型>
    参数 异常执行回调 <@匹配方法 = "异常收集回调模板函数">
    {
        @ FBroHsDumpStart(@<异常信息文件名>.GetText(),(HANDLE)@<异常执行回调>);
    }
}

类 类_FBrowser_浏览器 <公开 @全局类 = 真>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefBrowser> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefBrowser> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefBrowser> object) { m_class = object; }
    # <> </include>
    # @end

    方法 FBrowser_创建浏览器 <公开 静态 类型 = 逻辑型 注释 = "注意：浏览的静态事件和动态事件只能设置一个，优先静态事件有效，不设置则没有事件触发；采用动态事件可实现一个浏览器一个独立事件的动态多态操作，更加灵活；"
            @禁止流程检查 = 真 "">
    参数 链接地址 <类型 = 文本型>
    参数 窗口信息 <类型 = FBrowser_窗口信息>
    参数 浏览器设置 <类型 = FBrowser_浏览器配置 @默认值 = 空对象>
    参数 请求环境 <类型 = 类_FBrowser_请求环境 @默认值 = 空对象>
    参数 额外信息 <类型 = 类_FBrowser_字典值 @默认值 = 空对象>
    参数 浏览器事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_浏览器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 禁用事件 <类型 = FBrowser_禁用事件 注释 = "当前浏览器器事件开关，可关闭某些不必要的事件加载，合理设置可提高加载速度" @默认值 = 空对象>
    参数 标识 <类型 = 文本型 注释 = "设置创建后的浏览器的用户标识，设置后可通过用户标识获取到对应的浏览器，注意用户标识不要重复" @默认值 = "">
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<浏览器事件>.GetPtr(),BroEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsBroEvent> hsbroevent = static_cast<FBroHsBroEvent*>(@<浏览器事件>.GetPtr());
        @ return FBroHsCreate(@<链接地址>.GetText(), @<窗口信息>.ToFBroData(), @<浏览器设置>.ToFBroData(), @<请求环境>.m_class, @<额外信息>.m_class,
        @ hsbroevent, @<禁用事件>.ToFBroData(), @<标识>.GetText());
    }

    方法 FBrowser_创建浏览器_同步 <公开 静态 类型 = 类_FBrowser_浏览器 注释 = "只能通过：FBrowser_任务运行器_投递任务 的方式创建，发送到UI线程使用，在其他线程无效"
            注释 = "例如：FBrowser_任务运行器_投递任务 (#线程ID_UI, 任务运行器)"
            注释 = "注意：浏览的静态事件和动态事件只能设置一个，优先静态事件有效，不设置则没有事件触发；采用动态事件可实现一个浏览器一个独立事件的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 链接地址 <类型 = 文本型>
    参数 窗口信息 <类型 = FBrowser_窗口信息>
    参数 浏览器设置 <类型 = FBrowser_浏览器配置 @默认值 = 空对象>
    参数 请求环境 <类型 = 类_FBrowser_请求环境 @默认值 = 空对象>
    参数 额外信息 <类型 = 类_FBrowser_字典值 @默认值 = 空对象>
    参数 浏览器事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_浏览器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 禁用事件 <类型 = FBrowser_禁用事件 注释 = "当前浏览器器事件开关，可关闭某些不必要的事件加载，合理设置可提高加载速度" @默认值 = 空对象>
    参数 标识 <类型 = 文本型 注释 = "设置创建后的浏览器的用户标识，设置后可通过用户标识获取到对应的浏览器，注意用户标识不要重复" @默认值 = "">
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<浏览器事件>.GetPtr(),BroEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsBroEvent> hsbroevent = static_cast<FBroHsBroEvent*>(@<浏览器事件>.GetPtr());
        @ return @dt<类_FBrowser_浏览器>(FBroHsCreateSync(@<链接地址>.GetText(), @<窗口信息>.ToFBroData(), @<浏览器设置>.ToFBroData(), @<请求环境>.m_class, @<额外信息>.m_class,
        @ hsbroevent, @<禁用事件>.ToFBroData(), @<标识>.GetText()));
    }

    方法 FBrowser_创建后台浏览器 <公开 静态 类型 = 逻辑型 注释 = "创建一个完全后台没有窗口的浏览器，该浏览器没有窗口，也没有窗口句柄，只能后台，不能显示出来，"
            注释 = "不同于创建浏览器再隐藏窗口，也非无头模式其优于无头模式，类似于插件后台但不能用插件的API，" 注释 = "可用于纯后台刷新取数等相关操作，比前台浏览器占用更低，其他操作和普通浏览器无异"
            注释 = "注意：浏览的静态事件和动态事件只能设置一个，优先静态事件有效，不设置则没有事件触发；采用动态事件可实现一个浏览器一个独立事件的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 链接地址 <类型 = 文本型>
    参数 浏览器设置 <类型 = FBrowser_浏览器配置 @默认值 = 空对象>
    参数 请求环境 <类型 = 类_FBrowser_请求环境 @默认值 = 空对象>
    参数 额外信息 <类型 = 类_FBrowser_字典值 @默认值 = 空对象>
    参数 浏览器事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_浏览器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 禁用事件 <类型 = FBrowser_禁用事件 注释 = "当前浏览器器事件开关，可关闭某些不必要的事件加载，合理设置可提高加载速度" @默认值 = 空对象>
    参数 标识 <类型 = 文本型 注释 = "设置创建后的浏览器的用户标识，设置后可通过用户标识获取到对应的浏览器，注意用户标识不要重复" @默认值 = "">
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<浏览器事件>.GetPtr(),BroEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsBroEvent> hsbroevent = static_cast<FBroHsBroEvent*>(@<浏览器事件>.GetPtr());
        @ return FBroHsCreateBackground(@<链接地址>.GetText(), @<浏览器设置>.ToFBroData(), @<请求环境>.m_class, @<额外信息>.m_class, 
        @ hsbroevent, @<禁用事件>.ToFBroData(), @<标识>.GetText());

    }

