            注释 = "This method is only used when window rendering is disabled.">
    {
        @ if(!IsEmpty()) FBroHsBrowserHost_DragTargetDragLeave(m_class);


    }

    方法 离屏渲染_拖动放下 <公开 注释 = "英文名：DragTargetDrop"
            注释 = "说明：Call this method when the user completes the drag operation by dropping the object onto the web view (after calling DragTargetDragEnter)."
            注释 = "The object being dropped is |drag_data|, given as an argument to the previous DragTargetDragEnter call."
            注释 = "This method is only used when window rendering is disabled.">
    参数 鼠标事件 <类型 = FBrowser_鼠标事件>
    {
