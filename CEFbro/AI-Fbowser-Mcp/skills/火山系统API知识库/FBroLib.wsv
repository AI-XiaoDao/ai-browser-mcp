    方法 离屏渲染_IME置组成 <公开 注释 = "英文名：ImeSetComposition"
            注释 = "Begins a new composition or updates the existing composition. Blink has a"
            注释 = "special node (a composition node) that allows the input method to change"
            注释 = "text without affecting other DOM nodes. |text| is the optional text that"
            注释 = "will be inserted into the composition node. |underlines| is an optional set"
            注释 = "of ranges that will be underlined in the resulting text."
            注释 = "|replacement_range| is an optional range of the existing text that will be"
            注释 = " replaced. |selection_range| is an optional range of the resulting text that"
            注释 = "will be selected after insertion or replacement. The |replacement_range|" 注释 = "value is only used on OS X."
            注释 = "This method may be called multiple times as the composition changes. When"
            注释 = "the client is done making changes the composition should either be canceled"
            注释 = "or completed. To cancel the composition call ImeCancelComposition. To"
            注释 = "complete the composition call either ImeCommitText or"
            注释 = "ImeFinishComposingText. Completion is usually signaled when:"
            注释 = "   A. The client receives a WM_IME_COMPOSITION message with a GCS_RESULTSTR" 注释 = "      flag (on Windows), or;"
            注释 = "   B. The client receives a \"commit\" signal of GtkIMContext (on Linux), or;"
            注释 = "   C. insertText of NSTextInput is called (on Mac)."
            注释 = " This method is only used when window rendering is disabled." "">
    参数 文本 <类型 = 文本型>
    参数 下划线组成 <类型 = FBrowser_下划线组成数组>
    参数 代替范围 <类型 = FBrowser_范围>
    参数 选择范围 <类型 = FBrowser_范围>
    {
        @ if(!IsEmpty()) FBroHsBrowserHost_ImeSetComposition(m_class,@<文本>.GetText(),@<下划线组成>.m_class,@<代替范围>.ToFBroData(),@<选择范围>.ToFBroData());

    }

    方法 离屏渲染_IME置交互文本 <公开 注释 = "英文名：ImeCommitText"
            注释 = "说明：Completes the existing composition by optionally inserting the specified |text| into the composition node."
            注释 = "|replacement_range| is an optional range of the existing text that will be replaced."
            注释 = "|relative_cursor_pos| is where the cursor will be positioned relative to the current cursor position."
            注释 = "See comments on ImeSetComposition for usage."
            注释 = "The |replacement_range| and |relative_cursor_pos| values are only used on OS X."
            注释 = " This method is only used when window rendering is disabled.">
    参数 文本 <类型 = 文本型 注释 = "text">
    参数 代替范围 <类型 = FBrowser_范围 注释 = "replacement_range">
    参数 relative_cursor_pos <类型 = 整数>
    {
        @ if(!IsEmpty()) FBroHsBrowserHost_ImeCommitText(m_class,@<文本>.GetText(),@<代替范围>.ToFBroData(),relative_cursor_pos);

    }

    方法 离屏渲染_IME完成组合文本 <公开 注释 = "英文名：ImeFinishComposingText"
            注释 = "说明：Completes the existing composition by applying the current composition node contents."
            注释 = "If |keep_selection| is false the current selection, if any, will be discarded. See comments on ImeSetComposition for usage."
            注释 = "This method is only used when window rendering is disabled.">
    参数 保持选择 <类型 = 逻辑型 注释 = "keep_selection">
    {
        @ if(!IsEmpty()) FBroHsBrowserHost_ImeFinishComposingText(m_class,@<保持选择>);


    }

    方法 离屏渲染_IME取消组合 <公开 注释 = "英文名：ImeCancelComposition"
            注释 = "说明：Cancels the existing composition and discards the composition node contents without applying them."
            注释 = "See comments on ImeSetComposition for usage. This method is only used when window rendering is disabled.">
    {
