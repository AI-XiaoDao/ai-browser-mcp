    方法 离屏渲染_拖动结束位置 <公开 注释 = "英文名：DragSourceEndedAt"
            注释 = "说明：Call this method when the drag operation started by a CefRenderHandler::StartDragging call has ended either in a drop or by being cancelled."
            注释 = "|x| and |y| are mouse coordinates relative to the upper-left corner of the view."
            注释 = "If the web view is both the drag source and the drag target then all DragTarget* methods should be called before DragSource* mthods."
            注释 = "This method is only used when window rendering is disabled.">
    参数 横坐标 <类型 = 整数 注释 = "x">
    参数 纵坐标 <类型 = 整数 注释 = "y">
    参数 拖动操作类型 <类型 = 整数 注释 = "参考：拖动操作.xxxxx">
