            注释 = "说明：Call this method when the drag operation started by a CefRenderHandler::StartDragging call has completed."
            注释 = "This method may be called immediately without first calling DragSourceEndedAt to cancel a drag operation."
            注释 = "If the web view is both the drag source and the drag target then all DragTarget* methods should be called before DragSource* mthods."
            注释 = "This method is only used when window rendering is disabled.">
    {
        @ if(!IsEmpty()) CefBrowserHost_DragSourceSystemDragEnded(m_class);


    }

    方法 清理缓存 <公开 注释 = "非cef自带功能，FBrowser特有内核实现功能，"
            注释 = "清理当前浏览器缓存，支持占用状态下清理appcache,cache_storage,cookies,indexeddb,local_storage,service_workers,websql；"
            注释 = "注：如果是独立缓存又采用了单进程模式清理无效,因为独立缓存是不能使用单进程模式的，调试状态使用单进程模式的请注意，可以编译出来进行测试，或调试也不用单进程模式">
    参数 源地址 <类型 = 文本型
            注释 = "留空则为当前origin域，前面必须含http(s)，根域名不能包含网址后的路径。例如：\"https://www.baidu.com/s?ie=utf-8&f=8\"则填\"https://www.baidu.com"
            @默认值 = "">
    参数 清理对象 <类型 = 长整数
            注释 = "参考：清理缓存.xxxx    要清理什么缓存，可单个单个清理，也可一起清理，多个模式，用\"位或\"添加。例如：位或 (#清理缓存_Appcache, #清理缓存_Cookies，#清理缓存_LocalStorage)"
            @默认值 = 清理缓存.全部>
    参数 存储类型 <类型 = 长整数 注释 = "参考：缓存类型.xxxx    要清理缓存的类型" @默认值 = 缓存类型.全部>
    参数 结果回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_清理缓存回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<结果回调>.GetPtr(),ClearCacheCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ if(IsEmpty()) return;

        @ CefRefPtr<FBroHsClearCacheCallback> callback = static_cast<FBroHsClearCacheCallback*>(@<结果回调>.GetPtr());
        @ FBroHsBrowser_ClearCacheData(m_class,@<源地址>.GetText(),(unsigned long)@<清理对象>,(unsigned long)@<存储类型>,callback);


    }

    方法 设置代理 <公开 注释 = "设置当前浏览器代理，在\"浏览器_即将导航\"或\"浏览器_创建完毕\"事件中设置，也可在其他地方设置，但刷新后才会生效；"
            注释 = "配合独立缓存一起使用设置的代理也会成为独立，否则还是全局，如果需要认证则需要设置账号密码；" 注释 = "不支持带账号密码的S5代理，如要使用带账号密码的S5代理，请使用“VIP_高级_设置代理”"
            注释 = "注意：因为设置代理利用的首选项功能，如果启用了保留用户首选项，关闭的时候就要使用清理代理功能，否则可能再次打开浏览器还是使用的之前的代理，但又未手动设置账号密码或代理已经关闭而导致代理失败网页无法显示">
    参数 代理地址 <类型 = 文本型 注释 = "要区分大小写，不要有空格，否则地址错误将会设置失败">
    参数 代理账号 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    {
        @ if(IsEmpty()) return;
        @ FBroHsBrowser_SetProxy (m_class, @<代理地址>.GetText(), @<代理账号>.GetText(), @<代理密码>.GetText());

    }

    方法 清空代理 <公开>
    {
        @ if(IsEmpty()) return;
        @ FBroHsBrowser_ClearProxy (m_class);
    }

    方法 取主填表框架 <公开 类型 = 类_FBrowser_填表框架
            注释 = "英文名：GetMainFrame 说明：Returns the main (top-level) frame for the browser window.只能在主进程中使用" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_填表框架>(FBroHsBrowser_GetMainFrame(m_class));
        @ return @dt<类_FBrowser_填表框架>();
    }

    方法 取焦点填表框架 <公开 类型 = 类_FBrowser_填表框架 注释 = "英文名：GetFocusedFrame 说明：Returns the focused frame for the browser window."
            @禁止流程检查 = 真>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_填表框架>(FBroHsBrowser_GetFocusedFrame(m_class));
        @ return @dt<类_FBrowser_填表框架>();

    }

    方法 取填表框架_ID <公开 类型 = 类_FBrowser_填表框架 注释 = "英文名：GetFrame 说明：必须使用取框架ID取出的ID标识，ID错误会导致返回值为空，用类的是否为空判断，类为空而执行操作会导致奔溃"
            @禁止流程检查 = 真>
    参数 ID <类型 = 文本型>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_填表框架>(FBroHsBrowser_GetFrameById(m_class,@<ID>.GetText()));
        @ return @dt<类_FBrowser_填表框架>();
    }

    方法 取填表框架_名称 <公开 类型 = 类_FBrowser_填表框架 注释 = "英文名：GetFrame 说明：必须使用取框架名称取出的框架名，名称会导致返回值为空，用类的是否为空判断，类为空而执行操作会导致奔溃." @禁止流程检查 = 真>
    参数 名称 <类型 = 文本型>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_填表框架>(FBroHsBrowser_GetFrameByName(m_class,@<名称>.GetText()));
