    }

    方法 取像素宽度 <公开 类型 = 整数 注释 = "英文名：GetWidth 说明:Returns the image width in density independent pixel (DIP) units." @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return 0;
        @ return FBroHsImage_GetWidth(m_class);
    }

    方法 取像素高度 <公开 类型 = 整数 注释 = "英文名：GetHeight 说明:Returns the image height in density independent pixel (DIP) units" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return 0;
        @ return FBroHsImage_GetHeight(m_class);
    }

    方法 取图片信息 <公开 类型 = 逻辑型
            注释 = "英文名：GetRepresentationInfo 说明： Returns information for the representation that most closely matches |scale_factor|"
            @禁止流程检查 = 真>
    参数 比例因子 <类型 = 小数 注释 = "设置比例因子" "">
    参数 实际比例 <类型 = 小数类 注释 = "返回实际比例" "">
    参数 宽度 <类型 = 整数类 注释 = "返回宽度" "">
    参数 高度 <类型 = 整数类 注释 = "返回高度" "">
    {
        @ if(IsEmpty()) return false;
        @ float scale_factor,actual_scale_factor;
        @ int pixel_width,pixel_height;
        @ scale_factor=(float)@<比例因子>;
        @ bool retbool = FBroHsImage_GetRepresentationInfo(m_class,scale_factor,actual_scale_factor,pixel_width,pixel_height);
        @ @<实际比例.值>=actual_scale_factor;@<宽度.值>=pixel_width;@<高度.值>=pixel_height;
        @ return retbool;
    }

    方法 取图片数据_BMP <公开 类型 = 类_FBrowser_字节集 注释 = "英文名：GetAsBitmap">
    参数 比例因子 <类型 = 小数 注释 = "设置比例因子" "">
    参数 颜色类型 <类型 = 整数 注释 = "参考：颜色类型.xxx">
    参数 透明类型 <类型 = 整数 注释 = "参考：透明类型.xxx">
    参数 宽度 <类型 = 整数类 注释 = "返回宽度" "">
    参数 高度 <类型 = 整数类 注释 = "返回高度" "">
    {
        变量 图片数据 <类型 = 类_FBrowser_字节集>
        @ if(IsEmpty()) return @<图片数据>;
        @ float scale_factor;
        @ scale_factor=@<比例因子>;
        @ int colortype,alphatype,pixel_width,pixel_height,size;
        @ colortype=@<颜色类型>;alphatype=@<透明类型>;
        @ CefRefPtr<CefBinaryValue> datapoint=FBroHsImage_GetAsBitmap(m_class,scale_factor,colortype,alphatype,pixel_width,pixel_height);
        @ @<宽度.值>=pixel_width;
        @ @<高度.值>=pixel_height;
        @ @<图片数据>.Set(datapoint);
        返回 (图片数据)


    }

    方法 取图片数据_JPG <公开 类型 = 类_FBrowser_字节集>
