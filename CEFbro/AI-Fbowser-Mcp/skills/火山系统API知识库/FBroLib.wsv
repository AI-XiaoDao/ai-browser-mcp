类 类_FBrowser_服务器 <公开 注释 = "CefServer" @全局类 = 真>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefServer> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefServer> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefServer> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 FBrowser_服务器_创建 <公开 静态 注释 = "注意：静态事件和动态事件只能设置一个，优先静态事件有效；采用动态事件可实现回调的动态多态操作，更加灵活；">
    参数 地址 <类型 = 文本型>
    参数 端口 <类型 = 整数>
    参数 最大连接数 <类型 = 整数>
    参数 服务处理事件 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_服务器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<服务处理事件>.GetPtr(),ServerHandleType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsServerHandle> callback = static_cast<FBroHsServerHandle*>(@<服务处理事件>.GetPtr());
        @ FBroHsServer_CreateServer(@<地址>.GetText(),@<端口>,@<最大连接数>,callback);

    }

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 关闭 <公开 注释 = "Shutdown：" 注释 = "Stop the server and shut down the dedicated server thread."
            注释 = "See CefServerHandler::OnServerCreated documentation for a description of server lifespan." @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) FBroHsServer_Shutdown(m_class);
    }

    方法 是否运行中 <公开 类型 = 逻辑型 注释 = "IsRunning："
            注释 = "Returns true if the server is currently running and accepting incoming connections."
            注释 = "See CefServerHandler::OnServerCreated documentation for a description of server lifespan."
            注释 = "This method must be called on the dedicated server thread." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FBroHsServer_IsRunning(m_class);
    }

    方法 取服务器地址 <公开 类型 = 文本型 注释 = "GetAddress：Returns the server address including the port number." @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsServer_GetAddress(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 是否存在连接 <公开 类型 = 逻辑型 注释 = "HasConnection：" 注释 = "Returns true if the server currently has a connection."
            注释 = "This method must be called on the dedicated server thread." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FBroHsServer_HasConnection(m_class);
    }

    方法 是否有效连接 <公开 类型 = 逻辑型 注释 = "IsValidConnection：" 注释 = "Returns true if |connection_id| represents a valid connection."
            注释 = "This method must be called on the dedicated server thread." @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connection_id">
    {
        @ return IsEmpty()? false : FBroHsServer_IsValidConnection(m_class);
    }

    方法 发送Http200响应 <公开 注释 = "SendHttp200Response："
            注释 = " Send an HTTP 200 \"OK\" response to the connection identified by |connection_id|."
            注释 = "|content_type| is the response content type (e.g.\"text/html\"), |data| is the response content, and |data_size| is the size of |data| in bytes."
            注释 = "The contents of |data| will be copied. The connection will be closed automatically after the response is sent."
            @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connection_id">
    参数 连接类型 <类型 = 文本型 注释 = "content_type">
    参数 数据指针 <类型 = 变整数 注释 = "data">
    参数 数据大小 <类型 = 整数 注释 = "data_size">
    {
        @ if(!IsEmpty()) FBroHsServer_SendHttp200Response(m_class,@<连接ID>,@<连接类型>.GetText(),(void *)@<数据指针>,@<数据大小>);
    }

    方法 发送Http404响应 <公开 注释 = "SendHttp404Response："
            注释 = "Send an HTTP 404 \"Not Found\" response to the connection identified by |connection_id|."
            注释 = "The connection will be closed automatically after the response is sent." @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connectionid">
    {
        @ if(!IsEmpty()) FBroHsServer_SendHttp404Response(m_class,@<连接ID>);
    }

    方法 发送Http500响应 <公开 注释 = "SendHttp500Response："
            注释 = "Send an HTTP 500 \"Internal Server Error\" response to the connection identified by |connection_id|."
            注释 = "|error_message| is the associated error message."
            注释 = "The connection will be closed automatically after the response is sent." @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connection_id">
    参数 错误文本 <类型 = 文本型 注释 = "error_message">
    {
        @ if(!IsEmpty()) FBroHsServer_SendHttp500Response(m_class,@<连接ID>,@<错误文本>.GetText());

    }

    方法 取任务运行器 <公开 类型 = 类_FBrowser_任务运行器 注释 = "GetTaskRunner：Returns the task runner for the dedicated server thread."
            @禁止流程检查 = 真>
    {
        @ return IsEmpty()? @dt<类_FBrowser_任务运行器>() : @dt<类_FBrowser_任务运行器>(FBroHsServer_GetTaskRunner(m_class));
    }

    方法 发送原始数据 <公开 注释 = "SendRawData：" 注释 = "Send raw data directly to the connection identified by |connection_id|."
            注释 = "|data| is the raw data and |data_size| is the size of |data| in bytes.The contents of |data| will be copied."
            注释 = "No validation of |data| is performed internally so the client should be careful to send the amount indicated by the \"Content-Length\" header, if specified."
            注释 = "See SendHttpResponse documentation for intended usage." @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connectionid">
    参数 数据指针 <类型 = 变整数 注释 = "data">
    参数 数据大小 <类型 = 整数 注释 = "data_size">
    {
        @ if(!IsEmpty()) FBroHsServer_SendRawData(m_class,@<连接ID>,(void *)@<数据指针>,@<数据大小>);
    }

    方法 关闭连接 <公开 注释 = "CloseConnection" @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数>
    {
        @ if(!IsEmpty()) FBroHsServer_CloseConnection(m_class,@<连接ID>);
    }

    方法 发送WebSocket数据 <公开 注释 = "SendWebSocketMessage:Send a WebSocket message to the connection identified by |connection_id|."
            @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connection_id">
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ if(!IsEmpty()) FBroHsServer_SendWebSocketMessage(m_class,@<连接ID>,(void *)@<数据指针>,@<数据大小>);
    }

    方法 发送HttpResponse <公开 注释 = "SendHttpResponse：Send a custom HTTP response to the connection identified by |connection_id|"
            @禁止流程检查 = 真>
    参数 连接ID <类型 = 整数 注释 = "connectionid">
    参数 响应代码 <类型 = 整数 注释 = "responsecode:the HTTP response code sent in the status line (e.g. 200)">
    参数 响应类型 <类型 = 文本型 注释 = "contenttype:the response content type sent as the \"Content-Type\" header (e.g. \"text/html\")">
    参数 内容长度 <类型 = 整数 注释 = "content_length:"
            注释 = "the expected content length.If |content_length| is >= 0 then the \"Content-Length\" header will be sent."
            注释 = "If |content_length| is 0 then no content is expected and the connection will be closed automatically after the response is sent."
            注释 = "If |content_length| is < 0 then no \"Content-Length\" header will be sent and the client will continue reading until the connection is closed">
    参数 额外头数据 <类型 = FBrowser_双文本数组 注释 = "extra_headers：the map of extra response headers">
    {
        @ if(!IsEmpty()) FBroHsServer_SendHttpResponse(m_class,@<连接ID>,@<响应代码>,@<响应类型>.GetText(),@<内容长度>,@<额外头数据>.m_data);
    }
}

类 类_FBrowser_读取流 <公开 注释 = "CefStreamReader" @全局类 = 真>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefStreamReader> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefStreamReader> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefStreamReader> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 FBrowser_读取流_从文件创建 <公开 静态 类型 = 类_FBrowser_读取流 @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型>
    {
        @ return @dt<类_FBrowser_读取流>(FBroStream_CreateForFile(@<文件名>.GetText()));
    }

    方法 FBrowser_读取流_从数据创建 <公开 静态 类型 = 类_FBrowser_读取流 注释 = "Create a new CefStreamReader object from a file." @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ return @dt<类_FBrowser_读取流>(FBroStream_CreateForData((void *)@<数据指针>,@<数据大小>));
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "Create a new CefStreamReader object from data." @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 读取 <公开 类型 = 整数 注释 = "Read raw binary data." @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "ptr">
    参数 数据大小 <类型 = 整数 注释 = "size">
    参数 n <类型 = 整数 注释 = "n">
    {
        @ return IsEmpty()? 0 : FBroStream_Read(m_class,(void *)@<数据指针>,@<数据大小>,@<n>);
    }

    方法 到指定偏移位置 <公开 类型 = 整数 注释 = "Seek to the specified offset position."
            注释 = "|whence| may be any one of SEEK_CUR, SEEK_END or SEEK_SET. Returns zero on success and non-zero on failure."
            @禁止流程检查 = 真>
    参数 偏移位置 <类型 = 长整数 注释 = "offset">
    参数 由来 <类型 = 整数 注释 = "whence  参考：SEEK.XXXXX">
    {
        @ return IsEmpty()? 0 : FBroStream_Seek(m_class,@<偏移位置>,@<由来>);

    }

    方法 取当前偏移位置 <公开 类型 = 长整数 注释 = "Return the current offset position." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? 0 : FBroStream_Tell(m_class);
    }

    方法 是否到文件尾 <公开 类型 = 逻辑型 注释 = "Return non-zero if at end of file." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FBroStream_Eof(m_class)!=0;
    }

    方法 是否阻塞 <公开 类型 = 逻辑型 注释 = "Returns true if this reader performs work like accessing the file system  which may block."
            注释 = "Used as a hint for determining the thread to access the reader from." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FBroStream_MayBlock(m_class);
    }

    #
}

类 类_FBrowser_同步辅助类 <公开 注释 = "同步辅助类，可用于辅助异步等待返回值，注意：内置等待方法不能用于浏览器事件中，会卡事件照成浏览器停止加载而异常;不能直接通过\"=\"直接给类赋值，必须使用内置方法操作">
{

    # @begin
    # <> <include>
    # SynEventDis* _event = nullptr;
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { _event = objCopyFrom._event; }
    # <> </include>
    # @end

    方法 是否已创建 <公开 类型 = 逻辑型 注释 = "返回真表示已创建，返回假表示未创建" @禁止流程检查 = 真>
    {
        @ return _event!=nullptr;
    }

    #

    方法 创建 <公开 注释 = "创建后使用完毕需执行销毁释放资源，否则资源无法释放,如果数据已经存在再次创建会重置以前数据">
    {
        @ if(_event) {FBroSynEventDis_ResetEvent (_event);}
        @ _event = (SynEventDis *)FBroSynEventDis_CreatEvent ();

    }

    方法 销毁 <公开 注释 = "释放资源">
    {
        @ FBroSynEventDis_CloseEvent (_event);
        @ _event = nullptr;
    }

    方法 取指针 <公开 类型 = 变整数 注释 = "取出该类创建后的原始指针，未创建返回0" @禁止流程检查 = 真>
    {
        @ return (@dt<变整数>)_event;
    }

    方法 绑定 <公开 注释 = "绑定的指针必须是该类方法中\"取指针\"取出的数据，如果已存在指针值将会绑定失败，需将原数据销毁后才可重新绑定，乱设置指针会导致异常出错，严重的会崩溃">
    参数 指针 <类型 = 变整数>
    {
        @ if(_event) return;
        @ _event = (SynEventDis*)@<指针>;

    }

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "判断同步类是否有效，如果同步类已销毁或者意外终止这里会返回假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_IsValid(_event);
    }

    方法 清理数据 <公开 注释 = "清理全部已设置的数据，此方法不会重置等待，只清理数据">
    {
        @ FBroSynEventDis_ClearData();
    }

    方法 重置 <公开 类型 = 逻辑型 注释 = "使用前必须向执行创建命令，重置当前状态并清理已设置数据" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_ResetEvent (_event);

    }

    方法 等待 <公开 类型 = 整数 注释 = "使用前必须先执行创建命令,执行后,一直柱塞等待直到执行本类中的\"停止等待\"后结束,返回0等待失败，返回-1等待超时，返回1成功"
            注释 = "不能用于浏览器事件中，会卡事件照成浏览器停止加载而异常" @禁止流程检查 = 真>
    参数 超时 <类型 = 整数 @默认值 = 99999>
    {
        @ return FBroSynEventDis_WaitEvent(_event,@<超时>);
    }

    方法 停止等待 <公开 类型 = 逻辑型 注释 = "使用前必须先执行创建或绑定已创建的指针命令,结束等待操作" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_SetEvent (_event);
    }

    方法 置整数 <公开>
    参数 数据 <类型 = 整数>
    {
        @ FBroSynEventDis_SetIntData (_event, @<数据>);
    }

    方法 置双精度小数型 <公开>
    参数 数据 <类型 = 小数>
    {
        @ FBroSynEventDis_SetDoubleData (_event, @<数据>);
    }

    方法 置逻辑型 <公开>
    参数 数据 <类型 = 逻辑型>
    {
        @ FBroSynEventDis_SetBoolData (_event, @<数据>);
    }

    方法 置文本型 <公开>
    参数 数据 <类型 = 文本型>
    {
        @ FBroSynEventDis_SetWStringData (_event, @<数据>.GetText());
    }

    方法 置字节集 <公开>
    参数 数据 <类型 = 字节集类>
    {
        @ FBroSynEventDis_SetBitData (_event, @<数据>.GetPtr(),@<数据>.GetSize ());


    }

    方法 添加字节集 <公开 注释 = "在原有的基础上添加字节集数据，原数据保留">
    参数 数据 <类型 = 字节集类>
    {
        @ FBroSynEventDis_AddBitData (_event, @<数据>.GetPtr(),@<数据>.GetSize ());

    }

    方法 取整数 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_GetIntData(_event);
    }

    方法 取双精度小数型 <公开 类型 = 小数 @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_GetDoubleData(_event);
    }

    方法 取逻辑型 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_GetBoolData(_event);
    }

    方法 取文本型 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> fbrostring = FBroSynEventDis_GetWStringData(_event);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取字节集 <公开 类型 = 字节集类 @禁止流程检查 = 真>
    参数 取出大小 <类型 = 整数 注释 = "为0会取出全部大小，不能超出本身大小" @默认值 = 0>
    参数 偏移量 <类型 = 整数 注释 = "开始读取字节集位置" @默认值 = 0>
    {
        变量 tempret <类型 = 字节集类>
        @ int size = @<取出大小>==0? FBroSynEventDis_GetBitDataSize(_event)-@<偏移量> : @<取出大小>;
        @ if(size>0){ void* retdata = malloc(size);
        @ FBroSynEventDis_GetBitData(_event,retdata,size,@<偏移量>);
        @ @<tempret>=@an<CVolMem>(retdata, size); free(retdata);}
        返回 (tempret)

    }

    方法 置浏览器 <公开>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        @ FBroSynEventDis_SetCefBrowser(_event,@<浏览器>.m_class.get());
    }

    方法 置框架 <公开>
    参数 框架 <类型 = 类_FBrowser_框架>
    {
        @ FBroSynEventDis_SetCefFrame(_event,@<框架>.m_class.get());
    }

    方法 置字典值 <公开>
    参数 字典值 <类型 = 类_FBrowser_字典值>
    {
        @ FBroSynEventDis_SetCefDictionaryValue(_event,@<字典值>.m_class.get());
    }

    方法 取浏览器 <公开 类型 = 类_FBrowser_浏览器 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_浏览器>(FBroSynEventDis_GetCefBrowser(_event));
    }

    方法 取框架 <公开 类型 = 类_FBrowser_框架 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_框架>(FBroSynEventDis_GetCefFrame(_event));
    }

    方法 取字典值 <公开 类型 = 类_FBrowser_字典值 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_字典值>(FBroSynEventDis_GetCefDictionaryValue(_event));
    }

    方法 是否存在整数值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假，为真包括设置为0" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavIntData(_event);
    }

    方法 是否存在双精度小数值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假，为真包括设置为0" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavDoubleData(_event);
    }

    方法 是否存在逻辑值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假，为真包括设置为假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavBoolData(_event);
    }

    方法 是否存在文本值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假，为真包括设置为空文本" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavWStringData(_event);
    }

    方法 是否存在字节集值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavBitData(_event);
    }

    方法 是否存在浏览器值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavCefBrowser(_event);
    }

    方法 是否存在框架值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavCefFrame(_event);
    }

    方法 是否存在字典值 <公开 类型 = 逻辑型 注释 = "存在值返回真，不存在或重置后返回假" @禁止流程检查 = 真>
    {
        @ return FBroSynEventDis_HavCefDictionaryValue(_event);
    }

    #
}

类 类_FBrowser_填表框架 <公开 基础类 = 类_FBrowser_基础框架 "">
{

    # @begin
    # <> <include>
    # @sn<current_class> (CefRefPtr<CefFrame> object): @sn<base_class>(object){@sn<current_class> ();}
    # <> </include>
    # @end

    方法 点击元素 <公开>
    参数 选择器 <类型 = 文本型>
    参数 索引 <类型 = 整数 注释 = "从0开始，选择器的第几个标签" @默认值 = 0>
    {
        如果真 (是否有效 ())
        {
            子文本替换 (选择器, "\"", "\\\"", , , )
            @ FBroHsBrowserFrameTianBiao_SetClick(m_class,@<选择器>.GetText(),@<索引>);

        }
    }

    方法 滚动到元素 <公开>
    参数 选择器 <类型 = 文本型>
    参数 索引 <类型 = 整数 注释 = "从0开始，选择器的第几个标签" @默认值 = 0>
    参数 是否顶端对齐 <类型 = 逻辑型 注释 = "默认为：真，为否为底部对齐" @默认值 = 真>
    {
        如果真 (是否有效 ())
        {
            子文本替换 (选择器, "\"", "\\\"", , , )
            @ FBroHsBrowserFrameTianBiao_SetScrollIntoView(m_class,@<选择器>.GetText(),@<索引>,@<是否顶端对齐>);

        }
    }

    方法 置元素选择框 <公开>
    参数 选择器 <类型 = 文本型>
    参数 索引 <类型 = 整数 注释 = "从0开始，选择器的第几个标签" @默认值 = 0>
    参数 选择 <类型 = 逻辑型>
    {
        如果真 (是否有效 ())
        {
            子文本替换 (选择器, "\"", "\\\"", , , )
            @ FBroHsBrowserFrameTianBiao_SetChecked(m_class,@<选择器>.GetText(),@<索引>,@<选择>);

        }
    }

    方法 取元素选择框 <公开>
    参数 选择器 <类型 = 文本型>
    参数 索引 <类型 = 整数 注释 = "从0开始，选择器的第几个标签" @默认值 = 0>
    参数 结果回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_JS回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        如果真 (是否有效 ())
        {
            子文本替换 (选择器, "\"", "\\\"", , , )
            // 判断设置事件是否匹配,只在调试情况下生效
            @ _FBRO_CHECK_EVENT_TYPE(@<结果回调>.GetPtr(),JsCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

            @ CefRefPtr<FBroHsJsCallback> callback = static_cast<FBroHsJsCallback *>(@<结果回调>.GetPtr());
            @ FBroHsBrowserFrameTianBiao_GetChecked(m_class,@<选择器>.GetText(),@<索引>,callback);

        }
    }

    方法 置元素选择项 <公开>
    参数 选择器 <类型 = 文本型>
    参数 索引 <类型 = 整数 注释 = "从0开始，选择器的第几个标签" @默认值 = 0>
    参数 选择项 <类型 = 整数 注释 = "选择选择框的第几个">
    {
        如果真 (是否有效 ())
