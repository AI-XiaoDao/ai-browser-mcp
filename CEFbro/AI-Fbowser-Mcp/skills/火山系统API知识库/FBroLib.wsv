    参数 数据大小 <类型 = 整数>
    {
        变量 tempret <类型 = 字节集类>
        @ if(!IsEmpty ()){
        @ void * tempdata=malloc(@<数据大小>);
        @ FBroHsPostDataElement_GetBytes(m_class,@<数据大小>,tempdata);
