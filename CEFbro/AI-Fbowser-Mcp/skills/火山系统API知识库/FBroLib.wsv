        @ @<宽度.值>=pixel_width;
        @ @<高度.值>=pixel_height;
        @ @<图片数据>.Set(datapoint);
        返回 (图片数据)

    }

    方法 取图片数据_PNG <公开 类型 = 类_FBrowser_字节集>
