类 类_FBrowser_请求环境 <公开 @输出名 = "FBroRequestContext" @全局类 = 真 "">
{

    # @begin
    # <> <include>
    # CefRefPtr<CefRequestContext> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefRequestContext> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<CefRequestContext> object) { m_class = object; }
    # <> </include>
    # @end
    #

    方法 FBrowser_请求环境_取全局 <公开 静态 类型 = 类_FBrowser_请求环境 @禁止流程检查 = 真>
    {
        @ return @dt<类_FBrowser_请求环境>(FBroHsRequestContext_GetGlobalContext());

    }

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 是否为全局 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty ()) return false;
        @ return (FBroHsRequestContext_IsGlobal(m_class));
    }

    方法 创建 <公开>
    参数 请求环境配置 <类型 = FBrowser_请求环境配置>
    {
        @ Set(FBroHsRequestContext_CreateContext(@<请求环境配置>.ToFBroData()));

    }

    方法 创建_其他 <公开>
    参数 其他请求环境 <类型 = 类_FBrowser_请求环境>
    {
        @ if(@<其他请求环境>.IsEmpty() || !IsEmpty()) return;
        @ FBroHsRequestContext_CreateContextFromOther(@<其他请求环境>.m_class);
    }

    方法 是否相同 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 其他请求环境 <类型 = 类_FBrowser_请求环境>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsRequestContext_IsSame(m_class,@<其他请求环境>.m_class);
    }

    方法 是否为分享 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 其他请求环境 <类型 = 类_FBrowser_请求环境>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsRequestContext_IsSharingWith(m_class,@<其他请求环境>.m_class);

    }

    方法 取缓存路径 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsRequestContext_GetCachePath(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取Cookie管理器 <公开 类型 = 类_FBrowser_Cookie管理器 @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) return @dt<类_FBrowser_Cookie管理器>(FBroHsRequestContext_GetCookieManager(m_class));
        @ return @dt<类_FBrowser_Cookie管理器>();


    }

    方法 置首选项 <公开 类型 = 文本型 注释 = "SetPreference" @禁止流程检查 = 真>
    参数 设置值 <类型 = 类_FBrowser_值>
    参数 名称 <类型 = 文本型>
    参数 错误文本 <类型 = 文本型 注释 = "返回错误文本">
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbroerror=FBroString_Creat("");
        @ bool retbool=FBroHsRequestContext_SetPreference(m_class,@<名称>.GetText(),@<设置值>.m_class,fbroerror);
        @ @<错误文本>=FBroUnit::FBroStringToCWString(fbroerror);
        @ return retbool;


    }

    方法 VIP_高级_载入插件路径 <公开 注释 = "VIP功能，需赞助后才能使用，异步载入已经解压的插件，在全局环境中即为全局，在独立环境中即为独立，载入后未隐藏模式插件管理页不会展示出来" @禁止流程检查 = 真>
    参数 插件路径 <类型 = 文本型 注释 = "要载入的插件所在路径">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPRequestContext_LoadExtension(m_class.get(),@<插件路径>.GetText());
    }

    方法 VIP_高级_安装CRX插件包 <公开 注释 = "VIP功能，需赞助后才能使用，异步安装CRX插件包，在全局环境中即为全局，在独立环境中即为独立，安装完成后会在插件管理页中展示出来，"
