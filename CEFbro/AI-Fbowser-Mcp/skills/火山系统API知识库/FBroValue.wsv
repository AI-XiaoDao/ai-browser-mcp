<火山程序 类型 = "通常" 版本 = 1 />

包 FBrowser.值 <注释 = "浏览器各数据类型合集" "">

类 类_FBrowser_值转换 <公开 @全局类 = 真>
{
    方法 FBrowser_数据到字节集 <公开 静态 类型 = 类_FBrowser_字节集 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ return @dt<类_FBrowser_字节集>(FBroHsBinaryValue_Create((void *)@<数据指针>,@<数据大小>));
    }

    方法 FBrowser_字节集到字节集 <公开 静态 类型 = 类_FBrowser_字节集 注释 = "火山的字节集到cef字节集" @禁止流程检查 = 真>
    参数 字节集 <类型 = 字节集类>
    {
        变量 ptr <类型 = 变整数>
        变量 size <类型 = 整数>
        ptr = 字节集.取字节集指针 ()
        size = 字节集.取字节集长度 ()
        返回 (FBrowser_数据到字节集 (ptr, size))
    }

    方法 FBrowser_文本到字节集 <公开 静态 类型 = 类_FBrowser_字节集 注释 = "火山文本到cef字节集" @禁止流程检查 = 真>
    参数 文本 <类型 = 文本型>
    {
        变量 temp <类型 = 字节集类>
        temp = 文本到字节集 (文本)
        返回 (FBrowser_字节集到字节集 (temp))
    }

    #
}

