    参数 存取器标识ID <类型 = 长整数类 注释 = "创建成功返回创建的存取器标识ID，与事件中的第一个参数标识ID一一对应" @默认值 = 空对象>
    参数 拦截器标识ID <类型 = 长整数类 注释 = "创建成功返回创建的拦截器标识ID，与事件中的第一个参数标识ID一一对应" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<存取器回调>.GetPtr(),V8AccessorType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));
        @ _FBRO_CHECK_EVENT_TYPE(@<拦截器回调>.GetPtr(),V8InterceptorType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsV8Accessor> tempV8Accessor = static_cast<FBroHsV8Accessor*>(@<存取器回调>.GetPtr());
        @ CefRefPtr<FBroHsV8Interceptor> tempV8Interceptor = static_cast<FBroHsV8Interceptor*>(@<拦截器回调>.GetPtr());
        @ return @dt<类_FBrowser_V8值>(FBroHsV8Value_CreateObject(tempV8Accessor,tempV8Interceptor,@<存取器标识ID.值>,@<拦截器标识ID.值>));


    }

