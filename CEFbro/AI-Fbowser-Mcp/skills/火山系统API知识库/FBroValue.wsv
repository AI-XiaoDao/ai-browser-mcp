    参数 函数名 <类型 = 文本型>
    参数 处理回调 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_V8处理程序”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 处理回调标识ID <类型 = 长整数类 注释 = "创建成功返回创建的处理回调标识ID，与事件中的第一个参数标识ID一一对应">
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<处理回调>.GetPtr(),V8HandlerType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsV8Handler> callback = static_cast<FBroHsV8Handler*>(@<处理回调>.GetPtr());
        @ return @dt<类_FBrowser_V8值>(FBroHsV8Value_CreateFunction(@<函数名>.GetText(),callback,@<处理回调标识ID.值>));


    }

