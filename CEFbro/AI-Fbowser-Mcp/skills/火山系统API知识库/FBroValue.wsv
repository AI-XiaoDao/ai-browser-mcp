    方法 复制 <公开 类型 = 类_FBrowser_字节集 @禁止流程检查 = 真>
    {

        变量 tempdata <类型 = 类_FBrowser_字节集>
        @ if(IsEmpty ()) return @<tempdata>;
        @ @<tempdata>.set(FBroHsBinaryValue_Copy(m_class));
        返回 (tempdata)
    }

    方法 取大小 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ if(IsEmpty ()) return 0;
        @ return FBroHsBinaryValue_GetSize(m_class);
    }

    方法 取值 <公开 @禁止流程检查 = 真>
    参数 缓存指针 <类型 = 变整数 注释 = "存放数据的指针">
    参数 缓存大小 <类型 = 整数>
    参数 偏移量 <类型 = 整数>
    {
        @ if(IsEmpty ()) return;
        @ FBroHsBinaryValue_GetData(m_class,(void *)@<缓存指针>,@<缓存大小>,@<偏移量>);

    }

    方法 取文本 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(!IsEmpty ()) return FBroUnit::FBroStringToCWString(FBroHsBinaryValue_GetString(m_class));

    }

    方法 取字节集 <公开 类型 = 字节集类>
    {
        @ if(IsEmpty ()) return @dt<字节集类>();
        变量 size <类型 = 整数>
        变量 datapoint <类型 = 变整数>
        变量 tempret <类型 = 字节集类>
        size = 取大小 ()
        如果真 (size > 0)
        {
            datapoint = 分配内存 (size)
            取值 (datapoint, size, 0)
            tempret = 指针到字节集 (datapoint, size)
            释放内存 (datapoint)

        }

        返回 (tempret)


    }
}

