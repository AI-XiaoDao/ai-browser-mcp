    方法 取碎片基础地址 <公开 类型 = 文本型 注释 = "Return the base URL that the fragment came from. This value is used for"
            注释 = "resolving relative URLs and may be empty." @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsDragData_GetFragmentBaseURL(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取文件名 <公开 类型 = 文本型 注释 = "Return the name of the file being dragged out of the browser window" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsDragData_GetFileName(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);


    }

    方法 置链接地址 <公开 注释 = "Set the link URL that is being dragged." @禁止流程检查 = 真>
    参数 地址 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetLinkURL(m_class,@<地址>.GetText());

    }

    方法 置链接标题 <公开 注释 = "Set the title associated with the link being dragged" @禁止流程检查 = 真>
    参数 标题 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetLinkTitle(m_class,@<标题>.GetText());

    }

    方法 置关联数据 <公开 注释 = "Set the metadata associated with the link being dragged" @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetLinkMetadata(m_class,@<数据>.GetText());

    }

    方法 置碎片文本 <公开 注释 = "Set the plain text fragment that is being dragged" @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetFragmentText(m_class,@<数据>.GetText());

    }

    方法 置碎片源码 <公开 注释 = "Set the text/html fragment that is being dragged" @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetFragmentHtml(m_class,@<数据>.GetText());

    }

    方法 置碎片基础地址 <公开 注释 = "Set the base URL that the fragment came from" @禁止流程检查 = 真>
    参数 地址 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_SetFragmentBaseURL(m_class,@<地址>.GetText());

    }

    方法 增加文件 <公开 注释 = "Add a file that is being dragged into the webview" @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 显示名 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroHsDragData_AddFile(m_class,@<文件路径>.GetText(),@<显示名>.GetText());


    }

    方法 取图片 <公开 类型 = 类_FBrowser_图片 注释 = "Get the image representation of drag data. May return NULL if no image"
            注释 = "representation is available." @禁止流程检查 = 真>
    {
        @ return IsEmpty()? @dt<类_FBrowser_图片>() : @dt<类_FBrowser_图片>(FBroHsDragData_GetImage(m_class));

    }

    方法 取图片坐标 <公开 类型 = FBrowser_位置 注释 = "Get the image hotspot (drag start location relative to image dimensions)." @禁止流程检查 = 真>
    {
        变量 rettemp <类型 = FBrowser_位置>
        @ if(!IsEmpty()) {FBroHsDragData_GetImageHotspot(m_class,@<rettemp>.ToFBroData()); @<rettemp>.ToHsData();}
        返回 (rettemp)
    }

    方法 是否有图片 <公开 类型 = 逻辑型 注释 = "Returns true if an image representation of drag data is available" @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FBroHsDragData_HasImage(m_class);

    }

    #
}

类 类_FBrowser_共享内存数据 <公开 注释 = "CefSharedMemoryRegion" @输出名 = "FBroSharedMemoryRegion" "">
{

    # @begin
    # <> <include>
    # CefRefPtr<CefSharedMemoryRegion> m_class;
    # inline_ @sn<current_class> (CefRefPtr<CefSharedMemoryRegion> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL_P IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set(CefRefPtr<CefSharedMemoryRegion> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 取数据大小 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return IsEmpty()? 0 : FBroHsSharedMemoryRegion_Size(m_class);
    }

    方法 取数据 <公开 类型 = 字节集类 @禁止流程检查 = 真>
    {
        变量 size <类型 = 整数>
        变量 tempret <类型 = 字节集类>
        size = 取数据大小 ()
        如果真 (size > 0)
        {
            变量 datapoint <类型 = 变整数>
            datapoint = 分配内存 (size)
            @ FBroHsSharedMemoryRegion_Memory(m_class,(void *)@<datapoint>,@<size>);
            tempret = 指针到字节集 (datapoint, size)
            释放内存 (datapoint)

        }
        返回 (tempret)

    }

    #
}
