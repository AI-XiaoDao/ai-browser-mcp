类 ______客户端通用函数 <公开 注释 = "支持 websocket tcp tcppull" 注释 = "这些函数必须再客户端创建后调用" 折叠 @全局类 = 真>
{
    方法 HPClient_SetUserDataPVOID <静态 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    参数 附加数据 <类型 = 变整数>
    {
        @ HPClient_SetUserDataPVOID((void*)@<通讯句柄>,@<附加数据索引>,(void*)@<附加数据>)
        // VOID __HP_CALL HPClient_WebsocketSetUserDataPVOID(void* pClient, int nIndex, void* pData);
    }

    方法 HPClient_GetUserDataPVOID <静态 类型 = 变整数 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    {
        // VOID* __HP_CALL HPClient_WebsocketGetUserDataPVOID(void* pClient, int nIndex);
        @ (@dt<变整数>) HPClient_GetUserDataPVOID((void*)@<通讯句柄>,@<附加数据索引>)

    }

    方法 HPClient_SetUserData <静态 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    参数 附加数据指针 <类型 = 变整数>
    参数 附加数据大小 <类型 = 整数>
    {
        // VOID __HP_CALL HPClient_WebsocketSetUserData(void* pClient, int nIndex, void* pData, int nDataSize);
        @ HPClient_SetUserData((void*)@<通讯句柄>,@<附加数据索引>,(void*)@<附加数据指针>,@<附加数据大小>)
    }

    方法 HPClient_GetUserDataSize <静态 类型 = 整数 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    {
        @ (INT)HPClient_GetUserDataSize((void*)@<通讯句柄>,@<附加数据索引>)
        // size_t __HP_CALL HPClient_WebsocketGetUserDataSize(void* pClient, int nIndex);
    }

    方法 HPClient_GetUserData <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    {
        @ (@dt<变整数>) HPClient_GetUserData((void*)@<通讯句柄>,@<附加数据索引>)
        // void* __HP_CALL HPClient_WebsocketGetUserData(void* pClient, int nIndex);
    }

    方法 客户端_置附加数据指针 <公开 静态 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    参数 附加数据 <类型 = 变整数>
    {
        HPClient_SetUserDataPVOID (通讯句柄, 附加数据索引, 附加数据)
    }

    方法 客户端_取附加数据指针 <公开 静态 类型 = 变整数 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    {
        返回 (HPClient_GetUserDataPVOID (通讯句柄, 附加数据索引))
    }

    方法 客户端_置附加数据字节集 <公开 静态 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    参数 附加数据 <类型 = 字节集类>
    {
        HPClient_SetUserData (通讯句柄, 附加数据索引, 附加数据.取字节集指针 (), 附加数据.取字节集长度 ())
    }

    方法 客户端_取附加数据字节集 <公开 静态 类型 = 字节集类 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据索引 <类型 = 整数 注释 = "总共可以设置30个 从0 - 29">
    {
        变量 附加数据指针 <类型 = 变整数>
        变量 附加数据长度 <类型 = 整数>
        附加数据长度 = HPClient_GetUserDataSize (通讯句柄, 附加数据索引)
        附加数据指针 = HPClient_GetUserData (通讯句柄, 附加数据索引)
        返回 (指针到字节集 (附加数据指针, 附加数据长度))

    }
}

