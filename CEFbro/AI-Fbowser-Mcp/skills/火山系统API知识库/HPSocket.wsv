类 ______HPTcpPullAgent_全局函数 <公开 @全局类 = 真>
{
    变量 监听器 <静态 类型 = ______HPTcpPullAgent_监听器>

    方法 _HPTcpPullAgent_Create <静态 类型 = 变整数 @嵌入式方法 = "">
    参数 监听器句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)HPTcpPullAgent_Create((void*)@<监听器句柄>)
    }

    方法 HPTcpPullAgent_创建 <公开 静态 类型 = 变整数>
    {
        返回 (_HPTcpPullAgent_Create (监听器.成员_监听器句柄))
    }

    方法 HPTcpPullAgent_销毁 <公开 静态 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    {
        @ HPTcpPullAgent_Destory((void*)@<连接句柄>)

    }

    方法 HPTcpPullAgent_启动 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 绑定地址 <类型 = 文本型>
    参数 是否异步 <类型 = 逻辑型>
    {
        @ HPTcpPullAgent_Start((void*)@<连接句柄>, GetMbsText(@<绑定地址>, CVolMem(), NULL), @<是否异步>)


    }

    方法 HPTcpPullAgent_连接 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 地址 <类型 = 文本型>
    参数 端口 <类型 = 整数>
    参数 输出_连接ID <类型 = 变整数>
    {
        @ HPTcpPullAgent_Connect( (void*)@<连接句柄>, GetMbsText(@<地址>, CVolMem(), NULL), @<端口>, (ULONG_PTR*)&@<输出_连接ID>)

    }

    方法 HPTcpPullAgent_断开连接 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 是否强制断开 <类型 = 逻辑型 @默认值 = 真>
    {
        @ HPTcpPullAgent_DisConnect((void*)@<连接句柄>, (ULONG_PTR)@<连接ID>, @<是否强制断开>)
    }

    方法 HPTcpPullAgent_停止 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    {
        @ HPTcpPullAgent_Stop((void*)@<连接句柄>)
    }

    方法 _HPTcpPullAgent_取本地地址 <静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    参数 端口 <类型 = 整数>
    {
        @ HPTcpPullAgent_GetLocalAddress((void*)@<连接句柄>,(ULONG_PTR)@<连接ID>,( void* )@<缓冲区指针>,&@<缓冲区大小>,&@<端口>)
    }

    方法 HPTcpPullAgent_取本地地址 <公开 静态 类型 = 文本型 折叠>
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        变量 返回文本 <类型 = 文本型>
        变量 缓冲区 <类型 = 字节集类>
        变量 缓冲区大小 <类型 = 整数>
        变量 端口 <类型 = 整数>
        缓冲区 = 取空白字节集 (50)
        缓冲区大小 = 缓冲区.取字节集长度 ()
        如果 (_HPTcpPullAgent_取本地地址 (连接句柄, 连接ID, 缓冲区.取字节集指针 (), 缓冲区大小, 端口))
        {
            返回文本 = 多字节到文本 (缓冲区)
            返回文本 = 返回文本 + ":" + 到文本 (端口)
        }
        返回 (返回文本)
    }

    方法 HPTcpPullAgent_置连接附加数据 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 附加数据 <类型 = 变整数>
    {
        @ HPTcpPullAgent_SetConnectionExtra((void*)@<连接句柄>, (ULONG_PTR)@<连接ID>,(void*)@<附加数据>)
    }

    方法 HPTcpPullAgent_取连接附加数据 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        @ (INT_P)HPTcpPullAgent_GetConnectionExtra((void*)@<连接句柄>, (ULONG_PTR)@<连接ID>)

    }

    方法 HPTcpPullAgent_取错误文本 <公开 静态 类型 = 文本型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    {
        @ CVolString( HPTcpPullAgent_GetLastErrorText((void*)@<连接句柄>) )
    }

    方法 HPTcpPullAgent_取当前连接数 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    {
        @ HPTcpPullAgent_GetConnectionCount((void*)@<连接句柄>) 

    }

    方法 _HPTcpPullAgent_抓取数据 <静态 类型 = 整数 返回值注释 = "返回0表示成功" @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    {
        @ HPTcpPullAgent_Fetch((void*)@<连接句柄>, (ULONG_PTR)@<连接ID>, (void*)@<缓冲区指针>,@<缓冲区大小>)
    }

    方法 HPTcpPullAgent_抓取数据 <公开 静态 类型 = 字节集类 返回值注释 = "返回0表示成功">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 抓取大小 <类型 = 整数>
    {
        变量 缓冲区 <类型 = 字节集类>
        缓冲区.重分配字节集 (抓取大小)
        如果 (_HPTcpPullAgent_抓取数据 (连接句柄, 连接ID, 取字节集指针 (缓冲区), 抓取大小) == 0)
        {
            返回 (缓冲区)
        }
        缓冲区.清空字节集 ()
        返回 (缓冲区)






    }

    方法 HPTcpPullAgent_发送指针数据 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 要发送的数据指针 <类型 = 变整数>
    参数 要发送的数据大小 <类型 = 整数>
    {
        @ HPTcpPullAgent_Send((void*)@<连接句柄>, (ULONG_PTR)@<连接ID>, (const BYTE*)@<要发送的数据指针>, @<要发送的数据大小>)
    }

    方法 HPTcpPullAgent_发送 <公开 静态 类型 = 逻辑型 注释 = "" 注释 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 要发送的数据 <类型 = 字节集类>
    {
        返回 (HPTcpPullAgent_发送指针数据 (连接句柄, 连接ID, 要发送的数据.取字节集指针 (), 要发送的数据.取字节集长度 ()))


    }

    #
}

