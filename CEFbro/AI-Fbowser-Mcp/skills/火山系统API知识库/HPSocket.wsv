    方法 服务器_取连接地址 <公开 静态 类型 = 文本型 注释 = "获取客户端连接地址 例如 127.0.0.1:19730" 折叠>
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 "">
    {
        变量 端口 <类型 = 短整数>
        变量 IP <类型 = 文本型>
        变量 缓冲区长度 <类型 = 整数>
        缓冲区长度 = 20
        @ char buffer[20] = {0};
        @ HPServer_GetRemoteAddress((void*)@<连接句柄>,(ULONG_PTR)@<连接ID>,(char*)buffer,&@<缓冲区长度>,&(USHORT)@<端口>);
        @ @<IP> = buffer;
        IP = IP + ":"
        IP = IP + 到文本 (端口)
        返回 (IP)

    }

    方法 服务器_断开客户 <公开 静态 类型 = 逻辑型 注释 = ";" 折叠 @嵌入式方法 = "">
    参数 连接句柄 <类型 = 变整数>
    参数 连接ID <类型 = 整数 "">
    {
        @ HPServer_Disconnect ((void*)@<连接句柄>,@<连接ID>);

    }

    #
}

