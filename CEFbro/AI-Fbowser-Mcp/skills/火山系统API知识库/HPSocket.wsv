类 ______客户端监听器_Http_Websocket <折叠>
{
    变量 监听器句柄 <公开 类型 = 变整数>

    方法 类_初始化
    {
        监听器句柄 = Listener_CreateHttpClient ()
        // 调试输出 ("______HPHttp客户端监听器  构造")
    }

    方法 类_清理
    {
        Listener_DestroyHttpClient (监听器句柄)
        // 调试输出 ("______HPHttp客户端监听器  析构")
    }

    方法 Listener_CreateHttpClient <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    {
        @ (@dt<变整数>) Listener_CreateHttpClient()
    }

    方法 Listener_DestroyHttpClient <静态 折叠 @嵌入式方法 = "">
    参数 参数监听器句柄 <类型 = 变整数>
    {
        @ Listener_DestroyHttpClient((void*)@<参数监听器句柄>)

    }
}

类 ______客户端_Http_WebSocket_基础函数 <公开 折叠 @全局类 = 真>
{
    变量 监听器 <静态 类型 = ______客户端监听器_Http_Websocket>

    方法 "//客户端_websocket_挂接事件" <公开 静态 注释 = "必须在客户端创建前" 折叠 @嵌入式方法 = "">
    参数 事件类 <类型 = 客户端事件类_WebSocket>
    {

    }

    方法 _HPClient_Websocket_Create <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 事件监听器句柄 <类型 = 变整数>
    参数 是否异步 <类型 = 逻辑型>
    参数 要连接的url <类型 = 变整数>
    参数 加密套件 <类型 = 变整数 "">
    {
        @ (@dt<变整数>) HPClient_Websocket_Create( (void*)@<事件监听器句柄>,@<是否异步>,(LPCSTR)@<要连接的url>,(LPCSTR)@<加密套件>)

    }

    方法 客户端_websocket_创建 <公开 静态 类型 = 变整数 返回值注释 = "返回通讯句柄" 折叠 @禁止流程检查 = 真>
    参数 要连接的url <类型 = 文本型>
    参数 是否异步 <类型 = 逻辑型 @默认值 = 假>
    参数 加密套件 <类型 = 文本型 @默认值 = "">
    {

        变量 url <类型 = 字节集类>
        变量 SSLCipherList <类型 = 字节集类>
        url = 文本到多字节 (要连接的url)
        如果 (加密套件 != "")
        {
            SSLCipherList = 文本到多字节 (加密套件)
        }
        返回 (_HPClient_Websocket_Create (监听器.监听器句柄, 是否异步, url.取字节集指针 (), SSLCipherList.取字节集指针 ()))




    }

    方法 _HPClient_WebsocketSetRequestHeader <静态 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 键名称文本指针 <类型 = 变整数>
    参数 键值文本指针 <类型 = 变整数>
    {
        @ HPClient_Websocket_SetRequestHeader((void*)@<通讯句柄>,(LPCSTR)@<键名称文本指针>,(LPCSTR)@<键值文本指针>)

    }

    方法 客户端_websocket_置协议头 <公开 静态 注释 = "请再 客户端_websocket_创建 后使用" 注释 = "并且要再 客户端_websocket_启动之前" 折叠 折叠2>
    参数 通讯句柄 <类型 = 变整数>
    参数 键名称 <类型 = 文本型>
    参数 键值 <类型 = 文本型>
    {
        变量 key <类型 = 字节集类>
        变量 value <类型 = 字节集类>
        key = 文本到多字节 (键名称)
        value = 文本到多字节 (键值)
        _HPClient_WebsocketSetRequestHeader (通讯句柄, key.取字节集指针 (), value.取字节集指针 ())
    }

    方法 客户端_websocket_启动 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_Websocket_Start ((void*)@<通讯句柄>)

    }

    方法 客户端_websocket_停止 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_Websocket_Stop((void*)@<通讯句柄>)
    }

    方法 客户端_websocket_销毁 <公开 静态 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    {
        @ HPClient_Websocket_Destroy ((void*)@<客户端句柄>)
    }

    方法 客户端_websocket_发送字节集 <公开 静态 类型 = 逻辑型 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 要发送的数据 <类型 = 字节集类>
    {
        返回 (_HPClient_Websocket_SendWSMessage (通讯句柄, 2, 要发送的数据.取字节集指针 (), 要发送的数据.取字节集长度 ()))
    }

    方法 客户端_websocket_发送文本 <公开 静态 类型 = 逻辑型>
    参数 通讯句柄 <类型 = 变整数>
    参数 要发送的数据 <类型 = 文本型>
    {
        变量 文本utf8 <类型 = 字节集类>
        文本utf8 = 编码_Unicode转Utf8 (要发送的数据, 取文本长度 (要发送的数据))
        返回 (_HPClient_Websocket_SendWSMessage (通讯句柄, 1, 文本utf8.取字节集指针 (), 文本utf8.取字节集长度 ()))


    }

    方法 客户端_websocket_置超时 <公开 静态 注释 = "只有再异步的时候有用" @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 请求超时 <类型 = 整数>
    参数 连接超时 <类型 = 整数>
    {
        @ HPClient_Websocket_SetTimout((void*)@<通讯句柄>,(DWORD)@<请求超时>,(DWORD)@<连接超时>)

    }

    方法 _HPClient_Websocket_SendWSMessage <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 通讯句柄 <类型 = 变整数>
    参数 操作码 <类型 = 字节 注释 = "1 文本,2 字节集,8 断开连接 9 ping,10 pong">
    参数 要发送数据指针 <类型 = 变整数>
    参数 要发送的数据大小 <类型 = 整数>
    {
        @ BYTE lpszMask[4] = {1,2,3,4};
        @ return HPClient_Websocket_SendWSMessage((void*)@<通讯句柄>,@<操作码>,lpszMask,(const BYTE *)@<要发送数据指针>,@<要发送的数据大小>);
    }
}

