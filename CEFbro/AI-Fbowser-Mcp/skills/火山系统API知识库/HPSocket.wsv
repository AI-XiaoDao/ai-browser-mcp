        @ HPClient_TcpPull_Send( (void*)@<客户端句柄>,(const BYTE* )@<数据指针>,@<数据长度>)

    }

    方法 客户端_TcpPull_发送 <公开 静态 折叠>
    参数 客户端句柄 <类型 = 变整数>
    参数 要发送的数据 <类型 = 字节集类>
    {
        HPClient_TcpPull_Send_ptr (客户端句柄, 要发送的数据.取字节集指针 (), 要发送的数据.取字节集长度 ())


    }

    方法 _HPClient_TcpPull_Fetch <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区长度 <类型 = 整数>
    {
        @ HPClient_TcpPull_Fetch((void*)@<客户端句柄>,(BYTE*)@<缓冲区指针>,@<缓冲区长度>)
    }

    方法 客户端_TcpPull_抓取数据 <公开 静态 类型 = 字节集类 折叠>
    参数 客户端句柄 <类型 = 变整数>
    参数 要抓取的长度 <类型 = 整数>
    {
        变量 缓冲区 <类型 = 字节集类>
        变量 抓取结果 <类型 = 整数>
        缓冲区.分配字节集 (要抓取的长度)
        抓取结果 = _HPClient_TcpPull_Fetch (客户端句柄, 缓冲区.取字节集指针 (), 缓冲区.取字节集长度 ())
        如果 (抓取结果 == 0)
        {
            返回 (缓冲区)
        }

        缓冲区.清空字节集 ()
        如果 (抓取结果 == 1)
        {
            调试输出 ("错误: 客户端_TcpPull_抓取数据 抓取数据过大")
        }

        如果 (抓取结果 == 2)
        {
            调试输出 ("错误: 客户端_TcpPull_抓取数据 客户端句柄 不正确")
        }

        返回 (缓冲区)


    }
}

