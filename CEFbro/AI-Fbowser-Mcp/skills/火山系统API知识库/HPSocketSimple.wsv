        @ HPTcpPullClient_Destory((void* )@<通讯句柄>)
    }

    方法 _HPTcpPullClient_Fetch <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区长度 <类型 = 整数>
    {
        @ HPTcpPullClient_Fetch((void*)@<客户端句柄>,(BYTE*)@<缓冲区指针>,@<缓冲区长度>)
    }

    方法 _HPTcpPullClient_Peek <静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区长度 <类型 = 整数>
    {
        @ HPTcpPullClient_Peek((void*)@<客户端句柄>,(BYTE*)@<缓冲区指针>,@<缓冲区长度>)
    }

    方法 抓取数据 <公开 静态 类型 = 整数 返回值注释 = "0 成功" 返回值注释 = "1 抓取数据过大" 返回值注释 = "2 客户端句柄 不正确">
    参数 客户端句柄 <类型 = 变整数>
    参数 要抓取的长度 <类型 = 整数>
    参数 用来保存抓取到的数据 <类型 = 字节集类>
    {
        变量 状态 <类型 = 整数>
        用来保存抓取到的数据 = 取空白字节集 (要抓取的长度)
        状态 = _HPTcpPullClient_Fetch (客户端句柄, 用来保存抓取到的数据.取字节集指针 (), 用来保存抓取到的数据.取字节集长度 ())
        如果 (状态 != 0)
        {
            用来保存抓取到的数据.清空字节集 ()
        }
        返回 (状态)


    }

    方法 查看数据 <公开 静态 类型 = 整数 返回值注释 = "0 成功" 返回值注释 = "1 抓取数据过大" 返回值注释 = "2 客户端句柄 不正确" 折叠>
    参数 客户端句柄 <类型 = 变整数>
    参数 要抓取的长度 <类型 = 整数>
    参数 用来保存抓取到的数据 <类型 = 字节集类>
    {
        变量 状态 <类型 = 整数>
        用来保存抓取到的数据 = 取空白字节集 (要抓取的长度)
        状态 = _HPTcpPullClient_Peek (客户端句柄, 用来保存抓取到的数据.取字节集指针 (), 用来保存抓取到的数据.取字节集长度 ())
        如果 (状态 != 0)
        {
            用来保存抓取到的数据.清空字节集 ()
        }
        返回 (状态)


    }
}

