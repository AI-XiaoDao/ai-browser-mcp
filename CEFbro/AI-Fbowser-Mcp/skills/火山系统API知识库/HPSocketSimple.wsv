    }

    方法 停止 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPServer_Stop( (void*)@<通讯句柄>)
    }

    方法 发送指针 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ HPServer_Send( (void*)@<通讯句柄>, (ULONG_PTR)@<连接ID>, (const BYTE*) @<数据指针>, @<数据大小>)
    }

    方法 发送 <公开 静态 类型 = 逻辑型 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 要发送的数据 <类型 = 字节集类>
    {
        返回 (发送指针 (通讯句柄, 连接ID, 取字节集指针 (要发送的数据), 取字节集长度 (要发送的数据)))
    }

    方法 _HPServer_GetRemoteAddress <静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    参数 端口 <类型 = 整数>
    {
        @ HPServer_GetRemoteAddress ( (void*)@<通讯句柄>, (ULONG_PTR)@<连接ID>,( char*)@<缓冲区指针>,&@<缓冲区大小>,(USHORT*)&@<端口>)
    }

    方法 取客户地址 <公开 静态 类型 = 文本型 折叠>
    参数 通讯句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        变量 缓冲区 <类型 = 字节集类>
        变量 缓冲区大小 <类型 = 整数>
        变量 端口 <类型 = 整数>
        缓冲区 = 取空白字节集 (50)
        缓冲区大小 = 50
        端口 = 0
        如果 (_HPServer_GetRemoteAddress (通讯句柄, 连接ID, 取字节集指针 (缓冲区), 缓冲区大小, 端口))
        {
            变量 返回内容 <类型 = 文本型>
            返回内容 = 多字节到文本 (缓冲区)
            返回内容 = 返回内容 + ":" + 到文本 (端口)
            返回 (返回内容)
        }
        返回 ("")

    }

    方法 断开连接 <公开 静态 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        @ HPServer_Disconnect( (void*)@<通讯句柄>, (ULONG_PTR)@<连接ID>)


    }
}

类 ______TCP客户端函数_模板 <基础类 = ______客户端函数_模板 折叠 @模板基础类 = 真>
{
    方法 置通讯缓冲区大小 <公开 静态 注释 = "/* 设置通信数据缓冲区大小（根据平均通信数据包大小调整设置，通常设置为：(N * 1024) - sizeof(TBufferObj)） */" 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    {
        @ HPTcpClient_SetSocketBufferSize( (void* )@<通讯句柄>,@<缓冲区大小>)
    }

    方法 取通讯缓冲区大小 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPTcpClient_GetSocketBufferSize( (void* )@<通讯句柄>)
    }

    方法 置心跳时间 <公开 静态 注释 = "/* 设置正常心跳包间隔（毫秒，0 则不发送心跳包，默认：60 * 1000） */" 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 时间 <类型 = 整数>
    {
        @ HPTcpClient_SetKeepAliveTime( (void* )@<通讯句柄>,@<时间>)
    }

    方法 取心跳时间 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPTcpClient_GetKeepAliveTime( (void* )@<通讯句柄>)
    }

    方法 置异常心跳间隔 <公开 静态 注释 = "/* 设置异常心跳包间隔（毫秒，0 不发送心跳包，，默认：20 * 1000，如果超过若干次 [默认：WinXP 5 次, Win7 10 次] 检测不到心跳确认包则认为已断线） */" 折叠
            @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 时间 <类型 = 整数>
    {
        @ HPTcpClient_SetKeepAliveInterval( (void* )@<通讯句柄>,@<时间>)
    }

    方法 取异常心跳间隔 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPTcpClient_GetKeepAliveInterval( (void* )@<通讯句柄>)

    }

    #
    #
    #
    #
}

类 ______TCP服务器函数_模板 <基础类 = ______服务器函数_模板 折叠 @模板基础类 = 真>
{
    方法 _HPTcpServer_Setter <静态 类型 = 整数 折叠 @输出名 = "HPTcpServer_Setter" @禁止流程检查 = 真>
    参数 服务器句柄 <类型 = 变整数>
    参数 类型 <类型 = 整数>
    参数 值 <类型 = 整数>
    {
        @ return HPTcpServer_Setter((void*)@<服务器句柄>,@<类型>,(void*)&@<值>,4);
    }

    方法 置等候队列大小 <公开 静态 注释 = "/* 设置监听 Socket 的等候队列大小（根据并发连接数量调整设置） */" 注释 = "//#define TCPSERVER_SG_TYPE_SocketListenQueue  1" 折叠>
    参数 服务器句柄 <类型 = 变整数>
    参数 队列大小 <类型 = 整数>
    {
        _HPTcpServer_Setter (服务器句柄, 1, 队列大小)
    }

    方法 置预投递数量 <公开 静态 注释 = "/* 设置 Accept 预投递数量（根据负载调整设置，Accept 预投递数量越大则支持的并发连接请求越多） */"
            注释 = "#define TCPSERVER_SG_TYPE_AcceptSocketCount  2" 折叠>
    参数 服务器句柄 <类型 = 变整数>
    参数 数量 <类型 = 整数>
    {
        _HPTcpServer_Setter (服务器句柄, 2, 数量)
    }

    方法 置通讯缓冲区大小 <公开 静态 注释 = "/* 设置通信数据缓冲区大小（根据平均通信数据包大小调整设置，通常设置为 1024 的倍数） */"
            注释 = "#define TCPSERVER_SG_TYPE_SocketBufferSize   3" 折叠>
    参数 服务器句柄 <类型 = 变整数>
    参数 大小 <类型 = 整数>
    {
        _HPTcpServer_Setter (服务器句柄, 3, 大小)
    }

    方法 置心跳间隔 <公开 静态 注释 = "/* 设置正常心跳包间隔（毫秒，0 则不发送心跳包，默认：60 * 1000） */" 注释 = "#define TCPSERVER_SG_TYPE_KeepAliveTime   4" 折叠 折叠2>
    参数 服务器句柄 <类型 = 变整数>
    参数 大小 <类型 = 整数>
    {
        _HPTcpServer_Setter (服务器句柄, 4, 大小)
    }

    方法 置异常心跳间隔 <公开 静态 注释 = "/* 设置异常心跳包间隔（毫秒，0 不发送心跳包，，默认：20 * 1000，如果超过若干次"
            注释 = "[默认：WinXP 5 次, Win7 10 次] 检测不到心跳确认包则认为已断线） */" 注释 = "#define TCPSERVER_SG_TYPE_KeepAliveInterval  5" 折叠>
    参数 服务器句柄 <类型 = 变整数>
    参数 大小 <类型 = 整数>
    {
        _HPTcpServer_Setter (服务器句柄, 5, 大小)
    }

    # //=====

    方法 _HPTcpServer_Getter <静态 类型 = 整数 @输出名 = "HPTcpServer_Getter" @禁止流程检查 = 真>
    参数 服务器句柄 <类型 = 变整数>
    参数 类型 <类型 = 整数>
    参数 值 <类型 = 整数>
    {
        @ return HPTcpServer_Getter((void*)@<服务器句柄>,@<类型>,(void*)&@<值>,4);
    }

    方法 取等候队列大小 <公开 静态 类型 = 整数 注释 = "/* 设置监听 Socket 的等候队列大小（根据并发连接数量调整设置） */"
            注释 = "//#define TCPSERVER_SG_TYPE_SocketListenQueue  1" 折叠>
    参数 服务器句柄 <类型 = 变整数>
    {
