    方法 _HPTcpPullServer_Create <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 监听器句柄 <类型 = 变整数>
    参数 是否SSL <类型 = 逻辑型>
    {
        @ (@dt<变整数>) HPTcpPullServer_Create( (void*)@<监听器句柄> ,@<是否SSL>)
    }

    方法 创建 <公开 静态 类型 = 变整数 返回值注释 = "返回 通讯句柄">
    参数 是否SSL <类型 = 逻辑型 @默认值 = 假>
    {
        返回 (_HPTcpPullServer_Create (监听器.监听器句柄, 是否SSL))
    }

    方法 销毁 <公开 静态 @嵌入式方法 = "">
    参数 服务器句柄 <类型 = 变整数>
    {
        @ HPTcpPullServer_Destory((void*)@<服务器句柄>)
    }

    方法 "//置不验证证书" <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 服务器句柄 <类型 = 变整数>
    {
        @ HPTcpPullServer_SetSSLContext((void*)@<服务器句柄>,false,0, NULL,NULL,NULL,NULL)
    }

    方法 _HPTcpPullServer_Fetch <静态 类型 = 整数 @嵌入式方法 = "">
    参数 服务器句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    {
        @ HPTcpPullServer_Fetch( (void*)@<服务器句柄>,(ULONG_PTR) @<连接ID>,(BYTE* ) @<缓冲区指针>,@<缓冲区大小>)
    }

    方法 _HPTcpPullServer_Peek <静态 类型 = 整数 @嵌入式方法 = "">
    参数 服务器句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    {
        @ HPTcpPullServer_Peek( (void*)@<服务器句柄>,(ULONG_PTR) @<连接ID>,(BYTE* ) @<缓冲区指针>,@<缓冲区大小>)

    }

    方法 抓取数据 <公开 静态 类型 = 整数 返回值注释 = "0表示成功" 折叠 "">
    参数 服务器句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 抓取数据大小 <类型 = 整数>
    参数 用来保存抓取的数据 <类型 = 字节集类>
    {
        变量 返回值 <类型 = 整数>
        用来保存抓取的数据.分配字节集 (抓取数据大小)
        用来保存抓取的数据.重分配字节集 (抓取数据大小)
        返回值 = _HPTcpPullServer_Fetch (服务器句柄, 连接ID, 用来保存抓取的数据.取字节集指针 (), 抓取数据大小)
        如果 (返回值 != 0)
        {
            用来保存抓取的数据.清空字节集 ()
        }
        返回 (返回值)

    }

