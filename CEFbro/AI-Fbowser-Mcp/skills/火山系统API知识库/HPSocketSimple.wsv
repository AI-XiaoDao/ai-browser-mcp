<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "此模块的源码已经丢失" @文档 = "category = \"开源库.hpsocket\"">

类 ______HP套接字函数_模板 <折叠 @模板基础类 = 真 @视窗.外部头文件 = "HPSocketSimple\\HPSocketSimpleTool.h"
        @视窗.外部库.win32 = "HPSocketSimple\\HPSocketSimpleToolx86.lib" @视窗.附属文件.win32 = "HPSocketSimple\\HPSocketSimpleToolx86.dll"
        @视窗.外部库.x64 = "HPSocketSimple\\HPSocketSimpleToolx64.lib" @视窗.附属文件.x64 = "HPSocketSimple\\HPSocketSimpleToolx64.dll">
{
    方法 "//置套接字属性" <公开 静态 折叠 @嵌入式方法 = "">
    参数 套接字句柄 <类型 = 变整数>
    参数 等级 <类型 = 整数>
    参数 名称 <类型 = 整数>
    参数 值指针 <类型 = 变整数>
    参数 值指针大小 <类型 = 整数>
    {
        @ HPSocket_SetSocketOption( (SOCKET)@<套接字句柄>, @<等级>, @<名称>, (LPVOID)@<值指针>, @<值指针大小>)
    }

    方法 "//置不粘包" <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 套接字句柄 <类型 = 变整数>
    {
        @  const char chOpt=1;
        @  int nErr = HPSocket_SetSocketOption((SOCKET)@<套接字句柄>,   IPPROTO_TCP,   TCP_NODELAY,   (LPVOID)&chOpt,   sizeof(char));   
        @ return nErr;
    }

    #
}

类 ______客户端函数_模板 <基础类 = ______HP套接字函数_模板 折叠 @模板基础类 = 真>
{

    # bool FUCTIONTYPE  HPClient_Start(void* pClient, const char* lpszIP, unsigned short uPort, bool bAsyncConnect);
    # bool FUCTIONTYPE  HPClient_Stop(void* pClient);
    # bool FUCTIONTYPE  HPClient_Send(void* pClient, const BYTE* pBuffer, int iLength);

    方法 启动 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 IP地址 <类型 = 文本型>
    参数 端口 <类型 = 短整数>
    参数 是否异步 <类型 = 逻辑型 @默认值 = 真>
    {
        @ HPClient_Start((void*)@<通讯句柄>,GetMbsText(@<IP地址>, CVolMem(), NULL),(unsigned short)@<端口>,@<是否异步>)
    }

    方法 停止 <公开 静态 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    {
        @ HPClient_Stop((void*)@<客户端句柄>)

    }

    方法 发送指针数据 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据长度 <类型 = 整数>
    {
        @ HPClient_Send( (void*)@<客户端句柄>,(const BYTE* )@<数据指针>,@<数据长度>)
    }

    方法 发送 <公开 静态 类型 = 逻辑型 折叠>
    参数 客户端句柄 <类型 = 变整数>
    参数 要发送的数据 <类型 = 字节集类>
    {
        返回 (发送指针数据 (客户端句柄, 要发送的数据.取字节集指针 (), 要发送的数据.取字节集长度 ()))
    }

    方法 是否加密 <公开 静态 类型 = 逻辑型 注释 = "检测套接字是否经过 ssl 加密" 折叠 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_IsSecure((void*)@<通讯句柄>)
    }

    方法 加密设置 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    参数 验证模式 <类型 = 整数 注释 = "//SSL_VM_NONE = 0x00, // SSL_VERIFY_NONE" 注释 = "//SSL_VM_PEER = 0x01, // SSL_VERIFY_PEER"
            注释 = "//SSL_VM_FAIL_IF_NO_PEER_CERT = 0x02, // SSL_VERIFY_FAIL_IF_NO_PEER_CERT"
            注释 = "//SSL_VM_CLIENT_ONCE = 0x04, // SSL_VERIFY_CLIENT_ONCE" @默认值 = 0>
    参数 证书 <类型 = 文本型 注释 = "当内存加载为真时  这个必须是证书字符串，否则填写证书全路径" @默认值 = "">
    参数 密钥 <类型 = 文本型 注释 = "当内存加载为真时  这个必须是密钥字符串，否则填写密钥全路径" @默认值 = "">
    参数 密码 <类型 = 文本型 @默认值 = "">
    参数 CA证书 <类型 = 文本型 注释 = "当内存加载为真时  这个必须是CA证书字符串，否则填写CA证书目录或者文件全路径" @默认值 = "">
    参数 是否内存证书 <类型 = 逻辑型 @默认值 = 假>
    {
        @ HPClient_SetSSLContext((void*)@<客户端句柄>,@<是否内存证书>,@<验证模式>, GetMbsText(@<证书>, CVolMem(), NULL), GetMbsText(@<密钥>, CVolMem(), NULL), GetMbsText(@<密码>, CVolMem(), NULL),GetMbsText(@<CA证书>, CVolMem(), NULL) )
    }

    方法 置不验证证书 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 客户端句柄 <类型 = 变整数>
    {
        @ HPClient_SetSSLContext((void*)@<客户端句柄>,false,0, NULL,NULL,NULL,NULL)

    }

    方法 是否已启动 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_HasStarted((void*)@<通讯句柄>)
    }

    方法 取状态 <公开 静态 类型 = 整数 注释 = "返回值意义" 注释 = "//SS_STARTING = 0, // 正在启动" 注释 = "//SS_STARTED = 1, // 已经启动"
            注释 = "//SS_STOPPING = 2, // 正在停止" 注释 = "//SS_STOPPED = 3, // 已经停止" 折叠2 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_GetState((void*)@<通讯句柄>)


    }

    方法 取最后一次错误文本 <公开 静态 类型 = 文本型 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ CVolString(HPClient_GetLastText((void*)@<通讯句柄>))


    }

    方法 取连接ID <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ HPClient_GetConnectionID((void*)@<通讯句柄>))
    }

    方法 置附加数据 <公开 静态 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    参数 附加数据 <类型 = 变整数>
    {
        @ HPClient_SetExtra((void*)@<通讯句柄>,(void*)@<附加数据>)
    }

    方法 取附加数据 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 通讯句柄 <类型 = 变整数>
    {
        @ (INT_P)HPClient_GetExtra( (void*)@<通讯句柄>)
    }

    #
    #
    #
}

