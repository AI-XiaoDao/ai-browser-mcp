    方法 快照截图 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 窗口 注释 = "默认为0，0代表截屏整个屏幕，否则截取固定窗口" @默认值 = 空对象>
    参数 保存地址 <类型 = 文本型>
    参数 截取区域 <类型 = 矩形类 注释 = "注意：本参数只有在截取全屏时才有效" @默认值 = 空对象>
    参数 保存格式 <类型 = 整数 注释 = "默认为1，1等于BMP" 注释 = "2等于PNG" 注释 = "3等于JPEG" 折叠2 @默认值 = 1>
    {
        变量 X坐标 <类型 = 整数>
        变量 Y坐标 <类型 = 整数>
        变量 宽度 <类型 = 整数>
        变量 高度 <类型 = 整数>
        变量 指针 <类型 = 变整数>
        变量 字节集 <类型 = 字节集类>
        字节集 = 文本到多字节 (保存地址)
        指针 = 取字节集指针 (字节集)
        如果 (窗口句柄 == 空对象)
        {
            如果 (截取区域 != 空对象)
            {
                宽度 = 截取区域.右边 - 截取区域.左边
                高度 = 截取区域.底边 - 截取区域.顶边
                X坐标 = 截取区域.左边
                Y坐标 = 截取区域.顶边
                @ if(@<宽度>==0 || @<高度>==0){HDC hdc = GetDC(NULL);int client_width = GetDeviceCaps(hdc, DESKTOPHORZRES);int client_height = GetDeviceCaps(hdc, DESKTOPVERTRES);ReleaseDC(NULL, hdc);@<宽度>=client_width;@<高度>=client_height;};
                @ char * a=(char *)@<指针>;
                @ ScreenShot(NULL,a,@<宽度>,@<高度>,@<X坐标>,@<Y坐标>,@<保存格式>);
            }
            否则
            {
                @ char * a=(char *)@<指针>;
                @ HDC hdc = GetDC(NULL);
                @ int client_width = GetDeviceCaps(hdc, DESKTOPHORZRES);
                @ int client_height = GetDeviceCaps(hdc, DESKTOPVERTRES);
                @  ReleaseDC(NULL, hdc);

                @ ScreenShot(NULL,a,client_width,client_height,0,0,@<保存格式>);

            }

        }
        否则
        {
            宽度 = 窗口句柄.宽度
            高度 = 窗口句柄.高度

            @ char * a=(char *)@<指针>;
            变量 句柄 <类型 = 变整数>
            句柄 = 窗口句柄.取窗口句柄 ()
            @ ScreenShot((HWND)@<句柄>,a,@<宽度>,@<高度>,0,0,@<保存格式>);

        }


    }

    方法 快照截图2 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "默认为0，0代表截屏整个屏幕，否则截取固定窗口" @默认值 = 0>
    参数 窗口宽度 <类型 = 整数>
    参数 窗口高度 <类型 = 整数>
    参数 保存地址 <类型 = 文本型>
    参数 截取区域 <类型 = 矩形类 注释 = "注意：本参数只有在截取全屏时才有效" @默认值 = 空对象>
    参数 保存格式 <类型 = 整数 注释 = "默认为1，1等于BMP" 注释 = "2等于PNG" 注释 = "3等于JPEG" 折叠2 @默认值 = 1>
    {
        变量 X坐标 <类型 = 整数>
        变量 Y坐标 <类型 = 整数>
        变量 宽度 <类型 = 整数>
        变量 高度 <类型 = 整数>
        变量 指针 <类型 = 变整数>
        变量 字节集 <类型 = 字节集类>
        字节集 = 文本到多字节 (保存地址)
        指针 = 取字节集指针 (字节集)
        如果 (窗口句柄 == 0)
        {
            如果 (截取区域 != 空对象)
            {
                宽度 = 截取区域.右边 - 截取区域.左边
                高度 = 截取区域.底边 - 截取区域.顶边
                X坐标 = 截取区域.左边
                Y坐标 = 截取区域.顶边
                @ if(@<宽度>==0 || @<高度>==0){HDC hdc = GetDC(NULL);int client_width = GetDeviceCaps(hdc, DESKTOPHORZRES);int client_height = GetDeviceCaps(hdc, DESKTOPVERTRES);ReleaseDC(NULL, hdc);@<宽度>=client_width;@<高度>=client_height;};
                @ char * a=(char *)@<指针>;
                @ ScreenShot(NULL,a,@<宽度>,@<高度>,@<X坐标>,@<Y坐标>,@<保存格式>);
            }
            否则
            {
                @ char * a=(char *)@<指针>;
                @ HDC hdc = GetDC(NULL);
                @ int client_width = GetDeviceCaps(hdc, DESKTOPHORZRES);
                @ int client_height = GetDeviceCaps(hdc, DESKTOPVERTRES);
                @  ReleaseDC(NULL, hdc);

                @ ScreenShot(NULL,a,client_width,client_height,0,0,@<保存格式>);

            }

        }
        否则
        {
            宽度 = 窗口宽度
            高度 = 窗口高度

            @ char * a=(char *)@<指针>;
            变量 句柄 <类型 = 变整数>
            句柄 = 窗口句柄
            @ ScreenShot((HWND)@<句柄>,a,@<宽度>,@<高度>,0,0,@<保存格式>);

        }


    }

