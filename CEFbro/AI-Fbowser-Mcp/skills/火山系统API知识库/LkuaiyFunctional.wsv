    方法 文本_取右边_从右往左查找 <公开 类型 = 文本型 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 要查找的文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 注释 = "默认从尾部开始寻找" @默认值 = -1>
    {
        变量 找到位置 <类型 = 整数>
        变量 找到的文本 <类型 = 文本型>
        变量 文本长度 <类型 = 整数>
        找到位置 = 文本_倒找文本 (原始文本, 要查找的文本, 开始搜索位置)
        如果 (找到位置 != -1)
        {
            找到位置 = 找到位置 + 取文本长度 (要查找的文本)
            文本长度 = 取文本长度 (原始文本) - 找到位置
            如果 (取文本长度 (原始文本) >= 文本长度)
            {
                找到的文本 = 取文本右边 (原始文本, 文本长度)
            }
            否则
            {
                找到的文本 = ""

            }

        }

        返回 (找到的文本)
    }

    方法 文本_取左边_从右往左查找 <公开 类型 = 文本型 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 要查找的文本 <类型 = 文本型>
    参数 开始查找位置 <类型 = 整数 注释 = "-1表示从尾部开始查找，必须小于原始文本长度；否则崩溃" @默认值 = -1>
    参数 是否不区分大小写 <类型 = 逻辑型 注释 = "默认不取分大小写" @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 找到位置 <类型 = 整数>
        如果 (取文本长度 (原始文本) >= 开始查找位置)
        {
            找到位置 = 倒找文本 (原始文本, 要查找的文本, 开始查找位置, 是否不区分大小写)
            如果 (找到位置 == -1)
            {
                如果 (如果找不到返回原始文本)
                {
                    返回 (原始文本)
                }
                否则
                {
                    返回 ("")

                }

            }
            否则
            {
                如果 (取文本长度 (原始文本) >= 找到位置)
                {
                    返回 (取文本左边 (原始文本, 找到位置))
                }
                否则
                {
                    返回 ("")

                }

            }

        }
        否则
        {
            返回 ("")

        }


    }
}

