    方法 键盘_模拟快捷键 <公开 静态 注释 = "可以单键也可以组合键" 折叠 @禁止流程检查 = 真>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.V键" "">
    参数 Ctrl <类型 = 逻辑型 @默认值 = 假>
    参数 Alt <类型 = 逻辑型 @默认值 = 假>
    参数 Shift <类型 = 逻辑型 @默认值 = 假>
    参数 Win <类型 = 逻辑型 @默认值 = 假>
    {
        如果真 (Ctrl == 真)
        {
            @ keybd_event (17, 0, 0, 0);
        }
        如果真 (Shift == 真)
        {
            @ keybd_event (16, 0, 0, 0);
        }
        如果真 (Alt == 真)
        {
            @ keybd_event (18, 0, 0, 0);
        }
        如果真 (Win == 真)
        {
            @ keybd_event (91, 0, 0, 0);

        }
        @ keybd_event (@<键代码>, 0, 0, 0);
        如果真 (Ctrl == 真)
        {
            @ keybd_event (17, 0, 2, 0);
        }
        如果真 (Shift == 真)
        {
            @ keybd_event (16, 0, 2, 0);
        }
        如果真 (Alt == 真)
        {
            @ keybd_event (18, 0, 2, 0);
        }
        如果真 (Win == 真)
        {
            @ keybd_event (91, 0, 2, 0);

        }

        @ keybd_event (@<键代码>, 0, 2, 0);
    }

    方法 键盘_键盘点击lky <公开 静态 注释 = "前台模拟键盘操作" 返回值注释 = "仰望星空" 折叠 @禁止流程检查 = 真>
    参数 键代码 <类型 = 整数>
    参数 状态 <类型 = 整数 注释 = "1按下,2放开" @默认值 = 1>
    {
        如果 (状态 == 1)
        {
            @ keybd_event (@<键代码>, 0, 0, 0);
        }
        否则 (状态 == 2)
        {
            @ keybd_event (@<键代码>, 0, 2, 0);
        }

    }

    方法 键盘_取大小写状态lky <公开 静态 类型 = 逻辑型 注释 = "取当前的输入状态,返回真为大写,0小写,1大写" 返回值注释 = "仰望星空" 折叠 @禁止流程检查 = 真>
    {
        变量 结果 <类型 = 逻辑型>
        @ @<结果> = GetKeyState(20);
        返回 (结果)
    }

    方法 键盘_取小键盘状态lky <公开 静态 类型 = 逻辑型 注释 = "取当前的输入状态,返回真为开返回1,返回假则为关返回0" 返回值注释 = "仰望星空" 折叠 @禁止流程检查 = 真>
    {
        变量 结果 <类型 = 逻辑型>
        @ @<结果> = GetKeyState(144);
        返回 (结果)

    }

    方法 键盘_模拟按下回车键lky <公开 静态 注释 = "模拟按下回车键" 返回值注释 = "利快云@仰望星空" 折叠 @禁止流程检查 = 真>
    {
        @ keybd_event(VK_RETURN,0,0,0);
        @ keybd_event(VK_RETURN,0,KEYEVENTF_KEYUP,0);

    }

    #
}

