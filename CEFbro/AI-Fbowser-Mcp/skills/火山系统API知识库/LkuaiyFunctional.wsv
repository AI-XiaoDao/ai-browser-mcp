    方法 组合回调事件 <公开 定义事件 类型 = 整数 折叠>
    参数 按键码_ <类型 = 整数>
    参数 是否按下Ctrl <类型 = 逻辑型>
    参数 是否按下Alt <类型 = 逻辑型>
    参数 是否按下Shift <类型 = 逻辑型>
    参数 是否按下WIN键 <类型 = 逻辑型>
    参数 放开还是按下 <类型 = 逻辑型 注释 = "真放开，假按下">
    {

    }

    方法 内部回调方法 <公开 折叠 @禁止流程检查 = 真>
    参数 按键码 <类型 = 整数>
    参数 消息值 <类型 = 整数>
    参数 scanCode <类型 = 整数>
    参数 flags <类型 = 整数>
    {
        变量 是否按下Ctrl <静态 类型 = 逻辑型>
        变量 是否按下Alt <静态 类型 = 逻辑型>
        变量 是否按下Shift <静态 类型 = 逻辑型>
        变量 是否按下WIN键 <静态 类型 = 逻辑型>
        变量 放开还是按下 <静态 类型 = 逻辑型>
        如果 (消息值 == 512)
        {
            鼠标移动回调事件 ()
        }
        如果 (消息值 > 512)
        {
            如果 (消息值 == 522)
            {
                如果 (flags >= 0)
                {
                    滚轮是否转动 (1)
                }
                否则
                {
                    滚轮是否转动 (2)

                }

            }

            如果 (消息值 == 513)
            {
                // 鼠标左键按下
                鼠标按下按键回调事件 (1)
            }
            如果 (消息值 == 514)
            {
                // 鼠标左键放开
                鼠标放开按键回调事件 (1)
            }
            如果 (消息值 == 516)
            {
                // 鼠标右键按下
                鼠标按下按键回调事件 (2)
            }
            如果 (消息值 == 517)
            {
                // 鼠标右键放开
                鼠标放开按键回调事件 (2)
            }
            如果 (消息值 == 519)
            {
                // 鼠标中键按下
                鼠标按下按键回调事件 (3)
            }
            如果 (消息值 == 520)
            {
                // 鼠标中键按下
                鼠标放开按键回调事件 (3)

            }

        }
        如果 (消息值 == 256)
        {
            键盘按下按键回调事件 (按键码)
            放开还是按下 = 假
            如果 (按键码 == 160)
            {
                是否按下Shift = 真

            }
            如果 (按键码 == 162)
            {
                是否按下Ctrl = 真

            }
            如果 (按键码 == 164)
            {
                是否按下Alt = 真

            }
            如果 (按键码 == 91)
            {
                是否按下WIN键 = 真

            }

        }
        如果 (消息值 == 257)
        {
            键盘放开按键回调事件 (按键码)
            放开还是按下 = 真
            如果 (按键码 == 160)
            {
                是否按下Shift = 假
            }
            如果 (按键码 == 162)
            {
                是否按下Ctrl = 假

            }
            如果 (按键码 == 164)
            {
                是否按下Alt = 假

            }
            如果 (按键码 == 91)
            {
                是否按下WIN键 = 假

            }

        }

        如果 (消息值 == 260 || 消息值 == 164 || 消息值 == 165)  // 消息值
        {
            键盘按下按键回调事件 (按键码)

        }

        如果 (是否按下Shift == 真 && 是否按下Ctrl == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下Shift == 真 && 是否按下Alt == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下Alt == 真 && 是否按下Ctrl == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下WIN键 == 真 && 是否按下Ctrl == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下WIN键 == 真 && 是否按下Shift == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下WIN键 == 真 && 是否按下Alt == 真 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }

        如果 (是否按下Shift == 真 && 是否按下Ctrl == 假 && 是否按下Alt == 假 && 是否按下WIN键 == 假 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下Shift == 假 && 是否按下Ctrl == 真 && 是否按下Alt == 假 && 是否按下WIN键 == 假 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下Shift == 假 && 是否按下Ctrl == 假 && 是否按下Alt == 真 && 是否按下WIN键 == 假 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }
        如果 (是否按下Shift == 假 && 是否按下Ctrl == 假 && 是否按下WIN键 == 真 && 是否按下Alt == 假 && 按键码 != 160 && 按键码 != 162 && 按键码 != 164 && 按键码 != 91)
        {
            组合回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下WIN键, 放开还是按下)

        }


    }

