类 类_字节集操作 <公开 折叠 "">
{
    方法 字节集_字节集取整数 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 字节集 <类型 = 字节集类>
    参数 要取的成员 <类型 = 整数>
    {
        @ (int)@<字节集>.GetPtr()[@<要取的成员>]
    }

    方法 字节集_字节集取整数2 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 字节集 <类型 = 字节集类>
    参数 成员 <类型 = 整数 "">
    参数 最小宽度 <类型 = 整数>
    {
        @ int pt;
        @ &pt(整数)@<字节集>.GetPtr()[@<成员>];
        @ TCHAR buf [64];
        @ return CVolString (DWordToHexStr ((DWORD)&pt, @<最小宽度>, buf, NUM_ELEMENTS_OF (buf)));

    }

    方法 字节集_字节集是否相等 <公开 类型 = 逻辑型 折叠>
    参数 字节集1 <类型 = 字节集类>
    参数 字节集2 <类型 = 字节集类>
    {
        如果 (取字节集哈希值 (字节集1) == 取字节集哈希值 (字节集2))
        {
            返回 (真)

        }
        否则
        {
            返回 (假)

        }


    }

    方法 字节集_UTF8去首零 <公开 类型 = 字节集类 折叠>
    参数 UTF8数据 <类型 = 字节集类>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到UTF8 ("")
        如果 (取字节集长度 (UTF8数据) >= 1)
        {
            如果 (取字节集长度 (UTF8数据) >= 取字节集长度 (临时字节集))
            {
                如果 (取字节集左边 (UTF8数据, 取字节集长度 (临时字节集)) == 临时字节集)
                {
                    临时字节集 = 取字节集右边 (UTF8数据, 取字节集长度 (UTF8数据) - 取字节集长度 (临时字节集))
                }
                否则
                {
                    临时字节集 = UTF8数据

                }

            }

            返回 (临时字节集)
        }
        否则
        {
            临时字节集 = UTF8数据
            返回 (临时字节集)

        }
    }

    方法 字节集_UTF8去尾零 <公开 类型 = 字节集类 折叠>
    参数 UTF8数据 <类型 = 字节集类>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到UTF8 ("")
        如果 (取字节集长度 (UTF8数据) >= 1)
        {
            变量 长度 <类型 = 整数>
            长度 = 取字节集长度 (临时字节集)
            变量 UTF8长度 <类型 = 整数>
            UTF8长度 = 取字节集长度 (UTF8数据)
            如果 (UTF8长度 >= 长度)
            {
                如果 (取字节集右边 (UTF8数据, 长度) == 临时字节集)
                {
                    临时字节集 = 取字节集左边 (UTF8数据, UTF8长度 - 长度)
                }
                否则
                {
                    临时字节集 = UTF8数据

                }


            }

            返回 (临时字节集)
        }
        否则
        {
            临时字节集 = UTF8数据
            返回 (临时字节集)

        }
    }

    方法 字节集_字节集分割 <公开 折叠>
    参数 待分割字节集 <类型 = 字节集类>
    参数 用作分割字节集 <类型 = 字节集类>
    参数 结果字节集 <类型 = 字节集数组类>
    {
        变量 临时字节集 <类型 = 字节集数组类>
        变量 字节集 <类型 = 字节集类>
        字节集 = 待分割字节集
        字节集.添加字节集 (用作分割字节集)
        字节集.添加字节集 (文本到字节集 ("fengezijiejimengmengda"))
        分割字节集 (字节集, 用作分割字节集, 临时字节集)
        如果 (字节集_字节集是否相等 (临时字节集.取成员 (临时字节集.取成员数 () - 1), 文本到字节集 ("fengezijiejimengmengda")) == 真)
        {
            临时字节集.删除成员 (临时字节集.取成员数 () - 1)

        }

        结果字节集 = 临时字节集
    }

    方法 字节集_替换 <公开 类型 = 字节集类 折叠>
    参数 原始内容 <类型 = 字节集类>
    参数 要替换的文本 <类型 = 字节集类>
    参数 用作替换的文本 <类型 = 字节集类>
    {
        变量 替换后的内容 <类型 = 字节集类>
        替换后的内容 = 原始内容
        子字节集替换 (替换后的内容, 要替换的文本, 用作替换的文本)
        返回 (替换后的内容)
    }

    方法 字节集_寻找取右 <公开 类型 = 字节集类
            注释 = "从字节集的右边按 欲寻找的字节集 开始寻找  如 字节集_取右边({105,108,121,13,10,83,101},{13,10}) 将返回 {83,101}，如果没有找到将会返回空" 折叠>
    参数 被查找的字节集 <类型 = 字节集类 注释 = "被查找的字节集">
    参数 欲查找的字节集 <类型 = 字节集类 注释 = "欲寻找的字节集">
    参数 起始位置 <类型 = 整数 注释 = "默认从最右边寻找,欲寻找的字节集的起始寻找位置,一般情况都留空" @默认值 = 0>
    {
        变量 结果字节集 <类型 = 字节集类>
        变量 起始寻找位置 <类型 = 整数>
        如果 (起始位置 <= 0)
        {
            起始寻找位置 = 取字节集长度 (被查找的字节集)
        }
        否则
        {
            起始寻找位置 = 起始位置

        }

        如果 (倒找字节集 (被查找的字节集, 欲查找的字节集, 起始寻找位置) == -1)
        {
            变量 空字节 <类型 = 字节集类>
            返回 (空字节)

        }

        变量 查找位置 <类型 = 整数>
        查找位置 = 取字节集长度 (被查找的字节集) - 取字节集长度 (欲查找的字节集) - 倒找字节集 (被查找的字节集, 欲查找的字节集, 起始寻找位置)
        如果 (取字节集长度 (被查找的字节集) >= 查找位置)
        {
            结果字节集 = 取字节集右边 (被查找的字节集, 查找位置)
            返回 (结果字节集)
        }
        否则
        {
            变量 空字节 <类型 = 字节集类>
            返回 (空字节)

        }

    }

    方法 字节集_寻找取左 <公开 类型 = 字节集类
            注释 = "从字节集的右边按 欲寻找的字节集 开始寻找  如 字节集_取右边({105,108,121,13,10,83,101},{13,10}) 将返回 {105,108,121}，如果没有找到将会返回空" 折叠>
    参数 被查找的字节集 <类型 = 字节集类 注释 = "被查找的字节集">
    参数 欲查找的字节集 <类型 = 字节集类 注释 = "欲寻找的字节集">
    参数 起始位置 <类型 = 整数 注释 = "默认从最左边寻找,欲寻找的字节集的起始寻找位置,一般情况都留空，注意：必须大于0" @默认值 = 0>
    {
        变量 结果字节集 <类型 = 字节集类>
        如果 (寻找字节集 (被查找的字节集, 欲查找的字节集, 起始位置) == -1)
        {
            变量 空字节 <类型 = 字节集类>
            返回 (空字节)

        }


        变量 查找位置 <类型 = 整数>
        查找位置 = 寻找字节集 (被查找的字节集, 欲查找的字节集, 起始位置)
        如果 (取字节集长度 (被查找的字节集) >= 查找位置)
        {
            结果字节集 = 取字节集左边 (被查找的字节集, 查找位置)
            返回 (结果字节集)
        }
        否则
        {
            变量 空字节 <类型 = 字节集类>
            返回 (空字节)


        }

    }

    方法 字节集_寻找取右_从左开始 <公开 类型 = 字节集类
            注释 = "从字节集的左边按 欲寻找的字节集 开始寻找  如 字节集_取右边({105,108,121,13,10,83,101},{13,10}) 将返回 {83,101}，如果没有找到将会返回空" 折叠>
    参数 被查找的字节集 <类型 = 字节集类 注释 = "被查找的字节集">
    参数 欲查找的字节集 <类型 = 字节集类 注释 = "欲寻找的字节集">
    参数 起始位置 <类型 = 整数 注释 = "默认从最右边寻找,欲寻找的字节集的起始寻找位置,一般情况都留空" @默认值 = 0>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 字节集_寻找取左 (被查找的字节集, 欲查找的字节集)
        变量 长度 <类型 = 整数>
        长度 = 取字节集长度 (被查找的字节集) - 取字节集长度 (欲查找的字节集) - 取字节集长度 (临时字节集)
        如果 (取字节集长度 (被查找的字节集) >= 长度)
        {
            临时字节集 = 取字节集右边 (被查找的字节集, 长度)

        }
        返回 (临时字节集)

    }

    方法 字节集_寻找取左_从右开始 <公开 类型 = 字节集类
            注释 = "从字节集的右边按 欲寻找的字节集 开始寻找  如 字节集_取右边({105,108,121,13,10,83,101},{13,10}) 将返回 {105,108,121}，如果没有找到将会返回空" 折叠>
    参数 被查找的字节集 <类型 = 字节集类 注释 = "被查找的字节集">
    参数 欲查找的字节集 <类型 = 字节集类 注释 = "欲寻找的字节集">
    参数 起始位置 <类型 = 整数 注释 = "默认从最左边寻找,欲寻找的字节集的起始寻找位置,一般情况都留空，注意：必须大于0" @默认值 = 0>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 字节集_寻找取右 (被查找的字节集, 欲查找的字节集)
        变量 长度 <类型 = 整数>
        长度 = 取字节集长度 (被查找的字节集) - 取字节集长度 (欲查找的字节集) - 取字节集长度 (临时字节集)
        如果 (取字节集长度 (被查找的字节集) >= 长度)
        {
            临时字节集 = 取字节集左边 (被查找的字节集, 长度)

        }

        返回 (临时字节集)

    }

    方法 字节集_反转字节集 <公开 类型 = 字节集类 折叠>
    参数 字节集数据 <类型 = 字节集类>
    {
        变量 反转后字节集 <类型 = 字节集类>
        变量 长度 <类型 = 整数>
        长度 = 取字节集长度 (字节集数据)
        反转后字节集 = 字节集数据
        计次循环 (长度)
        {
            反转后字节集.置字节集值 (取循环索引 (), 字节集数据.取字节集数据 (长度 - 取循环索引 () - 1, 字节))

        }
        返回 (反转后字节集)
    }

    方法 字节集_取中间 <公开 类型 = 字节集类 折叠>
    参数 要操作的字节集 <类型 = 字节集类>
    参数 前面字节集 <类型 = 字节集类>
    参数 后面字节集 <类型 = 字节集类>
    {
        变量 结果字节集 <类型 = 字节集类>
        变量 位置变量 <类型 = 整数>
        位置变量 = 寻找字节集 (要操作的字节集, 前面字节集)
        如果 (位置变量 == -1)
        {
            返回 (文本到字节集 (""))

        }
        变量 长度 <类型 = 整数>
        长度 = 取字节集长度 (要操作的字节集) - 位置变量 - 取字节集长度 (前面字节集)
        如果 (取字节集长度 (要操作的字节集) < 长度)
        {
            返回 (文本到字节集 (""))

        }

        结果字节集 = 取字节集右边 (要操作的字节集, 长度)
        位置变量 = 倒找字节集 (结果字节集, 后面字节集)
        如果 (位置变量 == -1)
        {
            返回 (文本到字节集 (""))

        }
        如果 (取字节集长度 (结果字节集) >= 位置变量)
        {
            结果字节集 = 取字节集左边 (结果字节集, 位置变量)
            返回 (结果字节集)

        }
        否则
        {
            返回 (文本到字节集 (""))

        }



    }
}

类 类_文本数组独有 <公开 注释 = "使用方法参考本案例：https://www.lkuaiy.com/rsdetails?id=13811608625019" 折叠>
{
    变量 内_文本数组独有 <类型 = 文本独有数组类>
    变量 内_文本数组 <类型 = 文本数组类>
    变量 内_可重复数据 <类型 = 文本数组类>

    方法 初始化数据 <公开 折叠>
    {
        内_文本数组独有.删除所有成员 ()
        内_文本数组.删除所有成员 ()
        内_可重复数据.删除所有成员 ()

    }

    方法 定义可重复数据 <公开 折叠>
    参数 重复数据 <类型 = 文本数组类>
    {
        内_可重复数据 = 重复数据
    }

    方法 添加数据 <公开 折叠>
    参数 添加的文本数据 <类型 = 文本型>
    {
        变量 是否可以重复 <类型 = 逻辑型>
        变量 循环变量 <类型 = 整数>
        循环 (0, 内_可重复数据.取成员数 (), 循环变量)
        {
            如果 (内_可重复数据.取成员 (循环变量) == 添加的文本数据)
            {
                是否可以重复 = 真
                跳出循环

            }

        }

        如果 (是否可以重复 == 真)
        {
            内_文本数组.加入成员 (添加的文本数据)
            内_文本数组独有.加入成员 (添加的文本数据)

        }
        否则
        {
            变量 是否已经重复 <类型 = 逻辑型>
            循环 (0, 内_文本数组独有.取成员数 (), 循环变量)
            {
                如果 (内_文本数组独有.取成员 (循环变量) == 添加的文本数据)
                {
                    是否已经重复 = 真
                    跳出循环

                }

            }

            如果 (是否已经重复 == 假)
            {
                内_文本数组.加入成员 (添加的文本数据)
                内_文本数组独有.加入成员 (添加的文本数据)

            }

        }

    }

    方法 获取数据 <公开 属性读 类型 = 文本数组类 折叠>
    {
        返回 (内_文本数组)
    }
}

类 类_文本操作 <公开>
{
    方法 文本_XSS防注入处理 <公开 类型 = 文本型 返回值注释 = "返回防止注入后的值" 折叠>
    参数 XSS处理 <类型 = 文本型>
    参数 自身域名 <类型 = 文本型 注释 = "例如：lkuaiy.com" 注释 = "不需要带www" 折叠2 "">
    参数 是否严格模式 <类型 = 逻辑型 注释 = "如果启用了严格模式，则以下符号会被替换为空。" 注释 = "<" 注释 = ">" 注释 = "\"" 注释 = "\'" 注释 = "(" 注释 = ")" 注释 = "&" 注释 = "/"
            折叠2 @默认值 = 假>
    参数 是否替换点号 <类型 = 逻辑型 注释 = "是否将小写.替换成大写。" @默认值 = 真>
    参数 是否替换http <类型 = 逻辑型 注释 = "是否http://替换成http：/ /" @默认值 = 真>
    {
        变量 XSS检测文本 <类型 = 文本型>
        XSS检测文本 = XSS处理
        如果 (是否严格模式 == 真)
        {
            子文本替换 (XSS检测文本, "<", "")
            子文本替换 (XSS检测文本, ">", "")
            变量 双引号 <类型 = 文本型 值 = "\"">
            变量 单引号 <类型 = 文本型 值 = "\'">
            子文本替换 (XSS检测文本, 双引号, "")
            子文本替换 (XSS检测文本, 单引号, "")
            子文本替换 (XSS检测文本, "`", "")
            子文本替换 (XSS检测文本, "(", "")
            子文本替换 (XSS检测文本, ")", "")
            子文本替换 (XSS检测文本, "&", "")
            子文本替换 (XSS检测文本, "/", "")


        }
        子文本替换 (XSS检测文本, "<script", "")
        子文本替换 (XSS检测文本, "/script>", "")
        子文本替换 (XSS检测文本, "alert", "")
        子文本替换 (XSS检测文本, 自身域名, "KKKKLKUAIY")
        如果 (是否替换http == 真)
        {
            子文本替换 (XSS检测文本, "http://", "http：/ /")

        }

        如果 (是否替换点号 == 真)
        {
            子文本替换 (XSS检测文本, ".", "。")
            内部_安全文件内容处理 (XSS检测文本)

        }

        子文本替换 (XSS检测文本, "KKKKLKUAIY", 自身域名)
        // ===

        返回 (XSS检测文本)

    }

