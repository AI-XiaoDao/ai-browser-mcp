    方法 文本_取中间高级 <公开 类型 = 文本型 折叠>
    参数 待取内容 <类型 = 文本型>
    参数 起始查找位置 <类型 = 整数 @默认值 = 0>
    参数 起始文本1 <类型 = 文本型 @默认值 = "">
    参数 起始文本2 <类型 = 文本型 @默认值 = "">
    参数 结束文本 <类型 = 文本型 @默认值 = "">
    参数 不区分大小写 <类型 = 逻辑型 @默认值 = 真>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 结束位置 <类型 = 整数>
        变量 起始查找位置1 <类型 = 整数>
        如果 (取文本长度 (待取内容) >= 起始查找位置)
        {
            起始查找位置1 = 寻找文本 (待取内容, 起始文本1, 起始查找位置, 不区分大小写)
            如果 (起始查找位置1 < 0)
            {
                返回 ("")

            }

        }
        否则
        {
            返回 ("")

        }


        如果 (起始文本2 == "")
        {
            如果 (取文本长度 (待取内容) >= 起始查找位置)
            {
                起始查找位置1 = 寻找文本 (待取内容, 起始文本2, 起始查找位置, 不区分大小写)

            }
            否则
            {
                返回 ("")

            }

        }
        否则
        {
            起始查找位置1 = 起始查找位置
            起始文本2 = 起始文本1

        }
        如果 (起始查找位置1 < 0)
        {
            起始查找位置 = -1
            返回 ("")

        }

        如果 (结束文本 == "")
        {
            结束位置 = 取文本长度 (待取内容) + 1
        }
        否则
        {
            如果 (取文本长度 (待取内容) >= 起始查找位置1 + 取文本长度 (起始文本2))
            {
                结束位置 = 寻找文本 (待取内容, 结束文本, 起始查找位置1 + 取文本长度 (起始文本2), 不区分大小写)
                如果 (结束位置 < 0)
                {
                    返回 ("")

                }


            }
            否则
            {
                返回 ("")

            }

        }

        如果 (是否包含起始文本 == 假)
        {
            起始查找位置 = 起始查找位置1 + 取文本长度 (起始文本2)

        }

        如果 (取文本长度 (待取内容) >= 起始查找位置)
        {
            返回 (取文本中间 (待取内容, 起始查找位置, 结束位置 - 起始查找位置))

        }
        否则
        {
            返回 ("")

        }

    }

    方法 文本_取右边 <公开 类型 = 文本型 折叠>
    参数 被查找的文本 <类型 = 文本型>
    参数 欲寻找的文本 <类型 = 文本型>
