        变量 桌面句柄 <类型 = 变整数>
        @ HWND hWnd = ::FindWindow(TEXT("progman"),NULL);
        @      hWnd = ::FindWindowEx (hWnd, 0,TEXT("shelldll_defview"),NULL);
        @      hWnd = ::FindWindowEx (hWnd, 0,TEXT("SysListView32"), NULL);
        如果 (是否隐藏任务栏 == 真)
        {
            @ ::ShowWindow (hWnd, 0);
        }
        否则
