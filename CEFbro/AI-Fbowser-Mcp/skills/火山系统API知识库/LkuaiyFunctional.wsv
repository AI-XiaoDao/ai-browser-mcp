    方法 文本_取文本长度_易语言 <公开 类型 = 整数 注释 = "火山的取文本长度中文和英文都是1长度，本命令可以实现类似易语言的取文本长度  中文2  英文1" 折叠 @禁止流程检查 = 真>
    参数 文本 <类型 = 文本型>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<文本>,-1,NULL,NULL,0,NULL); 
        @ char *c = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<文本>,-1,c,dwNum,0,NULL);

        @ char* cha=c;
        @    int count{};   //定义返回的长度
        @    for (int i = 0; cha[i]; i++)
        @    {
        @        count++;
        @    }
        @    return count;

    }

    方法 文本_取文本中间_批量 <公开 类型 = 文本数组类 折叠>
    参数 文本内容 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 @默认值 = 0>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        变量 数组1 <类型 = 文本数组类>
        判断循环 (真)
        {
            如果 (取文本长度 (文本内容) >= 开始搜索位置)
            {
                开始位置 = 寻找文本 (文本内容, 开始文本, 开始搜索位置)

            }
            否则
            {
                跳出循环

            }


            如果 (开始位置 == -1)
            {
                跳出循环
            }

            开始搜索位置 = 开始位置 + 取文本长度 (开始文本)
            开始位置 = 开始搜索位置

            如果 (取文本长度 (文本内容) >= 开始搜索位置 + 取文本长度 (中间文本))
            {
                结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置 + 取文本长度 (中间文本))
                如果 (结束位置 == -1)
                {
                    跳出循环
                }

            }
            否则
            {
                跳出循环

            }

            如果 (取文本长度 (文本内容) >= 开始位置)
            {
                中间文本 = 取文本中间 (文本内容, 开始位置, 结束位置 - 开始位置)
                数组1.加入成员 (中间文本)

            }
            否则
            {
                跳出循环

            }

        }

        返回 (数组1)

    }

    方法 文本_取出中间文本 <公开 类型 = 文本型 折叠>
    参数 欲取全文本 <类型 = 文本型>
    参数 前面文本 <类型 = 文本型>
    参数 后面文本 <类型 = 文本型>
    参数 起始搜寻位置 <类型 = 整数 @默认值 = 0>
    参数 是否不区分大小写 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 局_位置 <类型 = 整数>
        变量 局_位置1 <类型 = 整数>
        变量 局_前面文本 <类型 = 文本型>
        变量 局_后面文本 <类型 = 文本型>
        局_前面文本 = 前面文本
        局_后面文本 = 后面文本
        局_位置 = 寻找文本 (欲取全文本, 局_前面文本, 起始搜寻位置, 是否不区分大小写)
        如果真 (局_位置 != -1)
        {
            局_位置 = 局_位置 + 取文本长度 (局_前面文本)

        }

        局_位置1 = 寻找文本 (欲取全文本, 局_后面文本, 局_位置, 是否不区分大小写)
        如果真 (局_位置 == -1 || 局_位置1 == -1)
        {
            返回 ("")

        }

        返回 (取文本中间 (欲取全文本, 局_位置, 局_位置1 - 局_位置))
    }

    方法 文本_随机文本 <公开 类型 = "文本型 ">
