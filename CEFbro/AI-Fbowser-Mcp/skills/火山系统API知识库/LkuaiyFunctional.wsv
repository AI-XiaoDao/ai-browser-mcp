    方法 选择文件夹 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 对话框标题 <类型 = 文本型 @默认值 = "选择文件夹">
    {
        @ BROWSEINFO  bi;
        @  bi.hwndOwner=NULL;
        @  bi.pidlRoot=NULL;
        @  bi.pszDisplayName=NULL;
        @  bi.lpszTitle=@<对话框标题>;
        @  bi.ulFlags=0;
        @  bi.lpfn =NULL;
        @  bi.iImage =0;
        @  LPCITEMIDLIST pidl=SHBrowseForFolder(&bi);
        @  if(!pidl)
        @   return "";
        @  TCHAR  szDisplayName[255];
        @  SHGetPathFromIDList(pidl,szDisplayName);
        @  CWString str(szDisplayName);
        @ return str;



    }

