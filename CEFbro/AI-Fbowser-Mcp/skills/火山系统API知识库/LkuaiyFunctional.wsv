类 类_指针操作 <公开 折叠>
{
    方法 指针_memcpy <公开 折叠 @嵌入式方法 = "">
    参数 内存指针 <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ memcpy((void*)@<内存指针>,(const void*)@<数据指针>,@<数据大小>)

    }

    方法 指针_memcmp <公开 折叠 @嵌入式方法 = "">
    参数 内存指针 <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ memcmp((void*)@<内存指针>,(const void*)@<数据指针>,@<数据大小>)


    }

    方法 指针_拷贝 <公开 折叠 @嵌入式方法 = "">
    参数 目标指针 <类型 = 变整数>
    参数 要拷贝的指针 <类型 = 变整数>
    参数 拷贝的大小 <类型 = 整数>
    {
        @ CopyMemory ((void*)@<目标指针>,(const void *)@<要拷贝的指针>,@<拷贝的大小>)

    }

    方法 指针_取数据指针 <公开 类型 = 变整数 注释 = "指针_到自定义类型 (测试类, 指针_取数据指针 (aa)).打印方法 ()" 折叠 @嵌入式方法 = "">
    参数 对象 <@匹配类型 = 所有类型>
    {
        @ (@dt<变整数>)&@<对象>
    }

    方法 指针_到自定义类型 <公开 注释 = "指针_到自定义类型 (测试类, 指针_取数据指针 (aa)).打印方法 ()" 折叠 @嵌入式方法 = "">
    参数 要强制转换的类型 <@需求类型 = 数据类型 @匹配类型 = 所有类型 @返回值类型 = 0>
    参数 参数 <类型 = 变整数>
    {
        @ *(@<要强制转换的类型>*)@<参数>
    }

    方法 指针_字节集智能指针添加 <公开 注释 = "智能指针" 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?id=16114965486005"
            注释 = "案例中的方法名叫做智能指针，这里改成了字节集智能指针添加" 注释 = "你们参考案例的时候自行更改一下名称即可" 折叠 折叠2 @禁止流程检查 = 真>
    参数 欲操作字节集地址 <类型 = 变整数 注释 = "文本到多字节 (\"随便插入几个数据进去！\", 假)  必须填写假，不能含有结束符！！！" 注释 = "格式：取变量地址（XXX字节集）" 折叠2>
    参数 字节集指针 <类型 = 变整数 @默认值 = 0>
    参数 字节集长度 <类型 = 整数 @默认值 = 0>
    参数 释放内存 <类型 = 逻辑型 @默认值 = 假>
    {
        如果真 (释放内存 == 真)  // 释放内存空间
        {
            @  ((@an<CVolMem>*)@<欲操作字节集地址>)->Free(); 
            返回
        }
        如果真 (字节集指针 == 0 || 字节集长度 == 0)  // 约束条件
        {
            返回
        }
        @  ((@an<CVolMem>*)@<欲操作字节集地址>)->Append((void *)@<字节集指针>, (INT_P)@<字节集长度>);    //追加数据.

    }

    方法 指针_通用文本数组类 <公开 注释 = "通用文本数组类" 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?id=16114969308238" 折叠 折叠2 @禁止流程检查 = 真>
    参数 欲操作文本数组地址 <类型 = 变整数 注释 = "文本到多字节 (\"随便插入几个数据进去！\", 假)  必须填写假，不能含有结束符！！！" 注释 = "格式：取文本数组数据地址（XXX文本数组类）" 折叠2>
    参数 文本指针 <类型 = 变整数 @默认值 = 0>
    参数 释放空间 <类型 = 逻辑型 @默认值 = 假>
    {
        如果真 (释放空间 == 真)  // 释放内存空间
        {
            @  ((CMStringArray *)@<欲操作文本数组地址>)->RemoveAll(); 
            返回
        }
        如果真 (文本指针 == 0)  // 约束条件
        {
            返回
        }
        @  ((CMStringArray *)@<欲操作文本数组地址>)->Add2 (GetWideText ((char *)@<文本指针>, CVolMem(), NULL));
    }

    方法 指针_取文本数组数据地址 <公开 类型 = 变整数 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?id=16114969308238" 折叠 @禁止流程检查 = 真>
    参数 欲操作文本数组类 <类型 = 文本数组类>
    {
        @ return (@dt<变整数>) &@<欲操作文本数组类>.data ();
    }

    方法 指针_通用整数数组类 <公开 注释 = "通用整数数组类" 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?id=16114969308238" 折叠 折叠2 @禁止流程检查 = 真>
    参数 欲操作整数数组地址 <类型 = 变整数>
    参数 欲加入数据 <类型 = 整数 @默认值 = 0>
    参数 释放空间 <类型 = 逻辑型 @默认值 = 假>
    {
        如果真 (释放空间 == 真)  // 释放内存空间
        {
            @ ( *(@dt<整数数组类>*)@<欲操作整数数组地址>).data ().RemoveAll();
            返回
        }
        @ ( *(@dt<整数数组类>*)@<欲操作整数数组地址>).data ().Add2(@<欲加入数据>);
    }

    #
}

