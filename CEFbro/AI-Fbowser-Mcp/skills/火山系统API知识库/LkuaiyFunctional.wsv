类 类_高速日志 <公开 折叠>
{
    方法 写出日志 <公开 类型 = 逻辑型 折叠>
    参数 标识名称_ <类型 = 文本型>
    参数 标识内容_ <类型 = 文本型>
    参数 文件目录_ <类型 = 文本型 注释 = "【文件目录全路径】默认为空，空代表运行目录，否则以该目录为准" 注释 = "注意：目录后面一定要有\\，注意火山有转义符，\\\\=\\"
            注释 = "正确格式 C:\\\\PerfLogs\\\\" 注释 = "错误格式：C:\\\\PerfLogs" 折叠2 @默认值 = "">
    参数 文件名称_ <类型 = 文本型 注释 = "默认为空，空代表直接生成日期文件  例如：2021-04-07" 注释 = "如果不为空则按照本参数创建文件名  例如：XXX.txt" 折叠2 @默认值 = "">
    {
        变量 当前日期 <类型 = 小数>
        变量 日志文件 <类型 = 文本型>
        变量 文件句柄 <类型 = 文件读写类>
        变量 是否打开文件正常 <类型 = 逻辑型>
        当前日期 = 取现行时间 ()
        加入格式文本 (日志文件, "%u-", 取年份 (当前日期))
        加入格式文本 (日志文件, 选择 (取月份 (当前日期) < 10, "0%u-", "%u-"), 取月份 (当前日期))
        加入格式文本 (日志文件, 选择 (取日 (当前日期) < 10, "0%u.txt", "%u.txt"), 取日 (当前日期))
        如果 (文件是否存在 (文件目录_) == 假)
        {
            如果 (创建目录 (文件目录_) == 假)
            {
                是否打开文件正常 = 假

            }

        }
        如果 (文件名称_ != "")
        {
            如果 (文件是否存在 (文件目录_ + 文件名称_) == 假)
            {
                如果 (文件目录_ == "")
                {
                    是否打开文件正常 = 文件句柄.打开文件 (取运行目录 () + 文件名称_, 文件打开方式.改写)
                }
                否则
                {
                    是否打开文件正常 = 文件句柄.打开文件 (文件目录_ + 文件名称_, 文件打开方式.改写)

                }

            }
            否则
            {
                如果 (文件目录_ == "")
                {
                    是否打开文件正常 = 文件句柄.打开文件 (取运行目录 () + 文件名称_, 文件打开方式.读写)
                }
                否则
                {
                    是否打开文件正常 = 文件句柄.打开文件 (文件目录_ + 文件名称_, 文件打开方式.读写)

                }


                如果 (是否打开文件正常 == 真)
                {
                    文件句柄.移到文件尾 ()

                }

            }


        }
        否则
        {
            如果 (文件是否存在 (文件目录_ + 日志文件) == 假)
            {
                如果 (文件目录_ == "")
                {
                    是否打开文件正常 = 文件句柄.打开文件 (取运行目录 () + 日志文件, 文件打开方式.改写)
                }
                否则
                {
                    是否打开文件正常 = 文件句柄.打开文件 (文件目录_ + 日志文件, 文件打开方式.改写)

                }

            }
            否则
            {
                如果 (文件目录_ == "")
                {
                    是否打开文件正常 = 文件句柄.打开文件 (取运行目录 () + 日志文件, 文件打开方式.读写)
                }
                否则
                {
                    是否打开文件正常 = 文件句柄.打开文件 (文件目录_ + 日志文件, 文件打开方式.读写)

                }


                如果 (是否打开文件正常 == 真)
                {
                    文件句柄.移到文件尾 ()

                }

            }


        }


        变量 是否写出成功 <类型 = 逻辑型>
        如果 (是否打开文件正常 == 真)
        {
            变量 日期 <类型 = 小数>
            日期 = 取现行时间 ()
            变量 标识内容 <类型 = 文本型 值 = "{\"名称替换\":\"内容替换\"}">
            变量 格式文本 <类型 = 文本型>
            加入格式文本 (格式文本, 选择 (取小时 (日期) < 10, "0%u:", "%u:"), 取小时 (日期))
            加入格式文本 (格式文本, 选择 (取分钟 (日期) < 10, "0%u:", "%u:"), 取分钟 (日期))
            子文本替换 (标识内容, "名称替换", 标识名称_)
            子文本替换 (标识内容, "内容替换", 标识内容_)
            加入格式文本 (格式文本, 选择 (取秒 (日期) < 10, "0%u >%s\r\n", "%u >%s\r\n"), 取秒 (日期), 标识内容)
            是否写出成功 = 文件句柄.写出字节集 (文本到UTF8 (格式文本, 假))
            文件句柄.关闭文件 ()
            返回 (是否写出成功)

        }

        返回 (假)
    }
}

类 类_全局 <公开 折叠 折叠2 @文档 = "category = \"程序调试\"" @全局类 = 真>
{
    方法 全_信息框2 <公开 静态 类型 = 返回按钮类型 注释 = "显示一个信息框,等待用户单击按钮." 返回值注释 = "返回一个值告诉用户单击哪一个按钮."
            返回值注释 = "如果信息框有\"取消\"按钮,则按下 ESC 键与单击\"取消\"按钮的效果相同." 折叠 @禁止流程检查 = 真>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 按钮 <类型 = 整数 注释 = "由\"信息框按钮\"类中的各组常量值相加后的值,具体请见该类中的说明." @默认值 = 0>
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "信息:">
    {
        @ const HWND hOldFocusWnd = ::GetFocus ();
        @ const INT nResult = ::MessageBox (NULL, @<提示信息>, @<窗口标题>, @<按钮>);
        @ if (hOldFocusWnd != NULL && ::IsWindow (hOldFocusWnd))
        @     ::SetFocus (hOldFocusWnd);
        @ return nResult;
    }

    方法 字节集到集合文本 <公开 静态 类型 = 文本型 折叠>
    参数 调试内容 <类型 = 字节集类>
    {
        变量 文本 <类型 = 文本型>
        计次循环 (取字节集长度 (调试内容))
        {
            变量 临时 <类型 = 文本型>
            临时 = 到文本 (调试内容.取字节集数据 (取循环索引 (), 字节))
            加入文本 (文本, 临时)
            加入文本 (文本, ",")

        }

        文本 = 取文本左边 (文本, 取文本长度 (文本) - 1)
        返回 (文本)
    }

    方法 集合文本到字节集 <公开 静态 类型 = 字节集类 折叠>
    参数 字节集文本 <类型 = 文本型>
    {
        变量 临时文本 <类型 = 文本型>
        临时文本 = 字节集文本
        如果 (取文本左边 (临时文本, 1) == "{")
        {
            临时文本 = 取文本右边 (临时文本, 取文本长度 (临时文本) - 1)
        }
        如果 (取文本右边 (临时文本, 1) == "{")
        {
            临时文本 = 取文本左边 (临时文本, 取文本长度 (临时文本) - 1)

        }

        变量 储存 <类型 = 文本数组类>
        分割文本 (临时文本, ",", 储存)
        变量 临时字节 <类型 = 字节集类>
        计次循环 (储存.取成员数 ())
        {
            临时字节.添加值到字节集 (文本到整数 (储存.取成员 (取循环索引 ())))
            临时字节 = 取字节集左边 (临时字节, 取字节集长度 (临时字节) - 3)

        }

        返回 (临时字节)


    }

    方法 输出调试文本_新版 <公开 静态 折叠>
    参数 所欲输出的数据 <类型 = 文本型 注释 = "" 编辑时信息 = "B554A, 0, 0, 0">
    {
        调试输出 (所欲输出的数据)
        调试输出 ("注意：输出调试文本_新版为老版本命令。你在看课程的时候可以使用【调试输出】这个命令来替代【输出调试文本_新版】这个命令")
    }

    方法 取出内置资源文件_ <公开 静态 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 资源文件 <类型 = 视窗文件资源>
    {
        @ CVolMem memRes;
        @ do
        @     {
        @         const HRSRC hSrc = FindResource (GetModuleHandle (NULL), MAKEINTRESOURCE (@<资源文件>), RT_RCDATA);
        @         if (hSrc == NULL)
        @             break;
        @         const HGLOBAL hResData = LoadResource (NULL, hSrc);
        @         if (hResData == NULL)
        @             break;
        @ 
        @         const BYTE* pb = (const BYTE*)LockResource (hResData);
        @         if (pb != NULL)
        @         {
        @             memRes.CopyFrom (pb, (INT_P)SizeofResource (NULL, hSrc));
        @         }
        @ 
        @         UnlockResource (hResData);
        @         FreeResource (hResData);
        @     }
        @     while (FALSE);
        @  return memRes;


    }
}

类 类_全局锁 <公开 折叠>
