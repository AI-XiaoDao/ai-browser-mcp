类 类_系统杂项 <公开 折叠 折叠2 @视窗.外部头文件 = "nb30.h" @视窗.外部头文件 = "time.h" @全局类 = 真>
{
    方法 打开指定目录 <公开 折叠>
    参数 指定目录 <类型 = 文本型>
    {
        @  ShellExecute( NULL, _T("open"), (LPCTSTR)@<指定目录>, NULL, NULL, SW_SHOWNORMAL );
        // edit 用编辑器打开 lpFile 指定的文档,如果 lpFile 不是文档,则会失败
        // explore 浏览 lpFile 指定的文件夹
        // find 搜索 lpDirectory 指定的目录
        // open 打开 lpFile 文件,lpFile 可以是文件或文件夹
        // print 打印 lpFile,如果 lpFile 不是文档,则函数失败
        // properties 显示属性
        // runas 请求以管理员权限运行,比如以管理员权限运行某个exe
        // NULL 执行默认”open”动作
    }

    方法 取代码 <公开 类型 = 整数 @嵌入式方法 = "">
