    方法 根据进程名取进程路径 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 进程名称 <类型 = 文本型>
    {
        变量 临时数据 <类型 = 文本型>
        @ CU8String u8str (@<进程名称>.GetText ());
        @ const U8CHAR* szProcessName = u8str.GetText ();
        @ _getch();
        @    PROCESSENTRY32 pe32;
        @    pe32.dwSize = sizeof(pe32);
        @    HANDLE hSnapShot = CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
        @    if (hSnapShot == INVALID_HANDLE_VALUE)
        @    {
        @        return "";
        @    }
        @    BOOL bRet = Process32First(hSnapShot, &pe32);
        @    while(bRet)
        @    {
        @         CU8String szExeFile (pe32.szExeFile);
        @         const U8CHAR* szExeFileName = szExeFile.GetText ();
        @        if (_strnicmp(szProcessName, szExeFileName, strlen(szProcessName)) == 0)
        @        {
        @            hSnapShot = CreateToolhelp32Snapshot(TH32CS_SNAPMODULE, pe32.th32ProcessID);
        @            if (hSnapShot == INVALID_HANDLE_VALUE)
        @            {
        @                DWORD dwErr = GetLastError();
        @                return "";
        @            }
        @            MODULEENTRY32 me32;
        @            me32.dwSize = sizeof(MODULEENTRY32);
        @            if (!Module32First(hSnapShot, &me32))
        @            {
        @                DWORD dwErr = GetLastError();
        @                return "";
        @            }
        @            @<临时数据>.SetText (me32.szExePath);
        @            return @<临时数据>;
        @        }
        @        bRet = ::Process32Next(hSnapShot, &pe32);
        @    }
        @ return CVolString (GetWideText( szProcessName, CVolMem (), NULL)); 


    }

    方法 结束进程2 <公开 折叠>
    参数 进程名称 <类型 = 文本型>
    {
        变量 返回的进程信息 <类型 = 类_进程信息数组>
        枚举所有进程 (返回的进程信息)
        变量 循环变量 <类型 = 整数>
        循环 (0, 返回的进程信息.取成员数 (), 循环变量, 1)
        {
            变量 数据 <类型 = 类_进程信息数据>
            数据 = 返回的进程信息.取成员 (循环变量)
            如果 (数据.进程文件名 == 进程名称)
            {
                结束进程 (数据.进程ID)


            }

        }

    }
}

类 类_鼠键相关 <公开
