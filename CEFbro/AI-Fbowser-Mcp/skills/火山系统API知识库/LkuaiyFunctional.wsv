    方法 取指定进程ID_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        @ HANDLE hProcessSnap = ::CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS,NULL);
        @ PROCESSENTRY32 pe32;CWString ProcessName = @<进程名>,sProcessName;
        @ ProcessName.MakeLower ();
        @ if (hProcessSnap == INVALID_HANDLE_VALUE)
        @ { return -1; }
        @ pe32.dwSize = sizeof(pe32);
        @ BOOL bRet = ::Process32First(hProcessSnap,&pe32);
        @ while(bRet)
        @ {
        @ sProcessName=pe32.szExeFile;
        @ sProcessName.MakeLower();
        @ if (sProcessName == ProcessName)
        @ { ::CloseHandle(hProcessSnap); return pe32.th32ProcessID; }
        @ bRet = ::Process32Next(hProcessSnap,&pe32);
        @ }
        @ ::CloseHandle(hProcessSnap);
        @ return 0;
    }

    方法 进程是否存在 <公开 类型 = 逻辑型 折叠>
    参数 进程名 <类型 = 文本型>
    {
        返回 (取指定进程ID_ (进程名) != 0)
    }

    方法 枚举所有进程 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 返回的进程信息 <类型 = 类_进程信息数组>
    {
        变量 临时进程 <类型 = 类_进程信息数据>
        @  HANDLE hProcessSnap;
        @  HANDLE hProcess;
        @  PROCESSENTRY32 pe32;
        @  DWORD dwPriorityClass;
        @  hProcessSnap = CreateToolhelp32Snapshot( TH32CS_SNAPPROCESS, 0 );
        @  if( hProcessSnap == INVALID_HANDLE_VALUE ){return(FALSE);}
        @  pe32.dwSize = sizeof( PROCESSENTRY32 );
        @  if( !Process32First( hProcessSnap, &pe32 ) ){CloseHandle( hProcessSnap );return(FALSE);}
        @  do
        @  {
        @    dwPriorityClass = 0;
        @    hProcess = OpenProcess( PROCESS_ALL_ACCESS, FALSE, pe32.th32ProcessID );
        @    @<临时进程.进程文件名>.SetText (pe32.szExeFile);
        @    if(pe32.th32ProcessID!=0 && @<临时进程.进程文件名>!=_T(""))
        @    {
        临时进程 = (类_进程信息数据)新建对象 (类_进程信息数据)
        @        @<临时进程.进程ID>=pe32.th32ProcessID;
        @        @<临时进程.线程计数>=pe32.cntThreads;
        @        @<临时进程.父进程ID>=pe32.th32ParentProcessID;
        @        @<临时进程.线程优先权>=pe32.pcPriClassBase;
        @        @<临时进程.进程引用计数>=pe32.cntUsage;
        @        @<临时进程.结构的大小>=pe32.dwSize;
        @        @<临时进程.进程默认堆ID>=(@dt<整数>)pe32.th32DefaultHeapID;
        @        @<临时进程.进程模块ID>=pe32.th32ModuleID;
        @        @<临时进程.保留>=pe32.dwFlags;
        @        @<临时进程.进程文件名>=pe32.szExeFile;
        返回的进程信息.加入成员 (临时进程)
        @    ListProcessModules_LKY( pe32.th32ProcessID );
        @    ListProcessThreads_LKY( pe32.th32ProcessID );
        @    }
        @  } while( Process32Next( hProcessSnap, &pe32 ) );
        @  CloseHandle( hProcessSnap );
        @  return(TRUE);
    }

    方法 枚举进程ID下所有窗口句柄 <公开 类型 = 变整数数组类 返回值注释 = "返回该进程ID下的所有窗口" 折叠>
    参数 进程ID <类型 = 变整数>
    {
        变量 窗口句柄数组 <类型 = 变整数数组类>
        @ std::vector<HWND> vecHWnds;
        @ GetHWndsByProcessID_LKY(@<进程ID>, vecHWnds);
        @ for (const HWND &h : vecHWnds)
        @ {
        @     HWND parent = GetParent(h);
        @     if (parent != NULL)
        @     {
        变量 窗口ID <类型 = 变整数>
        @        @<窗口ID>=(@dt<变整数>)parent;
        窗口句柄数组.加入成员 (窗口ID)
        @     }
        @ }
        返回 (窗口句柄数组)

    }

    方法 窗口句柄取标题 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ char text[1024];
        @ GetWindowTextA((HWND)@<窗口句柄>, (LPSTR)text, 1024); // 必须含有标题文字
        @ return CVolString (GetWideText( text, CVolMem (), NULL)); 

    }

