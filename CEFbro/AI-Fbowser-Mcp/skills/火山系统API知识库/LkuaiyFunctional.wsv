    方法 取特定目录_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 目录类型 <类型 = 整数 注释 = "#define CSIDL_DESKTOP                   0x0000        // <desktop>"
            注释 = "#define CSIDL_INTERNET                  0x0001        // Internet Explorer (icon on desktop)"
            注释 = "#define CSIDL_PROGRAMS                  0x0002        // Start Menu\\Programs"
            注释 = "#define CSIDL_CONTROLS                  0x0003        // My Computer\\Control Panel"
            注释 = "#define CSIDL_PRINTERS                  0x0004        // My Computer\\Printers"
            注释 = "#define CSIDL_PERSONAL                  0x0005        // My Documents"
            注释 = "#define CSIDL_FAVORITES                 0x0006        // <user name>\\Favorites"
            注释 = "#define CSIDL_STARTUP                   0x0007        // Start Menu\\Programs\\Startup"
            注释 = "#define CSIDL_RECENT                    0x0008        // <user name>\\Recent"
            注释 = "#define CSIDL_SENDTO                    0x0009        // <user name>\\SendTo"
            注释 = "#define CSIDL_BITBUCKET                 0x000a        // <desktop>\\Recycle Bin"
            注释 = "#define CSIDL_STARTMENU                 0x000b        // <user name>\\Start Menu"
            注释 = "#define CSIDL_MYDOCUMENTS               CSIDL_PERSONAL //  Personal was just a silly name for My Documents"
            注释 = "#define CSIDL_MYMUSIC                   0x000d        // \"My Music\" folder"
            注释 = "#define CSIDL_MYVIDEO                   0x000e        // \"My Videos\" folder"
            注释 = "#define CSIDL_DESKTOPDIRECTORY          0x0010        // <user name>\\Desktop"
            注释 = "#define CSIDL_DRIVES                    0x0011        // My Computer"
            注释 = "#define CSIDL_NETWORK                   0x0012        // Network Neighborhood (My Network Places)"
            注释 = "#define CSIDL_NETHOOD                   0x0013        // <user name>\\nethood"
            注释 = "#define CSIDL_FONTS                     0x0014        // windows\\fonts"
            注释 = "#define CSIDL_TEMPLATES                 0x0015"
            注释 = "#define CSIDL_COMMON_STARTMENU          0x0016        // All Users\\Start Menu"
            注释 = "#define CSIDL_COMMON_PROGRAMS           0X0017        // All Users\\Start Menu\\Programs"
            注释 = "#define CSIDL_COMMON_STARTUP            0x0018        // All Users\\Startup"
            注释 = "#define CSIDL_COMMON_DESKTOPDIRECTORY   0x0019        // All Users\\Desktop"
            注释 = "#define CSIDL_APPDATA                   0x001a        // <user name>\\Application Data"
            注释 = "#define CSIDL_PRINTHOOD                 0x001b        // <user name>\\PrintHood" 折叠2 "">
    {
        @  TCHAR lpBuffer[1024] = {0};
        @ SHGetSpecialFolderPath(NULL,lpBuffer,@<目录类型>,false);
        @ return lpBuffer;

    }

