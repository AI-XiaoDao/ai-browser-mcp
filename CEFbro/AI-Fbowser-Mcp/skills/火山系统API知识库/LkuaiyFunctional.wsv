类 类_内存类 <公开 折叠>
{
    方法 内存_申请lky <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 内存大小 <类型 = 整数>
    {
        @ (INT64)new byte[@<内存大小>]
    }

    方法 内存_释放lky <公开 折叠 @嵌入式方法 = "">
    参数 内存指针 <类型 = 变整数>
    {
        @ delete [] (BYTE*)@<内存指针>
    }

    方法 内存_写文本lky <公开 折叠>
    参数 内存指针 <类型 = 变整数>
    参数 内容 <类型 = 文本型>
    {
        @ memcpy(@<内存指针>,@<内容>,@<内容>.Lenth())

    }

    #
}
