类 FOFHTTP_文件发送 <公开 折叠>
{
    方法 Get文件处理 <公开 类型 = 逻辑型 折叠>
    参数 来源对象 <类型 = FOFHTTP>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        如果 (寻找文本 (用户数据.HTTP_待发整理.文件路径, ".") != -1)
        {
            如果 (寻找文本 (用户数据.HTTP_待发整理.文件路径, "%") != -1)
            {
                如果 (来源对象.FOF配置项.是否运行中文文件名 == 真)
                {
                    变量 编码处理 <类型 = FOFHTTP_HTTP辅助>
                    用户数据.HTTP_待发整理.文件路径 = UTF8到文本 (编码处理.URL解码 (文本到UTF8 (用户数据.HTTP_待发整理.文件路径, 假)))

                }

            }

            如果 (来源对象.链接视图.视图是否存在 (用户数据.HTTP_待发整理.请求Url) == 真 || 来源对象.链接视图.视图是否存在 (用户数据.HTTP_待发整理.文件路径) == 真)
            {
                返回 (假)

            }

            变量 临时 <类型 = 字节集类>
            变量 是否成功 <类型 = 整数>
            变量 循环变量 <类型 = 整数>
            变量 原始文件路径 <类型 = 文本型>
            如果 (来源对象.取项目目录 ().取成员数 () >= 1)
            {
                如果 (来源对象.FOF配置项.发送目录遍历模式 == 1)
                {
                    循环 (0, 来源对象.取项目目录 ().取成员数 (), 循环变量, 1)
                    {
                        变量 临时路径 <类型 = 文本型>
                        如果 (来源对象.FOF配置项.绑定域名.取成员数 () >= 1)  // 如果是域名绑定目录,则以绑定目录为标准
                        {
                            加入文本 (临时路径, 来源对象.项目目录2)
                            加入文本 (临时路径, 用户数据.HTTP_待发整理.文件路径)
                        }
                        否则
                        {
                            加入文本 (临时路径, 来源对象.取项目目录 ().取成员 (循环变量))
                            加入文本 (临时路径, 用户数据.HTTP_待发整理.文件路径)
                        }
                        如果 (寻找文本 (临时路径, "\\\\") != -1)  // 替换可能出现的//双符号
                        {
                            子文本替换 (临时路径, "\\\\", "\\")

                        }
                        如果 (来源对象.FOF配置项.安全路径模式 == 真)
                        {
                            子文本替换 (临时路径, "..", "", , , )
                            子文本替换 (临时路径, ".&", "", , , )
                            子文本替换 (临时路径, ".%", "", , , )


                        }
                        是否成功 = 从文件读字节集 (临时, 临时路径)
                        如果 (是否成功 != -1)
                        {
                            原始文件路径 = 临时路径
                            跳出循环

                        }

                    }

                }

                如果 (来源对象.FOF配置项.发送目录遍历模式 == 2)
                {
                    变量 成员数 <类型 = 整数>
                    成员数 = 来源对象.取项目目录 ().取成员数 ()
                    循环 (0, 成员数, 循环变量, 1)
                    {
                        变量 临时路径 <类型 = 文本型>
                        如果 (来源对象.FOF配置项.绑定域名.取成员数 () >= 1)  // 如果是域名绑定目录,则以绑定目录为标准
                        {
                            加入文本 (临时路径, 来源对象.项目目录2)
                            加入文本 (临时路径, 用户数据.HTTP_待发整理.文件路径)
                        }
                        否则
                        {
                            加入文本 (临时路径, 来源对象.取项目目录 ().取成员 (成员数 - 循环变量 - 1))
                            加入文本 (临时路径, 用户数据.HTTP_待发整理.文件路径)

                        }
                        如果 (寻找文本 (临时路径, "\\\\") != -1)  // 替换可能出现的//双符号
                        {
                            子文本替换 (临时路径, "\\\\", "\\")

                        }
                        如果 (来源对象.FOF配置项.安全路径模式 == 真)
                        {
                            子文本替换 (临时路径, "..", "", , , )
                            子文本替换 (临时路径, ".&", "", , , )
                            子文本替换 (临时路径, ".%", "", , , )

                        }

                        是否成功 = 从文件读字节集 (临时, 临时路径)
                        如果 (是否成功 != -1)
                        {
                            原始文件路径 = 临时路径
                            跳出循环

                        }

                    }

                }

                如果 (是否成功 != -1)
                {
                    如果 (来源对象.FOF配置项.资源发送域名 != "")
                    {
                        变量 是否走资源模式 <类型 = 逻辑型 值 = 真>
                        如果 (来源对象.FOF配置项.不走资源发送域名路径.取成员数 () >= 1)
                        {
                            变量 路径变量 <类型 = 整数>
                            循环 (0, 来源对象.FOF配置项.不走资源发送域名路径.取成员数 (), 路径变量)
                            {
                                如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, 来源对象.FOF配置项.不走资源发送域名路径.取成员 (路径变量), , ) != -1)
                                {
                                    是否走资源模式 = 假
                                    跳出循环

                                }

                            }

                        }
                        如果 (是否走资源模式 == 真)
                        {
                            如果 (寻找文本 (用户数据.HTTP_Host, 来源对象.FOF配置项.资源发送域名头, , ) != -1)
                            {
                                是否走资源模式 = 假

                            }

                        }
                        如果 (是否走资源模式 == 真)
                        {
                            如果 (来源对象.FOF配置项.资源发送模式 == 0)
                            {
                                来源对象.发送301跳转 (服务句柄, 连接ID, 来源对象.FOF配置项.资源发送域名 + 用户数据.HTTP_待发整理.请求Url, 用户数据)
                                返回 (真)
                            }
                            如果 (来源对象.FOF配置项.资源发送模式 == 1)
                            {
                                如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, ".js", , ) == -1)
                                {
                                    来源对象.发送301跳转 (服务句柄, 连接ID, 来源对象.FOF配置项.资源发送域名 + 用户数据.HTTP_待发整理.请求Url, 用户数据)
                                    返回 (真)

                                }
                            }
                            如果 (来源对象.FOF配置项.资源发送模式 == 2)
                            {
                                如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, ".js", , ) == -1 && 寻找文本 (用户数据.HTTP_待发整理.请求Url, ".css", , ) == -1)
                                {
                                    来源对象.发送301跳转 (服务句柄, 连接ID, 来源对象.FOF配置项.资源发送域名 + 用户数据.HTTP_待发整理.请求Url, 用户数据)
                                    返回 (真)

                                }

                            }

                        }

                    }
                    用户数据.HTTP_待发整理.页面标记 = 用户数据.HTTP_待发整理.文件后缀
                    变量 文件处理 <类型 = FOFHTTP_HTTP辅助>
                    如果 (临时.取字节集长度 () >= 8200000)  // 大于5MB的文件,全部走下载大文件
                    {
                        如果 (来源对象.FOF配置项.安全路径模式 == 真)
                        {
                            子文本替换 (原始文件路径, "..", "", , , )
                            子文本替换 (原始文件路径, ".&", "", , , )
                            子文本替换 (原始文件路径, ".%", "", , , )

                        }
                        来源对象.发送下载大文件 (服务句柄, 连接ID, 原始文件路径, 文件处理.URL文本解码 (用户数据.HTTP_待发整理.文件名称), 用户数据)
                    }
                    否则
                    {
                        来源对象.发送页面数据 (服务句柄, 连接ID, 临时, 用户数据)

                    }

                    返回 (真)
                }
                否则
                {
                    返回 (假)

                }

            }
            否则
            {
                返回 (假)

            }

        }
        否则
        {
            返回 (假)

        }

    }

