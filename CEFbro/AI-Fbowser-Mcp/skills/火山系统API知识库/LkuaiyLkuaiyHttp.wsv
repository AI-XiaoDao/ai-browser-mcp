2;\r\n&Agrave;\t\r\n&#224;\r\n&agrave;\r\n&#34;\r\n&quot;\r\n&#38;\r\n&amp;\r\n&#60;\r\n&lt;\r\n&#62;\r\n&gt;\r\n&#160;\r\n&nbsp;">

    变量 UTF8_换行符 <公开 静态 类型 = 字节集类>
    变量 UTF8_转义符 <公开 静态 类型 = 字节集类>
    变量 UTF8_Cookie <公开 静态 类型 = 字节集类>
    变量 UTF8_404页面 <公开 静态 类型 = 字节集类>
    变量 UTF8_404漂亮页面 <公开 静态 类型 = 字节集类>
    变量 UTF8_404文件过大提示 <公开 静态 类型 = 字节集类>
    变量 UTF8_Post测试 <公开 静态 类型 = 字节集类>
    变量 UTF8_空文本 <公开 静态 类型 = 字节集类>
    变量 UTF8_单横线 <公开 静态 类型 = 字节集类>
    变量 UTF8_cookies开始 <公开 静态 类型 = 字节集类>
    变量 UTF8_cookies结束 <公开 静态 类型 = 字节集类>
    变量 Content_Type <静态 类型 = 字节集类 注释 = "Content-Type:">
    变量 UTF8_name_等号 <静态 类型 = 字节集类 注释 = "name=">
    变量 UTF8_双横线 <静态 类型 = 字节集类>
    变量 UTF8_WebKitForm分割 <静态 类型 = 字节集类>
    变量 UTF8_Get判断 <公开 静态 类型 = 字节集类 注释 = "GET / HTTP/1.1">

    方法 初始化常用常量 <公开 静态>
    {
        UTF8_cookies开始 = 文本到UTF8 ("fofcookie=fofhttpserverbegin", 假)

        UTF8_cookies结束 = 文本到UTF8 ("fofhttpserverend", 假)

        UTF8_换行符 = 文本到UTF8 (换行符, 假)

        UTF8_转义符 = 文本到UTF8 (HTML转义符, 假)

        UTF8_Cookie = 文本到UTF8 ("Cookie:", 假)

        Content_Type = 文本到UTF8 ("Content-Type:", 假)

        UTF8_name_等号 = 文本到UTF8 ("name=", 假)

        UTF8_双横线 = 文本到UTF8 ("--", 假)

        UTF8_WebKitForm分割 = 文本到UTF8 ("------WebKitForm", 假)

        UTF8_单横线 = 文本到UTF8 ("-", 假)

        UTF8_404页面 = 文本到UTF8 (错误404, 假)

        UTF8_404文件过大提示 = 文本到UTF8 (错误404文件过大提示, 假)

        UTF8_404漂亮页面 = 文本到UTF8 (错误漂亮404, 假)

        UTF8_Post测试 = 文本到UTF8 (Post测试, 假)

        UTF8_空文本 = 文本到UTF8 ("", 假)

        UTF8_Get判断 = 文本到UTF8 ("GET / HTTP/1.1", 假)


    }
}

类 FOFHTTP_Charset编码 <公开 折叠 @常量类 = 文本型>
{
