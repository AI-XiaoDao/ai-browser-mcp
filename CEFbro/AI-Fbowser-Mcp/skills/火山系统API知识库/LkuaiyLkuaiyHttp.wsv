    方法 Base64文本编码 <公开 类型 = 文本型 注释 = "将指定数据进行Base64编码." 返回值注释 = "返回编码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲编码数据 <类型 = 文本型 注释 = "提供所欲进行编码的数据.">
    {
        如果 (欲编码数据 == "")
        {
            返回 ("")
        }
        变量 编码数据 <类型 = 字节集类>
        编码数据 = 文本到UTF8 (欲编码数据, 假)
        编码数据 = HPSocket类.Base64编码 (编码数据)
        返回 (UTF8到文本 (编码数据))
    }

    方法 Base64文本解码 <公开 类型 = 文本型 注释 = "将指定数据进行Base64解码." 返回值注释 = "返回解码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲解码数据 <类型 = 文本型 注释 = "提供所欲进行解码的数据.">
    {
        如果 (欲解码数据 == "")
        {
            返回 ("")
        }
        变量 解码数据 <类型 = 字节集类>
        解码数据 = 文本到UTF8 (欲解码数据, 假)
        解码数据 = HPSocket类.Base64解码 (解码数据)
        返回 (UTF8到文本 (解码数据))
    }

    方法 URL文本编码 <公开 类型 = 文本型 注释 = "将指定数据进行URL编码." 返回值注释 = "返回编码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲编码数据 <类型 = 文本型 注释 = "提供所欲进行编码的数据.">
    {
        如果 (欲编码数据 == "")
        {
            返回 ("")

        }
        变量 编码文本 <类型 = 文本型>
        编码文本 = UTF8到文本 (URL编码 (文本到UTF8 (欲编码数据, 假)))
        返回 (编码文本)
    }

    方法 URL文本解码 <公开 类型 = 文本型 注释 = "将指定数据进行URL解码." 返回值注释 = "返回解码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲解码数据 <类型 = 文本型 注释 = "提供所欲进行解码的数据.">
    {
        如果 (欲解码数据 == "")
        {
            返回 ("")

        }
        变量 解码文本 <类型 = 文本型>
        解码文本 = UTF8到文本 (URL解码 (文本到UTF8 (欲解码数据, 假)))
        返回 (解码文本)


    }

    方法 中文转URL编码 <公开 类型 = 文本型 注释 = "本方法与URL文本编码不同，可以处理一些特殊编码文本数据" 折叠>
    参数 中文文本 <类型 = 文本型>
    {
        变量 对中文进行编码 <类型 = FOFHTTP_HTTP辅助>
        返回 (UTF8到文本 (对中文进行编码.URL编码 (文本到UTF8 (中文文本, 假))))







    }

    方法 URL编码 <公开 类型 = 字节集类 注释 = "将指定数据进行URL编码." 返回值注释 = "返回编码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲编码数据 <类型 = 字节集类 注释 = "提供所欲进行编码的数据.">
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到UTF8 ("")
        如果 (取字节集右边 (欲编码数据, 取字节集长度 (临时字节集)) == 临时字节集)
        {
            返回 (HPSocket类.URL编码 (欲编码数据))
        }
        否则
        {
            欲编码数据.添加字节集 (临时字节集)
            返回 (HPSocket类.URL编码 (欲编码数据))

        }

    }

    方法 URL解码 <公开 类型 = 字节集类 注释 = "将指定数据进行URL解码." 返回值注释 = "返回解码后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲解码数据 <类型 = 字节集类 注释 = "提供所欲进行解码的数据.">
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到UTF8 ("")
        如果 (取字节集右边 (欲解码数据, 取字节集长度 (临时字节集)) == 临时字节集)
        {
            返回 (HPSocket类.URL解码 (欲解码数据))
        }
        否则
        {
            欲解码数据.添加字节集 (临时字节集)
            返回 (HPSocket类.URL解码 (欲解码数据))

        }


    }

    方法 解析参数转中文 <公开 类型 = 文本型 注释 = "当解析参数属性的数据中有中文并是URL编码时，可以使用本命令" 折叠>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 是否尾零 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
        返回 (UTF8到文本 (HTTP辅助.URL解码 (文本到UTF8 (用户数据.HTTP_待发整理.解析参数, 是否尾零))))
    }

    #
    #
}

类 FOFHTTP_常用常量 <公开 折叠>
{
    变量 错误404 <静态 类型 = 文本型
            值 = "<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <title>404 错误 - phpstudy</title>\r\n  <meta name=\"keywords\" content=\"\">\r\n  <meta name=\"description\" content=\"\">\r\n  <meta name=\"renderer\" content=\"webkit\">\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\r\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black\"> \r\n  <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <meta HTTP-EQUIV=\"pragma\" CONTENT=\"no-cache\"> \r\n  <meta HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-store, must-revalidate\"> \r\n  <meta HTTP-EQUIV=\"expires\" CONTENT=\"Wed, 26 Feb 1997 08:21:57 GMT\"> \r\n  <meta HTTP-EQUIV=\"expires\" CONTENT=\"0\">\r\n  <style>\r\n    body{\r\n      font: 16px arial,\'Microsoft Yahei\',\'Hiragino Sans GB\',sans-serif;\r\n    }\r\n    h1{\r\n      margin: 0;\r\n      color:#3a87ad;\r\n      font-size: 26px;\r\n    }\r\n    .content{\r\n      width: 45%;\r\n      margin: 0 auto;\r\n     \r\n    }\r\n    .content >div{\r\n      margin-top: 50px;\r\n      padding: 20px;\r\n      background: #d9edf7;  \r\n      border-radius: 12px;\r\n    }\r\n    .content dl{\r\n      color: #2d6a88;\r\n      line-height: 40px;\r\n    } \r\n    .content div div {\r\n      padding-bottom: 20px;\r\n      text-align:center;\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n  <div class=\"content\">\r\n      <div>\r\n           <h1>404 - Page Not Found 未找到</h1>\r\n        <dl>\r\n          <dt>错误说明：请求的页面不存在</dt>\r\n          <dt>原因1：访问的文档权限不够</dt>\r\n\t\t  <dd>解决办法：</dd>\r\n          <dd>以管理员模式运行FOF的服务端程序。</dd>\r\n          <dt>原因2：防火墙的原因</dt>\r\n\t\t  <dd>解决办法：</dd>\r\n          <dd>先关闭让防火墙通过WWW服务。</dd>\r\n\t\t  <dt>原因3：没有成功加载HTML页面文件及URL</dt>\r\n\t\t  <dd>解决办法：</dd>\r\n          <dd>检查初始化目录下是否加载了URL及HTML页面。</dd>\r\n\t\t  <dt>原因4：站点配置目录不正确</dt>\r\n\t\t  <dd>解决办法：</dd>\r\n          <dd>检查初始化目录下的初始化目录路径是否正确。</dd>\r\n        </dl>\r\n        <div>使用手册，视频教程，BUG反馈，官网地址： <a href=\"https://www.lkuaiy.com\"  target=\"_blank\">www.lkuaiy.com</a> </div>\r\n      </div>\r\n    </div> \r\n</body>\r\n</html>">
    变量 错误404文件过大提示 <静态 类型 = 文本型
            值 = "<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <title>404 错误 - phpstudy</title>\r\n  <meta name=\"keywords\" content=\"\">\r\n  <meta name=\"description\" content=\"\">\r\n  <meta name=\"renderer\" content=\"webkit\">\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\r\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black\"> \r\n  <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <meta HTTP-EQUIV=\"pragma\" CONTENT=\"no-cache\"> \r\n  <meta HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-store, must-revalidate\"> \r\n  <meta HTTP-EQUIV=\"expires\" CONTENT=\"Wed, 26 Feb 1997 08:21:57 GMT\"> \r\n  <meta HTTP-EQUIV=\"expires\" CONTENT=\"0\">\r\n  <style>\r\n    body{\r\n      font: 16px arial,\'Microsoft Yahei\',\'Hiragino Sans GB\',sans-serif;\r\n    }\r\n    h1{\r\n      margin: 0;\r\n      color:#3a87ad;\r\n      font-size: 26px;\r\n    }\r\n    .content{\r\n      width: 45%;\r\n      margin: 0 auto;\r\n     \r\n    }\r\n    .content >div{\r\n      margin-top: 50px;\r\n      padding: 20px;\r\n      background: #d9edf7;  \r\n      border-radius: 12px;\r\n    }\r\n    .content dl{\r\n      color: #2d6a88;\r\n      line-height: 40px;\r\n    } \r\n    .content div div {\r\n      padding-bottom: 20px;\r\n      text-align:center;\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n  <div class=\"content\">\r\n      <div>\r\n           <h1>404 - 上传文件失败</h1>\r\n        <dl>\r\n          <dt>错误说明：上传的文件不能大于8M</dt>\r\n          <dt>原因1：上传的文件不能大于8M</dt>\r\n\t\t  <dd>解决办法：</dd>\r\n          <dd>重新上传小于8M的文件或者使用FOF配置项的模式3自行组装数据。</dd>\r\n        </dl>\r\n        <div>使用手册，视频教程，BUG反馈，官网地址： <a href=\"https://www.lkuaiy.com\"  target=\"_blank\">www.lkuaiy.com</a> </div>\r\n      </div>\r\n    </div> \r\n</body>\r\n</html>">
    变量 错误漂亮404 <静态 类型 = 文本型
            值 = "<!DOCTYPE html>\r\n<html lang=\"en\" >\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<title>404页面错误</title>\r\n</head>\r\n<body>\r\n\t<section class=\"center\">\r\n        <article>\r\n            <h1 class=\"header\">\r\n                404</h1>\r\n            <p class=\"error\">\r\n                ERROR</p>\r\n        </article>\r\n        <article>\r\n            <p>\r\n                ${404Text}</p>\r\n        </article>\r\n    </section>\r\n\r\n<style>\r\nbody\r\n\t{\r\n\t\tbackground-color: #0A7189;\r\n\t\tcolor: #fff;\r\n\t\tfont: 100% \"Lato\" , sans-serif;\r\n\t\tfont-size: 1.8rem;\r\n\t\tfont-weight: 300;\r\n\t}\r\n\t\r\n\ta\r\n\t{\r\n\t\tcolor: #75C6D9;\r\n\t\ttext-decoration: none;\r\n\t}\r\n\t\r\n\th3\r\n\t{\r\n\t\tmargin-bottom: 1%;\r\n\t}\r\n\t\r\n\tul\r\n\t{\r\n\t\tlist-style: none;\r\n\t\tmargin: 0;\r\n\t\tpadding: 0;\r\n\t\tline-height: 50px;\r\n\t}\r\n\t\r\n\tli a:hover\r\n\t{\r\n\t\tcolor: #fff;\r\n\t}\r\n\t\r\n\t.center\r\n\t{\r\n\t\ttext-align: center;\r\n\t}\r\n\t\r\n\t/* Search Bar Styling */\r\n\tform > *\r\n\t{\r\n\t\tvertical-align: middle;\r\n\t}\r\n\t\r\n\t.srchBtn\r\n\t{\r\n\t\tborder: 0;\r\n\t\tborder-radius: 7px;\r\n\t\tpadding: 0 17px;\r\n\t\tbackground: #e74c3c;\r\n\t\twidth: 99px;\r\n\t\tborder-bottom: 5px solid #c0392b;\r\n\t\tcolor: #fff;\r\n\t\theight: 65px;\r\n\t\tfont-size: 1.5rem;\r\n\t\tcursor: pointer;\r\n\t}\r\n\t\r\n\t.srchBtn:active\r\n\t{\r\n\t\tborder-bottom: 0px solid #c0392b;\r\n\t}\r\n\t\r\n\t.srchFld\r\n\t{\r\n\t\tborder: 0;\r\n\t\tborder-radius: 7px;\r\n\t\tpadding: 0 17px;\r\n\t\tmax-width: 404px;\r\n\t\twidth: 40%;\r\n\t\tborder-bottom: 5px solid #bdc3c7;\r\n\t\theight: 60px;\r\n\t\tcolor: #7f8c8d;\r\n\t\tfont-size: 19px;\r\n\t}\r\n\t\r\n\t.srchFld:focus\r\n\t{\r\n\t\toutline-color: rgba(255, 255, 255, 0);\r\n\t}\r\n\t\r\n\t/* 404 Styling */\r\n\t.header\r\n\t{\r\n\t\tfont-size: 13rem;\r\n\t\tfont-weight: 700;\r\n\t\tmargin: 2% 0 2% 0;\r\n\t\ttext-shadow: 0px 3px 0px #7f8c8d;\r\n\t}\r\n\t\r\n\t/* Error Styling */\r\n\t.error\r\n\t{\r\n\t\tmargin: -70px 0 2% 0;\r\n\t\tfont-size: 7.4rem;\r\n\t\ttext-shadow: 0px 3px 0px #7f8c8d;\r\n\t\tfont-weight: 100;\r\n\t}\r\n</style>\r\n</body>\r\n</html>">

    常量 Post测试 <类型 = 文本型
            值 = "<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n<head>\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\r\n<title>Post测试</title>\r\n</head>\r\n<body>\r\n<form name=\"uploadForm\" action=\"/ssds\"  method=\"POST\" enctype=\"multipart/form-data\"\r\n        action=\"/ProcessServer/FileOperate/fileUpServlet\">\r\n        Upload File1:<input type=\"file\" name=\"file1\" size=\"30\"/>\r\n        <input type=\"submit\" name=\"submit\" value=\"提交\">\r\n        <input type=\"reset\" name=\"reset\" value=\"重置\">\r\n     </form>\r\n</body>\r\n</noframes>\r\n</html>">
    常量 换行符 <公开 类型 = 文本型 值 = "\r\n">
    常量 HTML转义符 <公开 类型 = 文本型
