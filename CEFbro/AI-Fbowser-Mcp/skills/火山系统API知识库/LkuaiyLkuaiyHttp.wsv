    方法 发送页面数据 <公开 类型 = 逻辑型 注释 = "发送数据，用户发送浏览器直接显示的数据，必须页面、图片等小数据。大数据使用发送文件命令" 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 页面数据 <类型 = 字节集类 注释 = "HTML页面数据" 注释 = "注意：传递给本参数的字节集在本方法执行完毕后会被清空。" 折叠2>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 自定义协议头 <类型 = 文本数组类 注释 = "例如：Content-Encoding:gzip" @默认值 = 空对象>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 时间 <类型 = 类_时间辅助函数>
        变量 局_响应头 <类型 = 文本型>
        加入文本 (局_响应头, 内_HTTP版本)
        加入文本 (局_响应头, " 200 OK")
        加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        如果 (FOF配置项.长连接开启状态 == 真)
        {
            如果 (寻找文本 (到小写 (用户数据.HTTP_Connection), "keep-alive", , 真) != -1)
            {
                加入文本 (局_响应头, "Connection: Keep-Alive")
                加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
            }
            否则
            {
                加入文本 (局_响应头, "Connection: close")
                加入文本 (局_响应头, FOFHTTP_常用常量.换行符)

            }
        }
        否则
        {
            加入文本 (局_响应头, "Connection: close")
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        如果 (用户数据.HTTP_待发整理.文件后缀 == "html" || 用户数据.HTTP_待发整理.文件后缀 == "css" || 用户数据.HTTP_待发整理.文件后缀 == "js")
        {
            变量 循环变量 <类型 = 整数>
            循环 (0, 全局内容替换名称.取成员数 (), 循环变量)
            {
                如果 (寻找字节集 (页面数据, 文本到UTF8 (全局内容替换名称.取成员 (循环变量), 假), ) != -1)
                {
                    子字节集替换 (页面数据, 文本到UTF8 (全局内容替换名称.取成员 (循环变量), 假), 文本到UTF8 (全局内容替换内容.取成员 (循环变量), 假), , )

                }

            }
        }
        如果 (寻找文本 (到小写 (用户数据.HTTP_Accept_Encoding), "gzip") != -1)
        {
            页面数据 = 辅助.压缩数据_GZip (页面数据)
            加入文本 (局_响应头, "Content-Encoding: gzip")
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        如果 (自定义协议头.取成员数 () >= 1)
        {
            变量 循环变量 <类型 = 整数>
            循环 (0, 自定义协议头.取成员数 (), 循环变量)
            {
                加入文本 (局_响应头, 自定义协议头.取成员 (循环变量))
                加入文本 (局_响应头, FOFHTTP_常用常量.换行符)

            }
        }
        如果 (用户数据.HTTP_是否格林时间 == 真)
        {
            加入文本 (局_响应头, "Date: ")
            加入文本 (局_响应头, 时间.时间_取格林时间 ())
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        如果 (用户数据.HTTP_待发整理.协议头类 != "")
        {
            加入文本 (局_响应头, 用户数据.HTTP_待发整理.协议头类)
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        加入文本 (局_响应头, 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie))
        如果 (用户数据.HTTP_待发整理.缓存时间 >= 1)
        {
            加入文本 (局_响应头, "Cache-Control: max-age=")
            加入文本 (局_响应头, 到文本 (用户数据.HTTP_待发整理.缓存时间 * 60))
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
            加入文本 (局_响应头, "Expires:")
            加入文本 (局_响应头, 时间.时间_时间戳转格林 (时间.时间_取格林时间时间戳 () + 用户数据.HTTP_待发整理.缓存时间 * 60, ))
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        如果 (用户数据.HTTP_待发整理.页面标记 != "")
        {
            变量 标记 <类型 = 文本型 值 = "ETag: \"标记内容\"">
            变量 文本 <类型 = 类_文本操作>
            标记 = 文本.文本_替换 (标记, "标记内容", 用户数据.HTTP_待发整理.页面标记)
            加入文本 (局_响应头, 标记)
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
            加入文本 (局_响应头, "Last-Modified: ")
            加入文本 (局_响应头, 时间.时间_取格林时间 ())
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        加入文本 (局_响应头, "Content-Length: ")
        加入文本 (局_响应头, 到文本 (取字节集长度 (页面数据)))
        加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        加入文本 (局_响应头, 辅助.取文件协议类型 (用户数据.HTTP_待发整理.文件后缀, 内_文本编码))
        加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        如果 (FOF配置项.开启跨域模式 == 真)
        {
            加入文本 (局_响应头, "Access-Control-Allow-Origin: *")
            加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        }
        加入文本 (局_响应头, "Server: ")
        加入文本 (局_响应头, 内_服务名称)
        加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        加入文本 (局_响应头, FOFHTTP_常用常量.换行符)
        // 常规发送
        判断循环 (服务器.取未发出数据长度 (连接ID) > 0)
        {
            服务器.断开连接 (连接ID, 真)
            返回 (假)
        }
        变量 局_数据段 <类型 = 字节集类>
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        局_数据段.添加字节集 (页面数据)
        返回 (服务器.发送字节集 (服务句柄, 连接ID, 局_数据段))
    }

    方法 内部_通用数据发送 <类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 局_响应头 <类型 = 文本型>
    参数 发送数据 <类型 = 字节集类>
    {
        变量 局_数据段 <类型 = 字节集类>
        变量 发送长度 <类型 = 整数>
        变量 总共长度 <类型 = 整数>
        变量 临时字节数据 <类型 = 字节集类>
        判断循环 (服务器.取未发出数据长度 (连接ID) > 0)
        {
            服务器.断开连接 (连接ID, 真)
            返回 (假)

        }

        发送长度 = 400
        总共长度 = 取字节集长度 (发送数据)
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        临时字节数据 = 发送数据
        服务器.发送字节集 (服务句柄, 连接ID, 局_数据段)
        如果 (总共长度 <= 发送长度)
        {
            变量 是否成功 <类型 = 逻辑型>
            是否成功 = 服务器.发送字节集 (服务句柄, 连接ID, 临时字节数据)
            返回 (是否成功)
        }
        否则
        {
            变量 发送延时 <类型 = 整数>
            变量 是否发送成功 <类型 = 逻辑型>
            判断循环 (取字节集长度 (临时字节数据) >= 1)
            {
                如果 (服务器.取连接状态 (连接ID) == 假)
                {
                    是否发送成功 = 假
                    跳出循环

                }
                发送延时 = 发送延时 + 1
                如果 (取字节集长度 (临时字节数据) > 发送长度)
                {
                    如果 (服务器.发送字节集 (服务句柄, 连接ID, 临时字节数据.取字节集左边 (发送长度)) == 假)
                    {
                        是否发送成功 = 假
                        跳出循环

                    }

                    临时字节数据.字节集删除 (0, 发送长度)
                }
                否则
                {
                    如果 (服务器.发送字节集 (服务句柄, 连接ID, 临时字节数据) == 假)
                    {
                        是否发送成功 = 假
                        跳出循环

                    }

                    是否发送成功 = 真
                    跳出循环

                }

                如果 (发送延时 >= 4)
                {
                    发送延时 = 0
                    延时 (1)

                }

            }

            返回 (是否发送成功)

        }

    }

    方法 发送下载文件 <公开 类型 = 逻辑型 注释 = "如果用户下载文件，请直接使用本命令" 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16483422848569278" 折叠
            折叠2>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 文件数据 <类型 = 字节集类 注释 = "注意：传递给本参数的字节集在本方法执行完毕后会被清空。">
    参数 文件名称 <类型 = 文本型 注释 = "浏览器显示的下载的文件名称，例如：xxx.txt">
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 自定义协议头 <类型 = 文本数组类 注释 = "例如：Content-Encoding:gzip" @默认值 = 空对象>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 时间 <类型 = 类_时间辅助函数>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 内_HTTP版本 + " 200 OK" + FOFHTTP_常用常量.换行符
        如果 (FOF配置项.长连接开启状态 == 真)
        {
            如果 (寻找文本 (到小写 (用户数据.HTTP_Connection), "keep-alive", , 真) != -1)
            {
                局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符
            }
            否则
            {
                局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
            }
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }

        如果 (寻找文本 (到小写 (用户数据.HTTP_Accept_Encoding), "gzip") != -1)
        {
            文件数据 = 辅助.压缩数据_GZip (文件数据)
            局_响应头 = 局_响应头 + "Content-Encoding: gzip" + FOFHTTP_常用常量.换行符

        }
        如果 (自定义协议头.取成员数 () >= 1)
        {
            变量 循环变量 <类型 = 整数>
            循环 (0, 自定义协议头.取成员数 (), 循环变量)
            {
                局_响应头 = 局_响应头 + 自定义协议头.取成员 (循环变量) + FOFHTTP_常用常量.换行符

            }

        }

        如果 (用户数据.HTTP_是否格林时间 == 真)
        {
            局_响应头 = 局_响应头 + "Date: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }
        如果 (用户数据.HTTP_待发整理.协议头类 != "")
        {
            局_响应头 = 局_响应头 + 用户数据.HTTP_待发整理.协议头类 + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        如果 (用户数据.HTTP_待发整理.缓存时间 >= 1)
        {
            局_响应头 = 局_响应头 + "Cache-Control: max-age=" + 到文本 (用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Expires:" + 时间.时间_时间戳转格林 (时间.时间_取格林时间时间戳 () + 用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符

        }

        如果 (用户数据.HTTP_待发整理.页面标记 != "")
        {
            变量 标记 <类型 = 文本型 值 = "ETag: \"标记内容\"">
            变量 文本 <类型 = 类_文本操作>
            标记 = 文本.文本_替换 (标记, "标记内容", 用户数据.HTTP_待发整理.页面标记)
            局_响应头 = 局_响应头 + 标记 + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Last-Modified: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (取字节集长度 (文件数据)) + FOFHTTP_常用常量.换行符
        如果 (文件名称 == "")
        {
            局_响应头 = 局_响应头 + 辅助.取文件协议类型 (用户数据.HTTP_待发整理.文件后缀, 内_文本编码) + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Content-type: application/octet-stream" + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Content-Disposition: attachment; filename=" + 文件名称 + ";" + FOFHTTP_常用常量.换行符

        }

        如果 (FOF配置项.开启跨域模式 == 真)
        {
            局_响应头 = 局_响应头 + "Access-Control-Allow-Origin: *" + FOFHTTP_常用常量.换行符
        }
        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        返回 (内部_通用数据发送 (服务句柄, 连接ID, 局_响应头, 文件数据))
    }

    方法 发送下载大文件 <公开 类型 = 逻辑型 注释 = "如果用户下载文件，请直接使用本命令" 注释 = "参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16483424773868925"
            折叠 折叠2>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 文件路径 <类型 = 文本型 注释 = "要发送的文件全路径">
    参数 文件名称 <类型 = 文本型 注释 = "浏览器显示的下载的文件名称，例如：xxx.txt">
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 下载速度权重 <类型 = 整数 注释 = "越大下载越快【不建议超过10】" @默认值 = 4>
    参数 自定义协议头 <类型 = 文本数组类 注释 = "例如：Content-Encoding:gzip" @默认值 = 空对象>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 时间 <类型 = 类_时间辅助函数>
        变量 文件处理 <类型 = 文件读写类>
        变量 局_响应头 <类型 = 文本型>
        如果 (文件是否存在 (文件路径) == 假)
        {
            返回 (假)

        }
        文件处理.打开文件 (文件路径)
        局_响应头 = 内_HTTP版本 + " 200 OK" + FOFHTTP_常用常量.换行符
        如果 (FOF配置项.长连接开启状态 == 真)
        {
            如果 (寻找文本 (到小写 (用户数据.HTTP_Connection), "keep-alive", , 真) != -1)
            {
                局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符
            }
            否则
            {
                局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
            }
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }

        如果 (自定义协议头.取成员数 () >= 1)
        {
            变量 循环变量 <类型 = 整数>
            循环 (0, 自定义协议头.取成员数 (), 循环变量)
            {
                局_响应头 = 局_响应头 + 自定义协议头.取成员 (循环变量) + FOFHTTP_常用常量.换行符

            }

        }

        如果 (用户数据.HTTP_是否格林时间 == 真)
        {
            局_响应头 = 局_响应头 + "Date: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }
        如果 (用户数据.HTTP_待发整理.协议头类 != "")
        {
            局_响应头 = 局_响应头 + 用户数据.HTTP_待发整理.协议头类 + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        如果 (用户数据.HTTP_待发整理.缓存时间 >= 1)
        {
            局_响应头 = 局_响应头 + "Cache-Control: max-age=" + 到文本 (用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Expires:" + 时间.时间_时间戳转格林 (时间.时间_取格林时间时间戳 () + 用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符

        }

        如果 (用户数据.HTTP_待发整理.页面标记 != "")
        {
            变量 标记 <类型 = 文本型 值 = "ETag: \"标记内容\"">
            变量 文本 <类型 = 类_文本操作>
            标记 = 文本.文本_替换 (标记, "标记内容", 用户数据.HTTP_待发整理.页面标记)
            局_响应头 = 局_响应头 + 标记 + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Last-Modified: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (文件处理.取文件长度 ()) + FOFHTTP_常用常量.换行符
        如果 (文件名称 == "")
        {
            局_响应头 = 局_响应头 + 辅助.取文件协议类型 (用户数据.HTTP_待发整理.文件后缀, 内_文本编码) + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Content-type: application/octet-stream" + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Content-Disposition: attachment; filename=" + 文件名称 + ";" + FOFHTTP_常用常量.换行符

        }

        如果 (FOF配置项.开启跨域模式 == 真)
        {
            局_响应头 = 局_响应头 + "Access-Control-Allow-Origin: *" + FOFHTTP_常用常量.换行符
        }
        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        变量 局_数据段 <类型 = 字节集类>
        变量 发送长度 <类型 = 整数>
        发送长度 = 400
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        服务器.发送字节集 (服务句柄, 连接ID, 局_数据段)
        如果 (文件处理.取文件长度 () <= 发送长度)
        {
            文件处理.关闭文件 ()
            返回 (服务器.发送字节集 (服务句柄, 连接ID, 读入文件 (文件路径)))
        }
        否则
        {
            变量 剩余长度 <类型 = 整数>
            变量 当前位置 <类型 = 整数>
            变量 读取长度 <类型 = 整数>
            变量 是否发送成功 <类型 = 逻辑型 值 = 假>
            剩余长度 = (整数)文件处理.取文件长度 ()
            变量 发送延时 <类型 = 整数>
            判断循环 (是否发送成功 == 假)
            {
                如果 (服务器.取连接状态 (连接ID) == 假)
                {
                    是否发送成功 = 假
                    跳出循环

                }
                发送延时 = 发送延时 + 1

                如果 (剩余长度 > 发送长度)
                {
                    当前位置 = 当前位置 + 发送长度
                    读取长度 = 发送长度
                    如果 (服务器.发送字节集 (服务句柄, 连接ID, 文件处理.读入字节集 (读取长度)) == 假)
                    {
                        是否发送成功 = 假
                        跳出循环

                    }
                    如果 (发送延时 >= 下载速度权重)
                    {
                        发送延时 = 0
                        延时 (1)

                    }

                }
                否则
                {
                    当前位置 = 当前位置 + 剩余长度
                    读取长度 = 取整 (剩余长度)
                    如果 (服务器.发送字节集 (服务句柄, 连接ID, 文件处理.读入字节集 (读取长度)) == 假)
                    {
                        是否发送成功 = 假
                        跳出循环

                    }

                    如果 (发送延时 >= 下载速度权重)
                    {
                        发送延时 = 0
                        延时 (1)

                    }

                    是否发送成功 = 真
                    跳出循环

                }


                剩余长度 = 剩余长度 - 读取长度
                文件处理.移动读写位置 (, 0)
                文件处理.移动读写位置 (, 当前位置)

            }


            文件处理.关闭文件 ()
            返回 (是否发送成功)

        }

    }

    方法 发送提示信息框 <公开 类型 = 逻辑型 注释 = "发送提示信息框给用户" 折叠 "">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 提示内容 <类型 = 文本型 注释 = "HTML页面数据">
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        返回 (发送页面数据 (服务句柄, 连接ID, 文本到UTF8 ("<script language=javascript>alert('" + 提示内容 + "');history.back();</script>", 假), 用户数据))
    }

    方法 发送跳出父框架 <公开 类型 = 逻辑型 注释 = "iframe 子页面让父页面跳转" 折叠 "">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 跳转地址 <类型 = 文本型 注释 = "HTML页面数据">
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        返回 (发送页面数据 (服务句柄, 连接ID, 文本到UTF8 ("<script language=javascript>window.parent.location.href='" + 跳转地址 + "';</script>", 假), 用户数据))
    }

    方法 压力测试发送 <公开 类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        变量 测试 <类型 = 文本型 值 = "HTTP/1.1 200 OK\r\nConnection: close\r\nContent-Type: text/html\r\nContent-Length: 长度替换\r\n\r\n">
        子文本替换 (测试, "长度替换", 到文本 (取文本长度 ("Server Int Cc")), , , 真)
        测试 = 测试 + "Server Int Cc"
        返回 (服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (测试, 假)))
    }

    # //发送方法===
}

类 FOFHTTPS <公开 基础类 = FOFHTTP基类 折叠>
{

    # //属性定义===

    方法 编码方式 <公开 属性写 折叠>
    参数 Charset编码 <类型 = FOFHTTP_Charset编码 注释 = "默认：(FOFHTTP_Charset编码.utf-8),详情参考FOFHTTP_Charset编码"
            @默认值 = FOFHTTP_Charset编码.utf_8>
    {
        如果 (Charset编码 == FOFHTTP_Charset编码.utf_8)
        {
            内_文本编码 = "charset=utf-8"
        }
        如果 (Charset编码 == FOFHTTP_Charset编码.big5)
        {
            内_文本编码 = "charset=big5"
        }
        如果 (Charset编码 == FOFHTTP_Charset编码.euc_kr)
        {
            内_文本编码 = "charset=euc-kr"
        }
        如果 (Charset编码 == FOFHTTP_Charset编码.gb2312)
        {
            内_文本编码 = "text/html;charset=gb2312"
        }
        如果 (Charset编码 == FOFHTTP_Charset编码.iso_8859_1)
        {
            内_文本编码 = "charset=iso-8859-1"

        }

    }

    # //属性定义===
    #
    # //启动相关===

    方法 初始化HTTP服务 <公开 注释 = "本方法只需要执行一次，如果使用了销毁服务器命令则必须再次执行本命令" 折叠>
    参数 验证模式 <类型 = HPSSL验证模式 注释 = "指定当前SSL验证模式." @默认值 = HPSSL验证模式.无验证>
    参数 证书文件 <类型 = 文本型 注释 = "提供所欲使用的证书文件内容." @默认值 = "">
    参数 私钥文件 <类型 = 文本型 注释 = "提供所欲使用的私钥文件内容." @默认值 = "">
    参数 私钥密码 <类型 = 文本型 注释 = "提供所欲使用的私钥密码,如无密码可为空." @默认值 = "">
    参数 CA证书 <类型 = 文本型 注释 = "CA证书内容." @默认值 = "">
    参数 SNI回调 <类型 = 变整数 注释 = "SNI回调函数指针(可选,如果为0则使用SNI默认回调函数)." @默认值 = 0>
    {
        服务器_HTTPS.初始化SSL环境_内存 (验证模式, 证书文件, 私钥文件, 私钥密码, CA证书, SNI回调)
        JSONCPP基础类.启用线程安全 ()
        高性能缓存表.置保存路径 (取运行目录 () + "缓存表")
    }

    方法 启动HTTP服务 <公开 类型 = 逻辑型>
    参数 服务器地址 <类型 = 文本型 注释 = "欲绑定的服务端IP地址。默认0.0.0.0" @默认值 = "0.0.0.0">
    参数 服务器端口 <类型 = 整数 注释 = "欲绑定的服务端端口" @默认值 = 9550>
    参数 最大连接数 <类型 = 整数 注释 = "服务端允许接受客户连接请求的最大数量。（单位：个）数量跟服务器配置相关自行测试" @默认值 = 1000>
    参数 Charset编码 <类型 = FOFHTTP_Charset编码 注释 = "默认：(FOFHTTP_Charset编码.utf-8),详情参考FOFHTTP_Charset编码"
            @默认值 = FOFHTTP_Charset编码.utf_8>
    参数 服务_名称 <类型 = 文本型 注释 = "内_服务名称，默认FOFHTTP框架,尽量不要使用中文" @默认值 = "FOFHTTP">
    参数 超时时间 <类型 = 整数 注释 = "默认超时5秒断开" @默认值 = 5000>
    参数 最大线程 <类型 = 整数 注释 = "服务端同一时刻内处理的最大并发数量" 注释 = "通常设置为 2 * CPU + 2硬件性能决定线程并发能力。" 注释 = "推荐默认或者100个线程以内。 CPU：代表处理器数量（单位：个）"
            注释 = "默认为" 折叠2 @默认值 = 10>
    参数 防火墙 <类型 = FOFHTTP_防火墙 注释 = "默认为空，空代表不启动" @默认值 = 空对象>
    参数 服务器配置 <类型 = FOFHTTP_配置项 注释 = "详情参考FOFHTTP_配置项类，默认空对象" @默认值 = 空对象>
    {
        变量 FOF牢记 <类型 = 文本型
                值 = "学习本框架请一定加入官方群：445790831，群里提问请友善一点\r\n本FOF版本：2024-05-04更新\r\n注意：请勿使用FOF开发任何违反国家法律法规的项目。\r\nFOF是一款完全开源的产品，使用FOF完全是用户自身的个人行为，与FOF作者无关。">
        调试输出 (FOF牢记)
        FOFHTTP_常用常量.初始化常用常量 ()
        编码方式 = Charset编码
        内_服务名称 = 服务_名称
        内_HTTP版本 = "HTTP/1.1"
        如果 (防火墙 != 空对象)
        {
            全_防火墙 = 防火墙
            如果 (全_防火墙.设置启动 == 真)
            {
                调试输出 ("启动防火墙成功")

            }
        }
        服务器_HTTPS.设置工作线程数量 (全_服务句柄, 最大线程)
        服务器_HTTPS.设置最大连接数 (全_服务句柄, 最大连接数)
        服务器_HTTPS.断开静默连接_ (全_服务句柄, 5000, 假)
        如果 (服务器配置.全局内容替换.成员数 >= 1)
        {
            服务器配置.全局内容替换.取所有键名 (全局内容替换名称)
            变量 循环变量 <类型 = 整数>
            循环 (0, 全局内容替换名称.取成员数 (), 循环变量)
            {
                全局内容替换内容.加入成员 (服务器配置.全局内容替换.取文本值 (全局内容替换名称.取成员 (循环变量)))

            }

        }

        如果 (服务器_HTTPS.断开超时连接_ (全_服务句柄, 超时时间, 假) == 真)
        {
            调试输出 ("设置超时断开连接成功，当前时间：" + 到文本 (超时时间) + "毫秒")
        }
        否则
        {
            调试输出 ("设置超时断开连接失败")
        }
        如果 (服务器_HTTPS.启动服务 (全_服务句柄, 服务器地址, (短整数)服务器端口) == 真)
        {
            调试输出 ("启动利快云服务器成功")
        }
        否则
        {
            调试输出 ("启动利快云服务器失败")
            返回 (假)
        }
        全_服务句柄 = 服务器_HTTPS.属性_服务器句柄
        如果 (服务器配置 != 空对象)
        {
            服务器配置.当前模式 = 2  // 默认为2
            初始化基类 (服务器配置)
        }
        否则
        {
            变量 空配置 <类型 = FOFHTTP_配置项>
            初始化基类 (空配置)

        }

        删除目录 (取运行目录 () + "fofByte\\", 目录删除模式.全部删除)
        内_当前服务类型 = 2
        变量 循环次数 <类型 = 整数>
        判断循环 (文件是否存在 (取运行目录 () + "fofByte\\") == 假)
        {
            创建目录 (取运行目录 () + "fofByte\\")
            如果 (循环次数 >= 1000)
            {
                跳出循环

            }

        }
        如果 (文件是否存在 (取运行目录 () + "fofByte\\") == 假)
        {
            返回 (假)

        }

        返回 (真)
    }

    方法 结束HTTP服务 <公开 类型 = 逻辑型 注释 = "使用本命令后可以再次直接使用启动服务来进行启动" 折叠>
    {
        // 这里就要开始进行触发IP信息的写出
        变量 是否成功 <类型 = 逻辑型>
        是否成功 = 服务器_HTTPS.关闭服务 (全_服务句柄)
        返回 (是否成功)
    }

    方法 销毁HTTP服务 <公开 注释 = "使用本命令后如果需要再次使用服务，必须进行一次初始化HTTP服务并启动HTTP服务" 折叠>
    {
        服务器_HTTPS.关闭服务 (全_服务句柄)
    }

    方法 断开服务客户 <公开 类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = "变整数 ">
    {
        返回 (服务器_HTTPS.主动断开连接 (服务句柄, 连接ID))
    }

    # //启动相关===
    # //属性方法===

    方法 取项目目录 <公开 类型 = 文本数组类 折叠>
    {
        返回 (内_项目目录)
    }

    方法 项目目录 <公开 属性写 注释 = "项目文件的装载目录，可以重复使用本命令添加不同的项目路径，可以通过“取项目目录()”这个命令来获取所有的路径" 折叠>
    参数 目录路径 <类型 = 文本型>
    {
        内_项目目录.加入成员 (目录路径)
    }

    方法 项目目录 <公开 属性读 类型 = 文本型 注释 = "项目文件的装载目录,默认是直接返回项目目录数组的最后一个成员，也就是最后一次设置的项目路径" 折叠>
    {
        如果 (内_项目目录.取成员数 () >= 1)
        {
            返回 (内_项目目录.取成员 (内_项目目录.取成员数 () - 1))
        }
        否则
        {
            返回 ("")

        }

    }

    方法 项目目录2 <公开 属性读 类型 = 文本型 注释 = "项目文件的装载目录,返回第一位项目目录,如果使用了\"域名绑定项目目录\"命令，则需要使用本命令"
            注释 = "因为使用了\"域名绑定项目目录\"后，会根据协议头的host自动将当前域名的目录提升到第一位" 折叠 折叠2>
    {
        如果 (内_项目目录.取成员数 () >= 1)
        {
            返回 (内_项目目录.取成员 (0))
        }
        否则
        {
            返回 ("")

        }

    }

    方法 域名绑定项目目录 <公开 注释 = "项目文件的装载目录，可以重复使用本命令添加不同的项目路径，可以通过“取项目目录()”这个命令来获取所有的路径" 注释 = "注意：与“属性写”的项目目录对比，本命令可以直接给域名绑定项目目录"
            注释 = "参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16483468270748346" 注释 = "注意:必须开启FOF_配置项.绑定域名  属性才可以使用本命令！" 折叠 折叠2>
    参数 目录路径 <类型 = 文本型>
    参数 项目域名 <类型 = 文本型 注释 = "如果设置了FOF配置项的绑定域名属性，则这里需要表明对应的哪一个域名的项目目录；否则留空即可" 注释 = "注意：一个域名只能绑定一个目录！"
            注释 = "注意：必须设置了FOF配置项的绑定域名属性，这里才会生效，否则输入了也无效！" 折叠2 @默认值 = "">
    {
        内_项目目录.加入成员 (目录路径)
        如果 (项目域名 != "")
        {
            内_项目目录域名.插入 (项目域名, 目录路径)

        }
    }

    方法 清空项目目录 <公开 折叠>
    {
        内_项目目录.删除所有成员 ()
    }

    方法 路径文件是否存在 <公开 类型 = 逻辑型 折叠>
    参数 文件路径 <类型 = 文本型 注释 = "用户数据.HTTP_待发整理.文件路径">
    {
        变量 循环变量 <类型 = 整数>
        循环 (0, 取项目目录 ().取成员数 (), 循环变量, 1)
        {
            如果 (FOF配置项.发送目录遍历模式 == 1)
            {
                循环 (0, 取项目目录 ().取成员数 (), 循环变量, 1)
                {
                    变量 临时路径 <类型 = 文本型>
                    临时路径 = 取项目目录 ().取成员 (循环变量) + 文件路径
                    如果 (寻找文本 (临时路径, "\\\\") != -1)
                    {
                        子文本替换 (临时路径, "\\\\", "\\")

                    }
                    如果 (文件是否存在 (临时路径) == 真)
                    {
                        返回 (真)

                    }

                }

            }
            如果 (FOF配置项.发送目录遍历模式 == 2)
            {
                变量 成员数 <类型 = 整数>
                成员数 = 取项目目录 ().取成员数 ()
                循环 (0, 成员数, 循环变量, 1)
                {
                    变量 临时路径 <类型 = 文本型>
                    临时路径 = 取项目目录 ().取成员 (成员数 - 循环变量 - 1) + 文件路径
                    如果 (寻找文本 (临时路径, "\\\\") != -1)
                    {
                        子文本替换 (临时路径, "\\\\", "\\")

                    }
                    如果 (文件是否存在 (临时路径) == 真)
                    {
                        返回 (真)

                    }

                }

            }


        }
        返回 (假)
    }

    #
    # //属性方法===
    # //通常方法===

