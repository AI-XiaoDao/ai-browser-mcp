    方法 发送404页面错误 <公开 类型 = 逻辑型 注释 = "404 页面不存在 HTTP/1.1 404 Not Found  可以自定义错误页面" 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 页面数据 <类型 = 字节集类 注释 = "HTML页面数据" @默认值 = 空对象>
    参数 用户数据 <类型 = FOFHTTP_用户数据 注释 = "cookies 包括 设置文本,有效时间,有效目录三个参数">
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 局_响应头 + 内_HTTP版本 + " 404 Not Found" + FOFHTTP_常用常量.换行符
        如果 (寻找文本 (用户数据.HTTP_Connection, "Keep-Alive", , 真) == -1)
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Content-Type: text/html" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        如果 (页面数据 == 空对象)
        {
            页面数据 = FOFHTTP_常用常量.UTF8_404页面

        }

        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (取字节集长度 (页面数据)) + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        // 常规发送
        判断循环 (服务器_HTTPS.取未发出数据长度 (连接ID) > 0)
        {
            服务器_HTTPS.断开连接 (连接ID, 真)
            返回 (假)
        }

        变量 局_数据段 <类型 = 字节集类>
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        局_数据段.添加字节集 (页面数据)
        返回 (服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 局_数据段))

    }

    方法 发送404漂亮页面 <公开 类型 = 逻辑型 注释 = "404 页面不存在 HTTP/1.1 404 Not Found  可以自定义错误页面" 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 页面提示 <类型 = 文本型 注释 = "页面的提示内容，本方法与发送404页面错误不同，本方法必须内置一段话语">
    参数 用户数据 <类型 = FOFHTTP_用户数据 注释 = "cookies 包括 设置文本,有效时间,有效目录三个参数">
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 局_响应头 + 内_HTTP版本 + " 404 Not Found" + FOFHTTP_常用常量.换行符
        如果 (寻找文本 (用户数据.HTTP_Connection, "Keep-Alive", , 真) == -1)
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Content-Type: text/html" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        变量 页面数据 <类型 = 字节集类>
        页面数据 = FOFHTTP_常用常量.UTF8_404漂亮页面
        页面数据 = 辅助.解析标签 (页面数据, "404Text", 页面提示)
        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (取字节集长度 (页面数据)) + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        // 常规发送
        判断循环 (服务器_HTTPS.取未发出数据长度 (连接ID) > 0)
        {
            服务器_HTTPS.断开连接 (连接ID, 真)
            返回 (假)
        }

        变量 局_数据段 <类型 = 字节集类>
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        局_数据段.添加字节集 (页面数据)
        返回 (服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 局_数据段))

    }

    方法 发送500错误 <公开 类型 = 逻辑型 注释 = "HTTP/1.1 500 Internal Server Error" 折叠>
    参数 服务句柄 <类型 = 变整数>
