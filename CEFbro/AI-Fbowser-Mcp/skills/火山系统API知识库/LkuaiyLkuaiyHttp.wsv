    方法 解析GetPost请求 <公开 类型 = FOFHTTP_待发资料 注释 = "传输一个URL，解析出【FOFHTTP_待发资料】数据" 折叠>
    参数 请求Url <类型 = 文本型>
    {
        变量 文本 <类型 = 类_文本操作>
        变量 解析类 <类型 = FOFHTTP_待发资料>
        变量 URL解析 <类型 = FOFHTTP_URL处理类>
        URL解析.创建2 (请求Url)
        解析类.URL路径 = URL解析.取路径 ()
        解析类.请求Url = 请求Url
        解析类.解析参数 = ""
        解析类.文件路径 = ""
        解析类.请求Url = 删首尾空 (解析类.请求Url)
        解析类.文件路径 = 解析类.请求Url
        变量 路径 <类型 = 文本型 值 = "\\">
        变量 问号位置 <类型 = 整数>
        子文本替换 (解析类.文件路径, "/", 路径)
        解析类.文件路径 = 删首尾空 (解析类.文件路径)
        如果 (解析类.请求Url == "")
        {
            返回 (解析类)
        }
        问号位置 = 寻找文本 (解析类.文件路径, "?")  // 处理带参数URL(类似带参数css和js),不然会找不到文件
        如果 (问号位置 != -1 && 寻找文本 (解析类.文件路径, ".") != -1)
        {
            解析类.文件路径 = 取文本左边 (解析类.文件路径, 问号位置)
        }
        解析类.文件后缀 = 文本.文本_取右边 (解析类.文件路径, ".")
        解析类.文件后缀 = 删首尾空 (解析类.文件后缀)
        解析类.解析参数 = 文本.文本_取右边 (请求Url, "?")
        解析类.解析参数 = 删首尾空 (解析类.解析参数)
        如果 (寻找文本 (解析类.文件路径, ".") != -1)
        {
            如果 (寻找文本 (解析类.文件路径, "\\") != -1)
            {
                解析类.文件名称 = 取地址文件名称 (解析类.文件路径)

            }
        }
        如果 (寻找文本 (解析类.解析参数, "=") == -1)
        {
            解析类.解析参数 = ""

        }

        返回 (解析类)
    }

    方法 重置解析参数 <公开 类型 = 文本型 注释 = "重新将URL变成解析参数" 返回值注释 = "返回重置后的解析参数" 折叠>
