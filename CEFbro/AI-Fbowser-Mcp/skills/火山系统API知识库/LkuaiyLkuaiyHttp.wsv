    方法 Cookie类到Cookie文本 <公开 类型 = 文本型 折叠>
    参数 Cookie <类型 = FOFHTTP_Cookies>
    {
        变量 Cookie设置 <类型 = 文本型>
        变量 设置目录 <类型 = 文本型>
        变量 设置时间 <类型 = 文本型>
        变量 Cookie数据 <类型 = 文本型>
        变量 时间 <类型 = 类_时间辅助函数>
        设置时间 = Cookie.格林到期时间
        设置目录 = Cookie.设置目录
        Cookie数据 = Cookie.临时Cookie

        如果 (Cookie数据 == "")
        {
            返回 ("")

        }

        如果 (设置目录 == "")
        {
            设置目录 = "/"

        }

        变量 SameSite文本 <类型 = 文本型>
        如果 (Cookie.SameSite_Secure开启状态 == 真)
        {
            SameSite文本 = "; Secure; SameSite=None"

        }

        如果 (Cookie数据 != "")
        {
            变量 请求平台 <类型 = 整数>
            请求平台 = 判断请求平台 (Cookie.协议头数据)
            如果 (请求平台 == 2 || 请求平台 == 3 || 请求平台 == 4 || 请求平台 == 5)
            {
                如果 (设置时间 == "")
                {
                    如果 (SameSite文本 != "")
                    {
                        Cookie设置 = "Set-Cookie: CookieName=" + Cookie数据 + "; path=" + 设置目录 + SameSite文本 + FOFHTTP_常用常量.换行符
                    }
                    否则
                    {
                        Cookie设置 = "Set-Cookie: CookieName=" + Cookie数据 + "; path=" + 设置目录 + "; SameSite=Lax;" + SameSite文本 + FOFHTTP_常用常量.换行符

                    }

                }
                否则
                {
                    如果 (SameSite文本 != "")
                    {
                        Cookie设置 = "Set-Cookie: CookieName=" + Cookie数据 + "; expires=" + 设置时间 + "; path=" + 设置目录 + SameSite文本 + FOFHTTP_常用常量.换行符
                    }
                    否则
                    {
                        Cookie设置 = "Set-Cookie: CookieName=" + Cookie数据 + "; expires=" + 设置时间 + "; path=" + 设置目录 + "; SameSite=Lax;" + SameSite文本 + FOFHTTP_常用常量.换行符
                        // Cookie设置 = "Set-Cookie: CookieName=" + Cookie数据 + ";expires=" + 设置时间 + ";path=/ " + FOFHTTP_常用常量.换行符
                        调试输出 (111222, Cookie设置, 设置时间)

                    }

                }


            }
            否则
            {
                如果 (设置时间 == "")
                {
                    Cookie设置 = "Set-Cookie: " + Cookie数据 + "; path=" + 设置目录 + SameSite文本 + FOFHTTP_常用常量.换行符
                }
                否则
                {
                    Cookie设置 = "Set-Cookie: " + Cookie数据 + "; expires=" + 设置时间 + "; path=" + 设置目录 + SameSite文本 + FOFHTTP_常用常量.换行符

                }

            }

        }
        否则
        {
            返回 ("")

        }

        返回 (Cookie设置)


    }

    方法 判断是否为Safari浏览器 <公开 类型 = 逻辑型 折叠>
    参数 协议头部 <类型 = 文本型>
    {
        如果 (寻找文本 (协议头部, "Safari", , 假) != -1 && 寻找文本 (协议头部, "Windows", , 真) == -1)
        {
            返回 (真)
        }
        否则
        {
            返回 (假)

        }


    }

    方法 判断是否为微信浏览器 <公开 类型 = 逻辑型 折叠>
    参数 协议头部 <类型 = 文本型>
    {
        如果 (寻找文本 (协议头部, "MicroMessenger", , 真) != -1)
        {
            返回 (真)
        }
        否则
        {
            返回 (假)

        }


    }

    方法 判断请求平台 <公开 类型 = 整数 返回值注释 = "返回1为安卓手机，返回2为苹果手机，返回3代表为ios系统的终端设备，返回4代表是否为iPad，返回5代表是否为Safari系列WEB，返回0为WIN或其他平台" 折叠>
    参数 协议头部 <类型 = 文本型>
    {
        如果 (寻找文本 (协议头部, "Android", , 真) != -1)
        {
            返回 (1)
        }
        如果 (寻找文本 (协议头部, "iPhone", , 真) != -1)
        {
            返回 (2)
        }
        如果 (寻找文本 (协议头部, "Mac OS X", , 真) != -1)
        {
            返回 (3)
        }
        如果 (寻找文本 (协议头部, "iPad", , 真) != -1)
        {
            返回 (4)
        }
        如果 (寻找文本 (协议头部, "Safari", , 真) != -1 && 寻找文本 (协议头部, "Windows", , 真) == -1)
        {
            返回 (5)
        }

        返回 (0)
    }

    方法 压缩数据 <公开 类型 = 字节集类 注释 = "对指定数据进行Zlib压缩." 返回值注释 = "返回被压缩后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲压缩数据 <类型 = 字节集类 注释 = "提供所欲压缩的数据.">
    参数 压缩级别 <类型 = 整数 注释 = "0-9之间,级别越高压缩率越大,相应的压缩时间会变长." @默认值 = -1>
    参数 压缩位数 <类型 = 整数 注释 = "8-15,表示处理raw deflate的方法." @默认值 = 15>
    参数 压缩状态 <类型 = 整数 注释 = "指定分配内存的等级,1-9之间,1会使用最低的内存,压缩时间最长." @默认值 = 8>
    参数 压缩算法 <类型 = 整数 注释 = "指定所欲使用的压缩算法." @默认值 = 0>
    {
        返回 (HPSocket类.压缩数据 (欲压缩数据, 压缩级别, 压缩位数, 压缩状态, 压缩算法))
    }

    方法 解压数据 <公开 类型 = 整数 注释 = "对指定数据进行Zlib解压." 返回值注释 = "返回解压的结果." 返回值注释 = "0->解压成功." 返回值注释 = "-3->提供的解压数据不正确."
            返回值注释 = "-5->输出缓冲区尺寸不足,需要分配更大空间." 折叠 @禁止流程检查 = 真>
    参数 欲解压数据 <类型 = 字节集类 注释 = "提供所欲解压的数据.">
    参数 输出缓冲区 <类型 = 字节集类 注释 = "提供的字节集必须先预分配足够的空间.">
    参数 压缩位数 <类型 = 整数 注释 = "8-15,表示处理raw deflate的方法." @默认值 = 15>
    {
        返回 (HPSocket类.解压数据 (欲解压数据, 输出缓冲区, 压缩位数))
    }

    方法 压缩数据_GZip <公开 类型 = 字节集类 注释 = "对指定数据进行GZip压缩." 返回值注释 = "返回被压缩后的数据." 折叠 @禁止流程检查 = 真>
    参数 欲压缩数据 <类型 = 字节集类 注释 = "提供所欲压缩的数据.">
