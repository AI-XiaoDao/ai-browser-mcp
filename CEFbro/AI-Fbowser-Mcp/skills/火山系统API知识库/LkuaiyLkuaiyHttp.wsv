    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = 整数 注释 = "0未知操作，1接受请求，2连接请求，3发送请求，4接收请求，5主动断开">
    参数 错误码 <类型 = 整数 注释 = "0成功，1未启动，2参数错误，3创建失败，4绑定失败，5设置失败，6监听失败，7端口错误，8创建线程失败"
            注释 = "9监测线程失败，10绑定端口失败，11连接失败，12网络错误，13数据处理错误，14数据发送失败，101SSL环境错误">
    {
        断开连接 (服务句柄, 连接ID)
        返回 (0)
    }

