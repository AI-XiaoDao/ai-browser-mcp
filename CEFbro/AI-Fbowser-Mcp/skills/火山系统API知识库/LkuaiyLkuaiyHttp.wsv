    常量 utf_8 <公开 值 = "charset=utf-8" 注释 = "世界通用语言编码">
    常量 big5 <公开 值 = "charset=big5" 注释 = "繁体中文编码">
    常量 euc_kr <公开 值 = "charset=euc-kr" 注释 = "韩文编码">

    #
}

类 FOFHTTP_Cookies <公开 折叠>
{
    变量 设置_Cookie <类型 = 文本型 注释 = "cookies,文本，不要太长，协议头必须少于4096字节">
    变量 临时_Cookie <类型 = 文本型>
    变量 设置_时间 <类型 = 文本型 注释 = "柏林时间，也就是到期的时间，空文本 表示关闭浏览器立刻失效">
    变量 设置_目录 <类型 = 文本型 注释 = "cookies，有效目录默认是“/”">
    变量 内部_协议头 <类型 = 字节集类>
    变量 内部_SameSite <类型 = 逻辑型>

    方法 初始化 <公开 属性写 折叠>
    参数 协议头 <类型 = 字节集类>
    {
        内部_协议头 = 协议头
    }

    方法 协议头数据 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (UTF8到文本 (内部_协议头))
    }

    方法 临时Cookie <公开 属性读 类型 = 文本型 注释 = "注意：该方法只有在设置了Cookie写的情况下才能获取到Cookie，属于内部使用，一般不需要调用本方法。"
            注释 = "如果想要获取浏览器的Cookie，请直接使用Cookie数据方法" 折叠 折叠2>
    {
        返回 (临时_Cookie)
    }

    方法 Cookie数据 <公开 属性读 类型 = 文本型 注释 = "cookies,文本，不要太长，协议头必须少于4096字节" 折叠>
    {
        如果 (设置_Cookie == "")
        {
            变量 分割数据 <类型 = 字节集数组类>
            变量 字节集 <类型 = 类_字节集操作>
            变量 临时字节集 <类型 = 字节集类>
            分割字节集 (内部_协议头, FOFHTTP_常用常量.UTF8_cookies开始, 分割数据)
            如果 (分割数据.取成员数 () >= 2)
            {
                临时字节集 = 分割数据.取成员 (1)
                如果 (寻找字节集 (临时字节集, FOFHTTP_常用常量.UTF8_cookies结束) != -1)
                {
                    临时字节集 = 字节集.字节集_寻找取左_从右开始 (临时字节集, FOFHTTP_常用常量.UTF8_cookies结束)
                    设置_Cookie = UTF8到文本 (临时字节集)
                    设置_Cookie = 删首尾空 (设置_Cookie)

                }

            }

        }

        子文本替换 (设置_Cookie, "fofcookie=fofhttpserverbegin", "")
        子文本替换 (设置_Cookie, "fofhttpserverend", "", , , )
        返回 (设置_Cookie)
    }

    方法 Cookie数据 <公开 属性写 折叠>
    参数 Cookie <类型 = 文本型 注释 = "cookies,文本，不要太长，协议头必须少于4096字节">
    {
        设置_Cookie = "fofcookie=fofhttpserverbegin" + Cookie + "fofhttpserverend"
        临时_Cookie = "fofcookie=fofhttpserverbegin" + Cookie + "fofhttpserverend"
    }

    方法 格林到期时间 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (设置_时间)
    }

    方法 SameSite_Secure开启状态 <公开 属性写 注释 = "设置是否开启SameSite跨域Cookie" 注释 = "注意：一定要为HTTPS的情况下本属性才可使用"
            注释 = "当你的浏览器出现了：Indicate whether to send a cookie in a cross-site request by specifying its SameSite attribute"
            注释 = "这样的提示的时候，我们就需要开启本状态" 折叠 折叠2>
    参数 是否开启 <类型 = 逻辑型>
    {
        内部_SameSite = 是否开启
    }

    方法 SameSite_Secure开启状态 <公开 属性读 类型 = 逻辑型 折叠>
    {
        返回 (内部_SameSite)
    }

    方法 到期时间 <公开 属性写 折叠>
    参数 设置时间信息 <类型 = 长整数 注释 = "Cookie失效的时间，单位：秒，默认为0，关闭浏览器立刻失效" 注释 = "例如：这里填写60，则60秒后浏览器Cookie失效" @默认值 = 0>
    {
        变量 临时时间 <类型 = 长整数>
        变量 时间操作 <类型 = 类_时间辅助函数>
        临时时间 = 时间操作.时间_取现行时间戳10位_长整数 ()
        临时时间 = 临时时间 + 设置时间信息
        临时时间 = 临时时间 - (长整数)60 * (长整数)60 * (长整数)8
        设置_时间 = 时间操作.时间_时间戳转格林 (临时时间)
        变量 文本 <类型 = 类_文本操作>
        设置_时间 = 文本.文本_替换 (设置_时间, " Jan ", "-Jan-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Feb ", "-Feb-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Mar ", "-Mar-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Apr ", "-Apr-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Jul ", "-Jul-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Jun ", "-Jun-")
        设置_时间 = 文本.文本_替换 (设置_时间, " May ", "-May-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Aug ", "-Aug-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Sep ", "-Sep-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Oct ", "-Oct-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Nov ", "-Nov-")
        设置_时间 = 文本.文本_替换 (设置_时间, " Dec ", "-Dec-")

    }

    方法 设置目录 <公开 属性写 折叠>
    参数 设置目录文本 <类型 = 文本型 注释 = "cookies，有效目录默认是“/”">
    {
        设置_目录 = 设置目录文本
    }

    方法 设置目录 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (设置_目录)
    }

    #
}

类 FOFHTTP_用户数据 <公开 折叠>
{
    变量 HTTP_用户IP <公开 类型 = 文本型 注释 = "例如：111.111.111.11">
    变量 HTTP_用户ID <公开 类型 = 变整数>
    变量 HTTP_请求类型 <公开 类型 = 整数 注释 = "1代表Get,2代表Post">
    变量 HTTP_提交数据 <公开 类型 = 字节集类 注释 = "用来记录Post提交的数据">
    变量 HTTP_协议头数据 <公开 类型 = 字节集类 注释 = "整体的协议头数据">
    变量 HTTP_是否格林时间 <公开 类型 = 逻辑型 值 = 真 注释 = "是否发送格林时间，默认为真，如果你是进行HTTP页面处理，那么建议这里开启为真"
            注释 = "如果你只是用来做HTTP的接口，可以把这里设置为假（设置为假可以增加并发效率）" 折叠2>
    变量 HTTP_待发整理 <公开 类型 = FOFHTTP_待发资料 注释 = "用户的待发送资料，里面会储存用户的请求URL、Cookies、文件的信息、类型、缓存时间、Cookie等各种信息">
    变量 HTTP_请求开始时间 <公开 类型 = 长整数 注释 = "请求开始的时间戳，用于POST数据判断">
    变量 ""
    变量 XFFIP <类型 = 文本型 注释 = "获取XFFIP，例如：111.111.111.11">
    变量 Host <类型 = 文本型>
    变量 版本号 <类型 = 文本型>
    变量 Accept <类型 = 文本型>
    变量 Referer <类型 = 文本型>
    变量 User_Agent <类型 = 文本型>
    变量 Connection <类型 = 文本型>
    变量 Accept_Language <类型 = 文本型>
    变量 Accept_Encoding <类型 = 文本型>
    变量 Upgrade <类型 = 文本型>
    变量 Content_Length <类型 = 整数 值 = -1>
    变量 用户协议头标志 <类型 = 文本型>
    变量 内部_文本协议头数据 <类型 = 文本型>

    方法 HTTP_精准IP <公开 属性读 类型 = 文本型 注释 = "从HTTP_XFFIP和HTTP_用户IP分别读取，如果HTTP_XFFIP为空则从HTTP_用户IP读取" 折叠>
    {
        如果 (HTTP_XFFIP == "")
        {
            返回 (HTTP_用户IP)
        }
        否则
        {
            返回 (HTTP_XFFIP)

        }

    }

    方法 HTTP_XFFIP <公开 属性读 类型 = 文本型 注释 = "获取XFFIP，例如：111.111.111.11" 注释 = "比如使用了nginx反向代理等  就需要使用本方法获取IP" 折叠 折叠2>
    {
        如果 (XFFIP == "")
        {
            如果 (内部_文本协议头数据 == "")
            {
                内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)

            }

            变量 文本 <类型 = 类_文本操作>
            XFFIP = 文本.文本_取右边 (内部_文本协议头数据, "X-Forwarded-For:", 真)
            如果 (寻找文本 (XFFIP, FOFHTTP_常用常量.换行符) != -1)
            {
                XFFIP = 文本.文本_取左边 (XFFIP, FOFHTTP_常用常量.换行符)

            }

            XFFIP = 删首尾空 (XFFIP)

        }
        返回 (XFFIP)

    }

    方法 HTTP_获取自定义协议头 <公开 类型 = 文本型>
    参数 自定义协议头标识 <类型 = 文本型 注释 = "例如：" 注释 = "Host:111.111.111.111    那么这里输入Host即可" 注释 = "cat:1   那么这里输入cat即可" 折叠2>
    {
        如果 (内部_文本协议头数据 == "")
        {
            内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)

        }

        变量 文本 <类型 = 类_文本操作>
        变量 临时文本 <类型 = 文本型>
        临时文本 = 文本.文本_取右边 (内部_文本协议头数据, 自定义协议头标识 + ":", 真)
        如果 (寻找文本 (临时文本, FOFHTTP_常用常量.换行符) != -1)
        {
            临时文本 = 文本.文本_取左边 (临时文本, FOFHTTP_常用常量.换行符)

        }

        临时文本 = 删首尾空 (临时文本)
        返回 (临时文本)

    }

    方法 HTTP_Host <公开 属性读 类型 = 文本型 注释 = "访问的域名" 折叠>
    {
        如果 (Host == "")
        {
            如果 (内部_文本协议头数据 == "")
            {
                内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)

            }

            变量 文本 <类型 = 类_文本操作>
            Host = 文本.文本_取右边 (内部_文本协议头数据, "Host:", 真)
            如果 (寻找文本 (Host, FOFHTTP_常用常量.换行符) != -1)
            {
                Host = 文本.文本_取左边 (Host, FOFHTTP_常用常量.换行符)

            }

            Host = 删首尾空 (Host)

        }
        返回 (Host)

    }

    方法 HTTP_Host <公开 属性写 注释 = "访问的域名" 折叠>
    参数 参数_Host <类型 = 文本型>
    {
        Host = 参数_Host

    }

    方法 HTTP_版本号 <公开 属性读 类型 = 文本型 注释 = "例如：HTTP/1.1" 折叠>
    {
