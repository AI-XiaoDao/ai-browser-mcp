类 FOFHTTP_标签视图 <公开 折叠>
{
    变量 UTF8标签数据 <类型 = 字节集数组类>
    变量 标签表 <类型 = 类_键值表>

    方法 清空 <公开 折叠>
    {
        UTF8标签数据.删除所有成员 ()
        标签表.清空 ()
    }

    方法 取视图成员数 <公开 类型 = 整数 折叠>
    {
        返回 (标签表.成员数)
    }

    方法 获取全部标签 <公开 类型 = 文本型>
    {
        返回 (标签表.到可读文本 ())
    }

    方法 添加标签 <公开 折叠>
    参数 url <类型 = 文本型>
    参数 页面数据 <类型 = 字节集类 注释 = "必须要是utf8数据">
    {
        变量 字节集 <类型 = 字节集类>
        字节集 = 创建字节集 (239, 187, 191)
        如果 (取字节集左边 (页面数据, 取字节集长度 (字节集)) == 字节集)
        {
            页面数据 = 取字节集右边 (页面数据, 取字节集长度 (页面数据) - 取字节集长度 (字节集))

        }

        标签表.置入整数值 (url, UTF8标签数据.加入成员 (页面数据))
    }

    方法 获取标签 <公开 类型 = 字节集类 折叠>
    参数 url <类型 = 文本型>
    {
        如果 (标签表.成员是否存在 (url) == 真)
        {
            变量 位置 <类型 = 整数>
            位置 = 标签表.取整数值 (url)
            如果 (位置 > UTF8标签数据.取成员数 () - 1)
            {
                返回 (FOFHTTP_常用常量.UTF8_空文本)
            }
            否则
            {
                变量 获取数据 <类型 = 字节集类>
                获取数据 = UTF8标签数据.取成员 (位置)
                返回 (获取数据)

            }

        }
        否则
        {
            返回 (FOFHTTP_常用常量.UTF8_空文本)

        }

    }

    方法 删除标签 <公开 注释 = "如果使用删除页面情况较多，建议开启线程安全" 折叠>
    参数 url <类型 = 文本型>
    {
        如果 (标签表.成员是否存在 (url) == 真)
        {
            变量 位置 <类型 = 整数>
            位置 = 标签表.取整数值 (url)
            如果 (位置 <= UTF8标签数据.取成员数 () - 1)
            {
                UTF8标签数据.删除成员 (位置)
                标签表.删除成员 (url)

            }

        }


    }

    方法 更新标签 <公开 注释 = "如果使用更新页面情况较多，建议开启线程安全" 折叠>
    参数 url <类型 = 文本型>
    参数 页面数据 <类型 = 字节集类 注释 = "必须要是utf8数据">
    {
        如果 (标签表.成员是否存在 (url) == 真)
        {
            变量 位置 <类型 = 整数>
            位置 = 标签表.取整数值 (url)
            如果 (位置 <= UTF8标签数据.取成员数 () - 1)
            {
                UTF8标签数据.置成员值 (位置, 页面数据)

            }

        }

    }
}

类 FOFHTTP_链接数据 <公开 折叠>
{
    变量 UTF8页面数据 <类型 = 字节集数组类>
    变量 url表 <类型 = 类_键值表>
    变量 页面键值表类型 <类型 = 类_键值表 注释 = "1代表标签页面，2代表普通页面">
    变量 UTF8对象数组 <类型 = 对象数组类>

    方法 获取全部链接 <公开 类型 = 文本型 折叠>
    {
        返回 (url表.到可读文本 ())
    }

    方法 添加页面 <公开 注释 = "根据域名添加页面">
    参数 url_ <类型 = 文本型>
    参数 页面数据 <类型 = 字节集类 注释 = "必须要是utf8数据">
    参数 域名 <类型 = 文本型 注释 = "如果想要添加域名页面，请在本处填写绑定的域名【FOF配置.绑定域名.加入成员的成员】" 注释 = "2022-4-8新增的参数，本参数不影响之前的功能，可以留空"
            注释 = "参数使用参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16493891957225531" @默认值 = "">
    {
        变量 字节集 <类型 = 字节集类>
        变量 url <类型 = 文本型>
        如果 (寻找文本 (url_, "我是重复不添加标识") != -1)
        {
            变量 临时URL <类型 = 文本型>
            临时URL = url_
            子文本替换 (临时URL, "我是重复不添加标识", "")
            如果 (url表.成员是否存在 (临时URL) == 真)  // 存在不添加
            {
                返回
            }
            url = 临时URL
        }
        否则
        {
            url = 域名 + url_
        }
        字节集 = 创建字节集 (239, 187, 191)
        如果 (取字节集左边 (页面数据, 取字节集长度 (字节集)) == 字节集)
        {
            页面数据 = 取字节集右边 (页面数据, 取字节集长度 (页面数据) - 取字节集长度 (字节集))
        }
        页面键值表类型.置入整数值 (url, 2)
        url表.置入整数值 (url, UTF8页面数据.加入成员 (页面数据))
        如果 (域名 != "")
        {
            添加页面 (url_ + "我是重复不添加标识", 页面数据)

        }

    }

    方法 获取页面 <公开 类型 = 字节集类 注释 = "支持带?数据，例如你在添加页面的时候添加的是/aaaa" 注释 = "但是你得到的请求是/aaaa?ssss=1111，这样的话依然会被本方法当成/aaaa处理；以方便得到正确的页面数据"
            折叠 折叠2>
    参数 url_ <类型 = 文本型>
    参数 域名 <类型 = 文本型 注释 = "如果想要获取域名页面，请在本处填写绑定的域名【FOF配置.绑定域名.加入成员的成员】" 注释 = "2022-4-8新增的参数，本参数不影响之前的功能，可以留空"
            注释 = "参数使用参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16493891957225531" @默认值 = "">
    {
        变量 url <类型 = 文本型>
        url = 域名 + url_
        如果 (url表.成员是否存在 (url) == 假 && 寻找文本 (url, "?") != -1)
        {
            变量 文本处理 <类型 = 类_文本操作>
            变量 非解析参数URL <类型 = 文本型>
            非解析参数URL = 文本处理.文本_取左边_从左往右查找 (url, "?")
            如果 (url表.成员是否存在 (非解析参数URL) == 真)
            {
                如果 (页面键值表类型.取整数值 (非解析参数URL) == 1)  // 类型错误判断,如果取的是标签视图,就会返回空字节集
                {
                    返回 (FOFHTTP_常用常量.UTF8_空文本)

                }

                变量 位置 <类型 = 整数>
                位置 = url表.取整数值 (非解析参数URL)
                如果 (位置 > UTF8页面数据.取成员数 () - 1)
                {
                    返回 (FOFHTTP_常用常量.UTF8_空文本)
                }
                否则
                {
                    变量 获取数据 <类型 = 字节集类>
                    获取数据 = UTF8页面数据.取成员 (位置)
                    返回 (获取数据)

                }

            }
            否则
            {
                非解析参数URL = 取文本右边 (非解析参数URL, 取文本长度 (非解析参数URL) - 1)
                如果 (url表.成员是否存在 (非解析参数URL) == 真)
                {
                    如果 (页面键值表类型.取整数值 (非解析参数URL) == 1)  // 类型错误判断,如果取的是标签视图,就会返回空字节集
                    {
                        返回 (FOFHTTP_常用常量.UTF8_空文本)

                    }

                    变量 位置 <类型 = 整数>
                    位置 = url表.取整数值 (非解析参数URL)
                    如果 (位置 > UTF8页面数据.取成员数 () - 1)
                    {
                        返回 (FOFHTTP_常用常量.UTF8_空文本)
                    }
                    否则
                    {
                        变量 获取数据 <类型 = 字节集类>
                        获取数据 = UTF8页面数据.取成员 (位置)
                        返回 (获取数据)

                    }
                }


            }


        }

        如果 (url表.成员是否存在 (url) == 真)
        {
            如果 (页面键值表类型.取整数值 (url) == 1)  // 类型错误判断,如果取的是标签视图,就会返回空字节集
            {
                返回 (FOFHTTP_常用常量.UTF8_空文本)

            }

            变量 位置 <类型 = 整数>
            位置 = url表.取整数值 (url)
            如果 (位置 > UTF8页面数据.取成员数 () - 1)
            {
                返回 (FOFHTTP_常用常量.UTF8_空文本)
            }
            否则
            {
                变量 获取数据 <类型 = 字节集类>
                获取数据 = UTF8页面数据.取成员 (位置)
                返回 (获取数据)

            }

        }
        否则
        {
            返回 (FOFHTTP_常用常量.UTF8_空文本)

        }

    }

    方法 清空 <公开 注释 = "如果使用删除页面情况较多，建议开启线程安全" 折叠>
