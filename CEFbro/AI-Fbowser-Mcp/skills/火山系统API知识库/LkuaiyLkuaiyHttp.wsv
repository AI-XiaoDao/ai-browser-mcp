    # //SSL内部接收事件===
    #
    # //内部接收事件===

    方法 基类网络_HP_PULL服务器_开始握手 <接收事件 类型 = 整数 注释 = "  当客户端通过事件\"客户进入\"后,将会立即触发本事件,只有通过本事件,才会进行握手动作." 返回值注释 = "可选返回值:"
            返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手." 返回值注释 = "  1 = 忽略本次操作, 客户端可与服务器建立正式连接." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接."
            折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        握手事件 (服务句柄, 连接ID)
        返回 (0)
    }

    方法 基类网络_HP_PULL服务器_发送完毕 <接收事件 类型 = 整数 注释 = "当服务器发送数据成功后,将触发本事件." 折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "接收本次发送所对应的连接ID.">
    参数 数据 <类型 = 字节集类 注释 = "本次所发送的数据.">
    参数 数据大小 <类型 = 整数 注释 = "所发送数据的长度.">
    {
        数据发送完毕 (服务句柄, 连接ID, 取字节集指针 (数据), 数据大小)
        返回 (0)
    }

    方法 基类网络_HP_PULL服务器_数据进入 <接收事件 类型 = 整数 注释 = "当服务器成功接收数据后将触发本事件,此时可以进行抓取数据/窥探数据." 返回值注释 = "可选返回值:"
            返回值注释 = "  0 = 本次操作成功, 继续执行." 返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接并触发关闭事件." 折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "接收到的数据由该连接ID发过来.">
    参数 数据大小 <类型 = 整数 注释 = "本次接收的数据长度.">
    {
        如果 (FOF配置项.被攻击公告 == 1)
        {
            变量 防火墙协议 <类型 = 文本型 值 = "HTTP/1.1 200 OK\r\nConnection: close\r\nContent-Type: text/html\r\nContent-Length: 长度替换\r\n\r\n">
            变量 内容 <类型 = 文本型
                    值 = "<html>\r\n        <head>\r\n        <style>\r\n/* latin-ext */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AUi-qJCY.woff2) format(\'woff2\');\r\n  unicode-range: U+0100-024F, U+0259, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F, U+A720-A7FF;\r\n}\r\n/* latin */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AXC-q.woff2) format(\'woff2\');\r\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\r\n}\r\n\r\n        </style>\r\n        <meta charset=\"UTF-8\">\r\n\t\t<link href=\'//fonts.googleapis.com/css?family=Lato:100\' rel=\'stylesheet\' type=\'text/css\'>\r\n\t\t<style>\r\n\t\t\tbody {\r\n\t\t\t\tmargin: 0;\r\n\t\t\t\tpadding: 0;\r\n\t\t\t\twidth: 100%;\r\n\t\t\t\theight: 100%;\r\n\t\t\t\tcolor: #B0BEC5;\r\n\t\t\t\tdisplay: table;\r\n\t\t\t\tfont-weight: 100;\r\n\t\t\t\tfont-family: \'Lato\';\r\n\t\t\t}\r\n\r\n\t\t\t.container {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: table-cell;\r\n\t\t\t\tvertical-align: middle;\r\n\t\t\t}\r\n\r\n\t\t\t.content {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: inline-block;\r\n\t\t\t}\r\n\r\n\t\t\t.title {\r\n\t\t\t\tfont-size: 42px;\r\n\t\t\t\tmargin-bottom: 40px;\r\n\t\t\t}\r\n\t\t</style>\r\n\t</head>\r\n\t<body>\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"content\">\r\n\t\t\t\t<div class=\"title\">网站正在维护中，请耐心等候！</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</body>\r\n</html>">
            子文本替换 (防火墙协议, "长度替换", 到文本 (取文本长度 (内容)), , , 真)
            加入文本 (防火墙协议, 内容)
            服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (防火墙协议, 假))
            服务器.断开连接 (连接ID, 真)
            返回 (0)
        }
        如果 (FOF配置项.被攻击公告 == 2)
        {
            变量 防火墙协议 <类型 = 文本型 值 = "HTTP/1.1 200 OK\r\nConnection: close\r\nContent-Type: text/html\r\nContent-Length: 长度替换\r\n\r\n">
            变量 内容 <类型 = 文本型
                    值 = "<html>\r\n        <head>\r\n        <style>\r\n/* latin-ext */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AUi-qJCY.woff2) format(\'woff2\');\r\n  unicode-range: U+0100-024F, U+0259, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F, U+A720-A7FF;\r\n}\r\n/* latin */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AXC-q.woff2) format(\'woff2\');\r\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\r\n}\r\n\r\n        </style>\r\n        <meta charset=\"UTF-8\">\r\n\t\t<link href=\'//fonts.googleapis.com/css?family=Lato:100\' rel=\'stylesheet\' type=\'text/css\'>\r\n\t\t<style>\r\n\t\t\tbody {\r\n\t\t\t\tmargin: 0;\r\n\t\t\t\tpadding: 0;\r\n\t\t\t\twidth: 100%;\r\n\t\t\t\theight: 100%;\r\n\t\t\t\tcolor: #B0BEC5;\r\n\t\t\t\tdisplay: table;\r\n\t\t\t\tfont-weight: 100;\r\n\t\t\t\tfont-family: \'Lato\';\r\n\t\t\t}\r\n\r\n\t\t\t.container {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: table-cell;\r\n\t\t\t\tvertical-align: middle;\r\n\t\t\t}\r\n\r\n\t\t\t.content {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: inline-block;\r\n\t\t\t}\r\n\r\n\t\t\t.title {\r\n\t\t\t\tfont-size: 42px;\r\n\t\t\t\tmargin-bottom: 40px;\r\n\t\t\t}\r\n\t\t</style>\r\n\t</head>\r\n\t<body>\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"content\">\r\n\t\t\t\t<div class=\"title\">网站被攻击正在维护中，请耐心等候！</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</body>\r\n</html>">
            子文本替换 (防火墙协议, "长度替换", 到文本 (取文本长度 (内容)), , , 真)
            加入文本 (防火墙协议, 内容)
            服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (防火墙协议, 假))
            服务器.断开连接 (连接ID, 真)
            返回 (0)

        }

        变量 字节集数据 <类型 = 字节集类>
        字节集数据 = 服务器.抓取数据_ (服务句柄, 连接ID, 数据大小)
        TCP数据到达 (服务句柄, 连接ID, 取字节集长度 (字节集数据), 字节集数据)
        变量 临时URL头 <类型 = 文本型>
        变量 请求类型 <类型 = 整数>
        临时URL头 = 内部_获取协议URL头 (字节集数据)
        请求类型 = 内部_判断请求类型 (临时URL头)
        如果 (请求类型 == 2 || 请求类型 == 0)  // POST数据,走安全线程
        {
            如果 (处理_请求回调函数_Post (字节集数据, 服务句柄, 连接ID, 临时URL头, 请求类型, 来源对象.取客户IP (服务句柄, 连接ID)) == 1)
            {
                服务器.断开连接 (连接ID, 真)
            }
            返回 (0)
        }
        如果 (处理_请求回调函数_GET (字节集数据, 服务句柄, 连接ID, 临时URL头, 请求类型, 来源对象.取客户IP (服务句柄, 连接ID)) == 1)
        {
            服务器.断开连接 (连接ID, 真)
        }
        返回 (0)
    }

    方法 发送301跳转_ <类型 = 逻辑型 注释 = "HTTP/1.1 301 Moved Permanently，让浏览器跳转到其它页面，并且设置浏览器的Cookies信息" 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 跳转地址 <类型 = 文本型 注释 = "跳转到地址URL /test.html">
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 局_响应头 + 内_HTTP版本 + " 301 Moved Permanently" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Content-Length: 0" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Location: " + 跳转地址 + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Content-Type: text/html" + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        返回 (服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (局_响应头, 假)))
    }

    方法 基类网络_HP_PULL服务器_客户离开 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件." 折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = 整数 注释 = "0未知操作，1接受请求，2连接请求，3发送请求，4接收请求，5主动断开">
    参数 错误码 <类型 = 整数 注释 = "0成功，1未启动，2参数错误，3创建失败，4绑定失败，5设置失败，6监听失败，7端口错误，8创建线程失败"
            注释 = "9监测线程失败，10绑定端口失败，11连接失败，12网络错误，13数据处理错误，14数据发送失败，101SSL环境错误">
    {
        断开连接 (服务句柄, 连接ID)
        返回 (0)
    }

    方法 基类网络_HP_PULL服务器_服务器被关闭 <接收事件 类型 = 整数 注释 = "当服务器被关闭后,将会触发本事件." 折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    {
        关闭HTTP服务器 (服务句柄)
        返回 (0)
    }

    方法 基类网络_HP_PULL服务器_启动完毕 <接收事件 类型 = 整数 注释 = "服务器端启动完毕并开始监听后,将触发本事件." 折叠>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    {
        监听事件 (服务句柄, 服务句柄)
        返回 (0)
    }

    方法 基类网络_HP_PULL服务器_客户进入 <接收事件 类型 = 整数 注释 = "  当客户连接到服务器后,将会触发本事件,请注意,本事件下的连接并非是正式连接,"
            注释 = "只有该连接通过\"完成握手\"事件,才可以与服务器建立正式连接,本事件返回值拥有具体意义,请参考返回值说明." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 将触发\"完成握手\"事件."
            返回值注释 = "  1 = 忽略本次操作, 将触发\"完成握手\"事件." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接." 折叠 折叠2>
    参数 来源对象 <类型 = 基类网络_HP_PULL服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    {
        用户上线 (服务句柄, 连接ID, 连接ID)
        返回 (0)
    }

    方法 处理_请求回调函数_GET <类型 = 整数 折叠>
    参数 接收数据 <类型 = 字节集类>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 临时URL头 <类型 = 文本型>
    参数 请求类型 <类型 = 整数>
    参数 客户IP <类型 = 文本型>
    {
        变量 字节集数据 <类型 = 字节集类>
        变量 文本 <类型 = 类_文本操作>
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 临时用户数据 <类型 = FOFHTTP_用户数据>
        字节集数据 = 接收数据
        临时用户数据.HTTP_请求类型 = 请求类型
        临时用户数据.HTTP_用户IP = 客户IP
        // 通用HTTP数据====
        变量 URL <类型 = 文本型>
        URL = 内部_获取请求url (临时URL头, 请求类型)  // 如果继续优化这里,效率还可以成倍增加
        临时用户数据.HTTP_待发整理 = 辅助.解析GetPost请求 (URL)  // 如果继续优化这里,效率还可以成倍增加
        // 通用HTTP数据====
        临时用户数据.HTTP_用户ID = 连接ID
        临时用户数据.HTTP_协议头数据 = 内部_获取get协议头 (字节集数据)
        临时用户数据.HTTP_待发整理.cookie.初始化 = 临时用户数据.HTTP_协议头数据
        如果 (内部_防火墙逻辑函数 (服务句柄, 连接ID, 请求类型, 客户IP, 临时用户数据.HTTP_XFFIP, 临时用户数据.HTTP_待发整理.请求Url) == 真)  // 触发防火墙网站防火墙
        {
            返回 (0)

        }

        如果 (FOF配置项.是否启用内置favicon图标 == 真)
        {
            如果 (寻找文本 (临时用户数据.HTTP_待发整理.请求Url, "favicon.ico") != -1)
            {
                临时用户数据.HTTP_待发整理.文件后缀 = "ico"
                内部_发送页面数据 (服务句柄, 连接ID, FOF配置项.内置favicon图标, 临时用户数据)
                返回 (0)

            }

        }

        如果 (处理_域名绑定及域名目录判断 (临时用户数据) == 1)
        {
            返回 (1)
        }
        如果 (请求类型 == 3)
        {
            OPTIONS事件 (服务句柄, 连接ID, 取字节集长度 (字节集数据), 临时用户数据)
        }
        否则
        {
            Get事件 (服务句柄, 连接ID, 取字节集长度 (字节集数据), 临时用户数据)

        }

        返回 (0)
    }

    方法 处理_请求回调函数_Post <类型 = 整数 折叠>
    参数 接收数据 <类型 = 字节集类>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 临时URL头_ <类型 = 文本型>
    参数 请求类型_ <类型 = 整数>
    参数 客户IP <类型 = 文本型>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 临时用户数据 <类型 = FOFHTTP_用户数据>
        临时用户数据.HTTP_请求类型 = 请求类型_
        临时用户数据.HTTP_用户IP = 客户IP
        // Post续传=====
        如果 (请求类型_ == 0)
        {
            内_POST锁.进入许可区 ()
            变量 文件数据 <类型 = 文件读写类>
            如果 (文件数据.打开文件 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte") == 假)
            {
                内_用户Post模式.删除成员 (到文本 (连接ID))
                文件数据.关闭文件 ()
                删除文件 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte")
                内_POST锁.离开许可区 ()
                临时用户数据.HTTP_待发整理.文件后缀 = "json"
                如果 (内_当前服务类型 == 1)
                {
                    服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 ("", 假))
                }
                否则
                {
                    服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 文本到UTF8 ("", 假))

                }

                返回 (0)
            }
            文件数据.移到文件尾 ()
            文件数据.写出字节集 (接收数据)
            变量 文件长度 <类型 = 长整数>
            文件长度 = 文件数据.取文件长度 ()
            文件数据.移到文件首 ()
            如果 (文件长度 + (长整数)15000 >= 内_用户信息.取长整数值 (到文本 (连接ID)))  // 快要上传完成了,开始检测数据
            {
                如果 (内部_POST数据解析处理 (文件数据.读入字节集 ((整数)文件数据.取文件长度 ()), 服务句柄, 连接ID, 临时用户数据) == 真)
                {
                    内_待处理文件.压入 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte")
                    内_用户Post模式.删除成员 (到文本 (连接ID))
                    文件数据.关闭文件 ()
                    内_POST锁.离开许可区 ()
                    Post事件 (服务句柄, 连接ID, 取字节集长度 (临时用户数据.HTTP_提交数据), 临时用户数据)
                    删除文件 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte")
                    返回 (0)

                }

            }
            文件数据.关闭文件 ()
            内_POST锁.离开许可区 ()  // 只要进入了许可区,就一定要离开许可区
            返回 (0)
        }
        // Post续传=====

        // 通用HTTP数据===
        变量 URL <类型 = 文本型>
        URL = 内部_获取请求url (临时URL头_, 请求类型_)  // 如果继续优化这里,效率还可以成倍增加
        临时用户数据.HTTP_待发整理 = 辅助.解析GetPost请求 (URL)  // 如果继续优化这里,效率还可以成倍增加
        // 通用HTTP数据====
        临时用户数据.HTTP_用户ID = 连接ID
        临时用户数据.HTTP_协议头数据 = 内部_获取Post协议头 (接收数据)
        临时用户数据.HTTP_待发整理.cookie.初始化 = 临时用户数据.HTTP_协议头数据
        临时用户数据.HTTP_提交数据 = 内部_取Post数据 (接收数据, 临时用户数据.HTTP_协议头数据)
        如果 (临时用户数据.HTTP_Content_Length >= FOF配置项.允许文件上传最大尺寸)
        {
            临时用户数据.HTTP_待发整理.文件后缀 = "html"
            内部_发送404页面错误 (服务句柄, 连接ID, FOFHTTP_常用常量.UTF8_404页面, 临时用户数据)
            如果 (内_当前服务类型 == 1)
            {
                服务器.断开连接 (连接ID, 真)
            }
            否则
            {
                服务器_HTTPS.断开连接 (连接ID, 真)
            }
            返回 (0)

        }

        变量 时间 <类型 = 类_时间辅助函数>
        临时用户数据.HTTP_请求开始时间 = 时间.时间_取现行时间戳10位_长整数 ()
        如果 (临时用户数据.HTTP_Content_Length > 取字节集长度 (临时用户数据.HTTP_提交数据))
        {
            触发POST上传数据 (服务句柄, 连接ID, 取字节集长度 (接收数据), 临时用户数据)
            内_POST锁.进入许可区 ()
            内_用户Post模式.置入整数值 (到文本 (连接ID), 2)
            写到文件 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte", 接收数据)
            内_用户信息.置入长整数值 (到文本 (连接ID), 临时用户数据.HTTP_Content_Length + 取字节集长度 (接收数据))
            内_POST锁.离开许可区 ()
            如果 (临时用户数据.HTTP_待发整理.请求Url != "" && 客户IP != "")
            {
                如果 (内部_防火墙逻辑函数 (服务句柄, 连接ID, 请求类型_, 客户IP, 临时用户数据.HTTP_XFFIP, 临时用户数据.HTTP_待发整理.请求Url) == 真)  // 触发防火墙网站防火墙
                {
                    删除文件 (取运行目录 () + "fofByte\\" + 到文本 (连接ID) + ".fofByte")
                    返回 (0)

                }

            }
        }
        否则 (取字节集长度 (临时用户数据.HTTP_提交数据) >= 临时用户数据.HTTP_Content_Length)
        {
            触发POST上传数据 (服务句柄, 连接ID, 取字节集长度 (接收数据), 临时用户数据)
            如果 (处理_域名绑定及域名目录判断 (临时用户数据) == 1)
            {
                如果 (内_当前服务类型 == 1)
                {
                    服务器.断开连接 (连接ID, 真)
                }
                否则
                {
                    服务器_HTTPS.断开连接 (连接ID, 真)

                }
                返回 (1)
            }
            如果 (内部_防火墙逻辑函数 (服务句柄, 连接ID, 请求类型_, 客户IP, 临时用户数据.HTTP_XFFIP, 临时用户数据.HTTP_待发整理.请求Url) == 真)  // 触发防火墙网站防火墙
            {
                如果 (内_当前服务类型 == 1)
                {
                    服务器.断开连接 (连接ID, 真)
                }
                否则
                {
                    服务器_HTTPS.断开连接 (连接ID, 真)
                }
                返回 (0)

            }
            Post事件 (服务句柄, 连接ID, 取字节集长度 (接收数据), 临时用户数据)

        }

        返回 (0)
    }

    方法 处理_域名绑定及域名目录判断 <类型 = 整数 折叠>
    参数 临时用户数据 <类型 = FOFHTTP_用户数据>
    {
        如果 (FOF配置项.绑定域名.取成员数 () >= 1)
        {
            变量 循环域名 <类型 = 整数>
            变量 是否匹配 <类型 = 逻辑型>
            循环 (0, FOF配置项.绑定域名.取成员数 (), 循环域名)
            {
                如果 (寻找文本 (临时用户数据.HTTP_Host, FOF配置项.绑定域名.取成员 (循环域名)) != -1)
                {
                    是否匹配 = 真
                    如果 (内_项目目录域名.是否存在 (FOF配置项.绑定域名.取成员 (循环域名)) == 真)
                    {
                        变量 目录值 <类型 = 文本型>
                        目录值 = 内_项目目录域名.取值 (FOF配置项.绑定域名.取成员 (循环域名))
                        内_域名处理锁.进入许可区 ()
                        如果 (内_项目目录.取成员数 () >= 1)
                        {
                            如果 (内_项目目录.取成员 (0) == 目录值)  // 不需要做处理,项目目录是在第一个位置
                            {
                                内_域名处理锁.离开许可区 ()
                                跳出循环

                            }

                        }

                        变量 循环目录 <类型 = 整数>
                        循环 (0, 内_项目目录.取成员数 (), 循环目录)
                        {
                            如果 (目录值 == 内_项目目录.取成员 (循环目录))
                            {
                                内_项目目录.删除成员 (循环目录)
                                内_项目目录.插入成员 (0, 目录值)  // 强制移动到第一位
                                内_域名处理锁.离开许可区 ()
                                跳出循环

                            }

                        }

                        内_域名处理锁.离开许可区 ()

                    }

                    跳出循环

                }

            }
            如果 (是否匹配 == 假)
            {
                返回 (1)

            }

        }

        返回 (0)
    }

    # //内部接收事件===
    # //内部封装方法===

    方法 内部_POST数据解析处理 <类型 = 逻辑型 折叠>
    参数 接收数据 <类型 = 字节集类>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 临时用户数据 <类型 = FOFHTTP_用户数据>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 字节集数据 <类型 = 字节集类>
        字节集数据 = 接收数据
        变量 临时URL头 <类型 = 文本型>
        变量 请求类型 <类型 = 整数>
        临时URL头 = 内部_获取协议URL头 (字节集数据)
        请求类型 = 内部_判断请求类型 (临时URL头)
        // 通用HTTP数据===
        变量 URL <类型 = 文本型>
        URL = 内部_获取请求url (临时URL头, 请求类型)  // 如果继续优化这里,效率还可以成倍增加
        临时用户数据.HTTP_待发整理 = 辅助.解析GetPost请求 (URL)  // 如果继续优化这里,效率还可以成倍增加
        // 通用HTTP数据====
        临时用户数据.HTTP_用户ID = 连接ID
        临时用户数据.HTTP_协议头数据 = 内部_获取Post协议头 (字节集数据)
        临时用户数据.HTTP_待发整理.cookie.初始化 = 临时用户数据.HTTP_协议头数据
        临时用户数据.HTTP_提交数据 = 内部_取Post数据 (字节集数据, 临时用户数据.HTTP_协议头数据)
        变量 时间 <类型 = 类_时间辅助函数>
        临时用户数据.HTTP_请求开始时间 = 时间.时间_取现行时间戳10位_长整数 ()
        如果 (临时用户数据.HTTP_Content_Length > 取字节集长度 (临时用户数据.HTTP_提交数据))
        {
            返回 (假)
        }
        如果 (取字节集长度 (临时用户数据.HTTP_提交数据) >= 临时用户数据.HTTP_Content_Length)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 内部_取Post数据 <类型 = 字节集类 折叠>
    参数 Post数据 <类型 = 字节集类>
    参数 协议头数据 <类型 = 字节集类>
    {
        变量 临时字节集 <类型 = 字节集类>
        如果 (取字节集长度 (Post数据) >= 取字节集长度 (协议头数据))
        {
            临时字节集 = 取字节集右边 (Post数据, 取字节集长度 (Post数据) - 取字节集长度 (协议头数据))

        }

        返回 (临时字节集)
    }

    方法 内部_获取get协议头 <类型 = 字节集类 折叠>
    参数 字节集数据 <类型 = 字节集类>
    {
        变量 字节集操作 <类型 = 类_字节集操作>
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 字节集数据
        如果 (取字节集长度 (临时字节集) >= 取字节集长度 (FOFHTTP_常用常量.UTF8_换行符))
        {
            判断循环 (字节集操作.字节集_字节集是否相等 (取字节集右边 (临时字节集, 取字节集长度 (FOFHTTP_常用常量.UTF8_换行符)), FOFHTTP_常用常量.UTF8_换行符) == 真)
            {
                临时字节集 = 取字节集左边 (临时字节集, 取字节集长度 (临时字节集) - 取字节集长度 (FOFHTTP_常用常量.UTF8_换行符))

            }

        }

        临时字节集.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        临时字节集.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        返回 (临时字节集)
    }

    方法 内部_获取Post协议头 <类型 = 字节集类 折叠>
    参数 字节集数据 <类型 = 字节集类>
    {
        变量 字节集 <类型 = 类_字节集操作>
        变量 临时分割 <类型 = 字节集数组类>
        变量 临时字节集 <类型 = 字节集类>
        变量 字节集分割 <类型 = 字节集类>
        字节集分割.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        字节集分割.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        分割字节集 (字节集数据, 字节集分割, 临时分割)

        如果 (临时分割.取成员数 () <= 0)
        {
            临时字节集 = 字节集.字节集_寻找取左 (字节集数据, 字节集分割)
        }
        否则
        {
            临时字节集 = 临时分割.取成员 (0)

        }

        临时字节集.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        临时字节集.添加字节集 (FOFHTTP_常用常量.UTF8_换行符)
        返回 (临时字节集)
    }

    方法 内部_判断请求类型 <类型 = 整数 返回值注释 = "返回1代表Get请求,返回2代表Post请求,返回3代表OPTIONS,返回0代表失败" 折叠>
    参数 临时URL头 <类型 = 文本型>
    {
        如果 (取文本长度 (临时URL头) <= 3)  // 排错安全机制
        {
            返回 (0)
        }
        如果 (取文本左边 (临时URL头, 3) == "GET")
        {
            返回 (1)
        }
        如果 (取文本长度 (临时URL头) <= 4)  // 排错安全机制
        {
            返回 (0)
        }
        如果 (取文本左边 (临时URL头, 4) == "POST")
        {
            返回 (2)
        }
        变量 小写协议头 <类型 = 文本型>
        小写协议头 = 到小写 (临时URL头)
        如果 (到小写 (取文本左边 (小写协议头, 3)) == "get")
        {
            返回 (1)
        }
        如果 (到小写 (取文本左边 (小写协议头, 4)) == "post")
        {
            返回 (2)
        }
        如果 (取文本长度 (临时URL头) <= 7)  // 排错安全机制
        {
            返回 (0)
        }
        如果 (取文本左边 (临时URL头, 7) == "OPTIONS")
        {
            返回 (3)
        }
        如果 (寻找文本 (小写协议头, "get", , ) != -1 && 寻找文本 (小写协议头, " https:", , ) != -1 && 寻找文本 (小写协议头, "accept", , ) != -1)
        {
            返回 (1)
        }
        如果 (寻找文本 (小写协议头, "get", , ) != -1 && 寻找文本 (小写协议头, " http:", , ) != -1 && 寻找文本 (小写协议头, "accept", , ) != -1)
        {
            返回 (1)
        }
        如果 (寻找文本 (小写协议头, "host", , ) != -1 && 寻找文本 (小写协议头, " http:", , ) != -1 && 寻找文本 (小写协议头, "accept", , ) != -1)
        {
            返回 (1)
        }
        如果 (寻找文本 (小写协议头, "host", , ) != -1 && 寻找文本 (小写协议头, " https:", , ) != -1 && 寻找文本 (小写协议头, "accept", , ) != -1)
        {
            返回 (1)
        }
        如果 (寻找文本 (小写协议头, "post", , ) != -1 && 寻找文本 (小写协议头, "host", , ) != -1 && 寻找文本 (小写协议头, "accept", , ) != -1)
        {
            返回 (2)
        }
        返回 (0)
    }

    方法 内部_获取请求url <类型 = 文本型 返回值注释 = "失败返回空文本" 折叠>
    参数 临时URL头 <类型 = 文本型 编辑时信息 = "42AA6, 0, 0, 0">
    参数 请求类型 <类型 = 整数>
    {
        如果 (临时URL头 == "")
        {
            返回 ("")

        }

        变量 临时文本 <类型 = 文本型>
        临时文本 = 临时URL头
        如果 (取文本长度 (临时文本) >= 9)
        {
            如果 (请求类型 == 1)
            {
                如果 (取文本长度 (临时文本) < 12)
                {
                    返回 ("")

                }

                临时文本 = 取文本右边 (临时文本, 取文本长度 (临时文本) - 4)
                临时文本 = 取文本左边 (临时文本, 取文本长度 (临时文本) - 8)
            }
            如果 (请求类型 == 2)
            {
                如果 (取文本长度 (临时文本) < 13)
                {
                    返回 ("")

                }

                临时文本 = 取文本右边 (临时文本, 取文本长度 (临时文本) - 5)
                临时文本 = 取文本左边 (临时文本, 取文本长度 (临时文本) - 8)

            }

        }
        否则
        {
            返回 ("")

        }

        返回 (临时文本)
    }

    方法 内部_获取协议URL头 <类型 = 文本型 注释 = "失败返回空，否则返回URL头" 返回值注释 = "失败返回空，否则返回URL头" 折叠>
    参数 字节集数据 <类型 = 字节集类>
    {
        变量 分割 <类型 = 字节集数组类>
        变量 文本 <类型 = 类_文本操作>
        分割字节集 (字节集数据, FOFHTTP_常用常量.UTF8_换行符, 分割)
        如果 (分割.取成员数 () <= 0)
        {
            返回 ("")

        }

        变量 临时文本 <类型 = 文本型>
        临时文本 = UTF8到文本 (分割.取成员 (0))
        返回 (临时文本)
    }

    方法 内部_发送页面数据 <公开 类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 页面数据 <类型 = 字节集类 注释 = "HTML页面数据">
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 自定义协议头 <类型 = 文本数组类 注释 = "例如：Content-Encoding:gzip" @默认值 = 空对象>
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 时间 <类型 = 类_时间辅助函数>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 内_HTTP版本 + " 200 OK" + FOFHTTP_常用常量.换行符
        如果 (寻找文本 (到小写 (用户数据.HTTP_Connection), "keep-alive", , 真) == -1)
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符

        }

        如果 (寻找文本 (到小写 (用户数据.HTTP_Accept_Encoding), "gzip") != -1)
        {
            页面数据 = 辅助.压缩数据_GZip (页面数据)
            局_响应头 = 局_响应头 + "Content-Encoding:gzip" + FOFHTTP_常用常量.换行符

        }

        如果 (自定义协议头.取成员数 () >= 1)
        {
            变量 循环变量 <类型 = 整数>
            循环 (0, 自定义协议头.取成员数 (), 循环变量)
            {
                局_响应头 = 局_响应头 + 自定义协议头.取成员 (循环变量) + FOFHTTP_常用常量.换行符

            }

        }

        如果 (用户数据.HTTP_是否格林时间 == 真)
        {
            局_响应头 = 局_响应头 + "Date: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }

        如果 (用户数据.HTTP_待发整理.协议头类 != "")
        {
            局_响应头 = 局_响应头 + 用户数据.HTTP_待发整理.协议头类 + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        如果 (用户数据.HTTP_待发整理.缓存时间 >= 1)
        {
            局_响应头 = 局_响应头 + "Cache-Control: max-age=" + 到文本 (用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Expires:" + 时间.时间_时间戳转格林 (时间.时间_取格林时间时间戳 () + 用户数据.HTTP_待发整理.缓存时间 * 60) + FOFHTTP_常用常量.换行符

        }
        如果 (用户数据.HTTP_待发整理.页面标记 != "")
        {
            变量 标记 <类型 = 文本型 值 = "ETag: \"标记内容\"">
            变量 文本 <类型 = 类_文本操作>
            标记 = 文本.文本_替换 (标记, "标记内容", 用户数据.HTTP_待发整理.页面标记)
            局_响应头 = 局_响应头 + 标记 + FOFHTTP_常用常量.换行符
            局_响应头 = 局_响应头 + "Last-Modified: " + 时间.时间_取格林时间 () + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (取字节集长度 (页面数据)) + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + 辅助.取文件协议类型 (用户数据.HTTP_待发整理.文件后缀, 内_文本编码) + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        变量 局_数据段 <类型 = 字节集类>
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        局_数据段.添加字节集 (页面数据)
        如果 (内_当前服务类型 == 1)
        {
            返回 (服务器.发送字节集 (服务句柄, 连接ID, 局_数据段))

        }
        否则
        {
            返回 (服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 局_数据段))

        }
    }

    方法 内部_发送404页面错误 <公开 类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 页面数据 <类型 = 字节集类 注释 = "HTML页面数据" @默认值 = 空对象>
    参数 用户数据 <类型 = FOFHTTP_用户数据 注释 = "cookies 包括 设置文本,有效时间,有效目录三个参数">
    {
        变量 辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 局_响应头 <类型 = 文本型>
        局_响应头 = 局_响应头 + 内_HTTP版本 + " 404 Not Found" + FOFHTTP_常用常量.换行符
        如果 (寻找文本 (用户数据.HTTP_Connection, "Keep-Alive", , 真) == -1)
        {
            局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        }
        否则
        {
            局_响应头 = 局_响应头 + "Connection: Keep-Alive" + FOFHTTP_常用常量.换行符

        }

        局_响应头 = 局_响应头 + "Server: " + 内_服务名称 + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Connection: close" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + "Content-Type: text/html" + FOFHTTP_常用常量.换行符
        局_响应头 = 局_响应头 + 辅助.Cookie类到Cookie文本 (用户数据.HTTP_待发整理.cookie)
        如果 (页面数据 == 空对象)
        {
            页面数据 = FOFHTTP_常用常量.UTF8_404页面

        }

        局_响应头 = 局_响应头 + "Content-Length: " + 到文本 (取字节集长度 (页面数据)) + FOFHTTP_常用常量.换行符 + FOFHTTP_常用常量.换行符
        变量 局_数据段 <类型 = 字节集类>
        局_数据段 = 文本到UTF8 (局_响应头, 假)
        局_数据段.添加字节集 (页面数据)
        如果 (内_当前服务类型 == 1)
        {
            返回 (服务器.发送字节集 (服务句柄, 连接ID, 局_数据段))

        }
        否则
        {
            返回 (服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 局_数据段))

        }


    }

    方法 内部_防火墙逻辑函数 <类型 = 逻辑型 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 请求类型 <类型 = 整数>
    参数 客户IP <类型 = 文本型>
    参数 XFFIP <类型 = 文本型>
    参数 请求URL <类型 = 文本型>
    {
        如果 (请求类型 == 1 || 请求类型 == 2)  // 防火墙规则
        {
            如果 (全_防火墙.启动状态 == 真)
            {
                变量 最终防火墙配置 <类型 = 文本型>
                最终防火墙配置 = 客户IP + XFFIP
                变量 防火墙 <类型 = 逻辑型>
                防火墙 = 全_防火墙.防火墙逻辑 (最终防火墙配置, 请求URL)
                如果 (防火墙 == 真)  // 触发防火墙限制
                {
                    触发防火墙 (最终防火墙配置, 请求URL)
                    变量 防火墙协议 <类型 = 文本型 值 = "HTTP/1.1 200 OK\r\nConnection: close\r\nContent-Type: text/html\r\nContent-Length: 长度替换\r\n\r\n">
                    变量 内容 <类型 = 文本型
                            值 = "<html>\r\n        <head>\r\n        <style>\r\n/* latin-ext */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AUi-qJCY.woff2) format(\'woff2\');\r\n  unicode-range: U+0100-024F, U+0259, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F, U+A720-A7FF;\r\n}\r\n/* latin */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AXC-q.woff2) format(\'woff2\');\r\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\r\n}\r\n\r\n        </style>\r\n        <meta charset=\"UTF-8\">\r\n\t\t<link href=\'//fonts.googleapis.com/css?family=Lato:100\' rel=\'stylesheet\' type=\'text/css\'>\r\n\t\t<style>\r\n\t\t\tbody {\r\n\t\t\t\tmargin: 0;\r\n\t\t\t\tpadding: 0;\r\n\t\t\t\twidth: 100%;\r\n\t\t\t\theight: 100%;\r\n\t\t\t\tcolor: #B0BEC5;\r\n\t\t\t\tdisplay: table;\r\n\t\t\t\tfont-weight: 100;\r\n\t\t\t\tfont-family: \'Lato\';\r\n\t\t\t}\r\n\r\n\t\t\t.container {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: table-cell;\r\n\t\t\t\tvertical-align: middle;\r\n\t\t\t}\r\n\r\n\t\t\t.content {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: inline-block;\r\n\t\t\t}\r\n\r\n\t\t\t.title {\r\n\t\t\t\tfont-size: 42px;\r\n\t\t\t\tmargin-bottom: 40px;\r\n\t\t\t}\r\n\t\t</style>\r\n\t</head>\r\n\t<body>\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"content\">\r\n\t\t\t\t<div class=\"title\">很抱歉，你触发了网站的防火墙设置！</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</body>\r\n</html>">
                    子文本替换 (防火墙协议, "长度替换", 到文本 (取文本长度 (内容)), , , 真)
                    防火墙协议 = 防火墙协议 + 内容
                    如果 (内_当前服务类型 == 1)
                    {
                        服务器.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (防火墙协议, 假))
                    }
                    否则
                    {
                        服务器_HTTPS.发送字节集 (服务句柄, 连接ID, 文本到UTF8 (防火墙协议, 假))

                    }

                    返回 (真)

                }

            }

        }

        返回 (假)
    }

    # //内部封装方法===
    #
}

类 FOFHTTP转发服务器 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "实现TCP转发服务器,高并发线程安全." 折叠 折叠2>
{
    变量 代理端 <类型 = HP_TCP代理类>
    变量 服务端 <类型 = HP_TCP服务器>
    变量 转发地址_ <类型 = 文本型>
    变量 转发端口_ <类型 = 短整数数组类>
    变量 转发锁_ <类型 = 类_全局锁>
    变量 当前转发位置_ <公开 类型 = 整数>
    变量 错误码_ <公开 类型 = 整数>

    方法 停止 <公开 折叠>
    {
        服务端.停止 ()
        代理端.停止 ()
        转发被关闭 ()
    }

    方法 启动 <公开 类型 = 逻辑型 注释 = "初始化并启动转发服务器" 返回值注释 = "返回初始化结果" 折叠>
    参数 地址 <类型 = 文本型 注释 = "提供所欲监听的地址">
    参数 端口 <类型 = 整数 注释 = "提供所欲监听的端口号. 有效端口号从0到65535.">
    参数 转发地址 <类型 = 文本型 注释 = "提供所欲转发到的服务器地址">
    参数 转发端口 <类型 = 短整数数组类 注释 = "提供所欲转发到的服务器端口. 有效端口号从0到65535.">
    {
        转发地址_ = 转发地址
        当前转发位置_ = 0
        变量 循环变量 <类型 = 整数>
        循环 (0, 转发端口.取成员数 (), 循环变量)
        {
            转发端口_.加入成员 (转发端口.取成员 (循环变量))
        }
        返回 (代理端.启动 () && 服务端.启动 (地址, 端口))
    }

    方法 出现错误 <折叠>
    参数 客户ID <类型 = 变整数>
    {
        调试输出 (111222333)
        如果 (转发端口_.取成员数 () >= 2)
        {
            转发锁_.进入许可区 ()
            如果 (转发端口_.取成员数 () - 1 > 当前转发位置_)
            {
                当前转发位置_ = 当前转发位置_ + 1
            }
            否则
            {
                当前转发位置_ = 0
            }
            转发锁_.离开许可区 ()

        }
        变量 防火墙协议 <类型 = 文本型 值 = "HTTP/1.1 200 OK\r\nConnection: close\r\nContent-Type: text/html\r\nContent-Length: 长度替换\r\n\r\n">
        变量 内容 <类型 = 文本型
                值 = "<html>\r\n        <head>\r\n        <style>\r\n/* latin-ext */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AUi-qJCY.woff2) format(\'woff2\');\r\n  unicode-range: U+0100-024F, U+0259, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F, U+A720-A7FF;\r\n}\r\n/* latin */\r\n@font-face {\r\n  font-family: \'Lato\';\r\n  font-style: normal;\r\n  font-weight: 100;\r\n  src: local(\'Lato Hairline\'), local(\'Lato-Hairline\'), url(https://fonts.gstatic.com/s/lato/v17/S6u8w4BMUTPHh30AXC-q.woff2) format(\'woff2\');\r\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\r\n}\r\n\r\n        </style>\r\n        <meta charset=\"UTF-8\">\r\n\t\t<link href=\'//fonts.googleapis.com/css?family=Lato:100\' rel=\'stylesheet\' type=\'text/css\'>\r\n\t\t<style>\r\n\t\t\tbody {\r\n\t\t\t\tmargin: 0;\r\n\t\t\t\tpadding: 0;\r\n\t\t\t\twidth: 100%;\r\n\t\t\t\theight: 100%;\r\n\t\t\t\tcolor: #B0BEC5;\r\n\t\t\t\tdisplay: table;\r\n\t\t\t\tfont-weight: 100;\r\n\t\t\t\tfont-family: \'Lato\';\r\n\t\t\t}\r\n\r\n\t\t\t.container {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: table-cell;\r\n\t\t\t\tvertical-align: middle;\r\n\t\t\t}\r\n\r\n\t\t\t.content {\r\n\t\t\t\ttext-align: center;\r\n\t\t\t\tdisplay: inline-block;\r\n\t\t\t}\r\n\r\n\t\t\t.title {\r\n\t\t\t\tfont-size: 42px;\r\n\t\t\t\tmargin-bottom: 40px;\r\n\t\t\t}\r\n\t\t</style>\r\n\t</head>\r\n\t<body>\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"content\">\r\n\t\t\t\t<div class=\"title\">当前网站访问用户数剧增，请稍等片刻再进行访问！</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</body>\r\n</html>">
        子文本替换 (防火墙协议, "长度替换", 到文本 (取文本长度 (内容)), , , 真)
        防火墙协议 = 防火墙协议 + 内容
        服务端.发送数据 (客户ID, 文本到UTF8 (防火墙协议, 假), , )
        服务端.断开连接 (客户ID, 真)
    }

    方法 取服务器对象 <公开 类型 = HP_TCP服务器 注释 = "获取当前转发端中所使用的服务器对象,可用于设置其各项属性或参数." 折叠 @视窗.返回参考 = 真>
    {
        返回 (服务端)
    }

    方法 取代理对象 <公开 类型 = HP_TCP代理类 注释 = "获取当前转发端中所使用的代理端对象,可用于设置其各项属性或参数." 折叠 @视窗.返回参考 = 真>
    {
        返回 (代理端)
    }

    方法 HP_TCP代理类_数据进入 <接收事件 类型 = 整数 注释 = "当通信组件成功接收数据后将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接并触发关闭事件." 折叠>
    参数 来源对象 <类型 = HP_TCP代理类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "接收到的数据由该连接ID发过来.">
    参数 已接收数据 <类型 = 字节集类 注释 = "所接收到的数据.">
    参数 已接收长度 <类型 = 整数 注释 = "已接收数据长度.">
    {
        如果 (来源对象 == 代理端)
        {
            变量 客户ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户ID)))
            {
                服务端.发送数据 (客户ID, 已接收数据, , )
                返回 (0)

            }

        }
        返回 (2)
    }

    方法 HP_TCP代理类_连接完成 <接收事件 类型 = 整数 注释 = "与服务端成功建立连接时本事件将被触发." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作, 继续执行." 返回值注释 = "  2 = 本次操作错误, 如果为同步连接将终止启动通信客户端,为异步则会关闭连接." 折叠>
    参数 来源对象 <类型 = HP_TCP代理类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        如果 (来源对象 == 代理端)
        {
            变量 客户ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户ID)))
            {
                返回 (客户已连接 (客户ID))
            }
        }
        返回 (0)
    }

    方法 HP_TCP代理类_通信发生错误 <接收事件 类型 = 整数 注释 = "当通信组件主动或被动与服务器断开后将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_TCP代理类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        如果 (来源对象 == 代理端)
        {
            变量 客户ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户ID)))
            {
                如果 (错误码 != HP错误码.成功)
                {
                    错误码_ = (整数)错误码
                    出现错误 (客户ID)

                }

            }
        }
        返回 (0)
    }

    方法 HP_TCP代理类_发送完毕 <接收事件 类型 = 整数 注释 = "当通信组件发送数据成功后,将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_TCP代理类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "接收本次发送所对应的连接ID.">
    参数 数据 <类型 = 字节集类 注释 = "本次所发送的数据.">
    参数 数据长度 <类型 = 整数 注释 = "所发送数据的长度.">
    {
        如果 (来源对象 == 代理端)
        {
            变量 客户ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户ID)))
            {
                返回 (数据转发成功 (客户ID, 数据, 数据长度))
            }
        }
        返回 (0)
    }

    方法 HP_TCP服务器_客户离开 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_TCP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        如果 (来源对象 == 服务端)
        {
            变量 客户端ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户端ID)))
            {
                代理端.断开连接 (客户端ID, 真)
                返回 (客户离开 (连接ID, 关闭原因, 错误码))

            }
        }
        返回 (0)
    }

    方法 HP_TCP服务器_客户进入 <接收事件 类型 = 整数 注释 = "  当客户连接到服务器后,将会触发本事件,请注意,本事件下的连接并非是正式连接,"
            注释 = "只有该连接通过\"完成握手\"事件,才可以与服务器建立正式连接,本事件返回值拥有具体意义,请参考返回值说明." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 将触发\"完成握手\"事件."
            返回值注释 = "  1 = 忽略本次操作, 将触发\"完成握手\"事件." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接." 折叠 折叠2>
    参数 来源对象 <类型 = HP_TCP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        如果 (来源对象 == 服务端)
        {
            变量 客户ID <类型 = 变整数类>
            变量 客户IP <类型 = 文本型>
            服务端.取客户本地地址 (连接ID, 客户IP)
            如果 (代理端.连接 (转发地址_, 转发端口_.取成员 (当前转发位置_), , , , 客户ID))
            {
                如果 (代理端.置连接附加数据 (客户ID.值, 连接ID) && 服务端.置连接附加数据 (连接ID, 客户ID.值))
                {
                    返回 (客户正在连接 (连接ID))
                }
                出现错误 (连接ID)
            }
            否则
            {
                出现错误 (连接ID)

            }
        }
        返回 (2)
    }

    方法 HP_TCP服务器_数据进入 <接收事件 类型 = 整数 注释 = "当服务器成功接收数据后将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接并触发关闭事件." 折叠>
    参数 来源对象 <类型 = HP_TCP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "接收到的数据由该连接ID发过来.">
    参数 已接收数据 <类型 = 字节集类 注释 = "所接收到的数据.">
    参数 已接收长度 <类型 = 整数 注释 = "已接收数据长度.">
    {
        如果 (来源对象 == 服务端)
        {
            变量 客户ID <类型 = 变整数>
            如果 (来源对象.取连接附加数据 (连接ID, 取变量地址 (客户ID)))
            {
                代理端.发送数据 (客户ID, 已接收数据, , )
                返回 (0)
            }
        }
        返回 (2)
    }

    方法 HP_TCP服务器_启动完毕 <接收事件 类型 = 整数 注释 = "服务器端启动完毕并开始监听后,将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_TCP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        如果 (来源对象 == 服务端)
        {
            变量 当前地址 <类型 = 文本型>
            来源对象.取当前监听地址 (当前地址)
            返回 (启动完毕 (当前地址, 来源对象.取当前监听端口 ()))
        }
        返回 (0)
    }

    方法 HP_TCP服务器_发送完毕 <接收事件 类型 = 整数 注释 = "当服务器发送数据成功后,将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_TCP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "接收本次发送所对应的连接ID.">
    参数 数据 <类型 = 字节集类 注释 = "本次所发送的数据.">
    参数 数据长度 <类型 = 整数 注释 = "所发送数据的长度.">
    {
        如果 (来源对象 == 服务端)
        {
            返回 (数据接收成功 (连接ID, 数据, 数据长度))
        }
        返回 (0)
    }

    方法 启动完毕 <公开 定义事件 类型 = 整数 注释 = "当转发服务器启动后准备就绪时本事件将被发送" 折叠>
    参数 本地地址 <类型 = 文本型 注释 = "转发端本地所监听的地址">
    参数 本地端口 <类型 = 整数 注释 = "转发端本地所监听的端口">

    方法 客户离开 <公开 定义事件 类型 = 整数 注释 = "当转发的客户端从转发目标端失去连接或从本地转发端失去连接时,本事件将被发送." 折叠>
    参数 连接ID <类型 = 变整数 注释 = "当前转发端本地的客户连接ID">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码">

    方法 客户正在连接 <公开 定义事件 类型 = 整数 注释 = "当客户端准备连接到转发服务器时本事件将被发送" 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接并触发关闭事件." 折叠>
    参数 连接ID <类型 = 变整数 注释 = "当前转发端本地的客户连接ID">

    方法 客户已连接 <公开 定义事件 类型 = 整数 注释 = "当客户端已成功连接到转发目标端时本事件被发送" 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作, 继续执行." 返回值注释 = "  2 = 本次操作错误, 如果为同步连接将终止启动通信客户端,为异步则会关闭连接." 折叠>
    参数 连接ID <类型 = 变整数 注释 = "当前转发端本地的客户连接ID">

    方法 转发被关闭 <公开 定义事件 类型 = 整数 注释 = "当转发服务器被关闭时本事件将被发送">

    方法 数据转发成功 <公开 定义事件 类型 = 整数 注释 = "当转发服务器收到真实客户端发送的数据并成功转发至目标服务器时本事件将被发送,可用于流量统计." 折叠>
    参数 连接ID <类型 = 变整数 注释 = "当前转发端本地的客户连接ID">
    参数 数据 <类型 = 字节集类 注释 = "当前转发端本次成功转发的数据内容">
    参数 数据长度 <类型 = 整数 注释 = "当前转发端本次成功转发的数据长度">

    方法 数据接收成功 <公开 定义事件 类型 = 整数 注释 = "当转发服务器收到转发目标服务器发送的数据并成功转发至真实客户端时本事件将被发送,可用于流量统计." 折叠>
    参数 连接ID <类型 = 变整数 注释 = "当前转发端本地的客户连接ID">
    参数 数据 <类型 = 字节集类 注释 = "当前转发端本次成功转发的数据内容">
    参数 数据长度 <类型 = 整数 注释 = "当前转发端本次成功转发的数据长度">
}
