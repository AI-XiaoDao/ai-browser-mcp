<火山程序 类型 = "通常" 版本 = 1 />

包 LkuaiyHttp.com <注释 = "本框架基于HP-Socket" 注释 = "本框架上层HTTP代码由利快云封装开发，欢迎加入官方群：445790831"
        注释 = "不要问本框架效率如何，HPSocket的效率怎么样，本框架的效率就怎么样" 注释 = "出现问题不要觉得是本框架的问题，本框架是基于HPSocket，HPSocket没有问题"
        注释 = "如果你确实检查了自己的代码，仍然觉得有问题，请在心里默念一百遍于HPSocket框架没有问题" 注释 = "然后再检查是否是自己的问题" 注释 = "学习本框架请一定加入官方群：445790831，群里提问请友善一点" 折叠2>

类 "//启动类" <公开 基础类 = 窗口程序类 注释 = "启动的类" 折叠>
{
    变量 主窗口对象 <类型 = 我的主窗口 标题 = "我的主窗口">

    方法 启动方法 <公开 类型 = 整数 折叠>
    {
        主窗口对象.创建主窗口 ()
        返回 (1)
    }
}

类 "//我的主窗口" <基础类 = 窗口 注释 = "样例主窗口" 注释 = "" 折叠 折叠2 @视窗.布局 = "client_size = \"500, 229\"">
{
    变量 FOF网站 <类型 = FOFHTTP>
    变量 按钮_开启服务器 <类型 = 按钮 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"56, 64, 176, 72\"" 标题 = "开启服务器">
    变量 按钮_关闭服务器 <类型 = 按钮 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"272, 64, 176, 72\"" 标题 = "关闭服务器">

    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 我的主窗口>
    参数 标记值 <类型 = 整数>
    {
        标题 = "FOF网站程序"
        按钮_关闭服务器.禁止 = 真
        FOF网站.初始化HTTP服务 ()
        返回 (0)
    }

    方法 按钮_被单击 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 按钮_开启服务器)
        {
            变量 防火墙设置 <类型 = FOFHTTP_防火墙>
            // 防火墙它最主要的作用就是用来简单的抵御其他人的cc或者ddos
            防火墙设置.设置启动 = 假
            防火墙设置.防火墙设置 (, 500, )
            如果 (FOF网站.启动HTTP服务 (, , , , "FOF课程服务", , 10, 防火墙设置, ) == 真)
            {
                标题 = "启动网站服务成功"
                按钮_关闭服务器.禁止 = 假
                按钮_开启服务器.禁止 = 真
            }
            否则
            {
                标题 = "启动网站服务失败"

            }

        }
        如果 (来源对象 == 按钮_关闭服务器)
        {
            如果 (FOF网站.结束HTTP服务 () == 真)
            {
                按钮_关闭服务器.禁止 = 真
                按钮_开启服务器.禁止 = 假
                标题 = "关闭服务器成功"
            }
            否则
            {
                标题 = "关闭服务器失败"

            }


        }



        返回 (0)
    }

    方法 FOFHTTP_Get事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = FOFHTTP>
    参数 标记值 <类型 = 整数>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        变量 文件处理 <类型 = FOFHTTP_文件发送>
        如果 (文件处理.Get文件处理 (来源对象, 服务句柄, 连接ID, 数据大小, 用户数据) == 真)  // 就代表目前请求的是文件,并且这个文件是存在的
        {
            返回 (0)

        }

        用户数据.HTTP_待发整理.文件后缀 = "html"  // 我们的网站页面,我们将它称之为HTML
        来源对象.发送404页面错误 (服务句柄, 连接ID, , 用户数据)  // 我们发送了一个404错误页面给我们的浏览器
        返回 (0)
    }

    方法 FOFHTTP_Post事件 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = FOFHTTP>
    参数 标记值 <类型 = 整数>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        变量 文件处理 <类型 = FOFHTTP_文件发送>
        如果 (文件处理.Post文件处理 (来源对象, 服务句柄, 连接ID, 数据大小, 用户数据) == 真)  // 就代表目前请求的是文件,并且这个文件是存在的
        {
            返回 (0)

        }
        如果 (文件处理.Post数据组装 (来源对象, 服务句柄, 连接ID, 数据大小, 用户数据) == 假)  // POST的数据组装处理
        {
            返回 (0)

        }



        用户数据.HTTP_待发整理.文件后缀 = "html"  // 我们的网站页面,我们将它称之为HTML
        来源对象.发送404页面错误 (服务句柄, 连接ID, , 用户数据)  // 我们发送了一个404错误页面给我们的浏览器
        返回 (0)
    }
}

类 FOFHTTP_防火墙 <公开 注释 = "注意：该版本的FOF已经支持了GET和POST的双防火墙！" 注释 = "注意：如果使用了nginx反向代理，请务必将nginx反向代理的IP转发协议头设置为：X-Forwarded-For:"
        注释 = "友情提示：压力测试时请关闭本防火墙" 折叠 折叠2>
{
    变量 次数表 <类型 = 类_键值表>
    变量 限制表 <类型 = 类_键值表>
    变量 时间表 <类型 = 类_键值表>
    变量 是否启动 <类型 = 逻辑型 值 = 假 注释 = "真为启动防火墙，假代表不启动">
    变量 触发时间 <类型 = 整数 值 = 60 注释 = "单位（秒）默认120秒">
    变量 触发次数 <类型 = 整数 值 = 200 注释 = "单位次，如果在触发时间内超过了本次书则触发防火墙">
    变量 限制时间 <类型 = 整数 值 = 180 注释 = "限制时间，默认限制三分钟">

    方法 防火墙设置 <公开 注释 = "注意：如果使用了反向代理，请务必将反向代理的IP转发协议头设置为：X-Forwarded-For:" 折叠>
    参数 触发时间_ <类型 = 整数 注释 = "单位（秒）默认60秒" @默认值 = 60>
    参数 触发次数_ <类型 = 整数 注释 = "单位次，如果在触发时间内超过了本次数则触发防火墙" @默认值 = 300>
    参数 限制时间_ <类型 = 整数 注释 = "限制时间，默认限制两分钟" @默认值 = 120>
    {
        触发时间 = 触发时间_
        触发次数 = 触发次数_
        限制时间 = 限制时间_
    }

    方法 启动状态 <公开 属性读 类型 = 逻辑型 折叠>
    {
        返回 (是否启动)
    }

    方法 设置启动 <公开 属性写 注释 = "真代表启动，假代表不启动" 折叠>
    参数 启动状态 <类型 = 逻辑型>
    {
        是否启动 = 启动状态
        如果 (是否启动 == 真)
        {
            变量 防火墙提醒 <类型 = 文本型
                    值 = "注意：本防火墙只针对GET请求，对于POST请求不做任何的防护\r\n如需对POST进行防护，可以关闭本防火墙在GET及POST事件下建立自己的防火墙机制\r\n\r\n友情提示：压力测试时请关闭本防火墙">

            调试输出 (防火墙提醒)

        }
    }

    方法 设置启动 <公开 属性读 类型 = 逻辑型 注释 = "真代表启动，假代表不启动" 折叠>
    {
        返回 (是否启动)
    }

    方法 防火墙逻辑 <公开 类型 = 逻辑型 注释 = "返回假代表正常，返回真代表触发逻辑">
    参数 标识 <类型 = 文本型 注释 = "用户的标识">
    参数 访问URL <类型 = 文本型>
    {
        变量 时间 <类型 = 类_时间辅助函数>
        如果 (是否启动 == 假)
        {
            返回 (假)

        }

        如果 (限制表.成员是否存在 (标识) == 真)
        {
            变量 老时间 <类型 = 长整数>
            老时间 = 限制表.取长整数值 (标识)
            如果 (老时间 + 限制时间 < 时间.时间_取现行时间戳10位_长整数 ())  // 可以解除限制了
            {
                限制表.删除成员 (标识)
                次数表.删除成员 (标识 + 访问URL)
                次数表.置入整数值 (标识 + 访问URL, 1)
                时间表.删除成员 (标识 + 访问URL)
                时间表.置入长整数值 (标识 + 访问URL, 时间.时间_取现行时间戳10位_长整数 ())
                返回 (假)
            }
            否则
            {
                返回 (真)

            }

        }

        如果 (时间表.成员是否存在 (标识 + 访问URL) == 真)
        {
            如果 (次数表.成员是否存在 (标识 + 访问URL) == 真)
            {
                变量 老时间 <类型 = 长整数>
                变量 老次数 <类型 = 整数>
                老时间 = 时间表.取长整数值 (标识 + 访问URL)
                老次数 = 次数表.取整数值 (标识 + 访问URL)
                如果 (老时间 + 触发时间 > 时间.时间_取现行时间戳10位_长整数 ())  // 在规定时间内
                {
                    如果 (老次数 >= 触发次数)  // 触发了限制
                    {
                        限制表.置入长整数值 (标识, 时间.时间_取现行时间戳10位_长整数 ())
                        返回 (真)
                    }
                    否则
                    {
                        老次数 = 老次数 + 1
                        次数表.置入整数值 (标识 + 访问URL, 老次数)

                    }

                }
                否则  // 如果超过了规定的时间,那么就要重新计零
                {
                    老时间 = 时间.时间_取现行时间戳10位_长整数 ()
                    时间表.置入长整数值 (标识 + 访问URL, 老时间)
                    次数表.置入整数值 (标识 + 访问URL, 1)

                }

                返回 (假)
            }
            否则
            {
                次数表.置入整数值 (标识 + 访问URL, 1)
                返回 (假)

            }

        }
        否则
        {
            时间表.置入长整数值 (标识 + 访问URL, 时间.时间_取现行时间戳10位_长整数 ())
            返回 (假)

        }

    }
}

类 FOFHTTP_配置项 <公开 折叠>
{
    变量 当前模式 <公开 类型 = 整数 值 = 2 注释 = "本参数默认为模式2，模式2为稳定版" 注释 = "请一如既往的设置本值为2即可" 折叠2>
    变量 是否启用内置favicon图标 <公开 类型 = 逻辑型 值 = 假 注释 = "如果本属性设置为真，就务必要设置内置favicon图标，可以直接使用读入文件()命令将favicon.ico读入给内置favicon图标属性">
    变量 内置favicon图标 <公开 类型 = 字节集类 注释 = "favicon.ico" "">
    变量 允许文件上传最大尺寸 <公开 类型 = 长整数 值 = 8200000 注释 = "设置允许上传的最大尺寸，默认8M" 注释 = "也就是只能上传8M以下的文件；该参数可自行设置服务端允许接受的最大文件" 折叠2>
    变量 发送目录遍历模式 <公开 类型 = 整数 值 = 1 注释 = "在FOF中项目目录可以设置多个，在使用【FOFHTTP_文件发送】的Get文件处理命令时，会根据设置的项目目录来发送文件"
            注释 = "本参数为1时代表发送文件时以正序遍历设置的项目目录发送文件" 注释 = "本参数为2时代表发送文件时以倒序遍历设置的项目目录发送文件" 注释 = "注意：如果使用了【绑定域名】属性绑定了域名目录，则该本属性无效" 折叠2>
    变量 是否运行中文文件名 <公开 类型 = 逻辑型 值 = 真 注释 = "如果本参数为真则类似JS、CSS、png等文件名称允许中文，为假遇见中文名称会发送失败">
    变量 绑定域名 <公开 类型 = 文本数组类 注释 = "如果设置了本项,则只有绑定的域名才可以访问"
            注释 = "参考案例：https://www.lkuaiy.com/rsdetails?page=1&id=16483429594171356" 折叠2>
    变量 长连接开启状态 <公开 类型 = 逻辑型 值 = 真 注释 = "是否支持【Connection: Keep-Alive】模式">
    变量 被攻击公告 <公开 类型 = 整数 值 = 0 注释 = "开启网站的被攻击被动公告模式" 注释 = "为1的情况下：公告网站正在维护" 注释 = "为2的情况下：公告网站正在被攻击" 注释 = ""
            注释 = "当设置本属性后，用户将无法正常访问网站" 折叠2>
    变量 资源发送域名 <公开 类型 = 文本型 注释 = "不为空的情况下，文件资源将被转发到此域名，例如：\"https://bbs.lkuaiy.com\"" 注释 = "也就是文件将会通过301跳转到本属性设置的域名" 折叠2>
    变量 资源发送域名头 <公开 类型 = 文本型 注释 = "在设置了资源发送域名的情况下需要设置本处" 注释 = "本格式为：资源发送域名没有http://和https://的格式" 注释 = "例如:bbs.lkuaiy.com" 折叠2>
    变量 不走资源发送域名路径 <公开 类型 = 文本数组类 注释 = "再设置了“资源发送域名”情况下" 注释 = "例如有一个链接为：https://www.xxx.com/path/1234.html"
            注释 = "如果本处添加成员：\"path\" 则path路径下的所有文件不会走资源发送域名！" 折叠2>
    变量 资源发送模式 <公开 类型 = 整数 值 = 0 注释 = "在【资源发送域名】属性不为空时触发" 注释 = "0代表所有通过get文件发送函数发送的静态资源都将被【资源发送域名】转发"
            注释 = "1代表除掉js外的所有通过get文件发送函数发送的静态资源都将被【资源发送域名】转发" 注释 = "2代表除掉js、css外的所有通过get文件发送函数发送的静态资源都将被【资源发送域名】转发" 折叠2>
    变量 开启跨域模式 <公开 类型 = 逻辑型 值 = 假>
    变量 全局内容替换 <公开 类型 = JSONCPP对象类 注释 = "全局替换css、js、html内容" 注释 = "例如：全局内容替换.置入文本值(\"我是替换的名称\",\"我是替换的内容\")"
            注释 = "此时当页面中有：\"我是替换的名称\"时，则会被替换为：\"我是替换的内容\"" 注释 = "注意：只能置入文本值！" 折叠2>
    变量 安全路径模式 <公开 类型 = 逻辑型 值 = 真>

    #
}

类 FOFHTTP_页面缓存池 <公开 注释 = "使用案例：https://www.lkuaiy.com/rsdetails?id=16257580412636" 注释 = "本类只适合小数据缓存，理论上缓存的条数不建议超过10000条" 折叠
        折叠2>
{
    变量 全局临时缓存表 <类型 = 高性能缓存表 折叠>
    变量 全局持久缓存表 <类型 = 高性能缓存表>
    变量 内部_缓存最大数量 <类型 = 整数 注释 = "缓存超过该参数条数据，将不在进行持久缓存">
    变量 内部_是否开启缓存 <类型 = 逻辑型>

    方法 初始化缓存路径并开启缓存 <公开 注释 = "本类只适合小数据缓存，理论上缓存的条数不建议超过5000条" 折叠>
    参数 持久缓存文件夹路径 <类型 = 文本型 注释 = "必须是文件夹的全路径" 注释 = "路径结尾必须腰带有/符号" 注释 = "正确：C:/XXX/XXX/" 注释 = "错误：C:/XXX/XXX" 折叠2>
    参数 临时缓存文件夹路径 <类型 = 文本型 注释 = "必须是文件夹的全路径" 注释 = "路径结尾必须腰带有/符号" 注释 = "正确：C:/XXX/XXX/" 注释 = "错误：C:/XXX/XXX"
            注释 = "本路径的所有文件会在服务启动的时候进行一次删除" 折叠2>
    参数 持久缓存最大数 <类型 = 整数 注释 = "注意：本参数全局有效" 注释 = "新版本的FOF，缓存百万级无压力" 注释 = "缓存的最大数量 不建议超过100万；峰值最多200万"
            注释 = "因MMKV的设计，100万的缓存将会占用180MB的内存。" 注释 = "如果你使用了缓存功能，发现内存有增长，均属正常现象" 折叠2 @默认值 = 1000000>
    参数 是否清空临时缓存 <类型 = 逻辑型 @默认值 = 真>
    参数 是否清空持久缓存 <类型 = 逻辑型 @默认值 = 假>
    {
        创建目录 (持久缓存文件夹路径)
        创建目录 (临时缓存文件夹路径)
        如果 (是否清空临时缓存 == 真)
        {
            删除文件 (取运行目录 () + "缓存表\\LsHc")
            删除文件 (取运行目录 () + "缓存表\\LsHc.crc")
        }
        如果 (是否清空持久缓存 == 真)
        {
            删除文件 (取运行目录 () + "缓存表\\YjHc")
            删除文件 (取运行目录 () + "缓存表\\YjHc.crc")

        }
        全局临时缓存表.打开 ("LsHc", , )
        全局持久缓存表.打开 ("YjHc", , )
        如果 (全局临时缓存表.是否存在表 ("LsHc", ) == 真 && 全局持久缓存表.是否存在表 ("YjHc", ) == 真)
        {
            内部_是否开启缓存 = 真

        }
        内部_缓存最大数量 = 持久缓存最大数
        变量 调试输出文本内容 <类型 = 文本型
                值 = "注意：本版本缓存库，百万级缓存无压力，不需要再根据课程中所说的那样降低缓存数量；此版本后的FOF缓存都是百万级！。\r\n注意：缓存的最大数量 不建议超过1000万。\r\n注意：因MMKV的设计，100万的缓存将会占用大约180MB的内存。\r\n如果你使用了缓存功能，发现内存有增长，均属正常现象。">
        调试输出 (调试输出文本内容)
    }

    方法 添加临时缓存 <公开 类型 = 整数 返回值注释 = "返回0失败，返回1成功，返回2代表缓存已经存在，返回3代表缓存数量超过了缓存最大数，添加缓存失败" 折叠>
    参数 缓存字节集 <类型 = 字节集类>
    参数 缓存标识 <类型 = 文本型 注释 = "不能有任何特殊字符，可以是URL等">
    参数 过期时间 <类型 = 长整数 注释 = "十位时间戳">
    {
