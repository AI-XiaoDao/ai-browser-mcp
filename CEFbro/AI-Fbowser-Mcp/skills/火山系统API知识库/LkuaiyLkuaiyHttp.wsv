        返回参数 = 删首尾空 (返回参数)
        如果 (寻找文本 (返回参数, "=") == -1)
        {
            返回参数 = ""

        }
        返回 (返回参数)
    }

    方法 数据防SQL注入处理 <公开 类型 = 文本型 注释 = "注意：本方法会将关键字做一些处理，所以请参考是否适用于自己的项目" 折叠>
    参数 数据内容 <类型 = 文本型>
    参数 是否启用星号防护 <类型 = 逻辑型>
    参数 是否启用单引号防护 <类型 = 逻辑型>
    参数 是否启用逗号防护 <类型 = 逻辑型>
    参数 是否启用加号防护 <类型 = 逻辑型>
    参数 是否启用流程关键字防护 <类型 = 逻辑型>
    {
        变量 参数内容 <类型 = 文本型>
        参数内容 = 数据内容
        如果 (参数内容 != "")
        {
            子文本替换 (参数内容, "update", "u p d a t e", , , 假)
            子文本替换 (参数内容, "delete", "d e l e t e", , , 假)
            子文本替换 (参数内容, "insert", "i n s e r t", , , 假)
            子文本替换 (参数内容, "select", "s e l e c t", , , 假)
            如果 (是否启用星号防护 == 真)
            {
                子文本替换 (参数内容, "*", "", , , 假)

            }
            如果 (是否启用单引号防护 == 真)
            {
                子文本替换 (参数内容, "'", "’", , , 假)

            }
            如果 (是否启用逗号防护 == 真)
            {
                子文本替换 (参数内容, ",", "，", , , 假)

            }
            如果 (是否启用加号防护 == 真)
            {
                子文本替换 (参数内容, "+", "", , , 假)

            }
            如果 (是否启用流程关键字防护 == 真)
            {
                子文本替换 (参数内容, "asc", "a s c", , , 假)
                子文本替换 (参数内容, "and", "a n d", , , 假)
                子文本替换 (参数内容, "=", "", , , 假)

            }

            子文本替换 (参数内容, "sysfiles", "s y s f i l e s", , , 假)
            子文本替换 (参数内容, "all", "a l l", , , 假)
            子文本替换 (参数内容, "union", "u n i o n", , , 假)
            子文本替换 (参数内容, "cast", "c a s t", , , 假)
            子文本替换 (参数内容, "char(", "c h a r(", , , 假)
            子文本替换 (参数内容, "varchar(", "v a r c h a r(", , , 假)
            子文本替换 (参数内容, "filename", "f i l e n a m e", , , 假)
            子文本替换 (参数内容, "sysdatabases", "s y s d a t a b a s e s", , , 假)
            子文本替换 (参数内容, "xtype", "x t y p e", , , 假)
            子文本替换 (参数内容, "database", "d a t a b a s e", , , 假)
            子文本替换 (参数内容, "version", "v e r s i o n", , , 假)
            子文本替换 (参数内容, "substring", "s u b s t r i n g", , , 假)
            子文本替换 (参数内容, "@", "[@]", , , 假)
            子文本替换 (参数内容, "((", "", , , 假)
            子文本替换 (参数内容, "))", "", , , 假)
            子文本替换 (参数内容, " len", " l e n", , , 假)
            子文本替换 (参数内容, "updatexml", "u p d a t e x m l", , , 假)
            子文本替换 (参数内容, "concat", "c o n c a t", , , 假)
            子文本替换 (参数内容, "database", "d a t a b a s e", , , 假)
            返回 (参数内容)
        }
        否则
        {
            返回 (参数内容)

        }

    }

    方法 取地址文件名称 <公开 类型 = 文本型 返回值注释 = "失败返回空文本" 折叠>
    参数 文件地址 <类型 = 文本型 注释 = "可以取网页文件地址【http://xxx.xxx.xxx/123.zip】，也可以直接取实体文件地址【C:\\1.zip】">
    {
        变量 临时文本 <类型 = 文本型>
        临时文本 = 文件地址
        子文本替换 (临时文本, "/", "\\")
        如果 (寻找文本 (临时文本, "\\") == -1)
        {
            返回 ("")

        }
        变量 结尾符号位 <类型 = 整数>
        结尾符号位 = 倒找文本 (临时文本, "\\", , 假)
        如果 (结尾符号位 == -1)
        {
            返回 ("")

        }
        变量 需取位置 <类型 = 整数>
        需取位置 = 取文本长度 (临时文本) - 结尾符号位 - 1
        如果 (需取位置 <= -1)
        {
            返回 ("")

        }
        如果 (取文本长度 (临时文本) >= 需取位置)
        {
            返回 (取文本右边 (临时文本, 需取位置))

        }
        返回 ("")
    }

