        {
            如果 (内部_文本协议头数据 == "")
            {
                内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)

            }
            版本号 = 内部_获取协议URL头 (内部_文本协议头数据)
            版本号 = 获取HTTP版本号 (版本号)

        }

        返回 (版本号)

    }

    方法 HTTP_Accept <公开 属性读 类型 = 文本型 注释 = "协议类型，类似image/*,*/*，" 注释 = "Accept 请求头用来告知（服务器）客户端可以处理的内容类型，这种内容类型用MIME类型来表示。"
            注释 = "借助内容协商机制, 服务器可以从诸多备选项中选择一项进行应用，并使用 Content-Type 应答头通知客户端它的选择。" 注释 = "浏览器会基于请求的上下文来为这个请求头设置合适的值"
            注释 = "比如获取一个CSS层叠样式表时值与获取图片、视频或脚本文件时的值是不同的。" 折叠 折叠2>
    {
        如果 (Accept == "")
        {
            如果 (内部_文本协议头数据 == "")
            {
                内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)
            }
            变量 文本 <类型 = 类_文本操作>
            Accept = 文本.文本_取右边 (内部_文本协议头数据, "Accept:", 真)
            如果 (寻找文本 (Accept, FOFHTTP_常用常量.换行符) != -1)
            {
                Accept = 文本.文本_取左边 (Accept, FOFHTTP_常用常量.换行符)

            }

            Accept = 删首尾空 (Accept)

        }
        返回 (Accept)
    }

    方法 HTTP_Referer <公开 属性读 类型 = 文本型 注释 = "HTTP Referer是header的一部分，当浏览器向web服务器发送请求的时候，一般会带上Referer"
            注释 = "告诉服务器我是从哪个页面链接过来的，服务器借此可以获得一些信息用于处理" 注释 = "例如：我们可以用来取来源页面,用于判断来源,但是不一定可靠" 折叠 折叠2>
    {
        如果 (Referer == "")
        {
            如果 (内部_文本协议头数据 == "")
            {
                内部_文本协议头数据 = UTF8到文本 (HTTP_协议头数据)
            }
            变量 文本 <类型 = 类_文本操作>
            Referer = 文本.文本_取右边 (内部_文本协议头数据, "Referer:", 真)
            如果 (寻找文本 (Referer, FOFHTTP_常用常量.换行符) != -1)
            {
                Referer = 文本.文本_取左边 (Referer, FOFHTTP_常用常量.换行符)

            }

            Referer = 删首尾空 (Referer)

        }
