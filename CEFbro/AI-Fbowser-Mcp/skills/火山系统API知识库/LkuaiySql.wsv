    }

    方法 刷新 <公开 类型 = 逻辑型 注释 = "刷新该集合." 返回值注释 = "返回调用结果." 折叠>
    {
        返回 (无参数及返回值方法 ("Refresh"))
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "获取该集合中所包含的指定成员." 折叠>
    参数 索引 <类型 = 整数>
    {
        返回 ((模板类型1)读属性 ("Item", COM对象类, 索引))
    }

    方法 取成员2 <公开 类型 = 模板类型1 注释 = "以指定的成员名称获取该成员对象." 折叠>
    参数 成员名 <类型 = 文本型>
