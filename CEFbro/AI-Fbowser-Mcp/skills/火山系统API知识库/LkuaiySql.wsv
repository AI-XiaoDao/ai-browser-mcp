    方法 查询 <公开 类型 = 逻辑型 注释 = "只能使用查询命令，不能使用增删改等命令！" 注释 = "注意：查询成功后的位置在第0条；需要使用到下一条命令移动到第一条" 注释 = "注意：使用本命令后必须使用关闭()命令"
            返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 Sql语句 <类型 = 文本型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称).">
    参数 数据库 <类型 = 数据库_ODBC数据库 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." 注释 = "如果使用了获取数据库命令则该参数不用填写" 折叠2 @默认值 = 空对象>
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." 折叠2 @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "-1无" 注释 = "0默认" 注释 = "1键集游标" 注释 = "2动态游标" 注释 = "3静态游标" 折叠2 @默认值 = -1>
    参数 是否启用事件 <类型 = 逻辑型 注释 = "启用事件后" 注释 = "【命令执行完成、开始事务完成、提交事务完成、回滚事务完成、警告信息反馈、即将开始执行】等事件才会生效" 注释 = "【取影响行数】等命令才会生效"
            注释 = "注意：如果不需要相关事件和命令请设置为假，本参数会影响执行效率【并发在原有基础上减少%30】" 折叠2 @默认值 = 假>
    参数 参数化语句 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 选项 <类型 = 整数 值 = -1 注释 = "一般提供-1即可" 折叠>
        变量 是否客户端 <类型 = 逻辑型 值 = 真 注释 = "指定是否将游标服务位置指向客户端,默认为真.">
        变量 源 <类型 = COM变体型>
        变量 连接 <类型 = COM变体型>
        变量 是否成功_ <类型 = 数据库_是否成功>
        记录集执行状态 = 1
        如果 (数据库获取状态 == 假)
        {
            如果 (数据库 == 空对象)
            {
                返回 (假)
            }
            数据库COM = 数据库.连接对象 (是否成功_)
            如果 (是否成功_.返回逻辑值 == 假)
            {
                记录集执行状态 = 0
                返回 (假)
            }
            数据库.释放连接 (数据库COM)
        }
        源.赋值 (Sql语句)
        连接.置COM对象 (数据库COM)
        事件启用状态 = 是否启用事件
        变量 事件对象 <类型 = COM对象事件类>
        如果 (是否启用事件 == 真)
        {
            事件对象.挂接 (数据库COM, "{00000400-0000-0010-8000-00AA006D2EA4}")
            挂接事件 (事件对象, )
        }
        变量 是否成功 <类型 = 逻辑型>
        是否成功 = 打开_ (源, 连接, 是否客户端, 游标类型, 编辑锁, 选项)
        如果 (是否成功 == 真)
        {
            到上一条 ()
        }
        返回 (是否成功)
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 注释 = "注意：使用本命令后必须使用关闭()命令" 注释 = "注意：本命令只能执行增删改 不能执行查询！" 返回值注释 = "执行成功返回真,否则返回假.">
    参数 Sql语句 <类型 = 文本型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称).">
    参数 数据库 <类型 = 数据库_ODBC数据库 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." 注释 = "如果使用了获取数据库命令则该参数不用填写" 折叠2 @默认值 = 空对象>
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "-1无" 注释 = "0默认" 注释 = "1键集游标" 注释 = "2动态游标" 注释 = "3静态游标" @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "一般提供-1即可" @默认值 = -1>
    参数 是否启用事件 <类型 = 逻辑型 注释 = "启用事件后" 注释 = "【命令执行完成、开始事务完成、提交事务完成、回滚事务完成、警告信息反馈、即将开始执行】等事件才会生效" 注释 = "【取影响行数】等命令才会生效"
            注释 = "注意：如果不需要相关事件和命令请设置为假，本参数会影响执行效率【并发在原有基础上减少%30】" @默认值 = 假>
    {
        变量 执行状态 <类型 = 逻辑型>
        变量 是否成功_ <类型 = 数据库_是否成功>
        记录集执行状态 = 2
        如果 (数据库获取状态 == 假)
        {
            如果 (数据库 == 空对象)
            {
                返回 (假)

            }
            数据库COM = 数据库.连接对象 (是否成功_)
            如果 (是否成功_.返回逻辑值 == 假)
            {
                记录集执行状态 = 0
                返回 (假)

            }

            数据库.释放连接 (数据库COM)
        }
        如果 (取文本长度 (Sql语句) >= 6)
        {
            如果 (到小写 (取文本左边 (Sql语句, 6)) == "select")
            {
                记录集执行状态 = 0
                返回 (假)

            }
        }
        变量 是否客户端 <类型 = 逻辑型 值 = 真 注释 = "指定是否将游标服务位置指向客户端,默认为真.">
        变量 连接 <类型 = COM变体型>
        变量 源 <类型 = COM变体型>
        源.赋值 (Sql语句)
        连接.置COM对象 (数据库COM)
        事件启用状态 = 是否启用事件
        变量 事件对象 <类型 = COM对象事件类>
        如果 (是否启用事件 == 真)
        {
            事件对象.挂接 (数据库COM, "{00000400-0000-0010-8000-00AA006D2EA4}")
            挂接事件 (事件对象, )

        }

        执行状态 = 打开_ (源, 连接, 是否客户端, 游标类型, 编辑锁, 选项)
        返回 (执行状态)
    }

    方法 取字段列表 <公开 类型 = ODBC数据库字段集合类 注释 = "获取该记录集当前位置所包含的所有字段(列)列表." 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<ODBC数据库字段集合类>(@<记录集对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Fields"), 0, _T ("")));
    }

    方法 读数据 <公开 类型 = COM变体型 注释 = "根据指定字段名读取该记录集当前所处位置的数据." 返回值注释 = "返回当前位置指定字段的数据." 折叠>
