    参数 错误对象 <类型 = 数据库_错误信息 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 警告信息反馈 <公开 定义事件 类型 = 整数 注释 = "在操作过程中如果出现警告信息,本事件将被调用." 注释 = "注意：需要在查询或执行SQL语句的参数中开启【是否启用事件】选项本事件才会生效" 折叠 折叠2>
    参数 错误对象 <类型 = 数据库_错误信息 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 即将开始执行 <公开 定义事件 类型 = 整数 注释 = "即将执行SQL命令时,本事件将被调用." 注释 = "注意：需要在查询或执行SQL语句的参数中开启【是否启用事件】选项本事件才会生效" 折叠 折叠2>
    参数 命令内容 <类型 = 文本型 注释 = "即将执行的命令内容文本.">
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型\"所提供的常量值.">
    参数 编辑锁类型 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型\"所提供的常量值.">
    参数 选项值 <类型 = 整数 注释 = "执行命令或打开记录集所使用的选项值.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 手动初始化 <公开 类型 = 逻辑型 折叠>
    {
        返回 (记录集对象.创建 ("ADODB.recordset"))
    }

    方法 打开_ <类型 = 逻辑型 注释 = "根据指定数据源以及连接串文本打开记录集." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 数据源 <类型 = COM变体型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称)." @默认值 = 空对象>
    参数 活动连接 <类型 = COM变体型 注释 = "是否提供一个已有的活动连接对象(数据库类),也可提供连接串文本,与连接数据库同理." @默认值 = 空对象>
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型\"所提供的常量." @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型\"所提供的常量." @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    {
        // 记录集对象.创建 ("ADODB.recordset")
