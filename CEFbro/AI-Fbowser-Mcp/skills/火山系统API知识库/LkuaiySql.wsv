    方法 到字节集 <公开 类型 = 字节集类 注释 = "将当前记录集转换为字节集数据,可通过\"记录集1.置字节集\"方法置入." 折叠>
    {
        变量 Stream <类型 = COM对象类>
        变量 value <类型 = COM变体型>
        Stream.创建 ("ADODB.Stream")
        value.置COM对象 (Stream)
        记录集对象.无返回值方法 ("Save", value, 0)
        变量 ret <类型 = COM变体型>
        ret = Stream.无参数方法 ("Read", COM变体型)
        变量 返回字节集 <类型 = 字节集类>
        ret.取字节集 (返回字节集)
        Stream.清除 ()
        value.清空 ()
        返回 (返回字节集)
    }

    方法 置字节集 <公开 类型 = 逻辑型 注释 = "可以将通过\"记录集1.到字节集()\"方法保存的记录集数据通过本方法置入." 折叠>
    参数 记录集数据 <类型 = 字节集类>
    {
        变量 Stream <类型 = COM对象类>
        变量 value <类型 = COM变体型>
        value.置字节集 (记录集数据)
        Stream.创建 ("ADODB.Stream")
        Stream.无参数及返回值方法 ("Open")
        Stream.写属性 ("Type", 1)
        Stream.无返回值方法 ("Write", value)
        Stream.写属性 ("Position", 0)
        value.清空 ()
        value.置COM对象 (Stream)
        记录集对象.创建 ("ADODB.RecordSet", )
        变量 临时 <类型 = COM变体型>
        记录集对象.无返回值方法 ("Open", value, 临时, 0, 1, 256)
        Stream.无参数及返回值方法 ("Close")
        Stream.清除 ()
        返回 (记录集对象.取错误 () == COM方法调用结果.成功)
    }

