    方法 连接 <类型 = 逻辑型 注释 = "开始连接到指定的数据库." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 参数_连接文本 <类型 = 文本型
            注释 = "提供包含连接信息的一个文本,具体信息可参阅文档\"https://docs.microsoft.com/zh-cn/sql/ado/reference/ado-api/connectionstring-property-ado?view=sql-server-ver15\"."
            注释 = "如果本参数为空,将使用\"连接文本\"属性作为该参数的值,如果本参数提供非空内容,将会优先于\"连接文本\"属性." 折叠2 @默认值 = "">
    参数 参数_用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名(如果连接文本中包含,此参数将会覆盖连接文本中的对应用户名信息)." @默认值 = "">
    参数 参数_密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码(如果连接文本中包含,此参数将会覆盖连接文本中的对应密码信息)." @默认值 = "">
    参数 参数_是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 参数_异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    参数 参数_内部连接 <类型 = COM对象类>
    参数 参数_投递数量 <类型 = 整数 @默认值 = 1>
    {
        变量 方式 <类型 = 整数>
        如果 (参数_异步连接)
        {
            方式 = 16
        }
        否则
        {
            方式 = -1

        }
        变量 连接判断 <类型 = 逻辑型>
        连接判断 = 参数_内部连接.无返回值方法 ("Open", 参数_连接文本, 参数_用户名, 参数_密码, 方式)
        如果 (参数_投递数量 >= 2)
        {
            循环 (0, 参数_投递数量)
            {
                内部_超级队列.投递COM对象类 (参数_内部连接)

            }

        }
        否则
        {
            内部_超级队列.投递COM对象类 (参数_内部连接)

        }

        如果 (参数_是否客户端)
        {
            设置游标服务位置 (3)

        }

        内部_连接文本 = 参数_连接文本
        内部_密码 = 参数_密码
        内部_方式 = 方式
        内部_用户名 = 参数_用户名
        内部_是否客户端 = 参数_是否客户端
        内部_异步连接 = 参数_异步连接
        内部_总共连接数 = 内部_总共连接数 + 1
        返回 (连接判断)


    }

    方法 连接MYSQL <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程Mysql数据库." 注释 = "注意:使用前确保系统中已安装对应的数据库驱动程序." 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 参数_服务器名 <类型 = 文本型>
    参数 参数_数据库 <类型 = 文本型>
    参数 参数_用户名 <类型 = 文本型>
    参数 参数_密码 <类型 = 文本型>
    参数 参数_连接端口 <类型 = 整数>
    参数 参数_连接池数量 <类型 = 整数 注释 = "需要时FOF连接池数量的两倍，也就是FOF连接池是10，那么这里要填写20" @默认值 = 40>
    参数 参数_连接字符集 <类型 = 文本型 注释 = "可以设置为UTF8等" @默认值 = "GBK">
    参数 参数_连接驱动版本 <类型 = 文本型 注释 = "注意：默认是3.51的驱动" 注释 = "3.51驱动下载地址：https://www.lkuaiy.com/rsdetails?page=1&id=80721599125772"
            注释 = "3.51比较老；如果你在使用过程中出现读取数据不全的情况；可以使用8.0驱动" 注释 = "使用8.0驱动本处请直接填写8.0"
            注释 = "8.0驱动下载地址：https://www.lkuaiy.com/rsdetails?page=1&id=16288230663181467" 折叠2 @默认值 = "3.51">
    参数 参数_超出池数量是否自动创建 <类型 = 逻辑型 注释 = "如果设置为真则并发超出队列池的时候会自动创建需求的连接" 注释 = "注意：当连接池数量超过300的时候将自动停止创建（为了保证开发者运行设备效率），请开发者自行根据需求设置"
            折叠2 @默认值 = 假>
    {
        变量 提示文本 <类型 = 文本型
                值 = "注意：默认是3.51的驱动\r\n3.51驱动下载地址：https://www.lkuaiy.com/rsdetails?page=1&id=80721599125772\r\n\r\n3.51比较老；如果你在使用过程中出现读取数据不全的情况；可以使用8.0驱动\r\n\r\n使用8.0驱动《参数_连接驱动版本》请直接填写8.0\r\n\r\n8.0驱动下载地址：https://www.lkuaiy.com/rsdetails?page=1&id=16288230663181467">
        调试输出 (提示文本)

        内部_超出池数量是否自动创建 = 参数_超出池数量是否自动创建
        关闭数据库 ()
        如果 (参数_连接池数量 < 1)
        {
            调试输出 ("连接池数量必须大于等于1")
            返回 (假)

        }
        变量 最终链接数 <类型 = 整数>
        最终链接数 = 参数_连接池数量
        如果 (最终链接数 <= 50)
        {
            最终链接数 = 最终链接数 * 2

        }
        如果 (最终链接数 <= 10)
        {
            最终链接数 = 10

        }
        循环 (0, 最终链接数)
        {
            变量 内部ADO <类型 = COM对象类>
            如果 (内部ADO.创建 ("ADODB.Connection"))
            {
                变量 链接版本文本 <类型 = 文本型>
                链接版本文本 = 参数_连接驱动版本
                如果 (寻找文本 (链接版本文本, "8") != -1 && 寻找文本 (链接版本文本, "Unicode") == -1)
                {
                    链接版本文本 = "" + 参数_连接驱动版本 + " Unicode"

                }

                如果 (连接 ("Driver={MySQL ODBC " + 链接版本文本 + " Driver};Server=" + 参数_服务器名 + ";Port=" + 到文本 (参数_连接端口) + ";DataBase=" + 参数_数据库 + ";UID=" + 参数_用户名 + ";Password=" + 参数_密码 + ";Stmt=Set Names '" + 参数_连接字符集 + "'", , , , , 内部ADO) == 假)
                {
                    返回 (假)

                }

            }

        }

        如果 (内部_超级队列.取COM对象队列数 () >= 1)
        {
            Mysql时钟.启动时钟 (500)
            返回 (真)
        }
        否则
        {
            返回 (假)

        }

    }

    方法 连接Access <公开 类型 = 逻辑型 注释 = "连接到指定Access数据库." 注释 = "注意:非线程安全,只能是单线程操作"
            注释 = "如果需要链接ACCESS,则需要安装对应的驱动:https://www.lkuaiy.com/rsdetails?id=16006599489631" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 文件路径 <类型 = 文本型 注释 = "提供数据库文件完整路径.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的用户密码." @默认值 = "">
    参数 是否新版 <类型 = 逻辑型 注释 = "本参数指定Access版本,为假则使用2003以下连接方式,为真则使用2007版本连接方式." @默认值 = 假>
    {
        关闭数据库 ()
        变量 内部ADO <类型 = COM对象类>
        如果 (内部ADO.创建 ("ADODB.Connection") == 假)
        {
            返回 (假)

        }

        如果 (是否新版)
        {
            返回 (连接 ("Provider=Microsoft.ACE.OLEDB.12.0; Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码, , , , , 内部ADO, 1))
        }
        否则
        {
            返回 (连接 ("Provider=Microsoft.Jet.OLEDB.4.0; Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码, , , , , 内部ADO, 1))

        }
    }

    方法 连接SQLSERVER <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程连接SQLSERVER数据库." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 参数_服务器名 <类型 = 文本型>
    参数 参数_数据库 <类型 = 文本型>
    参数 参数_用户名 <类型 = 文本型>
    参数 参数_密码 <类型 = 文本型>
    参数 参数_连接池数量 <类型 = 整数 注释 = "需要时FOF连接池数量的两倍，也就是FOF连接池是10，那么这里要填写20" @默认值 = 20>
    参数 参数_超出池数量是否自动创建 <类型 = 逻辑型 注释 = "如果设置为真则并发超出队列池的时候会自动创建需求的连接" 注释 = "注意：当连接池数量超过300的时候将自动停止创建（为了保证开发者运行设备效率），请开发者自行根据需求设置"
            折叠2 @默认值 = 假>
    参数 参数_是否远程连接 <类型 = 逻辑型 注释 = "如果是连接远程的服务器，请务必输入本参数" @默认值 = 假>
    参数 参数_远程连接端口 <类型 = 整数 @默认值 = 1433>
    {
        内部_超出池数量是否自动创建 = 参数_超出池数量是否自动创建
        关闭数据库 ()
        变量 连接文本 <类型 = 文本型>
        如果 (参数_是否远程连接 == 真)
        {
            连接文本 = "Provider=SQLOLEDB.1;Persist Security Info=False;Data Source=" + 参数_服务器名 + "," + 到文本 (参数_远程连接端口) + "; DATABASE=" + 参数_数据库 + ";"

        }
        否则
        {
            连接文本 = "driver={sql server};server=" + 参数_服务器名 + ";database=" + 参数_数据库 + ";uid=" + 参数_用户名 + ";pwd=" + 参数_密码

        }


        如果 (参数_连接池数量 < 1)
        {
            调试输出 ("连接池数量必须大于等于1")
            返回 (假)

        }
        变量 最终链接数 <类型 = 整数>
        最终链接数 = 参数_连接池数量
        如果 (最终链接数 <= 50)
        {
            最终链接数 = 最终链接数 * 2

        }

        循环 (0, 最终链接数)
        {
            变量 内部ADO <类型 = COM对象类>
            如果 (内部ADO.创建 ("ADODB.Connection"))
            {
                如果 (参数_是否远程连接 == 真)
                {
                    如果 (连接 (连接文本, 参数_用户名, 参数_密码, , , 内部ADO) == 假)
                    {
                        返回 (假)

                    }

                }
                否则
                {
                    如果 (连接 (连接文本, , , , , 内部ADO) == 假)
                    {
                        返回 (假)

                    }


                }


            }
            否则
            {
                返回 (假)

            }

        }

        如果 (内部_超级队列.取COM对象队列数 () >= 1)
        {
            返回 (真)
        }
        否则
        {
            返回 (假)

        }

    }

    方法 连接Oracle <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程Oracle数据库." 注释 = "注意:使用前确保系统中已安装对应的数据库驱动程序." 注释 = "注意:非线程安全,只能是单线程操作"
            返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码.">
    参数 驱动程序 <类型 = 文本型 注释 = "提供连接Oracle所需的驱动程序名称,例如\"Oracle in OraClient11g_home1\",使用前请确保系统中已安装该驱动,否则无法进行连接."
            @默认值 = "Oracle in OraClient11g_home1">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    {
        关闭数据库 ()
        变量 内部ADO <类型 = COM对象类>
        如果 (内部ADO.创建 ("ADODB.Connection") == 假)
        {
            返回 (假)

        }

        返回 (连接 ("DRIVER=" + 驱动程序 + "; SERVER=" + 地址, 用户名, 密码, , 异步连接, 内部ADO, 5))
    }

    方法 连接Postgresql <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程PostgreSQL数据库." 注释 = "注意:非线程安全,只能是单线程操作" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
