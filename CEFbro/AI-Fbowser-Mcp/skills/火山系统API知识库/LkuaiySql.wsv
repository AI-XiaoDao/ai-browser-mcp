    方法 查询并返回JSON文本 <公开 类型 = 文本型 注释 = "直接返回JSON的文本数组,注意：使用本方法可以不适用关闭命令" 返回值注释 = "直接返回JSON的文本数组,注意：使用本方法可以不适用关闭命令" 折叠>
    参数 Sql语句 <类型 = 文本型>
    参数 数据库 <类型 = 数据库_ODBC数据库>
    参数 表名 <类型 = 文本型 @默认值 = "JSONLKYZJJ">
    {
        变量 临时记录集 <类型 = 数据库_ODBC记录集>
        如果 (临时记录集.查询 (Sql语句, 数据库) == 假)
        {
            临时记录集.关闭 ()
            返回 ("")

        }

        变量 记录数量 <类型 = 整数>
        变量 循环变量 <类型 = 整数>
        变量 键值表 <类型 = 类_键值表>
        变量 JSON文本 <类型 = 文本型>
        变量 JSON最终文本 <类型 = 文本型 值 = "{\r\n   \"表名替换\": \r\n   [\r\n\t文本内容替换\r\n   ]\r\n}">
        记录数量 = 临时记录集.取记录数2 ()
        如果 (记录数量 <= 0)
        {
            临时记录集.关闭 ()
            返回 ("")

        }

        循环 (0, 记录数量, 循环变量, 1)
        {
            临时记录集.到下一条 ()
            变量 内部循环 <类型 = 整数>
            循环 (0, 临时记录集.取字段列表 ().成员数, 内部循环, 1)
            {
                变量 字段 <类型 = 文本型>
                变量 内容 <类型 = 文本型>
                变量 字段类 <类型 = ODBC数据库字段类>
                字段类 = 临时记录集.取字段列表 ().取成员 (内部循环)
                字段 = 字段类.名称
                内容 = 临时记录集.读文本 (字段)
                键值表.置入文本值 (字段, 内容)

            }

            变量 换行符_ <类型 = 文本型 值 = "\r\n">
            如果 (循环变量 + 1 >= 记录数量)
            {
                加入文本 (JSON文本, 键值表.到可读文本 ())
            }
            否则
            {
                加入文本 (JSON文本, 键值表.到可读文本 () + "," + 换行符_)

            }

            键值表.清空 ()

        }

        临时记录集.关闭 ()
        子文本替换 (JSON最终文本, "表名替换", 表名)
        子文本替换 (JSON最终文本, "文本内容替换", JSON文本)
        返回 (JSON最终文本)


    }

    方法 分页查询Mysql并返回JSON文本 <公开 类型 = 文本型 注释 = "直接返回JSON的文本数组,注意：使用本方法可以不适用关闭命令"
