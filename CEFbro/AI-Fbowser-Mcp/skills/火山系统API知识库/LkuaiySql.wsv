    方法 保存到文件 <公开 类型 = 逻辑型 注释 = "将该记录集写出保存至指定文件中." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 文件 <类型 = 文本型 注释 = "提供所欲写出文件的完整路径.">
    参数 类型 <类型 = 整数 注释 = "0Microsoft Advanced Data TableGram (ADTG)文件格式" 注释 = "1可扩展标记语言(XML)格式" 注释 = "2提供程序将使用其自己的格式保存记录集" 折叠2
            @默认值 = 0>
    {
        变量 输出路径 <类型 = COM变体型>
        输出路径.赋值 (文件)
        返回 (记录集对象.无返回值方法 ("Save", 输出路径, 类型))
    }

    方法 分页语句 <公开 类型 = 文本型 折叠>
    参数 表名 <类型 = 文本型>
    参数 当前页 <类型 = 整数>
    参数 每页记录数 <类型 = 整数>
    参数 条件 <类型 = 文本型 注释 = "例如:xxx=xxx" 注释 = "注意：不需要where" @默认值 = "">
    参数 客户端 <类型 = 整数 注释 = "1代表sqlserver，2代表mysql" @默认值 = 1>
    {
        变量 起始位置 <类型 = 整数>
        起始位置 = 每页记录数 * 当前页 - 2
        变量 最终条件 <类型 = 文本型>
        如果 (客户端 == 1)
        {
            如果 (条件 != "")
            {
                最终条件 = " and " + 条件
            }
            返回 ("select top (" + 到文本 (每页记录数) + ") * from " + 表名 + " where id not in(select top (" + 到文本 (起始位置) + ") id from " + 表名 + ")" + 最终条件)

        }
        否则
        {
            如果 (条件 != "")
            {
                最终条件 = " where " + 条件
            }
            返回 ("select * from " + 表名 + 最终条件 + " limit " + 到文本 (每页记录数 * 当前页) + "," + 到文本 (每页记录数))

        }

    }

    方法 最后错误 <公开 类型 = 文本型 注释 = "数据库最后错误描述" 折叠>
    {
        变量 数据库错误集合 <类型 = 数据库_错误信息集合>
        @ @<数据库错误集合>=@dt<数据库_错误信息集合>(@<数据库COM>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Errors"), 0, _T ("")));
        返回 (数据库错误集合.取成员 (0).错误描述)
    }

