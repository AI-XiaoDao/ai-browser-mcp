        {
            返回 (假)

        }

        如果 (文本是否为空 (驱动程序))
        {
            返回 (连接 ("Provider=PostgreSQL OLE DB; Data Source=" + 地址 + "; location=" + 数据库名 + ";", 用户名, 密码, , 异步连接, 内部ADO, 5))
        }
        否则
        {
            返回 (连接 ("Provider=MSDASQL; DRIVER=" + 驱动程序 + "; SERVER=" + 地址 + "; PORT=" + 到文本 (端口号) + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接, 内部ADO, 5))
        }
    }

    方法 连接Sqlite <公开 类型 = 逻辑型 注释 = "连接到指定Sqlite数据库." 注释 = "注意:非线程安全,只能是单线程操作"
            注释 = "如果需要链接Sqlite,则需要安装对应的驱动:https://www.lkuaiy.com/rsdetails?page=1&id=28411613267330" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 文件路径 <类型 = 文本型 注释 = "提供数据库文件完整路径.">
    {
        关闭数据库 ()
        变量 内部ADO <类型 = COM对象类>
        如果 (内部ADO.创建 ("ADODB.Connection") == 假)
        {
            返回 (假)

        }

        变量 Sqlite <类型 = 文本型 值 = "Provider=MSDASQL.1;Extended Properties=Driver={SQLite3 ODBC Driver};Password=\'\';Database=文件路径;">
