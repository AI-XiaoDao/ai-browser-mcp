类 数据库_ODBC数据库 <公开 注释 = "基于ADO实现对各种不同数据库的访问,使用前确保系统中已安装ADO"
        注释 = "本数据库对应效率使用案例：https://www.lkuaiy.com/rsdetails?id=23371615358144&page=1" 注释 = "" 折叠 折叠2>
{

    #

    变量 内部_连接文本 <类型 = 文本型
            注释 = "提供包含连接信息的一个文本,具体信息可参阅文档\"https://docs.microsoft.com/zh-cn/sql/ado/reference/ado-api/connectionstring-property-ado?view=sql-server-ver15\"."
            注释 = "如果本参数为空,将使用\"连接文本\"属性作为该参数的值,如果本参数提供非空内容,将会优先于\"连接文本\"属性." 折叠2>
    变量 内部_用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名(如果连接文本中包含,此参数将会覆盖连接文本中的对应用户名信息).">
    变量 内部_密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码(如果连接文本中包含,此参数将会覆盖连接文本中的对应密码信息).">
    变量 内部_是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真.">
    变量 内部_异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果.">
    变量 内部_方式 <类型 = 整数>
    变量 内部_超级队列 <类型 = 类_超级队列>
    变量 内部_总共连接数 <类型 = 整数>
    变量 内部_超出池数量是否自动创建 <类型 = 逻辑型>

    #

    变量 Mysql时钟 <类型 = 线程_线程时钟>

    方法 超出连接数 <公开 定义事件 类型 = 整数 注释 = "超出连接数后触发本事件" 折叠>
    {

    }

    方法 获取可用连接数 <公开 类型 = 整数 折叠>
    {
        返回 (内部_超级队列.取COM对象队列数 ())
    }

    方法 释放连接 <公开 折叠>
    参数 数据库对象 <类型 = COM对象类>
    {
        内部_超级队列.投递COM对象类 (数据库对象)
    }

    方法 连接对象 <公开 类型 = COM对象类 折叠>
    参数 是否成功 <类型 = 数据库_是否成功>
    {
        变量 COMADO <类型 = COM对象类>
        变量 对列数 <类型 = 整数>
        对列数 = 内部_超级队列.取COM对象队列数 ()
        如果 (对列数 >= 1)
        {
            COMADO = 内部_超级队列.获取COM对象类 ()
            是否成功.返回逻辑值 = 真
            返回 (COMADO)
        }
        否则
        {
            超出连接数 ()
            如果 (内部_超出池数量是否自动创建 == 真)
            {
                如果 (内部_总共连接数 < 300)
                {
                    变量 内部ADO <类型 = COM对象类>
                    如果 (内部ADO.创建 ("ADODB.Connection") == 真)
                    {
                        如果 (连接 (内部_连接文本, 内部_用户名, 内部_密码, 内部_是否客户端, 内部_异步连接, 内部ADO, ) == 真)
                        {
                            是否成功.返回逻辑值 = 真
                            返回 (内部ADO)

                        }

                    }

                }

            }

            是否成功.返回逻辑值 = 假
            返回 (COMADO)

        }

    }

