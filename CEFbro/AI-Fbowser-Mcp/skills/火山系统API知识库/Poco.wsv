<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序 <@文档 = "category = \"开源库.POCO\"" @视窗.外部头文件 = "poco\\pocoTool.h" @视窗.外部库.win32 = "poco\\pocoToolx86.lib"
        @视窗.附属文件.win32 = "poco\\pocoToolx86.dll" @视窗.外部库.x64 = "poco\\pocoToolx64.lib" @视窗.附属文件.x64 = "poco\\pocoToolx64.dll">

类 强大网页套接字数据类型_常量类 <公开 注释 = "#define PocoTool_Send_Type_Bin  2" 注释 = "#define PocoTool_Send_Type_Text  1"
        注释 = "#define PocoTool_Send_Type_Ping  9" 注释 = "#define PocoTool_Send_Type_Pong  10"
        注释 = "#define PocoTool_Send_Type_Close 8" 注释 = "#define PocoTool_Send_Type_BITMASK 15">
{
    常量 字节集 <公开 类型 = 整数 值 = @PocoTool_Send_Type_Bin>
    常量 文本 <公开 类型 = 整数 值 = @PocoTool_Send_Type_Text>
    常量 Ping <公开 类型 = 整数 值 = @PocoTool_Send_Type_Ping>
    常量 Pong <公开 类型 = 整数 值 = @PocoTool_Send_Type_Pong>
    常量 断开 <公开 类型 = 整数 值 = @PocoTool_Send_Type_Close>
    常量 掩码 <公开 类型 = 整数 值 = @PocoTool_Send_Type_BITMASK>

    #
}

类 强大网页套接字查询类型_常量类 <公开>
{
    常量 读 <公开 类型 = 整数 值 = @PocoTool_Poll_Read>
    常量 写 <公开 类型 = 整数 值 = @PocoTool_Poll_Write>
    常量 错误 <公开 类型 = 整数 值 = @PocoTool_Poll_Error>
    常量 读_写_错误 <公开 类型 = 整数 值 = 7>

    #
}

类 强大网页套接字数据类 <公开>
{
    变量 数据长度 <公开 类型 = 整数>
    变量 数据类型 <公开 类型 = 整数>
    变量 数据 <公开 类型 = 字节集类>

    #
}

类 强大网页套接字类 <公开>
{

    # @begin
    # <> <include>
