类 PPT幻灯片 <公开>
{
    变量 Slide对象 <类型 = COM对象类>

    方法 标题 <公开 属性读 类型 = 文本型 注释 = "返回幻灯片中有标题时的标题文本">
    {
        返回 (Slide对象.读无参数对象型属性 ("Shapes", COM对象类).读无参数对象型属性 ("Title", COM对象类).读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).读无参数属性 ("Text", 文本型))
    }

    方法 标题 <公开 属性写 注释 = "设置幻灯片中有标题时的标题文本">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Slide对象.读无参数对象型属性 ("Shapes", COM对象类).读无参数对象型属性 ("Title", COM对象类).读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).写属性 ("Text", 所欲设置的值)
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "返回幻灯片名称" "">
    {
        返回 (Slide对象.读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "设置幻灯片名称,当幻灯片插入到演示文稿中时,自动分配一个名称,格式为\"Slide n\",其中n是一个整数,表示幻灯片在演示文稿中的创建顺序." "">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Slide对象.写属性 ("Name", 所欲设置的值)
    }

    方法 ID <公开 属性读 类型 = 整数 注释 = "返回指定幻灯片的唯一ID号" "">
    {
        返回 (Slide对象.读无参数属性 ("SlideID", 整数))
    }

    方法 编号 <公开 属性读 类型 = 整数 注释 = "返回幻灯片编号,显示在幻灯片的右下角的实际数目,幻灯片编号总是等于开始幻灯片编号+幻灯片索引号-1." "">
    {
        返回 (Slide对象.读无参数属性 ("SlideNumber", 整数))
    }

    方法 图形数量 <公开 属性读 类型 = 整数 注释 = "返回PPT文稿中图形的数量">
    {
        返回 (Slide对象.读无参数对象型属性 ("Shapes", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 复制 <公开 注释 = "将幻灯片复制到剪贴板">
    {
        Slide对象.无参数及返回值方法 ("Copy")
    }

    方法 剪切 <公开 注释 = "删除幻灯片并将其放到剪贴板中">
    {
        Slide对象.无参数及返回值方法 ("Cup")
    }

    方法 删除 <公开 注释 = "删除幻灯片">
    {
        Slide对象.无参数及返回值方法 ("Delete")
    }

    方法 选定 <公开 注释 = "选定幻灯片">
    {
        Slide对象.无参数及返回值方法 ("Select")
    }

    方法 移动 <公开 注释 = "将指定幻灯片移动到同一集合中的指定位置.并适当地对集合中所有其他项目进行重新编号.">
    参数 索引号 <类型 = 整数 注释 = "动画效果要移动到的索引位置">
    {
        Slide对象.无返回值方法 ("MoveTo", 索引号)
    }

    方法 导出 <公开 注释 = "使用指定的图形筛选器导出幻灯片.并将导出的文件以指定的文件名保存.">
    参数 文件名 <类型 = 文本型 注释 = "将导出并保存到磁盘的文件的名称.可以包括完整路径.如果不包括完整路径,会在当前文件夹中创建一个文件.">
    参数 后缀名 <类型 = 文本型 注释 = "要导出幻灯片的图形格式.导出过程首先在注册表中搜索匹配的扩展名.如果没有找到与指定字符串匹配的扩展名.将查找匹配的筛选器名称.">
    参数 宽度 <类型 = 整数 注释 = "导出幻灯片的宽度(以像素为单位),默认为不指定." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "导出幻灯片的高度(以像素为单位),默认为不指定." @默认值 = -1>
    {
        变量 局_宽度 <类型 = COM变体型>
        变量 局_高度 <类型 = COM变体型>
        如果 (宽度 != -1)
        {
            局_宽度.赋值 (宽度, )
        }
        如果 (高度 != -1)
        {
            局_高度.赋值 (高度, )
        }
        Slide对象.无返回值方法 ("Export", 文件名, 后缀名, 宽度, 高度)
    }

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_PPT文稿对象 <类型 = COM对象类 注释 = "PPT文稿">
    {
        Slide对象 = 参_PPT文稿对象
        返回 (Slide对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Slide对象)
    }

    方法 创建副本 <公开 注释 = "创建在指定\"幻灯片\"对象的一个副本.为原始幻灯片,创建重复的幻灯片.">
    {
        Slide对象 = Slide对象.无参数对象型方法 ("Duplicate", COM对象类)
    }

    方法 置设计模板 <公开 注释 = "将设计模板应用于指定的幻灯片">
    参数 模板名 <类型 = 文本型 注释 = "指定设计模板的名称">
    {
        Slide对象 = Slide对象.对象型方法 ("ApplyTemplate", COM对象类, 模板名)
    }

    方法 置设计模板2 <公开 注释 = "将设计模板应用于指定的幻灯片">
    参数 模板名 <类型 = 文本型 注释 = "指定设计模板的名称">
    参数 主题ID <类型 = 文本型 注释 = "主题中变量ID">
    {
        Slide对象 = Slide对象.对象型方法 ("ApplyTemplate2", COM对象类, 模板名, 主题ID)
    }

    方法 添加图形 <公开 类型 = PPT图形 注释 = "添加一个自选图形">
    参数 形状类型 <类型 = PPT图形形状 注释 = "PPT图形形状.*,指定要创建的自选形状的类型.">
    参数 左边 <类型 = 小数 注释 = "设置幻灯片左边缘到图形对象左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置幻灯片上边缘到图形对象上边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置图形对象的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置图形对象的高度,以磅为单位." @默认值 = 100>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddShape", COM对象类, 形状类型, 左边, 上边, 宽度, 高度)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 选定所有图形 <公开 类型 = PPT图形 注释 = "选择\"图形\"集合中的所有图形">
    {
        变量 局_PPT图形 <类型 = PPT图形>
        局_PPT图形.置对象 (Slide对象.读无参数对象型属性 ("Shapes", COM对象类).无参数对象型方法 ("SelectAll", COM对象类))
        返回 (局_PPT图形)
    }

    方法 清空图形 <公开 注释 = "清空幻灯片\"图形\"集合中的所有图形">
    {
        Slide对象.读无参数对象型属性 ("Shapes", COM对象类).读无参数对象型属性 ("Range", COM对象类).无参数及返回值方法 ("Delete")
    }

    方法 添加媒体 <公开 类型 = PPT图形 注释 = "添加一个音频或视频文件(*.mpg,*.avi,*.mp3,*.cda...).并且可以在幻灯片中播放.">
    参数 文件名 <类型 = 文本型 注释 = "要添加的文件的名称." "">
    参数 链接源目标 <类型 = 逻辑型 注释 = "二选一.指示是否链接到文件.与\"文稿中存储\".必须有一个为真." @默认值 = 假>
    参数 文稿中存储 <类型 = 逻辑型 注释 = "二选一.指示是否随文稿一起保存媒体.与\"链接源目标\".必须有一个为真." @默认值 = 真>
    参数 左边 <类型 = 小数 注释 = "设置幻灯片左边缘到媒体对象左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置幻灯片上边缘到媒体对象上边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置媒体对象的宽度,以磅为单位.默认为-1.表示不指定宽度由内容决定宽度大小." @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "设置媒体对象的高度,以磅为单位.默认为-1.表示不指定高度由内容决定高度大小." @默认值 = -1>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        变量 局_宽度 <类型 = COM变体型>
        变量 局_高度 <类型 = COM变体型>
        如果 (宽度 != -1)
        {
            局_宽度.赋值 (宽度, )
        }
        如果 (高度 != -1)
        {
            局_高度.赋值 (高度, )
        }
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddMediaObject2", COM对象类, 文件名, 链接源目标, 文稿中存储, 左边, 上边, 局_宽度, 局_高度)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 添加OLE对象 <公开 类型 = PPT图形 注释 = "添加OLE对象并返回一个\"PPT图形\"类">
    参数 文件名 <类型 = 文本型 注释 = "二选一.要添加的文件的名称.为空文本时忽略该参数." "">
    参数 类名 <类型 = 文本型 注释 = "二选一.指定要添加的类对象名称.当\"文件名\"不为空时.忽略该参数.当\"文件名\"为空时.必须指定类名." @默认值 = "">
    参数 链接源目标 <类型 = 逻辑型 注释 = "指示是否链接到文件" @默认值 = 假>
    参数 左边 <类型 = 小数 注释 = "新对象左上角相对于幻灯片左上角的水平位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "新对象左上角相对于幻灯片左上角的垂直位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "OLE对象的初始宽度,以磅为单位.默认为-1.表示不指定宽度由内容决定宽度大小." @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "OLE对象的初始高度,以磅为单位.默认为-1.表示不指定高度由内容决定高度大小." @默认值 = -1>
    参数 显示为图标 <类型 = 逻辑型 注释 = "决定是否将OLE对象显示为图标" @默认值 = 假>
    参数 图标文件 <类型 = 文本型 注释 = "包含将要显示的图标的文件" @默认值 = "">
    参数 图标索引 <类型 = 整数 注释 = "\"图标文件\"中的图标索引.从0开始.如果具有给定索引编号的图标不存在时.则使用的图标索引号为1(文件中的第二个图标)." @默认值 = 0>
    参数 标签 <类型 = 文本型 注释 = "显示在图标下面的标签(标题)." @默认值 = "">
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        变量 局_宽度 <类型 = COM变体型>
        变量 局_高度 <类型 = COM变体型>
        如果 (宽度 != -1)
        {
            局_宽度.赋值 (宽度, )
        }
        如果 (高度 != -1)
        {
            局_高度.赋值 (高度, )
        }
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddOLEObject", COM对象类, 左边, 上边, 局_宽度, 局_高度, 类名, 文件名, 显示为图标, 图标文件, 图标索引, 标签, 链接源目标)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 添加直线 <公开 类型 = PPT图形 注释 = "向幻灯片添加一条直线图形,并返回新建的图形.">
    参数 起点横坐标 <类型 = 小数 注释 = "线条起点相对于幻灯片左边缘水平位置,以磅为单位." "">
    参数 起点纵坐标 <类型 = 小数 注释 = "线条起点相对于幻灯片上边缘垂直位置,以磅为单位." "">
    参数 终点横坐标 <类型 = 小数 注释 = "线条终点相对于幻灯片左边缘水平位置,以磅为单位." "">
    参数 终点纵坐标 <类型 = 小数 注释 = "线条终点相对于幻灯片上边缘垂直位置,以磅为单位." "">
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddLine", COM对象类, 起点横坐标, 起点纵坐标, 终点横坐标, 终点纵坐标)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 添加文本框 <公开 类型 = PPT图形 注释 = "向幻灯片添加一个文本框">
    参数 内容 <类型 = 文本型 注释 = "艺术字中的文字">
    参数 方向 <类型 = PPT文本方向 注释 = "PPT文本方向.*,指定文本的方向.其中某些常量可能不可用,这取决于您所选择或安装的语言支持." @默认值 = PPT文本方向.水平>
    参数 左边 <类型 = 小数 注释 = "设置幻灯片左边缘到文本框左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置幻灯片左边缘到文本框左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置文本框的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置文本框的高度,以磅为单位." @默认值 = 100>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddTextbox", COM对象类, 方向, 左边, 上边, 宽度, 高度)
        局_图形对象.读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).写属性 ("Text", 内容)  // 向文本框中写入内容
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 置标题文本 <公开 类型 = PPT图形 注释 = "设置对象标题区标题文本并返回该标题区域,请确保对象存在标题区.">
    参数 内容 <类型 = 文本型>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).无参数对象型方法 ("AddTitle", COM对象类)
        局_图形对象.读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).写属性 ("Text", 内容)  // 向标题写入内容
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 背景 <公开 属性读 类型 = PPT图形 注释 = "该对象表示幻灯片的背景">
