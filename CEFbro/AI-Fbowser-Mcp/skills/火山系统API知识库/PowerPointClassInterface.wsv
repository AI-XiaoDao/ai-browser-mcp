类 PPT图形层次 <公开 注释 = "指定要将形状移动到的相对于其他形状的顺序位置" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 顶层 <公开 值 = @msoBringToFront 注释 = "使形状置于顶层">
    常量 底层 <公开 值 = @msoSendToBack 注释 = "使形状置于底层">
    常量 上移一层 <公开 值 = @msoBringForward 注释 = "使形状上移一层">
    常量 下移一层 <公开 值 = @msoSendBackward 注释 = "使形状下移一层">
    常量 文字上方 <公开 值 = @msoBringInFrontOfText 注释 = "使形状浮于文字上方">
    常量 文字下方 <公开 值 = @msoSendBehindText 注释 = "使形状衬于文字下方">
}

