    方法 运行宏 <公开 注释 = "运行Visual Basic 宏">
    参数 宏名 <类型 = 文本型 注释 = "宏的名称,参数可以是任意模板,模块和宏名的组合.">
    参数 文本数组参数 <类型 = 文本数组类 注释 = "二选一,宏参数值." @默认值 = 空对象>
    参数 整数数组参数 <类型 = 整数数组类 注释 = "二选一,宏参数值." @默认值 = 空对象>
    {
        变量 COM变体 <类型 = COM变体型>
        如果 (文本数组参数.取成员数 () > 0)
        {
            COM变体.创建数组 (COM数组成员类型.文本值, 文本数组参数.取成员数 ())
            文本数组参数.枚举循环 ()
            {
                COM变体.赋值 (文本数组参数.取枚举值 (), 文本数组参数.取枚举索引 ())
            }
        }
        否则
        {
            COM变体.创建数组 (COM数组成员类型.整数值, 整数数组参数.取成员数 ())
            整数数组参数.枚举循环 ()
            {
                COM变体.赋值 (整数数组参数.取枚举值 (), 整数数组参数.取枚举索引 ())
            }
        }
        Application对象.无返回值方法 ("Run", 宏名, COM变体)
    }

