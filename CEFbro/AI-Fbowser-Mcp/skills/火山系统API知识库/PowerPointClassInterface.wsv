    方法 置节点文本位置 <公开 注释 = "当对象为智能图表时,设置智能图表节点文本位置." "">
    参数 节点索引 <类型 = 整数 "">
    参数 上 <类型 = 整数 注释 = "设置文本框架顶端与文本所在形状的内接矩形顶端之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 下 <类型 = 整数 注释 = "设置文本框架底端与文本所在形状的内接矩形底端之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 左 <类型 = 整数 注释 = "设置文本框架左边缘与文本所在形状的内接矩形左边缘之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 右 <类型 = 整数 注释 = "设置文本框架右边缘与文本所在形状的内接矩形右边缘之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    {
        变量 局_文本区 <类型 = COM对象类>
        局_文本区 = Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引).读无参数对象型属性 ("TextFrame2", COM对象类)  // 取节点文本区对象
        如果 (上 != -1)
        {
            局_文本区.写属性 ("MarginTop", 上)
        }
        如果 (下 != -1)
        {
            局_文本区.写属性 ("MarginBottom", 下)
        }
        如果 (左 != -1)
        {
            局_文本区.写属性 ("MarginLeft", 左)
        }
        如果 (右 != -1)
        {
            局_文本区.写属性 ("MarginRight", 右)
        }
    }

    方法 置节点文本 <公开 注释 = "当对象为智能图表时,设置智能图表节点文本." "">
    参数 节点索引 <类型 = 整数 注释 = "智能图表节点索引号">
    参数 内容 <类型 = 文本型 注释 = "智能图表节点所欲设置的内容">
    参数 字体名称 <类型 = 文本型 注释 = "设置字体名称,如果值为\"\",则忽略该参数." @默认值 = "">
    参数 字体大小 <类型 = 整数 注释 = "设置字体大小,如果值为-1,则忽略该参数." @默认值 = -1>
    参数 字体颜色 <类型 = 整数 注释 = "设置字体颜色,如果值为-1,则忽略该参数." @默认值 = -1>
    参数 加粗 <类型 = 逻辑型 注释 = "设置字体是否加粗" @默认值 = 假>
    参数 透明度 <类型 = 小数 注释 = "设置透明度的指定填充形状为0.0(不透明)到1.0(透明)之间的值" @默认值 = 0>
    {
        变量 局_节点 <类型 = COM对象类>
        变量 局_文本区 <类型 = COM对象类>
        局_节点 = Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引)  // 取节点对象
        局_文本区 = 局_节点.读无参数对象型属性 ("TextFrame2", COM对象类).读无参数对象型属性 ("TextRange", COM对象类)  // 取节点文本区
        局_文本区.写属性 ("Text", 内容)
        如果 (字体名称 != "")
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("NameFarEast", 字体名称)  // 设置字体名称
        }
        如果 (字体大小 != -1)
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("Size", 字体大小)  // 设置字体大小
        }
        如果 (字体颜色 != -1)
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).读无参数对象型属性 ("Fill", COM对象类).读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 字体颜色)  // 填充字体颜色
        }
        局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("Bold", 加粗)  // 设置字体加粗
        局_文本区.读无参数对象型属性 ("Font", COM对象类).读无参数对象型属性 ("Fill", COM对象类).写属性 ("Transparency", 透明度)  // 设置透明度
    }

    方法 节点数量 <公开 属性读 类型 = 整数 注释 = "当对象为智能图表时,返回智能图表节点的总数量." "">
    {
        返回 (Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 添加节点 <公开 注释 = "当对象为智能图表时,添加智能图表的节点." "">
    {
        Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).无参数及返回值方法 ("Add")
    }

    方法 删除节点 <公开 注释 = "当对象为智能图表时,删除智能图表的节点." "">
    参数 节点索引 <类型 = 整数 注释 = "智能图表节点索引号">
    {
        Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引).无参数及返回值方法 ("Delete")
    }
}
