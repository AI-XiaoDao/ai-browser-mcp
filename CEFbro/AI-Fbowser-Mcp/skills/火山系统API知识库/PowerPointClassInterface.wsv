类 PPT文本区 <公开 注释 = "代表PPT文稿中的一个段落中的指定文本区域内容">
{
    变量 TextRange对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 局_TextRange对象 <类型 = COM对象类>
    {
        TextRange对象 = 局_TextRange对象
        返回 (TextRange对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PPT提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (TextRange对象)
    }

    方法 删除 <公开 注释 = "删除该文本区内容" "">
    {
        TextRange对象.无参数及返回值方法 ("Delete")
    }

    方法 复制 <公开 注释 = "复制文本区内容到剪贴板上" "">
    {
        TextRange对象.无参数及返回值方法 ("Copy")
    }

    方法 粘贴 <公开 注释 = "将\"剪贴板\"的内容插入指定的选择范围处" "">
    {
        TextRange对象.无参数及返回值方法 ("Paste")
    }

    方法 选择性粘贴 <公开 注释 = "将\"剪贴板\"的内容插入指定的选择范围处" "">
    参数 格式 <类型 = PPT粘贴格式 注释 = "PPT粘贴格式.*" @默认值 = PPT粘贴格式.文本>
    {
        TextRange对象.无返回值方法 ("PasteSpecial", 格式)
    }

    方法 选定 <公开 注释 = "选中该文本区" "">
    {
        TextRange对象.无参数及返回值方法 ("Select")
    }

    方法 插入文本 <公开 类型 = PPT文本区 注释 = "将指定文本插入文本区的前面或末尾" "">
    参数 内容 <类型 = 文本型 注释 = "要插入的文本" "">
    参数 前插 <类型 = 逻辑型 注释 = "如果为真,则在前面插入." 注释 = "如果为假,则在后面插入." @默认值 = 假>
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        如果 (前插)
        {
            局_PPT文本区.置对象 (TextRange对象.方法 ("InsertBefore", COM对象类, 内容))
        }
        否则
        {
            局_PPT文本区.置对象 (TextRange对象.方法 ("InsertAfter", COM对象类, 内容))
        }
        返回 (局_PPT文本区)
    }

    方法 插入日期 <公开 类型 = PPT文本区 注释 = "在指定的文本区域中插入的日期和时间" "">
    参数 日期格式 <类型 = PPT日期格式 注释 = "日期和时间的格式" "">
    参数 打开更新 <类型 = 逻辑型 注释 = "决定是否每次打开PPT文稿时都更新插入的日期和时间" @默认值 = 假>
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        局_PPT文本区.置对象 (TextRange对象.方法 ("InsertDateTime", COM对象类, 日期格式, 选择 (打开更新, -1, 0)))
        返回 (局_PPT文本区)
    }

    方法 插入回车符 <公开 注释 = "将回车符插入范围或所选内容的末尾" "">
    {
        TextRange对象.无返回值方法 ("InsertAfter", "\r\n")
    }

    方法 剪切 <公开 注释 = "剪切该段落到剪贴板上" "">
    {
        TextRange对象.无参数及返回值方法 ("Cut")
    }

    方法 字符数量 <公开 属性读 类型 = 整数 注释 = "返回该文本区的字符数量" "">
    {
        返回 (TextRange对象.无参数对象型方法 ("Characters", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取范围文本 <公开 类型 = 文本型 注释 = "根据文本区中字符的索引号取出一定长度的文本内容" "">
    参数 位置 <类型 = 整数 注释 = "返回的范围中的位置">
    参数 长度 <类型 = 整数 注释 = "要取出文本长度">
    {
        返回 (TextRange对象.对象型方法 ("Characters", COM对象类, 位置, 长度).读无参数属性 ("Text", 文本型))
    }

    方法 取范围文本区 <公开 类型 = PPT文本区 注释 = "从文本区中,取出从\"位置\"一定长度的文本区.">
    参数 位置 <类型 = 整数 注释 = "开始字符位置">
    参数 长度 <类型 = 整数 注释 = "要取出文本长度">
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        变量 局_对象 <类型 = COM对象类>
        局_对象 = TextRange对象.对象型方法 ("Characters", COM对象类, 位置, 长度)
        局_PPT文本区.置对象 (局_对象)
        返回 (局_PPT文本区)
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "返回当前选区中的内容" "">
    {
        返回 (TextRange对象.读无参数属性 ("Text", 文本型))
    }

    方法 内容 <公开 属性写 注释 = "设置当前选区中的内容" "">
    参数 所欲设置的值 <类型 = 文本型>
    {
        TextRange对象.写属性 ("Text", 所欲设置的值)
    }

