    }

    方法 段落编号缩放 <公开 属性读 类型 = 小数 注释 = "返回项目符号相对于段落中第一个文本字符的大小" 返回值注释 = "属性值可以是 0.25 至 4.表示项目符号的大小可以从25%到400%的文本字符大小之间的浮点值">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).读无参数属性 ("RelativeSize", 小数))
    }

    方法 段落编号缩放 <公开 属性写 注释 = "设置项目符号相对于段落中第一个文本字符的大小">
    参数 所欲设置的值 <类型 = 小数 注释 = "属性值可以是0.25至4,表示项目符号的大小可以从25%到400%的文本字符大小之间的浮点值" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).写属性 ("RelativeSize", 所欲设置的值)
    }

    方法 段落编号开始值 <公开 属性读 类型 = 整数 注释 = "返回项目符号列表的开始值" 返回值注释 = "值必须在1到32767范围">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).读无参数属性 ("StartValue", 整数))
    }

    方法 段落编号开始值 <公开 属性写 注释 = "设置项目符号列表的开始值">
    参数 所欲设置的值 <类型 = 整数 注释 = "值必须在1到32767范围" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).写属性 ("StartValue", 所欲设置的值)
    }

    方法 置段落图形编号 <公开 注释 = "设置要用于项目符号列表中的项目符号的图形文件">
    参数 文件名 <类型 = 文本型 "">
    {
        段落符号类型 = PPT段落符号.带图像  // 设置图形编号前必须指定"段落符号类型"为带图像类型
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).无返回值方法 ("Picture", 文件名)
    }

    方法 段落符号类型 <公开 属性读 类型 = PPT段落符号 注释 = "返回段落符号类型" 返回值注释 = "PPT段落符号类型.*">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).读无参数属性 ("Type", PPT段落符号))
    }

    方法 段落符号类型 <公开 属性写 注释 = "设置段落符号类型">
    参数 所欲设置的值 <类型 = PPT段落符号 注释 = "PPT段落符号类型.*" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).写属性 ("Type", 所欲设置的值)
    }

    方法 段落基准线对齐 <公开 属性读 类型 = PPT基准线对齐 注释 = "返回指定段落的基准线对齐方式" 返回值注释 = "PPT基准线对齐.*">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数属性 ("BaseLineAlignment", PPT基准线对齐))
    }

    方法 段落基准线对齐 <公开 属性写 注释 = "设置指定段落的基准线对齐方式">
    参数 所欲设置的值 <类型 = PPT基准线对齐 注释 = "PPT基准线对齐.*" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("BaseLineAlignment", 所欲设置的值)
    }

    方法 段落后间距 <公开 属性写 注释 = "设置指定文本中每段最后一行后的间距大小,以磅为单位.">
    参数 所欲设置的值 <类型 = 整数 注释 = "以磅为单位" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("LineRuleAfter", 0)  // 将每段最后一行之后的行距设为特定的磅数
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("SpaceAfter", 所欲设置的值)
    }

    方法 段落前间距 <公开 属性写 注释 = "设置指定文本中每段第一行前的间距大小,以磅为单位.">
    参数 所欲设置的值 <类型 = 整数 注释 = "以磅为单位" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("LineRuleBefore", 0)  //  将每段首行前面的行距设为特定的磅数
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("SpaceBefore", 所欲设置的值)
    }

    方法 段落加句号 <公开 注释 = "在指定文本的每个段落末尾添加英文句号">
    {
        TextRange对象.无参数方法 ("AddPeriods", COM对象类)
    }

    方法 取行 <公开 类型 = PPT文本区 注释 = "返回当前文本区中的行">
    参数 索引号 <类型 = 整数 注释 = "返回的范围中的第一行">
    参数 长度 <类型 = 整数 注释 = "要返回的行数">
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        局_PPT文本区.置对象 (TextRange对象.对象型方法 ("Lines", COM对象类, 索引号, 长度))
        返回 (局_PPT文本区)
    }
}

类 PPT图形 <公开 注释 = "代表绘图层中的对象,例如自选图形、任意多边形、OLE对象或图片.">
{
    变量 Shape对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Shape对象 <类型 = COM对象类>
    {
        Shape对象 = 参_Shape对象
        返回 (Shape对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Shape对象)
    }

    方法 删除 <公开 注释 = "删除指定区域的形状" "">
    {
        Shape对象.无参数及返回值方法 ("Delete")
    }

    方法 复制 <公开 注释 = "将指定对象复制到剪贴板" "">
    {
        Shape对象.无参数及返回值方法 ("Copy")
    }

    方法 剪切 <公开 注释 = "将指定对象剪切到剪贴板" "">
    {
        Shape对象.无参数及返回值方法 ("Cuts")
    }

    方法 复制格式 <公开 注释 = "复制指定形状的格式" "">
    {
        Shape对象.无参数及返回值方法 ("PickUp")
    }

    方法 粘贴格式 <公开 注释 = "粘贴来源于\"复制格式\"指定形状的格式" "">
    {
        Shape对象.无参数及返回值方法 ("Apply")
    }

    方法 翻转 <公开 注释 = "绕指定形状的水平或垂直对称轴翻转该形状" "">
    参数 水平翻转 <类型 = 逻辑型 注释 = "指定形状是水平翻转还是垂直翻转.如果值为真.则表示水平翻转;如果值为假.则表示垂直翻转." @默认值 = 真>
    {
        Shape对象.无返回值方法 ("Flip", 选择 (水平翻转, 0, 1))
    }

    方法 旋转 <公开 注释 = "按指定度数值.改变指定形状绕z轴的旋转角度." "">
    参数 角度 <类型 = 整数 注释 = "指定形状的水平旋转量.以度为单位.为正值时顺时针旋转形状.为负值时逆时针旋转形状." "">
    {
        Shape对象.无返回值方法 ("IncrementRotation", 角度)
    }

    方法 置阴影 <公开 注释 = "指定形状的阴影格式">
    参数 颜色 <类型 = 整数 注释 = "设置阴影颜色.默认为黑色." @默认值 = 0>
    参数 水平偏移量 <类型 = 小数 注释 = "设置阴影相对指定形状的水平偏移量.以磅为单位." @默认值 = 2>
    参数 垂直偏移量 <类型 = 小数 注释 = "设置阴影相对指定形状的垂直偏移量.以磅为单位." @默认值 = 2>
    参数 风格 <类型 = PPT阴影风格 注释 = "PPT阴影风格.*" @默认值 = PPT阴影风格.外阴影>
    参数 类型 <类型 = 整数 注释 = "如果值为-2.则表示混合类型;如果值为1-20.则表示20个不同阴影类型.如果值为-1.则表示忽略该参数;" @默认值 = -1>
    参数 透明度 <类型 = 小数 注释 = "取值范围:0.0到1.0之间的小数值.如果值为-1.则表示忽略该参数." @默认值 = -1>
    参数 虚化半径 <类型 = 小数 注释 = "取值范围为正整数.设置指定阴影的虚化半径.以磅为单位.如果值为-1.则表示忽略该参数." @默认值 = -1>
    参数 大小 <类型 = 整数 注释 = "指定阴影的大小作为形状大小的百分比.取值范围:0到200之间的整数值.如果值为-1.则表示忽略该参数." @默认值 = -1>
    参数 跟随旋转 <类型 = 逻辑型 注释 = "设置与指定阴影相关联的形状旋转时指定的阴影是否旋转" @默认值 = 假>
    {
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Visible", 真)  // 设置对象格式的可见性
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 颜色)
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Style", 风格)  // 设置阴影风格
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("RotateWithShape", 跟随旋转)  // 设置与指定阴影相关联的形状旋转时指定的阴影是否旋转
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("OffsetX", 水平偏移量)  // 设置阴影水平偏移量
        Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("OffsetY", 垂直偏移量)  // 设置阴影垂直偏移量
        如果 (虚化半径 != -1)
        {
            Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Blur", 虚化半径)  // 设置阴影虚化半径
        }
        如果 (透明度 != -1)
        {
            Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Transparency", 透明度)  // 设置阴影透明度
        }
        如果 (类型 != -1)
        {
            Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Type", 类型)  // 设置阴影类型
        }
        如果 (大小 != -1)
        {
            Shape对象.读无参数对象型属性 ("Shadow", COM对象类).写属性 ("Size", 大小)  // 设置对象格式的可见性
        }
    }

    方法 取消组合 <公开 注释 = "取消指定的形状或形状范围中所有组合的形状的组合.图片和OLE对象指定的形状或形状范围." "">
    {
        Shape对象.无参数及返回值方法 ("Ungroup")
    }

    方法 按宽度缩放 <公开 注释 = "根据指定的系数缩放图形宽度.对于图片和OLE对象.您可以说明是相对于原始大小还是相对于当前大小缩放形状.图片和OLE对象以外的形状总是相对于当前宽度缩放." "">
    参数 缩放比例 <类型 = 小数 注释 = "指定形状调整后的宽度与当前或原始宽度的比例.例如.要将一个矩形放大百分之五十.请将此参数指定为 1.5.">
    参数 原形缩放 <类型 = 逻辑型 注释 = "指定是否相对于形状的当前或原始尺寸来缩放形状." 注释 = "真 相对于原始尺寸缩放形状." 注释 = "假 相对于当前尺寸缩放形状" @默认值 = 真>
    参数 不变位置 <类型 = 整数 注释 = "在缩放形状时.形状中位置不变的部分." 注释 = "0 形状的左上角保持在原有的位置." 注释 = "1 形状的中点保持在原有的位置." 注释 = "2 形状的右下角保持在原有的位置."
            @默认值 = 0>
    {
        Shape对象.无返回值方法 ("ScaleWidth", 缩放比例, 原形缩放, 不变位置)
    }

    方法 按高度缩放 <公开 注释 = "根据指定的系数缩放图形高度.对于图片和OLE对象.您可以说明是相对于原始大小还是相对于当前大小缩放形状.图片和OLE对象以外的形状总是相对于当前高度缩放." "">
    参数 缩放比例 <类型 = 小数 注释 = "指定形状调整后的高度与当前或原始高度的比例.例如.要将一个矩形放大百分之五十.请将此参数指定为 1.5.">
    参数 原形缩放 <类型 = 逻辑型 注释 = "指定是否相对于形状的当前或原始尺寸来缩放形状." 注释 = "真 相对于原始尺寸缩放形状." 注释 = "假 相对于当前尺寸缩放形状" @默认值 = 真>
    参数 不变位置 <类型 = 整数 注释 = "在缩放形状时.形状中位置不变的部分." 注释 = "0 形状的左上角保持在原有的位置." 注释 = "1 形状的中点保持在原有的位置." 注释 = "2 形状的右下角保持在原有的位置."
            @默认值 = 0>
    {
        Shape对象.无返回值方法 ("ScaleHeight", 缩放比例, 原形缩放, 不变位置)
    }

    方法 置层次 <公开 注释 = "指定层次方式设置形状的层次" "">
    参数 层次方式 <类型 = PPT图形层次 注释 = "PPT图形层次.*">
    {
        Shape对象.无返回值方法 ("ZOrder", 层次方式)
    }

    方法 置背景图案 <公开 注释 = "将背景填充为图案">
    参数 图案 <类型 = PPT背景图案 注释 = "PPT背景图案.*" @默认值 = PPT背景图案.点线百分之5>
    参数 前景色 <类型 = 整数 注释 = "前景色" @默认值 = 颜色类.蓝色>
    参数 背景色 <类型 = 整数 注释 = "背景色" @默认值 = 颜色类.白色>
    {
        背景可视 = 真  // 设置背景可视为真
