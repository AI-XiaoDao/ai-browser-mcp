        Presentation对象.读无参数对象型属性 ("Fonts", COM对象类).无返回值方法 ("Replace", 被替换字体, 替换字体)
    }
}

类 PPT播放 <公开 注释 = "代表PPT文稿的幻灯片放映设置及播放">
{
    变量 SlideShowSettings对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_SlideShowSettings对象 <类型 = COM对象类>
    {
        SlideShowSettings对象 = 参_SlideShowSettings对象
        返回 (SlideShowSettings对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (SlideShowSettings对象)
    }

    方法 开始放映 <公开 注释 = "运行指定\"PPT文稿\"的幻灯片放映">
    {
        SlideShowSettings对象.无参数及返回值方法 ("Run")
    }

