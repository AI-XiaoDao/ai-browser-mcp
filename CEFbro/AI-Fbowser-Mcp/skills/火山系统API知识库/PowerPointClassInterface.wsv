    方法 开始位置 <公开 属性读 类型 = 整数 注释 = "取文本区在整个PPT文稿中的开始位置" "">
    {
        返回 (TextRange对象.读无参数属性 ("Start", 整数))
    }

    方法 替换 <公开 注释 = "替换文本区中对应的文本内容" "">
    参数 查找文本 <类型 = 文本型 注释 = "用作查找文本">
    参数 替换文本 <类型 = 文本型 注释 = "用作替换文本">
    参数 开始位置 <类型 = 整数 注释 = "查找开始位置" @默认值 = 0>
    参数 替换所有 <类型 = 逻辑型 注释 = "如果为假,表示只替换遇到的第一个匹配项." @默认值 = 真>
    参数 区分大小写 <类型 = 逻辑型 注释 = "英文是否区分大小写" @默认值 = 真>
    {
        变量 Find对象 <类型 = COM对象类>
        变量 COM变体 <类型 = COM变体型>
        循环判断首 ()
        {
            Find对象 = TextRange对象.对象型方法 ("Find", COM对象类, 查找文本, 开始位置, 区分大小写)  // 取出查找到对象
            Find对象.写属性 ("Text", 替换文本)  // 将替换内容写入找到对象
            开始位置 = Find对象.读无参数属性 ("Start", 整数)  // 更新找到位置为下次查找位置
            如果 (替换所有 == 假)
            {
                跳出循环
            }
        }
        循环判断尾 (Find对象.是否为空 () == 假)  // 查找到对象为空时退出循环
    }

    方法 查找 <公开 类型 = PPT文本区 注释 = "查找文本区中对应的文本内容,返回一个新的\"PPT文本区\"." "">
    参数 查找文本 <类型 = 文本型 注释 = "用作查找文本">
    参数 开始位置 <类型 = 整数 注释 = "查找开始位置" @默认值 = 0>
    参数 区分大小写 <类型 = 逻辑型 注释 = "英文字母是否区分大小写" @默认值 = 真>
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        变量 局_对象 <类型 = COM对象类>
        局_对象 = TextRange对象.对象型方法 ("Find", COM对象类, 查找文本, 开始位置, 区分大小写)
        局_PPT文本区.置对象 (局_对象)
        返回 (局_PPT文本区)
    }

    方法 段落数 <公开 属性读 类型 = 整数 注释 = "返回当前文本区中段落数量,代表当前选区中段落数量.注意:当前文本区,非整个PPT文稿.">
    {
        返回 (TextRange对象.读无参数对象型属性 ("Paragraphs", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取段落 <公开 类型 = PPT文本区 注释 = "返回一个\"PPT段落\"类,代表当前文本区中段落集合中根据索引号对应的一段段落.注意:当前文本区,非整个PPT文稿.">
    参数 索引号 <类型 = 整数 注释 = "欲取出选区中的段落开始索引号">
    参数 段落数量 <类型 = 整数 注释 = "指从索引号开始算起,要取出段落的数量." @默认值 = 1>
    {
        变量 局_PPT文本区 <类型 = PPT文本区>
        局_PPT文本区.置对象 (TextRange对象.对象型方法 ("Paragraphs", COM对象类, 索引号, 段落数量))
        返回 (局_PPT文本区)
    }

    方法 段落对齐 <公开 属性读 类型 = PPT段落对齐 注释 = "返回每个段落的对齐方式">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数属性 ("Alignment", PPT段落对齐))
    }

    方法 段落对齐 <公开 属性写 注释 = "设置每个段落的对齐方式">
    参数 对齐方式 <类型 = PPT段落对齐 注释 = "PPT段落对齐.*" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("Alignment", 对齐方式)
    }

    方法 段落字间距 <公开 属性读 类型 = 整数 注释 = "以磅为单位返回指定文本中基准行之间的距离" 返回值注释 = "磅为单位">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("LineRuleWithin", 0)  // 将基线间的行距设为特定磅数
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数属性 ("SpaceWithin", 整数))
    }

    方法 段落字间距 <公开 属性写 注释 = "以磅为单位设置指定文本中基准行之间的距离">
    参数 间距 <类型 = 整数 注释 = "磅为单位" "">
    {
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("LineRuleWithin", 0)  // 将基线间的行距设为特定磅数
        TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).写属性 ("SpaceWithin", 间距)
    }

    方法 段落文本方向 <公开 属性读 类型 = PPT段落文本方向 注释 = "返回段落文本方向" 返回值注释 = "PPT段落文本方向.*">
    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数属性 ("TextDirection", PPT段落文本方向))
    }

    方法 段落文本方向 <公开 属性写 注释 = "设置段落文本方向">
