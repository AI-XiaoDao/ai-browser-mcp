    常量 设计器 <公开 值 = @vbext_ct_ActiveXDesigner 注释 = "ActiveX 设计器">
    常量 文档模块 <公开 值 = @vbext_ct_Document 注释 = "文档模块">
}

类 PPT程序 <公开 注释 = "代表整个PowerPoint程序">
{
    变量 Application对象 <类型 = COM对象类>
    变量 Application事件 <类型 = COM对象事件类 注释 = "事件对象">

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建PowerPoint对象" 返回值注释 = "成功返回真." 返回值注释 = "失败返回假,没有安装Microsoft Office PowerPoint程序." "">
    {
        返回 (Application对象.创建 ("PowerPoint.Application", ""))
    }

    方法 获取 <公开 类型 = 逻辑型 注释 = "获取当前操作系统中已经存在的\"PowerPoint对象\"填入本对象中,本对象中的原有内容将被覆盖.">
    {
        返回 (Application对象.获取 ("PowerPoint.Application"))
    }

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Application对象 <类型 = COM对象类>
    {
        Application对象 = 参_Application对象
        返回 (Application对象.是否为空 () == 假)
    }

    方法 宏设置 <公开 注释 = "设置是否启用宏并信任VBA工程对象模型的访问,需要在文稿未打开前使用.">
    参数 启用宏方式 <类型 = 整数 注释 = "1.启用所有宏." 注释 = "2.通过通知禁用VBA宏." 注释 = "3.禁用无数字签署的VBA宏." 注释 = "4.不提供通知,禁用VBA宏." @默认值 = 1>
    参数 信任 <类型 = 逻辑型 注释 = "是否信任对VBA工程对象模型的访问" @默认值 = 真>
    {
        写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Office\\" + 版本 + "\\PowerPoint\\Security\\VBAWarnings", 启用宏方式)  // 启用宏方式
        写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Office\\" + 版本 + "\\PowerPoint\\Security\\AccessVBOM", 选择 (信任, 1, 0))  // 是否信任对VBA工程对象模型的访问
    }

    方法 退出 <公开 注释 = "退出PowerPoint程序,并可选择保存或发送打开的文稿.">
    {
        Application对象.无参数及返回值方法 ("Quit")
    }

    方法 版本 <公开 属性读 类型 = 文本型 注释 = "PowerPoint版本号,与Office版本对应如下:" 注释 = "1.0----Office 1.0." 注释 = "5.0----Office 4.2."
            注释 = "7.0----Office 95." 注释 = "8.0----Office 97." 注释 = "9.0----Office 2000." 注释 = "10.0----Office XP/2002."
            注释 = "11.0----Office XP/2003." 注释 = "12.0----Office XP/2007." 注释 = "14.0----Office 2010." 注释 = "15.0----Office 2013."
            注释 = "16.0----Office 2016." 注释 = "16.0----Office 2021." "">
    {
        返回 (Application对象.读无参数属性 ("Version", 文本型))
    }

    方法 内部版本 <公开 属性读 类型 = 文本型 注释 = "返回PowerPoint内部版本号" "">
    {
        返回 (Application对象.读无参数属性 ("Build", 文本型))
    }

    方法 文稿集 <公开 属性读 类型 = PPT文稿集 注释 = "返回一个\"PPT文稿集\"集合,该集合代表所有打开的PPT文稿.此为只读属性." "">
    {
        变量 局_PPT文稿集 <类型 = PPT文稿集>
        局_PPT文稿集.置对象 (Application对象.读无参数对象型属性 ("Presentations", COM对象类))
        返回 (局_PPT文稿集)
    }

    方法 图表版式数 <公开 属性读 类型 = 整数 注释 = "返回应用程序中当前智能图表版式数量">
    {
        返回 (Application对象.读无参数对象型属性 ("SmartArtLayouts", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 图表样式数 <公开 属性读 类型 = 整数 注释 = "返回应用程序中当前智能图表快速样式数量">
    {
        返回 (Application对象.读无参数对象型属性 ("SmartArtQuickStyles", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 图表配色数 <公开 属性读 类型 = 整数 注释 = "返回应用程序中当前智能图表配色数量">
    {
        返回 (Application对象.读无参数对象型属性 ("SmartArtColors", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 显示警告 <公开 属性读 类型 = 逻辑型 注释 = "返回运行宏时产生的一些警告和消息的处理方式" 返回值注释 = "如果为真.则表示显示所有警告;如果为假.则表示不显示任何警告." 返回值注释 = "">
    {
        返回 (Application对象.读无参数属性 ("DisplayAlerts", 逻辑型))
    }

    方法 显示警告 <公开 属性写 注释 = "设置运行宏时产生的一些警告和消息的处理方式">
    参数 所欲设置的值 <类型 = 逻辑型 注释 = "如果为真.则表示显示所有警告;默认值为假.表示不显示任何警告或消息框.如果运行宏时遇到消息框.则选择默认值并继续运行宏." @默认值 = 假>
    {
        Application对象.写属性 ("DisplayAlerts", 选择 (所欲设置的值, 2, 1))
    }

    方法 可视 <公开 属性读 类型 = 逻辑型 注释 = "返回对象是否可见">
    {
        返回 (Application对象.读无参数属性 ("Visible", 逻辑型))
    }

    方法 可视 <公开 属性写 注释 = "设置对象是否可见">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Application对象.写属性 ("Visible", 所欲设置的值)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作.">
    {
        返回 (Application对象)
    }

    方法 激活 <公开 注释 = "激活指定的对象">
    {
        Application对象.无参数及返回值方法 ("Activate")
    }

    方法 像素到磅 <公开 类型 = 小数 注释 = "屏幕像素转换到以磅为单位大小">
    参数 待转换像素值 <类型 = 小数 注释 = "待转换像素值">
    {
        返回 (待转换像素值 * 0.75)
    }

    方法 帮助 <公开 注释 = "显示一个帮助主题">
    参数 文件名 <类型 = 文本型 注释 = "要显示的帮助文件的名称.可以是后缀为\".chm\"或\".hlp\"的文件.如果未指定该参数.将使用PowerPoint帮助." @默认值 = "">
    参数 ID号 <类型 = 整数 注释 = "帮助主题的上下文ID号.如果未指定该参数.或者没有与指定的上下文ID号相关的帮助主题.则显示\"帮助主题\"对话框." @默认值 = 0>
    {
        变量 局_文件名 <类型 = COM变体型>
        变量 局_ID号 <类型 = COM变体型>
        如果 (文件名 != "")
        {
            局_文件名.赋值 (文件名, )
        }
        如果 (ID号 != 0)
        {
            局_ID号.赋值 (ID号, )
        }
        Application对象.无返回值方法 ("Help", 文件名, ID号)
    }

    方法 激活文稿 <公开 注释 = "激活文稿集合中的一个文稿">
    参数 索引号 <类型 = 整数 注释 = "二选一,对象的索引号.从1开始,表示文稿在文稿集中的位置.为-1时忽略该参数." @默认值 = -1>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.索引号不为-1时忽略该参数." @默认值 = "">
    {
        如果 (索引号 == -1)
        {
            Application对象.读无参数对象型属性 ("ActivePresentation", COM对象类).读对象型属性 ("Item", COM对象类, 名称).无参数及返回值方法 ("Activate")  // 从文稿名激活
        }
        否则
        {
            Application对象.读无参数对象型属性 ("ActivePresentation", COM对象类).读对象型属性 ("Item", COM对象类, 索引号).无参数及返回值方法 ("Activate")  // 从文稿索引激活
        }
    }

