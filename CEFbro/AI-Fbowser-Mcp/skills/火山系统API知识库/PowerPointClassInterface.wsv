    方法 置表格边框 <公开 注释 = "当对象为表格时,设置表格边框.">
    参数 行索引 <类型 = 整数 注释 = "指定表格行索引号">
    参数 列索引 <类型 = 整数 注释 = "指定表格列索引号">
    参数 边框 <类型 = PPT边框集合 注释 = "二选一.PPT边框集合.*.如果\"四边\"为真.则忽略该参数." @默认值 = PPT边框集合.上边框>
    参数 四边 <类型 = 逻辑型 注释 = "二选一.是否指定设置上下左右四个边框.为假时则根据指定边框进行设置." @默认值 = 假>
    参数 宽度 <类型 = 小数 注释 = "设置指定线条的粗细,以磅为单位.如果值为-1.则忽略该参数." @默认值 = -1>
    参数 前景色 <类型 = 整数 注释 = "设置指定线条的前景色.如果值为-1.则忽略该参数." @默认值 = -1>
    参数 背景色 <类型 = 整数 注释 = "设置指定线条的背景色.如果值为-1.则忽略该参数." @默认值 = -1>
    参数 透明度 <类型 = 小数 注释 = "设置指定线条的透明度.取值范围0.0-1.0之间.如果值为-1.则忽略该参数." @默认值 = -1>
    参数 虚线样式 <类型 = 整数 注释 = "取值范围1-12设置,指定线条为虚线样式.如果值为1.则表示实线.如果值为-1.则忽略该参数." @默认值 = -1>
    {
        变量 局_边框 <类型 = COM对象类>
        如果 (四边)
        {
            计次循环 (4)  // 表示上下左右四个边框
            {
                局_边框 = Shape对象.读无参数对象型属性 ("Table", COM对象类).对象型方法 ("Cell", COM对象类, 行索引, 列索引).读无参数对象型属性 ("Borders", COM对象类).对象型方法 ("Item", COM对象类, 取循环索引 () + 1)
                如果 (宽度 != -1)
                {
                    局_边框.写属性 ("Weight", 宽度)  // 设置指定线条的粗细
                }
                如果 (前景色 != -1)
                {
                    局_边框.读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 前景色)  // 设置指定线条的前景色
                }
                如果 (背景色 != -1)
                {
                    局_边框.读无参数对象型属性 ("BackColor", COM对象类).写属性 ("RGB", 背景色)  // 设置指定线条的背景色
                }
                如果 (透明度 != -1)
                {
                    局_边框.写属性 ("Transparency", 透明度)  // 设置指定线条的透明度
                }
                如果 (虚线样式 != -1)
                {
                    局_边框.写属性 ("DashStyle", 虚线样式)  // 设置指定线条的虚线样式
                }
            }
        }
        否则
        {
            局_边框 = Shape对象.读无参数对象型属性 ("Table", COM对象类).对象型方法 ("Cell", COM对象类, 行索引, 列索引).读无参数对象型属性 ("Borders", COM对象类).对象型方法 ("Item", COM对象类, 边框)
            如果 (宽度 != -1)
            {
                局_边框.写属性 ("Weight", 宽度)  // 设置指定线条的粗细
            }
            如果 (前景色 != -1)
            {
                局_边框.读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 前景色)  // 设置指定线条的前景色
            }
            如果 (背景色 != -1)
            {
                局_边框.读无参数对象型属性 ("BackColor", COM对象类).写属性 ("RGB", 背景色)  // 设置指定线条的背景色
            }
            如果 (透明度 != -1)
            {
                局_边框.写属性 ("Transparency", 透明度)  // 设置指定线条的透明度
            }
            如果 (虚线样式 != -1)
            {
                局_边框.写属性 ("DashStyle", 虚线样式)  // 设置指定线条的虚线样式
            }
        }
    }

