    常量 空白 <公开 值 = @ppLayoutBlank 注释 = "空白">
    常量 文本与对象 <公开 值 = @ppLayoutTextAndObject 注释 = "文本和对象">
    常量 对象与文本 <公开 值 = @ppLayoutObjectAndText 注释 = "对象和文本">
    常量 无标题对象 <公开 值 = @ppLayoutLargeObject 注释 = "无标题大型对象">
    常量 对象 <公开 值 = @ppLayoutObject 注释 = "对象">
    常量 文本与媒体 <公开 值 = @ppLayoutTextAndMediaClip 注释 = "文本和媒体剪辑">
    常量 媒体和文本 <公开 值 = @ppLayoutMediaClipAndText 注释 = "媒体剪辑和文本">
    常量 文本上对象 <公开 值 = @ppLayoutObjectOverText 注释 = "对象在文本之上">
    常量 对象上文本 <公开 值 = @ppLayoutTextOverObject 注释 = "文本在对象之上">
