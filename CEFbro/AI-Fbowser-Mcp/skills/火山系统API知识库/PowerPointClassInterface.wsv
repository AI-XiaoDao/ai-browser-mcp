        局_PPT图形.置对象 (Slide对象.读无参数对象型属性 ("Background", COM对象类))
        返回 (局_PPT图形)
    }

    方法 隐藏背景图形 <公开 属性读 类型 = 逻辑型 注释 = "返回背景图形是否被隐藏">
    {
        返回 (Slide对象.读无参数属性 ("DisplayMasterShapes", 逻辑型))
    }

    方法 隐藏背景图形 <公开 属性写 注释 = "设置背景图形是否被隐藏">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Slide对象.写属性 ("DisplayMasterShapes", 所欲设置的值)
    }

    方法 取图形 <公开 类型 = PPT图形 注释 = "取出代表幻灯片中形状的PPT图形类">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示图形在PPT文稿图形集合中位置.为-1时忽略该参数." @默认值 = -1>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.索引号不为-1时忽略该参数." @默认值 = "">
    {
        变量 局_PPT图形 <类型 = PPT图形>
        如果 (索引号 == -1)
        {
            如果 (名称 != "")
            {
                局_PPT图形.置对象 (Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("Item", COM对象类, 名称))  // 名称取PPT图形
            }
        }
        否则
        {
            局_PPT图形.置对象 (Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("Item", COM对象类, 索引号))  // 索引号取PPT图形
        }
        返回 (局_PPT图形)
    }

    方法 添加表格 <公开 类型 = PPT图形 注释 = "将表格形状添加到幻灯片中">
    参数 行数 <类型 = 整数 注释 = "表格的行数" @默认值 = 1>
    参数 列数 <类型 = 整数 注释 = "表格的列数" @默认值 = 1>
    参数 左边 <类型 = 小数 注释 = "设置幻灯片左边缘到表格左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置幻灯片左边缘到表格左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置表格的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置表格的高度,以磅为单位." @默认值 = 100>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddTable", COM对象类, 行数, 列数, 左边, 上边, 宽度, 高度)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

    方法 添加智能图表 <公开 类型 = PPT图形 注释 = "向文档中添加智能图表,并返回新建的图形.">
    参数 版式索引 <类型 = 整数 注释 = "智能图表样式索引号,索引号不能大于图表总数量.智能图表数量可通过\"PPT程序.图表版式数\"获得." @默认值 = 1>
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        变量 局_版式 <类型 = COM变体型>
        局_版式 = Slide对象.读无参数对象型属性 ("Application", COM对象类).读无参数对象型属性 ("SmartArtLayouts", COM对象类).方法 ("Item", COM变体型, 版式索引)
        局_图形 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddSmartArt", COM对象类, 局_版式, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_PPT图形.置对象 (局_图形)
        返回 (局_PPT图形)
    }

    方法 添加图片 <公开 类型 = PPT图形 注释 = "将图片添加到幻灯片中,并返回新建图片的\"PPT图形\"类.">
    参数 文件名 <类型 = 文本型 注释 = "图片文件名">
    参数 链接到文件 <类型 = 逻辑型 注释 = "确定是否将图片链接到从中创建该图片的文件.与\"文稿中存储\".必须有一个为真." @默认值 = 假>
    参数 文稿中存储 <类型 = 逻辑型 注释 = "确定是否将已链接的图片插入到文稿一起保存.与\"链接源目标\".必须有一个为真." @默认值 = 真>
    参数 左边 <类型 = 小数 注释 = "设置幻灯片左边缘到图片对象左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置幻灯片上边缘到图片对象上边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置图片对象的宽度,以磅为单位.默认为-1.表示不指定宽度由内容决定宽度大小." @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "设置图片对象的高度,以磅为单位.默认为-1.表示不指定高度由内容决定高度大小." @默认值 = -1>
    {
        变量 局_图形对象 <类型 = COM对象类>
        变量 局_PPT图形 <类型 = PPT图形>
        变量 局_宽度 <类型 = COM变体型>
        变量 局_高度 <类型 = COM变体型>
        如果 (宽度 != -1)
        {
            局_宽度.赋值 (宽度, )
        }
        如果 (高度 != -1)
        {
            局_高度.赋值 (高度, )
        }
        局_图形对象 = Slide对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddPicture2", COM对象类, 文件名, 链接到文件, 文稿中存储, 左边, 上边, 局_宽度, 局_高度)
        局_PPT图形.置对象 (局_图形对象)
        返回 (局_PPT图形)
    }

