    {
        返回 (TextRange对象.读无参数对象型属性 ("ParagraphFormat", COM对象类).读无参数对象型属性 ("Bullet", COM对象类).读无参数属性 ("Style", PPT段落编号))
    }

    方法 段落编号 <公开 属性写 注释 = "设置项目段落编号">
