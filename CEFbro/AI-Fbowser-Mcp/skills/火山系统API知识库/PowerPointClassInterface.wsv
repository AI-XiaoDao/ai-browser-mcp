    参数 参_PPT文稿 <类型 = PPT文稿 注释 = "被保存的文稿">

    方法 窗口被激活 <公开 定义事件 类型 = 整数 注释 = "保存任意打开的\"PPT文稿\"前发生此事件">
    参数 参_PPT文稿 <类型 = PPT文稿 注释 = "在激活的窗口中显示的文稿">
    参数 参_窗口对象 <类型 = COM对象类 注释 = "PowerPoint提供的DocumentWindow对象,代表激活的文档窗口.">

    方法 窗口反激活 <公开 定义事件 类型 = 整数 注释 = "停用应用程序窗口或任意文档窗口时发生此事件">
    参数 参_PPT文稿 <类型 = PPT文稿 注释 = "非活动窗口中显示的文稿">
    参数 参_窗口对象 <类型 = COM对象类 注释 = "PowerPoint提供的DocumentWindow对象,代表非活动文档窗口.">

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出.事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        变量 局_返回值 <类型 = 整数 值 = 0>
        如果 (来源对象 == Application事件)
        {
            如果 (事件方法ID == 2004)  // 文稿被关闭
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文稿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文稿对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文稿对象)
                局_返回值 = 文稿被关闭 (局_PPT文稿)
            }
            如果 (事件方法ID == 2005)  // 文稿被保存
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文稿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文稿对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文稿对象)
                局_返回值 = 文稿被保存 (局_PPT文稿)
            }
            如果 (事件方法ID == 2006)  // 文稿被打开
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文稿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文稿对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文稿对象)
                局_返回值 = 文稿被打开 (局_PPT文稿)
            }
            如果 (事件方法ID == 2007)  // 文稿被新建
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文稿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文稿对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文稿对象)
                局_返回值 = 文稿被新建 (局_PPT文稿)
            }
            如果 (事件方法ID == 2008)  // 幻灯片被新建
            {
                变量 局_PPT幻灯片 <类型 = PPT幻灯片>
                变量 幻灯片对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (幻灯片对象, )  // 第一个参数为幻灯片对象
                局_PPT幻灯片.置对象 (幻灯片对象)
                局_返回值 = 幻灯片被新建 (局_PPT幻灯片)
            }
            如果 (事件方法ID == 2009)  // 窗口被激活
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文档对象 <类型 = COM对象类>
                变量 窗口对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文档对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文档对象)
                事件参数.取成员 (1).取COM对象 (窗口对象, )  // 第二个参数为窗口对象
                局_返回值 = 窗口被激活 (局_PPT文稿, 窗口对象)
            }
            如果 (事件方法ID == 2010)  // 窗口被激活
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文档对象 <类型 = COM对象类>
                变量 窗口对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文档对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文档对象)
                事件参数.取成员 (1).取COM对象 (窗口对象, )  // 第二个参数为窗口对象
                局_返回值 = 窗口反激活 (局_PPT文稿, 窗口对象)
            }
            如果 (事件方法ID == 2011)  // 幻灯片放映开始
            {
                变量 窗口对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (窗口对象, )  // 第一个参数为窗口对象
                局_返回值 = 开始放映 (窗口对象)
            }
            如果 (事件方法ID == 2013)  // 幻灯片放映切换到下一张
            {
                变量 窗口对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (窗口对象, )  // 第一个参数为窗口对象
                局_返回值 = 幻灯片被切换 (窗口对象)
            }
            如果 (事件方法ID == 2014)  // 幻灯片放映结束
            {
                变量 窗口对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (窗口对象, )  // 第一个参数为窗口对象
                局_返回值 = 结束放映 (窗口对象)
            }
            如果 (事件方法ID == 2015)  // 文稿被打印
            {
                变量 局_PPT文稿 <类型 = PPT文稿>
                变量 文稿对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文稿对象, )  // 第一个参数为文稿对象
                局_PPT文稿.置对象 (文稿对象)
                局_返回值 = 文稿被打印 (局_PPT文稿)
            }
            如果 (事件方法ID == 2016)  // 幻灯片被重选
            {
                变量 局_PPT幻灯片 <类型 = PPT幻灯片>
                变量 幻灯片对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (幻灯片对象, )  // 第一个参数为幻灯片对象
                局_PPT幻灯片.置对象 (幻灯片对象)
                局_返回值 = 幻灯片被重选 (局_PPT幻灯片)
            }
        }
        返回 (局_返回值)
    }
}

类 PPT宏 <公开 注释 = "代表VB宏对象">
{
    变量 VBComponents对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_VBComponents对象 <类型 = COM对象类 注释 = "VBComponents对象">
    {
        VBComponents对象 = 参_VBComponents对象
        返回 (VBComponents对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PPT程序提供的VB宏对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (VBComponents对象)
    }

    方法 工作区数量 <公开 属性读 类型 = 整数 注释 = "获取宏工作区数量" "">
    {
        返回 (VBComponents对象.读无参数属性 ("Count", 整数))
    }

    方法 取工作区名称 <公开 类型 = 文本型 注释 = "取宏工作区对象名称" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号,从1开始.">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("Name", 文本型))
    }

    方法 取工作区类型 <公开 类型 = PPT宏类型 注释 = "取宏工作区对象类型" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数属性 ("Type", PPT宏类型))
    }

    方法 插入行代码 <公开 注释 = "在指定工作区对应行增加代码,原代码后移.增加代码不理会和判断插入处代码的内容.当指定行大于最后一行行号时,在最后一行的后面插入." "">
    参数 区名 <类型 = 文本型>
    参数 行号 <类型 = 整数>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("InsertLines", 行号, 代码内容)
    }

    方法 添加代码 <公开 注释 = "在指定工作区第一个过程前面的行开始增加代码,原代码后移." "">
    参数 区名 <类型 = 文本型>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("AddFromString", 代码内容)
    }

    方法 添加模块 <公开 注释 = "向VB工作区中添加模块">
    参数 模块名称 <类型 = 文本型 @默认值 = "">
    参数 类型 <类型 = PPT宏类型 @默认值 = PPT宏类型.模块>
    {
        变量 局_模块对象 <类型 = COM对象类>
        局_模块对象 = VBComponents对象.方法 ("Add", COM对象类, 类型)
        如果 (模块名称 != "")
        {
            局_模块对象.写属性 ("Name", 模块名称)
        }
    }

    方法 取代码行数 <公开 类型 = 整数 注释 = "获取工作区代码总行数" "">
    参数 区名 <类型 = 文本型>
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("CountOfLines", 整数))
    }

    方法 取代码内容 <公开 类型 = 文本型 注释 = "获取工作区宏代码内容" "">
    参数 区名 <类型 = 文本型 注释 = "对象名称,如模块名称.">
    参数 开始行 <类型 = 整数 注释 = "欲取出代码区开始行">
    参数 结束行 <类型 = 整数 注释 = "欲取出代码区结束行">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读属性 ("Lines", 文本型, 开始行, 结束行))
    }

    方法 移除模块 <公开 注释 = "根据宏模块名称移除宏模块">
    参数 模块名 <类型 = 文本型 @默认值 = "">
    {
        变量 COM变体 <类型 = COM变体型>
        COM变体 = VBComponents对象.方法 ("Item", COM变体型, 模块名)  // 根据名称取出对象
        VBComponents对象.无返回值方法 ("Remove", COM变体)
    }

    方法 导入文件 <公开 注释 = "将VB宏代码文件导入宏工作区中" "">
    参数 文件名 <类型 = 文本型 注释 = "欲导入的宏文件">
    {
        VBComponents对象.无返回值方法 ("Import", 文件名)
    }
}

类 PPT文稿集 <公开 注释 = " 在PowerPoint中的所有\"PPT文稿\"对象的集合">
{
    变量 Presentations对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_PPT文稿集 <类型 = COM对象类 注释 = "PPT文稿集对象">
    {
        Presentations对象 = 参_PPT文稿集
        返回 (Presentations对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Presentations对象)
    }

    方法 打开 <公开 类型 = PPT文稿 注释 = "打开一个文稿方法1" 返回值注释 = "PPT文稿" "">
    参数 文件名 <类型 = 文本型 注释 = "要打开的文稿的文件名">
    参数 只读模式 <类型 = 逻辑型 注释 = "指定是以可读/写状态还是以只读状态打开文件" @默认值 = 假>
    参数 标题可见 <类型 = 逻辑型 注释 = "指定程序窗口是否有标题" @默认值 = 真>
    参数 可视 <类型 = 逻辑型 注释 = "设置打开程序时窗口是否可见" @默认值 = 真>
    {
        变量 局_PPT文稿 <类型 = PPT文稿>
        局_PPT文稿.置对象 (Presentations对象.对象型方法 ("Open", COM对象类, 文件名, 只读模式, 标题可见, 可视))
        返回 (局_PPT文稿)
    }

    方法 打开2 <公开 类型 = PPT文稿 注释 = "打开一个文稿方法2" 返回值注释 = "PPT文稿" "">
    参数 文件名 <类型 = 文本型 注释 = "要打开的文稿的文件名">
    参数 只读模式 <类型 = 逻辑型 注释 = "指定是以可读/写状态还是以只读状态打开文件">
    参数 标题可见 <类型 = 逻辑型 注释 = "指定程序窗口是否有标题">
    参数 可视 <类型 = 逻辑型 注释 = "设置打开程序时窗口是否可见" @默认值 = 真>
    参数 修复 <类型 = 逻辑型 注释 = "指定是否在打开文件之前修复文件以避免损坏" @默认值 = 假>
    {
        变量 局_PPT文稿 <类型 = PPT文稿>
        局_PPT文稿.置对象 (Presentations对象.对象型方法 ("Open2007", COM对象类, 文件名, 只读模式, 标题可见, 可视, 修复))
        返回 (局_PPT文稿)
    }

    方法 添加文稿 <公开 类型 = PPT文稿 注释 = "创建一个PPT文稿.返回一个代表新PPT文稿的\"PPT文稿\"类.">
    参数 可视 <类型 = 逻辑型 注释 = "是否在可视窗口中显示文稿" @默认值 = 真>
    {
        变量 局_PPT文稿 <类型 = PPT文稿>
        局_PPT文稿.置对象 (Presentations对象.对象型方法 ("Add", COM对象类, 选择 (可视, -1, 0)))
        返回 (局_PPT文稿)
    }

    方法 文稿数量 <公开 属性读 类型 = 整数 注释 = "返回文稿集合中文稿的数量">
    {
        返回 (Presentations对象.读无参数属性 ("Count", 整数))
    }

    方法 取文稿 <公开 类型 = PPT文稿 注释 = "从文稿集合中返回一个文稿">
    参数 索引号 <类型 = 整数 注释 = "二选一,从1开始,对象在文稿集合的索引号.为-1时.忽略该参数." @默认值 = -1>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.索引号不为0时.忽略该参数." @默认值 = "">
    {
        变量 局_PPT文稿 <类型 = PPT文稿>
        如果 (索引号 == -1)
        {
            如果 (名称 != "")  // 名称不为空时根据名称取出文稿
            {
                局_PPT文稿.置对象 (Presentations对象.对象型方法 ("Item", COM对象类, 名称))  // 使用名称
            }
        }
        否则
        {
            局_PPT文稿.置对象 (Presentations对象.对象型方法 ("Item", COM对象类, 索引号))  // 使用索引号
        }
        返回 (局_PPT文稿)
    }
}

类 PPT文稿 <公开>
{
    变量 Presentation对象 <类型 = COM对象类>

    方法 保存 <公开 注释 = "保存指定的PPT文稿">
    {
        Presentation对象.无参数及返回值方法 ("Save")
    }

    方法 关闭 <公开 注释 = "关闭指定的PPT文稿">
    参数 保存更改 <类型 = 逻辑型 注释 = "是否保存更改" @默认值 = 真>
    {
        如果 (保存更改)
        {
            Presentation对象.无参数及返回值方法 ("Close")
        }
        否则
        {
            已保存 = 真  // 设置不保存更改
            Presentation对象.无参数及返回值方法 ("Close")
        }
        Presentation对象.清除 ()
    }

    方法 另存为 <公开 注释 = "另外保存PPT文稿">
    参数 文件名 <类型 = 文本型 注释 = "指定文件的保存名称.如果不指定完整路径.PowerPoint会将该文件保存于当前文件夹中." "">
    参数 保存格式 <类型 = PPT保存格式 注释 = "指定文件的保存的格式" @默认值 = PPT保存格式.默认格式>
    参数 保存字体 <类型 = 逻辑型 注释 = "指定是否将\"字体\"嵌入保存的PPT文稿中" @默认值 = 真>
    {
        Presentation对象.无返回值方法 ("SaveAs", 文件名, 保存格式, 选择 (保存字体, -1, 0))
    }

    方法 宏 <公开 属性读 类型 = PPT宏 注释 = "返回文档中的VB宏项目">
    {
        变量 局_PPT宏 <类型 = PPT宏>
        变量 局_宏工作区对象 <类型 = COM对象类>
        局_宏工作区对象 = Presentation对象.读无参数对象型属性 ("VBProject", COM对象类).读无参数对象型属性 ("VBComponents", COM对象类)
        局_PPT宏.置对象 (局_宏工作区对象)
        返回 (局_PPT宏)
    }

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_PPT文稿对象 <类型 = COM对象类 注释 = "PPT文稿对象">
    {
        Presentation对象 = 参_PPT文稿对象
        返回 (Presentation对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取PowerPoint提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Presentation对象)
    }

    方法 幻灯片数量 <公开 属性读 类型 = 整数 注释 = "返回文稿中所有幻灯片的数量">
    {
        返回 (Presentation对象.读无参数对象型属性 ("Slides", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取幻灯片 <公开 类型 = PPT幻灯片 注释 = "返回一个\"PPT幻灯片\"类.表示从指定幻灯片集合中,取出的单个幻灯片.">
    参数 索引号 <类型 = 整数 注释 = "三选一,对象的索引号.从1开始,表示幻灯片在幻灯片集合中位置.如果值为-1时,忽略该参数." @默认值 = -1>
    参数 名称 <类型 = 文本型 注释 = "三选一,对象的名称.索引号不为-1时,忽略该参数." @默认值 = "">
    参数 ID <类型 = 整数 注释 = "三选一,对象的ID.如果索引号不为-1或者该值为-1时,则忽略该参数." @默认值 = -1>
    {
        变量 局_PPT幻灯片 <类型 = PPT幻灯片>

        如果 (索引号 == -1)
        {
            如果 (名称 != "")
            {
                局_PPT幻灯片.置对象 (Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("Item", COM对象类, 名称))  // 名称取PPT幻灯片
            }
            如果 (ID != -1)
            {
                局_PPT幻灯片.置对象 (Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("FindBySlideID", COM对象类, ID))  // ID取PPT幻灯片
            }
        }
        否则
        {
            局_PPT幻灯片.置对象 (Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("Item", COM对象类, 索引号))  // 索引号取PPT幻灯片
        }
        返回 (局_PPT幻灯片)
    }

    方法 打印 <公开 注释 = "打印全部或部分指定文稿">
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号.当\"打印范围\"设置为\"指定范围\"时生效." @默认值 = 0>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号.当\"打印范围\"设置为\"指定范围\"时生效." @默认值 = 0>
    参数 输出文件名 <类型 = 文本型 注释 = "此参数将指定输出文件的路径和文件名称.如果此参数不为空文本.则文件将输出到某个文件.而不是发送到打印机." @默认值 = "">
    参数 打印份数 <类型 = 整数 注释 = "打印份数" @默认值 = 1>
    参数 副本 <类型 = 逻辑型 注释 = "在打印PPT文稿的多份副本时,若此参数为真,则打印完一份副本之后再打印下一份副本." @默认值 = 真>
    {
        变量 局_输出文件名 <类型 = COM变体型 "">
        变量 局_开始页号 <类型 = COM变体型>
        变量 局_终止页号 <类型 = COM变体型>
        如果 (输出文件名 != "")
        {
            局_输出文件名.赋值 (输出文件名, )
        }
        如果 (开始页号 != 0)
        {
            局_开始页号.赋值 (开始页号, )
        }
        如果 (终止页号 != 0)
        {
            局_终止页号.赋值 (终止页号, )
        }
        Presentation对象.无返回值方法 ("PrintOut", 局_开始页号, 局_终止页号, 局_输出文件名, 打印份数, 副本)
    }

    方法 添加幻灯片 <公开 类型 = PPT幻灯片 注释 = "创建一张新幻灯片.并返回该幻灯片.">
    参数 索引号 <类型 = 整数 注释 = "要添加的幻灯片的索引,从1开始.默认-1.表示在末尾添加." @默认值 = -1>
    参数 从索引号 <类型 = 整数 注释 = "二选一.根据现有幻灯片索引号新建同样版式的幻灯片.如果值为一1时,则忽略该参数." @默认值 = -1>
    参数 版式 <类型 = PPT幻灯片版式 注释 = "二选一.PPT幻灯片版式.*.当\"从索引号\"不等于\"一1\"时.忽略该参数." @默认值 = PPT幻灯片版式.空白>
    {
        变量 局_自定义版式 <类型 = COM变体型>
        变量 局_PPT幻灯片 <类型 = PPT幻灯片>
        变量 局_图形对象 <类型 = COM对象类>
        如果 (索引号 == -1)
        {
            索引号 = 幻灯片数量 + 1  // 表示在末尾添加幻灯片
        }
        如果 (从索引号 != -1)
        {
            局_自定义版式 = Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("Item", COM对象类, 从索引号).读无参数属性 ("CustomLayout", COM变体型)  // 取"从索引号"自定义版式
            局_图形对象 = Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("AddSlide", COM对象类, 索引号, 局_自定义版式)  // 根据自定义版式创建新的幻灯片
        }
        否则
        {
            局_图形对象 = Presentation对象.读无参数对象型属性 ("Slides", COM对象类).对象型方法 ("Add", COM对象类, 索引号, 版式)  // 根据版式创建新的幻灯片
        }
        局_PPT幻灯片.置对象 (局_图形对象)
        返回 (局_PPT幻灯片)
    }

    方法 模板名称 <公开 属性读 类型 = 文本型 注释 = "返回与指定PPT文稿关联的第一个设计/母版的名称.此为只读属性." "">
    {
        返回 (Presentation对象.读无参数属性 ("TemplateName", 文本型))
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "PPT文稿的名称包括文件扩展名,不包括其路径.如果需要更改名称,请使用\"另存为\"方法以其他名称保存PPT文稿.此为只读属性." "">
    {
        返回 (Presentation对象.读无参数属性 ("Name", 文本型))
    }

    方法 文件路径 <公开 属性读 类型 = 文本型 注释 = "返回一个代表打开\"PPT文稿\"的文件路径,如\"PPT文稿\"未保存则返回空文本.此为只读属性." "">
    {
        返回 (Presentation对象.读无参数属性 ("Path", 文本型))
    }

    方法 字体数量 <公开 属性读 类型 = 整数 注释 = "替换PPT文稿使用字体集合中字体的数量" "">
    {
        返回 (Presentation对象.读无参数对象型属性 ("Fonts", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取字体 <公开 类型 = 文本型 注释 = "返回文稿中字体索引号字体名称" "">
    参数 索引号 <类型 = 整数>
    {
        返回 (Presentation对象.读无参数对象型属性 ("Fonts", COM对象类).对象型方法 ("Item", COM对象类, 索引号).读无参数属性 ("Name", 文本型))
    }

    方法 置字体 <公开 注释 = "根据文稿中字体索引号设置字体" "">
    参数 索引号 <类型 = 整数 注释 = "PPT文稿中第几种字体">
    参数 字体 <类型 = 文本型 注释 = "要设置的字体名称">
    {
        Presentation对象.读无参数对象型属性 ("Fonts", COM对象类).对象型方法 ("Item", COM对象类, 索引号).写属性 ("Name", 字体)
    }

    方法 已保存 <公开 属性读 类型 = 逻辑型 注释 = "确定\"PPT文稿\"自上次保存以来是否进行过更改" "">
    {
        返回 (Presentation对象.读无参数属性 ("Saved", 逻辑型))
    }

    方法 已保存 <公开 属性写 注释 = "当设置为真时,表示退出文稿时不会提示用户保存更改." "">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Presentation对象.写属性 ("Saved", 所欲设置的值)
    }

    方法 自动保存 <公开 属性读 类型 = 逻辑型 注释 = "如果是否自动保存在PPT文稿中所做的编辑">
    {
        返回 (Presentation对象.读无参数属性 ("AutoSaveOn", 逻辑型))
    }

    方法 自动保存 <公开 属性写 注释 = "设置是否自动保存PPT文稿中所做的编辑">
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Presentation对象.写属性 ("AutoSaveOn", 所欲设置的值)
    }

    方法 密码 <公开 属性读 类型 = 文本型 注释 = "返回在打开指定PPT文稿时必须提供的密码">
    {
        返回 (Presentation对象.读无参数属性 ("Password", 文本型))
    }

    方法 密码 <公开 属性写 注释 = "设置在打开指定PPT文稿时必须提供的密码">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Presentation对象.写属性 ("Password", 所欲设置的值)
    }

    方法 写权限密码 <公开 属性读 类型 = 文本型 注释 = "返回保存PPT文稿更改时必须提供的密码">
