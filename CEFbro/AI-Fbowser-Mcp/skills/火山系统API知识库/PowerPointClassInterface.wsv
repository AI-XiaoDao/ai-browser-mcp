    常量 对象与两对象 <公开 值 = @ppLayoutObjectAndTwoObjects 注释 = "对象和两个对象">
    常量 两对象与对象 <公开 值 = @ppLayoutTwoObjectsAndObject 注释 = "两个对象和对象">
    常量 自定义 <公开 值 = @ppLayoutCustom 注释 = "自定义">
