    }

    方法 写权限密码 <公开 属性写 注释 = "设置保存PPT文稿更改时必须提供的密码">
    参数 所欲设置的值 <类型 = 文本型>
    {
        Presentation对象.写属性 ("WritePassword", 所欲设置的值)
    }

    方法 播放设置 <公开 属性读 类型 = PPT播放 注释 = "代表PPT文稿的幻灯片放映设置及播放对象">
    {
        变量 局_PPT播放 <类型 = PPT播放>
        局_PPT播放.置对象 (Presentation对象.读无参数对象型属性 ("SlideShowSettings", COM对象类))
        返回 (局_PPT播放)
    }

    方法 替换字体 <公开 注释 = "替换PPT文稿集合中的某种字体" "">
    参数 被替换字体 <类型 = 文本型 注释 = "被替换字体">
