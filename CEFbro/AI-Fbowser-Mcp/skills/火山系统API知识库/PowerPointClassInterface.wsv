<火山程序 类型 = "通常" 版本 = 1 />

包 火山.PowrPoint2021支持库 <@视窗.外部头文件 = "lib\\PowerPointconstant.h">

类 PPT窗口状态 <公开 注释 = "指定传递给和\"新建窗口\"对象的窗口状态的常量" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 常规 <公开 值 = @ppWindowNormal 注释 = "常规">
    常量 最小化 <公开 值 = @ppWindowMinimized 注释 = "最小化">
    常量 最大化 <公开 值 = @ppWindowMaximized 注释 = "最大化">
}

