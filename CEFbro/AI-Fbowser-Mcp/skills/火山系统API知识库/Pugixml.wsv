    方法 遍历所有节点 <公开 折叠 @嵌入式方法 = "">
    参数 walker <类型 = pugi树遍历事件接收器>
    {
        @ @sn<this>.data().traverse(@<walker>);

    }

    # //每个XPath表达式可以有以下类型之一：布尔值、数字、字符串或节点集。布尔型bool类型，数字类型对应于double类型，字符串类型对应于std::string或std::wstring，取决于启用宽字符接口，节点集对应于XPath节点集类型。有一个枚举，xpath_value_type，它可以接受以下值xpath_type_boolean, xpath_type_number, xpath_type_string或xpath_type_node_set，相应地。
    #
    # //因为XPath节点可以是节点，也可以是属性，所以有一种特殊的类型，xpath_node，这是这些类型的受歧视的结合。此类型的值包含两个节点句柄，其中一个为xml_node类型，另一种xml_attribute类型；最多只能有一个为非空类型。获取这些句柄的访问器可用：
    #
    # //xml_node xpath_node::node() const;
    # //xml_attribute xpath_node::attribute() const;
    #
    # //XPath节点可以为空，在这种情况下，两个访问器都返回空句柄。
    # //请注意，根据XPath规范，每个XPath节点都有一个父节点，可以通过以下函数检索该父节点：
    # //xml_node xpath_node::parent() const;
    #

    方法 路径_取节点 <公开 类型 = pugi节点 @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
    {
        @ pugi::xpath_node build_tool = data().select_node(@<路径文本>);
        @ return @dt<pugi节点>( build_tool.node());
    }

    方法 路径_取属性 <公开 类型 = pugi属性 @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
    {
        @ pugi::xpath_node build_tool = data().select_node(@<路径文本>);
        @ return @dt<pugi属性>( build_tool.attribute());
    }

    方法 select_nodes的一些说明注释 <折叠>
    {
        // 节点集由xpath_node_set对象,该对象具有类似于顺序随机访问容器之一的接口。它有一个迭代器类型以及通常的开始/结束迭代器访问器:

        // typedef const xpath_node* xpath_node_set::const_iterator;
        // const_iterator xpath_node_set::begin() const;
        // const_iterator xpath_node_set::end() const;
        // 它也可以通过索引迭代,就像std::vector:

        // const xpath_node& xpath_node_set::operator[](size_t index) const;
        // size_t xpath_node_set::size() const;
        // bool xpath_node_set::empty() const;
        // 所有上述操作的语义都与std::vector:迭代器是随机访问的,所有上述操作都是常数时间,访问大于或等于设置大小的元素将导致未定义的行为。您可以同时使用基于迭代器的访问和基于索引的迭代访问,但是基于迭代器的访问可以更快。

        // 迭代顺序取决于集合内节点的顺序;可以通过以下函数查询顺序:

        // enum xpath_node_set::type_t {type_unsorted, type_sorted, type_sorted_reverse};
        // type_t xpath_node_set::type() const;

        // type函数返回节点的当前顺序;type_sorted意味着节点按前向文档顺序排列,type_sorted_reverse表示节点处于反向文档顺序,并且type_unsorted意味着两种顺序都没有得到保证(节点可能意外地处于排序顺序,即使在以下情况下)type()回报type_unsorted)。如果需要特定的迭代顺序,则可以通过sort函数:

        // void xpath_node_set::sort(bool reverse = false);


        // 调用sort根据参数将节点按正向或反向文档顺序排序;在此调用之后type()会回来type_sorted或type_sorted_reverse.
        // 通常不需要实际的迭代;相反,只需要文档顺序中的第一个元素。为此,提供了一个特殊访问器:
        // xpath_node xpath_node_set::first() const;
        // 此函数从集合中返回第一个按前向文档顺序排列的节点,如果集合为空,则返回空节点。注意,虽然节点的结果不依赖于集合中节点的顺序(即type()),如果对集合进行排序,则复杂度是常数,否则它在元素数或更糟的数量上是线性的。

        // 虽然在大多数情况下,节点集由XPath函数返回,但有时需要手动构造节点集。对于这种情况,提供了一个构造函数,该构造函数采用迭代器范围(const_iterator是const xpath_node*),以及一个可选类型:

        // xpath_node_set::xpath_node_set(const_iterator begin, const_iterator end, type_t type = type_unsorted);
        // 构造函数复制指定的范围并设置指定的类型。没有以任何方式检查范围中的对象;您必须确保范围不包含重复项,并且必须按照type参数。否则,使用此集合的XPath操作可能会产生意外的结果。


        // select_nodes函数编译表达式,然后以节点作为上下文节点执行表达式,并返回结果节点集。select_node仅按文档顺序从结果返回第一个节点,并等效于调用select_nodes(query).first()。如果XPath表达式与任何内容不匹配,或者节点句柄为空,select_nodes返回一个空集,并且select_node返回空XPath节点。

        // 如果未禁用异常处理,则两个函数都会引发XPath异常如果无法编译查询,或者查询返回的值类型不是节点集,请参见错误处理关于细节。

        // 虽然编译表达式速度快,但如果在小子树上多次使用相同的表达式,则编译时间会带来很大的开销。如果您正在执行许多类似的查询,请考虑将它们编译成查询对象(请参见使用查询对象供进一步参考)。一旦获得已编译的查询对象,就可以将其传递给选择函数而不是表达式字符串:

        // pugi::xpath_node_set tools = doc.select_nodes("/Profile/Tools/Tool[@AllowRemote='true' and @DeriveCaptionFrom='lastparam']");
        // std::cout << "Tools:\n";
        // for (pugi::xpath_node_set::const_iterator it = tools.begin(); it != tools.end(); ++it)
        // {
        //    pugi::xpath_node node = *it;
        //    std::cout << node.node().attribute("Filename").value() << "\n";
        // }
        // pugi::xpath_node build_tool = doc.select_node("//Tool[contains(Description, 'build system')]");
        // if (build_tool)
        //    std::cout << "Build tool: " << build_tool.node().attribute("Filename").value() << "\n"

    }

    方法 路径_取节点集 <公开 类型 = pugi节点集 注释 = "这个用于查询一系列结果集"
            注释 = "\"/Profile/Tools/Tool[@AllowRemote=\'true\' and @DeriveCaptionFrom=\'lastparam\']\"" 折叠 @嵌入式方法 = "">
    参数 路径文本 <类型 = 文本型>
    {
        @ @dt<pugi节点集>( @sn<this>.data().select_nodes(@<路径文本>) )
    }

    # //我们常用的一般都是取路径的值，这里我封装了几个易用api来取路径值整数

    方法 路径_取整数 <公开 类型 = 整数 @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return _ttoi( xnode.node().text().as_string() );
        @  }else
        @  {
        @   return _ttoi( xnode.attribute().as_string() );
        @  }




    }

    方法 路径_取长整数 <公开 类型 = 长整数 @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return _ttoi64( xnode.node().text().as_string() );
        @  }else
        @  {
        @   return _ttoi64( xnode.attribute().as_string() );
        @  }

    }

    方法 路径_取文本 <公开 类型 = 文本型 注释 = "取节点的值，或者属性的值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        // @ DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER + @an<CVolString> (_T("是节点"))).GetText ());
        @   return @an<CVolString>( xnode.node().text().as_string() );
        @  }else
        @  {
        // @ DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER + @an<CVolString> (_T("是属性"))).GetText ());
        @   return @an<CVolString>( xnode.attribute().as_string() );
        @  }

    }

    方法 路径_取逻辑值 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型>
