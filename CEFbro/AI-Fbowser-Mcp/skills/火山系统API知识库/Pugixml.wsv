类 pugi节点 <公开 基础类 = xml_node @模板实现类 = "">
{

    # @begin
    # <> <include>
    # //复制构造
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    #
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return m_data == objCompare.m_data;
    # }
    # @sn<current_class>(pugi::xml_node& o)
    # {
    #     m_data = o;
    # }
    # pugi::xml_node& data()
    # {
    # //@ DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER + @an<CVolString> (m_data.text().as_string())).GetText ());
    #     return m_data;
    # }
    # pugi::xml_node m_data;
    # <> </include>
    # @end

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把节点保存成缓冲区" @禁止流程检查 = 真>
    参数 缩进 <类型 = 文本型 @默认值 = "\t">
    参数 格式 <类型 = xml格式 @默认值 = xml格式.标准格式>
    参数 编码 <类型 = xml编码 @默认值 = xml编码.utf8>
    {
        @ class CBuffer_Writer: public pugi::xml_writer
        @ {
        @ public: 
        @     virtual void write(const void* data, size_t size) 
        @     {
        @         buf.Append ((void*)data,(int)size);
        @     }
        @     @dt<字节集类>& data()
        @     {
        @         return buf;
        @     }
        @     @dt<字节集类> buf;
        @ };
        @ CBuffer_Writer bufWriter;
        @ data().print(bufWriter,@<缩进>,@<格式>,(pugi::xml_encoding)@<编码>);
        @ return bufWriter.data();

    }

    #

    方法 到文本 <公开 类型 = 文本型 注释 = "把节点保存成文本" @禁止流程检查 = 真>
    参数 缩进 <类型 = 文本型 @默认值 = "\t">
    参数 格式 <类型 = xml格式 @默认值 = xml格式.标准格式>
    参数 编码 <类型 = xml编码 @默认值 = xml编码.utf8>
    {
        返回 (UTF8到文本 (到字节集 (缩进, 格式, 编码)))




    }

    #
}

