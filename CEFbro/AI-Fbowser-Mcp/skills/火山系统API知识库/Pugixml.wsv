    {
        @ ( _ttoi64( @sn<this>.data().as_string() )+ @<默认值> ) 

    }

    #
    # //====
    #

    方法 置文本 <公开 @嵌入式方法 = "">
    参数 内容 <类型 = 文本型>
    {
        @ @sn<this>.data().set_value(@<内容>)
    }

    方法 置整数 <公开 @嵌入式方法 = "">
    参数 内容 <类型 = 整数>
