        @  }else
        @  {
        // @ DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER + @an<CVolString> (_T("有属性值"))).GetText ());
        @   return xnode.attribute().as_double();
        @  }

    }

    # //---
    # //这里主要弄的是路径置值

    方法 路径_置整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
