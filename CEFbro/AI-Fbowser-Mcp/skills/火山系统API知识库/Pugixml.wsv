    方法 加载测试
    {
        变量 "//编译" <类型 = 常用编译命令>
        变量 文档 <类型 = pugi文档>
        变量 "//xml数据" <类型 = 字节集类>
        变量 "//缓冲区" <类型 = 缓冲区类>
        变量 tree_xml <类型 = 视窗文件资源>
        变量 "//测试文本" <类型 = 文本型
                值 = "<!--   Copyright w3school.com.cn  -->\r\n<note>\r\n<to>George</to>\r\n<from>John</from>\r\n<heading>Reminder</heading>\r\n<body>Don\'t forget the meeting!</body>\r\n</note>">
        // 编译.展开宏并写入文件 ()

        // 调试输出 (取当前目录_f ())
        // 文档.从文本加载 (测试文本)




        // 文档.从资源加载 (tree_xml)
        文档.从文件加载 ("tree.xml")
        // 文档.从字节集加载 (xml数据)
        // 文档.从缓冲区加载 (缓冲区)

        调试输出f (文档.到文本 ("\t\t", xml格式.标准格式, xml编码.utf8))
        调试输出f (文档.到字节集 ("||"))


    }

    方法 节点遍历测试 <折叠>
    {
        变量 文档 <类型 = pugi文档>
        变量 "//缓冲区" <类型 = 缓冲区类>
        变量 xgconsole_xml <类型 = 视窗文件资源 值 = "xgconsole.xml">
        变量 tools <类型 = pugi节点>
        变量 子节点 <类型 = pugi节点>
        变量 属性 <类型 = pugi属性>
        文档.从资源加载 (xgconsole_xml)
        // 缓冲区 = 文档.到缓冲区 ()
        // 调试输出 (缓冲区.到十六进制文本 ())
        // 调试输出 (缓冲区.到文本_从U8 ())
        tools = 文档.取子节点 ("Profile").取子节点 ("Tools")
        tools.遍历子节点 (子节点)
        {
            子节点.遍历属性 (属性)
            {
                调试输出 (属性.取属性名 ())
                调试输出 (属性.取属性值_文本型 ())

            }
        }

        文档.遍历所有节点 (树遍历事件接收器)

    }

    方法 节点修改测试 <折叠>
    {
        变量 文档 <类型 = pugi文档>
        变量 节点 <类型 = pugi节点>
        变量 ""
        变量 临时文本 <类型 = 文本型>
        如果 (文档.从文本加载 ("<node id='123'>text</node><!-- comment -->") == 假)
        {
            返回
        }

        调试输出 ("------------------")
        // 修改节点名称
        节点 = 文档.取子节点 ("node")

        节点.置节点名称 ("notnode")
        调试输出 (节点.取元素节点名称 ())
        调试输出 ("------------------")
        临时文本 = 文档.取节点类型文本 ()
        调试输出 (临时文本)
        // 修改注释
        调试输出 ("------------------")
        // 注意,普通的 <element>text</element>是一个节点
        // text 也是一个节点,如果对 element 置节点值会失败,此时要取子节点 text这个所在的节点 来设置值才可以
        文档.取尾子节点 ().取首子节点 ().取元素节点值 ().置文本 ("useless comment")
        临时文本 = 文档.取尾子节点 ().取元素节点值 ().取文本 ()


        文档.取尾子节点 ().取元素节点值 ().置文本 (" 哈啊哈adsfasdfasdf ")
        临时文本 = 文档.取尾子节点 ().取元素节点值 ().取文本 ()
        调试输出 (临时文本)

        调试输出 ("------------------")
        临时文本 = 文档.到文本 ()
        调试输出 (临时文本)

        // 文档.保存到文件 ("test.xml")


        // std::cout << ", new comment text: " << doc.last_child().value() << std::endl;

        // // we can't change value of the element or name of the comment
        // std::cout << node.set_value("1") << ", " << doc.last_child().set_name("2") << std::endl;
        // // end::node[]

        // // tag::attr[]
        // pugi::xml_attribute attr = node.attribute("id");

        // // change attribute name/value
        // std::cout << attr.set_name("key") << ", " << attr.set_value("345");
        // std::cout << ", new attribute: " << attr.name() << "=" << attr.value() << std::endl;

        // // we can use numbers or booleans
        // attr.set_value(1.234);
        // std::cout << "new attribute value: " << attr.value() << std::endl;

        // // we can also use assignment operators for more concise code
        // attr = true;
        // std::cout << "final attribute value: " << attr.value() << std::endl;
        // // end::attr[]

    }

    方法 路径选择测试 <折叠>
    {
        变量 文档 <类型 = pugi文档>
        变量 xml <类型 = 文本型
                值 = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"no\" ?>\n<Profile FormatVersion=\"1\">\n    <Tools>\n        <Tool Filename=\"jam\" AllowIntercept=\"true\">\n        \t<Description>Jamplus build system</Description>\n        </Tool>\n        <Tool Filename=\"mayabatch.exe\" AllowRemote=\"true\" OutputFileMasks=\"*.dae\" DeriveCaptionFrom=\"lastparam\" Timeout=\"40\" />\n        <Tool Filename=\"meshbuilder_*.exe\" AllowRemote=\"false\" OutputFileMasks=\"*.mesh\" DeriveCaptionFrom=\"lastparam\" Timeout=\"10\" />\n        <Tool Filename=\"texbuilder_*.exe\" AllowRemote=\"true\" OutputFileMasks=\"*.tex\" DeriveCaptionFrom=\"lastparam\" />\n        <Tool Filename=\"shaderbuilder_*.exe\" AllowRemote=\"true\" DeriveCaptionFrom=\"lastparam\" />\n    </Tools>\n</Profile>">
        文档.从文本加载 (xml)
        调试输出 (文档.路径_取属性 ("/Profile/Tools/Tool/@Filename").取属性值_文本型 ())


        变量 节点集 <类型 = pugi节点集>
        节点集 = 文档.路径_取节点集 ("/Profile/Tools/Tool[@AllowRemote='true' and @DeriveCaptionFrom='lastparam']")
        调试输出 (节点集.取成员数 ())

        节点集.迭代循环 ()
        {
            调试输出 (节点集.取迭代节点 ().到文本 ())

        }




    }

    方法 pugi树遍历事件接收器_遍历事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = pugi树遍历事件接收器>
    参数 标记值 <类型 = 整数>
    参数 节点 <类型 = pugi节点>
    {
        调试输出 (来源对象.取深度 ())
        调试输出 (节点.取元素节点名称 ())
        调试输出 (节点.取元素节点值 ().取文本 ())

        返回 (1)
    }

