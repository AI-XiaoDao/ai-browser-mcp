    # <> </include>
    # @end

    方法 迭代循环 <公开 注释 = "您可以用迭代方式，" 注释 = "也可以用取成员方式" 注释 = "来遍历节点集内容，" 注释 = "通常迭代比较高效"
            @嵌入式方法 = "name = for_xpath_node_set\nhas_body = true">
    {
        @ for_xpath_node_set(@sn<this>.data())
    }

