类 pugi节点类型 <公开 折叠 @常量类 = 整数>
{
    常量 空 <公开 值 = 0 注释 = " (null)">
    常量 文档 <公开 值 = 1>
    常量 元素 <公开 值 = 2 注释 = "\'<node/>\'">
    常量 pcdata <公开 值 = 3 注释 = "\'text\'">
    常量 cdata <公开 值 = 4 注释 = "<![CDATA[text]]>\'">
    常量 注释 <公开 值 = 5 注释 = "<!-- text -->\'">
    常量 处理指令 <公开 值 = 6 注释 = "<?name?>\'">
    常量 声明 <公开 值 = 7 注释 = "\'<?xml version=\"1.0\"?>\'">
    常量 文档类型 <公开 值 = 8 注释 = "\'<!DOCTYPE doc>\'">

    #   node_null,   // Empty (null) node handle
    #   node_document,  // A document tree's absolute root
    #   node_element,  // Element tag, i.e. '<node/>'
    #   node_pcdata,  // Plain character data, i.e. 'text'
    #   node_cdata,   // Character data, i.e. '<![CDATA[text]]>'
    #   node_comment,  // Comment tag, i.e. '<!-- text -->'
    #   node_pi,   // Processing instruction, i.e. '<?name?>'
    #   node_declaration, // Document declaration, i.e. '<?xml version="1.0"?>'
    #   node_doctype  // Document type declaration, i.e. '<!DOCTYPE doc>'
    #
}

类 xml_node <公开 注释 = "节点基础模板" @模板基础类 = 真>
{

    #
    # xml_node xml_node::parent() const;
    # xml_node xml_node::first_child() const;
    # xml_node xml_node::last_child() const;
    # xml_node xml_node::next_sibling() const;
    # xml_node xml_node::previous_sibling() const;

    方法 取节点类型文本 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @ const TCHAR* node_types[] =
        @ {
        @ _T("null"), _T("document"), _T("element"), _T("pcdata"),_T( "cdata"), _T("comment"), _T("pi"), _T("declaration")
        @ };
        @ if (data().type() < sizeof (node_types))
        @    return @an<CVolString>(node_types[data().type()] );
        @ else
        @    return @an<CVolString>(_T("null"));

    }

    方法 取节点类型整数 <公开 折叠 @禁止流程检查 = 真>
    {
        @ data().type()

    }

    方法 取父节点 <公开 类型 = pugi节点 注释 = "函数返回节点的父节点；除文档外，所有非空节点都具有非空父节点" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.data().parent()
    }

    方法 取首子节点 <公开 类型 = pugi节点 折叠 @嵌入式方法 = "">
    {
        @ @dt<pugi节点>( @sn<this>.data().first_child())
    }

    方法 取尾子节点 <公开 类型 = pugi节点 折叠 @嵌入式方法 = "">
    {
        @ @dt<pugi节点>(@sn<this>.data().last_child())
    }

    方法 取第一个子节点 <公开 类型 = pugi节点 注释 = "和 取首子节点 一模一样" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.data().first_child()
    }

    方法 取最后一个子节点 <公开 类型 = pugi节点 注释 = "和 取尾子节点 一模一样" @嵌入式方法 = "">
    {
        @ @sn<this>.data().last_child()
    }

    方法 取下一个兄弟节点 <公开 类型 = pugi节点 @嵌入式方法 = "">
    {
        @ @dt<pugi节点>( @sn<this>.data().next_sibling() )
    }

    方法 取上一个兄弟节点 <公开 类型 = pugi节点 @嵌入式方法 = "">
    {
        @ @dt<pugi节点>( @sn<this>.data().previous_sibling() )
    }

    #   
    #   xml_node next_sibling(const char_t* name) const;
    #   xml_node previous_sibling(const char_t* name) const;
    #

    方法 取下一个兄弟节点_指定节点名 <公开 类型 = pugi节点 @嵌入式方法 = "">
    参数 节点名称 <类型 = 文本型>
    {
        @ @dt<pugi节点>( @sn<this>.data().next_sibling(@<节点名称>) )
    }

    方法 取上一个兄弟节点_指定节点名 <公开 类型 = pugi节点 注释 = "只能用做元素节点的操作" @嵌入式方法 = "">
    参数 节点名称 <类型 = 文本型>
    {
        @ @dt<pugi节点>( @sn<this>.data().previous_sibling(@<节点名称>) )
    }

    #
    #
    # @begin
    # <> <include>
    #  #define pugui_for(pugui_node_recv_data,this_member_data) \
    #  for (pugui_node_recv_data.data() = this_member_data.first_child(); pugui_node_recv_data.data(); pugui_node_recv_data.data() =  pugui_node_recv_data.data().next_sibling())
    # <> </include>
    # @end

    方法 遍历子节点 <公开 @嵌入式方法 = "name = pugi_node_for\nhas_body = true">
    参数 用来保存节点值 <类型 = pugi节点 注释 = "它是一个循环，循环一次则 赋值给 用来保存节点值">
    {
        @ pugui_for(@<用来保存节点值>,@sn<this>.data())

    }

    # @begin
    # <> <include>
    #  #define pugui_for_attribute(pugui_attribute_recv_data,this_node_data) \
    #  for (pugui_attribute_recv_data.data() = this_node_data.first_attribute(); pugui_attribute_recv_data.data(); pugui_attribute_recv_data.data() =  pugui_attribute_recv_data.data().next_attribute())
    # <> </include>
    # @end
    #

    方法 遍历属性 <公开 @嵌入式方法 = "name = pugi_attribute_for\nhas_body = true">
    参数 用来保存属性值 <类型 = pugi属性>
    {
        @ pugui_for_attribute(@<用来保存属性值>,@sn<this>.data())
    }

    方法 取子节点 <公开 类型 = pugi节点 @嵌入式方法 = "">
    参数 节点名称 <类型 = 文本型>
    {
        @ @dt<pugi节点>( @sn<this>.data().child(@<节点名称>))

    }

    方法 是否为空 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @  ((bool)@sn<this>.data())
    }

    方法 取子元素节点值_文本型 <公开 类型 = 文本型 @嵌入式方法 = "">
    参数 节点名称 <类型 = 文本型>
    {
        @ @an<CVolString>( @sn<this>.data().child_value(@<节点名称>) )
    }

    方法 取数据节点值 <公开 类型 = 文本型 注释 = "用于 cdata pcdata comment 等数据节点" @嵌入式方法 = "">
    {
        @ @an<CVolString>( @sn<this>.data().value() )

    }

    方法 置数据节点值 <公开 注释 = "用于 cdata pcdata comment 等数据节点" @嵌入式方法 = "">
    参数 节点值 <类型 = 文本型>
    {
        @ @sn<this>.data().set_value(@<节点值>)
    }

    方法 取元素节点值 <公开 类型 = pugi节点值 注释 = "只能" @嵌入式方法 = "">
    {
        @ @dt<pugi节点值>( @sn<this>.data().text())

    }

    方法 取元素节点名称 <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @ @an<CVolString>( @sn<this>.data().name() )

    }

    方法 取属性 <公开 类型 = pugi属性 @嵌入式方法 = "">
    参数 属性名称 <类型 = 文本型>
    {
        @ @dt<pugi属性>(@sn<this>.data().attribute(@<属性名称>) )

    }

    # xml_attribute attribute(const char_t* name) const;
    #
    # //  xml_attribute first_attribute() const;
    # //  xml_attribute last_attribute() const;

    方法 取属性_第一个 <公开 类型 = pugi属性 @嵌入式方法 = "">
    {
        @ @dt<pugi属性>( @sn<this>.data().first_attribute())
    }

    方法 取属性_最后一个 <公开 类型 = pugi属性 @嵌入式方法 = "">
    {
        @ @dt<pugi属性>( @sn<this>.data().last_attribute())
    }

    # //==节点修改方法===

    方法 置节点名称 <公开 @嵌入式方法 = "">
    参数 节点名称 <类型 = 文本型>
    {
        @ @sn<this>.data().set_name(@<节点名称>)
    }

    # // 节点属性增加
    # // xml_attribute xml_node::append_attribute(const char_t* name);
    # // xml_attribute xml_node::prepend_attribute(const char_t* name);
    # // xml_attribute xml_node::insert_attribute_after(const char_t* name, const xml_attribute& attr);
    # // xml_attribute xml_node::insert_attribute_before(const char_t* name, const xml_attribute& attr);
    #

    方法 加入属性名_到末尾 <公开 类型 = pugi属性 注释 = "返回新加入的属性节点" 折叠 @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型>
    {
        @ @dt<pugi属性>( @sn<this>.data().append_attribute(@<属性名>) )
    }

    方法 加入属性名_到头部 <公开 类型 = pugi属性 注释 = "返回新加入的属性节点" 折叠 @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型>
    {
        @ @dt<pugi属性>( @sn<this>.data().prepend_attribute(@<属性名>))

    }

    方法 加入属性_指定属性之前 <公开 类型 = pugi属性 折叠 @嵌入式方法 = "">
    参数 指定的属性名 <类型 = 文本型>
    参数 属性值 <类型 = pugi属性>
    {
        @ @dt<pugi属性>( @sn<this>.data().insert_attribute_before(@<指定的属性名> ,@<属性值>.data()) )
    }

    方法 加入属性_指定属性之后 <公开 类型 = pugi属性 折叠 @嵌入式方法 = "">
    参数 指定的属性名 <类型 = 文本型>
    参数 属性值 <类型 = pugi属性>
    {
        @ @dt<pugi属性>( @sn<this>.data().insert_attribute_before(@<指定的属性名>,@<属性值>.data()) )
    }

    # 增加子节点
    # xml_node xml_node::append_child(xml_node_type type = node_element);
    # xml_node xml_node::prepend_child(xml_node_type type = node_element);
    # xml_node xml_node::insert_child_after(xml_node_type type, const xml_node& node);
    # xml_node xml_node::insert_child_before(xml_node_type type, const xml_node& node);

    方法 加入子节点_到尾部_类型 <公开 类型 = pugi节点 注释 = "可以加入 注释节点 元素节点 等等" @嵌入式方法 = "">
    参数 节点类型 <类型 = pugi节点类型 注释 = "默认增加一个元素节点" @默认值 = pugi节点类型.元素>
    {
        @ @dt<pugi节点>( @sn<this>.data().append_child((pugi::xml_node_type)@<节点类型>))
    }

    方法 加入子节点_到首部_类型 <公开 类型 = pugi节点 注释 = "可以加入 注释节点 元素节点 等等" @嵌入式方法 = "">
    参数 节点类型 <类型 = pugi节点类型 注释 = "默认增加一个元素节点" @默认值 = pugi节点类型.元素>
    {
        @ @dt<pugi节点>( @sn<this>.data().prepend_child((pugi::xml_node_type)@<节点类型>))
    }

    方法 加入子节点_指定位置之前_类型 <公开 类型 = pugi节点 注释 = "可以加入 注释节点 元素节点 等等 返回新增加的节点" @嵌入式方法 = "">
    参数 新节点类型 <类型 = pugi节点类型 注释 = "默认增加一个元素节点" @默认值 = pugi节点类型.元素>
    参数 指定的节点 <类型 = pugi节点>
    {
        @ @dt<pugi节点>( @sn<this>.data().insert_child_before(@<新节点类型>),@<指定的节点>.data())
    }

    方法 加入子节点_指定位置之后_类型 <公开 类型 = pugi节点 注释 = "可以加入 注释节点 元素节点 等等 返回新增加的节点" @嵌入式方法 = "">
