    参数 要删除的属性名称 <类型 = 文本型>
    {
        @ @sn<this>.data().remove_child(@<要删除的属性名称>)

    }

    #
}

类 xml格式 <公开 折叠 @常量类 = 整数>
{
    常量 标准格式 <公开 值 = 0x01
            注释 = " // Indent the nodes that are written to output stream with as many indentation strings as deep the node is in DOM tree. This flag is on by default.">
    常量 写入bom头 <公开 值 = 0x02 注释 = " // Write encoding-specific BOM to the output stream. This flag is off by default.">
    常量 原始格式 <公开 值 = 0x04
            注释 = "// Use raw output mode (no indentation and no line breaks are written). This flag is off by default.">
    常量 不保存声明 <公开 值 = 0x08
            注释 = " // Omit default XML declaration even if there is no declaration in the document. This flag is off by default.">
    常量 没有空格 <公开 值 = 0x10 注释 = " // Don\'t escape attribute values and PCDATA contents. This flag is off by default.">
    常量 文本格式 <公开 值 = 0x20
            注释 = " // Open file using text mode in xml_document::save_file. This enables special character (i.e. new-line) conversions on some systems. This flag is off by default.">
    常量 标准属性 <公开 值 = 0x40
            注释 = " // Write every attribute on a new line with appropriate indentation. This flag is off by default.">
    常量 不保存空元素标签 <公开 值 = 0x80
            注释 = "// Don\'t output empty element tags, instead writing an explicit start and end tag even if there are no children. This flag is off by default.">
    常量 忽略控制字符 <公开 值 = 0x100
            注释 = " // Skip characters belonging to range [0; 32) instead of \"&#xNN;\" encoding. This flag is off by default.">
    常量 属性单引号 <公开 值 = 0x200
            注释 = " // Use single quotes \' instead of double quotes \" for enclosing attribute values. This flag is off by default.">

    #
}

类 xml编码 <公开 折叠 @常量类 = 整数>
{
    常量 自动 <公开 值 = 0 注释 = "// Auto-detect input encoding using BOM or < / <? detection; use UTF8 if BOM is not found">
    常量 utf8 <公开 值 = 1 注释 = "// UTF8 encoding">
    常量 utf16_le <公开 值 = 2 注释 = "// Little-endian UTF16">
    常量 utf16_be <公开 值 = 3 注释 = "// Big-endian UTF16">
    常量 utf16 <公开 值 = 4 注释 = " // UTF16 with native endianness">
    常量 utf32_le <公开 值 = 5 注释 = "// Little-endian UTF32">
    常量 utf32_be <公开 值 = 6 注释 = "// Big-endian UTF32">
    常量 utf32 <公开 值 = 7 注释 = "// UTF32 with native endianness">
    常量 wchar <公开 值 = 8 注释 = "// The same encoding wchar_t has (either UTF16 or UTF32)">
    常量 latin1 <公开 值 = 9>

    #
}

类 pugi文档 <公开 基础类 = xml_node @模板实现类 = "" @视窗.预定义宏 = "PUGIXML_WCHAR_MODE"
        @视窗.外部头文件 = "pugixml\\pugixml-1.10\\src\\pugixml.hpp" @视窗.外部源文件 = "pugixml\\pugixml-1.10\\src\\pugixml.cpp">
{

    # @begin
    # <> <include>
    #
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     @ DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER + @an<CVolString> (_T("pugui文档 类不支持 = 或者复制构造函数"))).GetText ());
    #     //m_data = objCopyFrom.m_data;
    # }
    #
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return m_data == objCompare.m_data;
    # }
    #
    # pugi::xml_document& data()
    # {
    #     return m_data;
    # }
    #
    # pugi::xml_document m_data;
    # <> </include>
    #

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把节点保存成缓冲区" 折叠 @禁止流程检查 = 真>
    参数 缩进 <类型 = 文本型 @默认值 = "\t">
    参数 格式 <类型 = xml格式 @默认值 = xml格式.标准格式>
    参数 编码 <类型 = xml编码 @默认值 = xml编码.utf8>
    {
        @ class CBuffer_Writer: public pugi::xml_writer
        @ {
        @ public: 
        @     virtual void write(const void* data, size_t size) 
        @     {
        @         buf.Append ((void*)data,(int)size);
        @     }
        @     @dt<字节集类>& data()
        @     {
        @         return buf;
        @     }
        @     @dt<字节集类> buf;
        @ };
        @ CBuffer_Writer bufWriter;
        @ data().save(bufWriter,@<缩进>,@<格式>,(pugi::xml_encoding)@<编码>);
        @ return bufWriter.data();

    }

    #

    方法 从资源加载 <公开 类型 = 逻辑型>
    参数 资源名称 <类型 = 视窗文件资源>
    {
        变量 数据 <类型 = 字节集类>
        数据 = 资源_取文件 (资源名称)
        返回 (从字节集加载 (数据))
    }

    方法 从文件加载 <公开 类型 = 逻辑型>
    参数 文件名称 <类型 = 文本型>
    {
        //  xml_parse_result load_file(const char* path, unsigned int options = parse_default, xml_encoding encoding = encoding_auto);
        //  xml_parse_result load_file(const wchar_t* path, unsigned int options = parse_default, xml_encoding encoding = encoding_auto);
        @ pugi::xml_parse_result result = data().load_file(@<文件名称>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER  + (@an<CVolString> (@<文件名称>))+@an<CVolString> ("  ") + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)
    }

    方法 从文本加载 <公开 类型 = 逻辑型>
    参数 文件内容 <类型 = 文本型>
    {
        // xml_parse_result xml_document::load_string(const char_t* contents, unsigned int options = parse_default);
        @ pugi::xml_parse_result result = data().load_string((const wchar_t*)@<文件内容>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER +@an<CVolString>(_T("pugi文档从 文本加载  ")) + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)

    }

    方法 从内存加载 <公开 类型 = 逻辑型 折叠>
    参数 内存指针 <类型 = 变整数>
