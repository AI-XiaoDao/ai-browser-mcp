    {
        @ return @<从内存加载>((@dt<变整数>)@<字节集数据>.GetPtr(),@<字节集数据>.GetSize());
    }

    方法 到文本 <公开 类型 = 文本型>
    参数 缩进格式 <类型 = 文本型 @默认值 = "\t">
