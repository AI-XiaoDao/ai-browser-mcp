        @ @an<CVolString>( @sn<this>.data().as_string(@<默认值>) )
    }

    方法 取逻辑型 <公开 折叠 @嵌入式方法 = "">
    参数 默认值 <类型 = 逻辑型 注释 = "如果没有属性，那么将返回这个默认值" @默认值 = 假>
    {
