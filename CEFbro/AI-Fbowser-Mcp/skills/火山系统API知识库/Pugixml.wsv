    {
        // xml_parse_result xml_document::load_string(const char_t* contents, unsigned int options = parse_default);
        @ pugi::xml_parse_result result = data().load_buffer((void*)@<内存指针>,@<内存数据大小>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER  + @an<CVolString>(_T("pugi文档从从内存加载  ")) + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)

    }

