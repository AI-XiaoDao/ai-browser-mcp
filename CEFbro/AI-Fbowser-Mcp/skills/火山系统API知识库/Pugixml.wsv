        @ @sn<this>.data().as_int(@<默认值>)
    }

    方法 取属性值_小数型 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 默认值 <类型 = 小数 注释 = "如果没有属性，那么将返回这个默认值" @默认值 = 0>
