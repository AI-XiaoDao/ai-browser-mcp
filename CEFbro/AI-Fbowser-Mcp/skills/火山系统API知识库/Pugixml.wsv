类 __pugi测试类 <公开>
{
    变量 树遍历事件接收器 <类型 = pugi树遍历事件接收器>

    方法 开始测试 <公开>
    {
        // 节点遍历测试 ()
        // 节点修改测试 ()
        // 路径选择测试 ()
        路径取值测试 ()
        // pugi简易类测试 ()
        // 加载测试 ()


    }

    方法 pugi简易类测试 <折叠>
    {
        变量 xml <类型 = pugixml简易类>
        变量 测试文档 <类型 = 文本型
                值 = "<?xml version=\"1.0\"?>\n<Nodes>\n <node1 长整数测试=\"9223372036854774807\" 整数测试=\"2147483647\" 小数测试=\"1.77\" 一个属性=\"我是 加入属性_指定属性之前 的属性\" 文本测试=\"aa大\" 逻辑测试=\"1\" />\n <node1 />\n <node2 param=\"1\" />\n <node2 param=\"1\" />\n <node2 param=\"1\" />\n <node3 param1=\"1\" param2=\"2\" param3=\"3\" />\n <node4>1.71</node4>\n <node5>2147483647</node5>\n <node6>aa大</node6>\n <node7>9223372036854774807</node7><![CDATA[你实在欺骗我的感情？]]>pcdata节点值<!--我是注释-->\n <?:anonymous 我是指令?>\n</Nodes>\n<!DOCTYPE doc>">
        变量 ""
        xml.从文本载入 (测试文档)

        // 属性测试
        xml.置整数 ("/Nodes/node2/@param", 2147483647)
        如果 (xml.取整数 ("/Nodes/node2/@param") != 2147483647)
        {
            调试输出 ("测试置整数失败")

        }

        xml.置长整数 ("/Nodes/node2/@param", 9223372036854774807)
        如果 (xml.取长整数 ("/Nodes/node2/@param") != 9223372036854774807)
        {
            调试输出 ("测试置长整数失败")

        }

        xml.置逻辑型 ("/Nodes/node2/@param", 真)
        如果 (xml.取逻辑型 ("/Nodes/node2/@param") != 真)
        {
            调试输出 ("测试置逻辑值失败")

        }

        xml.置小数 ("/Nodes/node2/@param", 1.77)
        如果 (xml.取小数 ("/Nodes/node2/@param") != 1.77)
        {
            调试输出 ("测试置小数值失败")

        }

        xml.置文本 ("/Nodes/node2/@param", "aA大色")
        如果 (xml.取文本 ("/Nodes/node2/@param") != "aA大色")
        {
            调试输出 ("测试置文本失败")

        }

        // 节点值测试
        xml.置整数 ("/Nodes/node2", 2147483647)
        如果 (xml.取整数 ("/Nodes/node2") != 2147483647)
        {
            调试输出 ("测试置节点整数失败")

        }

        xml.置长整数 ("/Nodes/node2", 9223372036854774807)
        如果 (xml.取长整数 ("/Nodes/node2") != 9223372036854774807)
        {
            调试输出 ("测试置节点长整数失败")

        }

        xml.置逻辑型 ("/Nodes/node2", 真)
        如果 (xml.取逻辑型 ("/Nodes/node2") != 真)
        {
            调试输出 ("测试置节点逻辑值失败")

        }

        xml.置小数 ("/Nodes/node2", 1.77)
        如果 (xml.取小数 ("/Nodes/node2") != 1.77)
        {
            调试输出 ("测试置节点小数值失败")

        }

        xml.置文本 ("/Nodes/node2", "aA大色")
        如果 (xml.取文本 ("/Nodes/node2") != "aA大色")
        {
            调试输出 ("测试置节点文本失败")
        }

        调试输出 (xml.到文本 ())


    }

    #

    方法 路径取值测试
    {
        变量 文档 <类型 = pugi文档>
        变量 根节点 <类型 = pugi节点>
        变量 子节点 <类型 = pugi节点>
        变量 "//属性" <类型 = pugi属性>
        变量 文本属性 <类型 = pugi属性>
        根节点 = 文档.加入子元素节点_到尾部_名称 ("Nodes")

        子节点 = 根节点.加入子元素节点_到尾部_名称 ("node1")
        子节点.加入属性名_到末尾 ("整数测试").置整数 (2147483647)
        子节点.加入属性名_到末尾 ("小数测试").置小数 (1.77)
        文本属性 = 子节点.加入属性名_到末尾 ("文本测试")
        文本属性.置文本 ("aa大")

        子节点.加入属性名_到末尾 ("逻辑测试").置逻辑型 (真)
        子节点.加入属性名_到头部 ("长整数测试").置长整数 (9223372036854774807)

        子节点.加入属性_指定属性之前 ("一个属性", 文本属性).置文本 ("我是 加入属性_指定属性之前 的属性")

        根节点.加入子元素节点_到尾部_名称 ("node1")
        根节点.加入子元素节点_到尾部_名称 ("node2").加入属性名_到末尾 ("param").置文本 ("1")
        根节点.加入子元素节点_到尾部_名称 ("node2").加入属性名_到末尾 ("param").置文本 ("1")
        根节点.加入子元素节点_到尾部_名称 ("node2").加入属性名_到末尾 ("param").置文本 ("1")
        子节点 = 根节点.加入子元素节点_到尾部_名称 ("node3")
        子节点.加入属性名_到末尾 ("param1").置文本 ("1")
        子节点.加入属性名_到末尾 ("param2").置文本 ("2")
        子节点.加入属性名_到末尾 ("param3").置文本 ("3")
        根节点.加入子元素节点_到尾部_名称 ("node4").取元素节点值 ().置小数 (1.71)
        根节点.加入子元素节点_到尾部_名称 ("node5").取元素节点值 ().置整数 (2147483647)
        根节点.加入子元素节点_到尾部_名称 ("node6").取元素节点值 ().置文本 ("aa大")
        根节点.加入子元素节点_到尾部_名称 ("node7").取元素节点值 ().置长整数 (9223372036854774807)

        变量 附加数据节点 <类型 = pugi节点>
        调试输出 ("----- 附加数据节点 取值 置值 测试")
        附加数据节点 = 根节点.加入子节点_到尾部_类型 (pugi节点类型.cdata)
        附加数据节点.置数据节点值 ("cdata节点值")
        如果 (附加数据节点.取数据节点值 () != "cdata节点值")
        {
            调试输出 ("置数据节点值 取数据节点值 cdata节点值 测试未通过")
            调试输出 (附加数据节点.取数据节点值 ())
        }



        附加数据节点 = 根节点.加入子节点_到尾部_类型 (pugi节点类型.pcdata)
        附加数据节点.置数据节点值 ("pcdata节点值")
        如果 (附加数据节点.取数据节点值 () != "pcdata节点值")
        {
            调试输出 ("置数据节点值 取数据节点值 pcdata节点值  测试未通过")
            调试输出 (附加数据节点.取数据节点值 ())

        }



        附加数据节点 = 根节点.加入子节点_到尾部_类型 (pugi节点类型.声明)
        附加数据节点.置数据节点值 ("我是声明")

        附加数据节点 = 根节点.加入子节点_到尾部_类型 (pugi节点类型.注释)
        附加数据节点.置数据节点值 ("我是注释")

        附加数据节点 = 根节点.加入子节点_到尾部_类型 (pugi节点类型.处理指令)
        附加数据节点.置数据节点值 ("我是指令")

        附加数据节点 = 文档.加入子节点_到尾部_类型 (pugi节点类型.文档类型)
        附加数据节点.置数据节点值 ("doc")



        调试输出 (根节点.取元素节点值 ().取文本 ())  // 取出来的是  "cdata节点值"


        根节点.取元素节点值 ().置文本 ("你实在欺骗我的感情？")
        调试输出 (根节点.取元素节点值 ().取文本 ())  // 取出来的是  "你实在欺骗我的感情"

        调试输出 ("----取单个路径值测试")
        // 调试输出 (文档.路径_取长整数 ("/Nodes/node1/@长整数测试"))
        // 9223372036854774784
        // 9223372036854774807
        // 调试输出 (文档.路径_取整数 ("/Nodes/node1/@整数测试"))

        如果 (文档.路径_取长整数 ("/Nodes/node1/@长整数测试") != 9223372036854774807)
        {
            调试输出 ("路径_取长整数 测试失败")
        }
        如果 (文档.路径_取整数 ("/Nodes/node1/@整数测试") != 2147483647)
        {
            调试输出 ("路径_取整数 测试失败")
        }
        如果 (文档.路径_取小数 ("/Nodes/node1/@小数测试") != 1.77)
        {
            调试输出 ("小数测试 测试失败")
        }
        如果 (文档.路径_取逻辑值 ("/Nodes/node1/@逻辑测试") != 真)
        {
            调试输出 ("路径_取逻辑值 测试失败")
        }
        如果 (文档.路径_取文本 ("/Nodes/node1/@文本测试") != "aa大")
        {
            调试输出 ("路径_取文本 测试失败")
        }




        调试输出 ("--------------------利用属性自带函数进行遍历属性")

        变量 测试节点 <类型 = pugi节点>
        变量 最后一个属性 <类型 = pugi属性>
        变量 当前属性 <类型 = pugi属性>
        调试输出 (文档.取子节点 ("Nodes").取子节点 ("node1").到文本 ())



        调试输出 ("--------------------")
        测试节点 = 文档.取子节点 ("Nodes").取子节点 ("node1")
        当前属性 = 测试节点.取属性_第一个 ()
        最后一个属性 = 测试节点.取属性_最后一个 ()
        判断循环 (真)
        {

            如果 (当前属性.对象内容是否相同 (最后一个属性))
            {
                跳出循环
            }

            调试输出 (当前属性.取属性名 () + " - " + 当前属性.取属性值_文本型 ())

            当前属性 = 当前属性.取下一个兄弟属性 ()

        }



        调试输出 ("------ 开始测试属性取值函数 --------------")
        如果 (测试节点.取属性 ("长整数测试").取属性值_长整数 () != 9223372036854774807)
        {
            调试输出 ("路径_取长整数 测试失败")
        }
        如果 (测试节点.取属性 ("整数测试").取属性值_整数型 () != 2147483647)
        {
            调试输出 ("路径_取整数 测试失败")
        }
        如果 (测试节点.取属性 ("小数测试").取属性值_小数型 () != 1.77)
        {
            调试输出 ("小数测试 测试失败")
        }
        如果 (测试节点.取属性 ("逻辑测试").取属性值_逻辑型 () != 真)
        {
            调试输出 ("路径_取逻辑值 测试失败")
        }
        如果 (测试节点.取属性 ("文本测试").取属性值_文本型 () != "aa大")
        {
            调试输出 ("路径_取文本 测试失败")
        }
        调试输出 ("------ 结束测试属性取值函数 --------------")



        变量 节点 <类型 = pugi节点>
        变量 子节点A <类型 = pugi节点>
        变量 子节点A属性 <类型 = pugi属性>
        调试输出 ("---------节点遍历测试--------")
        节点 = 文档.路径_取节点 ("/Nodes")
        节点.遍历子节点 (子节点A)
        {
            调试输出 ("-->节点文本")
            调试输出 (子节点A.到文本 ())
            调试输出 ("-->节点属性")
            子节点A.遍历属性 (子节点A属性)
            {
                调试输出 (子节点A属性.取属性名 () + " - " + 子节点A属性.取属性值_文本型 ())

            }
        }

        变量 节点集 <类型 = pugi节点集>
        变量 节点集节点 <类型 = pugi节点>
        变量 节点集属性 <类型 = pugi属性>
        变量 ""
        调试输出 ("---------节点集遍历测试--------")
        调试输出 ("    节点集 节点合集遍历")
        节点集 = 文档.路径_取节点集 ("/Nodes/node2")
        节点集.迭代循环 ()
        {
            调试输出 ("-->节点文本")
            节点集节点 = 节点集.取迭代节点 ()
            调试输出 (节点集节点.到文本 ())
            调试输出 ("-->节点属性 子属性遍历")
            节点集节点.遍历属性 (节点集属性)
            {

                调试输出 (节点集属性.取属性名 () + " - " + 节点集属性.取属性值_文本型 ())

            }
        }


        调试输出 ("---------文档到文本测试--------")
        调试输出 (文档.到文本 ())






    }

