<火山程序 类型 = "通常" 版本 = 1 />

包 火山.音频处理 <注释 = "https://www.surina.net/soundtouch/soundstretch.html" 注释 = "https://codeberg.org/soundtouch/soundtouch"
        注释 = "封装自开源库soundtouch 2.3.2" 注释 = "" 编辑时信息 = "116A99, 0, 0, 0" @视窗.头文件搜寻目录 = "include"
        @视窗.外部头文件 = "include\\BPMDetect.h\ninclude\\FIFOSampleBuffer.h\ninclude\\FIFOSamplePipe.h\ninclude\\SoundTouch.h\ninclude\\soundtouch_config.h\ninclude\\STTypes.h\ninclude\\WavFile.h"
        @视窗.外部源文件 = "src\\AAFilter.cpp\nsrc\\BPMDetect.cpp\nsrc\\cpu_detect_x86.cpp\nsrc\\FIFOSampleBuffer.cpp\nsrc\\FIRFilter.cpp\nsrc\\InterpolateCubic.cpp\nsrc\\InterpolateLinear.cpp\nsrc\\InterpolateShannon.cpp\nsrc\\mmx_optimized.cpp\nsrc\\PeakFinder.cpp\nsrc\\RateTransposer.cpp\nsrc\\SoundTouch.cpp\nsrc\\sse_optimized.cpp\nsrc\\TDStretch.cpp\nsrc\\WavFile.cpp"
        @视窗.外部头文件 = "<memory>">

类 音频处理类 <公开 注释 = "本类提供音频处理功能.">
{

    # -----版本

    方法 取版本号2 <公开 静态 类型 = 文本型 注释 = "返回SoundTouch库的文本型版本号." @嵌入式方法 = "">
    {
        @ CVolString(soundtouch::SoundTouch::getVersionString())
    }

    方法 取版本号 <公开 静态 类型 = 整数 注释 = "返回SoundTouch库的版本号." @嵌入式方法 = "">
    {
        @ soundtouch::SoundTouch::getVersionId()
    }

    # -----参数设置

    方法 置速率 <公开 注释 = "设置新的速率控制值." @嵌入式方法 = "">
    参数 所欲设置的新速率 <类型 = 小数 注释 = "正常速率=1,小于1变慢,大于1变快.">
    {
        @ @sn<this>.data()->setRate(@<所欲设置的新速率>)
    }

    方法 置节拍 <公开 注释 = "设置新的节拍控制值." @嵌入式方法 = "">
    参数 所欲设置的新节拍 <类型 = 小数 注释 = "正常节拍=1.0,小于1变慢,大于1变快.">
    {
        @ @sn<this>.data()->setTempo(@<所欲设置的新节拍>)
    }

    方法 置速率百分比 <公开 注释 = "设置新的速率百分比值." @嵌入式方法 = "">
    参数 所欲设置的新速率 <类型 = 小数 注释 = "值为(-50 .. +100 %)之间.">
    {
        @ @sn<this>.data()->setRateChange(@<所欲设置的新速率>)
    }

    方法 置节拍百分比 <公开 注释 = "设置新的节拍百分比值." @嵌入式方法 = "">
    参数 所欲设置的新节拍 <类型 = 小数 注释 = "值为(-50 .. +100 %)之间.">
    {
        @ @sn<this>.data()->setTempoChange(@<所欲设置的新节拍>)
    }

    方法 置音调 <公开 注释 = "设置新的音调." @嵌入式方法 = "">
    参数 所欲设置的新音调 <类型 = 小数 注释 = "正常音调=1.0,小于1音调变低,大于1音调变高.">
    {
        @ @sn<this>.data()->setPitch(@<所欲设置的新音调>)
    }

    方法 置音调2 <公开 注释 = "在原音调基础上以八度音为单位进行调整." @嵌入式方法 = "">
    参数 所欲设置的新音调 <类型 = 小数 注释 = "值为-1.00到1.00之间.">
    {
        @ @sn<this>.data()->setPitchOctaves(@<所欲设置的新音调>)
    }

    方法 置音调3 <公开 注释 = "在原音调基础上以半音为单位进行调整." @嵌入式方法 = "">
    参数 所欲设置的新音调 <类型 = 整数 注释 = "值为-12到12之间.">
    {
        @ @sn<this>.data()->setPitchSemiTones(@<所欲设置的新音调>)
    }

    方法 置通道数 <公开 注释 = "设置音频数据的通道数." @嵌入式方法 = "">
    参数 所欲设置的通道数 <类型 = 整数 注释 = "1=单声道,2=立体声.">
    {
        @ @sn<this>.data()->setChannels(@<所欲设置的通道数>)
    }

    方法 置采样率 <公开 注释 = "设置采样率." @嵌入式方法 = "">
    参数 所欲设置的采样率 <类型 = 整数>
    {
        @ @sn<this>.data()->setSampleRate(@<所欲设置的采样率>)
    }

    方法 置控制属性 <公开 类型 = 逻辑型 注释 = "更改控制处理系统的行为设置." @嵌入式方法 = "">
    参数 所欲设置的属性类型 <类型 = 音频控制类型>
    参数 所欲设置的属性值 <类型 = 整数>
    {
        @ @sn<this>.data()->setSetting((int)@<所欲设置的属性类型>,@<所欲设置的属性值>)
    }

    # -----数据读取

    方法 取未处理样本数 <公开 类型 = 整数 注释 = "返回当前未处理的样本数." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->numUnprocessedSamples()
    }

    方法 取控制属性 <公开 类型 = 整数 注释 = "更改控制处理系统的行为设置." @嵌入式方法 = "">
    参数 所欲获取的属性类型 <类型 = 音频控制类型>
    {
        @ @sn<this>.data()->getSetting((int)@<所欲获取的属性类型>)
    }

    方法 取通道数 <公开 类型 = 整数 注释 = "返回音频数据的通道数." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->numChannels()
    }

    方法 取输入输出采样率比率 <公开 类型 = 小数 注释 = "获取输入和输出音频持续时间之间的比率,用于计算处理输出持续时间.如果您要处理N个样本流,可以预料得到(N*取输入输出采样率比率())个样本."
            注释 = "假设整个音轨是用相同的处理参数处理的,该比率将给出完整音轨的精确目标持续时间比率."
            注释 = "如果将此比率应用于计算处理内部的中间偏移流,那么这个比率是近似的,可以从理想的偏移偏离正负几十毫秒,但到音频流结束时,持续时间比率将变为准确." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getInputOutputSampleRatio()
    }

    # -----方法

    方法 刷新 <公开 注释 = "将最后一个样本从管道刷新到输出并清除内部缓冲区." 注释 = "注意：此函数用于提取声音的最后样本流.该功能最终可能会引入额外的空白样本因此不建议在声音流的中间调用此函数." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->flush()
    }

    方法 输入样本32 <公开 注释 = "将音频样本数据输入到采样处理缓冲区中." 注释 = "注意:调用本方法之前需要先设置采样率,否则将引发运行时异常." 注释 = "注意:本方法使用32位浮点采样类型." @嵌入式方法 = "">
    参数 所欲提供的样本输入缓冲区 <类型 = 变整数 注释 = "提供样本数据的输入缓冲区内存地址." 注释 = "注意:内存指针类型为单精度小数,即(float*).">
    参数 所欲提供的样本数 <类型 = 整数 注释 = "注意:在立体声的情况下,单个样本包含两个通道的数据.">
    {
        @ @sn<this>.data()->putSamples((soundtouch::SAMPLETYPE*)@<所欲提供的样本输入缓冲区>,@<所欲提供的样本数>)
    }

    方法 输入样本16 <公开 注释 = "将音频样本数据输入到采样处理缓冲区中." 注释 = "注意:调用本方法之前需要先设置采样率,否则将引发运行时异常." 注释 = "注意:本方法使用16位整数采样类型." @嵌入式方法 = "">
    参数 所欲提供的样本输入缓冲区 <类型 = 变整数 注释 = "提供样本数据的输入缓冲区内存地址." 注释 = "注意:内存指针类型为短整数,即(short*).">
    参数 所欲提供的样本数 <类型 = 整数 注释 = "注意:在立体声的情况下,单个样本包含两个通道的数据.">
    {
        @ @sn<this>.soundtouch_putSamples_i16((const short *)@<所欲提供的样本输入缓冲区>,@<所欲提供的样本数>)
    }

    方法 输出样本32 <公开 类型 = 整数 注释 = "从样本缓冲区的开头输出采样,将输入的样本复制到样本输出缓冲区,并将它们从采样缓冲区中删除." 注释 = "如果少于缓冲区中的样本数,返回所有可获取的样本."
            注释 = "注意:本方法使用32位浮点采样类型." 返回值注释 = "返回输出的样本数." @嵌入式方法 = "">
    参数 所欲提供的样本输出缓冲区 <类型 = 变整数 注释 = "提供样本数据的输出缓冲区内存地址." 注释 = "注意:内存指针类型为单精度小数,即(float*).">
    参数 最大接收样本数 <类型 = 整数 注释 = "输出缓冲区最大可接收的样本数.">
    {
        @ @sn<this>.data()->receiveSamples((soundtouch::SAMPLETYPE*)@<所欲提供的样本输出缓冲区>,@<最大接收样本数>)
    }

    方法 输出样本16 <公开 类型 = 整数 注释 = "从样本缓冲区的开头输出采样,将输入的样本复制到样本输出缓冲区,并将它们从采样缓冲区中删除." 注释 = "如果少于缓冲区中的样本数,返回所有可获取的样本."
            注释 = "注意:本方法使用16位浮点采样类型." 返回值注释 = "返回输出的样本数." @嵌入式方法 = "">
    参数 所欲提供的样本输出缓冲区 <类型 = 变整数 注释 = "提供样本数据的输出缓冲区内存地址." 注释 = "注意:内存指针类型为短整数,即(short*).">
    参数 最大接收样本数 <类型 = 整数 注释 = "输出缓冲区最大可接收的样本数.">
    {
        @ @sn<this>.soundtouch_receiveSamples_i16((short*)@<所欲提供的样本输出缓冲区>,@<最大接收样本数>)
    }

    方法 删除样本 <公开 类型 = 整数 注释 = "从样本缓冲区的开头删除指定数量的样本,而不将其复制到任何位置." 注释 = "用于在直接访问样本缓冲区时减少缓冲区中的样本数量." 返回值注释 = "返回输出样本数." @嵌入式方法 = "">
    参数 所欲删除的样本数 <类型 = 整数 注释 = "从样本缓冲区的开头删除的样本数.">
    {
        @ @sn<this>.data()->receiveSamples(@<所欲删除的样本数>)
    }

    方法 清空 <公开 注释 = "清空所有样本缓冲区." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->clear()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回是否有任何可用于输出的样本." @嵌入式方法 = "">
    {
        @ (@sn<this>.data()->isEmpty()!=0)
    }

    方法 置样本数 <公开 类型 = 整数 注释 = "设置管道中的样本数量." 返回值注释 = "返回修改后的样本数." @嵌入式方法 = "">
    参数 所欲设置的样本数 <类型 = 整数>
    {
        @ @sn<this>.data()->adjustAmountOfSamples(@<所欲设置的样本数>)
    }

    方法 移动样本 <公开 注释 = "将其他\"音频处理类\"中的样本数据移动到当前实例." @嵌入式方法 = "">
    参数 所欲移动的音频 <类型 = 音频处理类 注释 = "要移动的源样本数据">
    {
        @ @sn<this>.data()->moveSamples(*@<所欲移动的音频>.data())
    }

    方法 取输出样本地址 <公开 类型 = 变整数 注释 = "返回指向输出样本的起始地址,该功能用于直接访问输出样本." 注释 = "注意:如非对指针非常了解,请不要使用本方法."
            注释 = "使用此函数输出样本时,通过调用\"删除样本()\"函数删除." 返回值注释 = "返回输出样本的起始地址." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.data()->ptrBegin()
    }

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_Sound=objCopyFrom.m_Sound; }
