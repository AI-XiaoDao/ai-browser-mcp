类 音频速率类 <公开 注释 = "本类计算音频数据的BPM速率.">
{
    变量 样本通道数 <类型 = 整数>

    方法 创建 <公开 注释 = "创建对象数据,使用本类方式之前必须先调用本方法.">
    参数 所欲设置的样本通道数 <类型 = 整数>
    参数 所欲设置的样本采样率 <类型 = 整数>
    {
        @ this->m_Bpm=std::make_shared<soundtouch::BPMDetect>(@<所欲设置的样本通道数>,@<所欲设置的样本采样率>);
        @ @<样本通道数>=@<所欲设置的样本通道数>;
    }

    方法 销毁 <公开 注释 = "销毁之前创建的对象数据." @嵌入式方法 = "">
    {
        @ @sn<this>.m_Bpm.reset()
    }

    方法 取速率 <公开 类型 = 单精度小数 注释 = "返回BPM速率." 返回值注释 = "成功返回速率,失败返回零." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getBpm()
    }

    方法 输入样本32 <公开 注释 = "将音频样本数据输入到缓冲区中进行计算,使用\"取速率()\"可以获取到处理结果." 注释 = "注意:本方法使用32位浮点采样类型." @嵌入式方法 = "">
    参数 所欲提供的样本输入缓冲区 <类型 = 变整数 注释 = "提供样本数据的输入缓冲区内存地址." 注释 = "注意:内存指针类型为单精度小数,即(float*).">
    参数 所欲提供的样本数 <类型 = 整数 注释 = "注意:在立体声的情况下,单个样本包含两个通道的数据.">
    {
        @  @sn<this>.data()->inputSamples((soundtouch::SAMPLETYPE*)@<所欲提供的样本输入缓冲区>,@<所欲提供的样本数>)
    }

    方法 输入样本16 <公开 注释 = "将音频样本数据输入到采样处理缓冲区中进行计算,使用\"取速率()\"可以获取到处理结果." 注释 = "注意:本方法使用16位整数采样类型." @嵌入式方法 = "">
    参数 所欲提供的样本输入缓冲区 <类型 = 变整数 注释 = "提供样本数据的输入缓冲区内存地址." 注释 = "注意:内存指针类型为短整数,即(short*).">
    参数 所欲提供的样本数 <类型 = 整数 注释 = "注意:在立体声的情况下,单个样本包含两个通道的数据.">
    {
        @ @sn<this>.bpm_putSamples_i16((short *)@<所欲提供的样本输入缓冲区>,@<所欲提供的样本数>)
    }

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_Bpm=objCopyFrom.m_Bpm; }
    # inline soundtouch::BPMDetect* data(){return m_Bpm.get();}
    # std::shared_ptr<soundtouch::BPMDetect> m_Bpm;
    # void bpm_putSamples_i16(const short *samples, unsigned int numSamples);
    # <> </include>
    # void @sn<current_class>::bpm_putSamples_i16(const short *samples, unsigned int numSamples)
    # {
    #     if(data()==nullptr)return;
    #     uint numChannels =@<样本通道数>; //bpmh->numChannels;注意：源码里面 bpmh->numChannels 未赋值为未知值,根据源码来看应该是创建时的通道数!!!!!!!!!!!!!!
    #     // iterate until all samples converted & put to SoundTouch object
    #     while (numSamples > 0)
    #     {
    #         float convert[8192];    // allocate temporary conversion buffer from stack
    #         // how many multichannel samples fit into 'convert' buffer:
    #         uint convSamples = 8192 / numChannels;
    #         // convert max 'nround' values at a time to guarantee that these fit in the 'convert' buffer
    #         uint n = (numSamples > convSamples) ? convSamples : numSamples;
    #         for (uint i = 0; i < n * numChannels; i++)
    #         {
    #             convert[i] = samples[i];
    #         }
    #         // put the converted samples into SoundTouch
    #        data()->inputSamples(convert, n);
    #         numSamples -= n;
    #         samples += n * numChannels;
    #     }
    # }
    # @end
}

类 音频文件输入类 <公开 注释 = "本类提供WAV格式文件的读取操作.">
{

    # ----文件基本信息

    方法 取采样率 <公开 类型 = 整数 注释 = "获取音频文件采样率. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getSampleRate()
    }

    方法 取位数 <公开 类型 = 整数 注释 = "获取每个样本的位数,即8或16. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getNumBits()
    }

    方法 取数据大小 <公开 类型 = 整数 注释 = "获取以字节为单位的样本数据大小. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 注释 = "本方法应该返回\"取样本大小()\"相同信息." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getDataSizeInBytes()
    }

    方法 取样本数 <公开 类型 = 整数 注释 = "获取文件中的样本数. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getNumSamples()
    }

    方法 取样本大小 <公开 类型 = 整数 注释 = "获取每个音频样本的字节数（例如,16位立体声=4字节/样本）. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getDataSizeInBytes()
    }

    方法 取通道数 <公开 类型 = 整数 注释 = "获取文件中的音频通道数（1=单声道,2=立体声）. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getNumChannels()
    }

    方法 取时间长度 <公开 类型 = 整数 注释 = "获取音频文件长度（以毫秒为单位）. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getNumChannels()
    }

    方法 取已读时间 <公开 类型 = 整数 注释 = "获取到目前为止从文件中读取音频的毫秒数. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->getElapsedMS()
    }

    # ----方法

    方法 打开文件 <公开 类型 = 逻辑型 注释 = "打开文件并初始化资源,使用本类方法之前,必须先调用本方法." @禁止流程检查 = 真>
    参数 所欲打开的文件路径 <类型 = 文本型>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到多字节 (所欲打开的文件路径, )
        @ bool boRet=true; //文件打开失败会抛异常
        @ try{  this->m_Wav=std::make_shared<WavInFile>((const char*)@<临时字节集>.GetPtr()); }
        @ catch (...)  { boRet=false; } 
        @ return boRet;
    }

    方法 关闭文件 <公开 注释 = "关闭之前打开的文件,并释放资源." @嵌入式方法 = "">
    {
        @ @sn<this>.m_Wav.reset()
    }

    方法 移到文件首 <公开 注释 = "回放到文件的开头. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ @sn<this>.data()->rewind()
    }

    方法 是否文件尾 <公开 类型 = 逻辑型 注释 = "获取是否到达文件结尾. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." @嵌入式方法 = "">
    {
        @ (@sn<this>.data()->eof()!=0)
    }

    方法 读入数据8 <公开 类型 = 整数 注释 = "从WAV文件中读取音频样本. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 注释 = "注意:此方法仅适用于8位样本." 返回值注释 = "返回实际读取的大小."
            @嵌入式方法 = "">
    参数 要保存的数据缓冲区 <类型 = 变整数 注释 = "注意:必须确保内存地址有效.">
    参数 缓冲区尺寸 <类型 = 整数>
    {
        @ @sn<this>.data()->read((unsigned char*)@<要保存的数据缓冲区>,@<缓冲区尺寸>)
    }

    方法 读入数据16 <公开 类型 = 整数 注释 = "从WAV文件中读取音频样本为16位整数格式. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 返回值注释 = "返回实际读取的大小." @嵌入式方法 = "">
    参数 要保存的短整数数组地址 <类型 = 变整数 注释 = "指向短整数的内存地址,即：提供一个短整数的数组地址." 注释 = "注意:必须确保内存地址有效.">
    参数 短整数数组的成员数 <类型 = 整数 注释 = "参数\"要保存的短整数数组地址\"数组中的成员数.">
    {
        @ @sn<this>.data()->read((short*)@<要保存的短整数数组地址>,@<短整数数组的成员数>)
    }

    方法 读入数据32 <公开 类型 = 整数 注释 = "从WAV文件中读取音频样本为32位浮点格式。转换范围为[-1,1]的采样值."
            注释 = "本方法支持读取8/16/24/32位样本格式. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 返回值注释 = "返回实际读取的大小." @嵌入式方法 = "">
    参数 要保存的单精度数组地址 <类型 = 变整数 注释 = "指向单精度小数的内存地址,即：提供一个单精度小数的数组地址." 注释 = "注意:必须确保内存地址有效.">
    参数 单精度数组的成员数 <类型 = 整数 注释 = "参数\"要保存的单精度数组地址\"数组中的成员数.">
    {
        @ @sn<this>.data()->read((float*)@<要保存的单精度数组地址>,@<单精度数组的成员数>)
    }

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_Wav=objCopyFrom.m_Wav;
    # }
    # inline WavInFile* data()
    # {
    #     ASSERT (m_Wav.get()!=nullptr);//必须先调用打开文件方法
    #     return m_Wav.get();
    # }
    # std::shared_ptr<WavInFile> m_Wav;
    # <> </include>
    # @end
}

类 音频文件输出类 <公开 注释 = "本类提供WAV格式文件的写出操作">
{

    # ----方法

    方法 打开文件 <公开 类型 = 逻辑型 注释 = "打开文件并初始化资源,使用本类方法之前,必须先调用本方法." @禁止流程检查 = 真>
    参数 所欲打开的文件路径 <类型 = 文本型>
    参数 所欲设置的样本采样率 <类型 = 整数 注释 = "如:44100.">
    参数 所欲设置的样本位数 <类型 = 整数 注释 = "8或16位.">
    参数 所欲设置的样本通道数 <类型 = 整数 注释 = "1=单声道,2=立体声">
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 文本到多字节 (所欲打开的文件路径, )
        @ bool boRet=true; //文件打开失败会抛异常
        @ try
        @ { 
        @     this->m_Wav=std::make_shared<WavOutFile>((const char*)@<临时字节集>.GetPtr(),@<所欲设置的样本采样率>,@<所欲设置的样本位数>,@<所欲设置的样本通道数>);
        @ }
        @ catch (...) 
        @ {
        @     boRet=false;
        @ } 
        @ return boRet;
    }

    方法 关闭文件 <公开 注释 = "关闭之前打开的文件,并释放资源." @嵌入式方法 = "">
    {
        @ @sn<this>.m_Wav.reset()
    }

    方法 写出数据8 <公开 类型 = 逻辑型 注释 = "将数据写入WAV文件. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 注释 = "注意:此方法仅适用于8位样本." 返回值注释 = "返回操作是否成功."
            @禁止流程检查 = 真>
    参数 要写出的数据缓冲区 <类型 = 变整数 注释 = "注意:必须确保内存地址有效.">
    参数 缓冲区尺寸 <类型 = 整数>
    {
        @ try
        @ {
        @     data()->write((unsigned char*)@<要写出的数据缓冲区>,@<缓冲区尺寸>);
        @     return true;
        @ }
        @ catch (...)
        @ {
        @     return false;
        @ }
    }

    方法 写出数据16 <公开 类型 = 逻辑型 注释 = "以16位整数格式,将数据写入WAV文件. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 要保存的短整数数组地址 <类型 = 变整数 注释 = "指向短整数的内存地址,即：提供一个短整数的数组地址." 注释 = "注意:必须确保内存地址有效.">
    参数 短整数数组的成员数 <类型 = 整数 注释 = "参数\"要保存的短整数数组地址\"数组中的成员数.">
    {
        @ try
        @ {
        @     data()->write((short*)@<要保存的短整数数组地址>,@<短整数数组的成员数>);
        @     return true;
        @ }
        @ catch (...)
        @ {
        @     return false;
        @ }
    }

    方法 写出数据32 <公开 类型 = 逻辑型 注释 = "以32位浮点格式,将数据写入WAV文件. 调用本方法前,必须首先调用\"打开文件\"方法打开文件." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 要保存的单精度数组地址 <类型 = 变整数 注释 = "指向单精度小数的内存地址,即：提供一个单精度小数的数组地址." 注释 = "注意:必须确保内存地址有效.">
    参数 单精度数组的成员数 <类型 = 整数 注释 = "参数\"要保存的单精度数组地址\"数组中的成员数.">
    {
        @ try
        @ {
        @     data()->write((float*)@<要保存的单精度数组地址>,@<单精度数组的成员数>);
        @     return true;
        @ }
        @ catch (...)
        @ {
        @     return false;
        @ }
    }

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_Wav=objCopyFrom.m_Wav;
    # }
    # inline WavOutFile* data()
    # {
    #     ASSERT (m_Wav.get()!=nullptr);//必须先调用创建方法以创建对象
    #     return m_Wav.get();
    # }
    # std::shared_ptr<WavOutFile> m_Wav;
    # <> </include>
}

类 音频控制类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 AA滤波器 <公开 值 = @"@soundtouch::SETTING_USE_AA_FILTER" 注释 = "启用/禁用音调转置器中的抗混叠滤波器（0=禁用）.">
    常量 AA滤波器长度 <公开 值 = @"@soundtouch::SETTING_AA_FILTER_LENGTH" 注释 = "AA滤波器长度（8-128,默认值=32）.">
    常量 快速搜索算法 <公开 值 = @"@soundtouch::SETTING_USE_QUICKSEEK" 注释 = "启用/禁用快速搜索算法.">
    常量 帧时间 <公开 值 = @"@soundtouch::SETTING_SEQUENCE_MS" 注释 = "时间拉伸算法单个处理序列的长度（以毫秒为单位）.这决定了原始声音在时间拉伸算法中被截断的序列长度.官方例子设置值为40.">
    常量 叠加寻找窗的范围长度 <公开 值 = @"@soundtouch::SETTING_SEEKWINDOW_MS" 注释 = "时间拉伸算法为找到最佳可能重叠位置.官方例子设置值为15.">
    常量 叠加范围 <公开 值 = @"@soundtouch::SETTING_OVERLAP_MS" 注释 = "时间拉伸算法重叠长度（以毫秒为单位）.官方例子设置值为8.">
    常量 查询样本处理序列输入大小 <公开 值 = @"@soundtouch::SETTING_NOMINAL_INPUT_SEQUENCE"
            注释 = "查询样本中的处理序列大小.注意：这是只读参数,即不可设置此参数.此参数值不是恒定的,而是根据节奏/音高/速率/采样率设置.">
    常量 查询样本处理平均输出大小 <公开 值 = @"@soundtouch::SETTING_NOMINAL_OUTPUT_SEQUENCE"
            注释 = "查询样本平均处理输出大小.注意：这是只读参数,即不可设置此参数.此参数值不是恒定的,而是根据节奏/音高/速率/采样率设置.">
    常量 查询初始处理延迟 <公开 值 = @"@soundtouch::SETTING_INITIAL_LATENCY"
            注释 = "查询初始处理延迟.注意：这是只读参数,即不可设置此参数.此参数值不是恒定的,而是根据节奏/音高/速率/采样率设置.">
}
