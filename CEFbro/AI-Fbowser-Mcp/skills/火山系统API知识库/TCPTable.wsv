<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"windows.TCP连接查看\"" @视窗.外部头文件 = "TCPTable\\TCPTableTool.h"
        @视窗.外部库.win32 = "TCPTable\\TCPTableToolx86.lib" @视窗.附属文件.win32 = "TCPTable\\TCPTableToolx86.dll"
        @视窗.外部库.x64 = "TCPTable\\TCPTableToolx64.lib" @视窗.附属文件.x64 = "TCPTable\\TCPTableToolx64.dll">

类 TCPTable类 <公开 折叠>
{

    # @begin
    # <> <include>
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ m_pData = NULL;
    }

    方法 类_清理
    {
        @ TCPTable_free(m_pData);
    }

    方法 枚举 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ TCPTable_Enum(&@sn<this>.m_pData)
    }

    方法 取成员数 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)TCPTable_GetGount(@sn<this>.m_pData)
    }

    方法 取本地地址 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    {
        @ (INT)TCPTable_GetLocalAddr(@sn<this>.m_pData,(unsigned int)@<索引>)
    }

    方法 取本地端口 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 索引 <类型 = 整数>
    {
        @ int nPort = TCPTable_GetLocalPort(m_pData,(unsigned int)@<索引>);
        @ byte* pStart = (byte*)&nPort;
        @ byte temp = pStart[0];
        @ pStart[0]=pStart[1];
        @ pStart[1] = temp;
        @ return nPort;

    }

    方法 取远程地址 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    {
        @ (INT)TCPTable_GetRemoteAddr(@sn<this>.m_pData,(unsigned int)@<索引>)
    }

    方法 取远程端口 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 索引 <类型 = 整数>
    {
        @ int nPort = TCPTable_GetRemotePort(m_pData,(unsigned int)@<索引>);
        @ byte* pStart = (byte*)&nPort;
        @ byte temp = pStart[0];
        @ pStart[0]=pStart[1];
        @ pStart[1] = temp;
        @ return nPort;

    }

    方法 取状态 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    {
        @ (INT)TCPTable_GetState(@sn<this>.m_pData,(unsigned int)@<索引>)
    }

    方法 取状态文本 <公开 类型 = 文本型 折叠 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    {
        @ CVolString( TCPTable_GetStateText(TCPTable_GetState(@sn<this>.m_pData,(unsigned int)@<索引>)))
    }

    #
}

