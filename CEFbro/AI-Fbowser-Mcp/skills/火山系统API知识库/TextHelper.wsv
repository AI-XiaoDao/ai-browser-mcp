    方法 反转 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型>
    {
        @ @an<CVolString> str;
        @ DWORD dwSize = lstrlen(@<内容>)+1;
        @ if(dwSize <= 1)
        @   return str;
        @  TCHAR* lpstr = new TCHAR[dwSize];
        @  lstrcpy(lpstr,@<内容>);
        @  *(lpstr+(dwSize-1)) = (TCHAR)0;
        @ DWORD dwEnd   = dwSize-2;
        @ DWORD dwStart = 0;
        @ DWORD dwCount = (dwSize-1)/2;
        @ TCHAR ch;
        @ while(dwCount > 0)
        @ {
        @   ch =  lpstr[dwEnd];
        @   lpstr[dwEnd] =  lpstr[dwStart];
        @   lpstr[dwStart] = ch;
        @  dwCount--;
        @ }
        @ str = lpstr;
        @  delete [] lpstr;
        @ return str;

    }

