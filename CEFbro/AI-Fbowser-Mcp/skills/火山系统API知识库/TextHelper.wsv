    方法 字符_是否为汉字 <类型 = 逻辑型 注释 = "判断某个汉字,是否在GBK编码中! 小蜗牛提供" 折叠>
    参数 字符数据 <类型 = 字符>
    {
        如果 (字符数据 >= 19968 && 字符数据 <= 40869)
        {
            返回 (真)
        }
        否则 (字符数据 >= 59413 && 字符数据 <= 59492)
        {
            返回 (真)
        }
        否则 (字符数据 == 63788 || 字符数据 == 63865 || 字符数据 == 63893 || 字符数据 == 63975 || 字符数据 == 63985)
        {
            返回 (真)
        }
        否则 (字符数据 >= 64012 && 字符数据 <= 64015)
        {
            返回 (真)
        }
        否则 (字符数据 == 64017)
        {
            返回 (真)
        }
        否则 (字符数据 >= 64019 && 字符数据 <= 64020)
        {
            返回 (真)
        }
        否则 (字符数据 == 64024)
        {
            返回 (真)
        }
        否则 (字符数据 >= 64031 && 字符数据 <= 64033)
        {
            返回 (真)
        }
        否则 (字符数据 >= 64035 && 字符数据 <= 64036)
        {
            返回 (真)
        }
        否则 (字符数据 >= 64039 && 字符数据 <= 64041)
        {
            返回 (真)
        }
        否则
        {
            返回 (假)
        }

    }

    方法 字符数组类到文本 <静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 aa <类型 = 字符数组类>
    {
        变量 指针 <类型 = 变整数>
        变量 大小 <类型 = 整数>
        指针 = aa.取数组指针 ()
        大小 = aa.取成员数 () * aa.取成员尺寸 ()
        @ return @dt<文本型>(@<指针>,@<大小>)
    }
}

类 ______内存类 <公开 折叠 @全局类 = 真>
{
    方法 内存_申请 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 内存大小 <类型 = 整数>
    {
        @ (INT64)new byte[@<内存大小>]
    }

    方法 内存_释放 <公开 静态 折叠 @嵌入式方法 = "">
    参数 内存指针 <类型 = 变整数>
    {
        @ delete [] (BYTE*)@<内存指针>
    }

    方法 内存_写文本 <公开 静态 折叠>
    参数 内存指针 <类型 = 变整数>
    参数 内容 <类型 = 文本型>
    {
        @ memcpy((void *)@<内存指针>,@<内容>.GetText (),@<内容>.GetLength());
    }

    #
}

