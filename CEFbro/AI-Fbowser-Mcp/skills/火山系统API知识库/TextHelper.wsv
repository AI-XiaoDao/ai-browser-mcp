    方法 "//文本_反转" <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型>
    {
        @ @an<CVolString> str;
        @ DWORD dwSize = lstrlen(@<内容>)+1;
        @ if(dwSize <= 1)
        @   return str;
        @  TCHAR* lpstr = new TCHAR[dwSize];
        @  lstrcpy(lpstr,@<内容>);
        @  *(lpstr+(dwSize-1)) = (TCHAR)0;
        @ DWORD dwEnd   = dwSize-2;
        @ DWORD dwStart = 0;
        @ DWORD dwCount = (dwSize-1)/2;
        @ TCHAR ch;
        @ while(dwCount > 0)
        @ {
        @   ch =  lpstr[dwEnd];
        @   lpstr[dwEnd] =  lpstr[dwStart];
        @   lpstr[dwStart] = ch;
        @  dwCount--;
        @ }
        @ str = lpstr;
        @  delete [] lpstr;
        @ return str;

    }

    方法 文本_反转 <公开 静态 类型 = 文本型>
    参数 原始内容 <类型 = 文本型>
    {
        变量 返回值 <类型 = 文本型>
        变量 文本长度 <类型 = 整数>
        变量 i <类型 = 整数>
        文本长度 = 取文本长度 (原始内容)
        如果 (文本长度 > 0)
        {
            返回值 = 取空白文本 (文本长度)
        }

        循环 (0, 文本长度, i)
        {
            @  *(TCHAR*)(@<返回值>.GetText () + @<i>) = @<原始内容>.GetText()[@<文本长度> - @<i> - 1];
        }

        返回 (返回值)


    }

    方法 文本_反转自身 <公开 静态>
    参数 原始内容 <类型 = 文本型>
    {
        变量 文本长度 <类型 = 整数>
        变量 i <类型 = 整数 值 = 0>
        文本长度 = 取文本长度 (原始内容)
        循环 (0, 文本长度 / 2)
        {


            @  TCHAR ch = @<原始内容>.GetText ()[@<i>];
            @  *(TCHAR*)(@<原始内容>.GetText () + @<i>) = @<原始内容>.GetText()[@<文本长度> - @<i> - 1];
            @  *(TCHAR*)(@<原始内容>.GetText() + @<文本长度> - @<i> - 1 ) = ch;

            i = i + 1

        }



    }

    方法 文本_取出现次数 <公开 静态 类型 = 整数 折叠>
    参数 源文本 <类型 = 文本型>
    参数 要查找的特征文本 <类型 = 文本型>
    {
        变量 起始查找位置 <类型 = 整数 值 = 0>
        变量 找到的位置 <类型 = 整数>
        变量 出现次数 <类型 = 整数 值 = 0>
        判断循环 (真)
        {
            找到的位置 = 文本_寻找文本 (源文本, 要查找的特征文本, 起始查找位置)
            如果 (找到的位置 == -1)
            {
                返回 (出现次数)
            }
            出现次数 = 出现次数 + 1
            起始查找位置 = 找到的位置 + 文本_取长度 (要查找的特征文本)

        }
        返回 (0)
    }

    方法 文本_取中间_数组 <公开 折叠>
    参数 文本数据 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 结果数组 <类型 = 文本数组类>
    {
        变量 原始数据长度 <类型 = 整数>
        变量 开始文本长度 <类型 = 整数>
        变量 开始位置 <类型 = 整数 值 = 0>
        变量 结束位置 <类型 = 整数 值 = 0>
        变量 中间的文本 <类型 = 文本型>
        开始文本长度 = 取文本长度 (开始文本)
        原始数据长度 = 取文本长度 (文本数据)
        判断循环 (真)
        {

            开始位置 = 文本_寻找文本 (文本数据, 开始文本, 结束位置)
            如果 (开始位置 == -1)
            {
                跳出循环
            }

            结束位置 = 文本_寻找文本 (文本数据, 结束文本, 开始位置 + 开始文本长度)

            如果 (结束位置 == -1)
            {
                跳出循环
            }

            中间的文本 = 取文本中间 (文本数据, 开始位置 + 开始文本长度, 结束位置 - 开始位置 - 开始文本长度)
            结果数组.加入成员 (中间的文本)

        }


    }

    方法 "//文本_取中间_数组1" <公开 类型 = 文本数组类 注释 = "这个是返回一个文本数组类，暂时不用他了" 折叠>
    参数 文本数据 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    {
        变量 结果数组 <类型 = 文本数组类>
        变量 原始数据长度 <类型 = 整数>
        变量 开始文本长度 <类型 = 整数>
        变量 开始位置 <类型 = 整数 值 = 0>
        变量 结束位置 <类型 = 整数 值 = 0>
        变量 中间的文本 <类型 = 文本型>
        开始文本长度 = 取文本长度 (开始文本)
        原始数据长度 = 取文本长度 (文本数据)
        调试输出 (原始数据长度)
        判断循环 (真)
        {
            调试输出 (">>>>>")
            开始位置 = 文本_寻找文本 (文本数据, 开始文本, 结束位置)
            如果 (开始位置 == -1)
            {
                跳出循环
            }
            调试输出 (开始位置)

            调试输出 ("<<<<<")
            结束位置 = 文本_寻找文本 (文本数据, 结束文本, 开始位置 + 开始文本长度)

            如果 (结束位置 == -1)
            {
                跳出循环
            }
            调试输出 ("-----")

            调试输出 (开始位置)
            调试输出 (结束位置)
            调试输出 (结束位置 - 开始位置 - 开始文本长度)

            中间的文本 = 取文本中间 (文本数据, 开始位置 + 开始文本长度, 结束位置 - 开始位置 - 开始文本长度)
            结果数组.加入成员 (中间的文本)
            调试输出 (中间的文本)
        }

        返回 (结果数组)

    }

    方法 文本_取中间 <公开 静态 类型 = 文本型 折叠>
    参数 文本内容 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 @默认值 = 0>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        开始位置 = 寻找文本 (文本内容, 开始文本, 开始搜索位置)
        如果 (开始位置 == -1)
        {
            返回 (中间文本)
        }

        开始搜索位置 = 开始位置 + 取文本长度 (开始文本)
        如果 (是否包含起始文本 == 假)
        {
            开始位置 = 开始搜索位置
        }

        结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置)

        如果 (结束位置 == -1)
        {
            返回 (中间文本)
        }

