{
    方法 文本_取左边_从左往右查找 <公开 静态 类型 = 文本型 注释 = "默认从左边开始查找" 折叠 "">
    参数 原始文本 <类型 = 文本型>
    参数 要查找的文本 <类型 = 文本型>
    参数 搜索起始位置 <类型 = 整数 @默认值 = 0>
    参数 是否取分大小写 <类型 = 逻辑型 注释 = "默认不区分大小写" @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    {
        变量 找到位置 <类型 = 整数>
        变量 找到的文本 <类型 = 文本型>
        找到位置 = 文本_寻找文本 (原始文本, 要查找的文本, 搜索起始位置, 是否取分大小写)
        如果 (找到位置 != -1)
        {
            找到的文本 = 取文本左边 (原始文本, 找到位置)
        }
        否则
        {
            如果 (如果找不到返回原始文本 == 真)
            {
                返回 (原始文本)
            }

        }

        返回 (找到的文本)
    }

    方法 文本_取左边_从右往左查找 <公开 静态 类型 = 文本型>
    参数 原始文本 <类型 = 文本型>
    参数 要查找的文本 <类型 = 文本型>
    参数 开始查找位置 <类型 = 整数 注释 = "-1表示从尾部开始查找" @默认值 = -1>
    参数 是否区分分大小写 <类型 = 逻辑型 注释 = "默认不取分大小写" @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 找到位置 <类型 = 整数>
        // 调试输出 (原始文本)
        // 调试输出 (要查找的文本)
        // 调试输出 (开始查找位置)
        // 调试输出 (是否区分分大小写)

        找到位置 = 倒找文本 (原始文本, 要查找的文本, 开始查找位置, 是否区分分大小写)

        如果 (找到位置 == -1)
        {
            如果 (如果找不到返回原始文本)
            {
                返回 (原始文本)
            }
            否则
            {
                返回 ("")
            }

        }
        否则
        {
            返回 (取文本左边 (原始文本, 找到位置))
        }

    }

    方法 文本_取右边_从右往左查找 <公开 静态 类型 = 文本型 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 要查找的文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 注释 = "默认从尾部开始寻找" @默认值 = -1>
