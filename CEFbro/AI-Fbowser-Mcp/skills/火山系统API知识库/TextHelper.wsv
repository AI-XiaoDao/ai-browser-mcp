类 文本文件分割类 <公开 注释 = "由 小蜗牛提供" 注释 = "如果声明为局部变量,必须 挂接事件 才会有回调!" 折叠>
{
    方法 分割 <公开 类型 = 长整数 注释 = "会回调,阻塞线程,一直等待分割完成或者用户停止分割!" 返回值注释 = "返回总行数!">
    参数 文件路径 <类型 = 文本型>
    参数 分割符 <类型 = 文本型 @默认值 = "\r\n">
    参数 编码 <类型 = 文本型 注释 = "\"GBK\"/\"UTF-8\"/\"UTF-16\"" @默认值 = "GBK">
    {
        变量 文件 <类型 = 文件读写类>
        变量 文件长度 <类型 = 长整数>
        变量 缓冲区长度 <类型 = 整数>
        变量 缓冲区 <类型 = 字节集类>
        变量 数据 <类型 = 字节集类>
        变量 _分割符 <类型 = 字节集类>
        变量 行数 <类型 = 长整数>
        变量 位置 <类型 = 整数>
        变量 处理进度 <类型 = 小数>
        变量 call返回值 <类型 = 整数>
        变量 最后一段 <类型 = 逻辑型>
        变量 剩余文本长度 <类型 = 整数>
        变量 删除长度 <类型 = 整数>
        变量 一行文本 <类型 = 文本型>
        变量 分割完成 <类型 = 逻辑型>
        如果 (文件.打开文件 (文件路径) == 假)
        {
            返回 (0)
        }
        文件长度 = 文件.取文件长度 ()
        缓冲区长度 = 10 * 1024 * 1024  // 10M
        数据.置字节集预分配尺寸 (缓冲区长度)
        缓冲区.置字节集预分配尺寸 (缓冲区长度)
        如果 (编码 == "GBK")
        {
            _分割符 = 文本到多字节 (分割符, 假)
        }
        否则 (编码 == "UTF-8")
        {
            _分割符 = 文本到UTF8 (分割符, 假)
        }
        否则 (编码 == "UTF-16")
        {
            _分割符 = 文本到字节集 (分割符)
        }
        否则
        {
            _分割符 = 文本到多字节 (分割符, 假)
        }

        判断循环 (分割完成 == 假)
        {
            缓冲区 = 文件.读入字节集 (缓冲区长度)
            如果 (缓冲区.取字节集长度 () < 缓冲区长度)
            {
                最后一段 = 真
            }

            数据.添加字节集 (缓冲区)
            剩余文本长度 = 数据.取字节集长度 ()
            删除长度 = 0
            位置 = 0
            变量 已处理字节 <类型 = 长整数>

            判断循环 (剩余文本长度 > 0)
            {
                位置 = 数据.寻找字节集 (_分割符, 位置 + 1)  // 0D 0A
                如果 (位置 != -1)
                {
                    行数 = 行数 + 1
                    变量 数据长度 <类型 = 整数>
                    变量 一行数据 <类型 = 字节集类>
                    一行数据 = 数据.取字节集中间 (删除长度, 位置 - 删除长度)
                    数据长度 = 一行数据.取字节集长度 () + _分割符.取字节集长度 ()
                    删除长度 = 删除长度 + 数据长度
                    已处理字节 = 已处理字节 + 数据长度
                    剩余文本长度 = 剩余文本长度 - 数据长度
                    处理进度 = (小数)已处理字节 / 文件长度 * 100.0


                    如果 (最后一段 == 真 && 剩余文本长度 <= 0)  // 最后一行了,并且,剩余长度为0
                    {
                        处理进度 = 100
                        分割完成 = 真
                    }

                    如果 (编码 == "GBK")
                    {
                        一行文本 = 多字节到文本 (一行数据)
                    }
                    否则 (编码 == "UTF-8")
                    {
                        一行文本 = UTF8到文本 (一行数据)
                    }
                    否则 (编码 == "UTF-16")
                    {
                        一行文本 = 字节集到文本 (一行数据)
                    }
                    否则
                    {
                        调试信息框 ("不知道什么编码...")
                    }

                    call返回值 = 文本被读入 (一行文本, 行数, 处理进度)
                    如果 (call返回值 == 1)
                    {
                        文件.关闭文件 ()
                        返回 (行数)
                    }

                }
                否则
                {
                    跳出循环

                }

            }

            如果 (分割完成)
            {
                跳出循环
            }

            如果 (最后一段 == 真 && 分割完成 == 假)
            {
                行数 = 行数 + 1
                数据.字节集删除 (0, 删除长度)
                如果 (编码 == "GBK")
                {
                    一行文本 = 多字节到文本 (数据)
                }
                否则 (编码 == "UTF-8")
                {
                    一行文本 = UTF8到文本 (数据)
                }
                否则 (编码 == "UTF-16")
                {
                    一行文本 = 字节集到文本 (数据)
                }

                文本被读入 (一行文本, 行数, 100)
                跳出循环
            }

            如果 (删除长度 >= 数据.取字节集长度 ())
            {
                数据.清空字节集 ()
            }
            否则 (删除长度 > 0)
            {
                数据.字节集删除 (0, 删除长度)
            }

            如果 (最后一段)
            {
                跳出循环
            }

        }
        文件.关闭文件 ()
        返回 (行数)
    }

    方法 文本被读入 <公开 定义事件 类型 = 整数 注释 = "如果\"文件读写类\"为局部变量,那么则需要挂接事件!" 返回值注释 = "1=停止,0=继续">
    参数 被读入的文本 <类型 = 文本型>
    参数 当前行数 <类型 = 长整数>
    参数 处理进度 <类型 = 小数>
    {

    }
}

