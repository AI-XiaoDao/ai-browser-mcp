    #         dwExitCode = (DWORD)param->pThis->OnWork(param->ThreadParam);
    #         delete param;
    #         param = NULL;
    #     }
    #     return dwExitCode;
    # }
    # virtual int OnWork (INT_P pParam) 
    # {
    #         @<线程创建完毕>(pParam);
    #         BOOL bRet;
    #         MSG msg;
    #         @<成员退出消息循环> = FALSE;
    #         while(!@<成员退出消息循环>)
    #         {
    #             if(::PeekMessage(&msg, NULL,  0, 0, PM_REMOVE)) 
    #             {
    #                     if(msg.message == WM_QUIT)
    #                     {
    #                         break;
    #                     }
    #                     else
    #                     {
    #                         if(@<收到消息>((INT)msg.message-WM_USER,(INT_P)msg.wParam,(INT_P)msg.lParam) != 0)
    #                                 break;
    #                     }
    #                 
    #              }else
    #             {
