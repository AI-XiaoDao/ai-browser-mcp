<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" @文档 = "category = \"windows.线程\"">

类 ______线程辅助函数 <公开 @全局类 = 真>
{

    # //等待函数 Wait Function ===

    方法 WaitForSingleObject <公开 静态 类型 = 整数 返回值注释 = "具体查看 等待对象常量 这个里面的值" @嵌入式方法 = "">
    参数 句柄 <类型 = 变整数 注释 = "对象的句柄 handle to object">
    参数 等待超时 <类型 = 整数 注释 = "-1表示一直等待 超时 time-out interval" @默认值 = -1>
    {
        @ ::WaitForSingleObject((HANDLE)@<句柄>,@<等待超时>)
    }

    方法 CreateEvent <公开 静态 类型 = 变整数 返回值注释 = "返回创建的事件句柄" 折叠 @嵌入式方法 = "">
    参数 是否手动设置信号 <类型 = 逻辑型>
    参数 是否置有信号 <类型 = 逻辑型 注释 = "如果为真，则设置信号，否则为无信号状态">
    参数 事件名称 <注释 = "事件名称，如果为不填写，默认值表示创建" 注释 = "匿名事件" @匹配类型 = 通用基本型 @默认值 = 0>
    {
        @ (@dt<变整数>)::CreateEvent(NULL,@<是否手动设置信号>,@<是否置有信号>,@<事件名称>)
    }

    方法 CloseHandle <公开 静态 折叠 @嵌入式方法 = "">
    参数 内核对象句柄 <类型 = 变整数>
    {
        @ ::CloseHandle((HANDLE)@<内核对象句柄>)
    }

    方法 OpenEvent <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 事件名称 <类型 = 文本型>
    参数 访问权限 <类型 = OpenEvent常量 @默认值 = OpenEvent常量.EVENT_ALL_ACCESS>
    参数 是否可继承句柄 <类型 = 逻辑型 @默认值 = 假>
    {
        @ (@dt<变整数>)::OpenEvent(@<访问权限>,@<是否可继承句柄>,@<事件名称>)
    }

    方法 ResetEvent <公开 静态 注释 = "置事件无信号" 折叠 编辑时信息 = "47FFB, 0, 0, 0" @嵌入式方法 = "">
    参数 事件句柄 <类型 = 变整数 编辑时信息 = "47FFB, 0, 0, 0">
    {
        @ ::ResetEvent((HANDLE)@<事件句柄>)
    }

    方法 SetEvent <公开 静态 注释 = "设置事件有信号" 折叠 @嵌入式方法 = "">
    参数 事件句柄 <类型 = 变整数>
    {
        @ ::SetEvent((HANDLE)@<事件句柄>)
    }

    方法 PulseEvent <公开 静态 类型 = 逻辑型 注释 = "The PulseEvent function sets the specified event object"
            注释 = "to the signaled state and then resets it to the nonsignaled state"
            注释 = "after releasing the appropriate number of waiting threads." 折叠 @嵌入式方法 = "">
    参数 事件句柄 <类型 = 变整数>
    {
        @ ::PulseEvent((HANDLE)@<事件句柄>)
    }

    #
}

类 OpenEvent常量 <公开 折叠 @常量类 = 整数>
{
    常量 EVENT_ALL_ACCESS <公开 值 = @EVENT_ALL_ACCESS 注释 = "所有权限">
    常量 EVENT_MODIFY_STATE <公开 值 = @EVENT_MODIFY_STATE 注释 = "修改信号状态权限">
    常量 SYNCHRONIZE <公开 值 = @SYNCHRONIZE>
}

类 等待对象常量 <公开 折叠>
{
    常量 WAIT_ABANDONED <公开 类型 = 整数 值 = @WAIT_ABANDONED>
    常量 WAIT_OBJECT_0 <公开 类型 = 整数 值 = @WAIT_OBJECT_0>
    常量 WAIT_TIMEOUT <公开 类型 = 整数 值 = @WAIT_TIMEOUT>
}

类 ______线程基础函数 <公开 折叠 @全局类 = 真>
{
    方法 多线程_创建 <公开 静态 类型 = 变整数 返回值注释 = "返回线程句柄" 折叠 @嵌入式方法 = "">
    参数 回调函数 <类型 = 变整数 注释 = "一个参数 原型如右边   整数 WINAPI 回调函数(变整数 参数)  定义的时候注意设置前缀">
    参数 参数 <类型 = 变整数>
    参数 线程ID <类型 = 整数 注释 = "这个是返回值，，传递一个变量，返回一个线程ID" "">
    参数 是否挂起 <类型 = 逻辑型 注释 = "创建的时候是否挂起状态，默认创建了就运行" @默认值 = 假>
    {
        @ (@dt<变整数>)::CreateThread(NULL,0,(LPTHREAD_START_ROUTINE)@<回调函数>,(LPVOID)@<参数>,@<是否挂起>?CREATE_SUSPENDED:0,(LPDWORD)&@<线程ID>)
    }

    方法 "//线程回调函数原型" <类型 = 整数 折叠 @视窗.前缀文本 = "WINAPI">
    参数 参数 <类型 = 变整数>
    {

    }

    方法 多线程_投递消息 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 线程ID <类型 = 整数>
    参数 消息值 <类型 = 整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    {
        @ PostThreadMessage ((DWORD)@<线程ID>,(UINT)@<消息值>,(WPARAM)@<参数1>,(LPARAM)@<参数2>)
    }

    方法 多线程_等待 <公开 静态 类型 = 整数 注释 = "可以设置一个时间，然后等待线程执行，调用此函数会等待线程执行完毕" 返回值注释 = "具体查看 等待对象常量" 折叠>
    参数 线程句柄 <类型 = 变整数>
    参数 等待时间 <类型 = 整数 注释 = "-1表示一直等待" @默认值 = -1>
    {
        返回 (WaitForSingleObject (线程句柄, 等待时间))
    }

    方法 多线程_暂停 <公开 静态 类型 = 整数 注释 = "暂停一个正在工作的线程" 折叠 @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数>
    {
        @ ::SuspendThread(@<线程句柄>)
    }

    方法 多线程_继续 <注释 = "恢复一个被暂停的线程" 折叠 @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数>
    {
        @ ::ResumeThread(@<线程句柄>)
    }

    方法 多线程_取线程ID <公开 静态 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)GetCurrentThreadId()
    }

    #
}

类 线程消息类f <公开>
{
    方法 线程创建完毕 <公开 定义事件 类型 = 整数 注释 = "这个只会在线程创建完毕时被调用一次">
    参数 线程参数 <类型 = 变整数>
    {

    }

    方法 线程退出 <公开 定义事件 类型 = 整数 注释 = "线程退出时调用">
    参数 线程参数 <类型 = 变整数>
    {


    }

    方法 收到消息 <公开 定义事件 类型 = 整数>
    参数 消息 <类型 = 整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    {

    }

    方法 工作函数 <公开 定义事件 类型 = 整数 注释 = "此函数会被调用多次" 注释 = "此函数会不停的被调用，一般如果没什么事情，不要卡住此线程，否则消息" 注释 = "循环收不到消息">
    参数 参数 <类型 = 变整数>

    #
    # @begin
    # <> <include>
    #
    # typedef struct _tagThreadParam
    # {
    #     @sn<current_class>* pThis;
    #     INT_P ThreadParam;
    # }ThreadParam,*LPThreadParam;
