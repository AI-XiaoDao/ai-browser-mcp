    #  
    #      FreeLibrary(hModUser32);
    #  
    #      return  pfnChangeWindowMessageFilter(nMessage, bAllow ? FC_MSGFLT_ADD : FC_MSGFLT_REMOVE);
    # }
    #
    # @end

    方法 启用 <公开 静态>
    参数 窗口句柄 <类型 = 变整数>
    参数 启用拖放 <类型 = 逻辑型 @默认值 = 真>
    {
        @  if(@<启用拖放>)
        @  {
        @     ChangeWndMessageFilterOk(WM_DROPFILES, TRUE);
        @     ChangeWndMessageFilterOk(0x0049, TRUE);        // 0x0049 == WM_COPYGLOBALDATA
        @  }else
        @  {
        @     ChangeWndMessageFilterOk(WM_DROPFILES, FALSE);
        @     ChangeWndMessageFilterOk(0x0049, FALSE);        // 0x0049 == WM_COPYGLOBALDATA
        @  }
        @ ::DragAcceptFiles((HWND)@<窗口句柄>,@<启用拖放>);
    }

    方法 是否拖放消息 <公开 静态 类型 = 逻辑型 注释 = "再 消息过滤  中使用" @嵌入式方法 = "">
    参数 消息值 <类型 = 变整数>
    {
        @ (@<消息值> == WM_DROPFILES ? TRUE:FALSE)
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "获取拖放的文件的数量" @嵌入式方法 = "">
    参数 消息参数1 <类型 = 变整数>
    {
        @ (int)::DragQueryFile( (HDROP)@<消息参数1>, (UINT)-1, NULL, 0)
    }

    方法 取成员 <公开 静态 类型 = 文本型 注释 = "得到拖放数组中的文件名" @禁止流程检查 = 真>
    参数 消息参数1 <类型 = 变整数 注释 = "从0开始">
    参数 索引 <类型 = 整数>
    {
        @ TCHAR szFileName[_MAX_PATH] = {0};
        @ ::DragQueryFile((HDROP)@<消息参数1> , @<索引>, szFileName, sizeof(szFileName));
        @ return szFileName;
    }

    方法 释放资源 <公开 静态 注释 = "当获取成员完毕时候调用此函数" @嵌入式方法 = "">
    参数 消息参数1 <类型 = 变整数 注释 = "从0开始">
    {
        @ DragFinish((HDROP)@<消息参数1>)
    }
}

类 "//我的主窗口" <基础类 = 窗口 注释 = "拖放对象使用例子" 折叠 @视窗.布局 = "client_size = \"500, 300\"">
{
    变量 编辑框1 <类型 = 编辑框 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"37, 6, 392, 40\"">

    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 我的主窗口>
    参数 标记值 <类型 = 整数>
    {
        拖放对象_全局类.启用 (编辑框1.取窗口句柄 ())
        返回 (0)
    }

    方法 消息过滤 <公开 类型 = 逻辑型 注释 = "用户的窗口类可以覆盖此方法以过滤处理本窗口及其所有子组件中的消息" 返回值注释 = "返回真表示允许消息继续向后传递并处理,返回假表示取消掉该消息的后续处理." @虚拟方法 = 可覆盖>
    参数 窗口句柄 <类型 = 变整数 注释 = "提供消息所对应的窗口句柄(HWND),必定为本窗口或其直接/间接下属子窗口.">
    参数 消息值 <类型 = 整数 注释 = "提供消息的具体值">
    参数 消息参数1 <类型 = 变整数 注释 = "提供消息所附带的参数1的值">
    参数 消息参数2 <类型 = 变整数 注释 = "提供消息所附带的参数2的值">
    参数 消息地址 <类型 = 变整数 注释 = "提供消息的具体 MSG* 地址指针,用作备用.">
    {

        如果 (拖放对象_全局类.是否拖放消息 (消息值))
        {

            变量 数量 <类型 = 整数>
            变量 i <类型 = 整数>
            数量 = 拖放对象_全局类.取成员数 (消息参数1)
            循环 (0, 数量, i)
            {
                调试输出f (拖放对象_全局类.取成员 (消息参数1, i))
            }
            拖放对象_全局类.释放资源 (消息参数1)
        }
        返回 (父对象.消息过滤 (窗口句柄, 消息值, 消息参数1, 消息参数2, 消息地址))  // 调用基础类中的被覆盖虚拟方法

    }
}

