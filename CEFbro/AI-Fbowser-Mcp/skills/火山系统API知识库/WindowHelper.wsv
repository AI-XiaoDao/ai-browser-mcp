    方法 窗口_取父窗口句柄 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 当前窗口句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)GetParent((HWND)@<当前窗口句柄>)
    }

    方法 窗口_取控件句柄_从ID <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 控件ID <类型 = 整数>
    {
        @ (@dt<变整数>)GetDlgItem((HWND)@<窗口句柄>,@<控件ID>)
    }

    方法 窗口_取文本 <公开 静态 类型 = 文本型 注释 = "返回控件的标题，或者是内容" 注释 = "如果是窗口那么就是标题，" 注释 = "如果是编辑框那么返回内容" @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ TCHAR buf[4096]={0};
        @ SendMessage ((HWND)@<窗口句柄>,WM_GETTEXT,4096,(LPARAM)buf);
        @ return buf;

    }

    方法 窗口_置文本 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 要设置的内容 <类型 = 文本型>
    {
        @ SendMessage ((HWND)@<窗口句柄>,WM_SETTEXT,0,(LPARAM)@<要设置的内容>.GetText())
    }

    方法 窗口_取控件ID <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ GetDlgCtrlID((HWND)@<窗口句柄>)
    }

    方法 窗口_查找子窗口_根据控件ID <公开 静态 类型 = 变整数 注释 = "如果有多个，那么只会返回第一个" 折叠>
    参数 父窗口句柄 <类型 = 变整数>
    参数 ID <类型 = 变整数>
    {
        变量 窗口句柄 <类型 = 变整数>
        窗口句柄 = GetWindow (父窗口句柄, GetWindow常量.GW_CHILD)
        如果 (窗口句柄 == 0)
        返回 (0)
        判断循环 (窗口句柄 != 0)
        {

            如果 (窗口_取控件ID (窗口句柄) == ID)
            {
                返回 (窗口句柄)
            }

            临时窗口句柄 = 窗口_查找子窗口_根据标题_模糊 (窗口句柄, 要查找的子窗口标题)
            如果 (临时窗口句柄 != 0)
            {
                返回 (临时窗口句柄)
            }

            窗口句柄 = GetWindow (窗口句柄, GetWindow常量.GW_HWNDNEXT)
        }

        返回 (0)



    }

    方法 窗口_查找子窗口_根据标题_模糊 <公开 静态 类型 = 变整数 注释 = "如果有多个，那么只会返回第一个" 折叠>
    参数 父窗口句柄 <类型 = 变整数>
    参数 要查找的子窗口标题 <类型 = 文本型>
    {
        变量 窗口句柄 <类型 = 变整数>
        变量 窗口标题 <类型 = 文本型>
        变量 临时窗口句柄 <类型 = 变整数>
        变量 ""

        窗口句柄 = GetWindow (父窗口句柄, GetWindow常量.GW_CHILD)
        如果 (窗口句柄 == 0)
        {
            返回 (0)
        }

        判断循环 (窗口句柄 != 0)
        {
            窗口标题 = 窗口_取标题f (窗口句柄)
            如果 (寻找文本 (窗口标题, 要查找的子窗口标题) != -1)
            {
                返回 (窗口句柄)
            }

            临时窗口句柄 = 窗口_查找子窗口_根据标题_模糊 (窗口句柄, 要查找的子窗口标题)
            如果 (临时窗口句柄 != 0)
            {
                返回 (临时窗口句柄)
            }

            窗口句柄 = GetWindow (窗口句柄, GetWindow常量.GW_HWNDNEXT)
        }

        返回 (0)



    }

    方法 窗口_查找根据类名 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 窗口类名 <类型 = 文本型>
    {
        @ (@dt<变整数>) ::FindWindow(@<窗口类名>,NULL)

    }

    方法 窗口_查找根据标题 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 窗口标题 <类型 = 文本型>
    {
        @ (@dt<变整数>) ::FindWindow(NULL,@<窗口标题>)

    }

    方法 窗口_取类名f <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ TCHAR tszBuffer[1024] = {0};
        @ ::GetClassName((HWND)@<窗口句柄>, tszBuffer,1024);
        @ return tszBuffer;

    }

    方法 窗口_取标题f <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ TCHAR tszBuffer[1024] = {0};
        @ ::GetWindowText ((HWND)@<窗口句柄>, tszBuffer,1024);
        @ return tszBuffer;
    }

    方法 窗口_模糊查找_单一 <公开 静态 类型 = 变整数 折叠>
    参数 窗口标题 <类型 = 文本型>
    参数 是否查找类名 <类型 = 逻辑型 @默认值 = 假>
    {
        @  HWND hDeskTopWindow = ::GetDesktopWindow (); //1.先获得桌面窗口
        @  HWND hChildWnd = ::GetWindow (hDeskTopWindow, GW_CHILD);   //2.获得一个子窗口
        @   TCHAR tszBuffer[1024] = {0};
        @   INT nTextLen = 0;
        @   while(hChildWnd != NULL)
        @   {
        @    if(@<是否查找类名>)
        @    {
        @        nTextLen = ::GetClassNameW (hChildWnd, tszBuffer, sizeof(tszBuffer));
        @    }else
        @    {
        @        nTextLen = ::GetWindowText (hChildWnd, tszBuffer, sizeof(tszBuffer));
        @    }
        @    if(nTextLen != 0)
        @    {
        @     if (::StrStr(tszBuffer,@<窗口标题>) != NULL)
        @     {
        @      return (INT64)hChildWnd;
        @     }
        @    }
        @    hChildWnd = ::GetWindow (hChildWnd, GW_HWNDNEXT);
        @   }
        返回 (0)


    }

    方法 窗口_捕获鼠标_开始 <公开 静态 类型 = 长整数 返回值注释 = "返回值是先前捕获鼠标的窗口的句柄" @嵌入式方法 = "">
