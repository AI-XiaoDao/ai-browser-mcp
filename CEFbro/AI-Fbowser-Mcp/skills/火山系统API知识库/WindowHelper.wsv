类 ______窗口辅助 <公开 @全局类 = 真>
{

    #
    #
    #
    # @begin
    # <> <include>
    # static BOOL CALLBACK EnumChildWindow(HWND hwnd,LPARAM lParam);
    # //static BOOL VolEnumChildWindows(  HWND hWndParent,LPARAM lParam,WNDENUMPROC lpEnumFunc);
    # <> </include>
    # //对应 窗口_枚举子窗口F 的回调函数
    # BOOL CALLBACK @sn<current_class>::EnumChildWindow(HWND hwnd,LPARAM lParam)
    # {
    #     @dt<变整数数组类>* pArray = (@dt<变整数数组类>*)lParam;
    #     pArray->data ().Add2((INT_P)hwnd);
    #     return TRUE;
    # }
    # //BOOL @sn<current_class>::VolEnumChildWindows(HWND hWndParent,WNDENUMPROC lpEnumFunc)
    # //{
    # //  return EnumChildWindows(hWndParent,lpEnumFunc,NULL);
    # //}
    # @end

    方法 "//窗口_枚举子窗口循环" <公开 静态 @嵌入式方法 = "name = VolEnumChildWindows\r\nhas_loop_body = true\r\nbody_tail = \"});\"">
    参数 父窗口句柄 <类型 = 变整数>
    {
        @ @dt<______窗口辅助>::VolEnumChildWindows((HWND)@<父窗口句柄>,[] CALLBACK (HWND hwnd, LPARAM lparam) 
    }

    方法 窗口_枚举子窗口F <公开 静态 @嵌入式方法 = "">
    参数 父窗口句柄 <类型 = 变整数>
    参数 子窗口句柄数组 <类型 = 变整数数组类 注释 = "用来保存着所有子窗口句柄">
    {
