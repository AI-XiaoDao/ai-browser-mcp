类 __窗口枚举模板类 <公开 折叠 @模板基础类 = 真>
{
    变量 是否继续枚举 <公开 类型 = 逻辑型 值 = 真>

    #
    # @begin
    # <> <include>
    #  struct EnumChildWin
    #  {
    #     @sn<current_class>* pThis;
    #     @dt<模板类型1>*        p1;
    #     @dt<模板类型1>*        p2;
    #     @dt<模板类型1>*        p3;
    #     @dt<模板类型1>*        p4;
