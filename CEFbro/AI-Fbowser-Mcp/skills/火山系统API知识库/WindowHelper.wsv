    #     return pEcw->pThis->OnEnumWindow( (@dt<变整数>)hwnd ,pEcw->p1,pEcw->p2,pEcw->p3,pEcw->p4);
    # }
    # BOOL  OnEnumWindow(@dt<变整数> hWnd, @dt<模板类型1>* p1,@dt<模板类型2>* p2,@dt<模板类型3>* p3,@dt<模板类型4>* p4)
    # {
    #     @<回调函数>(hWnd,*p1,*p2,*p3,*p4);
    #     return @<是否继续枚举>;
    # }
    # <> </include>
    # @end

    方法 枚举 <公开>
    参数 窗口句柄 <类型 = 变整数>
    参数 参数1 <类型 = 模板类型1>
    参数 参数2 <类型 = 模板类型2>
    参数 参数3 <类型 = 模板类型3>
    参数 参数4 <类型 = 模板类型4>
    {
        @  struct EnumChildWin ecw;
        @  ecw.pThis = this;
        @  ecw.p1 = &@<参数1>;
        @  ecw.p2 = &@<参数2>;
        @  ecw.p3 = &@<参数3>;
        @  ecw.p4 = &@<参数4>;
        @ ::EnumChildWindows((HWND)@<窗口句柄>,@sn<current_class>::EnumChildProc,(LPARAM)&ecw);

    }

    方法 回调函数 <公开 定义事件 类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 参数1 <类型 = 模板类型1>
    参数 参数2 <类型 = 模板类型2>
    参数 参数3 <类型 = 模板类型3>
    参数 参数4 <类型 = 模板类型4>
    {

    }

    #
    #
}

类 窗口枚举类_整数 <公开 基础类 = __窗口枚举模板类 折叠 @模板实现类 = "整数,整数,整数,整数">
{

    #
}

类 模拟输入测试 <公开 折叠>
{
    方法 开始测试 <公开>
    {
        变量 火山主窗口句柄 <类型 = 变整数>
        调试输出 ("我擦执行到这里没？")
        // 窗口_到前台_第二步骤 (窗口_模糊查找_单一 ("火山软件开发平台"))

        // 火山主窗口句柄 = 窗口_模糊查找_单一 ("火山软件开发平台")
        // 窗口_到前台_第二步骤 (火山主窗口句柄)
        // 火山主窗口句柄 = 窗口_取火山编辑框句柄_临时用一下 (火山主窗口句柄)
        // 窗口_到前台_第二步骤 (火山主窗口句柄)
        火山主窗口句柄 = 67474
        消息_模拟组合键 (火山主窗口句柄, 键代码_常量类.CTRL键, 键代码_常量类.字母D键)
        // 键盘_模拟组合键 (键代码_常量类.VK_CONTROL, 键代码_常量类.VK_D)
        消息_模拟输入文本 (火山主窗口句柄, "测试常量")

        消息_模拟组合键 (火山主窗口句柄, 键代码_常量类.CTRL键, 键代码_常量类.字母B键)  // 生成一个空行
        变量 循环计次 <类型 = 整数>
        循环 (1, 10, 循环计次, 1)
        {
            消息_模拟组合键 (火山主窗口句柄, 键代码_常量类.CTRL键, 键代码_常量类.字母B键)  // 光标位置 常量名
            消息_模拟输入文本 (火山主窗口句柄, 到文本 (循环计次))  // 输入常量名称
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到类型
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到初始值
            消息_模拟输入文本 (火山主窗口句柄, "@" + 到文本 (循环计次))  // 设置初始值
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到公开
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.空格键)  // 设置公开
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到属性名
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到属性值
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 跳到备注
            消息_模拟按键 (火山主窗口句柄, 键代码_常量类.右键)  // 到下一行行首

        }


    }

    #
}
