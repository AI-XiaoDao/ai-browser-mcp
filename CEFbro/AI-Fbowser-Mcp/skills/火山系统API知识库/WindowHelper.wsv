    #  
    #      ChangeWindowMessageFilterOkFn pfnChangeWindowMessageFilter = (ChangeWindowMessageFilterOkFn) GetProcAddress(hModUser32,  "ChangeWindowMessageFilter" );
    #      if  (pfnChangeWindowMessageFilter == NULL)
    #      {
    #          FreeLibrary(hModUser32);
    #          return  FALSE;
