<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" 注释 = "" 注释 = "https://docs.microsoft.com/en-us/windows/win32/api/"
        @文档 = "category = \"windows.窗口辅助\"" "" @视窗.外部头文件 = "<Shlwapi.h>" @视窗.外部库 = "Shlwapi.lib">

类 ______CHM帮助文档_全局类 <公开 @全局类 = 真>
{
    方法 打开CHM文档 <公开 静态 类型 = 变整数 注释 = "https://docs.microsoft.com/zh-tw/windows/win32/api/htmlhelp/nf-htmlhelp-htmlhelpw"
            返回值注释 = "返回窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 帮助文档路径 <类型 = 文本型 注释 = "例如 \"c:\\\\Help.chm::/Intro.htm>Mainwin\"">
    参数 选项卡类型 <类型 = 整数 注释 = "可选值" 注释 = "#define HH_DISPLAY_TOPIC        0x0000"
            注释 = "#define HH_HELP_FINDER          0x0000  // WinHelp equivalent" 注释 = "#define HH_DISPLAY_TOC          0x0001"
            注释 = "#define HH_DISPLAY_INDEX        0x0002" 注释 = "#define HH_DISPLAY_SEARCH       0x0003"
            注释 = "#define HH_SET_WIN_TYPE         0x0004" 注释 = "#define HH_GET_WIN_TYPE         0x0005"
            注释 = "#define HH_GET_WIN_HANDLE       0x0006"
            注释 = "#define HH_ENUM_INFO_TYPE       0x0007  // Get Info type name, call repeatedly to enumerate, -1 at end"
            注释 = "#define HH_SET_INFO_TYPE        0x0008  // Add Info type to filter." 注释 = "#define HH_SYNC                 0x0009"
            注释 = "#define HH_RESERVED1            0x000A" 注释 = "#define HH_RESERVED2            0x000B"
            注释 = "#define HH_RESERVED3            0x000C" 注释 = "#define HH_KEYWORD_LOOKUP       0x000D"
            注释 = "#define HH_DISPLAY_TEXT_POPUP   0x000E  // display string resource id or text in a popup window"
            注释 = "#define HH_HELP_CONTEXT         0x000F  // display mapped numeric value in dwData"
            注释 = "#define HH_TP_HELP_CONTEXTMENU  0x0010  // text popup help, same as WinHelp HELP_CONTEXTMENU"
            注释 = "#define HH_TP_HELP_WM_HELP      0x0011  // text popup help, same as WinHelp HELP_WM_HELP"
            注释 = "#define HH_CLOSE_ALL            0x0012  // close all windows opened directly or indirectly by the caller"
            注释 = "#define HH_ALINK_LOOKUP         0x0013  // ALink version of HH_KEYWORD_LOOKUP"
            注释 = "#define HH_GET_LAST_ERROR       0x0014  // not currently implemented // See HHERROR.h"
            注释 = "#define HH_ENUM_CATEGORY        0x0015 // Get category name, call repeatedly to enumerate, -1 at end"
            注释 = "#define HH_ENUM_CATEGORY_IT     0x0016  // Get category info type members, call repeatedly to enumerate, -1 at end"
            注释 = "#define HH_RESET_IT_FILTER      0x0017  // Clear the info type filter of all info types."
            注释 = "#define HH_SET_INCLUSIVE_FILTER 0x0018  // set inclusive filtering method for untyped topics to be included in display"
            注释 = "#define HH_SET_EXCLUSIVE_FILTER 0x0019  // set exclusive filtering method for untyped topics to be excluded from display"
            注释 = "#define HH_INITIALIZE            0x001C  // Initializes the help system."
            注释 = "#define HH_UNINITIALIZE          0x001D  // Uninitializes the help system."
            注释 = "#define HH_SET_QUERYSERVICE     0x001E  // Set the Host IQueryService interface"
            注释 = "#define HH_PRETRANSLATEMESSAGE  0x00fd  // Pumps messages. (NULL, NULL, MSG*)."
            注释 = "#define HH_SET_GLOBAL_PROPERTY  0x00fc  // Set a global property. (NULL, NULL, HH_GPROP)"
            注释 = "#define HH_SAFE_DISPLAY_TOPIC   0x0020  // private addition to the interface for InternetExplorer." 折叠2 @默认值 = 0>
    {
        @ HWND hWnd = @<窗口句柄> ? (HWND)@<窗口句柄>:GetDesktopWindow();
        @ HWND hRetWnd = HtmlHelp(hWnd,@<帮助文档路径>.GetText(),(UINT)@<选项卡类型>,NULL);
        @ return hRetWnd;
        // HWND HtmlHelpW(
        // [in, optional] HWND      hwndCaller,
        // [in]           LPCWSTR   pszFile,
        // [in]           UINT      uCommand,
        // [in]           DWORD_PTR dwData
        //);
    }

    #
}

类 窗口显示方式_常量类 <公开 折叠 @常量类 = 整数>
{
    常量 强制最小化 <公开 值 = @SW_FORCEMINIMIZE>
    常量 隐藏 <公开 值 = @SW_HIDE>
    常量 最大化 <公开 值 = @SW_MAXIMIZE>
    常量 最小化 <公开 值 = @SW_MINIMIZE>
    常量 恢复 <公开 值 = @SW_RESTORE>
    常量 显示 <公开 值 = @SW_SHOW>
    常量 默认显示 <公开 值 = @SW_SHOWDEFAULT>
    常量 激活并最大化显示 <公开 值 = @SW_SHOWMAXIMIZED>
    常量 激活并最小化显示 <公开 值 = @SW_SHOWMINIMIZED>
    常量 最小化显示不激活 <公开 值 = @SW_SHOWMINNOACTIVE>
    常量 显示不激活 <公开 值 = @SW_SHOWNA>
    常量 显示并激活 <公开 值 = @SW_SHOWNOACTIVATE>
    常量 正常显示 <公开 值 = @SW_SHOWNORMAL>
    常量 SW_SHOWNOACTIVATE <公开 值 = @SW_SHOWNOACTIVATE>
    常量 SW_SHOWNORMAL <公开 值 = @SW_SHOWNORMAL>

    #
}

类 _____消息_组合框_全局类 <公开 折叠 @全局类 = 真>
{
    方法 消息_组合框_置选中项 <公开 静态 类型 = 整数
            注释 = "If the message is successful, the return value is the index of the item selected. If wParam is greater than the number of items in the list or if wParam is –1, the return value is CB_ERR and the selection is cleared."
            @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 选中索引 <类型 = 整数 注释 = "从0开始">
    {
        @ (INT)SendMessage ((HWND)@<窗口句柄>, CB_SETCURSEL, @<选中索引>, 0)
    }

    方法 消息_组合框_取项数 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ (INT) SendMessage ((HWND)@<窗口句柄>, CB_GETCOUNT, 0, 0)
    }

    方法 消息_组合框_取现行选中项 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ (INT)SendMessage ((HWND)@<窗口句柄>, CB_GETCURSEL, 0, 0)

    }

    方法 消息_组合框_取项附加数据 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ (INT_P)::SendMessage((HWND)@<窗口句柄>, CB_GETITEMDATA, @<索引>, 0)
    }

    方法 消息_组合框_置项附加数据 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    参数 附加数据 <类型 = 变整数>
    {
        @ (INT)::SendMessage((HWND)@<窗口句柄>, CB_SETITEMDATA, @<索引>, (LPARAM)@<附加数据>)
    }

    方法 消息_组合框_取项目文本 <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ int nTextLen = (int)::SendMessage((HWND)@<窗口句柄>, CB_GETLBTEXTLEN, @<索引>, 0);
        @ TCHAR* lpszText = new TCHAR[nTextLen+1];
        @ lpszText[nTextLen]= 0;
        @ (int)::SendMessage((HWND)@<窗口句柄>, CB_GETLBTEXT, @<索引>, (LPARAM)lpszText); 
        @ CVolString str(lpszText);
        @ delete [] lpszText;
        @ return str;

    }

    方法 消息_组合框_加入项目 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 项目文本 <类型 = 文本型>
    {
        @ (INT)::SendMessage((HWND)@<窗口句柄>, CB_ADDSTRING, 0, (LPARAM)@<项目文本>.GetText())
    }

    方法 消息_组合框_插入项目 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    参数 项目文本 <类型 = 文本型>
    {
        @ (INT)::SendMessage((HWND)@<窗口句柄>, CB_INSERTSTRING, @<索引>, (LPARAM)@<项目文本>.GetText())
    }

    方法 消息_组合框_查找 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数 注释 = "从指定的索引后开始查找">
    参数 要查找的文本 <类型 = 文本型>
    {
        @ (INT)::SendMessage((HWND)@<窗口句柄>, CB_FINDSTRING, @<索引>, (LPARAM)@<要查找的文本>.GetText())
    }

    方法 消息_组合框_删除项目 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ (INT)::SendMessage((HWND)@<窗口句柄>, CB_DELETESTRING,  @<索引>, 0)
    }

    方法 消息_组合框_清空 <公开 静态 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ ::SendMessage((HWND)@<窗口句柄>, CB_RESETCONTENT, 0, 0)
    }

    方法 消息_组合框_清除 <公开 静态 注释 = "只是清除组合框里面的编辑框内容" @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    {
        @ ::SendMessage((HWND)@<窗口句柄>, WM_CLEAR, 0, 0)
    }

    #
}

类 ______窗口模拟点击 <公开 @全局类 = 真 @禁止创建对象 = 真>
{
    方法 消息_窗口_点击 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 横坐标 <类型 = 整数 @默认值 = 0>
    参数 纵坐标 <类型 = 整数 @默认值 = 0>
    参数 延时 <类型 = 整数 @默认值 = 5>
    {
        @ SendMessage ((HWND)@<窗口句柄>, WM_LBUTTONDOWN, 0, MAKEWPARAM (@<横坐标>, @<纵坐标>));
        @ Sleep (@<延时>);
        @ SendMessage ((HWND)@<窗口句柄>, WM_LBUTTONUP, 0, MAKEWPARAM (@<横坐标>, @<纵坐标>));
    }

    方法 消息_窗口_点击_异步 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 横坐标 <类型 = 整数 @默认值 = 0>
    参数 纵坐标 <类型 = 整数 @默认值 = 0>
    参数 延时 <类型 = 整数 @默认值 = 5>
    {
        @ PostMessage ((HWND)@<窗口句柄>, WM_LBUTTONDOWN, 0, MAKEWPARAM (@<横坐标>, @<纵坐标>));
        @ Sleep (@<延时>);
        @ PostMessage ((HWND)@<窗口句柄>, WM_LBUTTONUP, 0, MAKEWPARAM (@<横坐标>, @<纵坐标>));
    }

    方法 消息_编辑框_置内容 <公开 静态 类型 = 逻辑型 注释 = "成功返回真 否则为假" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 要设置的内容 <类型 = 文本型>
    {
        @ return SendMessage ((HWND)@<窗口句柄>, WM_SETTEXT, 0, (LPARAM)(LPCTSTR)@<要设置的内容>) ? true:false;
    }

    方法 消息_选择框_置选中 <公开 静态 类型 = 整数 注释 = "支持单选框和复选框" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 类型 <类型 = 整数 注释 = "0 取消选中  1 变灰  2 选中  默认0 取消选中  ,如果填写了其他数值，则默认取消选中" @默认值 = 0>
    {
        变量 状态标记 <类型 = 整数>

        如果 (类型 == 1)
        {
            @ @<状态标记> = BST_INDETERMINATE;
        }
        否则 (类型 == 2)
        {
            @ @<状态标记> = BST_CHECKED ;
        }
        @ return SendMessageA ((HWND)@<窗口句柄>, BM_SETCHECK, @<状态标记>, 0);



    }

    方法 消息_选择框_取选中 <公开 静态 类型 = 逻辑型 注释 = "这个只能判断 启用的情况下面的情况，如果选择框是灰色的，似乎不能取出来" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ LRESULT re = SendMessageA ((HWND)@<窗口句柄>, BM_GETCHECK, 0, 0);
        @ if( re & BST_CHECKED)
        @    return true;
        @ else if( re & BST_UNCHECKED )
        @    return false;
        @  return false;
    }

    方法 消息_模拟组合键 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 控制键 <类型 = 键代码_常量类>
    参数 普通键代码 <类型 = 键代码_常量类>
    参数 延时 <类型 = 整数 注释 = "按下键和松开键之间的间隔时间" @默认值 = 20>
    {
        @ keybd_event (@<控制键>, 0, 0, 0);
        @ Sleep(@<延时>);
        消息_模拟按键 (窗口句柄, 普通键代码, 延时)
        @ Sleep(@<延时>);
        @ keybd_event (@<控制键>, 0, 2, 0);


    }

    方法 消息_模拟输入字符 <公开 静态 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数>
    参数 要输入的字符 <类型 = 整数>
    {
        @ PostMessage((HWND)@<窗口句柄>,WM_CHAR,(WPARM)键代码,NULL)
    }

    方法 消息_模拟按键 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 键代码 <类型 = 键代码_常量类>
    参数 延时 <类型 = 整数 @默认值 = 30>
    {
        @ PostMessage((HWND)@<窗口句柄>,WM_KEYDOWN,@<键代码>,NULL);
        @ Sleep(@<延时>);
        @ PostMessage((HWND)@<窗口句柄>,WM_KEYUP,@<键代码>,NULL);
        @ Sleep(@<延时>);
    }

    方法 消息_模拟回车 <公开 静态>
    参数 窗口句柄 <类型 = 变整数>
    参数 延时 <类型 = 整数 @默认值 = 30>
    {
        @ PostMessage((HWND)@<窗口句柄>,WM_KEYUP,@<键代码_常量类.回车键>,NULL);
        @ Sleep(@<延时>);
    }

    方法 消息_模拟按下某键 <公开 静态>
    参数 窗口句柄 <类型 = 变整数>
    参数 键代码 <类型 = 键代码_常量类>
    参数 延时 <类型 = 整数 @默认值 = 30>
    {
        @ PostMessage((HWND)@<窗口句柄>,WM_KEYDOWN,@<键代码>,NULL);
        @ Sleep(@<延时>);

    }

    方法 消息_模拟松开某键 <公开 静态>
    参数 窗口句柄 <类型 = 变整数>
    参数 键代码 <类型 = 键代码_常量类>
    参数 延时 <类型 = 整数 @默认值 = 30>
    {
        @ PostMessage((HWND)@<窗口句柄>,WM_KEYUP,@<键代码>,NULL);
        @ Sleep(@<延时>);


    }

    方法 消息_模拟输入文本 <公开 静态>
    参数 窗口句柄 <类型 = 变整数>
    参数 要输入的文本 <类型 = 文本型>
    参数 延时 <类型 = 整数 @默认值 = 30>
    {
        @ const TCHAR* lpText = (const TCHAR*) @<要输入的文本>;
        @ INT nLen = lstrlen(lpText);
        @ for(int i = 0; i < nLen; i++)
        @ {
        @  PostMessage((HWND)@<窗口句柄>,WM_CHAR,(WPARAM)lpText[i],NULL);
        @  Sleep(@<延时>);
        @ }
    }

    #
}

