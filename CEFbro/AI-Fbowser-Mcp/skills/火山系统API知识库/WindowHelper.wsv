    方法 窗口_到前台_第一步骤设置广播 <公开 静态 注释 = "代码出处 https://www.cnblogs.com/dengpeng1004/p/5049646.html" 折叠>
    {

        // BOOL SystemParametersInfo(
        // UINT uiAction,  // system parameter to retrieve or set
        // UINT uiParam,   // depends on action to be taken
        // PVOID pvParam,  // depends on action to be taken
        // UINT fWinIni    // user profile update option);
        @ DWORD dwTimeout = -1;  
        @ SystemParametersInfo(SPI_GETFOREGROUNDLOCKTIMEOUT, 0, (LPVOID)&dwTimeout, 0);  
        @ if (dwTimeout >= 100) {  
        @     SystemParametersInfo(SPI_SETFOREGROUNDLOCKTIMEOUT, 0, (LPVOID)0, SPIF_SENDCHANGE | SPIF_UPDATEINIFILE);  
        @ }  

    }

    方法 窗口_到前台_第二步骤 <公开 静态 注释 = "代码出处 https://www.cnblogs.com/dengpeng1004/p/5049646.html" 折叠>
    参数 窗口句柄 <类型 = 长整数>
    {
        @ HWND hForeWnd = NULL; 
        @ HWND hWnd= FindWindow(NULL,_T("")); 
        @ DWORD dwForeID; 
        @ DWORD dwCurID; 
        @ hForeWnd =  GetForegroundWindow(); 
        @ dwCurID =  GetCurrentThreadId(); 
        @ dwForeID =  GetWindowThreadProcessId( hForeWnd, NULL ); 
        @ AttachThreadInput( dwCurID, dwForeID, TRUE); 
        @ ShowWindow((HWND) @<窗口句柄>, SW_SHOWNORMAL ); 
        @ SetWindowPos( (HWND) @<窗口句柄>, HWND_TOPMOST, 0,0,0,0, SWP_NOSIZE|SWP_NOMOVE ); 
        @ SetWindowPos( (HWND) @<窗口句柄>, HWND_NOTOPMOST, 0,0,0,0, SWP_NOSIZE|SWP_NOMOVE ); 
        @ SetForegroundWindow( (HWND) @<窗口句柄> ); 
        @ AttachThreadInput( dwCurID, dwForeID, FALSE);

    }

