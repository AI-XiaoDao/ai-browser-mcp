        @ (@dt<变整数>)::GetWindow ((HWND)@<窗口句柄>, @<类型>)

    }

    方法 "//窗口_取控件ID" <公开 静态 类型 = 变整数>
    参数 窗口句柄 <类型 = 整数>
    {
