    方法 启用窗口过程 <公开>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否启用 <类型 = 逻辑型 @默认值 = 真>
    参数 启用拖放 <类型 = 逻辑型 @默认值 = 真>
    {
        @ m_hWnd = (HWND)@<窗口句柄>;
        @ if(@<是否启用>)
        @ {
        @     if(!m_OldWndProc) 
        @     {
        @        ::SetWindowLongPtr(m_hWnd,GWLP_USERDATA, (LONG_PTR)this);
        @         m_OldWndProc = ::SetWindowLongPtr(m_hWnd,GWLP_WNDPROC,(LONG_PTR)WindowProc);
        @      }
        @ }
        @ else
        @ {
        @    if(m_hWnd && m_OldWndProc)
        @    {
        @       ::SetWindowLongPtr(m_hWnd,GWLP_WNDPROC,(LONG_PTR)m_OldWndProc);
        @    }
        @ }
        @ ::DragAcceptFiles(m_hWnd,@<启用拖放>);
    }
}

