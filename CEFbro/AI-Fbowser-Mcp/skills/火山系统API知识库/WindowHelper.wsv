    方法 窗口_移动 <公开 静态 "">
    参数 窗口句柄 <类型 = 变整数>
    参数 横坐标 <类型 = 整数 注释 = "-1代表不变动" @默认值 = -1>
    参数 纵坐标 <类型 = 整数 @默认值 = -1>
    参数 宽度 <类型 = 整数 @默认值 = -1>
    参数 高度 <类型 = 整数 @默认值 = -1>
    参数 是否重绘 <类型 = 逻辑型 @默认值 = 假>
    {

        变量 原始横坐标 <类型 = 整数>
        变量 原始纵坐标 <类型 = 整数>
        变量 原始窗口宽度 <类型 = 整数>
        变量 原始窗口高度 <类型 = 整数>
        @ RECT rt;
        @ ::GetWindowRect((HWND)@<窗口句柄>,&rt);
        @ @<原始横坐标> = rt.left;
        @ @<原始纵坐标> = rt.top;
        @ @<原始窗口宽度> = rt.right- rt.left;
        @ @<原始窗口高度> = rt.bottom - rt.top;

        变量 新横坐标 <类型 = 整数>
        变量 新纵坐标 <类型 = 整数>
        变量 新宽度 <类型 = 整数>
        变量 新高度 <类型 = 整数>
        如果 (横坐标 == -1)
        {
            新横坐标 = 原始横坐标
        }
        否则
        {
            新横坐标 = 横坐标
        }

        如果 (纵坐标 == -1)
        {
            新纵坐标 = 原始纵坐标
        }
        否则
        {
            新纵坐标 = 纵坐标
        }

        如果 (宽度 == -1)
        {
            新宽度 = 原始窗口宽度
        }
        否则
        {
            新宽度 = 宽度
        }

        如果 (高度 == -1)
        {
            新高度 = 原始窗口高度
        }
        否则
        {
            新高度 = 高度
        }

        MoveWindow (窗口句柄, 新横坐标, 新纵坐标, 新宽度, 新高度, 是否重绘)


    }

