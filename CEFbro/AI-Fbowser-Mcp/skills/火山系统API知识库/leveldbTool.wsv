<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "leveldb-1.23" 注释 = "https://github.com/google/leveldb/blob/main/doc/index.md"
        @文档 = "category = \"开源库.leveldb\"" "" @视窗.外部头文件 = "leveldb\\leveldbTool.h" @视窗.外部库.win32 = "leveldb\\leveldbToolx86.lib"
        @视窗.附属文件.win32 = "leveldb\\leveldbToolx86.dll" @视窗.外部库.x64 = "leveldb\\leveldbToolx64.lib"
        @视窗.附属文件.x64 = "leveldb\\leveldbToolx64.dll">

类 ______leveldb全局类 <公开 @全局类 = 真>
{

    # @begin
    # <> <include>
    # void* m_pData;
    # <> </include>
    # @end

    方法 等级数据库_创建 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (INT_P)leveldb_DB_New()
    }

    方法 等级数据库_销毁 <公开 静态 @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    {
        @ leveldb_DB_Delete((void*)@<数据库句柄>)
    }

    方法 等级数据库_打开配置_置不存在创建 <公开 静态 注释 = "再 打开 前调用 ，一般用作 写配置的时候才用" @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    参数 是否启用不存在创建 <类型 = 逻辑型>
    {
        @ leveldb_DB_Options_Set_create_if_missing( (void*)@<数据库句柄>,@<是否启用不存在创建> )

    }

    方法 等级数据库_打开数据库 <公开 静态 类型 = 逻辑型 返回值注释 = "如果为假 可以调用 等级数据库_取错误信息（）" @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    参数 数据库名称 <类型 = 文本型>
    {
        @ leveldb_DB_Open(  (void*)@<数据库句柄>, GetMbsText(@<数据库名称>, CVolMem(), NULL) )
    }

    方法 等级数据库_关闭数据库 <公开 静态 @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    {
        @ leveldb_DB_Close((void*)@<数据库句柄>)
    }

    方法 等级数据库_置文本 <公开 静态 类型 = 逻辑型 返回值注释 = "如果为假 可以调用 等级数据库_取错误信息（）" @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    参数 键名称 <类型 = 文本型>
    参数 键值 <类型 = 文本型>
    {
        @ leveldb_DB_Put((void*)@<数据库句柄>, CU8String(@<键名称>.GetText ()).GetText (),CU8String(@<键值>.GetText ()).GetText ())
    }

    方法 等级数据库_取文本 <公开 静态 类型 = 逻辑型 返回值注释 = "如果为假 可以调用 等级数据库_取错误信息（）" @禁止流程检查 = 真>
    参数 数据库句柄 <类型 = 变整数>
    参数 键名称 <类型 = 文本型>
    参数 输出_键值 <类型 = 文本型 注释 = "用来保存取出来的文本">
    {
        @ void* pValue = leveldb_DB_std_string_new();
        @ bool bOK = leveldb_DB_Get( (void*)@<数据库句柄>,  CU8String(@<键名称>.GetText ()).GetText () , pValue);
        @ @<输出_键值> =  leveldb_DB_std_string_GetText(pValue);
        @ leveldb_DB_std_string_Delete(pValue);
        @ return bOK;

    }

    方法 等级数据库_删除 <公开 静态 类型 = 逻辑型 返回值注释 = "如果为假 可以调用 等级数据库_取错误信息（）" @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    参数 键名称 <类型 = 文本型>
    {
        @ leveldb_DB_DeleteKey( (void*)@<数据库句柄>, CU8String(@<键名称>.GetText ()).GetText () )
    }

    方法 等级数据库_取错误信息 <公开 静态 类型 = 文本型 @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    {
        @ CVolString( leveldb_DB_GetErrorText( (void*)@<数据库句柄>) )
    }

    方法 等级数据库_枚举 <公开 静态 注释 = "void FUCTIONTYPE leveldb_DB_EnumKV(void* p, void* pUser, pEnumCallBack pCallback);" @嵌入式方法 = "">
    参数 数据库句柄 <类型 = 变整数>
    参数 用户数据 <类型 = 变整数>
    参数 回调函数 <@匹配方法 = "等级数据库枚举回调">
    {
        @ leveldb_DB_EnumKV( (void*)@<数据库句柄>,(void*)@<用户数据>,(pEnumCallBack)@<回调函数> )
    }

    方法 等级数据库枚举回调 <公开 静态 类型 = 整数 注释 = "typedef int (FUCTIONTYPE* pEnumCallBack)(const char* k, const char* v, void* pUser);"
            返回值注释 = "返回1 表示停止枚举 0，表示继续">
    参数 键文本指针 <类型 = 变整数>
    参数 值文本指针 <类型 = 变整数>
    参数 用户数据 <类型 = 变整数>
    {
        返回 (0)
    }

    #
    #
    #
    #
}

类 CleveldbHandle <@禁止创建对象 = 真>
{
    方法 类_清理
    {
        关闭 ()
    }

    方法 关闭 <公开>
    {
        如果 (句柄 != 0)
        {
            等级数据库_销毁 (句柄)
            调试输出 ("调用销毁")
            句柄 = 0
        }
    }

    变量 句柄 <公开 类型 = 变整数 值 = 0>
}

类 等级数据库类 <公开 基础类 = 参考对象模板类 @模板实现类 = "CleveldbHandle">
{
    方法 取最后一次错误信息文本 <公开 类型 = 文本型>
    {
        返回 (等级数据库_取错误信息 (参考数据.句柄))
    }

    方法 打开预配置_是否不存在则创建 <公开 属性写 返回值注释 = "如果数据库不存在，则打开的时候 会创建">
    参数 是否启用 <类型 = 逻辑型>
    {
        等级数据库_打开配置_置不存在创建 (参考数据.句柄, 是否启用)

    }

    方法 类_初始化
    {
        如果 (参考数据.句柄 == 0)
        {
            参考数据.句柄 = 等级数据库_创建 ()
        }
    }

    方法 打开 <公开 类型 = 逻辑型 返回值注释 = "如果返回假 可以调用 取最后一次错误信息文本 查看错误信息">
    参数 数据库名称 <类型 = 文本型>
    {
        返回 (等级数据库_打开数据库 (参考数据.句柄, 数据库名称))
    }

    方法 关闭 <公开>
    {
        等级数据库_关闭数据库 (参考数据.句柄)
    }

    方法 置文本 <公开 类型 = 逻辑型 返回值注释 = "如果返回假 可以调用 取最后一次错误信息文本 查看错误信息">
    参数 键 <类型 = 文本型>
    参数 值 <类型 = 文本型>
    {
        返回 (等级数据库_置文本 (参考数据.句柄, 键, 值))
    }

    方法 取文本 <公开 类型 = 逻辑型 返回值注释 = "如果返回假 可以调用 取最后一次错误信息文本 查看错误信息">
    参数 键 <类型 = 文本型>
    参数 输出_值 <类型 = 文本型 注释 = "用来保存枚举到的值">
    {
        返回 (等级数据库_取文本 (参考数据.句柄, 键, 输出_值))
    }

    方法 删除 <公开 类型 = 逻辑型 返回值注释 = "如果返回假 可以调用 取最后一次错误信息文本 查看错误信息">
    参数 键 <类型 = 文本型>
    {
        返回 (等级数据库_删除 (参考数据.句柄, 键))


    }

    方法 _内部静态枚举回调模板 <静态 类型 = 整数 注释 = "typedef int (FUCTIONTYPE* pEnumCallBack)(const char* k, const char* v, void* pUser);"
            返回值注释 = "返回1 表示停止枚举 0，表示继续">
    参数 键文本指针 <类型 = 变整数>
    参数 值文本指针 <类型 = 变整数>
    参数 用户数据 <类型 = 变整数>
    {
        变量 键 <类型 = 文本型>
        变量 值 <类型 = 文本型>
        键 = 多字节指针到文本 (键文本指针)
        值 = 多字节指针到文本 (值文本指针)
        返回 (指针_到自定义类型 (等级数据库类, 用户数据).键值枚举回调 (键, 值))
    }

    方法 多字节指针到文本 <静态 类型 = 文本型 @嵌入式方法 = "">
    参数 指针 <类型 = 变整数>
    {
        @ CVolString( (const char*)@<指针> )

    }

    方法 键值枚举回调 <公开 定义事件 类型 = 整数 返回值注释 = "返回1 表示停止枚举 返回 0表示继续">
    参数 键 <类型 = 文本型>
    参数 值 <类型 = 文本型>
    {

    }

    方法 枚举键值 <公开>
    {
        等级数据库_枚举 (参考数据.句柄, 指针_取变量指针 (本对象), _内部静态枚举回调模板)
    }

    #
}
