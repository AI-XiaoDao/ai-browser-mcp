<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 启动类 <公开 基础类 = 程序类>
{
    变量 主窗口 <类型 = 普通窗口>

    方法 启动方法 <公开 类型 = 整数>
    {
        炫彩_初始化 ()  // 炫彩三部曲中的第一部->初始化UI库,参数1默认为空,即为:假=GDI+渲染,否则:真=D2D渲染
        // 下面是窗口的创建及元素或其他工作安排
        主窗口.创建 (, , 600, 400, "炫彩界面库窗口", , )
        //这里是炫彩元素组件的创建或其他工作





        主窗口.显示 ()
        炫彩_运行 ()  // 炫彩三部曲中的第二部->运行UI库
        //这里可以用来释放一些模板
        炫彩_退出 ()  // 炫彩三部曲中的第三部->退出UI库
        返回 (0)
    }
}
