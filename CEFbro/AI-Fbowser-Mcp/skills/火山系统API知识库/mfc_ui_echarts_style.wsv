        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ return getJSON();
    }

    方法 显示在图形上方 <公开 属性写 注释 = "视觉引导线是否显示在图形上方">
    参数 是否上方显示 <类型 = 逻辑型 注释 = "是否上方显示" @默认值 = 假>
    {
        @ SetData (_T("showAbove"), (@<是否上方显示> ? _T("true") : _T("false")));
    }

    方法 长度 <公开 属性写 注释 = "视觉引导线的长度">
    参数 长度值 <类型 = 整数 注释 = "长度值">
    {
        @ SetData (_T("length"), @<长度值>);
    }

    方法 二段长度 <公开 属性写 注释 = "视觉引导线第二段的长度">
    参数 长度值 <类型 = 整数 注释 = "长度值">
    {
        @ SetData (_T("length2"), @<长度值>);
    }

    方法 最小夹角 <公开 属性写 注释 = "限制引导线两端之间最小的夹角,以防止过小的夹角导致显示不美观." 折叠>
    参数 夹角值 <类型 = 整数 注释 = "可以设置为 0 - 180 度">
    {
        @ SetData (_T("minTurnAngle"), @<夹角值>);
    }

    方法 平滑曲线 <公开 属性写 注释 = "是否启用平滑视觉引导线,默认不平滑.">
    参数 是否启用 <类型 = 逻辑型 注释 = "默认关闭" @默认值 = 假>
    {
        @ SetData (_T("smooth"), (@<是否启用> ? _T("true") : _T("false")));
    }
}

类 标记图形基础类 <基础类 = 图表参数基础类 注释 = "数据图形样式和标记样式" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 标记图形 <公开 属性写 注释 = "标记的图形形状">
    参数 图形类型 <类型 = 标记图形形状 注释 = "提供标记图形形状常量" @默认值 = 标记图形形状.水滴>
    {
        @ SetDataStr (_T("symbol"), (@dt<文本型>)@<图形类型>);
    }

    方法 标记图形2 <公开 属性写 注释 = "标记的图形,扩展方法,用于自定义图形.">
    参数 标记图形 <类型 = 文本型 注释 = "可以通过 \'image://url\' 设置为图片,其中 URL 为图片的链,或者 dataURI. 也可以通过 \'path://\' 将图标设置为任意的矢量路径.">
    {
        @ SetDataStr (_T("symbol"), @<标记图形>);
    }

    方法 标记图形尺寸 <公开 属性写 注释 = "图形标记大小">
    参数 标记大小 <类型 = 整数 注释 = "标记大小值">
    {
        @ SetData (_T("symbolSize"), @an<CVolString> (@<标记大小>)); 
    }

    方法 标记图形尺寸2 <公开 属性写 注释 = "图形标记大小">
    参数 标记大小 <类型 = 文本型 注释 = "可以设置成诸如\'10\'这样单一的数值文本,也可以用数组分开表示宽和高,例如 \'[20, 10]\' 表示标记宽为20,高为10.">
    {
        @ SetData (_T("symbolSize"), @<标记大小>);
    }

    方法 标记图形旋转角度 <公开 属性写 注释 = "标记图形旋转角度">
    参数 旋转角度 <类型 = 整数 注释 = "正值表示逆时针旋转">
    {
        @ SetData (_T("symbolRotate"), @an<CVolString> (@<旋转角度>));
    }

    方法 保持标记图形比例 <公开 属性写 注释 = "如果标记图形是 path:// 的形式,是否在缩放时保持该图形的长宽比.">
    参数 是否保持长宽比 <类型 = 逻辑型 注释 = "是否保持长宽比">
    {
        @ SetData (_T("symbolKeepAspect"), (@<是否保持长宽比> ? _T("true") : _T("false")));
    }

    方法 标记图形偏移 <公开 属性写 注释 = "标记相对于原本位置的偏移">
    参数 偏移值文本 <类型 = 文本型 注释 = "  提供一个具有两个成员的js数组文本,成员可以是绝对的像素值,也可以是相对的百分比."
            注释 = "如:\"[0, \'-50%\']\" 首个成员代表横向偏移距离,第二个成员代表纵向偏移距离.">
    {
        @ SetData (_T("symbolOffset"), @<偏移值文本>);
    }

    方法 静默 <公开 属性写 注释 = "静默模式,即图形是否响应和触发鼠标事件.">
    参数 是否静默 <类型 = 逻辑型 注释 = "是否静默" @默认值 = 假>
    {
        @ SetData (_T("silent"), (@<是否静默> ? _T("true") : _T("false")));
    }
}

类 图表标注类 <公开 基础类 = 标记图形基础类 注释 = "图表标注,标注线,标域配置." @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 标签样式 <公开 类型 = 标签样式类 注释 = "标线标签样式">
    变量 悬停高亮样式 <公开 类型 = 悬停高亮类 注释 = "标线的高亮样式">
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "标线线条样式">
    变量 图形样式 <公开 类型 = 图形样式类 注释 = "标域的样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<标签样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("label"), str);
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ str = @<图形样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("itemStyle"), str);
        @ str = @<悬停高亮样式.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("emphasis"), str);
        变量 标注数据集 <类型 = 对象数组类>
        变量 自定标线标域 <类型 = 对象数组类>
        @ @<标注数据集>= data().objArr;
        @ @<自定标线标域>= data().objArr2;
        如果 (标注数据集.取成员数 () > 0)
        {
            变量 data <类型 = 文本型 值 = "[">
            标注数据集.枚举循环 ()
            {
                data = 选择 (data == "[", data + 标注数据集.取指定类型枚举值 (标注配置类).取文本 (), data + "," + 标注数据集.取指定类型枚举值 (标注配置类).取文本 ())
            }
            如果 (自定标线标域.取成员数 () > 0)
            {
                变量 data2 <类型 = 文本型>
                自定标线标域.枚举循环 ()
                {
                    data2 = 选择 (data2 == "", data2 + 自定标线标域.取指定类型枚举值 (自定标线标域类).取文本 (), data2 + "," + 自定标线标域.取指定类型枚举值 (自定标线标域类).取文本 ())
                }
                data = data + "," + data2 + "]"
            }
            否则
            {
                data = data + "]"
            }
            @ SetData(_T("data"), @<data>);
        }
        否则
        {
            如果 (自定标线标域.取成员数 () > 0)
            {
                变量 data2 <类型 = 文本型>
                自定标线标域.枚举循环 ()
                {
                    data2 = 选择 (data2 == "", data2 + 自定标线标域.取指定类型枚举值 (自定标线标域类).取文本 (), data2 + "," + 自定标线标域.取指定类型枚举值 (自定标线标域类).取文本 ())
                }
                data2 = "[" + data2 + "]"
                @ SetData(_T("data"), @<data2>);
            }
        }
        @ return getJSON();
    }

    方法 创建标注 <公开 类型 = 标注配置类 注释 = "创建一个标注配置" 返回值注释 = "返回标注配置类对象" @视窗.返回参考 = 真 @禁止流程检查 = 真>
    参数 标注名称 <类型 = 文本型 注释 = "标注名称">
    参数 标注类型 <类型 = 图表标注类型 注释 = "提供图表标注类型常量">
    {
        变量 数据成员 <类型 = 标注配置类>
        数据成员.标注名称 = 标注名称
        数据成员.标注类型 = 标注类型
        @ CVolObject* pNewVolObject;
        @ data().objArr.Add (@<数据成员>, &pNewVolObject); 
        @ return (@dt<标注配置类>&)*pNewVolObject;
    }

    方法 添加标注 <公开 类型 = 标注配置类 注释 = "添加一个标注配置" 返回值注释 = "返回所添加的对象" @视窗.返回参考 = 真 @禁止流程检查 = 真>
    参数 数据对象 <类型 = 标注配置类 注释 = "提供标注配置类对象">
    {
        @ CVolObject* pNewVolObject;
        @ data().objArr.Add (@<数据对象>, &pNewVolObject); 
        @ return (@dt<标注配置类>&)*pNewVolObject;
    }

    方法 删除标注 <公开 注释 = "删除一个标注配置">
    参数 索引位置 <类型 = 整数 注释 = "索引从0开始,-1表示最后一个" @默认值 = -1>
    {
        @ if (@<索引位置> == -1)
        @     @<索引位置> = (INT)data().objArr.GetCount () - 1;
        @ if (data().objArr.IsIndexValid(@<索引位置>))
        @    data().objArr.RemoveAt(@<索引位置>,1);
    }

    方法 取标注数 <公开 类型 = 整数 注释 = "取当前标注对象的标注配置数" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data().objArr.GetCount ()
    }

    方法 取标注 <公开 类型 = 标注配置类 注释 = "取标注配置类对象" @视窗.返回参考 = 真 @禁止流程检查 = 真>
    参数 索引位置 <类型 = 整数 注释 = "索引从0开始 默认(-1)为最后一个" @默认值 = -1>
    {
        @ if (@<索引位置>==-1)
        @     @<索引位置>=(INT)data().objArr.GetCount ()-1;
        @ if (data().objArr.IsIndexValid(@<索引位置>))
        @     return (@dt<标注配置类>&)data().objArr.GetAt (@<索引位置>, VOL_RUNTIME_CLASS (@dt<标注配置类>), @dt<标注配置类> ());
        @ return (@dt<标注配置类>&)data().objArr.GetAt ( (INT)data().objArr.GetCount ()-1, VOL_RUNTIME_CLASS (@dt<标注配置类>), @dt<标注配置类> ());
    }

    方法 添加自定标线或标域 <公开 类型 = 自定标线标域类 注释 = "向当前标注配置中添加一个自定义标线标域" 返回值注释 = "返回所添加的自定义标线标域" @视窗.返回参考 = 真 @禁止流程检查 = 真>
    参数 数据对象 <类型 = 自定标线标域类 注释 = "提供一个自定标线标域类对象">
    {
        @ CVolObject* pNewVolObject;
        @ data().objArr2.Add (@<数据对象>, &pNewVolObject); 
        @ return (@dt<自定标线标域类>&)*pNewVolObject;
    }

    方法 清空 <公开 注释 = "清空当前标注配置">
    {
        @ data().objArr.RemoveAll ();
        @ data().objArr2.RemoveAll ();
    }
}

类 标注配置类 <公开 基础类 = 标记图形基础类 注释 = "标注,标注线,标域的配置数据." @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "标线的线条样式">
    变量 标签样式 <公开 类型 = 标签样式类 注释 = "标签样式">
    变量 悬停状态 <公开 类型 = 悬停高亮类 注释 = "悬停高亮样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<标签样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("label"), str);
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ str = @<悬停状态.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("emphasis"), str);
        @ return getJSON();
    }

    方法 标注类型 <公开 属性写 注释 = "特殊的标注类型,用于标注最大值最小值等." 折叠>
    参数 标注类型值 <类型 = 图表标注类型 注释 = "提供图表标注类型常量">
    {
        @ SetDataStr (_T("type"), (@dt<文本型>)@<标注类型值>);
    }

    方法 标注名称 <公开 属性写 注释 = "标注名称,将会作为文字显示" 折叠>
    参数 名称 <类型 = 文本型 注释 = "标注名称">
    {
        @ SetDataStr (_T("name"), @<名称>);
    }

    方法 标注值 <公开 属性写 注释 = "标注值,可以不设" 折叠>
    参数 标注值文本 <类型 = 文本型 注释 = "标注值">
    {
        @ SetDataStr (_T("value"), @an<CVolString> (@<标注值文本>));
    }

    方法 标注坐标位置 <公开 属性写 注释 = "标注的坐标,坐标格式视系列的坐标系而定,可以是直角坐标系上的横向位置,纵向位置,也可以是极坐标系上的半径,角度.例如 \"[121, 2323]\" 或 \"[\'aa\', 998]\"" 折叠>
    参数 坐标值 <类型 = 文本型 注释 = "提供一个数组文本">
    {
        @ SetData (_T("coord"), @<坐标值>);
    }

    方法 横向位置 <公开 属性写 注释 = "相对图表容器的屏幕横向位置坐标">
    参数 坐标值 <类型 = 文本型 注释 = "横向坐标,单位像素,也可以是百分比值如:\"10%\"">
    {
        如果 (寻找文本 (坐标值, "%") != -1)
        {
            @ SetDataStr (_T("x"), @<坐标值>);
        }
        否则
        {
            @ SetData (_T("x"), @<坐标值>);
        }
    }

    方法 纵向位置 <公开 属性写 注释 = "相对图表容器的纵向位置坐标" 折叠>
    参数 坐标值 <类型 = 文本型 注释 = "纵向坐标,单位像素.也可以是百分比值如:\"10%\"">
    {
        如果 (寻找文本 (坐标值, "%") != -1)
        {
            @ SetDataStr (_T("y"), @<坐标值>);
        }
        否则
        {
            @ SetData (_T("y"), @<坐标值>);
        }
    }

    方法 横轴位置 <公开 属性写 注释 = "相对横轴刻度的位置坐标" 折叠>
    参数 坐标值 <类型 = 文本型 注释 = "提供一个值文本,也可以是百分比值如:\"10%\"">
    {
        如果 (寻找文本 (坐标值, "%") != -1)
        {
            @ SetDataStr (_T("xAxis"), @<坐标值>);
        }
        否则
        {
            @ SetData (_T("xAxis"), @<坐标值>);
        }
    }

    方法 纵轴位置 <公开 属性写 注释 = "相对纵轴刻度的位置坐标" 折叠>
    参数 坐标值 <类型 = 文本型 注释 = "提供一个值文本,也可以是百分比值如:\"10%\"">
    {
        如果 (寻找文本 (坐标值, "%") != -1)
        {
            @ SetDataStr (_T("yAxis"), @<坐标值>);
        }
        否则
        {
            @ SetData (_T("yAxis"), @<坐标值>);
        }
    }

    方法 横轴位置2 <公开 属性写 注释 = "相对横轴刻度的位置坐标" 折叠>
    参数 坐标值 <类型 = 图表标注类型 注释 = "提供图表标注类型">
    {
        @ SetDataStr (_T("xAxis"), @<坐标值>);
    }

    方法 纵轴位置2 <公开 属性写 注释 = "相对纵轴刻度的位置坐标" 折叠>
    参数 坐标值 <类型 = 图表标注类型 注释 = "提供图表标注类型">
    {
        @ SetDataStr (_T("yAxis"), @<坐标值>);
    }

    方法 维度索引 <公开 属性写 注释 = "在使用 标注类型 时有效,用于指定在哪个维度上指定最大值最小值，可以是 0:(横轴,半径轴）1:(纵轴,角度轴)默认使用第一个数值轴所在的维度" 折叠>
    参数 索引 <类型 = 整数 注释 = "提供图表标注类型常量">
    {
        @ SetData (_T("valueIndex"), (@dt<文本型>)@<索引>);
    }

    方法 维度名称 <公开 属性写 注释 = "在使用 标注类型 时有效,用于指定在哪个维度上指定最大值最小值，这可以是维度的直接名称，例如折线图时可以是x、angle等、K线图时可以是open、close等维度名称。">
    参数 索引 <类型 = 文本型 注释 = "提供图表标注类型常量">
    {
        @ SetDataStr (_T("valueDim"), @<索引>);
    }
}

类 自定标线标域类 <公开 基础类 = 参考对象类 注释 = "自定标注线,标域的配置数据." 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 起点配置 <公开 类型 = 标注配置类 注释 = "用于设置标线,标域的起点配置参数">
    变量 终点配置 <公开 类型 = 标注配置类 注释 = "用于设置标线,标域的终点配置参数">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        变量 起点数据 <类型 = 文本型>
        变量 终点数据 <类型 = 文本型>
        起点数据 = 起点配置.取文本 ()
        终点数据 = 终点配置.取文本 ()
        如果 (起点数据 != "" && 终点数据 != "")
        {
            返回 ("[" + 起点数据 + "," + 终点数据 + "]")
        }
        返回 ("")
    }
}

类 刷选范围样式 <公开 基础类 = 图表参数基础类 注释 = "区域选择组件或视觉映射组件选中范围内或选中范围外的样式设定" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 标记图形 <公开 属性写 注释 = "标记的图形形状">
    参数 图形类型 <类型 = 标记图形形状 注释 = "提供标记图形形状常量">
    {
        @ SetDataStr (_T("symbol"), (@dt<文本型>)@<图形类型>);
    }

    方法 标记图形2 <公开 属性写 注释 = "标记的图形,扩展方法,用于自定义图形.">
    参数 标记图形 <类型 = 文本型 注释 = "可以通过 \'image://url\' 设置为图片,其中 URL 为图片的链,或者 dataURI. 也可以通过 \'path://\' 将图标设置为任意的矢量路径.">
    {
        @ SetDataStr (_T("symbol"), @<标记图形>);
    }

    方法 颜色 <公开 属性写 注释 = "图表元素的颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        如果 (到小写 (颜色值文本) == "null")
        {
            @ SetData (_T("color"), _T("null"));
        }
        如果 (取文本左边 (颜色值文本, 1) == "[" && 取文本右边 (颜色值文本, 1) == "]")
        {
            @ SetData (_T("color"), @<颜色值文本>);
        }
        否则
        {
            @ SetDataStr (_T("color"), @<颜色值文本>);
        }
    }

    方法 颜色透明度 <公开 属性写 注释 = "图形元素颜色的透明度支持从 0 到 1 的小数数字,为0时不绘制该图形.">
    参数 透明度值 <类型 = 小数 注释 = "0 到 1 的小数值" @默认值 = 1>
    {
        @ SetData (_T("colorAlpha"), @an<CVolString> (@<透明度值>));
    }

    方法 颜色明暗度 <公开 属性写 注释 = "颜色的明暗度">
    参数 明暗度值 <类型 = 文本型>
    {
        @ SetData (_T("colorLightness"), @an<CVolString> (@<明暗度值>));
    }

    方法 颜色饱和度 <公开 属性写 注释 = "颜色的饱和度">
    参数 饱和度值 <类型 = 文本型>
    {
        @ SetData (_T("colorSaturation"), @an<CVolString> (@<饱和度值>));
    }

    方法 透明度 <公开 属性写 注释 = "图形元素及其附属物(如文字标签)的透明度,支持从 0 到 1 的小数数字,为0时不绘制该图形.">
    参数 透明度值 <类型 = 小数 注释 = "0 到 1 的小数值" @默认值 = 1>
    {
        @ SetData (_T("opacity"), @an<CVolString> (@<透明度值>));
    }
}

类 图表动画设置类 <公开 基础类 = 图表参数基础类 注释 = "设置图表及各组件的动画效果参数." @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 开启动画 <公开 属性写 注释 = "是否开启动画">
    参数 是否开启动画 <类型 = 逻辑型 注释 = "默认开启" @默认值 = 真>
    {
        @ SetData (_T("animation"), (@<是否开启动画> ? _T("true") : _T("false")));
    }

    方法 动画开启阈值 <公开 属性写 注释 = "是否开启动画的阈值">
    参数 动画阈值 <类型 = 整数 注释 = "单位毫秒,当单个系列显示的图形数量大于这个阈值时会关闭动画." @默认值 = 2000>
    {
        @ SetData (_T("animationThreshold"), CVolString(@<动画阈值>));
    }

    方法 初始动画效果 <公开 属性写 注释 = "初始动画效果">
    参数 动画效果类型 <类型 = 图表动画效果 注释 = "提供图表动画效果常量" @默认值 = 图表动画效果.展开>
    {
        @ SetDataStr (_T("animationType"), CVolString(@<动画效果类型>));
    }

    方法 初始动画时长 <公开 属性写 注释 = "初始动画的时长" 折叠>
    参数 动画时长 <类型 = 整数 注释 = "默认为1000毫秒,即1秒." @默认值 = 1000>
    {
        @ SetData (_T("animationDuration"), CVolString(@<动画时长>));
    }

    方法 初始动画时长递增 <公开 属性写 注释 = "设置每个数据图形初始动画的时长递增实现更戏剧的初始动画效果" 折叠>
    参数 递增时长 <类型 = 整数 注释 = "动画依次递增时长">
    {
        变量 animationDuration <类型 = 文本型>
        animationDuration = "function (idx) {return idx * " + 到文本 (递增时长) + "}"
        @ SetData (_T("animationDuration"), @<animationDuration>);
    }

    方法 初始动画时长_脚本 <公开 属性写 注释 = "初始动画的时长函数,可以通过每个数据返回不同的时间实现更戏剧的初始动画效果." 折叠>
    参数 动画时长脚本 <类型 = 文本型 注释 = "提供一个JS方法文本,该方法中的参数代表当前数据的索引 例如:" 注释 = "function (idx) {"
            注释 = "    return idx * 100;  // 越往后的数据时长越大." 注释 = "}">
    {
        @ SetData (_T("animationDuration"), @<动画时长脚本>);
    }

    方法 初始动画缓动效果 <公开 属性写 注释 = "初始动画的缓动效果" 折叠>
    参数 缓动效果类型 <类型 = 图表动画缓动效果 注释 = "提供图表动画缓动效果常量">
