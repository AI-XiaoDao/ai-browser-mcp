类 轴刻度配置类 <公开 基础类 = 图表参数基础类 注释 = "坐标轴刻度与次刻度相关设置" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "坐标轴刻度线线条样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" 折叠 @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);

        @ return getJSON();
    }

    方法 与类目标签对齐 <公开 属性写 注释 = "在类目轴边界留白为真时候有效,可以保证刻度线和标签对齐.">
    参数 是否对齐 <类型 = 逻辑型 注释 = "真为对齐" @默认值 = 真>
    {
        @ SetData (_T("alignWithLabel"), (@<是否对齐> ? _T("true") : _T("false")));
    }

    方法 刻度间隔 <公开 属性写 注释 = "坐标轴刻度的显示间隔,默认与轴的标签间隔一致,在类目轴中有效.">
    参数 间隔 <类型 = 整数 注释 = "默认会采用标签不重叠的策略间隔显示标签." 注释 = "可以设置成 0 强制显示所有标签."
            注释 = "如果设置为 1,表示『隔一个标签显示一个标签』,如果值为 2,表示隔两个标签显示一个标签,以此类推.">
    {
        @ SetData (_T("interval"), CVolString(@<间隔>));
    }

    方法 刻度朝内 <公开 属性写 注释 = "坐标轴刻度是否朝内,默认朝外.">
    参数 是否刻度朝内 <类型 = 逻辑型 注释 = "真为朝内" @默认值 = 假>
    {
        @ SetData (_T("inside"), (@<是否刻度朝内> ? _T("true") : _T("false")));
    }

    方法 长度 <公开 属性写 注释 = "坐标轴刻度的长度">
    参数 长度值 <类型 = 整数 注释 = "长度值,单位为像素." @默认值 = 5>
    {
        @ SetData (_T("length"), @an<CVolString> (@<长度值>));
    }

    方法 次刻度分割数 <公开 属性写 注释 = "次刻度线分割数,">
    参数 分割数 <类型 = 整数 注释 = "默认会分割成5段" @默认值 = 5>
    {
        @ SetData (_T("splitNumber"), @an<CVolString> (@<分割数>));
    }

    方法 分割刻度数 <公开 属性写 注释 = "分隔线之间分割的刻度数">
    参数 刻度数 <类型 = 整数 注释 = "默认会分割成5段" @默认值 = 5>
    {
        @ SetData (_T("splitNumber"), @an<CVolString> (@<刻度数>));
    }

    方法 与轴线距离 <公开 属性写 注释 = "刻度线与轴线的距离">
    参数 距离 <类型 = 整数 注释 = "与轴线距离">
    {
        @ SetData (_T("distance"), @an<CVolString> (@<距离>));
    }
}

