<火山程序 类型 = "通常" 版本 = 1 />

包 火山.ECharts <注释 = "火山MFC·Echarts图表控件,图表及元素样式参数配置.">

类 文本样式类 <公开 基础类 = 图表组件基础类 注释 = "图表元素的文字样式(textStyle)" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 文本颜色 <公开 属性写 注释 = "图表元素的文字的颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        @ SetDataStr (_T("color"), @<颜色值文本>);
    }

    方法 透明度 <公开 属性写 注释 = "文字的透明度,支持从 0 到 1 的小数数字,为0时不绘制该文字.">
    参数 透明度值 <类型 = 小数 注释 = "0 到 1 的小数值" @默认值 = 1>
    {
        @ SetData (_T("opacity"), @an<CVolString> (@<透明度值>));
    }

    方法 字体样式 <公开 属性写 注释 = "文字字体的风格">
    参数 是否斜体 <类型 = 逻辑型 注释 = "默认为通常风格,需要将字体设置为斜体时为真" @默认值 = 假>
    {
        @ SetDataStr (_T("fontStyle"), (@<是否斜体> ? _T("italic") : _T("normal")));
    }

    方法 使用斜体 <公开 属性写 注释 = "将字体的风格设置为斜体">
    参数 是否斜体 <类型 = 逻辑型 注释 = "默认为通常风格,需要将字体设置为斜体时为真" @默认值 = 假>
    {
        @ SetDataStr (_T("fontStyle"), (@<是否斜体> ? _T("italic") : _T("normal")));
    }

    方法 字体粗细 <公开 属性写 注释 = "文字字体的粗细">
    参数 字体粗细值 <类型 = 元素字体粗细 注释 = "提供元素字体粗细常量" @默认值 = 元素字体粗细.通常>
    {
        @ SetDataStr (_T("fontWeight"), @<字体粗细值>);
    }

    方法 字体粗细2 <公开 属性写 注释 = "文字字体的粗细">
    参数 字体粗细值 <类型 = 整数 注释 = "提供100-900的字体粗细值,400 等同于常量:元素字体粗细.通常,而 700 等同于元素字体粗细.粗体." @默认值 = 400>
    {
        @ SetData (_T("fontWeight"), @an<CVolString> (@<字体粗细值>)); 
    }

    方法 字体系列 <公开 属性写 注释 = "文字的字体系列" 折叠>
    参数 字体名称 <类型 = 文本型 注释 = "提供字体系列名称,可以是 \'serif\' , \'monospace\', \'Arial\', \'Courier New\', \'Microsoft YaHei\'...">
    {
        @ SetDataStr (_T("fontFamily"), @<字体名称>);
    }

    方法 字体大小 <公开 属性写 注释 = "文字的字体大小">
    参数 字体大小 <类型 = 整数 注释 = "提供字号大小" @默认值 = 12>
    {
        @ SetData (_T("fontSize"), @an<CVolString> (@<字体大小>)); 
    }

    方法 行高 <公开 属性写 注释 = "文本行高,如果没有设置,则会取父层级的." 折叠>
    参数 行高值 <类型 = 整数 注释 = "行高,值默认12." @默认值 = 12>
    {
        @ SetData (_T("lineHeight"), @an<CVolString> (@<行高值>)); 
    }

    方法 文本显示宽度 <公开 属性写 注释 = "文本显示宽度" 折叠>
    参数 宽度 <类型 = 整数 注释 = "宽度值" @默认值 = 0>
    {
        @ SetData (_T("width"), @an<CVolString> (@<宽度>)); 
    }

    方法 文本显示高度 <公开 属性写 注释 = "文本显示高度" 折叠>
    参数 高度 <类型 = 整数 注释 = "高度值" @默认值 = 0>
    {
        @ SetData (_T("height"), @an<CVolString> (@<高度>)); 
    }

    方法 文本边框颜色 <公开 属性写 注释 = "文字本身的描边颜色" 折叠>
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        @ SetDataStr (_T("textBorderColor"), @<颜色值文本>);
    }

    方法 文本边框宽度 <公开 属性写 注释 = "文字本身的描边宽度" 折叠>
    参数 边框宽度 <类型 = 整数 注释 = "描边宽度" @默认值 = 0>
    {
        @ SetData (_T("textBorderWidth"), @an<CVolString> (@<边框宽度>)); 
    }

    方法 文本边框类型 <公开 属性写 注释 = "文字本身的描边边框线类型">
    参数 边框类型 <类型 = 元素线条类型 注释 = "提供元素线条类型常量" @默认值 = 元素线条类型.无>
    {
        @ SetDataStr (_T("textBorderType"), @<边框类型>);
    }

    方法 文本边框虚线阵列 <公开 属性写 注释 = "用以指定线条的虚线阵列,配合虚线偏移可实现更灵活的虚线效果.">
    参数 阵列数组文本 <类型 = 文本型 注释 = "提供一个数组文本 如:\"[5,10]\"">
    {
        @ SetData (_T("textBorderType"), @<阵列数组文本>);
    }

    方法 文本边框虚线偏移 <公开 属性写 注释 = "用于设置文本边框虚线的偏移量,可搭配虚线类型边框,实现灵活的虚线效果.">
    参数 偏移量 <类型 = 整数 注释 = "偏移量" @默认值 = 5>
    {
        @ SetData (_T("textBorderDashOffset"), @an<CVolString> (@<偏移量>)); 
    }

    方法 文本阴影颜色 <公开 属性写 注释 = "文字本身的阴影颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        @ SetDataStr (_T("textShadowColor"), @<颜色值文本>);
    }

    方法 文本阴影模糊大小 <公开 属性写 注释 = "文字本身的阴影模糊大小">
    参数 模糊大小 <类型 = 整数 注释 = "阴影模糊大小">
    {
        @ SetData (_T("textShadowBlur"), CVolString(@<模糊大小>));
    }

    方法 文本阴影水平偏移 <公开 属性写 注释 = "阴影水平方向上的偏移距离,此配置项生效的前提是设置了是否显示为真.">
    参数 偏移距离 <类型 = 整数 注释 = "单位px" @默认值 = 0>
    {
        @ SetData (_T("textShadowOffsetX"), @an<CVolString> (@<偏移距离>));
    }

    方法 文本阴影垂直偏移 <公开 属性写 注释 = "阴影垂直方向上的偏移距离,此配置项生效的前提是设置了是否显示为真.">
    参数 偏移距离 <类型 = 整数 注释 = "单位px" @默认值 = 0>
    {
        @ SetData (_T("textShadowOffsetY"), @an<CVolString> (@<偏移距离>));
    }

    方法 富文本样式 <公开 属性写 注释 = "自定义富文本样式,利用和结合标签格式器,可以在标签中做出非常丰富的效果.">
    参数 自定义富文本样式 <类型 = 文本型
            注释 = "提供一个对象文本,如:\"{style:{color: \'red\',lineHeight: 10}, style2:{ height: 40, backgroundColor: { image: \'xxx/xxx.jpg\'}}}\"."
            注释 = "其中 style 和 style2... 分别代表一个自定义风格,在标签格式器中可以引用这些风格来实现丰富的效果.">
    {
        如果 (取文本左边 (自定义富文本样式, 1) == "{" && 取文本右边 (自定义富文本样式, 1) == "}")
        {
            @ @<自定义富文本样式>.Replace (CVolString(_T("\r\n")), CVolString(_T("")));
            @ SetData (_T("rich"), @<自定义富文本样式>);
        }
    }

    方法 溢出截断 <公开 属性写 注释 = "文字超出宽度是否截断或者换行,当设置了宽度时有效.">
    参数 截断类型 <类型 = 元素溢出截断类型 注释 = "提供元素溢出截断类型常量" @默认值 = 元素溢出截断类型.无>
    {
        @ SetDataStr (_T("overflow"), @<截断类型>);
    }

    方法 截断省略文本 <公开 属性写 注释 = "在溢出截断配置为\'截断\'时,可以通过该属性配置末尾显示的省略文本.">
    参数 省略文本 <类型 = 文本型 注释 = "省略文本" @默认值 = "...">
    {
        @ SetDataStr (_T("ellipsis"), @<省略文本>);
    }
}

类 标签样式类 <公开 基础类 = 文本样式类 注释 = "文本标签的文字样式" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 数值精度 <公开 属性写 注释 = "文本标签中数值的小数点精度" 折叠>
    参数 小数点精度 <类型 = 整数 注释 = "可以指定如 2 表示保留两位小数.如果提供 -1 根据当前轴的值将自动判." @默认值 = -1>
    {
        @ SetData (_T("precision"), (@<小数点精度>==-1) ? _T("'auto'") : CVolString(@<小数点精度>));
    }

    方法 格式器 <公开 属性写 注释 = "文本标签文字的格式化器" 折叠>
    参数 格式化文本 <类型 = 文本型 注释 = "  提供一段格式化文本,可以是 例如: \"\'文本 {value} 文本\'\",其中 {value} 会被自动替换为对应轴或对应项的值." 注释 = "在系列中的字符串模板模板变量有："
            注释 = "{a}:系列名  {b}:数据名  {c}:数据值  {d}:百分比." 注释 = "{@xxx}:数据中名为 \'xxx\' 的维度的值，如 {@product} 表示名为 \'product\' 的维度的值."
            注释 = "{@[n]}:数据中维度 n 的值，如 {@[3]} 表示维度 3 的值，从 0 开始计数." 注释 = "在不同的图标组件当中格式器的用法也有所不同,详细使用方法请参考echarts官方文档.">
    {
        @ SetDataStr (_T("formatter"), @<格式化文本>);
    }

    方法 格式器脚本 <公开 属性写 注释 = "文本标签文字的格式化器" 折叠>
    参数 格式器方法 <类型 = 文本型 注释 = "提供一个js方法(function)文本 在不同的图标组件当中格式器的用法也有所不同,详细使用方法请参考echarts官方文档.">
    {
        如果 (取文本左边 (格式器方法, 1) == "f" || 取文本左边 (格式器方法, 1) == "(")
        {
            @ SetData (_T("formatter"), @<格式器方法>);
        }
    }

    方法 距轴距离 <公开 属性写 注释 = "文本标签距离轴的距离" 折叠>
    参数 距离 <类型 = 整数 注释 = "距离轴的距离单位px">
    {
        @ SetData (_T("margin"), @an<CVolString>(@<距离>));
    }

    方法 位置 <公开 属性写 注释 = "文本标签的位置,在日历坐标系中设置周的位置(起始点,结束点)">
    参数 定位方式 <类型 = 图表元素定位 注释 = "图表元素定位常量" @默认值 = 图表元素定位.内部居中>
    {
        @ SetDataStr (_T("position"), (@an<CVolString>)@<定位方式>);
    }

    方法 位置2 <公开 属性写 注释 = "文本标签的位置">
    参数 定位坐标 <类型 = 文本型 注释 = "横向和纵向的坐标,提供一个数组文本,可以是\"[10, 10]\"这样的据对像素值,也可以是\"[\'10%\', \'10%\']\"百分比值.">
    {
        @ SetData (_T("position"),(@an<CVolString>)@<定位坐标>);
    }

    方法 文字水平对齐 <公开 属性写 注释 = "文字水平对齐方式默认自动" 折叠>
    参数 对齐方式 <类型 = 元素水平对齐 注释 = "提供元素水平对齐常量" @默认值 = 元素水平对齐.自动>
    {
        @ SetDataStr (_T("align"), (@an<CVolString>)@<对齐方式>);
    }

    方法 文字垂直对齐 <公开 属性写 注释 = "文字垂直对齐方式默认自动" 折叠>
    参数 对齐方式 <类型 = 元素垂直对齐 注释 = "提供元素垂直对齐常量" @默认值 = 元素垂直对齐.自动>
    {
        @ SetDataStr (_T("verticalAlign"), (@an<CVolString>)@<对齐方式>);
    }

    方法 旋转角度 <公开 属性写 注释 = "文本标签旋转角度" 折叠>
    参数 旋转角度值 <类型 = 整数 注释 = "从 -90 度到 90 度,正值是逆时针.">
    {
        @ SetData (_T("rotate"), @an<CVolString>(@<旋转角度值>));
    }

    方法 与图形元素距离 <公开 属性写 注释 = "距离图形元素的距离">
    参数 距离 <类型 = 整数 注释 = "单位像素">
    {
        @ SetData (_T("distance"), @an<CVolString>(@<距离>));
    }

    方法 与刻度线距离 <公开 属性写 注释 = "仪表盘中刻度文字标签与刻度线的距离">
    参数 距离 <类型 = 整数 注释 = "单位像素">
    {
        @ SetData (_T("distance"), @an<CVolString>(@<距离>));
    }

    方法 圆角半径 <公开 属性写 注释 = "图形四个角的圆角半径" 折叠>
    参数 圆角半径值 <类型 = 文本型 注释 = "可以是数值文本如:\"5\"统一设置四个角的圆角大小为5像素,也可以是个数组文本如:\"[5, 5, 0, 0]\"分别设置顺时针左上,右上,右下,左下四个角的圆角大小.">
    {
        @ SetData (_T("borderRadius"), @<圆角半径值>);
    }

    方法 内边距 <公开 属性写 注释 = "图形元素内边距,即元素的padding属性.">
    参数 标题内边距 <类型 = 文本型 注释 = "  默认各方向内边距为5,单位px可以是数值文本,接受数组文本分别设定上右下左边距."
            注释 = "例:\"[5, 10]\"即为上5px下10px  \"[5,10,20,15,]\"即为上右下左分别为对应的像素尺寸." @默认值 = "5">
    {
        @ SetData (_T("padding"), @<标题内边距>);
    }

    方法 颜色 <公开 属性写 注释 = "图表元素的颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \"#ccc\" 一些特殊场景下还可以设置为\"null\"表示空,\"auto\"表示自适应.">
    {
        如果 (到小写 (颜色值文本) == "null")
        {
            @ SetData (_T("color"), _T("null"));
        }
        如果 (取文本左边 (颜色值文本, 1) == "[" && 取文本右边 (颜色值文本, 1) == "]")
        {
            @ SetData (_T("color"), @<颜色值文本>);
        }
        否则
        {
            @ SetDataStr (_T("color"), @<颜色值文本>);
        }
    }

    方法 开启数字动画 <公开 属性写 注释 = "是否开启标签的数字动画">
    参数 是否开启动画 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ SetData (_T("valueAnimation"), (@<是否开启动画> ? _T("true"): _T("false")));
    }

    方法 中心偏移 <公开 属性写 注释 = "相对于仪表盘中心的偏移位置">
    参数 中心偏移值 <类型 = 文本型 注释 = "提供一个数组文本如:[\'50\', \'50%\']数组第一项是水平方向的偏移,第二项是垂直方向的偏移." 注释 = "可以是绝对的数值,也可以是相对于仪表盘半径的百分比."
            @默认值 = "[0, 0]">
    {
        @ SetData(_T("offsetCenter"), @<中心偏移值>); 
    }
}

类 日历标签样式类 <公开 基础类 = 标签样式类 注释 = "日历标签的文字样式" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 周起始日 <公开 属性写 注释 = "一周从周几开始,默认从周日开始.">
    参数 起始日 <类型 = 整数 注释 = "取值0-6" @默认值 = 0>
    {
        @ SetData (_T("firstDay"), CVolString(@<起始日>));
    }

    方法 周显示设置 <公开 属性写 注释 = "星期显示的效果，默认为\'en\' 可设置中英文以及自定义 下标0为对应星期天的文字显示">
    参数 显示效果 <类型 = 文本型 注释 = "\'en\':快捷设置英文 \'[\'S\', \'M\', \'T\', \'W\', \'T\', \'F\', \'S\']\'."
            注释 = "\'cn\':快捷设置中文 \'[\'日\', \'一\', \'二\', \'三\', \'四\', \'五\', \'六\']\'."
            注释 = "自定意设置:\'[\'S\', \'一\', \'T\', \'三\', \'\', \'五\', \'S\']\'.">
    {
        如果 (显示效果 == "en" || 显示效果 == "cn")
        {
            @ SetDataStr (_T("nameMap"), @<显示效果>);
        }
        否则 (取文本左边 (显示效果, 1) == "[")
        {
            @ SetData (_T("nameMap"), @<显示效果>);
        }
    }
}

类 颜色透明度阴影样式类 <基础类 = 图表参数基础类 注释 = "带有颜色和阴影样式属性的配置项共用基础类" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 颜色 <公开 属性写 注释 = "图表元素的颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \"#ccc\" 一些特殊场景下还可以设置为\"null\"表示空,\"auto\"表示自适应.">
    {
        如果 (到小写 (颜色值文本) == "null")
        {
            @ SetData (_T("color"), _T("null"));
        }
        如果 (取文本左边 (颜色值文本, 1) == "[" && 取文本右边 (颜色值文本, 1) == "]")
        {
            @ SetData (_T("color"), @<颜色值文本>);
        }
        否则
        {
            @ SetDataStr (_T("color"), @<颜色值文本>);
        }
    }

    方法 置颜色径向渐变 <公开 注释 = "图表元素的径向渐变颜色,坐标位置相当于在图形包围盒中的百分比">
    参数 中心点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 中心点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 渐变半径 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 结束颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 是否绝对值 <类型 = 逻辑型 注释 = "默认位置用样百分比值,如果设置为真则采用绝对像素值" @默认值 = 假>
    {
        @ SetData (_T("color"), _T("{\"type\":\"radial\",\"x\":")+CVolString(@<中心点横坐标>)+_T(",\"y\":")+CVolString(@<中心点纵坐标>)+_T(", \"r\":")+CVolString(@<渐变半径>)+_T(",\"colorStops\":[{\"offset\": 0, \"color\":\"")+@<起始颜色>+_T("\"}, {\"offset\":1, \"color\":\"")+@<结束颜色>+_T("\"}], \"global\":")+CVolString(@<是否绝对值>)+_T("}"));
    }

    方法 置颜色线性渐变 <公开 注释 = "图表元素的线性渐变颜色,坐标位置相当于在图形包围盒中的百分比.">
    参数 起始点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 结束点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 结束点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 结束颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 是否绝对值 <类型 = 逻辑型 注释 = "默认位置采用百分比值,如果设置为真则采用绝对像素值" @默认值 = 假>
    {
        @ SetData (_T("color"), _T("{\"type\":\"linear\",\"x\":")+CVolString(@<起始点横坐标>)+_T(",\"y\":")+CVolString(@<起始点纵坐标>)+_T(", \"x2\":")+CVolString(@<结束点横坐标>)+_T(", \"y2\":")+CVolString(@<结束点纵坐标>)+_T(",\"colorStops\":[{\"offset\": 0, \"color\":\"")+@<起始颜色>+_T("\"}, {\"offset\":1, \"color\":\"")+@<结束颜色>+_T("\"}], \"global\":")+CVolString(@<是否绝对值>)+_T("}"));
    }

    方法 填充纹理 <公开 注释 = "设置图表元素的纹理填充">
    参数 图片元素名称 <类型 = 文本型 注释 = "图片元素可调用方法\"图表组件.置图片元素()\"来创建." "">
    参数 平铺重复 <类型 = 图表背景重复模式 注释 = "提供图表背景重复模式常量" @默认值 = 图表背景重复模式.重复>
    {
        @ SetData (_T("color"), _T("{\"image\":window.")+@<图片元素名称>+_T(", \"repeat\":\"")+@<平铺重复>+_T("\"}"));
    }

    方法 透明度 <公开 属性写 注释 = "图形透明度,支持从 0 到 1 的小数数字,为0时不绘制该图形.">
    参数 透明度值 <类型 = 小数 注释 = "0 到 1 的小数值" @默认值 = 1>
    {
        @ SetData (_T("opacity"), @an<CVolString> (@<透明度值>));
    }

    方法 阴影颜色 <公开 属性写 注释 = "阴影颜色" 折叠>
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        @ SetDataStr (_T("shadowColor"), @<颜色值文本>);
    }

    方法 阴影模糊大小 <公开 属性写 注释 = "图形阴影的模糊大小,该属性配合阴影颜色,阴影水平偏移,阴影垂直偏移,一起设置图形的阴影效果." 折叠>
    参数 模糊大小 <类型 = 整数 注释 = "阴影模糊大小" @默认值 = 1>
    {
        @ SetData (_T("shadowBlur"), @an<CVolString> (@<模糊大小>));
    }

    方法 阴影水平偏移 <公开 属性写 注释 = "阴影水平方向上的偏移距离,此配置项生效的前提是设置了是否显示为真." 折叠>
    参数 偏移距离 <类型 = 整数 注释 = "单位px" @默认值 = 0>
    {
        @ SetData (_T("shadowOffsetX"), @an<CVolString> (@<偏移距离>));
    }

    方法 阴影垂直偏移 <公开 属性写 注释 = "阴影垂直方向上的偏移距离,此配置项生效的前提是设置了是否显示为真." 折叠>
    参数 偏移距离 <类型 = 整数 注释 = "单位px" @默认值 = 0>
    {
        @ SetData (_T("shadowOffsetY"), @an<CVolString> (@<偏移距离>));
    }
}

类 线条样式类 <公开 基础类 = 颜色透明度阴影样式类 注释 = "线条样式(lineStyle)" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 线宽 <公开 属性写 注释 = "线宽,即线条的粗细" 折叠>
    参数 线宽值 <类型 = 小数 注释 = "线宽值" @默认值 = 2>
    {
        @ SetData (_T("width"), @an<CVolString> (@<线宽值>));
    }

    方法 线条类型 <公开 属性写 注释 = "线条类型" 折叠>
    参数 线条类型值 <类型 = 元素线条类型 注释 = "提供元素线条类型常量" @默认值 = 元素线条类型.实线>
    {
        @ SetDataStr (_T("type"), (@dt<文本型>)@<线条类型值>);
    }

    方法 虚线偏移 <公开 属性写 注释 = "用于设置虚线的偏移量,配合线条类型实现" 折叠>
    参数 偏移距离 <类型 = 整数 注释 = "偏移距离">
    {
        @ SetData (_T("dashOffset"), @an<CVolString> (@<偏移距离>));
    }
}

类 图形样式类 <公开 基础类 = 颜色透明度阴影样式类 注释 = "图形样式(itemStyle)" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 边框颜色 <公开 属性写 注释 = "图形的描边颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ SetData(_T("borderColor"), _T("null"));
        }
        否则
        {
            @ SetDataStr (_T("borderColor"), @<颜色值文本>);
        }
    }

    方法 地图区域颜色 <公开 属性写 注释 = "地图区域的颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'" @默认值 = "#eee">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ SetData(_T("areaColor"), _T("null"));
        }
        否则
        {
            @ SetDataStr (_T("areaColor"), @<颜色值文本>);
        }
    }

    方法 阴线颜色 <公开 属性写 注释 = "K线图阴线图形颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\' 设置为\"null\"表示空">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ SetData(_T("color0"), _T("null"));
        }
        否则
        {
            @ SetDataStr (_T("color0"), @<颜色值文本>);
        }
    }

    方法 阴线边框颜色 <公开 属性写 注释 = "K线图阴线图形的描边颜色">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如 \'rgb(128, 128, 128)\' ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \'rgba(128, 128, 128, 0.5)\'."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ SetData(_T("borderColor0"), _T("null"));
        }
        否则
        {
            @ SetDataStr (_T("borderColor0"), @<颜色值文本>);
        }
    }

    方法 边框宽度 <公开 属性写 注释 = "描边线宽" 折叠>
    参数 描边线宽 <类型 = 整数 注释 = "为0时无描边" @默认值 = 0>
    {
        @ SetData (_T("borderWidth"), @an<CVolString> (@<描边线宽>)); 
    }

    方法 边框线类型 <公开 属性写 注释 = "描边边框线类型" 折叠>
    参数 边框类型 <类型 = 元素线条类型 注释 = "提供元素线条类型常量" @默认值 = 元素线条类型.实线>
    {
        @ SetDataStr (_T("borderType"), @<边框类型>);
    }

    方法 圆角半径 <公开 属性写 注释 = "图形四个角的圆角半径">
    参数 圆角半径值 <类型 = 文本型 注释 = "可以是数值文本如:\"5\"统一设置四个角的圆角大小为5像素,也可以是个数组文本如:\"[5, 5, 0, 0]\"分别设置顺时针左上,右上,右下,左下四个角的圆角大小.">
    {
        @ SetData (_T("borderRadius"), @<圆角半径值>);
    }
}

类 区域填充样式类 <公开 基础类 = 颜色透明度阴影样式类 注释 = "区域填充样式,设置后显示成区域面积图." @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    方法 起始位置 <公开 属性写 注释 = "  图形区域的起始位置,默认情况下,图形会从坐标轴轴线到数据间进行填充." 注释 = "如果需要填充的区域是坐标轴最大值到数据间，或者坐标轴最小值到数据间，则可以通过这个配置项进行设置。">
    参数 起始位置 <类型 = 整数 注释 = "缺省值:0为自动填充坐标轴轴线到数据间的区域,1为填充坐标轴底部到数据间的区间,2为填充坐标轴顶部到数据间的区间." @默认值 = 0>
    {
        @ if (@<起始位置>==0)  SetDataStr (_T("origin"), _T("auto"));
        @ if (@<起始位置>==1)  SetDataStr (_T("origin"), _T("start"));
        @ if (@<起始位置>==2)  SetDataStr (_T("origin"), _T("end"));
    }
}

类 悬停高亮类 <公开 基础类 = 图表参数基础类 注释 = "图表图形的高亮强调状态配置." @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 标签样式 <公开 类型 = 标签样式类 注释 = "焦点悬停时文本标签的样式">
    变量 标签引导线 <公开 类型 = 标签引导线类 注释 = "焦点悬停时标签引导线的样式">
    变量 图形样式 <公开 类型 = 图形样式类 注释 = "焦点悬停时图形的样式">
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "焦点悬停时线条的样式">
    变量 区域填充 <公开 类型 = 区域填充样式类 注释 = "焦点悬停时区域填充样式">
    变量 端点标签 <公开 类型 = 标签样式类 注释 = "焦点悬停时折线端点(结束点)标签的样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" 折叠 @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<标签样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("label"), str);
        @ str = @<标签引导线.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("labelLine"), str);
        @ str = @<端点标签>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("endLabel"), str);
        @ str = @<图形样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("itemStyle"), str);
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ str = @<区域填充>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("areaStyle"), str);
        @ return getJSON();
    }

    方法 移入放大 <公开 属性写 注释 = "是否开启鼠标移入在拐点标志上,饼图扇区上,以及不同系列的数据图形上的放大效果,默认为真." 折叠>
    参数 是否移入放大 <类型 = 逻辑型 注释 = "是否放大" @默认值 = 真>
    {
        @ SetData (_T("scale"), (@<是否移入放大> ? _T("true") : _T("false")));
    }

    方法 移入放大尺寸 <公开 属性写 注释 = "是否开启鼠标移入在拐点标志上,饼图扇区上,以及不同系列的数据图形上的放大的尺寸.开启移入放大有效" 折叠>
    参数 放大尺寸 <类型 = 整数 注释 = "放大尺寸,单位像素." @默认值 = 10>
    {
        @ SetData (_T("scaleSize"), CVolString(@<放大尺寸>)); 
    }

    方法 聚焦淡出 <公开 属性写 注释 = "在高亮图形时,是否淡出其它数据的图形已达到聚焦的效果." 折叠>
    参数 聚焦淡出设置 <类型 = 聚焦淡出方式 注释 = "提供聚焦淡出方式常量" @默认值 = 聚焦淡出方式.不淡出其他图形>
    {
        @ SetDataStr (_T("focus"), @<聚焦淡出设置>);
    }

    方法 淡出范围 <公开 属性写 注释 = "在开启聚焦淡出的时候,可以配置淡出的范围." 折叠>
    参数 淡出设置 <类型 = 聚焦淡出范围 注释 = "提供聚焦淡出范围常量" @默认值 = 聚焦淡出范围.系列>
    {
        @ SetDataStr (_T("blurScope"), @<淡出设置>);
    }
}

类 淡出状态类 <公开 基础类 = 图表参数基础类 注释 = "淡出状态样式设置" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 标签样式 <公开 类型 = 标签样式类 注释 = "淡出状态文本标签的样式">
    变量 标签引导线 <公开 类型 = 标签引导线类 注释 = "焦点悬停时标签引导线的样式">
    变量 图形样式 <公开 类型 = 图形样式类 注释 = "淡出状态时图形的样式">
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "淡出状态时线条的样式">
    变量 区域填充 <公开 类型 = 区域填充样式类 注释 = "淡出状态时区域填充样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" 折叠 @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<标签样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("label"), str);
        @ str = @<标签引导线.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("labelLine"), str);
        @ str = @<图形样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("itemStyle"), str);
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ str = @<区域填充>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("areaStyle"), str);
        @ return getJSON();
    }
}

类 选中状态类 <公开 基础类 = 图表参数基础类 注释 = "数据选中时的图形样式和标签样式" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 标签样式 <公开 类型 = 标签样式类 注释 = "选择状态下的标签样式">
    变量 标签引导线 <公开 类型 = 标签引导线类 注释 = "选择状态下的标签引导线样式">
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "选择状态下的线条样式">
    变量 图形样式 <公开 类型 = 图形样式类 注释 = "选择状态图形样式">
    变量 区域填充 <公开 类型 = 区域填充样式类 注释 = "选择状态区域填充样式">
    变量 端点标签 <公开 类型 = 标签样式类 注释 = "选择状态下折线端点(结束点)标签的样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<标签样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("label"), str);
        @ str = @<标签引导线.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("labelLine"), str);
        @ str = @<区域填充>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("areaStyle"), str);
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ str = @<图形样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("itemStyle"), str);
        @ str = @<端点标签>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("endLabel"), str);
        @ return getJSON();
    }
}

类 轴线配置类 <公开 基础类 = 图表参数基础类 注释 = "坐标轴轴线相关设置" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "坐标轴轴线样式配置">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ return getJSON();
    }

    方法 是否在零刻度 <公开 属性写 注释 = "横轴或者纵轴的轴线是否在另一个轴的 0 刻度上,只有在另一个轴为数值轴且包含 0 刻度时有效.">
    参数 是否零刻度 <类型 = 逻辑型 注释 = "是否在零刻度" @默认值 = 真>
    {
        @ SetData (_T("onZero"), (@<是否零刻度> ? _T("true") : _T("false")));
    }

    方法 零刻度轴索引 <公开 属性写 注释 = "当有双轴时,可以用这个属性手动指定,在哪个轴的 0 刻度上." 折叠>
    参数 轴索引 <类型 = 整数 注释 = "零刻度轴索引">
    {
        @ SetData (_T("onZeroAxisIndex"), @an<CVolString> (@<轴索引>));
    }

    方法 两端标记 <公开 属性写 注释 = "轴线两边的箭头" 折叠>
    参数 箭头类型 <类型 = 标记图形形状 注释 = "提供标记图形形状常量" @默认值 = 标记图形形状.无>
    {
        @ SetDataStr (_T("symbol"), (@dt<文本型>)@<箭头类型>);
    }

    方法 置两端标记 <公开 注释 = "分别设置轴线两边的箭头">
    参数 起始箭头 <类型 = 标记图形形状 注释 = "起始箭头,提供标记图形形状常量" @默认值 = 标记图形形状.无>
    参数 末端箭头 <类型 = 标记图形形状 注释 = "末端箭头,提供标记图形形状常量" @默认值 = 标记图形形状.无>
    {
        @ SetData (_T("symbol"), _T("[") + (@dt<文本型>)@<起始箭头> +_T(",") +  (@dt<文本型>)@<末端箭头> +_T("]"));
    }

    方法 两端标记尺寸 <公开 属性写 注释 = "轴线两边的箭头尺寸">
    参数 箭头尺寸 <类型 = 整数 注释 = "箭头尺寸单位px">
    {
        @ SetData (_T("symbolSize"),  _T("[") + @an<CVolString> (@<箭头尺寸>) +_T(",") + @an<CVolString> (@<箭头尺寸>) +_T("]"));
    }

    方法 两端标记偏移 <公开 属性写 注释 = "轴线两边的箭头的偏移">
    参数 偏移距离 <类型 = 整数 注释 = "偏移距离单位px">
    {
        @ SetData (_T("symbolOffset"),  _T("[") + @an<CVolString> (@<偏移距离>) + _T(",") + @an<CVolString> (@<偏移距离>) + _T("]"));
    }
}

类 仪表盘配置类 <公开 基础类 = 图表参数基础类 注释 = "仪表盘独有的参数配置" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 标题 <公开 类型 = 标签样式类 注释 = "仪表盘标题配置">
    变量 指针 <公开 类型 = 仪表盘指针类 注释 = "仪表盘指针配置">
    变量 针轴 <公开 类型 = 仪表盘针轴类 注释 = "表盘中指针的固定点(轴)">
    变量 轴线 <公开 类型 = 仪表盘轴线类 注释 = "仪表盘轴线配置">
    变量 进度条 <公开 类型 = 仪表盘进度条类 注释 = "仪表盘的进度条配置">
    变量 轴刻度 <公开 类型 = 轴刻度配置类 注释 = "仪表盘轴刻度样式配置">
    变量 刻度标签 <公开 类型 = 标签样式类 注释 = "仪表盘轴刻度标文本签样式配置">
    变量 详情样式 <公开 类型 = 标签样式类 注释 = "仪表盘显示仪表详情">
    变量 分割线样式 <公开 类型 = 网格分割线类 注释 = "仪表盘分隔线样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<指针.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("pointer"), str);
        @ str = @<针轴.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("anchor"), str);
        @ str = @<轴线.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("axisLine"), str);
        @ str = @<进度条.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("progress"), str);
        @ str = @<轴刻度.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("axisTick"), str);
        @ str = @<刻度标签>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("axisLabel"), str);
        @ str = @<标题>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("title"), str);
        @ str = @<详情样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("detail"), str);
        @ str = @<分割线样式.取文本>();
        @ if (!str.IsEmpty())  SetData(_T("splitLine"), str);
        @ return getJSON();
    }
}

类 仪表盘轴线类 <公开 基础类 = 图表参数基础类 注释 = "仪表盘专属轴线配置" 折叠 @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 线条样式 <公开 类型 = 线条样式类 注释 = "坐标轴轴线样式配置">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" 折叠 @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<线条样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("lineStyle"), str);
        @ return getJSON();
    }

    方法 两端圆形 <公开 属性写 注释 = "是否在两端显示成圆形">
    参数 是否在两端显示成圆形 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        @ SetData (_T("roundCap"), (@<是否在两端显示成圆形> ? _T("true") : _T("false")));
    }

    方法 轴线颜色 <公开 属性写 注释 = "仪表盘轴线颜色">
    参数 颜色值文本 <类型 = 文本型 注释 = "可以被分成不同颜色的多段,每段的结束位置和颜色可以通过一个数组来表示."
            注释 = "如:\"[[0.3, \'#67e0e3\'],[0.7, \'#37a2da\'],[1, \'#fd666d\']]\"." 注释 = "每个成员的首成员代表轴线长度的百分比,(取值0-1).次成员为颜色值."
            @默认值 = "[[1, '#E6EBF8']]">
    {
        如果 (取文本左边 (颜色值文本, 1) == "[" && 取文本右边 (颜色值文本, 1) == "]")
        {
            @ @<线条样式>.SetData (_T("color"), @<颜色值文本>);
        }
    }
}

类 仪表盘指针类 <公开 基础类 = 图表参数基础类 注释 = "仪表盘指针配置" @文档 = "category = \"图表配置参数.公用参数样式\"">
{
    变量 指针样式 <公开 类型 = 图形样式类 注释 = "指针图形样式">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前对象的图表配置参数转换成JSON文本" 折叠 @禁止流程检查 = 真>
    {
        @ CVolString str;
        @ str = @<指针样式>.getJSON();
        @ if (!str.IsEmpty())  SetData(_T("itemStyle"), str);
        @ return getJSON();
    }

    方法 图形 <公开 属性写 注释 = "指针标记的图形形状" 折叠>
    参数 图形类型 <类型 = 标记图形形状 注释 = "提供标记图形形状常量" @默认值 = 标记图形形状.水滴>
    {
        @ SetDataStr (_T("icon"), (@dt<文本型>)@<图形类型>);
    }

    方法 图形2 <公开 属性写 注释 = "标记的图形,扩展方法,用于自定义图形." 折叠>
    参数 标记图形 <类型 = 文本型 注释 = "可以通过 \'image://url\' 设置为图片,其中 URL 为图片的链,或者 dataURI. 也可以通过 \'path://\' 将图标设置为任意的矢量路径.">
    {
        @ SetDataStr (_T("icon"), @<标记图形>);
    }

    方法 中心偏移 <公开 属性写 注释 = "相对于仪表盘中心的偏移位置">
    参数 中心偏移值 <类型 = 文本型 注释 = "提供一个数组文本如:[\'50\', \'50%\']数组第一项是水平方向的偏移,第二项是垂直方向的偏移." 注释 = "可以是绝对的数值,也可以是相对于仪表盘半径的百分比."
            @默认值 = "[0, 0]">
    {
        @ SetData(_T("offsetCenter"), @<中心偏移值>); 
    }

    方法 长度 <公开 属性写 注释 = "指针长度">
    参数 长度值 <类型 = 文本型 注释 = "可以是绝对数值,也可以是相对于半径的半分比.">
    {
        如果 (寻找文本 (长度值, "%") != -1)
        {
            @ SetDataStr (_T("length"), @<长度值>);
        }
        否则
        {
            @ SetData (_T("length"), @<长度值>);
        }
    }

    方法 宽度 <公开 属性写 注释 = "指针宽度" 折叠>
    参数 宽度值 <类型 = 整数 注释 = "指针宽度">
    {
        @ SetData (_T("width"), CVolString(@<宽度值>));
    }

    方法 保持图形比例 <公开 属性写 注释 = "如果指针图形是 path:// 的形式,是否在缩放时保持该图形的长宽比.">
    参数 是否保持长宽比 <类型 = 逻辑型 注释 = "是否保持长宽比">
    {
        @ SetData (_T("keepAspect"), (@<是否保持长宽比> ? _T("true") : _T("false")));
    }
}

