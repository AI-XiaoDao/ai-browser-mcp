    常量 站点数据 <公开 值 = @COREWEBVIEW2_BROWSING_DATA_KINDS_ALL_SITE 注释 = "Cookie会将新的站点数据类型添加到这种数据类型中">
    常量 磁盘缓冲区 <公开 值 = @COREWEBVIEW2_BROWSING_DATA_KINDS_DISK_CACHE>
