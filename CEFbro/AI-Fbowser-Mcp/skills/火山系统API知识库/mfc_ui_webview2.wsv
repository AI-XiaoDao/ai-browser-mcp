    常量 鼠标移入 <公开 值 = "onmouseout">
    常量 鼠标移出 <公开 值 = "onmouseout">
    常量 鼠标按下 <公开 值 = "onmousedown">
    常量 鼠标抬起 <公开 值 = "onmouseup">
    常量 鼠标移动 <公开 值 = "onmousemove">
    常量 按键按下 <公开 值 = "keydown" 注释 = "按下键盘上的任意键">
    常量 按键抬起 <公开 值 = "keyup" 注释 = "释放键盘上的键">
    常量 按键 <公开 值 = "keypress" 注释 = "按下键盘上的字符键">
    常量 获得焦点 <公开 值 = "focus" 注释 = "元素获得焦点">
    常量 失去焦点 <公开 值 = "blur" 注释 = "元素失去焦点">
    常量 值改变 <公开 值 = "change" 注释 = "input、textarea元素value值改变且失去焦点、select元素选项改变.">
    常量 输入 <公开 值 = "input" 注释 = "元素用户输入">
}

类 EdgeSameSite属性 <公开 注释 = "Chrome51开始,浏览器的Cookie新增加了SameSite属性,用来防止CSRF攻击和用户追踪." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 关闭 <公开 值 = @COREWEBVIEW2_COOKIE_SAME_SITE_KIND_NONE 注释 = "关闭SameSite属性">
    常量 不全禁止 <公开 值 = @COREWEBVIEW2_COOKIE_SAME_SITE_KIND_LAX 注释 = "大多数情况不发送第三方Cookie,导航到目标网址的Get请求除外.">
    常量 完全禁止 <公开 值 = @COREWEBVIEW2_COOKIE_SAME_SITE_KIND_STRICT 注释 = "完全禁止第三方Cookie,跨站点时,任何情况下都不会发送Cookie.">
}

