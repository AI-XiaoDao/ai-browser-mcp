类 Edge错误码 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 成功 <公开 值 = -1 注释 = "表示成功加载">
    常量 未知错误 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_UNKNOWN 注释 = "表示发生了未知错误">
    常量 证书地址错误 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CERTIFICATE_COMMON_NAME_IS_INCORRECT 注释 = "表示 SSL 证书公用名与 Web 地址不匹配">
    常量 证书过期 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CERTIFICATE_EXPIRED 注释 = "表示 SSL 证书已过期">
    常量 证书错误 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CLIENT_CERTIFICATE_CONTAINS_ERRORS 注释 = "指示 SSL 客户端证书包含错误">
    常量 证书已吊销 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CERTIFICATE_REVOKED 注释 = "表示 SSL 证书已被吊销">
    常量 证书无效 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CERTIFICATE_IS_INVALID 注释 = "表示 SSL 证书无效">
    常量 主机不可达 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_SERVER_UNREACHABLE 注释 = "表示主机不可达">
    常量 连接超时 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_TIMEOUT 注释 = "表示连接已超时">
    常量 无效响应 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_ERROR_HTTP_INVALID_SERVER_RESPONSE 注释 = "表示服务器返回了无效或无法识别的响应">
    常量 连接停止 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CONNECTION_ABORTED 注释 = "表示连接已停止">
    常量 连接重置 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CONNECTION_RESET 注释 = "表示连接已重置">
    常量 连接丢失 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_DISCONNECTED 注释 = "表示 Internet 连接已丢失">
    常量 连接未建立 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_CANNOT_CONNECT 注释 = "表示未建立到目标的连接">
    常量 无法解析 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_HOST_NAME_NOT_RESOLVED 注释 = "表示无法解析提供的主机名">
    常量 操作取消 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_OPERATION_CANCELED 注释 = "表示操作已取消">
    常量 重定向失败 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_REDIRECT_FAILED 注释 = "表示请求重定向失败">
    常量 其他错误 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_UNEXPECTED_ERROR 注释 = "一个意料之外的问题发生了">
    常量 提示登录 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_VALID_AUTHENTICATION_CREDENTIALS_REQUIRED 注释 = "表示提示用户登录,等待用户操作.">
    常量 缺少身份凭据 <公开 值 = @COREWEBVIEW2_WEB_ERROR_STATUS_VALID_PROXY_AUTHENTICATION_REQUIRED 注释 = "表示用户缺少代理服务器的正确身份验证凭据">
}

