    {
        缓存目录 = 目录
    }

    方法 置虚拟主机文件映射 <公开 类型 = 逻辑型 注释 = "   设置虚拟主机名和文件夹路径之间的映射,以便通过该主机名访问该目录站点,设置映射后,"
            注释 = "浏览器中加载的文档可以使用指定的主机名以HTTP(S)URL访问文件夹指定的本地文件夹中的文件资源." @嵌入式方法 = "">
    参数 虚拟主机名 <类型 = 文本型 注释 = "主机名 如:\"appassets.example\"">
    参数 映射文件夹 <类型 = 文本型 注释 = "文件目录">
    参数 资源访问类型 <类型 = 整数 注释 = "主机资源访问类型 0.拒绝跨来源访问,1.允许跨来源资源访问,2.正常访问而拒绝CORS检查的访问" @默认值 = 1>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->SetVirtualHostNameToFolderMapping(@<虚拟主机名>, @<映射文件夹>,  @<资源访问类型>)
    }

