    方法 取坐标 <公开 类型 = 文本型 注释 = "取元素位于页面的相对坐标,返回以逗号分隔的坐标文本." 返回值注释 = "注意:在浏览器事件中调用无效.详情查看填表类说明." @禁止流程检查 = 真>
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型
                值 = "function huoShanGetAbsPoint(){oRect=document.querySelectorAll(\'%s\')[%d].getBoundingClientRect();return oRect.left+\",\"+oRect.top;}huoShanGetAbsPoint();">
        子文本替换 (JS代码, "%s", 选择器, , , )
        子文本替换 (JS代码, "%d", 到文本 (选择器索引), , , )
        @ return data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 模拟事件 <公开 注释 = "模拟发送页面事件" "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 模拟方式 <类型 = Edge模拟方式 注释 = "Edge模拟方式.*">
    参数 按键码 <类型 = 整数 注释 = "键盘按键码,当模拟方式为按键时,必需提供该参数.默认为回车键." @默认值 = 13>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        常量 JS事件代码 <类型 = 文本型
                值 = "function huoShanEvents(keyType,keyCode){var event=new UIEvent(keyType,{bubbles:true,cancelable:true,view:window,ctrlKey:false,altKey:false,shiftKey:false,metaKey:false,});if(typeof(keyCode)===\'object\'){for(var k in keyCode){event[k]=keyCode[k];}}else{event.keyCode=keyCode||0;}return event;}">
        变量 JS代码 <类型 = 文本型>
        如果 (是否以文本开头 ((文本型)模拟方式, "key", 假))
        {
            JS代码 = "huoShanEvents('" + (文本型)模拟方式 + "', " + 到文本 (按键码) + ")"  // 模拟按键事件
        }
        否则
        {
            JS代码 = "huoShanEvents('" + (文本型)模拟方式 + "')"  // 模拟除按键之外事件
        }
        JS代码 = JS事件代码 + "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].dispatchEvent(" + JS代码 + ");"
        @ data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 取浏览区大小 <公开 类型 = 文本型 注释 = "返回浏览区页面的宽度和高度用逗号分隔的文本." 注释 = "注意:在浏览器事件中调用无效.详情查看填表类说明." @禁止流程检查 = 真>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型
                值 = "function huoShanGetBodyClient(){return document.body.clientWidth+\",\"+document.body.clientHeight;}huoShanGetBodyClient();">
        @ return data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }
}

类 EdgeCookie管理类 <公开 注释 = "Cookie管理类,用于对Cookie操作." 注释 = "注意: 仅当调用\"取Cookie管理\"方法时所提供的\"Edge浏览框\"组件存在时才能对本类对象进行操作.">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserCookieManager)
    # <> <include>
    # @sn<current_class> (wil::com_ptr<ICoreWebView2CookieManager> cookieManager,CVWnd_EWVBrowser* MfcWndPtr) : @sn<current_class> ()  {
    #      data().webviewCookieManager = cookieManager;
    #      data().webviewMfcWndPtr =  MfcWndPtr;
    #  }
    # <> </include>
    # @end

    方法 取Cookies <公开 类型 = 文本型 注释 = "获取打开网址所产生的所有Cookies" @嵌入式方法 = "">
    参数 网址 <类型 = 文本型 注释 = "如果为空文本表示取出当前页面,如:\"https://www.baidu.com\"" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败;1成功有返回值,当Cookies为空时,返回空文本;2成功无返回值;3超时无返回值." @默认值 = 空对象>
    {
        @ @sn<this>.data().GetAllCookie(@<网址>.GetText(),@<超时时间>,@<状态码.值>)
    }

    方法 取Cookies信息 <公开 类型 = 文本型
            注释 = "取出网址下每条Cookie的详细信息以JSON文本返回,其中包含cookie相关信息:name(子名称),value(子名称对应值),expires(有效期),domain(域名),"
            注释 = "isHttpOnly(浏览器是否允许脚本操作更改cookie,当值为\"true\"时,通过js等将无法读取到cookie),isSecure(当值为\"true\"时,cookie在\"HTTP\"中是无效,在\"HTTPS\"中才有效),"
            注释 = "isSession(是否用于记录用户的相关信息),path(表示cookie影响到的路径),"
            注释 = "sameSite(执行模式,防止CSRF攻击和用户追踪,其值分别表示:0,关闭;1,不发送第三方Cookie;2,完全禁止第三方Cookie)." @嵌入式方法 = "">
    参数 网址 <类型 = 文本型 注释 = "如果为空文本表示取出当前页面,如:\"https://www.baidu.com\"" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败;1成功有返回值,当Cookies为空时,返回空文本;2成功无返回值;3超时无返回值." @默认值 = 空对象>
    {
        @ @sn<this>.data().GetAllCookieForJson(@<网址>.GetText(),@<超时时间>,@<状态码.值>)
    }

    方法 置Cookies信息 <公开 类型 = 逻辑型 注释 = "根据网址下单条Cookie的子名称单独设置该条Cookie的相关信息." @嵌入式方法 = "">
    参数 网址 <类型 = 文本型 注释 = "如果为空文本表示取出当前页面,如:\"https://www.baidu.com\"" @默认值 = "">
    参数 子名称 <类型 = 文本型 注释 = "所欲设置的Cookie中的单个名称.">
    参数 所欲设置的值 <类型 = 文本型 注释 = "表示指定\"子名称\"所欲设置的单个Cookie的值.">
    参数 允许更改 <类型 = 逻辑型 注释 = "参考\"取Cookies信息\"中的\"isHttpOnly\",浏览器是否允许脚本操作更改Cookie,当值为\"真\"时,通过js等将无法读取到cookie." @默认值 = 假>
    参数 安全域名 <类型 = 逻辑型 注释 = "参考\"取Cookies信息\"中的\"isSecure\",当值为真时,表示cookie在\"HTTP\"中是无效,在\"HTTPS\"中才有效." @默认值 = 假>
    参数 限制第三方 <类型 = EdgeSameSite属性 注释 = "是否限制第三方Cookie." @默认值 = EdgeSameSite属性.不全禁止>
    参数 有效期 <类型 = 小数 注释 = "参考\"取Cookies信息\"中的\"expires\",设置Cookie有效期.当值为0时表示忽略该参数.过期时间设置为-1.0,则立即失效,不可以设置除-1.0以外的任何负数值."
            @默认值 = 0>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败;1成功有返回值,当Cookies为空时,返回空文本;2成功无返回值;3超时无返回值." @默认值 = 空对象>
    {
        @ @sn<this>.data().SetCookiesInfo(@<网址>,@<子名称>,@<所欲设置的值>,@<允许更改>,@<安全域名>,@<限制第三方>,@<有效期>,@<超时时间>,@<状态码.值>)
    }

    方法 置Cookie <公开 类型 = 逻辑型 注释 = "使用给定的Cookie数据添加或更新Cookie;如果存在,则会覆盖具有匹配名称、域和路径的Cookie." @禁止流程检查 = 真>
    参数 域名 <类型 = 文本型 注释 = "参考\"取Cookies信息\"中的\"domain\",域名,如:\"www.baidu.com\",\".baidu.com\".">
    参数 子名称 <类型 = 文本型 注释 = "根据子名称设置一条Cookie的值.如果为空文本,则表示根据参数\"所欲设置的值\"设置所有包含名称的Cookie文本." @默认值 = "">
    参数 所欲设置的值 <类型 = 文本型 注释 = "当\"子名称\"不为空时,表示指定\"子名称\"所欲设置的单个Cookie的值.否则则表示设置单个或多个名称中对应的Cookie值."
            注释 = "例如:\"bdime=0; ORIGIN=2; sugstore=0; sug=0; \".">
    参数 路径 <类型 = 文本型 注释 = "Cookie影响到的路径,一般为根目录\"/\",如果更新Cookie,请参考\"取Cookies信息\"方法中获得的\"path\"值." @默认值 = "/">
    {
        @ BOOL resultBool = FALSE;
        如果 (子名称 != "")
        {
            @ resultBool = data().AddOrUpdateCookie(@<子名称>.GetText(),@<所欲设置的值>.GetText(),@<域名>.GetText(),@<路径>.GetText());
        }
        否则
        {
            变量 局_Cookie数组 <类型 = 文本数组类>
            分割文本 (所欲设置的值, ";", 局_Cookie数组, 真, 真)
            局_Cookie数组.枚举循环 ()
            {
                变量 局_左文本 <类型 = 文本型 值 = "">
                变量 局_右文本 <类型 = 文本型 值 = "">
                分割左右子文本 (局_Cookie数组.取枚举值 (), "=", 局_左文本, 局_右文本, 真)
                @ resultBool = data().AddOrUpdateCookie(@<局_左文本>.GetText(),@<局_右文本>.GetText(),@<域名>.GetText(),@<路径>.GetText());
                @ if(resultBool==FALSE) break;
            }
        }
        @ return resultBool;
    }

    方法 删除所有Cookies <公开 类型 = 逻辑型 注释 = "删除所有打开域名所产生的Cookies" @嵌入式方法 = "">
    {
        @ @sn<this>.data().DeleteAllCookies()
    }

    方法 删除Cookies <公开 类型 = 逻辑型 注释 = "删除某个域名下由打开时所产生的单条Cookies" @嵌入式方法 = "">
    参数 网址 <类型 = 文本型 注释 = "要删除Cookie的网址,如果为空文本则表示要删除Cookie的网址为当前页面." @默认值 = "">
    参数 子名称 <类型 = 文本型 注释 = "根据Cookie子名称删除一条Cookie的值." @默认值 = "">
    {
        @ @sn<this>.data().DeleteCookies(@<子名称>,@<网址>)
    }

    方法 删除目录中Cookies <公开 类型 = 逻辑型 注释 = "删除对应某个域名及路径所产生的单条Cookies" @嵌入式方法 = "">
    参数 域名 <类型 = 文本型 注释 = "与\"取Cookie信息\"方法取得值中\"域名\"相对应.">
    参数 子名称 <类型 = 文本型 注释 = "根据Cookie子名称删除一条Cookie的值." @默认值 = "">
    参数 路径 <类型 = 文本型 注释 = "Cookie影响到的路径,一般为根目录\"/\",请参考\"取Cookies信息\"方法中的path." @默认值 = "/">
    {
        @ @sn<this>.data().DeleteCookiesWithDomainAndPath(@<子名称>.GetText(),@<域名>.GetText(),@<路径>.GetText())
    }
}

类 Edge框架 <公开 注释 = "用作表述浏览页面中的一个框架." 注释 = "注意: 仅当调用\"取框架\"方法时所提供的\"Edge浏览框\"组件存在时才能对本类对象进行操作.">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserFrame)
    # <> <include>
    # @sn<current_class> (ICoreWebView2Frame* frame,CVWnd_EWVBrowser* MfcWndPtr) : @sn<current_class> ()  {
    #      data().webviewFrame = frame;
    #      data().webviewMfcWndPtr =  MfcWndPtr;
    #  }
    # <> </include>
    # @end

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "返回框架名称,名称为空时返回空文本." @嵌入式方法 = "">
    {
        @ @sn<this>.data().FrameGetName()
    }

    方法 取填表 <公开 类型 = Edge填表类 注释 = "返回Edge填表类,用于对表单操作." 注释 = "注意:填表类中的同步方法会阻止浏览器事件返回." 注释 = "所以在事件中调用将不能得到填表类方法的执行结果."
            @禁止流程检查 = 真>
    {
        @ return @dt<Edge填表类>(data().webviewFrame.get (), data().webviewMfcWndPtr); // 根据框架指针得到框架
    }

    方法 是否就绪 <公开 类型 = 逻辑型 注释 = "返回框架是否就绪" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsFrameCompleted()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回值为\"真\"时,表示当前框架为空或已经被销毁." @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsDestroyed()
    }

    方法 运行JS_异步 <公开 类型 = 逻辑型 注释 = "运行JS脚本,将触发\"Edge浏览框\"的\"JS执行完成\"事件." @禁止流程检查 = 真>
    参数 JS代码 <类型 = 文本型>
    参数 用户数据 <类型 = 变整数 注释 = "携带一个自定义数据,传送至\"JS执行完成\"事件中,用于标记或其他特殊操作." @默认值 = 0>
    {
        @ return data().ExecuteScript(@<JS代码>.GetText() , @<用户数据>);
    }

    方法 运行JS <公开 类型 = 文本型 注释 = "运行JS脚本,当\"是否就绪\"为假时,直接返回失败." @嵌入式方法 = "">
    参数 JS代码 <类型 = 文本型 编辑时信息 = "9EAA0, 0, 0, 0">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ @sn<this>.data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>)
    }

    方法 发送信息到页面 <公开 类型 = 逻辑型 注释 = "发送信息到框架页面,提供与前端页面通讯,页面启用监听JS脚本将取到内容.如:"
            注释 = "\"chrome.webview.addEventListener(\'message\', event => alert(event.data));\"." @嵌入式方法 = "">
    参数 欲发送文本 <类型 = 文本型>
    {
        @ @sn<this>.data().PostWebMessageAsString (@<欲发送文本>.GetText())
    }

    方法 发送Json信息 <公开 类型 = 逻辑型 注释 = "发送Json信息到框架页面,提供与前端页面通讯." @嵌入式方法 = "">
    参数 欲发送文本 <类型 = 文本型>
    {
        @ @sn<this>.data().PostWebMessageAsJson (@<欲发送文本>.GetText())
    }

    方法 取网页源代码 <公开 类型 = 文本型 注释 = "取当前网页源代码" @禁止流程检查 = 真>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 结果文本 <类型 = 文本型>
        @ @<结果文本>.SetText(data().ExecuteScript(_T("document.documentElement.outerHTML;"),@<超时时间>,@<状态码.值>));
        替换所有子文本 (结果文本, "\\u003C", "<")  // 由于javaScript编码会将危险字符"<"号转换成"\u003C",这里我们替换回来.
        返回 (结果文本)
    }

    方法 取网页文本 <公开 类型 = 文本型 注释 = "取当前网页文本" @嵌入式方法 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ @sn<this>.data().ExecuteScript(_T("document.documentElement.outerText;"),@<超时时间>,@<状态码.值>)
    }

    方法 取链接地址 <公开 类型 = 文本型 注释 = "取链接地址" @禁止流程检查 = 真>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        常量 JS代码 <类型 = 文本型 值 = "window.document.URL;">
        @ return data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 框架ID <公开 属性读 类型 = 整数 注释 = "返回框架ID,成功返回非0" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetFrameId()
    }

    方法 是否为主框架 <公开 属性读 类型 = 逻辑型 注释 = "是否为主框架" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsMainFrame()
    }
}

类 Edge浏览框 <公开 基础类 = 窗口组件 注释 = "支持Edge的WebView2组件,使用前请确保本地安装有Edge浏览器."
        注释 = "Edge浏览器官方下载地址: https://www.microsoft.com/zh-cn/edge"
        注释 = "Edge浏览器运行时环境官方下载地址: https://developer.microsoft.com/zh-cn/microsoft-edge/webview2/"
        @视窗.后缀文本 = "public EWVBrowserEventListener"
        @视窗.窗口组件 = "icon=\"@64\"\r\ndefault_size = \"200, 200\"\r\npreview_unsupported">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_EWVBrowser, EWVBrowserEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 环境即将创建 <公开 定义事件 类型 = 整数 注释 = "浏览器环境即将创建时触发此事件,此时可设置环境选项.">
    参数 环境选项 <类型 = Edge环境选项 注释 = "注意:如果在一个项目中使用多个浏览器组件或多个进程共用相同的\"缓存目录\",应保证此选项设置全部相同,"
            注释 = "否则应分别设置不同的\"缓存目录\" 避免因环境配置不同造成无法创建浏览器视图.">

    方法 浏览器创建完毕 <公开 定义事件 类型 = 整数 注释 = "浏览器控制器及视图创建完毕时触发此事件,此时可以发起导航,修改或获取信息,调用浏览器功能,等操作.">

    方法 载入开始 <公开 定义事件 类型 = 整数 注释 = "当浏览器开始载入将要显示的文档时触发该事件" 返回值注释 = "返回1则取消本次导航">
    参数 地址 <类型 = 文本型 注释 = "提供将要导航到的页面URL地址">
    参数 提交协议头 <类型 = 文本型 注释 = "要发送的协议头JSON文本">
    参数 导航ID <类型 = 长整数>
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">
    参数 是否重定向 <类型 = 逻辑型 注释 = "真为重定向导航">
    参数 用户发起 <类型 = 逻辑型 注释 = "真为用户操作发起的导航,而非JS脚本执行的导航行为.">
    参数 导航类型 <类型 = 整数 注释 = "0.刷新 1.后退或前进 2.新页面">

    方法 载入完毕 <公开 定义事件 类型 = 整数 注释 = "当将要显示在浏览器内的文档被载入完毕后触发本事件">
    参数 状态码 <类型 = Edge错误码 注释 = "可根据该值判断产生错误时的错误原因,如果该值为-1,则表示载入成功.">
    参数 导航ID <类型 = 长整数>
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">
    参数 HTTP状态码 <类型 = 整数 注释 = "如果导航涉及HTTP请求,则导航的状态代码.">

    方法 数据源被改变 <公开 定义事件 类型 = 整数 注释 = "数据源被改变时触发该事件">
    参数 地址 <类型 = 文本型 注释 = "数据源被改变的新页面URL地址">
    参数 是否新资源 <类型 = 逻辑型 注释 = "是否新资源">

    方法 内容被加载 <公开 定义事件 类型 = 整数 注释 = "当浏览器内容被加载时响应该事件,此操作在\"加载开始\"和\"数据源被改变\"事件之后,在\"浏览历史被改变\"和\"加载完毕\"事件之前。">
    参数 地址 <类型 = 文本型 注释 = "内容被加载时的URL地址">
    参数 是否错误页 <类型 = 逻辑型 注释 = "为真时,表示加载的内容是错误页面.">
    参数 导航ID <类型 = 长整数 注释 = "导航ID">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 文档加载完毕 <公开 定义事件 类型 = 整数 注释 = "当浏览器当解析html文档时,将触发此事件,这与html中文档的DOMContentLoaded事件一致.">
    参数 地址 <类型 = 文本型 注释 = "内容被加载时的URL地址">
    参数 导航ID <类型 = 长整数 注释 = "导航ID">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 浏览历史被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器浏览历史被改变触发此事件">
    参数 能否后退 <类型 = 逻辑型 注释 = "当前页面能否能否向后跳转" 编辑时信息 = "2C3C1, 0, 0, 0">
    参数 能否前进 <类型 = 逻辑型 注释 = "当前页面能否能否向前跳转" 编辑时信息 = "2C3C1, 0, 0, 0">

    方法 标题被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器的标题文本被改变时响应该事件">
    参数 标题文本 <类型 = 文本型 注释 = "提供具体的标题文本内容">

    方法 即将加载资源 <公开 定义事件 类型 = 整数 注释 = "在浏览器即将加载资源时触发该事件">
    参数 地址 <类型 = 文本型 注释 = "提供即将跳转到的页面URL地址">
    参数 协议头 <类型 = 文本型 注释 = "  请求头和响应头拼接在一起的JSON文本.其中\"content\"的值为\"Null\"时表示无数据内容,"
            注释 = "为\"NotNull\"时表示有数据内容,为\"BINARY_DATA\"时表示内容为二进制数据," 注释 = "其值通过\"请求数据\"和\"响应数据\"参数得到.">
    参数 请求数据 <类型 = 变整数 注释 = "请求数据指针地址,通过\"Edge浏览框.指针到数据\"方法得到字节集数据. 仅在处理本事件时有效.">
    参数 响应数据 <类型 = 变整数 注释 = "响应数据指针地址,通过\"Edge浏览框.指针到数据\"方法得到字节集数据. 仅在处理本事件时有效.">

    方法 图标被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器导航到新的地址并获得图标时触发此事件">
    参数 图标地址 <类型 = 文本型 注释 = "获得图标的URL地址" 编辑时信息 = "2C3C1, 0, 0, 0">
    参数 图像流指针 <类型 = 变整数 注释 = "  图标数据指针,可调用\"来源对象.置窗口图标\"设置窗口图标," 注释 = "或者\"Edge浏览框.指针到数据\"获得字节集数据. 仅在处理本事件时有效."
            编辑时信息 = "2C3C1, 0, 0, 0">

    方法 框架被创建 <公开 定义事件 类型 = 整数 注释 = "当框架被创建时触发本事件">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 框架被销毁 <公开 定义事件 类型 = 整数 注释 = "当框架被销毁时触发本事件">
    参数 框架指针 <类型 = 变整数 注释 = "通过\"取框架\"方法得到Edge框架">

    方法 即将打开新窗口 <公开 定义事件 类型 = 整数 注释 = "在浏览器即将打开新窗口浏览另一个页面之前产生此事件." 返回值注释 = "返回0:在新窗口打开."
            返回值注释 = "返回1:阻止弹出新窗口,如果提供了新浏览器则将其跳转到当前导航地址." 返回值注释 = "返回2:阻止弹出新窗口,如果提供了新浏览器则将其作为首次导航(浏览历史,及附加脚本失效).">
    参数 地址 <类型 = 文本型 注释 = "提供即将打开新窗口的页面URL地址.">
    参数 名称 <类型 = 文本型 注释 = "页面使用\"window.open(url, name)\"打开窗口时提供的名称.">
    参数 新浏览器指针地址 <类型 = 变整数 注释 = "  如需在另一个浏览器控件中打开页面,调用\"写指针处值 (新浏览器指针地址, Edge浏览框2.取浏览器指针 ())\"."
            注释 = "注意: 新的浏览器控件必须与当前浏览器共环境,即\"环境选项\",\"缓存目录\",\"代理\",\"同源策略\"完全相同.">

    方法 即将弹出脚本对话框 <公开 定义事件 类型 = 整数 注释 = "当\"启用默认脚本对话框\"为假,页面脚本对话框即将打开时触发此事件." 返回值注释 = "返回0表示:\"取消\"  返回1表示:\"确定\"">
    参数 网址 <类型 = 文本型 注释 = "发起对话框的URL" 编辑时信息 = "2C3C1, 0, 0, 0">
    参数 对话框类型 <类型 = 整数 注释 = "0.信息框(alert), 1.询问信息框(confirm), 2.输入框(prompt)" 编辑时信息 = "2C3C1, 0, 0, 0">
    参数 信息文本 <类型 = 文本型 注释 = "对话框提示信息">
    参数 默认文本 <类型 = 文本型 注释 = "输入框(prompt)的初始文本">
    参数 返回文本 <类型 = 文本型 注释 = "输入框(prompt)设置返回文本内容">

    方法 JS执行完成 <公开 定义事件 类型 = 整数 注释 = "执行\"运行JS\"方法后的回调函数.">
    参数 返回码 <类型 = 整数 注释 = "如果该值为0,表示操作成功,否则表示发生错误时的错误码.英文名为HRESULT类型.">
    参数 执行结果 <类型 = 文本型 注释 = "运行JS后所得到的结果,无结果返回时为null.">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">
    参数 用户数据 <类型 = 变整数 注释 = "\"运行JS\"方法时提供的用户自定义数据">

    方法 收到信息 <公开 定义事件 类型 = 整数 注释 = "当前端页面发送信息(如例子)将触发本事件,提供与前端页面通讯." 注释 = "例子:chrome.webview.postMessage(\"hello\").">
    参数 内容 <类型 = 文本型 注释 = "  所接收到信息的内容文本,如果从Web视图内容发送消息是字符串类型,则为字符串的值." 注释 = "如果发送的消息是其他类型的JS对象,则转换为JSON字符串.">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 收到文件 <公开 定义事件 类型 = 整数 注释 = "当前端页面发送文件信息将触发本事件."
            注释 = "例子:window.chrome.webview.postMessageWithAdditionalObjects(\"file\",e.dataTransfer.files)">
    参数 内容 <类型 = 文本型 注释 = "所接收到信息的内容文本，如果从Web视图内容发送消息是字符串类型，则为字符串的值。如果发送的消息是其他类型的JS对象，则转换为JSON字符串。">
    参数 文件路径 <类型 = 文本型 注释 = "如果前端发送了文件对象，此参数为完整文件名，多个文件以逗号分隔。">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 触发过滤器 <公开 定义事件 类型 = 整数 注释 = "当设置过滤器后,加载页面资源时,将根据过滤器设置触发该事件.">
    参数 地址 <类型 = 文本型 注释 = "提供已经跳转到的页面URL地址">
    参数 过滤类型 <类型 = Edge过滤类型>
    参数 协议头 <类型 = 文本型 注释 = "请求头拼接在一起的JSON文本.其中\"content\"的值为\"Null\"时表示无数据内容," 注释 = "为\"NotNull\"时表示有数据内容,其值通过\"请求数据\"参数得到.">
    参数 请求数据 <类型 = 变整数 注释 = "请求数据指针地址,通过\"Edge浏览框.指针到数据\"方法得到字节集数据.">
    参数 资源响应 <类型 = Edge资源响应 注释 = "使用\"资源响应.创建\" 应答本次请求">

    方法 自定义菜单被单击 <公开 定义事件 类型 = 整数 注释 = "当自定义菜单被单击时触发该事件">
    参数 菜单序号 <类型 = 整数 注释 = "被单击的菜单序号">
    参数 选中信息 <类型 = 文本型 注释 = "返回json格式的文本,指示鼠标所在位置信息,包含选中类型,是否是输入框,网址,链接文本,链接地址等.">
    参数 选框状态 <类型 = 逻辑型 注释 = "当类型为复选框或单选框时,提示是否选中状态.其他类型均返回假.">
    参数 菜单项 <类型 = Edge菜单项 注释 = "当前被点击菜单项目信息">

    方法 远程调试回调 <公开 定义事件 类型 = 整数 注释 = "开启远程调试时将响应该事件">
    参数 返回码 <类型 = 整数 注释 = "如果该值为0,表示操作成功,否则表示发生错误时的错误码.英文名为HRESULT类型.">
    参数 结果文本 <类型 = 文本型 注释 = "JSON形式文本,执行远程调试后返回值结果.">

    方法 远程调试接收 <公开 定义事件 类型 = 整数 注释 = "远程调试会话收到的事件">
    参数 网址 <类型 = 文本型 注释 = "没有网址时为空文本">
    参数 会话标识 <类型 = 文本型 注释 = "没有会话标识时为空文本">
    参数 目标标识 <类型 = 文本型 注释 = "没有目标标识时为空文本">
    参数 类型 <类型 = 文本型 注释 = "没有类型时为空文本">
    参数 完整文本 <类型 = 文本型 注释 = "远程调试项完整响应结果,JSON形式文本.">

    方法 功能键被按下 <公开 定义事件 类型 = 整数 注释 = "浏览框在激活状态下,当功能键被按下时将触发该事件." 返回值注释 = "返回非0阻止按键事件传递">
    参数 按键种类 <类型 = Edge按键种类 注释 = "系统非系统功能键按下或弹起">
    参数 键控代码 <类型 = 整数 注释 = "键盘扫描码">
    参数 扩展消息 <类型 = 整数 注释 = "0-15位：指定当前消息的重复次数.其值就是用户按下该键后自动重复的次数,但是重复次数不累积." 注释 = "16-23位：指定其扫描码,其值依赖于OEM厂商."
            注释 = "24位：指定该按键是否为扩展按键,所谓扩展按键就是Ctrl,Alt之类的,如果是扩展按键,其值为1,否则为0." 注释 = "25-28位：保留字段,暂时不可用."
            注释 = "29位：指定按键时的上下文,其值为1时表示在按键时Alt键被按下." 注释 = "30位：指定该按键之前的状态,其值为1时表示该消息发送前,该按键是被按下的,其值为0表示该消息发送前该按键是抬起的."
            注释 = "31位：指定其转换状态.">

    方法 框架名被改变 <公开 定义事件 类型 = 整数 注释 = "当框架的名称发生改变时响应该事件">
    参数 新名称 <类型 = 文本型 注释 = "框架新名称">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 权限请求 <公开 定义事件 类型 = 整数 注释 = "服务器获取本地权限请求时响应该事件." 注释 = "返回值设置为0时,以默认方法响应请求."
            注释 = "返回值设置为1时,指定授予该权限请求,当指定该权限时,如果没能通过服务器验证,而导致出错时,请设置为其他值." 注释 = "返回值设置为2时,拒绝提供权限.">
    参数 地址 <类型 = 文本型 注释 = "请求数据时的URL地址,当为框架时始终为空文本,请通过框架方法取URL地址.">
    参数 数据类型 <类型 = Edge数据类型 注释 = "Edge数据类型.*,请求连接的数据类型.当为框架时始终为\"未知权限\".">
    参数 是否手势操作 <类型 = 逻辑型 注释 = "当导航是通过用户手势而不是通过页面脚本进行编程导航时其值为\"真\".当为框架时始终为\"假\".">
    参数 框架指针 <类型 = 变整数 注释 = "其值不为0时,表示事件由框架引发而产生.通过\"取框架\"方法得到Edge框架.">

    方法 视图尝试挂起 <公开 定义事件 类型 = 整数 注释 = "在控件最小化或不可视时,应用程序可以调用\"尝试挂起\"以使浏览器消耗更少的内存." 注释 = "挂起将暂停视图脚本计时器和动画,最大限度地减少浏览器渲染器进程的CPU使用."
            注释 = "并允许操作系统将渲染器进程使用的内存重新用于其他进程." 注释 = "请注意,一旦请求被发送到浏览器渲染器进程,就被认为已成功完成."
            注释 = "如果有一个正在运行的脚本,该脚本将继续运行,并且在该脚本完成后,渲染器进程将挂起." 注释 = "当视图可视时,将自动恢复,一般不需要显式的调用\"挂起恢复\".">
    参数 是否成功 <类型 = 逻辑型 注释 = "挂起命令是否已成功发送到渲染器进程">

    方法 请求关闭窗口 <公开 定义事件 类型 = 整数 注释 = "当视图中的内容请求关闭窗口时,例如在运行JS Window.Close时,会触发此事件.">

    方法 全屏模式被改变 <公开 定义事件 类型 = 整数 注释 = "视图中的HTML元素可能会进入或离开与视图大小相同的全屏模式,例如当视频元素请求全屏显示时." 注释 = "触发此事件用于响应调整窗口视图的大小或标题栏的显示.">
    参数 是否全屏 <类型 = 逻辑型 注释 = "真为页面元素进入全屏模式">

    方法 即将开始下载 <公开 定义事件 类型 = 整数 注释 = "下载开始时引发此事件,可阻止默认下载对话框,或取消下载." 返回值注释 = "返回0:下载,显示默认下载对话框. 返回1:下载,不显示默认下载对话框. 返回2:取消下载.">
    参数 下载网址 <类型 = 文本型 注释 = "下载文件的URL">
    参数 文件类型 <类型 = 文本型 注释 = "即:\"mimeType\"">
    参数 内容说明 <类型 = 文本型 注释 = "即:\"Content-Disposition\"标头">
    参数 保存文件名 <类型 = 文本型 注释 = "引用参数:默认的保存完整路径文件名,如要修改保存路径重新赋值此参数为完整文件名即可.">

    方法 下载进度已改变 <公开 定义事件 类型 = 整数 注释 = "当下载状态或进度变更时引发此事件.">
    参数 下载网址 <类型 = 文本型 注释 = "下载文件的URL">
    参数 保存文件名 <类型 = 文本型 注释 = "保存完整路径文件名">
    参数 文件总字节数 <类型 = 长整数 注释 = "文件总字节数">
    参数 已接收字节数 <类型 = 长整数 注释 = "已接收字节数">
    参数 下载状态 <类型 = 整数 注释 = "下载状态 0:下载进行中  1:下载中断  2:下载已完成">
    参数 下载操作 <类型 = Edge下载操作 注释 = "操作当前下载\"暂停\",\"恢复\"或\"取消\"">

    方法 音频播放或静音状态被改变 <公开 定义事件 类型 = 整数 注释 = "当文档播放音频或静音状态被更改时触发此事件">
    参数 是否正在播放音频 <类型 = 逻辑型 注释 = "是否正在播放音频">
    参数 是否已静音 <类型 = 逻辑型 注释 = "是否已静音">

    方法 请求基本身份验证 <公开 定义事件 类型 = 整数 注释 = "当访问带有身份验证凭据的请求时触发此事件,主机可提供验证凭据响应或取消请求." 返回值注释 = "返回0:不做处理,弹出默认的身份质询对话框."
            返回值注释 = "返回1:主机将参数\"用户名\",\"密码\"作为响应提交身份验证." 返回值注释 = "返回2:取消身份验证.">
    参数 发起网址 <类型 = 文本型 注释 = "发起身份验证的URL">
    参数 质询内容 <类型 = 文本型 注释 = "身份验证质询字符串">
    参数 用户名 <类型 = 文本型 注释 = "引用参数:提交用户名">
    参数 密码 <类型 = 文本型 注释 = "引用参数:提交密码">

    方法 状态栏文本被改变 <公开 定义事件 类型 = 整数 注释 = "当状态栏文本被更改时触发此事件">
    参数 状态栏文本 <类型 = 文本型 注释 = "状态栏文本">

    方法 即将导航到外部URI <公开 定义事件 类型 = 整数 注释 = "  当浏览器即将启动一个外部URI时,将触发此事件."
            注释 = "如:浏览器导航到\"calculator://\"默认将弹出对话框询问是否打开计算器,此时可以取消或接管启动操作." 返回值注释 = "返回0:弹出默认询问对话框" 返回值注释 = "返回1:取消启动,行为由调用者接管.">
    参数 URI <类型 = 文本型 注释 = "发起的外部URI">
    参数 发起源 <类型 = 文本型 注释 = "发起源">

    #
    # 属性 --

    方法 用户代理 <公开 属性读 类型 = 文本型 注释 = "英文名:UserAgent,简称UA." @禁止流程检查 = 真>
    {
        @ return ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->GetUserAgent();
    }

    方法 用户代理 <公开 属性写 注释 = "英文名:UserAgent,简称UA." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的值 <类型 = 文本型>
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->SetUserAgent(@<所欲设置的值>);
    }

    方法 代理服务器 <公开 属性写 注释 = "设置代理服务器,由地址加端口号组成的字符串,如:127.0.0.1:8888." 注释 = "必须在创建前设置,才能生效." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的值 <类型 = 文本型 注释 = "由地址加端口号组成的字符串">
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->m_proxyServer = @<所欲设置的值>.GetText();
    }

    方法 远程调试端口 <公开 属性写 注释 = "添加远程调试端口,同缓存目录下只能设置一个端口号." 注释 = "必须在创建前设置,才能生效."
            注释 = "如设置9222端口,则可通过\"http://localhost:9222/json\",获取websocket连接方式." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的值 <类型 = 整数>
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->m_debuggingPort = @<所欲设置的值>;
    }

    方法 缓存目录 <公开 属性读 类型 = 文本型 注释 = "返回浏览网页所产生缓存文件的存放目录" @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->GetUserDataFolder()
    }

    方法 缓存目录 <公开 属性写 注释 = "设置浏览网页所产生缓存文件的存放目录." 注释 = "必须在组件创建前设置,才能生效." @视窗.设置时机 = 组件创建前>
    参数 所欲设置目录 <类型 = 文本型 注释 = "指定已经存在的目录作为缓存路径,如提供目录不存在,将尝试创建该目录." 注释 = "为空或创建指定目录失败将基于当前被执行文件所处目录创建默认缓存目录."
            注释 = "不设置本属性将使用位于系统临时目录中的默认目录位置.">
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->m_strUserDataFolder.SetText (@<所欲设置目录>);
    }

    方法 固定版本运行时目录 <公开 属性读 类型 = 文本型 注释 = "返回所指定的WebView2固定版本运行时环境所处文件目录" @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->m_browserExecutableFolder
    }

    方法 固定版本运行时目录 <公开 属性写 注释 = "  指定使用WebView2的固定版本运行时环境.本方法必须在组件创建前设置."
            注释 = "  WebView2 的固定版本运行时环境允许开发者将 WebView2 运行时环境作为一个应用程序的私有依赖项进行分发,"
            注释 = "而不是依赖于用户系统上可能已安装的 WebView2 运行时环境. 这种方式确保了应用程序使用的 WebView2 版本是"
            注释 = "固定的,并且可以避免由于用户系统中已安装的 WebView2 运行时版本不兼容或未安装导致的问题." @视窗.设置时机 = 组件创建前>
    参数 目录 <类型 = 文本型 注释 = "提供所欲使用的WebView2固定版本运行时环境所处文件目录,可以是相对当前可执行文件所处目录的路径也可以是绝对路径.">
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->m_browserExecutableFolder.SetText (@<目录>); 
    }

    方法 清除缓存 <公开 类型 = 逻辑型 注释 = "清除浏览网页所产生缓存文件" @嵌入式方法 = "">
    参数 缓存类型 <类型 = Edge缓存类型 注释 = "表示所要删除的缓存类型.当\"时间范围\"值为-1时,忽略该参数." @默认值 = Edge缓存类型.所有项目>
    参数 时间范围 <类型 = 整数 注释 = "单位秒." 注释 = "值为-1时,表示删除全部类型缓存." 注释 = "值为0时,表示根据缓存类型清除所有时间缓存数据." 注释 = "值大于0时,则根据类型和时间段清理缓存数据."
            @默认值 = -1>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->ClearBrowsingData(@<缓存类型>,@<时间范围>,@<超时时间>,@<状态码.值>)
    }

    方法 链接地址 <公开 属性读 类型 = 文本型 注释 = "返回主框架所浏览页面的链接地址" @嵌入式方法 = "">
