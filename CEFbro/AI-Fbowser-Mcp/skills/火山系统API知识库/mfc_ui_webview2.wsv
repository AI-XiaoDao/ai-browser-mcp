类 Edge下载操作 <公开 注释 = "用于对下载过程控制操作" @文档 = "category = \"辅助类\"">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserDownloadOperation)
    # <> <include>
    # @sn<current_class> (ICoreWebView2DownloadOperation *downloadOperation) : @sn<current_class> ()  {
    #      data().m_downloadOperation = downloadOperation;
    #  }
    # <> </include>
    # @end

    方法 暂停 <公开 类型 = 逻辑型 注释 = "暂停下载" @嵌入式方法 = "">
    {
        @ @sn<this>.data().Pause()
    }

    方法 能否恢复 <公开 类型 = 逻辑型 注释 = "下载被中断后能否恢复下载" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetCanResume()
    }

    方法 恢复 <公开 类型 = 逻辑型 注释 = "恢复被中断的下载" @嵌入式方法 = "">
    {
        @ @sn<this>.data().Resume()
    }

    方法 取消下载 <公开 类型 = 逻辑型 注释 = "取消当前下载过程,下载被终止." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Cancel();
    }

    方法 取下载总字节数 <公开 类型 = 长整数 注释 = "取当前下载文件的总大小,尚未开始下载或失败则返回-1." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetTotalBytesToReceive()
    }

    方法 取已接收字节数 <公开 类型 = 长整数 注释 = "取当前下载的已接收字节数,尚未开始下载或失败则返回-1." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetBytesReceived()
    }

    方法 取下载文件内容说明 <公开 类型 = 文本型 注释 = "即:\"Content-Disposition\"标头" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetContentDisposition();
    }

    方法 取下载预计完成时间 <公开 类型 = 文本型 注释 = "取下载预计完成时间,注意时区." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetEstimatedEndTime()
    }

    方法 取下载文件类型 <公开 类型 = 文本型 注释 = "即:\"mimeType\"" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetMimeType()
    }

    方法 取下载文件名 <公开 类型 = 文本型 注释 = "下载保存的完整路径文件名" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetResultFilePath()
    }

    方法 取下载网址 <公开 类型 = 文本型 注释 = "即下载来源URL" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetUri()
    }

    方法 取下载状态 <公开 类型 = 整数 注释 = "下载状态: 0:下载进行中;  1:下载中断;  2:下载已完成; -1:未开始下载或获取状态失败." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetState()
    }

    方法 取下载中断原因 <公开 类型 = Edge下载中断原因 注释 = "查看\"Edge下载中断原因\"常量" @嵌入式方法 = "">
    {
        @ (@dt<Edge下载中断原因>)@sn<this>.data().GetInterruptReason()
    }
}

类 Edge下载中断原因 <公开 注释 = "下载中断原因" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 空 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NONE 编辑时信息 = "18786, 0, 0, 0">
    常量 文件错误 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_FAILED 编辑时信息 = "18786, 0, 0, 0">
    常量 文件访问被拒绝 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_ACCESS_DENIED 编辑时信息 = "18786, 0, 0, 0">
    常量 文件没有空间 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_NO_SPACE 编辑时信息 = "18786, 0, 0, 0">
    常量 文件名过长 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_NAME_TOO_LONG 编辑时信息 = "18786, 0, 0, 0">
    常量 文件过长 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_TOO_LARGE 编辑时信息 = "18786, 0, 0, 0">
    常量 恶意文件 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_MALICIOUS 编辑时信息 = "18786, 0, 0, 0">
    常量 文件瞬态错误 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_TRANSIENT_ERROR 编辑时信息 = "18786, 0, 0, 0">
    常量 文件被策略阻止 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_BLOCKED_BY_POLICY 编辑时信息 = "18786, 0, 0, 0">
    常量 文件安全检查失败 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_SECURITY_CHECK_FAILED 编辑时信息 = "18786, 0, 0, 0">
    常量 文件太短 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_TOO_SHORT 编辑时信息 = "18786, 0, 0, 0">
    常量 文件哈希不匹配 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_FILE_HASH_MISMATCH 编辑时信息 = "18786, 0, 0, 0">
    常量 网络故障 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NETWORK_FAILED 编辑时信息 = "18786, 0, 0, 0">
    常量 网络超时 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NETWORK_TIMEOUT 编辑时信息 = "18786, 0, 0, 0">
    常量 网络断开 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NETWORK_DISCONNECTED 编辑时信息 = "18786, 0, 0, 0">
    常量 网络服务器关闭 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NETWORK_SERVER_DOWN 编辑时信息 = "18786, 0, 0, 0">
    常量 网络无效请求 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_NETWORK_INVALID_REQUEST 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器失败 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_FAILED 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器无响应 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_NO_RANGE 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器错误内容 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_BAD_CONTENT 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器未经授权 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_UNAUTHORIZED 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器证书问题 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_CERTIFICATE_PROBLEM 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器被禁止 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_FORBIDDEN 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器意外响应 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_UNEXPECTED_RESPONSE 编辑时信息 = "18786, 0, 0, 0">
    常量 服务器内容长度不匹配 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_CONTENT_LENGTH_MISMATCH>
    常量 服务器跨原点重定向 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_SERVER_CROSS_ORIGIN_REDIRECT 编辑时信息 = "18786, 0, 0, 0">
    常量 用户取消 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_USER_CANCELED 编辑时信息 = "18786, 0, 0, 0">
    常量 用户关闭 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_USER_SHUTDOWN 编辑时信息 = "18786, 0, 0, 0">
    常量 用户暂停 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_USER_PAUSED 编辑时信息 = "18786, 0, 0, 0">
    常量 下载进程崩溃 <公开 值 = @COREWEBVIEW2_DOWNLOAD_INTERRUPT_REASON_DOWNLOAD_PROCESS_CRASHED 编辑时信息 = "18786, 0, 0, 0">
}

