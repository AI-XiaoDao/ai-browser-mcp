类 Edge资源响应 <公开 注释 = "用于在过滤器中应答或拦截资源请求." 注释 = "注意: 本类对象只能在接收到\"触发过滤器\"事件时基于其\"资源响应\"参数使用,在事件接收方法退出后不能再使用."
        @文档 = "category = \"辅助类\"">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserWebResourceResponse)
    # <> <include>
    # @sn<current_class> (ICoreWebView2WebResourceResponse **resourceResponse, CVWnd_EWVBrowser *webviewEWVBrowserPtr) : @sn<current_class> ()  {
    #      data().m_response = resourceResponse;
    #      data().webviewEWVBrowserPtr = webviewEWVBrowserPtr;
    #  }
    # <> </include>
    # @end

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建一个资源响应对象,用于应答或拦截资源请求" @嵌入式方法 = "">
    参数 响应数据 <类型 = 字节集类 注释 = "响应数据">
    参数 标头 <类型 = 文本型 注释 = "响应头 例:\"Content-Type: image/jpeg\" 或 \"Content-Type:text/html; charset=utf-8\""
            注释 = "多个响应头用换行符(\'\\n\')隔开.">
    参数 状态码 <类型 = 整数 注释 = "状态码 默认:200" @默认值 = 200>
    参数 响应短语 <类型 = 文本型 注释 = "响应短语" @默认值 = "OK">
