    方法 允许开发工具 <公开 属性写 注释 = "设置是否允许按F12来开启开发工具" @视窗.设置时机 = 组件创建前>
    参数 许可状态 <类型 = 逻辑型>
    {
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->m_DevTools = @<许可状态>;
    }

    # 方法 --

    方法 添加自定义菜单 <公开 类型 = 整数 注释 = "在右键菜单最后位置添加菜单项,可多次添加多项菜单,成功返回菜单序号." 注释 = "当所有菜单项添加完成,使用\"启用自定义菜单\"方法使其生效."
            返回值注释 = "成功返回新增菜单序号,失败返回-1." @嵌入式方法 = "">
    参数 菜单标题 <类型 = 文本型 注释 = "菜单新增项上显示的文本">
    参数 菜单类型 <类型 = Edge菜单类型 注释 = "所要新增菜单类型" @默认值 = Edge菜单类型.命令>
    参数 触发对象 <类型 = Edge菜单触发对象 注释 = "选择触发对象.当为多级子菜单时,该属性由一级菜单决定,则忽略该参数." @默认值 = Edge菜单触发对象.页面>
    参数 ico图片 <类型 = 文本型 注释 = "提供ico图片路径,在菜单标题左边显示." @默认值 = "">
    参数 是否选中 <类型 = 逻辑型 注释 = "当类型为复选框或单选框时,设置其选中状态.其他选项无效." @默认值 = 真>
    参数 是否禁用 <类型 = 逻辑型 注释 = "当为真时,菜单项为灰色不可用状态,无法触发单击事件或选择下级菜单." @默认值 = 假>
    参数 父菜单序号 <类型 = 整数 注释 = "如属父菜单子项,请指定父菜单序号,且所指定父菜单类型须为多级菜单." 注释 = "子项只能依次添加.如果该值为-1表示1级菜单." @默认值 = -1>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->CreateContextMenuItem(@<菜单标题>, (COREWEBVIEW2_CONTEXT_MENU_ITEM_KIND)@<菜单类型>, (COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND)@<触发对象>, @<ico图片>,@<是否选中>,@<是否禁用>,@<父菜单序号>)
    }

    方法 置自定义菜单项状态 <公开 注释 = "设置菜单项禁用状态及类型为选择框时的选中状态" @嵌入式方法 = "">
    参数 菜单序号 <类型 = 整数 注释 = "添加自定义菜单所返回的菜单序号">
    参数 是否选中 <类型 = 逻辑型 注释 = "当类型为复选框或单选框时,设置其选中状态.其他选项无效." @默认值 = 真>
    参数 是否禁用 <类型 = 逻辑型 注释 = "当为真时,菜单项为灰色不可用状态,无法触发单击事件或选择下级菜单." @默认值 = 假>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->SetCreateContextMenuStatus(@<菜单序号>,@<是否选中>,@<是否禁用>)
    }

    方法 启用自定义菜单 <公开 类型 = 整数 注释 = "自定义菜单添加后,使用该方法使其生效,菜单被点击时将触发\"自定义菜单被点击\"事件." 返回值注释 = "成功返回新增菜单序号" @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->m_customMenuEnabled = TRUE
    }

    方法 停用自定义菜单 <公开 类型 = 逻辑型 注释 = "清空右键菜单所有自定义选项,并停止响应\"自定义菜单被点击\"事件." @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->m_customMenuEnabled = FALSE
    }

    方法 清空自定义菜单 <公开 类型 = 逻辑型 注释 = "清空右键菜单所有自定义选项,并停止响应\"自定义菜单被点击\"事件." @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->RemoveContextMenuRequested()
    }

    方法 添加附加脚本 <公开 类型 = 文本型 注释 = "可多次添加,提供的JavaScript添加到应在创建全局对象之后、解析HTML文档之前以及运行HTML文档中包含的任何其他脚本之前运行的脚本列表."
            返回值注释 = "返回文本型脚本ID标识" @嵌入式方法 = "">
    参数 所欲运行的脚本 <类型 = 文本型>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->SetJavaScriptDocumentCreated(@<所欲运行的脚本>.GetText(), @<超时时间>)
    }

    方法 删除附加脚本 <公开 类型 = 逻辑型 注释 = "根据\"添加运行前脚本\"方法所获得的脚本ID进行反向操作" @嵌入式方法 = "">
    参数 脚本ID <类型 = 文本型 注释 = "提供要删除的脚本ID标识">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->RemoveJavaScriptDocumentCreated(@<脚本ID>.GetText())
    }

    方法 启动开发工具 <公开 注释 = "启动并显示开发工具窗口" @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->OpenDevToolsWindow ()
    }

    方法 运行JS_异步 <公开 类型 = 逻辑型 注释 = "运行JS脚本,将触发\"JS执行完成\"事件." @嵌入式方法 = "">
    参数 JS代码 <类型 = 文本型 编辑时信息 = "9EAA0, 0, 0, 0">
    参数 用户数据 <类型 = 变整数 注释 = "携带一个自定义数据,传送至\"JS执行完成\"事件中,用于标记或其他特殊操作." @默认值 = 0>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->ExecuteScript(@<JS代码>.GetText(), @<用户数据>)
    }

    方法 运行JS <公开 类型 = 文本型 注释 = "运行JS脚本" @嵌入式方法 = "">
    参数 JS代码 <类型 = 文本型 编辑时信息 = "9EAA0, 0, 0, 0">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>)
    }

    方法 取网页源代码 <公开 类型 = 文本型 注释 = "取当前网页源代码" "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 结果文本 <类型 = 文本型>
        @ @<结果文本>.SetText(((CVWnd_EWVBrowser*)GetMfcWndPtr ())->ExecuteScript(_T("document.documentElement.outerHTML;"),@<超时时间>,@<状态码.值>));
        替换所有子文本 (结果文本, "\\u003C", "<")  // 由于javaScript编码会将危险字符"<"号转换成"\u003C",这里我们替换回来.
        返回 (结果文本)
    }

    方法 取网页文本 <公开 类型 = 文本型 注释 = "取当前网页文本" @嵌入式方法 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->ExecuteScript(_T("document.documentElement.outerText;"),@<超时时间>,@<状态码.值>)
    }

    方法 加载HTML <公开 注释 = "加载HTML源代码" @嵌入式方法 = "">
    参数 HTML源码 <类型 = 文本型>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->NavigateToString(@<HTML源码>.GetText ())
    }

    方法 指针到数据 <公开 静态 类型 = 整数 注释 = "将提交数据指针及响应数据指针转换到字节集" 返回值注释 = "失败返回-1,成功返回在\"数据结果\"中填入的数据长度." @嵌入式方法 = "">
    参数 指针地址 <类型 = 变整数>
    参数 数据结果 <类型 = 字节集类 注释 = "用作存放所获得的数据">
    {
        @ CVWnd_EWVBrowser::GetSourceDataWithAddr(@<指针地址>,@<数据结果>)
    }

    方法 打印到PDF <公开 注释 = "将页面打印到PDF,目前不支持其他程序化打印." "">
    参数 文件名 <类型 = 文本型>
    参数 链接文本 <类型 = 文本型 注释 = "当\"打印页眉页脚\"为\"真\"和\"打印当前链接\"为\"假\"且该参数不为空文本时,表示覆盖打印链接为所设的值." @默认值 = "">
    参数 上边距 <类型 = 小数 注释 = "以英寸为单位的上边距.默认值为 1 厘米即 ~0.4 英寸." @默认值 = 0.4>
    参数 下边距 <类型 = 小数 注释 = "以英寸为单位的下边距.默认值为 1 厘米即 ~0.4 英寸." @默认值 = 0.4>
    参数 左边距 <类型 = 小数 注释 = "以英寸为单位的左边距.默认值为 1 厘米即 ~0.4 英寸." @默认值 = 0.4>
    参数 右边距 <类型 = 小数 注释 = "以英寸为单位的右边距.默认值为 1 厘米即 ~0.4 英寸." @默认值 = 0.4>
    参数 纵横向 <类型 = Edge打印方向 注释 = "方向可以是纵向或横向" @默认值 = Edge打印方向.纵向>
    参数 页面高度 <类型 = 小数 注释 = "以英寸为单位的页面高度.默认高度为 11 英寸." @默认值 = 11>
    参数 页面宽度 <类型 = 小数 注释 = "以英寸为单位的页面宽度.默认宽度为 8.5 英寸." @默认值 = 8.5>
    参数 比例 <类型 = 小数 注释 = "比例因子是介于 0.1 和 2.0 之间的值.默认值为 1.0." @默认值 = 1>
    参数 打印背景 <类型 = 逻辑型 注释 = "指示是否打印背景颜色和图像" @默认值 = 真>
    参数 打印页眉页脚 <类型 = 逻辑型 注释 = "指示是否打印页眉和页脚" @默认值 = 假>
    参数 打印当前链接 <类型 = 逻辑型 注释 = "当\"打印页眉页脚\"为\"真\"时,指示是否打印当前页面链接地址.当值为\"假\"时,则打印\"链接文本\"所提供内容." @默认值 = 假>
    参数 打印选中 <类型 = 逻辑型 注释 = "只打印最后在文档中选择的HTML" @默认值 = 假>
    {
        变量 局_链接文本 <类型 = 文本型>
        局_链接文本 = 选择 (打印当前链接, 链接地址, 链接文本)
        @ ((CVWnd_EWVBrowser*)GetMfcWndPtr ())->PrintToPdfAsync(@<文件名>.GetText (),@<局_链接文本>.GetText(),@<上边距>,@<下边距>,@<左边距>,@<右边距>,@<纵横向>,@<页面高度>,@<页面宽度>,@<比例>,@<打印背景>,@<打印页眉页脚>,@<打印选中>);
    }

    方法 快照 <公开 类型 = 逻辑型 注释 = "截取当前页面快照,保存到指定格式文件." @嵌入式方法 = "">
    参数 文件路径 <类型 = 文本型 注释 = "指定要保存的带后缀名的文件路径">
    参数 快照格式 <类型 = Edge快照格式 注释 = "指定保存格式" @默认值 = Edge快照格式.PNG>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->SaveScreenshot(@<文件路径>.GetText (),(COREWEBVIEW2_CAPTURE_PREVIEW_IMAGE_FORMAT)@<快照格式>,@<超时时间>,@<状态码.值>)
    }

    方法 添加过滤器 <公开 类型 = 逻辑型 注释 = "添加过滤器,该方法将触发响应\"触发过滤器\"事件,如过滤多种资源,可多次使用." @嵌入式方法 = "">
    参数 过滤器 <类型 = 文本型
            注释 = "支持匹配符*,如\"*://contoso.com/*\"可匹配到\"https://contoso.com/a/b/c\";\"*example/\"可匹配到\"https://example\"." @默认值 = "*">
    参数 过滤类型 <类型 = Edge过滤类型 注释 = "Edge过滤类型.*,设置资源的类型." @默认值 = Edge过滤类型.所有资源>
    参数 开启事件 <类型 = 逻辑型 注释 = "是否开始开启\"触发过滤器\"事件,多次添加时,可在最后开启." @默认值 = 真>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->WebResourceRequested(@<过滤器>.GetText (),(COREWEBVIEW2_WEB_RESOURCE_CONTEXT)@<过滤类型>,@<开启事件>)
    }

    方法 删除过滤器 <公开 类型 = 逻辑型 注释 = "添加过滤器的反向操作,可删除其中一个或多个过滤器." @嵌入式方法 = "">
    参数 过滤器 <类型 = 文本型
            注释 = "支持匹配符*,如\"*://contoso.com/*\"可匹配到\"https://contoso.com/a/b/c\";\"*example/\"可匹配到\"https://example\"." @默认值 = "*">
    参数 过滤类型 <类型 = Edge过滤类型 注释 = "Edge过滤类型.*,设置资源的类型." @默认值 = Edge过滤类型.所有资源>
    参数 关闭事件 <类型 = 逻辑型 注释 = "关闭响应\"触发过滤器\"事件" @默认值 = 真>
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->RemoveWebResourceRequestedFilter(@<过滤器>.GetText (),(COREWEBVIEW2_WEB_RESOURCE_CONTEXT)@<过滤类型>,@<关闭事件>)
    }

