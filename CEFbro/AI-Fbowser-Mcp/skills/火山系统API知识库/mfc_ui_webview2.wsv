    }

    方法 开启远程调试 <公开 类型 = 逻辑型 注释 = "提供cdp协议通讯,无需通过WebSocket作为中介,无需开启远程调试端口也能,直接访问的方法."
            注释 = "cdp协议简称chrome调试协议(Chrome DevTools Protocol),是基于 scoket(websocket、usb、adb)消息的 json rpc 协议."
            注释 = "用来调用 chrome 内部的方法实现 js,css ,dom 的开发调试." 注释 = "调用成功将响应\"远程调试回调\"事件." @嵌入式方法 = "">
    参数 方法 <类型 = 文本型 注释 = "如:\"Runtime.enable\".">
    参数 参数 <类型 = 文本型 注释 = "默认为空参数" @默认值 = "{}">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->CallDevToolsProtocolMethod (@<方法>,@<参数>)
    }

    方法 开启会话远程调试 <公开 注释 = "提供cdp协议通讯,如果获取到会话标识,有针对性对会话标识进行cdp协议通讯." @嵌入式方法 = "">
    参数 会话标识 <类型 = 文本型 注释 = "监听某些事件会返回会话标识.多用于框架.">
    参数 方法 <类型 = 文本型 注释 = "如:\"Runtime.getHeapUsage\".">
    参数 参数 <类型 = 文本型 注释 = "默认为空参数" @默认值 = "{}">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->CallDevToolsProtocolMethodForSession (@<会话标识>,@<方法>,@<参数>)
    }

    方法 添加远程调试接收 <公开 类型 = 长整数 注释 = "提供远程调试会话监控." 注释 = "调用成功将响应\"远程调试接收\"事件." 返回值注释 = "返回事件标志,失败返回0." @嵌入式方法 = "">
    参数 方法 <类型 = 文本型 注释 = "如控制台信息:\"Runtime.consoleAPICalled\"." 注释 = "更多方法可打开浏览器的协议监视器(protocol monitor)进行查看.">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->AddDevToolsProtocolEventReceived (@<方法>)
    }

    方法 删除远程调试接收 <公开 类型 = 逻辑型 注释 = "删除远程调试会话监控" @嵌入式方法 = "">
    参数 方法 <类型 = 文本型 注释 = "如控制台信息:\"Runtime.consoleAPICalled\".与\"添加远程调试接收\"方法中的参数一致.">
    参数 事件标志 <类型 = 长整数 注释 = "\"添加远程调试接收\"方法返回的事件标志.">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->RemoveDevToolsProtocolEventReceived (@<方法>,@<事件标志>)
    }

