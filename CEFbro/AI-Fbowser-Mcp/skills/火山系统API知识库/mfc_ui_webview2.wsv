    方法 取环境运行时版本号 <公开 类型 = 文本型 注释 = "返回当前正在运行的环境所使用的浏览器运行时版本号." 返回值注释 = "设置使用\"独立运行时目录\"此版本号即为独立运行时的版本." @嵌入式方法 = "">
    {
        @ ((CVWnd_EWVBrowser*)@sn<this>.GetMfcWndPtr ())->GetEnvironmentBrowserVersionString()
    }

    方法 置窗口图标 <公开 类型 = 逻辑型 注释 = "将\"图标被改变\"事件中获得的图像流指针转为图标句柄并设置窗口图标">
    参数 窗口句柄 <类型 = 变整数 注释 = "窗口句柄">
    参数 图像流指针 <类型 = 变整数 注释 = "\"图标被改变\"事件中获得的图像流指针">
    {
        如果 (图像流指针 != 0 && 窗口句柄 != 0)
        {
            @ if (g_objVolApp.InitGDIPlus () == FALSE) 
            @     return FALSE;
            @ CVWnd_EWVBrowser* pBrowser = (CVWnd_EWVBrowser*)GetMfcWndPtr ();
            @ if (pBrowser->m_hWinIcon != NULL)  { DestroyIcon(pBrowser->m_hWinIcon); pBrowser->m_hWinIcon = NULL; }
            @ Gdiplus::Bitmap iconBitmap((IStream*)@<图像流指针>);
            @ if (iconBitmap.GetHICON(&pBrowser->m_hWinIcon) == Gdiplus::Status::Ok ) {
            @     ::SendMessage((HWND)@<窗口句柄>, WM_SETICON, ICON_SMALL, (LPARAM)pBrowser->m_hWinIcon);
            @     return TRUE;
            @ }
            @ SendMessage((HWND)@<窗口句柄>, WM_SETICON, ICON_SMALL, (LPARAM)IDC_NO);
        }
        返回 (假)
    }

    方法 取是否允许外部拖放 <公开 类型 = 逻辑型 注释 = "是否允许外部向浏览器中拖放,默认为真." @嵌入式方法 = "">
