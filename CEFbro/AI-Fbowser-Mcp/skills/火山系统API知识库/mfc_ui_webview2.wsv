    参数 附加参数 <类型 = 文本型>
    {
        @ data().PutAdditionalBrowserArguments(@<附加参数>);
    }

    方法 语言 <公开 属性读 类型 = 文本型 注释 = "默认显示语言" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLanguage()
    }

    方法 语言 <公开 属性写 注释 = "默认显示语言">
    参数 语言 <类型 = 文本型>
    {
        @ data().PutLanguage(@<语言>);
    }

    方法 目标兼容浏览器版本 <公开 属性读 类型 = 文本型 注释 = "指定与应用程序兼容所需的WebView2运行时版本" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetTargetCompatibleBrowserVersion()
    }

    方法 目标兼容浏览器版本 <公开 属性写 注释 = "指定与应用程序兼容所需的WebView2运行时版本">
    参数 兼容浏览器版本 <类型 = 文本型>
    {
        @ data().PutTargetCompatibleBrowserVersion(@<兼容浏览器版本>);
    }

    方法 允许使用主帐户登录 <公开 属性写 注释 = "其他进程是否可以使用与当前相同用户数据文件夹,从而共享相同的浏览器进程实例," 注释 = "为真时如果其他进程也与当前设置的相同的用户数据文件夹则环境将创建失败.">
    参数 是否允许 <类型 = 逻辑型>
    {
        @ data().PutAllowSingleSignOnUsingOSPrimaryAccount(@<是否允许>);
    }

    方法 独占用户数据文件夹 <公开 属性写 注释 = "其他进程是否可以使用与当前相同用户数据文件夹,从而共享相同的浏览器进程实例," 注释 = "为真时如果其他进程也与当前设置的相同的用户数据文件夹则环境将创建失败.">
    参数 是否独占 <类型 = 逻辑型>
    {
        @ data().PutExclusiveUserDataFolderAccess(@<是否独占>);
    }

    方法 独占用户数据文件夹 <公开 属性读 类型 = 逻辑型 注释 = "其他进程是否可以使用与当前相同用户数据文件夹,从而共享相同的浏览器进程实例," 注释 = "为真时如果其他进程也与当前设置的相同的用户数据文件夹则环境将创建失败."
            @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetExclusiveUserDataFolderAccess()
    }

    方法 启用自定义崩溃报告 <公开 属性写 注释 = "当\"启用自定义崩溃报告\"设置为真时,Windows将不会向Microsoft端点发送崩溃数据">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ data().PutIsCustomCrashReportingEnabled(@<是否启用>);
    }

    方法 启用自定义崩溃报告 <公开 属性读 类型 = 逻辑型 注释 = "当\"启用自定义崩溃报告\"设置为真时,Windows将不会向Microsoft端点发送崩溃数据" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetIsCustomCrashReportingEnabled()
    }

    方法 启用跟踪防护 <公开 属性写 注释 = "是否启用跟踪防护,通过限制跟踪器访问基于浏览器的存储以及网络的能力,防止跟踪,从而保护用户免受在线跟踪.">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ data().PutEnableTrackingPrevention(@<是否启用>);
    }

    方法 启用跟踪防护 <公开 属性读 类型 = 逻辑型 注释 = "是否启用跟踪防护,通过限制跟踪器访问基于浏览器的存储以及网络的能力,防止跟踪,从而保护用户免受在线跟踪." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetEnableTrackingPrevention()
    }

    方法 启用浏览器扩展 <公开 属性写 注释 = "启用浏览器扩展,可以将扩展添加到用户配置文件中并使用">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ data().PutAreBrowserExtensionsEnabled(@<是否启用>);
    }

    方法 启用浏览器扩展 <公开 属性读 类型 = 逻辑型 注释 = "启用浏览器扩展,可以将扩展添加到用户配置文件中并使用" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetAreBrowserExtensionsEnabled()
    }

    方法 注册自定义URI方案 <公开 类型 = 逻辑型 注释 = "注册提交通过`添加自定义URI方案`设置的自定义URI,注册成功后即可通过所设置的[名称://路径]作为URL发起导航请求."
            注释 = "例: wv2rocks://home/index 注意:应答请求需要在过滤器中设置应答内容,否则访问为404" @嵌入式方法 = "">
    {
        @ @sn<this>.data().SetCustomSchemeRegistrations()
    }

    方法 滚动条样式 <公开 属性写 注释 = "设置滚动条样式,0.EDGE默认滚动条 1.流畅的叠加滚动条">
    参数 样式 <类型 = 整数 注释 = "0.默认 1.流畅的叠加滚动条">
    {
        @ data().PutScrollBarStyle((COREWEBVIEW2_SCROLLBAR_STYLE)@<样式>);
    }

    方法 滚动条样式 <公开 属性读 类型 = 整数 注释 = "获取滚动条样式,0.EDGE默认滚动条 1.流畅的叠加滚动条" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetScrollBarStyle()
    }

    方法 添加自定义URI方案 <公开 类型 = 逻辑型 注释 = "添加一个自定义URI方案" @禁止流程检查 = 真>
    参数 方案名称 <类型 = 文本型 注释 = "要注册的自定义方案的名称 如:\"wv2rocks\"">
    参数 允许站点 <类型 = 文本型 注释 = "允许使用自定义方案发出请求的站点,多个以\",\"分割" @默认值 = "*">
    参数 视为安全 <类型 = 逻辑型 注释 = "使用此方案的网站是否会像HTTPS网站一样被视为安全内容" @默认值 = 真>
    参数 具有权限 <类型 = 逻辑型 注释 = "有此自定义方案的URI将具有权限组件" @默认值 = 真>
    {
        变量 站点 <类型 = 文本数组类>
        变量 站点数 <类型 = 整数>
        变量 origin <类型 = 文本型>
        站点数 = 分割文本 (允许站点, ",", 站点, 真, 真)
        @ BOOL isSucceed;
        如果 (站点数 == 0 || 允许站点 == "")
        {
            @ isSucceed = data().AddCustomSchemeRegistration(@<方案名称>.GetText(), @<视为安全>, @<具有权限>, NULL, 0);
        }
        否则
        {
            @ const WCHAR** allowedOrigins = (const WCHAR **)malloc(sizeof(WCHAR*) * @<站点数>);
            站点.枚举循环 ()
            {
                origin = 站点.取枚举值 ()
                @ allowedOrigins[__vol_itr_index_sary] = @<origin>.GetText();
            }
            @ isSucceed = data().AddCustomSchemeRegistration(@<方案名称>.GetText(), @<视为安全>, @<具有权限>, allowedOrigins, @<站点数>);
            @ free(allowedOrigins);
        }
        @ return isSucceed;
    }
}

类 Edge菜单项目集 <公开 注释 = "菜单项目集,\"即将弹出上下文菜单\"事件参数" @文档 = "category = \"辅助类\"">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserContextMenuItemCollection)
    # <> <include>
    # @sn<current_class> (ICoreWebView2ContextMenuItemCollection *contextMenuItemCollection) : @sn<current_class> ()  {
    #      data().m_contextMenuItemCollection = contextMenuItemCollection;
    #  }
    # <> </include>
    # @end

    方法 取菜单项目数 <公开 类型 = 整数 注释 = "取当前事件中即将弹出菜单的项目数" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetCount()
    }

    方法 取菜单项 <公开 类型 = 逻辑型 注释 = "通过索引取菜单项目" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "遍历菜单项目集的循环索引">
    参数 菜单项 <类型 = Edge菜单项 注释 = "\"Edge菜单项\"类型变量,用于存储菜单信息." "">
    {
        @ @sn<this>.data().GetAtIndex(@<菜单索引>, &@<菜单项>.data().m_contextMenuItem)
    }

    方法 移除菜单项 <公开 类型 = 逻辑型 注释 = "在\"即将弹出上下文菜单\"事件中,调用本方法移除\"菜单项目集\"中的菜单项，在当次弹出菜单不显示该菜单."
            注释 = "注意：此操作将改变\"菜单项目集\"中的项目数量,在循环中使用应避免下标越界." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "遍历菜单项目集的循环索引">
    {
        @ @sn<this>.data().RemoveAtIndex(@<菜单索引>)
    }

    方法 移除菜单项2 <公开 注释 = "在\"即将弹出上下文菜单\"事件中,调用本方法移除\"菜单项目集\"中的菜单项，在当次弹出菜单不显示该菜单.">
    参数 名称 <类型 = 文本型 注释 = "菜单名称">
    {
        变量 菜单项 <类型 = Edge菜单项>
        计次循环 (取菜单项目数 ())
        {
            取菜单项 (取循环索引 (), 菜单项)
            如果 (菜单项.名称 == 名称)
            {
                移除菜单项 (取循环索引 ())
                跳出循环
            }
        }
    }

    方法 取菜单项2 <公开 类型 = Edge菜单项 注释 = "通过菜单名称取菜单项目">
    参数 名称 <类型 = 文本型 注释 = "菜单名称">
    {
        变量 item <类型 = Edge菜单项>
        计次循环 (取菜单项目数 ())
        {
            取菜单项 (取循环索引 (), item)
            如果 (item.名称 == 名称)
            {
                返回 (item)
            }
        }
        item.重置为空对象 ()
        返回 (item)
    }
}

类 Edge菜单项 <公开 注释 = "通过\"菜单项目集.取菜单项\"方法获得菜单信息" @文档 = "category = \"辅助类\"">
