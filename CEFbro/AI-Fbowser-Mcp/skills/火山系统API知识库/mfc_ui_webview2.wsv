    }

    方法 取框架 <公开 类型 = Edge框架 注释 = "取页面框架,用于对框架页面操作." @禁止流程检查 = 真>
    参数 框架指针 <类型 = 变整数 注释 = "三选一,当值为-1时,忽略该参数." @默认值 = -1>
    参数 框架索引 <类型 = 整数 注释 = "三选一,当值为-1时,忽略该参数." @默认值 = -1>
    参数 框架名称 <类型 = 文本型 注释 = "三选一,当值为空文本时,忽略该参数." @默认值 = "">
    {
        如果真 (框架指针 != -1)
        {
            @ ICoreWebView2Frame* frame=(ICoreWebView2Frame*)@<框架指针>;
            @ return @dt<Edge框架>(frame,(CVWnd_EWVBrowser*)GetMfcWndPtr ()); // 根据框架指针得到框架
        }
        如果真 (框架索引 != -1)
        {
            @ ICoreWebView2Frame* frame=((CVWnd_EWVBrowser*)GetMfcWndPtr ())->GetFrameIndex(@<框架索引>); // 根据索引号取得框架指针
            @ return @dt<Edge框架>(frame,(CVWnd_EWVBrowser*)GetMfcWndPtr ());
        }
        @ ICoreWebView2Frame* frame=((CVWnd_EWVBrowser*)GetMfcWndPtr ())->GetFrameFromName(@<框架名称>.GetText()); // 根据框架名称取得框架指针
        @ return @dt<Edge框架>(frame,(CVWnd_EWVBrowser*)GetMfcWndPtr ());
    }

