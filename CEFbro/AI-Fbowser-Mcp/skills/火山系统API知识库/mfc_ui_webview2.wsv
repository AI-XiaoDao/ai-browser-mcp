    常量 单选框 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_ITEM_KIND_RADIO 注释 = "不会显示选框,触发事件提供是否选中.">
    常量 分隔符 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_ITEM_KIND_SEPARATOR 注释 = "不会触发事件">
    常量 多级菜单 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_ITEM_KIND_SUBMENU 注释 = "可创建多级菜单,选中时弹出子级菜单.不会触发事件.">
}

类 Edge菜单触发对象 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 页面 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND_PAGE 注释 = "右键页面时触发">
    常量 图片 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND_IMAGE 注释 = "右键图片时触发">
    常量 选择文本 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND_SELECTED_TEXT 注释 = "右键选择文本时触发">
    常量 声音 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND_AUDIO 注释 = "右键声音时触发">
    常量 视频 <公开 值 = @COREWEBVIEW2_CONTEXT_MENU_TARGET_KIND_VIDEO 注释 = "右键视频时触发">
}

类 Edge填表类 <公开 注释 = "页面表单操作类,注意:填表类中的同步方法会阻止浏览器事件返回." 注释 = "而填表取值等操作的内部实现均依托于执行JS事件的返回结果."
        注释 = "浏览器的事件均与窗口处在同一线程,所以在事件中调用将不能得到执行结果." 注释 = "注意: 仅当调用\"取填表\"方法时所对应的\"Edge浏览框\"组件存在时才能对本类对象进行操作.">
{

    # @begin
    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVWnd_EWVBrowserFill)
    # <> <include>
    # @sn<current_class> (ICoreWebView2Frame* frame,CVWnd_EWVBrowser* pWndPtr) : @sn<current_class> ()  {
    #          data().webviewFrame = frame;
    #          data().webviewEWVBrowserPtr = pWndPtr;
    #  }
    # <> </include>
    # @end

    方法 点击 <公开 注释 = "置元素热点并点击" "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型>
        JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "]"
        JS代码 = JS代码 + ".focus();" + JS代码 + ".click();"
        @ data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 滚动到元素 <公开 注释 = "自动滚动到元素位置" "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型>
        JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].scrollIntoView();"
        @ data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 置选框勾选 <公开 注释 = "对页面单选框或多选配元素执行勾选或取消勾选" "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 是否勾选 <类型 = 逻辑型 注释 = "表示勾选或取消勾选" @默认值 = 真>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型>
        如果 (是否勾选)
        {
            JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].checked=true;"
        }
        否则
        {
            JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].checked=false;"
        }
        @ data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 取选框勾选 <公开 类型 = 逻辑型 注释 = "取页面单选框或多选框元素勾选状态." 返回值注释 = "注意:在浏览器事件中调用无效.详情查看填表类说明." @禁止流程检查 = 真>
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 是否勾选 <类型 = 逻辑型 注释 = "表示勾选或取消勾选" @默认值 = 真>
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型>
        JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].checked==true;"
        @ return (data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>)==_T("true"));
    }

    方法 置选择项 <公开 注释 = "对页面下拉列表框元素执行选项选择" "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
    参数 选择器索引 <类型 = 整数 注释 = "从0开始.选择器结果的第几个标签." @默认值 = 0>
    参数 选中索引 <类型 = 整数 注释 = "要选择第几个选项" "">
    参数 超时时间 <类型 = 整数 注释 = "单位毫秒,设置最大超时时间,一般都是几毫秒就能取到结果. 小于0表示始终等待." @默认值 = 500>
    参数 状态码 <类型 = 整数类 注释 = "返回值分别表示:0失败,1成功有返回值,2成功无返回值,3超时无返回值." @默认值 = 空对象>
    {
        变量 JS代码 <类型 = 文本型>
        JS代码 = "document.querySelectorAll('" + 选择器 + "')[" + 到文本 (选择器索引) + "].options[" + 到文本 (选中索引) + "].selected = true;"
        @ data().ExecuteScript(@<JS代码>.GetText(),@<超时时间>,@<状态码.值>);
    }

    方法 取选择项 <公开 类型 = 整数 注释 = "返回页面下拉列表框元素选项的索引." 返回值注释 = "注意:在浏览器事件中调用无效.详情查看填表类说明." "">
    参数 选择器 <类型 = 文本型 注释 = "querySelectorAll选择器">
