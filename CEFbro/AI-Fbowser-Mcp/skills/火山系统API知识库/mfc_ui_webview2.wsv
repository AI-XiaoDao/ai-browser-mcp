<火山程序 类型 = "通常" 版本 = 1 />

包 火山.Edge浏览框 <@视窗.预定义宏 = "_WIN32_WINNT=0x0600" @视窗.外部头文件 = "src\\mfc_edge_web_view.h"
        @视窗.外部源文件 = "src\\mfc_edge_web_view.cpp" @视窗.外部库.win32 = "lib\\x86\\WebView2LoaderStatic.lib"
        @视窗.外部库.x64 = "lib\\x64\\WebView2LoaderStatic.lib" @视窗.需求VS版本 = "16-">

类 Edge过滤类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 所有资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_ALL 注释 = "所有资源">
    常量 文档资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_DOCUMENT 注释 = "文档资源">
    常量 CSS资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_STYLESHEET 注释 = "CSS 资源">
    常量 图片资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_IMAGE 注释 = "图片资源">
    常量 媒体资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_MEDIA 注释 = "媒体资源">
    常量 字体资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_FONT 注释 = "字体资源">
    常量 脚本资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_SCRIPT 注释 = "脚本资源">
    常量 XML资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_XML_HTTP_REQUEST 注释 = "XML请求">
    常量 API通信 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_FETCH 注释 = "获取API通信">
    常量 片段资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_TEXT_TRACK 注释 = "片段资源">
    常量 事件资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_EVENT_SOURCE 注释 = "事件资源">
    常量 WebSocket <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_WEBSOCKET 注释 = "WEBSOCKET">
    常量 网络清单 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_MANIFEST 注释 = "网络清单">
    常量 SXG资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_SIGNED_EXCHANGE 注释 = "SXG资源">
    常量 心跳资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_PING 注释 = "心跳资源">
    常量 无效资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_CSP_VIOLATION_REPORT 注释 = "无效资源">
    常量 其他资源 <公开 值 = @COREWEBVIEW2_WEB_RESOURCE_CONTEXT_OTHER 注释 = "其他资源">
}

