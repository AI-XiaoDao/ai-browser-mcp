类 ________查询器测试例子 <公开>
{
    方法 开始测试 <公开 类型 = 整数>
    {
        变量 套接字句柄 <类型 = 变整数>
        变量 客户端句柄 <类型 = 变整数>
        变量 ""

        如果 (套接字_初始化 () == 假)
        {
            调试输出 ("套接字初始化失败")
            返回 (0)
        }

        套接字句柄 = 套接字_创建 ()
        如果 (套接字句柄 == 0)
        {
            调试输出 ("套接字创建失败!")
            调试输出 (取最后一次错误信息 ())
            返回 (0)
        }

        如果 (套接字_绑定 (套接字句柄, "0.0.0.0", 19730) == 0)
        {
            调试输出 ("绑定地址失败！")
            调试输出 (取最后一次错误信息 ())
            套接字_销毁 (套接字句柄)
            返回 (0)
        }

        如果 (套接字_监听 (套接字句柄) == 假)
        {
            调试输出 (取最后一次错误信息 ())
            调试输出 ("监听失败！")
            套接字_销毁 (套接字句柄)
            返回 (0)
        }


        判断循环 (真)
        {
            客户端句柄 = 套节字_接受连接 (套接字句柄)
            调试输出 ("有客户连接")
            变量 线程 <类型 = 线程类f>
            挂接事件 (线程)
            线程.创建线程 (客户端句柄)

        }

        套接字_销毁 (套接字句柄)

        套接字_清理 ()

    }

    方法 线程类f_工作函数 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 线程类f>
    参数 标记值 <类型 = 整数>
    参数 线程参数 <类型 = 变整数>
    {
        变量 客户端句柄 <类型 = 变整数>
        变量 查询 <类型 = 套接字查询类>
        变量 接收数据缓冲区 <类型 = 字节集类>
        调试输出 ("线程已启动")
        客户端句柄 = 线程参数

        判断循环 (真)
        {

            // 第一步,必须把套接字加入到读集合
            // 第二步,调用查询读集合后,如果可读,句柄就会保留在读集合,如果不可读,加入的句柄就会从集合中删除
            // 第三步,调用是 套接字是否可读 就会判断集合中是否存在该 套接字句柄,如果存在即可调用相关函数

            // 可以加入很多个客户端句柄到读合集,最大数量64个
            查询.加入读集合 (客户端句柄)

            // 查询器能一次性查询64个套接字句柄
            如果 (查询.查询读集合 () == 假)
            {
                跳出循环
            }

            // 分别判断每个套接字句柄是否可以读
            如果 (查询.套接字是否可读 (客户端句柄))
            {

                如果 (套接字_接收数据TCP (客户端句柄, 接收数据缓冲区) > 0)
                {
                    调试输出 ("收到数据")
                    调试输出 (多字节到文本 (接收数据缓冲区))

                }
                否则
                {
                    调试输出 ("客户端断开连接")
                    套接字_销毁 (客户端句柄)
                    跳出循环
                }


            }

        }

        返回 (0)

    }
}

类 数据转发类 <公开>
{
    变量 成员_套接字句柄 <类型 = 变整数>
    变量 成员_监听线程 <类型 = 线程类f>
    变量 成员_监听IP与端口 <类型 = 文本型>
    变量 成员_目标IP地址 <类型 = 文本型>
    变量 成员_目标端口 <类型 = 短整数>

    方法 启动 <公开 类型 = 整数 返回值注释 = "0表示失败">
    参数 本机IP <类型 = 文本型 注释 = "一般是\"0.0.0.0\"">
    参数 本机端口 <类型 = 短整数 注释 = "一般大于8080 < 65535">
    参数 转发到IP <类型 = 文本型>
    参数 转发到端口 <类型 = 短整数>
    {

        成员_套接字句柄 = 套接字_创建 ()
        如果 (成员_套接字句柄 == 0)
        {
            调试输出 ("套接字创建失败!")
            调试输出 (取最后一次错误信息 ())
            返回 (0)
        }

        如果 (套接字_绑定 (成员_套接字句柄, 本机IP, 本机端口) == 0)
        {
            调试输出 ("绑定地址失败！")
            调试输出 (取最后一次错误信息 ())
            套接字_销毁 (成员_套接字句柄)
            返回 (0)
        }

        如果 (套接字_监听 (成员_套接字句柄) == 假)
        {
            调试输出 (取最后一次错误信息 ())
            调试输出 ("监听失败！")
            套接字_销毁 (成员_套接字句柄)
            返回 (0)
        }

        成员_监听IP与端口 = 本机IP + ":" + 到文本 (本机端口)

        成员_目标IP地址 = 转发到IP
        成员_目标端口 = 转发到端口
        成员_监听线程.创建线程 (, )
        返回 (1)

    }

    方法 停止 <公开>
    {
        套接字_销毁 (成员_套接字句柄)
        延时 (50)
        成员_监听线程.强制结束 ()


    }

    方法 线程类f_工作函数 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 线程类f 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 线程参数 <类型 = 变整数>
    {
        如果 (来源对象 == 成员_监听线程)
        {
            变量 客户端句柄 <类型 = 变整数>
            判断循环 (真)
            {
                客户端句柄 = 套节字_接受连接 (成员_套接字句柄)
                调试输出 ("有客户连接")
                变量 线程 <类型 = 线程类f>
                挂接事件 (线程)
                线程.创建线程 (客户端句柄)
            }

        }
        否则
        {


            变量 客户IP端口 <类型 = 文本型>
            客户IP端口 = 套接字_取IP端口2 (线程参数)
            客户连接 (成员_监听IP与端口, 成员_目标IP地址 + ":" + 到文本 (成员_目标端口), 客户IP端口)

            套接字_数据转发到目标IP (线程参数, 成员_目标IP地址, 成员_目标端口)


        }

        返回 (0)

    }

    方法 客户连接 <公开 定义事件 类型 = 整数>
    参数 本地IP与端口 <类型 = 文本型>
    参数 转发IP与端口 <类型 = 文本型>
    参数 客户IP与端口 <类型 = 文本型>
    {

    }
}

