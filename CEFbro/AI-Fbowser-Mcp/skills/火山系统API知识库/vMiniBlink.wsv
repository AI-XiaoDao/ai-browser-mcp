    方法 网络响应 <公开 定义事件 类型 = 整数 注释 = "网络请求发送后,收到服务器响应时触发此事件" 返回值注释 = "返回非0 将被阻断">
    参数 链接地址 <类型 = 文本型 注释 = "本次相应对应的url地址">
    参数 网络工作 <类型 = MB网络工作 注释 = "MB网络工作相关操作">

    方法 获得Cookie <公开 定义事件 类型 = 整数 注释 = "当调用\"枚举Cookie\"方法是触发此事件.用于获得所有Cookie." 返回值注释 = "如由返回1则此Cookie由用户处理">
    参数 Cookie名称 <类型 = 文本型 注释 = "Cookie名称">
    参数 Cookie值 <类型 = 文本型 注释 = "Cookie值">
    参数 作用域 <类型 = 文本型 注释 = "Cookie的作用域">
    参数 路径 <类型 = 文本型 注释 = "如非空,只有路径上或路径下的URL才会获取cookie值.">
    参数 是否安全保护 <类型 = 逻辑型 注释 = "是否使用HTTPS安全协议发送Cookie">
    参数 限HTTP <类型 = 逻辑型 注释 = "如为真则仅为HTTP请求发送cookie,防止客户端脚本通过document.cookie属性访问Cookie.">
    参数 是否设置生存期 <类型 = 逻辑型 注释 = "cookie过期日期仅在为真时有效">

    方法 即将开始下载 <公开 定义事件 类型 = 整数 注释 = "  需要调用\"启用下载事件\",浏览器在下载浏览器有下载文件时触发此事件,此接口尚未完善,"
            注释 = "回调中暂时只返回了下载UR,未带有身份认证信息,所以只适用于不需要身份认证的下载请求.">
    参数 链接地址 <类型 = 文本型 注释 = "目标url">

    方法 启用下载事件 <公开 注释 = "启用\"即将开始下载\"事件">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用 假为关闭" @默认值 = 真>
    {
        @ (@<是否启用> ? wkeOnDownload(GetwebView(), handleDownloadCallback, this) :  wkeOnDownload(GetwebView(), NULL, 0));
    }

    方法 启用下载事件2 <公开 注释 = "启用\"即将开始下载2\"事件">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用 假为关闭" @默认值 = 真>
    {
        @ (@<是否启用> ? wkeOnDownload2(GetwebView(), handleDownload2Callback, this) :  wkeOnDownload2(GetwebView(), NULL, 0));
    }

    方法 即将开始下载2 <公开 定义事件 类型 = 整数 注释 = "  需要调用\"启用下载事件2\",浏览器有下载文件时触发此事件,此接口尚未完善,"
            注释 = "回调中暂时只返回了下载UR,未带有身份认证信息,所以只适用于不需要身份认证的下载请求." 返回值注释 = "返回0取消 返回1缓存数据">
    参数 预计长度 <类型 = 变整数 注释 = "目标预计长度">
    参数 链接地址 <类型 = 文本型 注释 = "目标url">
    参数 MIME类型 <类型 = 文本型 注释 = "目标MIME类型">
    参数 disposition <类型 = 文本型>
    参数 网络工作 <类型 = MB网络工作 注释 = "MB网络工作">

    方法 执行JS脚本 <公开 类型 = js值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()">
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJSW(GetwebView(), @<JS文本>);
        @ @<es>=(INT_P)wkeGlobalExec(GetwebView());
        返回 (js.绑定 (es, jv))
    }

    方法 执行JS脚本UTF8 <公开 类型 = js值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()">
    参数 JS文本UTF8 <类型 = 字节集类 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 jsValue <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJS(GetwebView(), (const utf8*)@<JS文本UTF8>.GetPtr());
        @ @<es>=(INT_P)wkeGlobalExec(GetwebView());
        返回 (jsValue.绑定 (es, jv))
    }

    方法 执行JS脚本自框架 <公开 类型 = js值
            注释 = "在指定框架中执行一段js代码,返回js执行返回值类实例 使用方法 如: 变量.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()"
            返回值注释 = "返回js值对象,用于js执行结果取值操作.">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真,则MB会将这段js代码放到一个function(){ script }中执行,以避免变量名和页面中的js变量重名导致的错误.">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJsByFrame(GetwebView(),(wkeWebFrameHandle)@<框架ID>,CU8String (@<JS文本>).GetText(),@<是否闭包>);
        @ @<es>=(INT_P)wkeGetGlobalExecByFrame(GetwebView(),(wkeWebFrameHandle)@<框架ID>);
        返回 (js.绑定 (es, jv))
    }

    方法 取主框架 <公开 类型 = 变整数 注释 = "取页面主框架ID" 返回值注释 = "返回页面主框架ID" @嵌入式方法 = "">
    {
        @ (INT_P)wkeWebFrameGetMainFrame (@sn<this>.GetwebView())
    }

    方法 是否为主框架 <公开 类型 = 逻辑型 注释 = "判断页面中的某个框架是否为远程框架" 返回值注释 = "如果为主框架则返回真" @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    {
        @ wkeIsMainFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 是否为远程框架 <公开 类型 = 逻辑型 注释 = "判断页面中的某个框架是否为远程框架" 返回值注释 = "如果为远程框架则返回真" @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    {
        @ wkeIsWebRemoteFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 取JS执行状态 <公开 类型 = 变整数 注释 = "获取页面主框架的js执行状态,js执行状态可以理解为一个句柄,js相关接口会频繁使用该句柄,使用完立刻就失效,再次使用需重新获取.。" 返回值注释 = "主框架js执行状态"
            @嵌入式方法 = "">
    {
        @ (INT_P)wkeGlobalExec(@sn<this>.GetwebView())
    }

    方法 取JS执行状态_框架 <公开 类型 = 变整数 注释 = "获取页面的js执行状态,js执行状态可以理解为一个句柄,js相关接口会频繁使用该句柄,使用完立刻就失效,再次使用需重新获取." 返回值注释 = "js执行状态"
            @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供页面框架ID">
    {
        @ (INT_P)wkeGetGlobalExecByFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 JS绑定函数 <公开 静态 注释 = "绑定全局JS函数,须在窗口创建前调用." "">
    参数 函数名称 <类型 = 文本型 注释 = "提供该js方法的函数名称,全局生效,请注意方法名的唯一性.">
    参数 参数个数 <类型 = 整数 注释 = "提供该js方法的参数个数">
    参数 回调方法指针 <类型 = 变整数 注释 = "指定一个静态方法指针值" 注释 = "属性:@视窗.前缀文本 值为:@CDECL;" 注释 = "返回值类型:整数 即调用jsValue类成员方法生成的js值;"
            注释 = "参数1 类型:js执行状态;" 注释 = "如不指定此方法默认会在本类各实例对象的\"JS绑定方法被执行\"事件中触发" @默认值 = 0>
    {
        @ wkeJsBindFunction(CU8String (@<函数名称>).GetText (), (@<回调方法指针> == 0 ? (wkeJsNativeFunction)handlewkeJsNativeFunction : (wkeJsNativeFunction)@<回调方法指针>), (void *)@<函数名称>.GetText (), (unsigned int)@<参数个数>);
    }

    方法 插入CSS到框架 <公开 注释 = "插入一段CSS到页面框架中" @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供页面框架ID">
    参数 CSS文本 <类型 = 文本型 注释 = "提供CSS文本">
    {
        @ wkeInsertCSSByFrame (@sn<this>.GetwebView(), (wkeWebFrameHandle)@<框架ID>,CU8String (@<CSS文本>).GetText ())
    }

    方法 显示窗口 <公开 注释 = "显示或隐藏浏览器窗口" @嵌入式方法 = "">
