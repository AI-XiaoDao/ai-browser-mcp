        @ wkeVisitAllCookie(GetwebView(), this, (wkeCookieVisitor)onCookieVisitor);
    }

    方法 取Cookie_UTF8 <公开 类型 = 字节集类 注释 = "取浏览器Cookie" 返回值注释 = "成功返回Cookie UTF8类型" @禁止流程检查 = 真>
    {
        @ return wkeGetCookie(GetwebView());
    }

    方法 置Cookie <公开 注释 = "向浏览器写入一段Cookie" @嵌入式方法 = "">
    参数 链接地址 <类型 = 文本型 注释 = "写入Cookie对应的url">
    参数 cookie文本 <类型 = 文本型 注释 = "  cookie格式必须是类似:"
            注释 = "cna=4UvTFE12fEECAXFKf4SFW5eo; expires=Tue, 23-Jan-2029 13:17:21 GMT; path=/; domain=.youku.com">
    {
        @ wkeSetCookie(@sn<this>.GetwebView(),CU8String (@<链接地址>).GetText (),CU8String (@<cookie文本>).GetText ())
    }

    方法 清除Cookie <公开 注释 = "清除Cookie,由于缓存等因素,直接删cookie.dat可能更有效.另外有的网站可能有服务端缓存,所以会存在清理无效的情况." @嵌入式方法 = "">
    {
        @ wkeClearCookie(@sn<this>.GetwebView())
    }

    方法 执行Cookie命令 <公开 注释 = "执行一个COOKIE操作命令" @嵌入式方法 = "">
    参数 COOKIE命令 <类型 = MBCookie命令 注释 = "提供MBCookie命令类型" @默认值 = MBCookie命令.全部清除>
    {
        @ wkePerformCookieCommand(@sn<this>.GetwebView(),(wkeCookieCommand)@<COOKIE命令>)
    }

    方法 置Cookie文件路径 <公开 注释 = "设置Cookie文件的目录,默认情况下文件名是 cookies.dat" @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "文件目录路径,不包括文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 置Cookie文件全路径 <公开 注释 = "设置Cookie文件的全路径包括文件名,默认是程序运行的当前目录,默认文件名为cookie.dat。" @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "全路径,包括cookie文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarFullPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 置LocalStorage路径 <公开 注释 = "设置LocalStorage本地存储文件的路径" @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\LocalStorage,必须且只能是目录,默认是当前目录.">
    {
        @ wkeSetLocalStorageFullPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 添加插件目录 <公开 注释 = "设置插件目录,默认情况下为plugins目录" @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\plugins,必须且只能是目录,默认是当前目录">
