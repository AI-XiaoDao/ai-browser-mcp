    }

    方法 启用Npapi插件 <公开 注释 = "可启用或关闭Npapi插件" @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetNpapiPluginsEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用无头模式 <公开 注释 = "开启或关闭无头模式,开启后页面不会被渲染上屏,直接内存运行,大幅提升性能." @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetHeadlessEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用默认菜单 <公开 注释 = "设置是否允许右键弹出MB浏览器默认菜单,默认状态下为开启." @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetContextMenuEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 置默认菜单项显示 <公开 注释 = "设置MB浏览器某菜单项是否显示" @嵌入式方法 = "">
    参数 菜单项 <类型 = MB默认菜单项 注释 = "MB默认菜单项常量">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示,假为隐藏">
    {
        @ wkeSetContextMenuItemShow(@sn<this>.GetwebView(),(wkeMenuItemId)@<菜单项>,@<是否显示>)
    }

    方法 启用导航到新窗口 <公开 注释 = "当有新页面需要打开时,是否在新窗口打开,默认是当前窗口,如开启,则会触发\"即将创建新窗口\"事件." @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用,假为关闭." @默认值 = 真>
    {
        @ wkeSetNavigationToNewWindowEnable(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用跨域检查 <公开 注释 = "设置是否开启csp跨域检查,默认状态下为开启,如需进行跨域操作,如跨域ajax,跨域设置iframe等,则需要先关闭此开关." @嵌入式方法 = "">
    参数 是否检查 <类型 = 逻辑型>
    {
        @ wkeSetCspCheckEnable(@sn<this>.GetwebView(),@<是否检查>)
    }

    方法 置设备参数 <公开 注释 = "设置webView模拟硬件设备环境" @嵌入式方法 = "">
    参数 设备参数名 <类型 = 文本型 注释 = "为\"navigator.maxTouchPoints\"时，需设置\"整数参数\"，表示touch的点数。"
            注释 = "为\"navigator.platform\"时，需设置\"文本参数\"，表示js里获取的navigator.platform字符串。"
            注释 = "为\"navigator.hardwareConcurrency\"时，需设置\"整数参数\"，表示js里获取的navigator.hardwareConcurrency整数值。"
            注释 = "为\"screen.width\"时，需设置\"整数参数\"，表示js里获取的screen.width整数值。"
            注释 = "为\"screen.height\"时，需设置\"整数参数\"，表示js里获取的screen.height整数值。"
            注释 = "为\"screen.availWidth\"时，需设置\"整数参数\"，表示js里获取的screen.availWidth整数值。"
            注释 = "为\"screen.availHeight\"时，需设置\"整数参数\"，表示js里获取的screen.availHeight整数值。"
            注释 = "为\"screen.pixelDepth\"时，需设置\"整数参数\"，表示js里获取的screen.pixelDepth整数值。">
    参数 文本参数 <类型 = 文本型 @默认值 = "">
    参数 整数参数 <类型 = 整数 @默认值 = 0>
    参数 浮点参数 <类型 = 小数 @默认值 = 0>
    {
        @ wkeSetDeviceParameter (@sn<this>.GetwebView(), CU8String  (@<设备参数名>).GetText (), CU8String (@<文本参数>).GetText (), @<整数参数>, (float)@<浮点参数>)
    }

    方法 置代理 <公开 注释 = "置当前浏览器代理设置" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 代理类型 <类型 = MB代理类型 注释 = "提供MB代理类型" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = MB代理类型.HTTP>
    参数 服务器 <类型 = 文本型 注释 = "代理服务器地址" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 端口 <类型 = 短整数 注释 = "代理服务器端口" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 用户名 <类型 = 文本型 注释 = "代理服务器用户" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "代理服务器密码" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    {
        @ wkeProxy  Proxy;
        @ Proxy.type=(wkeProxyType)@<代理类型>;
        @ strncpy_z(Proxy.hostname, CU8String (@<服务器>).GetText(), NUM_ELEMENTS_OF (Proxy.hostname) - 1);
        @ strncpy_z(Proxy.username, CU8String (@<用户名>).GetText(), NUM_ELEMENTS_OF (Proxy.username) - 1);
        @ strncpy_z(Proxy.password, CU8String (@<密码>).GetText(), NUM_ELEMENTS_OF (Proxy.password) - 1);
        @ Proxy.port=@<端口>;
        @ wkeSetViewProxy (GetwebView(), &Proxy);
    }

    方法 置全局代理 <公开 静态 注释 = "设置MB浏览器代理全局生效">
    参数 代理类型 <类型 = MB代理类型 注释 = "提供MB代理类型" @默认值 = MB代理类型.HTTP>
    参数 服务器 <类型 = 文本型 注释 = "代理服务器地址">
    参数 端口 <类型 = 短整数 注释 = "代理服务器端口">
    参数 用户名 <类型 = 文本型 注释 = "代理服务器用户" @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "代理服务器密码" @默认值 = "">
    {
        @ wkeProxy  Proxy;
        @ Proxy.type=(wkeProxyType)@<代理类型>;
        @ strncpy_z(Proxy.hostname, CU8String (@<服务器>).GetText(), NUM_ELEMENTS_OF (Proxy.hostname) - 1);
        @ strncpy_z(Proxy.username, CU8String (@<用户名>).GetText(), NUM_ELEMENTS_OF (Proxy.username) - 1);
        @ strncpy_z(Proxy.password, CU8String (@<密码>).GetText(), NUM_ELEMENTS_OF (Proxy.password) - 1);
        @ Proxy.port=@<端口>;
        @ wkeSetProxy (&Proxy);
    }

    方法 置调试配置 <公开 注释 = "设置一些实验性选项,配置项目前支持:"
            注释 = "showDevTools:开启开发者工具,此时参数值要填写开发者工具的资源路径,如file:///c:/miniblink-release/front_end/inspector.html 必须是全路径,并且不能有中文."
            注释 = "wakeMinInterval:设置帧率,默认值是10值越大帧率越低;" 注释 = "drawMinInterval:设置帧率,默认值是3,值越大帧率越低;"
            注释 = "antiAlias:设置抗锯齿渲染,参数值必须设置为\"1\";" 注释 = "minimumFontSize:最小字体;" 注释 = "minimumLogicalFontSize:最小逻辑字体;"
            注释 = "defaultFontSize:默认字号;" 注释 = "defaultFixedFontSize:默认Fixed字号;" 注释 = "imageEnable:是否打开无图模式,参数值为\"0\"表示开启无图模式;"
            注释 = "jsEnable:是否禁用js,参数值为\"0\"表示禁用;" 注释 = "enableNodejs:是否开启nodejs 支持,参数值为\"1\"表示开启.(目前仅支持32位)" @嵌入式方法 = "">
    参数 配置项 <类型 = 文本型 注释 = "配置项名">
    参数 参数值 <类型 = 文本型 注释 = "配置项参数值">
    {
        @ wkeSetDebugConfig(@sn<this>.GetwebView(),CU8String (@<配置项>).GetText(),CU8String (@<参数值>).GetText())
    }

    方法 窗口将被关闭 <公开 定义事件 类型 = 整数 注释 = "窗口模式下在浏览器窗口收到WM_CLODE消息时触发此回调接口,可返回非0拒绝关闭窗口." "">

    方法 窗口将被销毁 <公开 定义事件 类型 = 整数 注释 = "窗口模式下当浏览器窗口即将被销毁时触发此事件,与\'窗口将被关闭\'事件不同的时这个操作一旦开始无法取消." "">

    方法 文档就绪 <公开 定义事件 类型 = 整数 注释 = "当前页面文档就绪时触发此事件" "">

    方法 文档就绪2 <公开 定义事件 类型 = 整数 注释 = "当前页面文档就绪时触发此事件" "">
    参数 框架ID <类型 = 变整数 注释 = "触发当前事件的页面框架ID">

