# jsValue封装===

类 jsValue类 <公开 注释 = "js取值相关操作类,由于js是弱类型语言jsValue其实是一个指向封装了v8内部各种类型的类指针,可以理解成一个代表js中各种类型的句柄." @禁止创建对象 = 真>
{
    方法 js垃圾回收 <公开 静态 注释 = "js垃圾回收" @嵌入式方法 = "">
    {
        @ jsGC();
    }

    方法 js执行 <公开 静态 类型 = js值
            注释 = "执行一段js代码,代码会在MB内部自动被包裹在一个function(){}中,所以使用的变量会作为局部变量以避免同页面js代码中的其他变量重名导致运行出错,要获取返回值,请加return."
            返回值注释 = "返回一个js返回值对象用于取值操作">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态句柄">
    参数 JS文本 <类型 = 文本型 注释 = "js代码脚本">
    参数 是否闭包 <类型 = 逻辑型 注释 = "设定是否闭包运行js" @默认值 = 真>
    {
        变量 jv <类型 = 变整数>
        变量 js <类型 = js值>
        @ @<jv>=(INT_P)jsEvalExW((jsExecState)@<js执行状态>, @<JS文本>,@<是否闭包>);
        返回 (js.绑定 (js执行状态, jv))
    }

    方法 js执行状态是否有效 <公开 静态 类型 = 逻辑型 注释 = "判断js执行状态是否有效" 返回值注释 = "返回真代表有效" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 长整数 注释 = " js执行状态句柄">
    {
        @ jsIsValidExecState(( jsExecState)@<js执行状态>)
    }

    方法 jsValue是否有效 <公开 静态 类型 = 逻辑型 注释 = "判断jsValue句柄是否有效" 返回值注释 = "返回真代表有效" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 长整数 注释 = "js执行状态句柄">
    参数 jsValue句柄 <类型 = 长整数 注释 = "jsValue句柄">
    {
        @ jsIsJsValueValid(( jsExecState)@<js执行状态>,( jsValue)@<jsValue句柄>)
    }

    方法 js取浏览器句柄 <公开 静态 类型 = 变整数 注释 = "通过js执行状态取浏览器句柄" 返回值注释 = "返回浏览器起句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态句柄">
    {
        @ (INT_P)jsGetWebView((jsExecState)@<js执行状态>)
    }

    方法 js到整数 <公开 静态 类型 = 整数 注释 = "将jsValue代表的js值转换为整数" 返回值注释 = "整数js值" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "js执行状态">
    {
        @ jsToInt((jsExecState)@<js执行状态>, ( jsValue)@<jsValue句柄>)
    }

    方法 js到文本 <静态 类型 = 文本型 注释 = "将jsValue代表的js值转换为文本" 返回值注释 = "文本js值" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ CVolString(jsToString((jsExecState)@<js执行状态>, @<jsValue句柄>))
    }

    方法 js到浮点数 <静态 类型 = 小数 注释 = "将jsValue代表的js值转换为浮点数" 返回值注释 = "js浮点数值" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ jsToFloat((jsExecState)@<js执行状态>, @<jsValue句柄>)
    }

    方法 js到小数 <静态 类型 = 小数 注释 = "将jsValue代表的js值转换为小数" 返回值注释 = "js小数值" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ jsToDouble((jsExecState)@<js执行状态>, @<jsValue句柄>)
    }

    方法 js到逻辑 <静态 类型 = 逻辑型 注释 = "将jsValue代表的js值转换为小数" 返回值注释 = "js逻辑值" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ jsToBoolean((jsExecState)@<js执行状态>, @<jsValue句柄>)
    }

    方法 js取类型 <静态 类型 = js数据类型 注释 = "取js值类型返回JS数据类型常量" 返回值注释 = "返回JS数据类型 0:数值; 1:文本; 2:逻辑; 3:对象; 4:方法; 5:未定义; 6:数组; 7:空"
            @嵌入式方法 = "">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ jsTypeOf(@<jsValue句柄>)
    }

    方法 js参数类型 <静态 类型 = js数据类型 返回值注释 = "js数据类型常量 0:数值; 1:文本; 2:逻辑; 3:对象; 4:方法; 5:未定义; 6:数组; 7:空" @禁止流程检查 = 真>
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 参数索引 <类型 = 整数 注释 = "参数索引从0开始">
    {
        @ return jsArgType((jsExecState)@<js执行状态>,@<参数索引>);
    }

    方法 js取参数 <静态 类型 = 变整数 注释 = "取js绑定方法参数,返回一个代表js参数的jsValue句柄用于后续的取值操作." 返回值注释 = "代表js参数的jsValue句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 参数索引 <类型 = 整数 注释 = "参数索引从0开始">
    {
        @ (INT_P)jsArg((jsExecState)@<js执行状态>,@<参数索引>)
    }

    方法 js取参数个数 <静态 类型 = 整数 注释 = "取js绑定方法的参数个数" 返回值注释 = "返回参数个数" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数>
    {
        @ jsArgCount ((jsExecState)@<js执行状态>)
    }

    方法 js空 <公开 静态 类型 = 整数 注释 = "创建一个值为Null的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    {
        @ (int)jsNull ()
    }

    方法 js未定义 <公开 静态 类型 = 整数 注释 = "创建一个值为Undefined的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    {
        @ (int)jsUndefined ()
    }

    方法 js真 <公开 静态 类型 = 整数 注释 = "创建一个值为True的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    {
        @ (int)jsTrue ()
    }

    方法 js假 <公开 静态 类型 = 整数 注释 = "创建一个值为False的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    {
        @ (int)jsFalse ()
    }

    方法 js整数 <公开 静态 类型 = 整数 注释 = "创建一个值为数值型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 整数值 <类型 = 整数 注释 = "整数返回值">
    {
        @ (int)jsInt (@<整数值>)
    }

    方法 js浮点数 <公开 静态 类型 = 整数 注释 = "创建一个值为Float型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 小数型值 <类型 = 小数 注释 = "浮点数返回值">
    {
        @ (int)jsFloat ((float)@<小数型值>)
    }

    方法 js双精度 <公开 静态 类型 = 整数 注释 = "创建一个值为Double型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 小数型值 <类型 = 小数 注释 = "双精度小数返回值" "">
    {
        @ (int)jsDouble (@<小数型值>)
    }

    方法 js逻辑 <公开 静态 类型 = 整数 注释 = "创建一个值为逻辑型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "jsValue句柄" @嵌入式方法 = "">
    参数 逻辑值 <类型 = 逻辑型 注释 = "逻辑型返回值" "">
    {
        @ (int)jsBoolean (@<逻辑值>)
    }

    方法 js字符串 <公开 静态 类型 = 整数 注释 = "创建一个值为js字符串型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 文本内容 <类型 = 文本型 注释 = "文本内容">
    {
        @ (int)jsDoubleString (CU8String (@<文本内容>).GetText())
    }

    方法 js文本 <公开 静态 类型 = 整数 注释 = "创建一个值为js字符串型的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 文本内容 <类型 = 文本型 注释 = "文本内容">
    {
        @ (int)jsStringW ((jsExecState)@<js执行状态>,@<文本内容>)
    }

    方法 js数组缓冲区 <公开 静态 类型 = 整数 注释 = "创建一个表示jsArrayBuffer型的jsValue句柄主要用来处理一些二进制数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 二进制数据 <类型 = 字节集类 注释 = "欲向js中加入的字节集数据">
    参数 数据长度 <类型 = 变整数 注释 = "数据尺寸">
    {
        @ (int)jsArrayBuffer ((jsExecState)@<js执行状态>,(const char*)@<二进制数据>.GetPtr(), (size_t)@<数据长度>)
    }

    方法 js取数组缓冲区 <公开 静态 类型 = 字节集类 注释 = "将代表jsArrayBuffer的数据转成字节集" 返回值注释 = "返回内存数据字节集" @禁止流程检查 = 真>
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        @ wkeMemBuf* buf = jsGetArrayBuffer((jsExecState)@<js执行状态>, (jsValue)@<jsValue句柄>);
        @ if (buf == NULL)  return CVolMem();
        @ return CVolMem(buf->data, buf->length);
    }

    方法 js空对象 <公开 静态 类型 = 整数 注释 = "创建一个空对象的jsValue句柄 用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    {
        @ (int)jsEmptyObject ((jsExecState)@<js执行状态>)
    }

    方法 js空数组 <公开 静态 类型 = 整数 注释 = "创建一个表示空数组的jsValue句柄用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @嵌入式方法 = "">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    {
        @ (int)jsEmptyArray ((jsExecState)@<js执行状态>)
    }

    方法 js对象 <静态 类型 = 整数 注释 = "创建一个表示js对象型的jsValue句柄用于程序向js返回数据" 返回值注释 = "返回jsValue句柄" @禁止流程检查 = 真>
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    {
        @ jsData* data = new jsData();
        @ memset(data, 0, sizeof(jsData));
        @ strcpy(data->typeName, "Object");
        @ return (int)jsObject ((jsExecState)@<js执行状态>, data);
    }
}

类 js值 <公开 基础类 = jsValue类 注释 = "用于获得执行JS脚本的返回值以及获得js参数值">
{
    变量 _jv <类型 = 变整数>
    变量 _es <类型 = 变整数>

    方法 绑定 <公开 类型 = js值 注释 = "绑定jsValue句柄和js执行状态" 返回值注释 = "返回js值对象用于后续的取值操作">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态">
    参数 jsValue句柄 <类型 = 变整数 注释 = "jsValue句柄">
    {
        _jv = jsValue句柄
        _es = js执行状态
        返回 (本对象)
    }

    方法 jsValue句柄 <公开 属性读 类型 = 变整数 注释 = "取代表当前js值的jsValue句柄">
    {
        返回 (_jv)
    }

    方法 js执行状态 <公开 属性读 类型 = 变整数 注释 = "取当前js值的执行状态句柄">
    {
        返回 (_es)
    }

    方法 取文本值 <公开 类型 = 文本型 注释 = "将js返回的值转换成文本" 返回值注释 = "返回js返回的文本值">
    {
        返回 (js到文本 (_es, _jv))
    }

    方法 取整数值 <公开 类型 = 整数 注释 = "将js返回的值转换成整数" 返回值注释 = "返回js返回的整数值">
    {
        返回 (js到整数 (_es, _jv))
    }

    方法 取小数值 <公开 类型 = 小数 注释 = "将js返回的值转换成小数" 返回值注释 = "js返回的小数值">
    {
        返回 (js到小数 (_es, _jv))
    }

    方法 取浮点数值 <公开 类型 = 小数 注释 = "将js返回的值转换成小数" 返回值注释 = "返回js返回的浮点数,这里使用小数表示">
    {
        返回 (js到浮点数 (_es, _jv))
    }

    方法 取逻辑值 <公开 类型 = 逻辑型 注释 = "将js返回的值转换成逻辑值" 返回值注释 = "返回js返回的逻辑值">
    {
        返回 (js到逻辑 (_es, _jv))
    }

    方法 取字节集值 <公开 类型 = 字节集类 注释 = "将js返回的ArrayBuffer类型值转为字节集" 返回值注释 = "失败返回空字节集">
    {
        返回 (js取数组缓冲区 (_es, _jv))
    }

    方法 取值类型 <公开 类型 = js数据类型 注释 = "取js值的类型,与js数据类型常量进行比较判断值的类型"
            返回值注释 = "js数据类型常量 0:数值; 1:文本; 2:逻辑; 3:对象; 4:方法; 5:未定义; 6:数组; 7:空">
    {
        返回 (js取类型 (_jv))
    }
}

类 js参数 <公开 基础类 = jsValue类 注释 = "用于获得js绑定方法被执行时提供的的参数">
{
    变量 _es <类型 = 变整数>

    方法 绑定 <公开 类型 = js参数 注释 = "绑定设置js执行状态" 返回值注释 = "返回js参数对象" 折叠>
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态,可以理解成一个句柄.">
    {
        _es = js执行状态
        返回 (本对象)
    }

    方法 js执行状态 <公开 属性读 类型 = 变整数 注释 = "取当前js参数的执行状态句柄" 折叠>
    {
        返回 (_es)
    }

    方法 取参数 <公开 类型 = js值 注释 = "取绑定js方法的参数" 返回值注释 = "返回js值对象" 折叠>
    参数 参数索引 <类型 = 整数 注释 = "参数索引 从0开始第几个参数">
    {
        变量 jr <类型 = js值>
        jr.绑定 (_es, js取参数 (_es, 参数索引))
        返回 (jr)
    }

    方法 取参数类型 <公开 类型 = js数据类型 注释 = "取绑定js方法的参数类型" 返回值注释 = "返回js数据类型常量 0:数值; 1:文本; 2:逻辑; 3:对象; 4:方法; 5:未定义; 6:数组; 7:空" 折叠>
    参数 参数索引 <类型 = 整数 注释 = "参数索引 从0开始第几个参数">
    {
        返回 (js参数类型 (_es, 参数索引))
    }

    方法 取参数个数 <公开 类型 = 整数 注释 = "取绑定js方法的参数个数" 返回值注释 = "返回js方法的参数个数" 折叠>
    {
        返回 (js取参数个数 (_es))
    }
}

# //==

类 MB网络工作 <公开 注释 = "MB网络工作类,用于获得或处理MB网络请求相关操作" "">
{
    变量 _job <类型 = 变整数>

    方法 绑定 <公开 类型 = MB网络工作 注释 = "初始化绑网络工作指针封装层内部使用" 返回值注释 = "返回MB网络工作对象" "">
    参数 网络工作指针 <类型 = 变整数>
    {
        _job = 网络工作指针
        返回 (本对象)
    }

    方法 置MIMEType <公开 注释 = "设置网络响应的的MIMEType">
    参数 MIME类型 <类型 = 文本型 注释 = "MIME类型 如:\"image/jpeg\"">
    {
        变量 mime <类型 = 字节集类>
        mime = 文本到字节集 (MIME类型)
        @ wkeNetSetMIMEType((wkeNetJob)@<_job>,(const utf8 *)@<mime>.GetPtr());
    }

    方法 取MIMEType <公开 类型 = 文本型 注释 = "获取网络响应的的MIMEType" @禁止流程检查 = 真>
    参数 MIME类型 <类型 = 文本型 注释 = "MIME类型 如:\"image/jpeg\"" @默认值 = "">
    {
        变量 mime <类型 = 字节集类>
        mime = 文本到字节集 (MIME类型)
        @ wkeString str =wkeCreateString((const utf8 *)@<mime>.GetPtr(),@<mime>.GetSize ());
        @ return wkeNetGetMIMEType((wkeNetJob)@<_job>,str);
    }

    方法 取HTTP头某字段 <公开 类型 = 文本型 注释 = "根据参数名获取http请求头" 返回值注释 = "http头字段的值" @禁止流程检查 = 真>
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    {
        @ return wkeNetGetHTTPHeaderField((wkeNetJob)@<_job>,CU8String (@<http头字段名>).GetText());
    }

    方法 置HTTP头某字段 <公开 注释 = "设置http请求（或者file:///协议）的http请求头" "">
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    参数 http头字段值 <类型 = 文本型 注释 = "http头字段值">
    {
        @ wkeNetSetHTTPHeaderField((wkeNetJob)@<_job>, @<http头字段名>, @<http头字段值>, 0);
    }

    方法 取HTTP响应头某字段 <公开 类型 = 文本型 注释 = "获取http响应头" 返回值注释 = "http头字段的值" @禁止流程检查 = 真>
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    {
        @ return wkeNetGetHTTPHeaderFieldFromResponse((wkeNetJob)@<_job>,CU8String (@<http头字段名>).GetText());
    }

    方法 置数据 <公开 注释 = "  调用此方法后,网络层收到数据会存储在一个内存缓冲区内,接收数据完成后触发\"结束加载Url\"事件.并允许次方法修改网络数据,"
            注释 = "此接口一般在\"开始加载Url\"事件中使用,在网络访问执行前,设置指定的数据到网络层,数据内容可以为js代码,图片,字符串,数据块等任意类型.">
    参数 数据 <类型 = 字节集类 注释 = "欲修改的网络数据">
    {
        @ wkeNetSetData((wkeNetJob)@<_job>,(void*)@<数据>.GetPtr(),(int)@<数据>.GetSize ());
    }

    方法 Hook请求 <公开 注释 = "此方法一般在\"开始加载Url\"事件中使用,调用此方法会在接收数据完成后响应\"结束加载Url\"事件中获得拦截到的数据.">
    {
        @ wkeNetHookRequest((wkeNetJob)@<_job>);
    }

    方法 取请求方法 <公开 类型 = 整数 注释 = "取当前http请求类型" 返回值注释 = "请求类型 0:无效; 1:Get; 2:Post; 3:Put." @禁止流程检查 = 真>
    {
        @ return (int)wkeNetGetRequestMethod((wkeNetJob)@<_job>);
    }

    方法 取Url <公开 类型 = 文本型 注释 = "获取当前请求的链接地址" 返回值注释 = "前请求的链接地址" @禁止流程检查 = 真>
    {
        @ return wkeNetGetUrlByJob((wkeNetJob)@<_job>);
    }

    方法 取消请求 <公开 注释 = "取消本次网络请求,此方法需要在\"开始载入Ulr\"事件中使用.">
    {
        @ wkeNetCancelRequest((wkeNetJob)@<_job>);
    }

    方法 修改请求URL <公开 注释 = "修改当前请求的url,使请求指向另外一个url,此方法需要在\"开始载入Ulr\"事件中使用.">
    参数 链接地址 <类型 = 文本型 注释 = "欲修改的url">
    {
        @ wkeNetChangeRequestUrl((wkeNetJob)@<_job>,CU8String (@<链接地址>).GetText ());
    }

    方法 取HTTP请求头 <公开 注释 = "用于获得当前载入链接的请求头信息">
    参数 请求头数据 <类型 = 文本数组类 注释 = "提供文本数组变量,用于存放获得的请求头信息,每个成员代表一个字段.">
    {
        @ const wkeSlist* psHeadList = wkeNetGetRawHttpHead((wkeNetJob)@<_job>);
        @ while (psHeadList != nullptr)
        @ {
        @     @<请求头数据>.data ().Add2 (psHeadList->data);
        @     psHeadList = psHeadList->next;
        @ }
    }

    方法 取HTTP响应头 <公开 注释 = "用于获得当前载入链接的响应头信息">
    参数 响应头数据 <类型 = 文本数组类 注释 = "提供文本数组变量,用于存放获得的响应头信息,每个成员代表一个字段.">
    {
        @ const wkeSlist* psHeadList = wkeNetGetRawResponseHead((wkeNetJob)@<_job>);
        @ while (psHeadList != nullptr)
        @ {
        @     @<响应头数据>.data ().Add2 (psHeadList->data);
        @     psHeadList = psHeadList->next;
        @ }
    }

    方法 取POST数据 <公开 类型 = 整数 注释 = "取当前POST请求数据,当前请求类型为POST时有效." 返回值注释 = "成功返回提交数据(文件)个数,否则返回0." @禁止流程检查 = 真>
    参数 POST数据 <类型 = 字节集数组类 注释 = "提供一个字节集数组,用来接收POST数据集.">
    {
        @ wkePostBodyElements* pPostDatas = wkeNetGetPostBody((wkeNetJob)@<_job>);
        @ if(pPostDatas == nullptr) return 0;
        @ wkePostBodyElement* pElement;
        @ for (int i = 0; i< pPostDatas->elementSize; i++)
        @ {
        @     if (pPostDatas->element != nullptr)
        @     {
        @         pElement =(pPostDatas->element)[i];
        @         if (pElement->type == wkeHttBodyElementTypeData)
        @         {
        @             if(pElement->data != NULL ) 
        @                @<POST数据>.Add (CVolMem((BYTE*)pElement->data->data, pElement->data->length) , NULL);
        @         } else {
        @            @<POST数据>.Add (CVolMem(wkeGetString( pElement->filePath)) , NULL); //@<POST数据>.Add (CVolMem((BYTE*)pElement->fileStart, pElement->fileLength) , NULL); //
        @         }
        @     } 
        @ }
        @ return (int)pPostDatas->elementSize; 
    }
}

