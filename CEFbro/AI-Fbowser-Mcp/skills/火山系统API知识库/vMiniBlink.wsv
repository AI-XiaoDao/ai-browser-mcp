        @ wkeAddPluginDirectory(@sn<this>.GetwebView(), @<文件目录>)
    }

    方法 媒体音量 <公开 属性写 注释 = "设置浏览器的媒体音量">
    参数 音量 <类型 = 小数 注释 = "媒体音量值默认为1">
    {
        @ wkeSetMediaVolume(GetwebView(),(float)@<音量>);
    }

    方法 媒体音量 <公开 属性读 类型 = 小数 注释 = "取浏览器的媒体音量" 返回值注释 = "媒体音量值" @嵌入式方法 = "">
    {
        @ wkeGetMediaVolume(@sn<this>.GetwebView())
    }

    方法 启用Cookie <公开 属性写 注释 = "设置Cookie是否可用">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用" @默认值 = 真>
    {
        @ wkeSetCookieEnabled(GetwebView(),@<是否启用>);
    }

    方法 启用Cookie <公开 属性读 类型 = 逻辑型 注释 = "判断是否启用Cookie" 返回值注释 = "真为启用" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsCookieEnabled(@sn<this>.GetwebView())
    }

    方法 启用高分辨率支持 <公开 静态 注释 = "本质是通过设置ZOOM并且关闭系统默认缩放来实现的,所以再使用\"缩放系数\"会发现值可能不为1。" @嵌入式方法 = "">
    {
        @ wkeEnableHighDPISupport()
    }

    方法 启用鼠标 <公开 注释 = "开启或关闭鼠标消息,可以在开启触屏后,关闭鼠标消息" @嵌入式方法 = "">
