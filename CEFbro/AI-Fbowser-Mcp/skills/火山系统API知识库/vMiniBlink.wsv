    {
        @ wkeGetContentWidth(@sn<this>.GetwebView() )
    }

    方法 垃圾回收 <公开 注释 = " 延迟让MB垃圾回收" @嵌入式方法 = "">
    参数 延迟毫秒 <类型 = 整数 注释 = "时间单位为毫秒">
    {
        @ wkeGC(@sn<this>.GetwebView(), @<延迟毫秒>)
    }

    方法 置资源回收间隔 <公开 注释 = "设置浏览器资源回收间隔" @嵌入式方法 = "">
    参数 时间间隔 <类型 = 整数 注释 = "时间单位为秒">
    {
        @ wkeSetResourceGc(@sn<this>.GetwebView(), @<时间间隔>)
    }

    方法 工具_截图 <公开 类型 = 字节集类 注释 = "将页面打印到位图,返回位图字节集数据." 返回值注释 = "成功返回页面截图数据" @禁止流程检查 = 真>
    参数 框架ID <类型 = 变整数 注释 = "欲截图的框架ID">
    {
        @ wkeScreenshotSettings sst;
        @ const wkeMemBuf * buf;
        @ buf = wkePrintToBitmap(GetwebView(), (wkeWebFrameHandle) @<框架ID>, &sst);
        @ CVolMem data(buf->data ,buf->length);
        @ return data;
    }

    方法 工具_打印到PDF <公开 类型 = 字节集类 注释 = "将页面生产PDF文件" 返回值注释 = "成功返回PDF文件" @禁止流程检查 = 真>
    参数 框架ID <类型 = 变整数 注释 = "提供欲生成PDF的框架ID">
    参数 分辨率 <类型 = 整数 注释 = "设置PDF的分辨率(50倍数)" @默认值 = 100>
    参数 打印背景 <类型 = 逻辑型 注释 = "是否打印背景" @默认值 = 真>
    参数 宽度 <类型 = 整数 注释 = "设置PDF页面宽度" @默认值 = 842>
    参数 高度 <类型 = 整数 注释 = "设施PDF页面高度" @默认值 = 595>
    参数 顶边距 <类型 = 整数 注释 = "设置PDF页面顶边边距" @默认值 = 0>
    参数 底边距 <类型 = 整数 注释 = "设置PDF页面底边边距" @默认值 = 0>
    参数 左边距 <类型 = 整数 注释 = "设置PDF页面左边边距" @默认值 = 0>
    参数 右边距 <类型 = 整数 注释 = "设置PDF页面右边边距" @默认值 = 0>
    {
        // 打印设置
        @ wkePrintSettings pst;
        @ pst.structSize = sizeof(wkePrintSettings);
        @ pst.dpi = @<分辨率>;
        @ pst.width = @<宽度>;
        @ pst.height = @<高度>;
        @ pst.marginTop=@<顶边距>;
        @ pst.marginBottom=@<底边距>;
        @ pst.marginLeft=@<左边距>;
        @ pst.marginRight=@<右边距>;
        @ pst.isPrintPageHeadAndFooter = 0;
        @ pst.isPrintBackgroud =@<打印背景>;
        @ pst.isLandscape = 0;
        @ pst.isPrintToMultiPage = 0;
        // pdf结构
        @ const wkePdfDatas* pdf;
        @ pdf = wkeUtilPrintToPdf(GetwebView(),(wkeWebFrameHandle) @<框架ID>, &pst);
        @ size_t size = *(pdf->sizes);
        @ const  void * data =*(pdf->datas);
        @ CVolMem rdata((char *)data, size);
        @ wkeUtilRelasePrintPdfDatas(pdf);
        @ return rdata;
    }

    方法 工具_序列化到MHTML <公开 类型 = 字节集类 注释 = "序列化到MHTML文档,返回UTF8字节集." 返回值注释 = "成功返回MHTML文档字节集" @禁止流程检查 = 真>
    {
        @ return wkeUtilSerializeToMHTML(GetwebView());
    }

    方法 URLEscape编码 <公开 静态 类型 = 文本型 注释 = "将一串URL地址转化成Escape编码" 返回值注释 = "成功返回Escape编码文本" @嵌入式方法 = "">
