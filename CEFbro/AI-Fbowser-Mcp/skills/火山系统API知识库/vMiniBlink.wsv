    方法 初始化 <公开 静态 注释 = "MiniBlink全局初始化 创建窗口前调用">
    参数 DllPath <类型 = 文本型 注释 = "MiniBlink动态库名称默认为\"node.dll\"用户可通过此参数修改调用动态库dll名称,请将改名后的dll库放置在编译目录." @默认值 = "node.dll">
    {
        @ wkeSetWkeDllPath(@<DllPath>);
        @ wkeInitialize();
    }

    方法 是否初始化 <公开 静态 类型 = 逻辑型 注释 = "检查MiniBlink是否初始化" 返回值注释 = "是否已初始化" @禁止流程检查 = 真>
    参数 DllPath <类型 = 文本型 注释 = "mb库dll名称 默认:\"node.dll\"" @默认值 = "node.dll">
    {
        @ typedef bool (WKE_CALL_TYPE *FN_wkeIsInitializes)();
        @ HMODULE hMod = s_wkeMainDllHandle;
        @ if(!hMod)
        @ {
        @     hMod = LoadLibraryW(@<DllPath>);
        @     wkeSetWkeDllHandle(hMod);
        @ }
        @ if (hMod)
        @ {
        @     FN_wkeIsInitializes wkeIsInitializeFunc = (FN_wkeIsInitializes)GetProcAddress(hMod, "wkeIsInitialize");
        @     return wkeIsInitializeFunc();
        @ }
        @ return FALSE;
    }

    方法 事件注册 <公开 注释 = "浏览器窗口创建后会默认调用此方法注册事件,如果使用创建内存视图方式由用户自行事件注册">
    {
        @ wkeOnTitleChanged(GetwebView(), handleTitleChanged, this);
        @ wkeOnDocumentReady(GetwebView(),handleDocumentReady, this);
        @ wkeOnDocumentReady2(GetwebView(), handleDocumentReady2, this);
        @ wkeOnLoadUrlBegin(GetwebView(), handleLoadUrlBegin, this);
        @ wkeOnLoadUrlEnd(GetwebView(),  handleLoadUrlEnd, this);
        @ wkeOnURLChanged(GetwebView(),  handleURLChanged, this);
        @ wkeOnURLChanged2(GetwebView(),  handleURLChanged2, this);
        @ wkeOnLoadingFinish(GetwebView(),  handleLoadingFinish, this);
        @ wkeOnAlertBox(GetwebView(), handleAlertBoxCallback, this);
        @ wkeOnConfirmBox(GetwebView(), handleConfirmBoxCallback, this);
        @ wkeOnPromptBox(GetwebView(), handlePromptBoxCallback, this);
        @ wkeOnNavigation(GetwebView(), handleNavigationCallback, this);
        @ wkeOnConsole(GetwebView(), handleConsoleCallback, this);
        @ wkeOnDidCreateScriptContext(GetwebView(),  handleDidCreateScriptContextCallback, this);
        @ wkeOnWillReleaseScriptContext(GetwebView(),  handleWillReleaseScriptContextCallback, this);
        @ wkeNetOnResponse(GetwebView(),  handleNetResponseCallback, this);
        @ wkeOnMouseOverUrlChanged(GetwebView(),  handleMouseOverUrlChangedCallback, this);
        @ wkeOnWillMediaLoad(GetwebView(),  handleWillMediaLoadCallback, this);
        @ wkeOnCreateView(GetwebView(), handleCreateViewCallback, this);
        @ wkeOnWindowClosing (GetwebView(), handleWindowClosingCallback, this);
        @ wkeOnWindowDestroy (GetwebView(), handleWindowDestroyCallback, this);
    }

    方法 取浏览器句柄 <公开 类型 = 变整数 注释 = "取MB浏览器句柄" 返回值注释 = "返回MB浏览器句柄" @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.GetwebView()
    }

    方法 置浏览器句柄 <公开 注释 = "相当于更换了本类对象的MB浏览器句柄用于操作不同的浏览器,本对象已经创建的浏览器(WebView)包括MB窗口将被销毁." "">
    参数 浏览器句柄 <类型 = 变整数 注释 = "提供一个新的浏览器句柄(WebView),并确保此句柄的有效性." "">
    {
        @ if (GetwebView () != NULL)
        @     wkeDestroyWebWindow(GetwebView());//销毁与webView相关的内容包括真实窗口
        @ SetwebView((wkeWebView)@<浏览器句柄>);
        @ wkeSetUserKeyValue((wkeWebView)@<浏览器句柄>,"pThis", (void *)this);
    }

    方法 取窗口句柄 <公开 类型 = 变整数 注释 = "取MB浏览器的窗口句柄" 返回值注释 = "MB浏览器的窗口句柄" @嵌入式方法 = "">
    {
        @ (INT_P)wkeGetHostHWND(@sn<this>.GetwebView())
    }

    方法 创建窗口 <公开 类型 = 逻辑型 注释 = "创建一个MB窗口,可以是弹出式窗口;无边框透明窗口;或者作为窗口子控件." "">
    参数 横坐标 <类型 = 整数 注释 = "窗口起始位置相对于屏幕的横坐标" @默认值 = 0>
    参数 纵坐标 <类型 = 整数 注释 = "窗口起始位置相对于屏幕的纵坐标" @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "窗口宽度" @默认值 = 500>
    参数 高度 <类型 = 整数 注释 = "窗口高度" @默认值 = 300>
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供一个父窗口句柄,当MB窗口类型为子控件窗口时需要提供父窗口句柄" @默认值 = 0>
    参数 窗口类型 <类型 = MB窗口类型 注释 = "提供MB窗口类型" @默认值 = MB窗口类型.弹出式窗口>
    {
        @ if(GetwebView ()!=NULL) return false;
        如果 (取反 (是否初始化 ()))
        {
            初始化 ()
        }
        @ wkeWebView webView = wkeCreateWebWindow((wkeWindowType)@<窗口类型>,(HWND)@<父窗口句柄>, @<横坐标>,@<纵坐标>,@<宽度>, @<高度>);
        @ if(!webView) return false;
        @ SetwebView(webView);
        @ wkeSetUserKeyValue(webView,"pThis", (void *)this);
        @ wkeShowWindow(webView, true);
        事件注册 ()
        返回 (真)
    }

    方法 创建自定义风格窗口 <公开 类型 = 逻辑型 注释 = "创建一个MB窗口,可以是弹出式窗口;无边框透明窗口;或者作为窗口子控件." "">
    参数 窗口风格 <类型 = 整数 注释 = "窗口风格">
    参数 扩展风格 <类型 = 整数 注释 = "窗口扩展风格">
    参数 横坐标 <类型 = 整数 注释 = "窗口起始位置相对于屏幕的横坐标" @默认值 = 0>
    参数 纵坐标 <类型 = 整数 注释 = "窗口起始位置相对于屏幕的纵坐标" @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "窗口宽度" @默认值 = 500>
    参数 高度 <类型 = 整数 注释 = "窗口高度" @默认值 = 300>
    参数 背景颜色 <类型 = 整数 注释 = "窗口的背景颜色,请使用颜色类常量." @默认值 = 颜色类.白色>
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供一个父窗口句柄" @默认值 = 0>
    {
        @ if(GetwebView ()!=NULL) return false;
        如果 (取反 (是否初始化 ()))
        {
            初始化 ()
        }
        @ wkeWindowCreateInfo info;
        @ info.parent=(HWND)@<父窗口句柄>;
        @ info.style=(DWORD)@<窗口风格>;
        @ info.styleEx=(DWORD)@<扩展风格>;
        @ info.x=@<横坐标>;
        @ info.y=@<纵坐标>;
        @ info.width=@<宽度>;
        @ info.height=@<高度>;
        @ info.color = @<背景颜色>;
        @ wkeWebView webView = wkeCreateWebCustomWindow(&info);
        @ if(!webView) return false;
        @ SetwebView(webView);
        @ wkeSetUserKeyValue(webView,"pThis", (void *)this);
        @ wkeShowWindow(webView, true);
        事件注册 ()
        返回 (真)

    }

    方法 置无边框窗口缩放 <公开 注释 = "创建MB窗口类型为:\'透明窗口\' 即无边框窗口时设置窗口可拖拽缩放">
    {
        @ if (GetwebView () == NULL ) return ;
        @ HWND hWnd = wkeGetHostHWND(GetwebView());
        @ if (SetWindowNewWndProc(hWnd) != NULL)
        @ {
        @     wkeSetUserKeyValue(GetwebView (), "IsZoom", (void*)1);
        @     SetProp (hWnd, _T("webView"), (HANDLE)GetwebView());
        @ }

    }

    方法 置窗口最大缩放 <公开 注释 = "设置MB窗口的最大缩放尺寸">
    参数 宽度 <类型 = 整数 注释 = "MB窗口的最大宽度">
    参数 高度 <类型 = 整数 注释 = "MB窗口的最大高度">
    {
        @ if (GetwebView () == NULL ) return ;
        @ HWND hWnd = wkeGetHostHWND(GetwebView());
        @ if (SetWindowNewWndProc(hWnd) != NULL)
        @ {
        @     wkeSetUserKeyValue(GetwebView (), "MaxTrackSizeW", (void*)@<宽度>);
        @     wkeSetUserKeyValue(GetwebView (), "MaxTrackSizeH", (void*)@<高度>);
        @     SetProp (hWnd, _T("webView"), (HANDLE)GetwebView());
        @ }
    }

    方法 置窗口最小缩放 <公开 注释 = "设置MB窗口的最小缩放尺寸">
    参数 宽度 <类型 = 整数 注释 = "MB窗口的最小宽度">
    参数 高度 <类型 = 整数 注释 = "MB窗口的最小高度">
    {
        @ if (GetwebView () == NULL ) return ;
        @ HWND hWnd = wkeGetHostHWND(GetwebView());
        @ if (SetWindowNewWndProc(hWnd) != NULL)
        @ {
        @     wkeSetUserKeyValue(GetwebView (), "MinTrackSizeW", (void*)@<宽度>);
        @     wkeSetUserKeyValue(GetwebView (), "MinTrackSizeH", (void*)@<高度>);
        @     SetProp (hWnd, _T("webView"), (HANDLE)GetwebView());
        @ }
    }

    方法 创建内存浏览器 <公开 类型 = 逻辑型 注释 = "创建一个内存浏览器,但不创建真窗口(故没有窗口句柄),一般用在离屏渲染,无头模式,或绑定到窗口控件,游戏等." 返回值注释 = "成功返回真" @禁止流程检查 = 真>
    {
        @ if(GetwebView () != NULL) return false;
        @ wkeWebView webView = wkeCreateWebView();
        @ if(!webView) return false;
        @ SetwebView(webView);
        @ wkeSetUserKeyValue(webView,"pThis", (void *)this);
        @ return true;
    }

