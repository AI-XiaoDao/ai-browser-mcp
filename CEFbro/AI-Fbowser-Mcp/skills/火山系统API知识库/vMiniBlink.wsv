    参数 页面标题 <类型 = 文本型 注释 = "被改变页面的标题">

    方法 开始加载Url <公开 定义事件 类型 = 整数 注释 = "浏览器在开始一个请求时触发此事件,本事件中封装了一个类型为\"MB网络工作\"的对象,可对此次请求进行修改或拦截操作">
    参数 链接地址 <类型 = 文本型 注释 = "开始请求的url地址">
    参数 网络工作指针 <类型 = 变整数 注释 = "网络工作指针">
    参数 网络工作 <类型 = MB网络工作 注释 = "MB浏览器网络相关操作">

    方法 结束加载Url <公开 定义事件 类型 = 整数 注释 = "在 \"开始加载Url\" 事件中调用 \"网络工作.Hook请求()\"方法 在本事件中触发 并获得此次请求响应的数据">
    参数 链接地址 <类型 = 文本型 注释 = "请求的url地址">
    参数 网络工作指针 <类型 = 变整数 注释 = "MB网络工作指针">
    参数 网络工作 <类型 = MB网络工作 注释 = "MB浏览器网络相关操作">
    参数 响应数据 <类型 = 字节集类 注释 = "拦截到的响应数据">
    参数 数据长度 <类型 = 整数 注释 = "数据长度">

    方法 Url被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器Url被改变时触发此事件">
    参数 链接地址 <类型 = 文本型 注释 = "当前浏览器的url地址">

    方法 Url被改变2 <公开 定义事件 类型 = 整数 注释 = "当浏览器Url被改变时触发此事件">
    参数 框架ID <类型 = 变整数 注释 = "触发此事件所在的框架ID">
    参数 链接地址 <类型 = 文本型 注释 = "当前浏览器的url地址">

    方法 载入完成 <公开 定义事件 类型 = 整数 注释 = "  当浏览器载入完成触发此事件,由于现代网页大多采用动态加载,多框架等原因,"
            注释 = "本事件返回的加载完成并不等于\"网页已全部加载完成\",只表示MB已接收了服务器本次传回的全部数据.">
    参数 链接地址 <类型 = 文本型 注释 = "当前载入页面的url">
    参数 返回状态 <类型 = 整数 注释 = "返回状态 0:载入成功(SUCCEEDED)  1:载入失败(FAILED)  2:取消载入(CANCELED)">
    参数 失败原因 <类型 = 文本型 注释 = "失败原因">

    方法 Alert被调用 <公开 定义事件 类型 = 整数 注释 = "页面中js调用alert()方法 弹出信息框">
    参数 提示文本 <类型 = 文本型 注释 = "信息框提示文本">

    方法 Confirm被调用 <公开 定义事件 类型 = 整数 注释 = "页面中js调用confirm()方法 弹出信息框">
    参数 提示文本 <类型 = 文本型 注释 = "信息框提示文本">

    方法 Prompt被调用 <公开 定义事件 类型 = 整数 注释 = "页面中js调用prompt()方法 弹出对话框">
    参数 提示文本 <类型 = 文本型 注释 = "对话框中显示的提示文本 网页prompt 函数的第1个参数">
    参数 默认输入文本 <类型 = 文本型 注释 = "默认输入文本 调用prompt 函数的第二个参数">
    参数 输入文本 <类型 = 文本型 注释 = "输入的文本">

    方法 即将导航 <公开 定义事件 类型 = 整数 注释 = "浏览器即将跳转时触发此事件" 返回值注释 = "返回非0将拦截本次导航" "">
    参数 导航类型 <类型 = MB导航类型 注释 = "MB导航类型常量">
    参数 链接地址 <类型 = 文本型 注释 = "即将导航的链接地址">

    方法 即将创建新窗口 <公开 定义事件 类型 = 整数 注释 = "浏览器即将创建新窗口时触发此事件,配合\"启用导航到新窗口\"开关方法使用.">
    参数 导航类型 <类型 = MB导航类型 注释 = "MB导航类型常量">
    参数 链接地址 <类型 = 文本型 注释 = "即将在新窗口中载入的链接地址">
    参数 新浏览器句柄 <类型 = 变整数 注释 = "  由于火山的事件只能返回整数类型,故这里传递了一个指针,即打开新窗口的浏览器句柄," 注释 = "如果需要在新窗口中载入新的页面,请调用 写指针处值 (新浏览器句柄, 新的MB浏览器对"
            注释 = "象.取浏览器句柄()) 如果不写入此值将默认在当前浏览器窗口中载入链接地址.">

    方法 即将载入媒体 <公开 定义事件 类型 = 整数 注释 = "浏览器即将载入媒体时触发此事件">
    参数 链接地址 <类型 = 文本型 注释 = "媒体资源的链接地址">
