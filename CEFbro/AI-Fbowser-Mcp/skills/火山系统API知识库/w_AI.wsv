<火山程序 类型 = "通常" 版本 = 1 />

包 火山.AI

类 阿里云问答类 <公开 注释 = "基于阿里云百炼AI问答服务,通过\"模型\"变量来切换模型,默认为deepseek-r1,支持阿里云百炼平台所有的文本对话模型."
        注释 = "比如通义千问、DeepSeek、Llama、百川、ChatGLM、零一万物等." 注释 = "阿里云百炼官网申请密钥: https://bailian.console.aliyun.com/">
{
    变量 密钥 <公开 静态 类型 = 文本型 注释 = "提供秘钥\"sk-xxxxxxx\".">
    变量 模型 <公开 类型 = 文本型 值 = "deepseek-r1" 注释 = "默认为deepseek-r1,支持阿里云百炼平台所有的文本对话模型." 注释 = "模型名称可以去阿里云百炼官网获取." @属性变量 = 真>

    常量 API <类型 = 文本型 值 = "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions" 编辑时信息 = "0, F5E41, 0, 0">

    变量 访问 <类型 = 流式网络访问类>
    变量 提问历史 <类型 = 文本数组类>
    变量 回答历史 <类型 = 文本数组类>
    变量 回答内容收集 <类型 = 文本型>
    变量 互斥锁 <类型 = 互斥锁类>

    方法 提问 <公开>
    参数 欲提问的内容 <类型 = 文本型>
    参数 是否清除先前问答记录 <类型 = 逻辑型 注释 = "  如果本次提问为当前用户的首次提问或对话中不希望启用多轮对话支持,设置为真以自动清空本对象中记录的先前问答历史记录,避免内存一直被占用,"
            注释 = "否则设置为假,此时先前问答历史记录将一直被保存,用作在进行多轮对话时提供相关上下文信息. 多轮会话最大可用Token数可查询阿里云百炼官网介绍:"
            注释 = "  https://bailian.console.aliyun.com/?spm=5176.29619931.J__Z58Z6CX7MY__Ll8p1ZOR.1.74cd521cqb2Vgb&accounttraceid=a9382953620746809cb3b9471c096094bdje#/model-market/detail/deepseek-r1?tabKey=sdk">
    {
        变量 头部 <类型 = 文本数组类>
        头部.加入成员 ("Authorization: Bearer " + 密钥)
        头部.加入成员 ("Content-Type: application/json")
        变量 JSON <类型 = JSON对象类>
        JSON.置入文本值 ("model", 模型)
        互斥锁.加锁 ()
        如果 (是否清除先前问答记录)
        {
            提问历史.删除所有成员 ()
            回答历史.删除所有成员 ()
            回答内容收集 = ""
        }
        提问历史.加入成员 (欲提问的内容)
        JSON.置入数组值 ("messages", 生成消息列表 ())
        互斥锁.解锁 ()
        JSON.置入逻辑值 ("stream", 真)
        JSON.置入逻辑值 ("//stream_options.include_usage", 真)
        访问.网页访问 (API, 网页访问方式.POST, JSON.到字节集 (), 头部)
    }

    方法 清除先前问答记录 <公开 注释 = "清空本对象中记录的先前问答历史记录,避免内存一直被占用." 注释 = "注意: 先前问答历史记录被清除后在继续进行本次多轮对话时将无法提供历史问答上下文信息.">
    {
        互斥锁.加锁 ()
        提问历史.删除所有成员 ()
        回答历史.删除所有成员 ()
        回答内容收集 = ""
        互斥锁.解锁 ()
    }

    方法 停止回答 <公开 注释 = "中途停止AI的回答">
    {
        清除先前问答记录 ()
        访问.传输对象.暂停传输 ()
    }

    方法 生成消息列表 <类型 = JSON数组类>
    {
        变量 消息列表 <类型 = JSON数组类>
        计次循环 (回答历史.取成员数 ())
        {
            变量 提问消息 <类型 = JSON对象类>
            提问消息.置入文本值 ("role", "user")
            提问消息.置入文本值 ("content", 提问历史.取成员 (取循环索引 ()))
            变量 回答消息 <类型 = JSON对象类>
            回答消息.置入文本值 ("role", "assistant")
            回答消息.置入文本值 ("content", 回答历史.取成员 (取循环索引 ()))
            消息列表.置入对象值 (提问消息)
            消息列表.置入对象值 (回答消息)
        }
        如果 (提问历史.取成员数 () > 回答历史.取成员数 ())
        {
            变量 提问消息 <类型 = JSON对象类>
            提问消息.置入文本值 ("role", "user")
            提问消息.置入文本值 ("content", 提问历史.取成员 (提问历史.取成员数 () - 1))
            消息列表.置入对象值 (提问消息)
        }
        返回 (消息列表)
    }

    方法 流式网络访问类_正在访问 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 流式网络访问类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 访问结果 <类型 = 字节集类>
    {
        变量 流数据 <类型 = 文本型>
        流数据 = UTF8到文本 (访问结果)
        如果 (寻找文本 (流数据, "data: ") == -1)
        {
            变量 结果 <类型 = 阿里云问答结果类>
            结果.错误原因 = 流数据
            正在回答 (结果)
            清除先前问答记录 ()
            返回 (0)
        }
        变量 结果数组 <类型 = 文本数组类>
        分割子文本 (流数据, "data: ", 结果数组)
        结果数组.枚举循环 ()
        {
            变量 JSON <类型 = JSON对象类>
            变量 结果 <类型 = 阿里云问答结果类>
            如果 (JSON.创建自文本 (结果数组.取枚举值 ()))
            {
                如果 (JSON.成员是否存在 ("//usage.total_tokens"))
                {
                    结果.Token数 = JSON.取整数值 ("//usage.total_tokens")
                }
                结果.完成原因 = JSON.取文本值 ("//choices.[0].finish_reason")
                结果.思考内容 = JSON.取文本值 ("//choices.[0].delta.reasoning_content")
                结果.回答内容 = JSON.取文本值 ("//choices.[0].delta.content")
                互斥锁.加锁 ()
                如果 (结果.完成原因 != "")
                {
                    回答历史.加入成员 (回答内容收集)
                    回答内容收集 = ""
                }
                否则
                {
                    加入文本 (回答内容收集, 结果.回答内容)
                }
                互斥锁.解锁 ()
                正在回答 (结果)
                返回 (0)
            }
            结果.错误原因 = 流数据
            正在回答 (结果)
            清除先前问答记录 ()
        }
        返回 (0)
    }

    方法 正在回答 <公开 定义事件 类型 = 整数>
    参数 回答结果 <类型 = 阿里云问答结果类>
}

类 阿里云问答结果类 <公开 @文档 = "category = \"辅助类\"">
{
    变量 思考内容 <公开 类型 = 文本型>
    变量 回答内容 <公开 类型 = 文本型>
    变量 完成原因 <公开 类型 = 文本型>
    变量 Token数 <公开 类型 = 整数>
    变量 错误原因 <公开 类型 = 文本型 注释 = "发生错误后返回错误原因">
}

类 流式网络访问类 <公开 注释 = "针对AI流式响应封装的网络访问类">
{
    变量 传输对象 <公开 类型 = 网络传输类 编辑时信息 = "5BC9B, 0, 0, 0" 快速打开 = 真>

    方法 网页访问 <公开 注释 = "访问结果将通过\"正在访问\"事件返回.">
    参数 网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容.">
    参数 访问方式 <类型 = 网页访问方式 注释 = "提供所欲使用的请求方式." @默认值 = 网页访问方式.POST>
    参数 提交信息 <类型 = 字节集类 注释 = "设置本次请求所提交的数据,如果需要提交空请求体提供空对象即可." @默认值 = 空对象>
    参数 提交协议头 <类型 = 文本数组类 注释 = "提供本次请求所欲使用的附加协议头,协议头名称可重复." @默认值 = 空对象>
    {
        如果 (是否以文本开头 (网址, "http://", 假) == 假 && 是否以文本开头 (网址, "https://", 假) == 假)
        {
            网址 = "http://" + 网址
        }
        传输对象.地址 = 网址
        传输对象.置请求方式 (多项选择 ((整数)访问方式, "GET", "POST", "HEAD", "PUT", "OPTIONS", "DELETE", "TRACE", "CONNECT", "PATCH"))
        传输对象.置请求头 (提交协议头)
        如果 (是否为空对象 (提交信息) == 假)
        {
            如果 (提交信息.取字节集长度 () > 0)
            {
                传输对象.置提交数据 (提交信息)
            }
            否则
            {
                传输对象.置提交数据 (空对象, 假)
                传输对象.置提交数据尺寸 (0)
            }
        }
        否则
        {
            传输对象.置提交数据尺寸 (0)
        }
        如果 (访问方式 == 网页访问方式.HEAD)
        {
            传输对象.忽略主体请求 = 真
        }
        否则
        {
            传输对象.忽略主体请求 = 假
        }
        传输对象.置写入数据回调函数 (流式数据回调, 取对象自身指针 ())
        传输对象.发送请求 ()
    }

    方法 流式数据回调 <静态 类型 = 变整数 注释 = "\"置写入数据回调函数\"对应的方法模板." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式." 返回值注释 = "返回所处理的数据长度."
            @视窗.前缀文本 = "@CDECL">
    参数 数据 <类型 = 变整数 注释 = "本次回调提供的数据指针.">
    参数 数据尺寸 <类型 = 变整数 注释 = "本次回调提供单个数据的长度,即总长度应为 \"数据尺寸\"*\"数据数量\".">
    参数 数据数量 <类型 = 变整数 注释 = "本次回调提供数据的个数.">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    {
        读指针处对象 (用户数据, 流式网络访问类).正在访问 (指针到字节集 (数据, (整数)数据尺寸 * (整数)数据数量))
        返回 (数据尺寸 * 数据数量)
    }

    方法 正在访问 <公开 定义事件 类型 = 整数>
    参数 访问结果 <类型 = 字节集类>
}
