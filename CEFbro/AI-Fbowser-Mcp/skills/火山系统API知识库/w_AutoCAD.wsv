        返回 (读无参数属性 ("DirectionVector", COM变体型))
    }

    方法 方向矢量 <公开 属性写 注释 = "指定构造线方向矢量的 X、Y、Z 坐标">
    参数 欲写入属性值 <类型 = COM变体型>
    {
        写属性 ("DirectionVector", 欲写入属性值)
    }

    方法 偏移 <公开 类型 = COM变体型 注释 = "通过将构造线偏移指定距离来创建新图元对象">
    参数 距离 <类型 = 小数>
    {
        返回 (方法 ("Offset", COM变体型, 距离))
    }
}

