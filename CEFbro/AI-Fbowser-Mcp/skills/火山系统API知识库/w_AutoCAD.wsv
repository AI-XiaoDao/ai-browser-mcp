类 CAD文档 <公开 基础类 = 图形数据库 注释 = "AutoCAD 图形" @输出名 = "IAcadDocument">
{
    变量 事件管理对象 <类型 = COM对象事件类>

    方法 初始化 <公开 类型 = 逻辑型>
    {
        返回 (事件管理对象.挂接 (本对象, ))
    }

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = COM对象事件类>
    参数 标记值 <类型 = 整数>
    参数 来源COM对象 <类型 = COM对象类>
    参数 事件方法ID <类型 = 整数>
    参数 事件参数 <类型 = COM变体型数组类>
    参数 事件返回值 <类型 = COM变体型>
    {
        如果 (事件方法ID == 1 && 事件参数.取成员数 () >= 1)
        {
            请求保存 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 2 && 事件参数.取成员数 () >= 1)
        {
            保存完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 6 && 事件参数.取成员数 () >= 1)
        {
            命令被执行 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 7 && 事件参数.取成员数 () >= 1)
        {
            命令完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 8 && 事件参数.取成员数 () >= 1)
        {
            LISP请求 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 9)
        {
            LIST计算完毕 ()
        }
        否则 (事件方法ID == 10)
        {
            LISP被取消 ()
        }
        否则 (事件方法ID == 11)
        {
            选择被改变 ()
        }
        否则 (事件方法ID == 12)
        {
            被激活 ()
        }
        否则 (事件方法ID == 13)
        {
            取消激活 ()
        }
        否则 (事件方法ID == 14 && 事件参数.取成员数 () >= 1)
        {
            开始右击 (事件参数.取成员 (0))
        }
        否则 (事件方法ID == 15 && 事件参数.取成员数 () >= 1)
        {
            开始快捷菜单默认 (事件参数.取成员 (0).取COM对象2 (弹出菜单))
        }
        否则 (事件方法ID == 16 && 事件参数.取成员数 () >= 2)
        {
            开始编辑快捷菜单 (事件参数.取成员 (0).取COM对象2 (弹出菜单), 事件参数.取成员 (1).取COM对象2 (选择集))
        }
        否则 (事件方法ID == 17 && 事件参数.取成员数 () >= 2)
        {
            开始快捷菜单命令 (事件参数.取成员 (0).取COM对象2 (弹出菜单), 事件参数.取成员 (1).取值 (文本型))
        }
        否则 (事件方法ID == 18 && 事件参数.取成员数 () >= 1)
        {
            开始快捷菜单夹点 (事件参数.取成员 (0).取COM对象2 (弹出菜单))
        }
        否则 (事件方法ID == 19 && 事件参数.取成员数 () >= 1)
        {
            开始快捷菜单对象捕捉 (事件参数.取成员 (0).取COM对象2 (弹出菜单))
        }
        否则 (事件方法ID == 30 && 事件参数.取成员数 () >= 1)
        {
            结束快捷菜单 (事件参数.取成员 (0).取COM对象2 (弹出菜单))
        }
        否则 (事件方法ID == 20 && 事件参数.取成员数 () >= 1)
        {
            开始双击 (事件参数.取成员 (0))
        }
        否则 (事件方法ID == 21 && 事件参数.取成员数 () >= 1)
        {
            对象已添加 (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        否则 (事件方法ID == 22 && 事件参数.取成员数 () >= 1)
        {
            对象已删除 (事件参数.取成员 (0).取值 (长整数))
        }
        否则 (事件方法ID == 23 && 事件参数.取成员数 () >= 1)
        {
            对象已修改 (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        否则 (事件方法ID == 24 && 事件参数.取成员数 () >= 1)
        {
            开始打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 25 && 事件参数.取成员数 () >= 1)
        {
            结束打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 29 && 事件参数.取成员数 () >= 2)
        {
            窗口移动或调整大小 (事件参数.取成员 (0).取值 (长整数), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 31 && 事件参数.取成员数 () >= 1)
        {
            布局已切换 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 32 && 事件参数.取成员数 () >= 1)
        {
            窗口已修改 ((窗口状态)事件参数.取成员 (0).取值 (整数))
        }
        否则 (事件方法ID == 33)
        {
            开始关闭 ()
        }
        否则 (事件方法ID == 34 && 事件参数.取成员数 () >= 1)
        {
            文档开始关闭 (事件参数.取成员 (0).取值 (逻辑型))
        }
        返回 (0)
    }

    方法 请求保存 <公开 定义事件 类型 = 整数 注释 = "AutoCAD 收到保存图形的请求后触发" @输出名 = "BeginSave">
    参数 文件名称 <类型 = 文本型 @输出名 = "FileName">

    方法 保存完成 <公开 定义事件 类型 = 整数 注释 = "AutoCAD 完成保存图形时触发" @输出名 = "EndSave">
    参数 文件名称 <类型 = 文本型 @输出名 = "FileName">

    方法 命令被执行 <公开 定义事件 类型 = 整数 注释 = "命令发出后、完成前触发" @输出名 = "BeginCommand">
    参数 命令名称 <类型 = 文本型 @输出名 = "CommandName">

