    参数 选择对象 <类型 = COM对象类>
    参数 拾取点 <类型 = COM变体型>
    参数 提示文本 <类型 = COM变体型 @默认值 = 空对象>
    {
        无返回值方法 ("GetEntity", 选择对象, 拾取点, 提示文本)
    }

    方法 提示文本 <公开 注释 = "向命令行发送提示">
    参数 提示信息 <类型 = 文本型>
    {
        无返回值方法 ("Prompt", 提示信息)
    }

    方法 取子对象 <公开 注释 = "交互式获取对象或子图元">
    参数 对象 <类型 = COM对象类>
    参数 拾取点 <类型 = COM变体型>
    参数 转换矩阵 <类型 = COM变体型>
    参数 嵌套对象ID数组 <类型 = COM变体型>
    参数 提示文本 <类型 = COM变体型 @默认值 = 空对象>
    {
        无返回值方法 ("GetSubEntity", 对象, 拾取点, 转换矩阵, 嵌套对象ID数组, 提示文本)
    }

    方法 验证URL地址 <公开 类型 = 逻辑型 注释 = "验证给定的 URL">
    参数 URL地址 <类型 = 文本型>
    {
        返回 (方法 ("IsURL", 逻辑型, URL地址))
    }

    方法 取远程文件 <公开 注释 = "下载由 URL 指定的文件">
    参数 URL地址 <类型 = 文本型>
    参数 文件名称 <类型 = 文本型>
    参数 即时下载 <类型 = 逻辑型>
    {
        无返回值方法 ("GetRemoteFile", URL地址, 文件名称, 即时下载)
    }

    方法 上传文件 <公开 注释 = "将文件上载到由 URL 指定的远程位置">
    参数 URL地址 <类型 = 文本型>
    参数 文件名称 <类型 = 文本型>
    {
        无返回值方法 ("PutRemoteFile", URL地址, 文件名称)
    }

    方法 取远程文件地址 <公开 类型 = 逻辑型 注释 = "返回下载远程文件的源 URL">
    参数 文件名称 <类型 = 文本型>
    参数 URL地址 <类型 = 文本型>
    {
        返回 (方法 ("IsRemoteFile", 逻辑型, 文件名称, URL地址))
    }

    方法 打开指定网址 <公开 类型 = 逻辑型 注释 = "启动 Web 浏览器窗口，允许用户导航到任意 URL 并可指定 URL">
    参数 URL地址 <类型 = 文本型>
    参数 对话框标题 <类型 = 文本型>
    参数 按钮标题 <类型 = 文本型>
    参数 初始URL地址 <类型 = 文本型>
    参数 信息注册主键 <类型 = 文本型>
    参数 按钮总是被激活 <类型 = 逻辑型>
    {
        返回 (方法 ("LaunchBrowserDialog", 逻辑型, URL地址, 对话框标题, 按钮标题, 初始URL地址, 信息注册主键, 按钮总是被激活))
    }

    方法 非模态操作将开始 <公开 注释 = "指示无模式操作将要开始">
    参数 文本内容 <类型 = 文本型>
    {
        无返回值方法 ("SendModelessOperationStart", 文本内容)
    }

    方法 非模态操作已结束 <公开 注释 = "指示无模式操作已经结束.">
    参数 文本内容 <类型 = 文本型>
    {
        无返回值方法 ("SendModelessOperationEnded", 文本内容)
    }

    方法 取对象ID字符串 <公开 类型 = 文本型>
    参数 对象 <类型 = COM对象类>
    参数 是否十六进制 <类型 = 逻辑型>
    {
        返回 (方法 ("GetObjectIdString", 文本型, 对象, 是否十六进制))
    }
}

