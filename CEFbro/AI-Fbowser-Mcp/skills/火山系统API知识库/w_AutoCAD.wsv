类 CAD应用程序 <公开 基础类 = COM对象类 注释 = "AutoCAD 应用程序的实例" @输出名 = "IAcadApplication">
{
    变量 事件管理对象 <类型 = COM对象事件类>

    方法 初始化 <公开 类型 = 逻辑型 注释 = "调用本方法以初始化本类对象的内容,成功返回真,失败返回假.">
    参数 版本类型 <类型 = 应用程序类型 @默认值 = 应用程序类型.CAD>
    {
        获取 ((文本型)版本类型)
        如果 (是否为空 ())
        {
            返回 (创建 ((文本型)版本类型, ) && 事件管理对象.挂接 (本对象, ))
        }
        否则
        {
            事件管理对象.挂接 (本对象, )
            返回 (真)
        }
    }

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = COM对象事件类>
    参数 标记值 <类型 = 整数>
    参数 来源COM对象 <类型 = COM对象类>
    参数 事件方法ID <类型 = 整数>
    参数 事件参数 <类型 = COM变体型数组类>
    参数 事件返回值 <类型 = COM变体型>
    {
        如果 (事件方法ID == 1 && 事件参数.取成员数 () >= 2)
        {
            系统变量被改变 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1))
        }
        否则 (事件方法ID == 2)
        {
            新建图形 ()
        }
        否则 (事件方法ID == 3)
        {
            程序将被激活 ()
        }
        否则 (事件方法ID == 4)
        {
            程序将被取消激活 ()
        }
        否则 (事件方法ID == 5 && 事件参数.取成员数 () >= 2)
        {
            窗口被移动或改变大小 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 6)
        {
            将显示模式对话框 ()
        }
        否则 (事件方法ID == 7)
        {
            销毁模式对话框 ()
        }
        否则 (事件方法ID == 8 && 事件参数.取成员数 () >= 1)
        {
            即将被关闭 (事件参数.取成员 (0).取值 (逻辑型))
        }
        否则 (事件方法ID == 10 && 事件参数.取成员数 () >= 2)
        {
            放弃主应用程序文件 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 11 && 事件参数.取成员数 () >= 1)
        {
            加载ARX应用程序 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 12 && 事件参数.取成员数 () >= 1)
        {
            卸载ARX应用程序 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 13 && 事件参数.取成员数 () >= 1)
        {
            开始打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 14 && 事件参数.取成员数 () >= 1)
        {
            打印完毕 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 19 && 事件参数.取成员数 () >= 1)
        {
            请求保存 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 20 && 事件参数.取成员数 () >= 1)
        {
            保存完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 21 && 事件参数.取成员数 () >= 1)
        {
            请求打开图形 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 22 && 事件参数.取成员数 () >= 1)
        {
            图形打开完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 17 && 事件参数.取成员数 () >= 1)
        {
            命令被执行 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 18 && 事件参数.取成员数 () >= 1)
        {
            命令完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 15 && 事件参数.取成员数 () >= 1)
        {
            LISP请求 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 16)
        {
            LIST计算完毕 ()
        }
        否则 (事件方法ID == 24)
        {
            LISP被取消 ()
        }
        否则 (事件方法ID == 25 && 事件参数.取成员数 () >= 1)
        {
            窗口被改变 ((窗口状态)事件参数.取成员 (0).取值 (整数))
        }
        返回 (0)
    }

