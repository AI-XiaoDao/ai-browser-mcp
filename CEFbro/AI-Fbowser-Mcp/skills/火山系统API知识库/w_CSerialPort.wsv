<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.串口 <注释 = "封装自开源库：https://github.com/itas109/CSerialPort" 编辑时信息 = "224FDD, 0, 0, 0" @视窗.头文件搜寻目录 = "."
        @视窗.外部头文件 = "CSerialPort\\SerialPort.h\r\nCSerialPort\\SerialPortInfo.h"
        @视窗.外部源文件 = "CSerialPort\\SerialPort.cpp\r\nCSerialPort\\SerialPortBase.cpp\r\nCSerialPort\\SerialPortInfo.cpp\r\nCSerialPort\\SerialPortInfoBase.cpp\r\nCSerialPort\\SerialPortInfoWinBase.cpp\r\nCSerialPort\\SerialPortWinBase.cpp"
        @视窗.外部库 = "setupapi.lib" @视窗.外部头文件 = "<vector>">

类 串口通信类 <公开 基础类 = 参考对象类 注释 = "本类用于提供对串口数据收发支持." @视窗.后缀文本 = "public has_slots<>">
{

