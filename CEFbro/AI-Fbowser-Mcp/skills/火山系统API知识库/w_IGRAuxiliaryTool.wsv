    方法 取巴塞尔曲线控制点 <公开 注释 = "CalcCurveControlPoints，计算出绘制巴塞尔曲线的控制点位置。"
            注释 = "根据前点、中间点与后点这三点计算出绘制巴塞尔曲线的控制点位置，得到的控制点是两个，是相对于中间点的内侧控制点与外侧控制点。本函数不会直接返回这两个控制点的数据，而是在执行本函数后通过 CCPInnerX、CCPInnerY、CCPOuterX 与 CCPOuterY 这四个属性获取控制点的位置值。">
    参数 前点X <类型 = 小数 注释 = "前点的 X 位置。">
    参数 前点Y <类型 = 小数 注释 = "前点的 Y 位置。">
    参数 中间点X <类型 = 小数 注释 = "中间点的 X 位置。">
    参数 中间点Y <类型 = 小数 注释 = "中间点的 Y 位置。">
    参数 后点X <类型 = 小数 注释 = "后点的 X 位置。">
    参数 后点Y <类型 = 小数 注释 = "后点的 Y 位置。">
    {
        无返回值方法 ("CalcCurveControlPoints", 前点X, 前点Y, 中间点X, 中间点Y, 后点X, 后点Y)
    }

    方法 取内侧控制点X <公开 属性读 类型 = 小数 注释 = "CCPInnerX，获取绘制巴塞尔曲线的内侧控制点的 X 位置。" 注释 = "在获取本属性值时，前面必须调用过 CalcCurveControlPoints 函数。">
    {
        返回 (读无参数属性 ("CCPInnerX", 小数))
    }

