类 绘图接口 <公开 基础类 = COM对象类 注释 = "Graphics，应用工具，实现在部件框中自绘输出显示的功能接口，当部件框为自绘部件框时，调用本接口的方法在部件框中实现输出显示。">
{
    方法 类_清理
    {
        清除 ()
    }

    方法 对象值复制 <公开 注释 = "Assign，将同类型的参数对象赋值到本对象。">
    参数 对象类 <类型 = COM对象类>
    {
        无返回值方法 ("Assign", 对象类)
    }

    方法 依据计量单位 <公开 属性读 类型 = 逻辑型 注释 = "ByUnit，指定在绘制过程中与位置与大小相关的参数值采用哪种类型计量单位。"
            注释 = "如果本属性值为true，则采用报表的当前计量单位，通常为厘米或英寸，由报表主对象的“计量单位”属性指定；反之采用屏幕像素点为计量单位。" 返回值注释 = "默认值false">
    {
        返回 (读无参数属性 ("ByUnit", 逻辑型))
    }

    方法 依据计量单位 <公开 属性写 注释 = "ByUnit，指定在绘制过程中与位置与大小相关的参数值采用哪种类型计量单位。"
            注释 = "如果本属性值为true，则采用报表的当前计量单位，通常为厘米或英寸，由报表主对象的“计量单位”属性指定；反之采用屏幕像素点为计量单位。">
    参数 逻辑值 <类型 = 逻辑型 注释 = "默认值false">
    {
        写属性 ("ByUnit", 逻辑值)
    }

    方法 左 <公开 属性读 类型 = 小数 注释 = "Left，获取绘制输出的左端位置，此属性值始终为0，由 ByUnit 属性指定属性值采用的计量单位。">
    {
        返回 (读无参数属性 ("Left", 小数))
    }

    方法 上 <公开 属性读 类型 = 小数 注释 = "Top，获取绘制输出的上端位置，此属性值始终为0，由 ByUnit 属性指定属性值采用的计量单位。">
    {
        返回 (读无参数属性 ("Top", 小数))
    }

    方法 宽度 <公开 属性读 类型 = 小数 注释 = "Width，获取输出区域的高度，由 ByUnit 属性指定属性值采用的计量单位。">
    {
        返回 (读无参数属性 ("Width", 小数))
    }

    方法 高度 <公开 属性读 类型 = 小数 注释 = "Height，获取输出区域的宽度，由 ByUnit 属性指定属性值采用的计量单位。" 编辑时信息 = "46AA6, 0, 0, 0">
    {
        返回 (读无参数属性 ("Height", 小数))
    }

    方法 左端位置 <公开 属性读 类型 = 小数 注释 = "LeftInPaper，获取当前自定义绘制部件框在页面中输出的左端位置。"
            注释 = "此属性值只有在生成报表页面时有效(即在报表查询显示时本属性值始终为0)，且只能在部件框的“自绘脚本”中，或报表的 ControlCustomDraw 事件响应函数中读取。"
            注释 = "如果部件框在整个报表中只会显示一次，将属性值记录到某个报表参数中，后面再通过读取报表参数的值来获取此属性的值。"
            注释 = "如果部件框在整个报表中会显示多次，应该在 ControlCustomDraw 事件响应函数中获取此属性值并分别记录下每次的获取值。"
            注释 = "此属性可用于对报表进行数字签章定位功能，通过获取一个自绘部件框的位置实现指定签章位置的要求。">
    {
        返回 (读无参数属性 ("LeftInPaper", 小数))
    }

    方法 上端位置 <公开 属性读 类型 = 小数 注释 = "TopInPaper，获取当前自定义绘制部件框在页面中输出的上端位置。" 注释 = "本属性进一步说明请参考 LeftInPaper 属性的详细说明。">
    {
        返回 (读无参数属性 ("TopInPaper", 小数))
    }

    方法 取内侧控制点X <公开 属性读 类型 = 小数 注释 = "CCPInnerX，获取绘制巴塞尔曲线的内侧控制点的 X 位置。" 注释 = "在获取本属性值时，前面必须调用过 CalcCurveControlPoints 函数。">
    {
        返回 (读无参数属性 ("CCPInnerX", 小数))
    }

    方法 取内侧控制点Y <公开 属性读 类型 = 小数 注释 = "CCPInnerY，获取绘制巴塞尔曲线的内侧控制点的 Y 位置。" 注释 = "在获取本属性值时，前面必须调用过 CalcCurveControlPoints 函数。">
    {
        返回 (读无参数属性 ("CCPInnerY", 小数))
    }

    方法 取外侧控制点X <公开 属性读 类型 = 小数 注释 = "CCPOuterX，获取绘制巴塞尔曲线的外侧控制点的 X 位置。" 注释 = "在获取本属性值时，前面必须调用过 CalcCurveControlPoints 函数。">
    {
        返回 (读无参数属性 ("CCPOuterX", 小数))
    }

    方法 取外侧控制点Y <公开 属性读 类型 = 小数 注释 = "CCPOuterY，获取绘制巴塞尔曲线的外侧控制点的 Y 位置。" 注释 = "在获取本属性值时，前面必须调用过 CalcCurveControlPoints 函数。">
    {
        返回 (读无参数属性 ("CCPOuterY", 小数))
    }

    方法 绘制巴塞尔曲线 <公开 注释 = "CurveTo，从当前点开始用当前画笔绘制巴塞尔曲线。" 注释 = "从当前位置开始，根据内侧控制点、外侧控制点及终点绘制巴塞尔曲线。曲线经过当前位置点与终点。">
    参数 内侧点X <类型 = 小数 注释 = "内侧控制点的 X 位置。">
    参数 内侧点Y <类型 = 小数 注释 = "内侧控制点的 Y 位置。">
    参数 外侧点X <类型 = 小数 注释 = "外侧控制点的 X 位置。">
    参数 外侧点Y <类型 = 小数 注释 = "外侧控制点的 Y 位置。">
    参数 曲线终点X <类型 = 小数 注释 = "曲线终点的 X 位置。">
    参数 曲线终点Y <类型 = 小数 注释 = "曲线终点的 Y 位置。">
    {
        无返回值方法 ("CurveTo", 内侧点X, 内侧点Y, 外侧点X, 外侧点Y, 曲线终点X, 曲线终点Y)
    }

    方法 取巴塞尔曲线控制点 <公开 注释 = "CalcCurveControlPoints，计算出绘制巴塞尔曲线的控制点位置。"
            注释 = "根据前点、中间点与后点这三点计算出绘制巴塞尔曲线的控制点位置，得到的控制点是两个，是相对于中间点的内侧控制点与外侧控制点。本函数不会直接返回这两个控制点的数据，而是在执行本函数后通过 CCPInnerX、CCPInnerY、CCPOuterX 与 CCPOuterY 这四个属性获取控制点的位置值。">
    参数 前点X <类型 = 小数 注释 = "前点的 X 位置。">
    参数 前点Y <类型 = 小数 注释 = "前点的 Y 位置。">
    参数 中间点X <类型 = 小数 注释 = "中间点的 X 位置。">
    参数 中间点Y <类型 = 小数 注释 = "中间点的 Y 位置。">
    参数 后点X <类型 = 小数 注释 = "后点的 X 位置。">
    参数 后点Y <类型 = 小数 注释 = "后点的 Y 位置。">
    {
        无返回值方法 ("CalcCurveControlPoints", 前点X, 前点Y, 中间点X, 中间点Y, 后点X, 后点Y)
    }

    方法 开始路径 <公开 注释 = "BeginPath，开始一个路径"
            注释 = "在本函数调用之后，必须调用 MoveTo、LineTo、CurveTo 等函数进行路径的定义，也可以调用 ClosePath 封闭一个路径，最后调用 FillPath、StrokePath 或 StrokeAndFillPath 函数进行路径绘制。">
    {
        无参数及返回值方法 ("BeginPath")
    }

    方法 封闭路径 <公开 注释 = "ClosePath，封闭一个路径，让当前路径点连直线到起点。">
    {
        无参数及返回值方法 ("ClosePath")
    }

    方法 结束路径 <公开 注释 = "EndPath，结束一个路径(慎用此接口，导出PDF文件会出错，用封闭路径ClosePath即可)。">
    {
        无参数及返回值方法 ("EndPath")
    }

    方法 绘制路径 <公开 注释 = "StrokePath，此函数必须在 BeginPath 函数之后调用，即前面必须已经定义了一个路径。">
    {
        无参数及返回值方法 ("StrokePath")
    }

    方法 填充路径 <公开 注释 = "FillPath，填充路径前必须保证当前路径是一个封闭路径。此函数必须在 BeginPath 函数之后调用，即前面必须已经定义了一个路径。">
    {
        无参数及返回值方法 ("FillPath")
    }

    方法 绘制并填充路径 <公开 注释 = "StrokeAndFillPath，绘制并填充路径，必须保证当前路径是一个封闭路径。此函数必须在 BeginPath 函数之后调用，即前面必须已经定义了一个路径。">
    {
        无参数及返回值方法 ("StrokeAndFillPath")
    }

    方法 计算标签文本高度 <公开 类型 = 小数 注释 = "CalcLabelTextHeight，计算用当前字体完整输出指定文字需要的高度。" 返回值注释 = "返回指定文字的输出高度。">
    参数 文本串 <类型 = 文本型 注释 = "进行计算的文字串。">
    {
        返回 (方法 ("CalcLabelTextHeight", 小数, 文本串))
    }

    方法 计算标签文本宽度 <公开 类型 = 小数 注释 = "CalcLabelTextWidth，计算用当前字体完整输出指定文字需要的宽度。" 返回值注释 = "返回指定文字的输出宽度。">
    参数 文本串 <类型 = 文本型 注释 = "进行计算的文字串。">
    {
        返回 (方法 ("CalcLabelTextWidth", 小数, 文本串))
    }

    方法 计算文本输出个数 <公开 类型 = 整数 注释 = "CalcTextOutLen，计算出指定的文字在指定大小的区域中最多能完整输出多少个字符。" 返回值注释 = "返回能完整输出的字符个数。">
    参数 宽度 <类型 = 小数 注释 = "区域宽度。">
    参数 高度 <类型 = 小数 注释 = "区域高度。">
    参数 文本串 <类型 = 文本型 注释 = "要输出的文字串 。">
    参数 自动绕行 <类型 = 逻辑型 注释 = "文字是否自动绕行输出。">
    {
        返回 (方法 ("CalcTextOutLen", 整数, 宽度, 高度, 文本串, 自动绕行))
    }

    方法 计算格式文本输出宽度 <公开 类型 = 小数 注释 = "CalcDrawFormatTextWidth，计算出完整输出文字需要的宽度。"
            注释 = "将文字完整显示出来需要的宽度。这里宽度的计量单位由 ByUnit 属性值确定，默认以屏幕像素为计量单位。" 注释 = "如果是多行文字，按每行文字分别计算需要的输出宽度，以其中的最大值为计算结果。"
            返回值注释 = "返回完整输出文字需要的宽度。">
    参数 文本串 <类型 = 文本型 注释 = "指定要输出的文字。">
    参数 文本格式对象 <类型 = 文本格式 注释 = "指定文字的输出格式。">
    {
        返回 (方法 ("CalcDrawFormatTextWidth", 小数, 文本串, 文本格式对象))
    }

    方法 计算格式文本输出高度 <公开 类型 = 小数 注释 = "CalcDrawFormatTextHeight，计算输出文字需要的高度。"
            注释 = "在指定的输出宽度下，将文字完整显示出来需要的高度。这里宽度与高度的计量单位由 ByUnit 属性值确定，默认以屏幕像素为计量单位。" 返回值注释 = "返回完整输出文字需要的高度。">
    参数 文本串 <类型 = 文本型 注释 = "指定要输出的文字。">
    参数 宽度 <类型 = 小数 注释 = "指定输出区域的宽度。">
    参数 文本格式对象 <类型 = 文本格式 注释 = "指定文字输出格式。">
    {
        返回 (方法 ("CalcDrawFormatTextHeight", 小数, 文本串, 宽度, 文本格式对象))
    }

    方法 计算格式文本输出个数 <公开 类型 = 整数 注释 = "CalcDrawFormatTextOutLen，在指定大小的区域中，可以输出的文字个数。"
            注释 = "在给定宽度与高度的区域中，求得传入的文字能输出多少个。如果能完整输出，则返回值与文字的长度一致。" 返回值注释 = "返回可以输出的文字个数。">
    参数 文本串 <类型 = 文本型 注释 = "指定要输出的文字。">
