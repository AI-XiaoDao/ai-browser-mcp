    }

    方法 从文件载入 <公开 类型 = 逻辑型 注释 = "LoadFromFile，从磁盘文件或网络URL中载入二进制数据。">
    参数 文件名 <类型 = 文本型 注释 = "磁盘文件路径与文件名，或网络URL。">
    {
        返回 (方法 ("LoadFromFile", 逻辑型, 文件名))
    }

    方法 从变量载入 <公开 类型 = 逻辑型 注释 = "LoadFromVariant，从一个封装的二进制变量中载入数据。">
    参数 变量 <类型 = COM变体型 注释 = "二进制变量。">
    {
        返回 (方法 ("LoadFromVariant", 逻辑型, 变量))
    }

    方法 从内存载入 <公开>
    参数 数据指针 <类型 = 字节 注释 = "pData，数据地址指针">
