            注释 = "    PaperListNames += PaperName;" 注释 = "    PaperListNames += \"\\r\\n\";" 注释 = "}" 注释 = "alert(PaperListNames);"
            返回值注释 = "打印纸型的名称">
    参数 纸型序号 <类型 = 整数 注释 = "纸型序号，从1开始。">
    {
        返回 (读属性 ("GetPrinterPaperName", 文本型, 纸型序号))
    }

