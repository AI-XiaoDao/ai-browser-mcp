类 导出PDF选项 <公开 基础类 = 导出选项 注释 = "E2PDFOption，数据导出，表示导出PDF格式文件的选项。" 注释 = "PDF导出乱码原因与解决办法:"
        注释 = "1、一般是因为报表中的“字体“属性中的“字符集”没有设为对应的语言；" 注释 = "2、报表主对象的字体属性中的“字符集”要设对，不应该是“西方”；"
        注释 = "3、检查对应部件框或单元格的字体属性中的“字符集”要设对，不应该是“西方”；" 注释 = "4、如果是简体中文，字符集应该是GB2312，如果是繁体，字符集应该是CHINESE_BIG5；"
        注释 = "5、尝试将PDF导出对话框的“ANSI文字编码”项不勾选，以新的方式进行PDF导出。" 折叠2>
{
    方法 ANSI文字编码 <公开 属性读 类型 = 逻辑型 注释 = "AnsiTextMode，指定是否将文本数据编码为ANSI字符方式。"
            注释 = "如果此属性为FALSE，则文本内容将编码为字体图形方式，这种方式能很好解决乱码问题，但可能存在Windows XP与Windows7下产生的PDF文件互不相认的问题。" 注释 = "PDF导出乱码原因与解决办法:"
            注释 = "1、一般是因为报表中的“字体“属性中的“字符集”没有设为对应的语言；" 注释 = "2、报表主对象的字体属性中的“字符集”要设对，不应该是“西方”；"
            注释 = "3、检查对应部件框或单元格的字体属性中的“字符集”要设对，不应该是“西方”；" 注释 = "4、如果是简体中文，字符集应该是GB2312，如果是繁体，字符集应该是CHINESE_BIG5；"
            注释 = "5、尝试将PDF导出对话框的“ANSI文字编码”项不勾选，以新的方式进行PDF导出。">
    {
        返回 (读无参数属性 ("AnsiTextMode", 逻辑型))
    }

    方法 ANSI文字编码 <公开 属性写 注释 = "AnsiTextMode，指定是否将文本数据编码为ANSI字符方式。"
            注释 = "如果此属性为FALSE，则文本内容将编码为字体图形方式，这种方式能很好解决乱码问题，但可能存在Windows XP与Windows7下产生的PDF文件互不相认的问题。" 注释 = "PDF导出乱码原因与解决办法:"
            注释 = "1、一般是因为报表中的“字体“属性中的“字符集”没有设为对应的语言；" 注释 = "2、报表主对象的字体属性中的“字符集”要设对，不应该是“西方”；"
            注释 = "3、检查对应部件框或单元格的字体属性中的“字符集”要设对，不应该是“西方”；" 注释 = "4、如果是简体中文，字符集应该是GB2312，如果是繁体，字符集应该是CHINESE_BIG5；"
            注释 = "5、尝试将PDF导出对话框的“ANSI文字编码”项不勾选，以新的方式进行PDF导出。">
    参数 逻辑值 <类型 = 逻辑型>
    {
