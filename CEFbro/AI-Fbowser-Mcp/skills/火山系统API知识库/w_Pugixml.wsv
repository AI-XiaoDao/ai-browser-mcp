    方法 取变整数值 <公开 类型 = 变整数 注释 = "通过指定路径取出变整数值" 返回值注释 = "返回变整数值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @ #ifndef _PF_64_BITS
        @     return @<取整数值> (@<路径文本>);
        @ #else
        @     return @<取长整数值> (@<路径文本>);
        @ #endif
    }

    方法 置入变整数值 <公开 类型 = 逻辑型 注释 = "通过指定路径设置变整数值" 返回值注释 = "成功返回真" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    参数 内容 <类型 = 变整数 注释 = "提供要设置的内容">
    {
        @ #ifndef _PF_64_BITS
        @     return @<置入整数值>(@<路径文本>, @<内容>);
        @ #else
        @     return @<置入长整数值>(@<路径文本>, @<内容>);
        @ #endif
    }
}

类 XML节点集 <公开 注释 = "XML节点集合操作" @文档 = "category = \"辅助类\"">
{

    # @begin
    # <> <include>
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return &m_data == &objCompare.m_data;
    # }
    # @sn<current_class>(const pugi::xpath_node_set& o)
    # {
    #     m_data = o;
    # }
    # pugi::xpath_node_set& data()
    # {
    #     return m_data;
    # }
    # pugi::xpath_node_set m_data;
    #
    # #define for_xpath_node_set(member_data) \
    #     for (pugi::xpath_node_set::const_iterator it = member_data.begin(); it != member_data.end(); ++it)
    # <> </include>
    # @end

    方法 迭代循环 <公开 静态 注释 = "用于循环进行取节点对象操作." @嵌入式方法 = "name = for_xpath_node_set\nhas_loop_body = true">
    参数 所操作的本对象 <类型 = XML节点集>
    {
        @ for_xpath_node_set(@<所操作的本对象>.data())
    }

    方法 取迭代节点 <公开 类型 = XML节点类 注释 = "本方法只能在\"迭代循环\"的子语句体内使用." @嵌入式方法 = "parent = for_xpath_node_set">
    {
        @ @dt<XML节点类>( (*it).node() )
    }

    方法 取成员节点 <公开 静态 类型 = XML节点类 注释 = "取出当前集合中指定索引成员的节点对象." @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点集>
    参数 索引 <类型 = 整数 注释 = "本参数必定大于等于0,小于成员数.">
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data()[@<索引>].node() ) 
    }

    方法 取成员属性 <公开 静态 类型 = XML属性类 注释 = "取出当前集合中指定索引成员的属性对象." @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点集>
    参数 索引 <类型 = 整数 注释 = "本参数必定大于等于0,小于成员数.">
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data()[@<索引>].attribute())
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "取出当前集合的成员数" 返回值注释 = "返回数量" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点集>
    {
        @ (INT) @<所操作的本对象>.data().size()
    }
}

类 XML节点类 <公开 基础类 = XML节点基础类 注释 = "用于XML节点操作" @文档 = "category = \"辅助类\"">
{

    # @begin
    # <> <include>
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return m_data == objCompare.m_data;
    # }
    # @sn<current_class>(pugi::xml_node& o)
    # {
    #     m_data = o;
    # }
    # pugi::xml_node& data()
    # {
    #     return m_data;
    # }
    # pugi::xml_node m_data;
    # <> </include>
    # @end

    方法 到文本 <公开 类型 = 文本型 注释 = "将当前节点转换成文本显示.">
    {
        返回 (UTF8到文本 (到字节集 ()))
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把节点转换成字节集" 返回值注释 = "返回字节集" @禁止流程检查 = 真>
    参数 缩进 <类型 = 文本型 注释 = "提供缩进文本" @默认值 = "\t">
    {
        @ class CBuffer_Writer: public pugi::xml_writer
        @ {
        @ public: 
        @     virtual void write(const void* data, size_t size) 
        @     {
        @         buf.Append ((void*)data,(int)size);
        @     }
        @     @dt<字节集类>& data()
        @     {
        @         return buf;
        @     }
        @     @dt<字节集类> buf;
        @ };
        @ CBuffer_Writer bufWriter;
        @ data().print(bufWriter,@<缩进>);
        @ return bufWriter.data();
    }
}

