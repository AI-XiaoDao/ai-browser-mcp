类 XML节点值 <公开 注释 = "可用设置和读取节点内容." @文档 = "category = \"辅助类\"">
{

    # @begin
    # <> <include>
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return m_data == objCompare.m_data;
    # }
    # @sn<current_class>(pugi::xml_text& o)
    # {
    #     m_data = o;
    # }
    # pugi::xml_text& data()
    # {
    #     return m_data;
    # }
    # pugi::xml_text m_data;
    # <> </include>
    # @end

    方法 置入文本值 <公开 静态 注释 = "将指定的文本值置入当前XML节点值内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 文本型 注释 = "提供要置入的内容">
    {
        @ @<所操作的本对象>.data().set(@<内容>)
    }

    方法 置入整数值 <公开 静态 注释 = "将指定的整数值置入当前XML节点值内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 整数 注释 = "提供要置入的内容">
    {
        @ @<所操作的本对象>.data().set(@<内容>)
    }

    方法 置入逻辑值 <公开 静态 注释 = "将指定的逻辑值置入当前XML节点值内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 逻辑型 注释 = "提供要置入的内容">
    {
        @ @<所操作的本对象>.data().set(@<内容>)
    }

    方法 置入小数值 <公开 静态 注释 = "将指定的小数值置入当前XML节点值内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 小数 注释 = "提供要置入的内容">
    {
        @ @<所操作的本对象>.data().set(@<内容>)
    }

    方法 置入长整数值 <公开 静态 注释 = "将指定的长整数值置入当前XML节点值内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 长整数 注释 = "提供要置入的内容">
    {
        @ set_text_value_INT64(@<内容>,@<所操作的本对象>.data())
    }

    # @begin
    # <> <include>
    # #ifdef PUGIXML_HAS_LONG_LONG
    #     #define set_text_value_INT64(default_value,menber_xml_text_data)  menber_xml_text_data.set(default_value)
    # #else
    #     #define set_text_value_INT64(default_value)  menber_xml_text_data.set((double)default_value)
    # #endif
    # <> </include>
    # @end

    方法 取文本值 <公开 静态 类型 = 文本型 注释 = "读取XML节点文本值" 返回值注释 = "返回取出的文本值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 文本型 注释 = "如果属性不存在,将返回此默认值" @默认值 = "">
    {
        @ @an<CVolString>( @<所操作的本对象>.data().as_string(@<默认值>) )
    }

    方法 取逻辑值 <公开 静态 类型 = 逻辑型 注释 = "读取XML节点逻辑值" 返回值注释 = "返回取出的逻辑值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 逻辑型 注释 = "如果属性不存在,将返回此默认值" @默认值 = 假>
    {
        @ @<所操作的本对象>.data().as_bool(@<默认值>)
    }

    方法 取整数值 <公开 静态 类型 = 整数 注释 = "读取XML节点整数值" 返回值注释 = "返回取出的整数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 整数 注释 = "如果属性不存在,将返回此默认值" @默认值 = 0>
    {
        @ @<所操作的本对象>.data().as_int(@<默认值>)
    }

    方法 取小数值 <公开 静态 类型 = 整数 注释 = "读取XML节点小数值" 返回值注释 = "返回取出的小数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 小数 注释 = "如果属性不存在,将返回此默认值" @默认值 = 0>
    {
        @ @<所操作的本对象>.data().as_double(@<默认值>)
    }

    方法 取长整数值 <公开 静态 类型 = 长整数 注释 = "读取XML节点长整数值" 返回值注释 = "返回取出的长整数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 长整数 注释 = "如果属性不存在,将返回此默认值" @默认值 = 0>
    {
        @ (INT64)get_text_value_INT64( @<所操作的本对象>.data(),@<默认值>)
    }

    方法 取变整数值 <公开 静态 类型 = 变整数 注释 = "读取XML节点变整数值" 返回值注释 = "返回取出的变整数值" @禁止流程检查 = 真>
    参数 所操作的本对象 <类型 = XML节点值>
    参数 默认值 <类型 = 变整数 注释 = "如果属性不存在,将返回此默认值" @默认值 = 0>
    {
        @ #ifndef _PF_64_BITS
        @     return @<所操作的本对象>.data().as_int(@<默认值>);
        @ #else
        @     return (INT64)get_text_value_INT64( @<所操作的本对象>.data(),@<默认值>);
        @ #endif
    }

    方法 置入变整数 <公开 静态 注释 = "将指定的变整数值置入当前XML节点值内">
    参数 所操作的本对象 <类型 = XML节点值>
    参数 内容 <类型 = 变整数 注释 = "提供要置入的内容">
    {
        @ #ifndef _PF_64_BITS
        @     @<所操作的本对象>.data().set(@<内容>);
        @ #else
        @     set_text_value_INT64 (@<内容>,@<所操作的本对象>.data());
        @ #endif
    }
}

类 XML属性基础类 <公开 注释 = "用于XML属性操作" @文档 = "category = \"辅助类\"">
{
    方法 取首属性 <公开 静态 类型 = XML属性类 注释 = "取XML首属性" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @dt<XML属性类>( @<所操作的本对象>.data().first_child() )
    }

    方法 取尾属性 <公开 静态 类型 = XML属性类 注释 = "取XML尾属性" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @dt<XML属性类>( @<所操作的本对象>.data().last_child() )
    }

    方法 取下一个属性 <公开 静态 类型 = XML属性类 注释 = "取下一个XML属性" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @dt<XML属性类>( @<所操作的本对象>.data().next_attribute() )
    }

    方法 取上一个属性 <公开 静态 类型 = XML属性类 注释 = "取上一个XML属性" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @dt<XML属性类>( @<所操作的本对象>.data().previous_attribute())
    }

    方法 取属性名 <公开 静态 类型 = 文本型 注释 = "取XML属性名" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @an<CVolString>( @<所操作的本对象>.data().name() )
    }

    方法 取属性文本值 <公开 静态 类型 = 文本型 注释 = "取出XML属性的文本值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 默认值 <类型 = 文本型 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = "">
    {
        @ @an<CVolString>( @<所操作的本对象>.data().as_string(@<默认值>) )
    }

    方法 取属性逻辑值 <公开 静态 类型 = 逻辑型 注释 = "取出XML属性的逻辑值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 默认值 <类型 = 逻辑型 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = 假>
    {
        @ @<所操作的本对象>.data().as_bool(@<默认值>)
    }

    方法 取属性整数值 <公开 静态 类型 = 整数 注释 = "取出XML属性的整数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 默认值 <类型 = 整数 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = 0>
    {
        @ @<所操作的本对象>.data().as_int(@<默认值>)
    }

    方法 取属性小数值 <公开 静态 类型 = 整数 注释 = "取出XML属性的小数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 默认值 <类型 = 小数 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = 0>
    {
        @ @<所操作的本对象>.data().as_double(@<默认值>)
    }

    方法 取属性长整数值 <公开 静态 类型 = 长整数 注释 = "取出XML属性的长整数值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 默认值 <类型 = 长整数 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = 0>
    {
        @ _ttoi64 (@<所操作的本对象>.data ().as_string (@an<CVolString> (@<默认值>).GetText ())) 
    }

    方法 置入变整数值 <公开 静态 注释 = "将指定的变整数值置入当前XML属性内">
    参数 所操作的本对象 <类型 = XML属性类>
    参数 内容 <类型 = 变整数 注释 = "提供要设置的内容">
    {
        @ #ifndef _PF_64_BITS
        @     @<所操作的本对象>.data().set_value(@<内容>);
        @ #else
        @     set_value_INT64(@<内容>,@<所操作的本对象>.data());
        @ #endif
    }

    方法 取属性变整数值 <公开 静态 类型 = 变整数 注释 = "取出XML属性的变整数值" @禁止流程检查 = 真>
    参数 所操作的本对象 <类型 = XML属性类>
    参数 默认值 <类型 = 变整数 注释 = "如果属性不存在,那么将返回此默认值" @默认值 = 0>
    {
        @ #ifndef _PF_64_BITS
        @     return @<所操作的本对象>.data().as_int(@<默认值>);
        @ #else
        @     return _ttoi64 (@<所操作的本对象>.data().as_string(@an<CVolString>(@<默认值>).GetText ()));
        @ #endif
    }

    # @begin
    # <> <include>
    # #ifdef PUGIXML_HAS_LONG_LONG
    #     #define attribute_value_INT64(attribute,default_value)  attribute.as_llong(default_value)
    # #else
    #     #define attribute_value_INT64(attribute,default_value)  (INT64)attribute.as_double(default_value)
    # #endif
    # <> </include>
    # @end

    方法 置入文本值 <公开 静态 注释 = "将指定的文本值置入当前XML属性内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 内容 <类型 = 文本型 注释 = "提供要设置的内容">
    {
        @ @<所操作的本对象>.data().set_value(@<内容>)
    }

    方法 置入整数值 <公开 静态 注释 = "将指定的整数值置入当前XML属性内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 内容 <类型 = 整数 注释 = "提供要设置的内容">
    {
        @ @<所操作的本对象>.data().set_value(@<内容>)
    }

    方法 置入逻辑型 <公开 静态 注释 = "将指定的逻辑值置入当前XML属性内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 内容 <类型 = 逻辑型 注释 = "提供要设置的内容">
    {
        @ @<所操作的本对象>.data().set_value(@<内容>)
    }

    方法 置入小数值 <公开 静态 注释 = "将指定的小数值置入当前XML属性内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 内容 <类型 = 小数 注释 = "提供要设置的内容">
    {
        @ @<所操作的本对象>.data().set_value(@<内容>)
    }

    # @begin
    # <> <include>
    # #ifdef PUGIXML_HAS_LONG_LONG
    #     #define set_value_INT64(default_value,menber_xml_text_data)  menber_xml_text_data.set_value(default_value)
    # #else
    #     #define set_value_INT64(default_value)  menber_xml_text_data.set_value((double)default_value)
    # #endif
    # <> </include>
    # @end

    方法 置入长整数值 <公开 静态 注释 = "将指定的长整数值置入当前XML属性内" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    参数 内容 <类型 = 长整数 注释 = "提供要设置的内容">
    {
        @ set_value_INT64(@<内容>,@<所操作的本对象>.data())
    }

    方法 取哈希值 <公开 静态 类型 = 变整数 注释 = "取出当前XML属性的哈希值" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML属性基础类>
    {
        @ @<所操作的本对象>.data().hash_value()
    }
}

类 XML节点类型 <公开 注释 = "用于判断XML节点类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 空 <公开 值 = 0 注释 = "空节点">
    常量 文档根 <公开 值 = 1 注释 = "文档树根部">
    常量 元素 <公开 值 = 2 注释 = "元素标签,例如:\"<node/>\".">
    常量 PCDATA <公开 值 = 3 注释 = " 为可被解析字符串(PCDATA)."
            注释 = " XML解析器通常会解析XML文档中所有的文本,当某个XML元素被解析时,其标签之间的文本也会被解析,这样的数据就被称\"可被解析字符串(PCDATA)\".">
    常量 CDATA <公开 值 = 4 注释 = " 为不被解析字符串(CDATA)."
            注释 = " 像 \"<\" 和 \"&\" 字符在 XML 元素中都是非法的,某些文本包含大量 \"<\" 或 \"&\" 字符,为了避免错误,可以将脚本代码定义为\"不被解析字符串(CDATA)\",由 \"<![CDATA[\" 开始，由 \"]]>\" 结束.">
    常量 注释 <公开 值 = 5 注释 = "表示为注释内容">
    常量 处理指令 <公开 值 = 6 注释 = "处理指令,例如:\"<?name?>\".">
    常量 文档声明 <公开 值 = 7 注释 = "文档声明,声明这是一个xml文档.">
    常量 文档类型 <公开 值 = 8 注释 = "文档类型">
}

类 XML节点基础类 <公开 注释 = "用于XML节点操作" @文档 = "category = \"辅助类\"" @禁止创建对象 = 真>
{
    方法 取节点类型 <公开 静态 类型 = XML节点类型 注释 = "取出节点类型" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ (@dt<XML节点类型>)@<所操作的本对象>.data().type()
    }

    方法 取父节点 <公开 静态 类型 = XML节点类 注释 = "返回节点的父节点,除文档外,所有非空节点都具有非空父节点." @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ @<所操作的本对象>.data().parent()
    }

    方法 取首节点 <公开 静态 类型 = XML节点类 注释 = "取第一个节点" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data().first_child())
    }

    方法 取尾节点 <公开 静态 类型 = XML节点类 注释 = "取最后一个节点" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ @dt<XML节点类>(@<所操作的本对象>.data().last_child())
    }

    方法 取下一个节点 <公开 静态 类型 = XML节点类 注释 = "取下一个节点" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data().next_sibling() )
    }

    方法 取上一个节点 <公开 类型 = XML节点类 注释 = "取上一个节点" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data().previous_sibling() )
    }

    # @begin
    # <> <include>
    #  #define pugui_for(pugui_node_recv_data,this_member_data) \
    #  for (pugui_node_recv_data.data() = this_member_data.first_child(); pugui_node_recv_data.data(); pugui_node_recv_data.data() =  pugui_node_recv_data.data().next_sibling())
    # <> </include>
    # @end

    方法 枚举子节点 <公开 静态 注释 = "可枚举所有子节点,通过本方法的子语句体可取出子节点." @嵌入式方法 = "name = XML_node_for\nhas_loop_body = true">
    参数 所操作的本对象 <类型 = XML节点基础类>
    参数 用来保存节点值 <类型 = XML节点类 注释 = "循环一次则更新一次本参数值">
    {
        @ pugui_for(@<用来保存节点值>,@<所操作的本对象>.data())
    }

    # @begin
    # <> <include>
    #  #define pugui_for_attribute(pugui_attribute_recv_data,this_node_data) \
    #  for (pugui_attribute_recv_data.data() = this_node_data.first_attribute(); pugui_attribute_recv_data.data(); pugui_attribute_recv_data.data() =  pugui_attribute_recv_data.data().next_attribute())
    # <> </include>
    # @end

    方法 枚举属性 <公开 静态 注释 = "可枚举所有属性,通过本方法的子语句体可取出属性." @嵌入式方法 = "name = XML_attribute_for\nhas_loop_body = true">
    参数 所操作的本对象 <类型 = XML节点基础类>
    参数 用来保存属性值 <类型 = XML属性类 注释 = "循环一次则更新一次本参数值">
    {
        @ pugui_for_attribute(@<用来保存属性值>,@<所操作的本对象>.data())
    }

    方法 从名称取下一节点 <公开 静态 类型 = XML节点类 注释 = "从指定节点名称取出下一个节点,本方法只能用做元素节点的操作." @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    参数 节点名称 <类型 = 文本型 注释 = "提供节点名称">
    {
        @ @dt<XML节点类>( @<所操作的本对象>.data().next_sibling(@<节点名称>) )
    }

    方法 从名称取上一节点 <公开 静态 类型 = XML节点类 注释 = "从指定节点名称取出上一节点,本方法只能用做元素节点的操作." @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML节点基础类>
    参数 节点名称 <类型 = 文本型 注释 = "提供节点名称">
    {
