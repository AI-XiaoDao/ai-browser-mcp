    }
}

类 XML合成器类 <公开 注释 = "可以快速进行xml合成操作">
{
    变量 文档 <类型 = XML文档类>
    变量 根节点 <类型 = XML节点类>

    方法 开始节点 <公开 注释 = "本方法开始定义一个XML根节点">
    参数 名称 <类型 = 文本型 注释 = "提供欲开始节点的名称">
    {
        根节点 = 文档.添加节点到尾部 (名称)
    }

    变量 同级节点 <类型 = XML节点类>

    方法 添加同级节点 <公开 注释 = "添加同级节点,必须保证\"开始节点\"方法被调用过.">
    参数 名称 <类型 = 文本型 注释 = "提供欲开始节点的名称">
    {
        同级节点 = 根节点.添加节点到尾部 (名称)
    }

    方法 置同级节点内容 <公开 注释 = "本方法为当前节点设置内容,必须保证\"开始节点\"方法被调用过.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲设置节点的内容.">
    {
        同级节点.取元素节点值 ().置入文本值 (内容)
    }

    方法 置同级节点属性 <公开 注释 = "本方法为当前子节点添加一个属性,必须保证\"开始节点\"方法被调用过.">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲添加属性的名称.">
    参数 属性内容 <类型 = 文本型 注释 = "提供所欲添加属性的内容.">
    {
        同级节点.添加属性到尾部 (属性名).置入文本值 (属性内容)
    }

    方法 添加子节点 <公开 注释 = "本方法开始添加一个子节点,必须保证\"开始节点\"方法被调用过.">
    参数 名称 <类型 = 文本型 注释 = "提供欲开始节点的名称">
    {
        根节点 = 根节点.添加节点到尾部 (名称)
    }

    方法 添加节点属性 <公开 注释 = "本方法为当前子节点添加一个属性,必须保证\"开始节点\"方法被调用过.">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲添加属性的名称.">
    参数 属性内容 <类型 = 文本型 注释 = "提供所欲添加属性的内容.">
    {
        根节点.添加属性到尾部 (属性名).置入文本值 (属性内容)
    }

    方法 置节点内容 <公开 注释 = "本方法为当前子节点设置内容,必须保证\"开始节点\"方法被调用过.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲设置节点的内容.">
    {
        根节点.取元素节点值 ().置入文本值 (内容)
    }

    方法 添加注释 <公开 注释 = "本方法在当前位置添加注释,必须保证\"开始节点\"方法被调用过.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲添加的注释内容.">
    {
        根节点.添加指定类型节点到尾部 (XML节点类型.注释).置数据节点值 (内容)
    }

    方法 导出XML文档 <公开 类型 = 文本型 注释 = "本方法用于将已编写的XML文档数据导出为文本.">
    {
        返回 (文档.到文本 ())
    }
}
