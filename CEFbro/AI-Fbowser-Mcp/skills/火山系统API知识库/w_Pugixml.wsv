类 XML文档类 <公开 基础类 = XML节点基础类 注释 = "用于XML文档操作">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (pugi::xml_document)

    方法 从资源创建 <公开 类型 = 逻辑型 注释 = "从文件资源创建XML文档对象" 返回值注释 = "成功返回真">
    参数 资源名称 <类型 = 视窗文件资源 注释 = "提供要创建的文件资源">
    {
        变量 数据 <类型 = 字节集类>
        文件资源到字节集 (资源名称, 数据)
        返回 (从字节集创建 (数据))
    }

    方法 从文件创建 <公开 类型 = 逻辑型 注释 = "从文件创建XML文档对象" 返回值注释 = "成功返回真">
    参数 文件名称 <类型 = 文本型 注释 = "提供文件路径">
    {
        @ pugi::xml_parse_result result = data().load_file(@<文件名称>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER  + (@an<CVolString> (@<文件名称>)) + _T ("  ") + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)
    }

    方法 从文本创建 <公开 类型 = 逻辑型 注释 = "从文本创建XML文档对象" 返回值注释 = "成功返回真">
    参数 文件内容 <类型 = 文本型 注释 = "提供XML文档内容">
    {
        @ pugi::xml_parse_result result = data().load_string(@<文件内容>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER +@an<CVolString>(_T("pugi文档从 文本加载  ")) + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)
    }

    方法 从内存创建 <公开 类型 = 逻辑型 注释 = "从内存创建XML文档对象" 返回值注释 = "成功返回真">
    参数 内存指针 <类型 = 变整数 注释 = "提供内存指针">
    参数 内存数据大小 <类型 = 变整数 注释 = "提供内存数据大小">
    {
        @ pugi::xml_parse_result result = data().load_buffer((void*)@<内存指针>,@<内存数据大小>);
        @ if(!result)
        @ { 
        @     DEBUG_PRINT ((_T_VOL_DEBUG_OUT_STRING_LEADER  + @an<CVolString>(_T("pugi文档从从内存加载  ")) + @an<CVolString> (result.description()) ).GetText ());
        @     return false;
        @ }
        返回 (真)
    }

    方法 从字节集创建 <公开 类型 = 逻辑型 注释 = "从字节集创建XML文档对象" 返回值注释 = "成功返回真" @禁止流程检查 = 真>
    参数 字节集数据 <类型 = 字节集类 注释 = "提供XML文档字节集数据">
    {
        @ return @<从内存创建>((@dt<变整数>)@<字节集数据>.GetPtr(),@<字节集数据>.GetSize());
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将当前XML文档转换成文本显示.">
    {
        返回 (UTF8到文本 (到字节集 ()))
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把节点转换成字节集" 返回值注释 = "返回字节集" @禁止流程检查 = 真>
    参数 缩进 <类型 = 文本型 注释 = "提供缩进文本" @默认值 = "\t">
    {
        @ class CBuffer_Writer: public pugi::xml_writer
        @ {
        @ public: 
        @     virtual void write(const void* data, size_t size) 
        @     {
        @         buf.Append ((void*)data,(int)size);
        @     }
        @     @dt<字节集类>& data()
        @     {
        @         return buf;
        @     }
        @     @dt<字节集类> buf;
        @ };
        @ CBuffer_Writer bufWriter;
        @ data().print(bufWriter,@<缩进>);
        @ return bufWriter.data();
    }

    方法 保存到文件 <公开 静态 注释 = "将当前文档对象保存到指定文件中" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML文档类>
    参数 文件名 <类型 = 文本型 注释 = "提供文件路径">
    {
        @ @<所操作的本对象>.data().save_file(@<文件名>)
    }

    方法 枚举所有节点 <公开 静态 注释 = "本方法用于枚举所有节点" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML文档类>
    参数 事件接收器 <类型 = XML枚举事件接收器 注释 = "提供接收器对象">
    {
        @ @<所操作的本对象>.data().traverse(@<事件接收器>);
    }

    方法 取节点 <公开 类型 = XML节点类 注释 = "通过指定路径取出节点对象" 返回值注释 = "返回节点对象" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @ pugi::xpath_node build_tool = data().select_node(@<路径文本>);
        @ return @dt<XML节点类>( build_tool.node());
    }

    方法 取路径属性 <公开 类型 = XML属性类 注释 = "通过指定路径取出属性对象" 返回值注释 = "返回属性对象" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @ pugi::xpath_node build_tool = data().select_node(@<路径文本>);
        @ return @dt<XML属性类>( build_tool.attribute());
    }

    方法 取节点集 <公开 静态 类型 = XML节点集 注释 = "用于查询一系列结果集" 返回值注释 = "返回节点集对象" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = XML文档类>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @ @dt<XML节点集>( @<所操作的本对象>.data().select_nodes(@<路径文本>) )
    }

    方法 取整数值 <公开 类型 = 整数 注释 = "通过指定路径取出整数值" 返回值注释 = "返回整数值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return _ttoi( xnode.node().text().as_string() );
        @  }else
        @  {
        @   return _ttoi( xnode.attribute().as_string() );
        @  }
    }

    方法 取长整数值 <公开 类型 = 长整数 注释 = "通过指定路径取出长整数值" 返回值注释 = "返回长整数值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return _ttoi64( xnode.node().text().as_string() );
        @  }else
        @  {
        @   return _ttoi64( xnode.attribute().as_string() );
        @  }
    }

    方法 取文本值 <公开 类型 = 文本型 注释 = "通过指定路径取出文本值,可取出节点值或者属性值." 返回值注释 = "返回文本值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return @an<CVolString>( xnode.node().text().as_string() );
        @  }else
        @  {
        @   return @an<CVolString>( xnode.attribute().as_string() );
        @  }
    }

    方法 取逻辑值 <公开 类型 = 逻辑型 注释 = "通过指定路径取出逻辑值" 返回值注释 = "返回逻辑值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
        @  if (!xnode.attribute())
        @  {
        @   return xnode.node().text().as_bool();
        @  }else
        @  {
        @   return xnode.attribute().as_bool();
        @  }
    }

    方法 取小数值 <公开 类型 = 小数 注释 = "通过指定路径取出小数值" 返回值注释 = "返回小数值" @禁止流程检查 = 真>
    参数 路径文本 <类型 = 文本型 注释 = "提供XPath路径表达式">
    {
        @  pugi::xpath_node xnode = data().select_node(@<路径文本>);
