包 火山视窗.XML操作 <注释 = "本模块封装自pugi开源库,开源地址:https://github.com/zeux/pugixml" @视窗.预定义宏 = "PUGIXML_WCHAR_MODE"
        @视窗.外部头文件 = "..\\..\\shared\\extern_lib\\common\\pugixml\\1\\pugixml.hpp"
