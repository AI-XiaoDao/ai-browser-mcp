    参数 最低事件值 <类型 = 整数 注释 = "常用事件常量值.*,设置响应信息范围最低事件值. 使用常量\"常用事件常量值.最低事件值\"可以指定可能的最小事件值.">
    参数 最高事件值 <类型 = 整数 注释 = "常用事件常量值.*,设置响应信息范围最高事件值. 使用常量\"常用事件常量值.最高事件值\"可以指定可能的最小事件值.">
    参数 函数DLL句柄 <类型 = 变整数 注释 = "当\"事件标志值\"为\"挂钩DLL\"时,提供 DLL 句柄,其他标志时必须为0." @默认值 = 0>
    参数 事件进程ID <类型 = 整数 注释 = "指定挂钩函数从中接收事件的进程的 ID. 指定为0,以从当前桌面上的所有进程接收事件." @默认值 = 0>
    参数 事件线程ID <类型 = 整数 注释 = "指定挂钩函数从中接收事件的线程的 ID. 如果此参数为0,则挂钩函数与当前桌面上的所有现有线程相关联." @默认值 = 0>
    参数 事件标志值 <类型 = 事件标志值 注释 = "事件标志值" @默认值 = 事件标志值.跨进程异步>
    {
        @ @<当前类指针>=((INT_P)this);
        @ return (INT_P)SetWinEventHook((DWORD)@<最低事件值> , (DWORD)@<最高事件值> , (HMODULE)@<函数DLL句柄>, OnCallbackEvent, (DWORD)@<事件进程ID>, (DWORD)@<事件线程ID>, (DWORD)@<事件标志值> );
    }

    方法 卸载全局事件钩子 <公开 注释 = "卸载全局事件钩子">
    参数 事件钩子句柄 <类型 = 变整数 注释 = "安装全局事件钩子返回的句柄">
    {
        @ if (@<事件钩子句柄> != 0)  UnhookWinEvent((HWINEVENTHOOK)@<事件钩子句柄>);
    }

    方法 拦截到全局事件消息 <公开 定义事件 类型 = 整数 注释 = "安装全局事件钩子触发的事件" "">
    参数 事件钩子句柄 <类型 = 变整数 注释 = "事件挂钩函数的句柄.\"安装事件钩子\"时的返回此值,区分事件钩子的每个实例.">
    参数 事件值 <类型 = 整数 注释 = "常用事件常量值.*">
    参数 窗口句柄 <类型 = 变整数 注释 = "对生成事件的窗口的句柄.如果没有与事件关联的窗口,则为0.">
    参数 对象标识 <类型 = 整数 注释 = "标识与事件关联的对象. 对象标识符之一或自定义对象ID.">
    参数 子对象标识 <类型 = 整数 注释 = "标识事件是由对象还是对象的子元素触发. 如果此值为0,则事件由对象触发;否则,此值是触发事件的元素的子ID.">
    参数 线程ID <类型 = 整数 注释 = "线程ID">
    参数 响应时间 <类型 = 整数 注释 = "指定生成事件的时间（以毫秒为单位）">

    方法 拦截到窗口消息 <公开 定义事件 类型 = 整数 注释 = "安装窗口消息钩子触发的事件." 返回值注释 = "  返回0表示将该消息向后继续传递到该窗口的原处理函数,返回1表示将该消息"
            返回值注释 = "拦截不再进行后续处理,返回-1表示将该消息传递到Windows系统默认窗口消息" 返回值注释 = "处理函数而不是该窗口的原处理函数." "">
    参数 窗口句柄 <类型 = 变整数 注释 = "消息所对应的窗口句柄值">
    参数 消息值 <类型 = 整数 注释 = "消息ID值">
    参数 参数一 <类型 = 变整数 注释 = "消息所携带参数一">
    参数 参数二 <类型 = 变整数 注释 = "消息所携带参数二">

    方法 拦截到鼠标消息 <公开 定义事件 类型 = 整数 注释 = "安装全局鼠标钩子触发的事件" 返回值注释 = "返回0表示将该消息向后继续传递,返回1表示将该消息拦截不再进行后续处理." "">
    参数 消息值 <类型 = 整数 注释 = "请参考\"常用窗口消息\"中的鼠标标志,如\"常用窗口消息.鼠标左键按下\".">
    参数 横向坐标 <类型 = 整数 注释 = "鼠标当前横向坐标">
    参数 纵向坐标 <类型 = 整数 注释 = "鼠标当前横向坐标">
    参数 鼠标数据 <类型 = 整数 注释 = "区分鼠标X键1或鼠标X键2,滑轮滚动向上或向下等的鼠标数据.">

    方法 拦截到键盘消息 <公开 定义事件 类型 = 整数 注释 = "安装全局键盘钩子触发的事件" 返回值注释 = "返回0表示将该消息向后继续传递,返回1表示将该消息拦截不再进行后续处理." "">
    参数 消息值 <类型 = 整数 注释 = "请参考\"常用窗口消息\"中的键盘标志,如\"常用窗口消息.键盘按键按下\".">
    参数 火山按键码 <类型 = 整数 注释 = "提供按键的火山按键代码值(为\"扩展按键码\"类中的常量值)">
    参数 虚拟键代码 <类型 = 整数 注释 = "提供按键的虚拟键代码">
    参数 按键扫描码 <类型 = 整数 注释 = "提供按键的对应硬件扫描码">
    参数 击键信息 <类型 = 整数 注释 = "指定击键关联的信息">

    方法 安装窗口消息钩子 <公开 类型 = 逻辑型 注释 = "针对所指定窗口安装消息钩子,成功返回真,失败返回假.支持单窗口多消息." 注释 = "注意: 一个本类对象只能截获一个窗口的消息,如欲同时截获多个窗口,请使用多个本类对象."
            @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "要安装钩子的窗口句柄,支持外部窗口.">
    {
        @ return data().HookWindowsHookEx((HWND)@<窗口句柄>,OnMsgCallbackEvent,(UINT_P)this);
    }

    方法 卸载窗口消息钩子 <公开 注释 = "卸载先前所安装的窗口消息钩子" @嵌入式方法 = "">
    {
        @ @sn<this>.data().UnHookWindowsHookEx()
    }

    方法 添加窗口过滤消息 <公开 注释 = "根据消息标识添加拦截过滤,多次添加可拦截的多个消息.只触发过滤器中消息.如无过滤器消息将触发全部消息." @嵌入式方法 = "">
    参数 窗口消息ID <类型 = 整数 注释 = "\"常用窗口消息.*\"枚举了常用部分,并非全部.">
    {
        @ @sn<this>.data().AddWindowsHookEx((DWORD)@<窗口消息ID>)
    }

    方法 删除窗口过滤消息 <公开 注释 = "根据所指定的消息ID值删除拦截消息" @嵌入式方法 = "">
    参数 窗口消息ID <类型 = 整数 注释 = "\"常用窗口消息.*\"枚举了常用部分,并非全部.">
    {
        @ @sn<this>.data().RemoveWindowsHookEx((DWORD)@<窗口消息ID>)
    }

    方法 清空窗口过滤消息 <公开 注释 = "清空过滤器中所有消息标识,清空后,由于失去过滤,将触发全部消息." @嵌入式方法 = "">
    {
        @ @sn<this>.data().ClearWindowsHookEx()
    }

    方法 安装全局键盘钩子 <公开 类型 = 逻辑型 注释 = "安装键盘全局钩子" @禁止流程检查 = 真>
    {
        @ return data().AddKeyboardWinHookEx(OnKeyboCallbackEvent,(UINT_P)this);
    }

    方法 卸载全局键盘钩子 <公开 注释 = "卸载键盘全局钩子" @嵌入式方法 = "">
    {
        @ @sn<this>.data().RemoveKeyboardWinHookEx()
    }

    方法 安装全局鼠标钩子 <公开 类型 = 逻辑型 注释 = "安装鼠标全局钩子" @禁止流程检查 = 真>
    {
        @ return data().AddMouseWinHookEx(OnMouseCallbackEvent,(UINT_P)this);
    }

    方法 卸载全局鼠标钩子 <公开 注释 = "卸载鼠标全局钩子" @嵌入式方法 = "">
    {
        @ @sn<this>.data().RemoveMouseWinHookEx()
    }
}
