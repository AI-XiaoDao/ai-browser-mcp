类 APIHOOK执行结果 <公开 注释 = "调用apiHook方法时的返回值." 注释 = "用于判断执行状态." @文档 = "category = \"辅助类\"">
{
    常量 未知错误 <公开 类型 = 整数 值 = @MH_UNKNOWN 注释 = "未知错误">
    常量 成功 <公开 类型 = 整数 值 = @MH_OK 注释 = "成功">
    常量 已经初始化 <公开 类型 = 整数 值 = @MH_ERROR_ALREADY_INITIALIZED 注释 = "已经初始化,尝试再次初始化时返回该值.">
    常量 尚未初始化 <公开 类型 = 整数 值 = @MH_ERROR_NOT_INITIALIZED 注释 = "尚未初始化">
    常量 钩子已被创建 <公开 类型 = 整数 值 = @MH_ERROR_ALREADY_CREATED 注释 = "目标函数钩子已被创建">
    常量 钩子尚未创建 <公开 类型 = 整数 值 = @MH_ERROR_NOT_CREATED 注释 = "尚未创建指定目标函数的钩子">
    常量 钩子已被启用 <公开 类型 = 整数 值 = @MH_ERROR_ENABLED 注释 = "钩子已被启用">
    常量 钩子启用失败 <公开 类型 = 整数 值 = @MH_ERROR_DISABLED 注释 = "钩子启用失败">
    常量 无效指针 <公开 类型 = 整数 值 = @MH_ERROR_NOT_EXECUTABLE 注释 = "指针无效">
    常量 连接函数失败 <公开 类型 = 整数 值 = @MH_ERROR_UNSUPPORTED_FUNCTION 注释 = "无法连接到指定的目标函数">
    常量 无法分配内存 <公开 类型 = 整数 值 = @MH_ERROR_MEMORY_ALLOC 注释 = "无法分配内存">
    常量 更改保护失败 <公开 类型 = 整数 值 = @MH_ERROR_MEMORY_PROTECT 注释 = "未能更改内存保护">
    常量 未知模块 <公开 类型 = 整数 值 = @MH_ERROR_MODULE_NOT_FOUND 注释 = "没找到模块">
    常量 未知函数 <公开 类型 = 整数 值 = @MH_ERROR_FUNCTION_NOT_FOUND 注释 = "没找到函数">
}

类 常用窗口消息 <公开 注释 = "枚举了一些常用窗口消息ID值" @文档 = "category = \"辅助类\"">
{
    常量 创建 <公开 类型 = 整数 值 = @WM_CREATE 注释 = "创建窗口" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 销毁 <公开 类型 = 整数 值 = @WM_DESTROY 注释 = "窗口正被销毁" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 移动 <公开 类型 = 整数 值 = @WM_MOVE 注释 = "窗口被移动" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 尺寸改变 <公开 类型 = 整数 值 = @WM_SIZE 注释 = "窗口尺寸被改变" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 尺寸改变中 <公开 类型 = 整数 值 = @WM_SIZING 注释 = "窗口正在调整大小">
    常量 正在激活 <公开 类型 = 整数 值 = @WM_ACTIVATEAPP 注释 = "指示窗口是激活还是已停用" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 模式取消 <公开 类型 = 整数 值 = @WM_CANCELMODE 注释 = "发送到取消某些模式,例如鼠标反捕获." 编辑时信息 = "0, C6A9E, 0, 0">
    常量 子窗口激活 <公开 类型 = 整数 值 = @WM_CHILDACTIVATE 注释 = "子窗口被激活" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 关闭 <公开 类型 = 整数 值 = @WM_CLOSE 注释 = "发送为窗口或应用程序应终止的信号" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 系统内存不足 <公开 类型 = 整数 值 = @WM_COMPACTING 注释 = "当系统检测到超过30秒到60秒间隔的系统时间超过12.5%时,发送到所有顶级窗口.这表示系统内存较低."
            编辑时信息 = "0, C6A9E, 0, 0">
    常量 启用状态 <公开 类型 = 整数 值 = @WM_ENABLE 注释 = "当应用程序更改窗口的启用状态时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 进入改变尺寸 <公开 类型 = 整数 值 = @WM_ENTERSIZEMOVE 注释 = "在窗口进入移动或调整大小时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 退出改变尺寸 <公开 类型 = 整数 值 = @WM_EXITSIZEMOVE 注释 = "在窗口退出移动或调整大小后发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 取缩略图 <公开 类型 = 整数 值 = @WM_GETICON 注释 = "检索与窗口关联的大图标或小图标的句柄.当按下Alt+TAB时,对话框中显示大图标或在窗口标题中显示小图标都会触发该消息."
            编辑时信息 = "0, C6A9E, 0, 0">
    常量 最小化最大化 <公开 类型 = 整数 值 = @WM_GETMINMAXINFO 注释 = "当窗口的大小或位置即将更改时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 输入法显示 <公开 类型 = 整数 值 = @WM_INPUTLANGCHANGE 注释 = "更改应用程序输入语言时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 输入法切换 <公开 类型 = 整数 值 = @WM_INPUTLANGCHANGEREQUEST 注释 = "当用户选择新的输入语言时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 移动中 <公开 类型 = 整数 值 = @WM_MOVING 注释 = "的窗口正在移动时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 拖动图标 <公开 类型 = 整数 值 = @WM_QUERYDRAGICON 注释 = "最小化窗口被拖动时,没有为其类定义的图标.应用程序将句柄返回到图标或游标." 编辑时信息 = "0, C6A9E, 0, 0">
    常量 还原 <公开 类型 = 整数 值 = @WM_QUERYOPEN 注释 = "当用户请求将窗口还原到其以前的大小和位置时,发送图标显示." 编辑时信息 = "0, C6A9E, 0, 0">
    常量 退出程序 <公开 类型 = 整数 值 = @WM_QUIT 注释 = "指示终止应用程序的请求" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 显示 <公开 类型 = 整数 值 = @WM_SHOWWINDOW 注释 = "当窗口即将隐藏或显示时发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 样式改变 <公开 类型 = 整数 值 = @WM_STYLECHANGED 注释 = "更改窗口的一个或多个样式后发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 样式改变中 <公开 类型 = 整数 值 = @WM_STYLECHANGING 注释 = "更改窗口的一个或多个样式中" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 主题更改 <公开 类型 = 整数 值 = @WM_THEMECHANGED 注释 = "主题更改事件之后发送.主题更改事件包括主题的激活、主题停用或从一个主题过渡到另一个主题." 编辑时信息 = "0, C6A9E, 0, 0">
    常量 层次改变 <公开 类型 = 整数 值 = @WM_WINDOWPOSCHANGED 注释 = "窗口层次(Z顺序)被改变后发送" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 层次改变中 <公开 类型 = 整数 值 = @WM_WINDOWPOSCHANGING 注释 = "窗口层次(Z顺序)被改变中" 编辑时信息 = "0, C6A9E, 0, 0">
    常量 设置文本 <公开 类型 = 整数 值 = @WM_SETTEXT 注释 = "设置窗口的文本">
    常量 获取文本 <公开 类型 = 整数 值 = @WM_GETTEXT 注释 = "将对应于窗口的文本复制到调用方提供的缓冲区中">
    常量 获取菜单 <公开 类型 = 整数 值 = @MN_GETHMENU 注释 = "检索当前窗口的菜单句柄">
    常量 菜单项选择 <公开 类型 = 整数 值 = @WM_MENUSELECT 注释 = "菜单项选择">
    常量 菜单快捷键按下 <公开 类型 = 整数 值 = @WM_MENUCHAR 注释 = "菜单快捷键按下">
    常量 菜单右键抬起 <公开 类型 = 整数 值 = @WM_MENURBUTTONUP 注释 = "菜单中鼠标右键被抬起">
    常量 菜单切换 <公开 类型 = 整数 值 = @WM_NEXTMENU 注释 = "系统菜单之间切换时发送">
    常量 菜单下拉销毁 <公开 类型 = 整数 值 = @WM_UNINITMENUPOPUP 注释 = "下拉菜单或子菜单被销毁时发送">
    常量 绘制文本 <公开 类型 = 整数 值 = @WM_GETFONT 注释 = "检索控件当前正在绘制其文本的字体">
    常量 改变字体 <公开 类型 = 整数 值 = @WM_SETFONT 注释 = "设置控件在绘制文本时要使用的字体">
    常量 键盘获得焦点 <公开 类型 = 整数 值 = @WM_SETFOCUS 注释 = "在窗口获得键盘焦点后发送到窗口">
    常量 键盘失去焦点 <公开 类型 = 整数 值 = @WM_KILLFOCUS 注释 = "在窗口失去键盘焦点后发送到窗口">
    常量 键盘功能键按下 <公开 类型 = 整数 值 = @WM_SYSKEYDOWN 注释 = "当用户按下F10键(激活菜单栏)或按住Alt键,然后按另一个键时发送.">
    常量 键盘功能键放开 <公开 类型 = 整数 值 = @WM_SYSKEYUP 注释 = "功能键放开,Alt键放开.">
    常量 键盘输入字符 <公开 类型 = 整数 值 = @WM_CHAR 注释 = "输入字符">
    常量 键盘热键按下 <公开 类型 = 整数 值 = @WM_HOTKEY 注释 = "快捷键被按">
    常量 键盘按键按下 <公开 类型 = 整数 值 = @WM_KEYDOWN 注释 = "按键按下">
    常量 键盘按键抬起 <公开 类型 = 整数 值 = @WM_KEYUP 注释 = "按键抬起">
    常量 鼠标失去焦点 <公开 类型 = 整数 值 = @WM_CAPTURECHANGED 注释 = "丢失鼠标捕获">
    常量 鼠标左键双击 <公开 类型 = 整数 值 = @WM_LBUTTONDBLCLK 注释 = "双击鼠标左键时">
    常量 鼠标左键按下 <公开 类型 = 整数 值 = @WM_LBUTTONDOWN 注释 = "鼠标左键按下">
    常量 鼠标左键抬起 <公开 类型 = 整数 值 = @WM_LBUTTONUP 注释 = "鼠标左键抬起">
    常量 鼠标中键双击 <公开 类型 = 整数 值 = @WM_MBUTTONDBLCLK 注释 = "双击鼠标中间按钮">
    常量 鼠标中键按下 <公开 类型 = 整数 值 = @WM_MBUTTONDOWN 注释 = "鼠标中键按下">
    常量 鼠标中键抬起 <公开 类型 = 整数 值 = @WM_MBUTTONUP 注释 = "鼠标中键抬起">
    常量 鼠标激活 <公开 类型 = 整数 值 = @WM_MOUSEACTIVATE 注释 = "当光标处于非活动窗口中且用户按下鼠标按钮时发送">
    常量 鼠标悬停 <公开 类型 = 整数 值 = @WM_MOUSEHOVER 注释 = "鼠标悬停直到指定时间段内">
    常量 鼠标滑轮滚动 <公开 类型 = 整数 值 = @WM_MOUSEWHEEL 注释 = "鼠标滑轮滚动">
    常量 鼠标离开 <公开 类型 = 整数 值 = @WM_MOUSELEAVE 注释 = "鼠标离开">
    常量 鼠标移动 <公开 类型 = 整数 值 = @WM_MOUSEMOVE 注释 = "鼠标移动">
    常量 鼠标右键双击 <公开 类型 = 整数 值 = @WM_RBUTTONDBLCLK 注释 = "鼠标右键双击">
    常量 鼠标右键按下 <公开 类型 = 整数 值 = @WM_RBUTTONDOWN 注释 = "鼠标右键按下">
    常量 鼠标右键抬起 <公开 类型 = 整数 值 = @WM_RBUTTONUP 注释 = "鼠标右键抬起">
    常量 鼠标X键双击 <公开 类型 = 整数 值 = @WM_XBUTTONDBLCLK 注释 = "鼠标X键双击">
    常量 鼠标X键按下 <公开 类型 = 整数 值 = @WM_XBUTTONDOWN 注释 = "鼠标X键按下">
    常量 鼠标X键抬起 <公开 类型 = 整数 值 = @WM_XBUTTONUP 注释 = "鼠标X键抬起">
}

类 系统键鼠操作类 <公开 注释 = "提供键盘按键及鼠标模拟操作" @文档 = "category = \"键盘鼠标输入模拟\"">
{

    #  @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CWinKeyboardOperateModule)

    方法 绑定窗口 <公开 属性写 注释 = "设置操作将指向被绑定窗口,鼠标操作时,如超过窗口范围,将被定位到窗口边缘.">
    参数 窗口句柄 <类型 = 变整数 注释 = "要被绑定的窗口句柄.为0时,则表示取消绑定窗口." @默认值 = 0>
    {
        @ data().hStatusWnd=(HWND)@<窗口句柄>;
    }

    方法 绑定窗口 <公开 属性读 类型 = 变整数 注释 = "返回被绑定的窗口句柄." @禁止流程检查 = 真>
    {
        @  return (INT_P)data().hStatusWnd;
    }

    方法 后台模式 <公开 属性写 注释 = "设置键鼠操作前后台模式">
    参数 所欲设置的值 <类型 = 逻辑型 注释 = "默认为假,表示窗口置于屏幕前台操作模式." 注释 = "如果为真,表示向绑定窗口发送操作信息的模式." @默认值 = 假>
    {
        @ data ().backstageModel=@<所欲设置的值>;
    }

    方法 后台模式 <公开 属性读 类型 = 逻辑型 注释 = "返回键鼠操作前后台模式" @禁止流程检查 = 真>
    {
        @ return data().backstageModel;
    }

    方法 位置定位方式 <公开 属性写 注释 = "设置鼠标前台操作时,位置是绝对位置或相对位置.绑定窗口后,忽略该属性.">
    参数 所欲设置的值 <类型 = 逻辑型 注释 = "默认为真,表示指定坐标为屏幕绝对位置.如果为假,则指定以当前鼠标坐标为基准的相对位置.">
    {
        @ data().absolute=@<所欲设置的值>;
    }

    方法 位置定位方式 <公开 属性读 类型 = 逻辑型 注释 = "返回鼠标操作时,位置是绝对位置或相对位置." @禁止流程检查 = 真>
    {
        @ return data().absolute;
    }

    方法 置组合键 <公开 注释 = "设置键鼠操作时,是否附加Ctrl键及Shift键等功能键.">
    参数 Ctrl键 <类型 = 逻辑型 注释 = "如果为真,表示附加Ctrl键.如果为假,表示取消附加Ctrl键.键盘鼠标有效." @默认值 = 假>
    参数 Shift键 <类型 = 逻辑型 注释 = "如果为真,表示附加Shift键.如果为假,表示取消附加Shift键.键盘鼠标有效." @默认值 = 假>
    参数 Atl键 <类型 = 逻辑型 注释 = "如果为真,表示附加Atl键.如果为假,表示取消附加Atl键.键盘有效." @默认值 = 假>
    {
        变量 局_位或值 <类型 = 整数 值 = 0>
        局_位或值 = 位或 (局_位或值, 选择 (Ctrl键, 8, 0))
        局_位或值 = 位或 (局_位或值, 选择 (Shift键, 4, 0))
        局_位或值 = 位或 (局_位或值, 选择 (Atl键, 32, 0))
        @ data().groupKey=@<局_位或值>;
    }

    方法 取按键状态 <公开 静态 类型 = 逻辑型 注释 = "用来判断函数调用时指定按键的状态.如键被按下,则返回真,否则返回假." @禁止流程检查 = 真>
    参数 键鼠按键码 <类型 = 整数 注释 = "扩展按键码.*" "">
    {
        @ return ((GetAsyncKeyState(@<键鼠按键码>) & 0x01)==1);
    }

    方法 取按键开关状态 <公开 静态 类型 = 逻辑型 注释 = "取上一次按键状态.函数可实现按键逻辑开关状态获取.如获取大小写开关状态." 返回值注释 = "返回1" @禁止流程检查 = 真>
    参数 键盘按键 <类型 = 整数 注释 = "扩展按键码.*" "">
    {
        @ return ((GetKeyState(@<键盘按键>) & 0x01)==1);
    }

    方法 取鼠标移动速度 <公开 静态 类型 = 整数 注释 = "返回当前鼠标速度快慢,范围为:1-20." @禁止流程检查 = 真>
    {
        @ int dwMouseSpeed = 0;
        @ SystemParametersInfo(SPI_GETMOUSESPEED, 0, &dwMouseSpeed, 0);
        @ return dwMouseSpeed;
    }

    方法 置鼠标移动速度 <公开 静态 类型 = 逻辑型 注释 = "设置当前鼠标速度快慢" @禁止流程检查 = 真>
    参数 所欲设置的值 <类型 = 整数 注释 = "范围为:1-20.">
    {
        @ return SystemParametersInfo(SPI_SETMOUSESPEED, 0, (PVOID)NUM_EXTENTS(@<所欲设置的值>,1,20), SPIF_UPDATEINIFILE | SPIF_SENDCHANGE);
    }

    方法 取鼠标双击速度 <公开 静态 类型 = 整数 注释 = "返回鼠标双击速度" @禁止流程检查 = 真>
    {
        @ return GetDoubleClickTime();
    }

    方法 置鼠标双击速度 <公开 静态 类型 = 逻辑型 注释 = "设置鼠标双击速度" @禁止流程检查 = 真>
    参数 所欲设置的值 <类型 = 整数 注释 = "单位:毫秒,范围为:0-5000.如果此参数设置为0,系统将使用默认的双击时间500毫秒.如果此参数值大于5000毫秒,则系统会将该值设置为5000毫秒.">
    {
        @ return SetDoubleClickTime(NUM_EXTENTS(@<所欲设置的值>,0,5000));
    }

    方法 置按键焦点 <公开 静态 类型 = 变整数 注释 = "为窗口设置键盘按键焦点,成功返回被设置焦点的窗口句柄,失败返回0,如窗口句柄无效、窗口处于禁用状态等." 返回值注释 = "成功返回绑定窗口的句柄" @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "要设置焦点的窗口句柄" "">
    {
        @ CWinKeyboardOperateModule::SetKeyboardFocus((HWND)@<窗口句柄>)
    }

    方法 鼠标捕获 <公开 静态 类型 = 变整数 注释 = "将鼠标捕获设置为属于当前线程指定的窗口." 注释 = "一旦窗口捕获了鼠标,所有鼠标输入都针对该窗口,无论光标是否在窗口的边界内." 注释 = "同一时刻只能有一个窗口捕获鼠标."
            注释 = "如果鼠标光标在另一个线程创建的窗口上,只有当鼠标键按下时系统才将鼠标输入指向指定的窗口." 返回值注释 = "成功返回绑定窗口的句柄" @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "要设置焦点的窗口句柄" "">
    参数 开启 <类型 = 逻辑型 注释 = "如果为真,表示开启鼠标捕获,反而,则表示释放鼠标捕获." @默认值 = 真>
    {
        @ CWinKeyboardOperateModule::SetMouseCapture((HWND)@<窗口句柄>,@<开启>)
    }

    方法 发送文本 <公开 静态 注释 = "将编辑控件中的选定文本或丰富的编辑控件替换为指定的文本" @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "要将文本发送到的窗口句柄" "">
    参数 要发送内容 <类型 = 文本型 注释 = "要发送文本内容" "">
    {
        @ SendMessage((HWND)@<窗口句柄>,EM_REPLACESEL,1,(LPARAM)@<要发送内容>.GetText())
    }

    方法 置键鼠输入状态 <公开 静态 类型 = 逻辑型 注释 = "启用或禁用指定窗口或控件的鼠标和键盘按键输入.禁用输入后,窗口不会接收输入,如鼠标单击和按键.启用输入后,窗口将接收所有输入." @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "要设置焦点的窗口句柄" @默认值 = 0>
    参数 是否禁止 <类型 = 逻辑型 注释 = "开启或禁止" "">
    {
        @ return EnableWindow((HWND)@<窗口句柄>,@<是否禁止>);
    }

    方法 取键鼠输入状态 <公开 静态 类型 = 逻辑型 注释 = "返回指定的窗口是否启用鼠标和键盘按键输入" @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "要设置焦点的窗口句柄" @默认值 = 0>
    {
        @ return IsWindowEnabled((HWND)@<窗口句柄>);
    }

    方法 延时 <公开 静态 类型 = 逻辑型 注释 = "异步延时,退出程序前,需等待延时结束." @嵌入式方法 = "">
    参数 欲等待的时间 <类型 = 长整数 注释 = "单位:毫秒.">
    {
        @ CWinKeyboardOperateModule::asyncDelay(@<欲等待的时间>);
    }

    方法 鼠标滚动 <公开 类型 = 逻辑型 注释 = "模拟鼠标滑轮滚动,如模式为后台并绑定窗口,则为向窗口发送鼠标滑轮滚动动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 滚动方向 <类型 = 整数 注释 = "0为向上滚动,1为向下滚动.">
    {
        @ @sn<this>.data().MouseUpDownClick(0, 0, 0, NUM_EXTENTS(@<滚动方向> + 4,4,5));
    }

    方法 鼠标移动 <公开 类型 = 逻辑型 注释 = "模拟鼠标移动,如模式为后台并绑定窗口,则为向窗口发送鼠标移动动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 横向坐标 <类型 = 整数 注释 = "指定水平方向的绝对位置或相对位置">
    参数 纵向坐标 <类型 = 整数 注释 = "指定垂直方向的绝对位置或相对位置">
    {
        @ @sn<this>.data().MouseMove(@<横向坐标>,@<纵向坐标>)
    }

    方法 鼠标按下 <公开 类型 = 逻辑型 注释 = "模拟鼠标按下,如模式为后台并绑定窗口,则为向窗口发送鼠标按下动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 鼠标按键 <类型 = 鼠标按键类型 注释 = "按下的鼠标键" @默认值 = 鼠标按键类型.左键>
    参数 横向坐标 <类型 = 整数 注释 = "指定水平方向的绝对位置或相对位置.后台绑定窗口模式下有效,否则,忽略该参数." @默认值 = 0>
    参数 纵向坐标 <类型 = 整数 注释 = "指定垂直方向的绝对位置或相对位置.后台绑定窗口模式下有效,否则,忽略该参数." @默认值 = 0>
    {
        @ @sn<this>.data().MouseUpDownClick(@<鼠标按键>,@<横向坐标>,@<纵向坐标>,0)
    }

    方法 鼠标抬起 <公开 类型 = 逻辑型 注释 = "模拟鼠标抬起,如模式为后台并绑定窗口,则为向窗口发送鼠标抬起动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 鼠标按键 <类型 = 鼠标按键类型 注释 = "按下的鼠标键" @默认值 = 鼠标按键类型.左键>
    参数 横向坐标 <类型 = 整数 注释 = "指定水平方向的绝对位置或相对位置.后台绑定窗口模式下有效,否则,忽略该参数." @默认值 = 0>
    参数 纵向坐标 <类型 = 整数 注释 = "指定垂直方向的绝对位置或相对位置.后台绑定窗口模式下有效,否则,忽略该参数." @默认值 = 0>
    {
        @ @sn<this>.data().MouseUpDownClick(@<鼠标按键>,@<横向坐标>,@<纵向坐标>,1)
    }

    方法 鼠标单击 <公开 类型 = 逻辑型 注释 = "模拟鼠标单击,如模式为后台并绑定窗口,则为向窗口发送鼠标单击动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 鼠标按键 <类型 = 鼠标按键类型 注释 = "按下的鼠标键" @默认值 = 鼠标按键类型.左键>
    参数 横向坐标 <类型 = 整数 注释 = "后台绑定窗口模式下,指定对窗口发送点击信息的横向坐标位置,否则,忽略该参数." @默认值 = 0>
    参数 纵向坐标 <类型 = 整数 注释 = "后台绑定窗口模式下,指定对窗口发送点击信息的纵向坐标位置,否则,忽略该参数." @默认值 = 0>
    {
        @ @sn<this>.data().MouseUpDownClick(@<鼠标按键>,@<横向坐标>,@<纵向坐标>,2)
    }

    方法 鼠标双击 <公开 类型 = 逻辑型 注释 = "模拟鼠标双击,如模式为后台并绑定窗口,则为向窗口发送鼠标双击动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 鼠标按键 <类型 = 鼠标按键类型 注释 = "按下的鼠标键" @默认值 = 鼠标按键类型.左键>
    参数 横向坐标 <类型 = 整数 注释 = "后台绑定窗口模式下,指定对窗口发送点击信息的横向坐标位置,否则,忽略该参数." @默认值 = 0>
    参数 纵向坐标 <类型 = 整数 注释 = "后台绑定窗口模式下,指定对窗口发送点击信息的纵向坐标位置,否则,忽略该参数." @默认值 = 0>
    {
        @ @sn<this>.data().MouseUpDownClick(@<鼠标按键>,@<横向坐标>,@<纵向坐标>,3)
    }

    方法 键盘按下 <公开 类型 = 逻辑型 注释 = "模拟键盘按键按下,如模式为后台并绑定窗口,则为向窗口发送键盘按键按下动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 键盘按键 <类型 = 整数 注释 = "扩展按键码.*.键盘按键的按键码." "">
    参数 功能键 <类型 = 逻辑型 注释 = "默认为假,表示普通击键,如果为真,则表示功能键,可用于热键技能不输入字符.如果为功能键,请保持按下抬起一置." 注释 = "当组合键不为空时,作为功能键使用,忽略该参数." @默认值 = 假>
    {
        @ @sn<this>.data().KeyboardUpDownClickChar(@<键盘按键>,0,@<功能键>)
    }

    方法 键盘抬起 <公开 类型 = 逻辑型 注释 = "模拟键盘按键抬起,如模式为后台并绑定窗口,则为向窗口发送键盘按键抬起动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 键盘按键 <类型 = 整数 注释 = "扩展按键码.*.键盘按键的按键码." "">
    参数 功能键 <类型 = 逻辑型 注释 = "默认为假,表示普通击键,如果为真,则表示功能键,可用于热键技能不输入字符.如果为功能键,请保持按下抬起一置." 注释 = "当组合键不为空时,作为功能键使用,忽略该参数." @默认值 = 假>
    {
        @ @sn<this>.data().KeyboardUpDownClickChar(@<键盘按键>,1,@<功能键>)
    }

    方法 键盘单击 <公开 类型 = 逻辑型 注释 = "模拟键盘单击,如模式为后台并绑定窗口,则为向窗口发送键盘单击动作." 返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真."
            @嵌入式方法 = "">
    参数 键盘按键 <类型 = 整数 注释 = "扩展按键码.*.键盘按键的按键码." "">
    参数 功能键 <类型 = 逻辑型 注释 = "默认为假,表示普通击键,如果为真,则表示功能键,可用于热键技能不输入字符." 注释 = "当组合键不为空时,作为功能键使用,忽略该参数." @默认值 = 假>
    {
        @ @sn<this>.data().KeyboardUpDownClickChar(@<键盘按键>,2,@<功能键>)
    }

    方法 键盘输入 <公开 类型 = 逻辑型 注释 = "模拟键盘输入,如模式为后台并绑定窗口,则为向窗口发送键盘输入动作.如模式为前台等同于键盘单击."
            返回值注释 = "成功返回真,失败返回假.后台模式绑定窗口无效时,直接返回假,异步发送动作后返回真." @嵌入式方法 = "">
    参数 键盘按键 <类型 = 整数 注释 = "扩展按键码.*.键盘按键的按键码." "">
    {
        @ @sn<this>.data().KeyboardUpDownClickChar(@<键盘按键>,3,FALSE)
    }
}

类 系统CPU信息类 <公开 注释 = "提供获取单个或多个CPU硬件设备信息" @文档 = "category = \"硬件信息\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CWinCpuInfo)
    # <> <include>
    # @sn<current_class> (IEnumWbemClassObject* pAdapter) : @sn<current_class> ()  {
    #      data().m_pFirsthEnumerator = pAdapter;
    #      data().GetIWbemClassObject();
    #  }
    # <> </include>
    # @end

    方法 到下一个 <公开 类型 = 逻辑型 注释 = "用于多个CPU硬件环境,成功将指向下一个CPU,如果失败将不改变当前指向CPU." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetIWbemClassObject()
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "当前CPU名称" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("name"))
    }

    方法 描述 <公开 属性读 类型 = 文本型 注释 = "当前CPU描述" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Description"))
    }

    方法 硬件ID <公开 属性读 类型 = 文本型 注释 = "当前CPU硬件ID" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("ProcessorId"))
    }

    方法 设备ID <公开 属性读 类型 = 文本型 注释 = "当前CPU设备ID" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("DeviceID"))
    }

    方法 序列号 <公开 属性读 类型 = 文本型 注释 = "当前CPU序列号" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("SerialNumber"))
    }

    方法 制造商 <公开 属性读 类型 = 文本型 注释 = "当前CPU制造商" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Manufacturer"))
    }

    方法 插槽名称 <公开 属性读 类型 = 文本型 注释 = "当前CPU插槽名称" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("SocketDesignation"))
    }

    方法 状态 <公开 属性读 类型 = 文本型 注释 = "当前CPU状态" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Status"))
    }

    方法 核心数 <公开 属性读 类型 = 长整数 注释 = "当前CPU核心数量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("NumberOfCores"))
    }

    方法 逻辑核心数 <公开 属性读 类型 = 长整数 注释 = "当前CPU逻辑核心数量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("NumberOfLogicalProcessors"))
    }

    方法 启用核心数 <公开 属性读 类型 = 长整数 注释 = "当前CPU启用核心数" @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("NumberOfEnabledCore"))
    }

    方法 线程数 <公开 属性读 类型 = 长整数 注释 = "当前CPU每个核心的线程数." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("ThreadCount"))
    }

    方法 数据宽度 <公开 属性读 类型 = 整数 注释 = "当前CPU数据宽度" 返回值注释 = "单位:bits." @嵌入式方法 = "">
    {
        @ @sn<this>.data().IntGetHardwareInfo(_T("DataWidth"))
    }

    方法 地址宽度 <公开 属性读 类型 = 整数 注释 = "当前CPU地址宽度" 返回值注释 = "单位:bits." @嵌入式方法 = "">
    {
        @ @sn<this>.data().IntGetHardwareInfo(_T("AddressWidth"))
    }

    方法 实时时钟频率 <公开 属性读 类型 = 长整数 注释 = "当前CPU实时时钟频率" 返回值注释 = "单位:MHz." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("CurrentClockSpeed"))
    }

    方法 最大时钟频率 <公开 属性读 类型 = 长整数 注释 = "CPU最大时钟频率" 返回值注释 = "单位:MHz." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("MaxClockSpeed"))
    }

    方法 外部时钟频率 <公开 属性读 类型 = 长整数 注释 = "CPU外部时钟频率" 返回值注释 = "单位:MHz." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("ExtClock"))
    }

    方法 使用率 <公开 属性读 类型 = 整数 注释 = "当前CPU使用率,返回百分比数值." 返回值注释 = "百分比" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IntGetHardwareInfo(_T("LoadPercentage"))
    }

    方法 处理器类型 <公开 属性读 类型 = 文本型 注释 = "当前CPU处理器类型" "">
    {
        变量 局_类型 <类型 = 整数>
        @ @<局_类型>=data().IntGetHardwareInfo(_T("ProcessorType"));
        返回 (多项选择 (局_类型, "其他", "其他", "未知", "中央处理器", "数学处理器", "DSP 处理器", "视频处理器"))
    }

    方法 二级缓存 <公开 属性读 类型 = 长整数 注释 = "当前CPU二级缓存,多核心时,为所有核心二级缓存总和." 返回值注释 = "计量单位:kb." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("L2CacheSize"))
    }

    方法 二级缓存速度 <公开 属性读 类型 = 长整数 注释 = "当前CPU二级缓存速度." 返回值注释 = "计量单位:megahertz(MHz)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("L2CacheSpeed"))
    }

    方法 三级缓存 <公开 属性读 类型 = 长整数 注释 = "当前CPU三级缓存,多核心时,为所有核心三级缓存总和." 返回值注释 = "计量单位:kb." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("L3CacheSize"))
    }

    方法 三级缓存速度 <公开 属性读 类型 = 长整数 注释 = "当前CPU三级缓存速度." 返回值注释 = "计量单位:megahertz(MHz)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Int64GetHardwareInfo(_T("L3CacheSpeed"))
    }
}

类 系统硬盘信息类 <公开 注释 = "提供获取存储设备磁盘驱动器信息.包括:硬盘,U盘,移动硬盘等多个或单个设备." @文档 = "category = \"硬件信息\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CWinCpuInfo)
    # <> <include>
    # @sn<current_class> (IEnumWbemClassObject* pAdapter) : @sn<current_class> ()  {
    #      data().m_pFirsthEnumerator = pAdapter;
    #      data().GetIWbemClassObject();
    #  }
    # <> </include>
    # @end

    方法 到下一个 <公开 类型 = 逻辑型 注释 = "用于硬件有多个硬盘环境,成功将指向下一个硬盘,如果失败不改变当前指向硬盘." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetIWbemClassObject()
    }

    方法 状态 <公开 属性读 类型 = 文本型 注释 = "硬盘状态" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Status"))
    }

    方法 型号 <公开 属性读 类型 = 文本型 注释 = "硬盘型号" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Model"))
    }

    方法 序列号 <公开 属性读 类型 = 文本型 注释 = "硬盘序列号" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("SerialNumber"))
    }

    方法 制造商 <公开 属性读 类型 = 文本型 注释 = "硬盘制造商" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Manufacturer"))
    }

    方法 版本 <公开 属性读 类型 = 文本型 注释 = "硬盘版本" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Version"))
    }

    方法 描述 <公开 属性读 类型 = 文本型 注释 = "硬盘描述" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Description"))
    }

    方法 标签 <公开 属性读 类型 = 文本型 注释 = "硬盘标签" @嵌入式方法 = "">
    {
        @ @sn<this>.data().CVolStrGetHardwareInfo(_T("Caption"))
    }

