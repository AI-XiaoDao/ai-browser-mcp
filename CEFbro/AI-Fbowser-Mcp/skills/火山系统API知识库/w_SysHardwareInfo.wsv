<火山程序 类型 = "通常" 版本 = 1 />

包 火山.系统操作支持库 <注释 = "APIHOOK、键鼠操作、系统硬件信息" @视窗.外部头文件 = "include\\WinOperateModule.h"
        @视窗.外部源文件 = "include\\WinOperateModule.cpp" @视窗.外部头文件 = "include\\WinApiHook.h" @视窗.外部源文件 = "include\\WinApiHook.cpp">

类 鼠标按键类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 左键 <公开 值 = 0>
    常量 右键 <公开 值 = 1>
    常量 中键 <公开 值 = 2>
    常量 X键1 <公开 值 = 3>
    常量 X键2 <公开 值 = 4>
}

类 事件标志值 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 跨进程异步 <公开 值 = @WINEVENT_OUTOFCONTEXT 注释 = "回调函数不会映射到生成事件的进程的地址空间.挂钩函数跨进程边界调用,保证事件异步按顺序排列.">
    常量 跳过自身线程 <公开 值 = @WINEVENT_SKIPOWNTHREAD 注释 = "阻止此挂钩实例接收由注册此挂钩的线程生成的事件">
    常量 跳过线程 <公开 值 = @WINEVENT_SKIPOWNPROCESS 注释 = "阻止此挂钩实例接收此进程中线程生成的事件.此标志不会阻止线程生成事件.">
    常量 挂钩DLL <公开 值 = @WINEVENT_INCONTEXT 注释 = "包含回调函数的DLL映射到生成事件的进程的地址空间.指定此标志时,挂钩函数必须位于 DLL 中.">
}

类 常用事件常量值 <公开 注释 = "枚举了常用事件常量值" @文档 = "category = \"辅助类\"">
{
    常量 激活键盘快捷键 <公开 类型 = 整数 值 = @EVENT_OBJECT_ACCELERATORCHANGE 注释 = "激活键盘快捷键">
    常量 窗口可视 <公开 类型 = 整数 值 = @EVENT_OBJECT_CLOAKED 注释 = "当窗口被遮盖时发送. 隐藏的窗口仍然存在,但对用户不可见.">
    常量 滚动条到底 <公开 类型 = 整数 值 = 0x8015 注释 = "窗口对象的滚动已结束,无论滚动是水平滚动还是垂直滚动,每当滚动操作完成时,都发送此事件.">
    常量 对象被创建 <公开 类型 = 整数 值 = @EVENT_OBJECT_CREATE 注释 = "已创建对象.窗口或控件被创建完成.">
    常量 默认值被改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_DEFACTIONCHANGE 注释 = "可用于如单选框多选框选中状态被更变">
    常量 描述被改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_DESCRIPTIONCHANGE 注释 = "基于对象的名称、角色、状态和值属性改变">
    常量 对象被销毁 <公开 类型 = 整数 值 = @EVENT_OBJECT_DESTROY 注释 = "对象已被销毁">
    常量 开始拖动元素 <公开 类型 = 整数 值 = @EVENT_OBJECT_DRAGSTART 注释 = "开始拖动元素">
    常量 结束拖动元素 <公开 类型 = 整数 值 = @VENT_OBJECT_DRAGCANCEL 注释 = "已结束拖动操作">
    常量 元素被拖动删除 <公开 类型 = 整数 值 = @EVENT_OBJECT_DRAGCOMPLETE 注释 = "删除了放置目标上的元素">
    常量 元素拖动到边界 <公开 类型 = 整数 值 = @EVENT_OBJECT_DRAGENTER 注释 = "用户将元素拖动到放置目标的边界">
    常量 元素被删除 <公开 类型 = 整数 值 = @EVENT_OBJECT_DRAGDROPPED 注释 = "元素被删除">
    常量 最低事件值 <公开 类型 = 整数 值 = @EVENT_MIN 注释 = "最低对象事件值">
    常量 最高事件值 <公开 类型 = 整数 值 = @EVENT_MAX 注释 = "最高对象事件值">
    常量 接收到键盘焦点 <公开 类型 = 整数 值 = @EVENT_OBJECT_FOCUS 注释 = "对象已接收键盘焦点">
    常量 帮助属性被改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_HELPCHANGE 注释 = "对象的帮助属性已更改.服务器应用程序为它们的辅助性对象发送该事件.">
    常量 对象被隐藏 <公开 类型 = 整数 值 = @EVENT_OBJECT_HIDE 注释 = "对象已隐藏">
    常量 更改托管对象 <公开 类型 = 整数 值 = @EVENT_OBJECT_HOSTEDOBJECTSINVALIDATED 注释 = "承载其他可访问对象的窗口已更改托管对象">
    常量 输入法被隐藏 <公开 类型 = 整数 值 = @EVENT_OBJECT_IME_HIDE 注释 = "已隐藏输入法窗口">
    常量 输入法被显示 <公开 类型 = 整数 值 = @EVENT_OBJECT_IME_SHOW 注释 = "输入法窗口已变为可见">
    常量 输入法尺寸改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_IME_CHANGE 注释 = "输入法窗口尺寸被改变">
    常量 对象被调用 <公开 类型 = 整数 值 = 0x8013 注释 = "已调用对象;例如,用户已单击按钮.">
    常量 区域被更改 <公开 类型 = 整数 值 = @EVENT_OBJECT_LIVEREGIONCHANGED 注释 = "作为实时区域的一部分的对象已更改.实时区域是应用程序经常更改和/或异步更改的区域.">
    常量 窗口尺寸被改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_LOCATIONCHANGE 注释 = "对象已更改位置、形状和大小.">
    常量 名称被更改 <公开 类型 = 整数 值 = @EVENT_OBJECT_NAMECHANGE 注释 = "对象的名称属性已更改">
    常量 父对象改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_PARENTCHANGE 注释 = "对象具有新的父对象">
    常量 容器准备好 <公开 类型 = 整数 值 = @EVENT_OBJECT_REORDER 注释 = "容器对象已添加、移除其子对象或对其子对象重新排序." 注释 = "当子元素数或元素顺序发生更改时,列表视图对象会生成此事件."
            注释 = "子窗口的Z顺序更改时,父窗口也会发送此事件.">
    常量 焦点被改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_SELECTION 注释 = "容器对象中的选择已更改">
    常量 新增内容 <公开 类型 = 整数 值 = @EVENT_OBJECT_SELECTIONADD 注释 = "容器对象中的子对象已添加到现有选定内容,如超级列表添加列表项.">
    常量 删除内容 <公开 类型 = 整数 值 = @EVENT_OBJECT_SELECTIONREMOVE 注释 = "容器对象中的项已从所选内容中删除,如超级列表删除列表项.">
    常量 选中项被更改 <公开 类型 = 整数 值 = @EVENT_OBJECT_SELECTIONWITHIN 注释 = "容器对象中发生了许多选择更改,如列表项选择被更改.">
    常量 对象被显示 <公开 类型 = 整数 值 = @EVENT_OBJECT_SHOW 注释 = "显示隐藏对象">
    常量 状态改变 <公开 类型 = 整数 值 = @EVENT_OBJECT_STATECHANGE 注释 = "对象的状态已更改.例如,在单击或释放按钮对象或启用或禁用对象时发生状态更改.">
    常量 输入法转换目标 <公开 类型 = 整数 值 = @EVENT_OBJECT_TEXTEDIT_CONVERSIONTARGETCHANGED 注释 = "输入法转换目标">
    常量 选中文本被改变 <公开 类型 = 整数 值 = 0x8014 注释 = "对象的文本选择已更改">
    常量 窗口未遮盖 <公开 类型 = 整数 值 = @EVENT_OBJECT_UNCLOAKED 注释 = "当窗口未遮盖时发送. 隐藏的窗口仍然存在,但对用户不可见.">
    常量 内容被更改 <公开 类型 = 整数 值 = @EVENT_OBJECT_VALUECHANGE 注释 = "对象的内容属性被更改">
    常量 已生成警报 <公开 类型 = 整数 值 = @EVENT_SYSTEM_ALERT 注释 = "已生成警报">
    常量 显示预览框 <公开 类型 = 整数 值 = 0x8016 注释 = "正在显示预览矩形">
    常量 鼠标反捕获 <公开 类型 = 整数 值 = @EVENT_SYSTEM_CAPTUREEND 注释 = "窗口已丢失鼠标捕获">
    常量 鼠标捕获 <公开 类型 = 整数 值 = @EVENT_SYSTEM_CAPTURESTART 注释 = "窗口已收到鼠标捕获">
    常量 退出帮助模式 <公开 类型 = 整数 值 = @EVENT_SYSTEM_CONTEXTHELPEND 注释 = "窗口已退出上下文相关的帮助模式">
    常量 进入帮助模式 <公开 类型 = 整数 值 = @EVENT_SYSTEM_CONTEXTHELPSTART 注释 = "窗口已进入上下文相关的帮助模式">
    常量 激活窗口被改变 <公开 类型 = 整数 值 = @EVENT_SYSTEM_DESKTOPSWITCH 注释 = "活动桌面已切换">
    常量 关闭对话框 <公开 类型 = 整数 值 = @EVENT_SYSTEM_DIALOGEND 注释 = "关闭对话框">
    常量 弹出对话框 <公开 类型 = 整数 值 = @EVENT_SYSTEM_DIALOGSTART 注释 = "弹出对话框">
    常量 退出拖放模式 <公开 类型 = 整数 值 = @EVENT_SYSTEM_DRAGDROPEND 注释 = "应用程序将退出拖放模式">
    常量 进入拖放模式 <公开 类型 = 整数 值 = @EVENT_SYSTEM_DRAGDROPSTART 注释 = "应用程序将进入拖放模式">
    常量 最高系统事件值 <公开 类型 = 整数 值 = @EVENT_SYSTEM_END 注释 = "最高的系统事件值.">
    常量 前台窗口被更改 <公开 类型 = 整数 值 = @EVENT_SYSTEM_FOREGROUND 注释 = "前台窗口已更改.同线程中的另一个窗口到前台,系统也会发送此事件.">
    常量 系统菜单被关闭 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MENUPOPUPEND 注释 = "弹出菜单已关闭">
    常量 系统菜单被显示 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MENUPOPUPSTART 注释 = "此时会显示一个弹出菜单">
    常量 菜单栏菜单关闭 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MENUEND 注释 = "菜单栏中的菜单已关闭">
    常量 菜单栏菜单项选择 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MENUSTART 注释 = "已选择菜单栏上的菜单项">
    常量 窗口还原 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MINIMIZEEND 注释 = "即将还原窗口对象">
    常量 窗口最小化 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MINIMIZESTART 注释 = "窗口对象即将最小化">
    常量 窗口移动 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MOVESIZEEND 注释 = "窗口的移动或调整大小已完成">
    常量 窗口正在移动 <公开 类型 = 整数 值 = @EVENT_SYSTEM_MOVESIZESTART 注释 = "正在移动窗口或调整窗口的大小">
    常量 滚动条滚动结束 <公开 类型 = 整数 值 = @EVENT_SYSTEM_SCROLLINGEND 注释 = "滚动条上的滚动已经结束">
    常量 滚动条滚动开始 <公开 类型 = 整数 值 = @EVENT_SYSTEM_SCROLLINGSTART 注释 = "滚动条上的滚动已经开始">
    常量 开始播放声音 <公开 类型 = 整数 值 = @EVENT_SYSTEM_SOUND 注释 = "一个声音已经播放">
    常量 切换窗口 <公开 类型 = 整数 值 = @EVENT_SYSTEM_SWITCHEND 注释 = "ALT+TAB按键触发切换窗口">
    常量 切换激活窗口 <公开 类型 = 整数 值 = @EVENT_SYSTEM_SWITCHSTART 注释 = "ALT+TAB按键切换,使得窗口被激活.">
}

