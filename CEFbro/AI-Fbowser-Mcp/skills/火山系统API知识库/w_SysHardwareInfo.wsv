类 系统API钩子类 <公开 注释 = "提供对API函数HOOK方法" @文档 = "category = \"钩子操作\"">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CwinApihookModule)

    方法 初始化 <公开 类型 = 整数 注释 = "初始化MinHook库,必须在程序开始做一次初始化,否则无法使用它进行API Hook." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    {
        @ @sn<this>.data().MH_Initialize()
    }

    方法 清理 <公开 类型 = 整数 注释 = "手动清理释放内存,该类退出时,会自动调用该方法." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    {
        @ @sn<this>.data().MH_Uninitialize()
    }

    方法 类_清理 <注释 = "关闭时自动清理">
    {
        清理 ()
    }

    方法 从指针创建 <公开 类型 = 整数 注释 = "从函数指针创建一个Hook,并保存进行Hook所需要的信息,成功加入HOOK列表." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    参数 函数指针 <类型 = 变整数 注释 = "目标函数指针地址">
    参数 挂接子程序 <类型 = 变整数 注释 = "用来HOOK的子程序指针">
    参数 回调指针 <类型 = 变整数类 注释 = "返回值,原始函数回调指针,通过该指针可执行回原始函数.可为空." @默认值 = 空对象>
    {
        @ @sn<this>.data().MH_CreateHook((LPVOID)@<函数指针>,(LPVOID)@<挂接子程序>,reinterpret_cast<LPVOID*>(&@<回调指针.值>))
    }

    方法 从函数名创建 <公开 类型 = 整数 注释 = "从函数名创建一个Hook,并保存进行Hook所需要的信息,成功加入HOOK列表." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    参数 模块名称 <类型 = 文本型 注释 = "指定函数所属模块名称">
    参数 函数名称 <类型 = 文本型 注释 = "模块所在的目标函数名称">
    参数 挂接子程序 <类型 = 变整数 注释 = "用来HOOK的子程序指针">
    参数 回调指针 <类型 = 变整数类 注释 = "返回值,原始函数回调指针,通过该指针可执行回原始函数.可为空." @默认值 = 空对象>
    参数 函数指针 <类型 = 变整数类 注释 = "返回值,目标函数指针地址,用以接收原始函数真实地址,可根据该值进行\"移除\",\"设置队列\"等操作.可为空." @默认值 = 空对象>
    {
        @ @sn<this>.data().MH_CreateHookApiEx(@<模块名称>.GetText(),GetMbsText (@<函数名称>, CVolMem (), NULL),(LPVOID)@<挂接子程序>,reinterpret_cast<LPVOID*>(&@<回调指针.值>),reinterpret_cast<LPVOID*>(&@<函数指针.值>))
    }

    方法 开启 <公开 类型 = 整数 注释 = "根据函数指针,开启Hook,使Hook生效.多函数时,使用\"开启队列\"方法." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    参数 函数指针 <类型 = 变整数 注释 = "目标函数指针地址">
    {
        @ @sn<this>.data().MH_HookSwitch((LPVOID)@<函数指针>,TRUE)
    }

    方法 暂停 <公开 类型 = 整数 注释 = "根据函数指针,暂停Hook,使Hook暂时失效.多函数时,使用\"设置队列\"方法." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    参数 函数指针 <类型 = 变整数 注释 = "目标函数指针地址">
    {
        @ @sn<this>.data().MH_HookSwitch((LPVOID)@<函数指针>,FALSE)
    }

    方法 设置队列 <公开 类型 = 整数 注释 = "以队列形式管理HOOK列表,设置队列中的某个函数是否开启HOOK." 注释 = "多函数可分多次设置.统一设置时,请将\"函数指针\"设为0."
            注释 = "设置后执行\"开启队列\"方法使HOOK生效." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    参数 函数指针 <类型 = 变整数 注释 = "目标函数指针地址.如果为0,表示设置对象为HOOK列表全部函数." @默认值 = 0>
    参数 是否开启 <类型 = 逻辑型 注释 = "设置是否开启状态." @默认值 = 真>
    {
        @ @sn<this>.data().MH_QueueHookSwitch((LPVOID)@<函数指针>,@<是否开启>)
    }

    方法 开启队列 <公开 类型 = 整数 注释 = "根据HOOK列表及队列设置,选择性开启Hook,使Hook生效." 返回值注释 = "APIHOOK执行结果.*" @嵌入式方法 = "">
    {
        @ @sn<this>.data().MH_ApplyQueued()
    }
}

