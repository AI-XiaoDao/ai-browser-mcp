    方法 取Cookie <公开 类型 = 文本型 注释 = "执行\"发送\"相关的方法成功响应后,所返回协议头中的Cookie标头.">
    参数 子名称 <类型 = 文本型 注释 = "根据子名称取出其中一条Cookie的值.如果为空文本,则表示取出所有包含名称的Cookie文本." @默认值 = "">
    {
        变量 局_响应头 <类型 = 文本型>
        变量 局_头数组 <类型 = 文本数组类>
        变量 局_返回值 <类型 = 文本型>
        局_响应头 = 取响应头 ()
        分割文本 (局_响应头, "\n", 局_头数组, 真, 真)
        局_头数组.枚举循环 ()
        {
            变量 局_左文本 <类型 = 文本型 值 = "">
            变量 局_右文本 <类型 = 文本型 值 = "">
            变量 局_临时文本 <类型 = 文本型 值 = "">
            变量 局_找到位置 <类型 = 整数 值 = -1>
            分割左右子文本 (局_头数组.取枚举值 (), ":", 局_左文本, 局_右文本, 真)
            如果 (局_左文本 == "Set-Cookie")
            {
                局_找到位置 = 寻找文本 (局_右文本, ";", , )
                如果 (局_找到位置 != -1)
                {
                    局_临时文本 = 取文本左边 (局_右文本, 局_找到位置)
                    分割左右子文本 (局_临时文本, "=", 局_左文本, 局_右文本, 真)
                    如果 (子名称 != "" && 子名称 == 局_左文本)  // 找到符合子名称条件的Cookie
                    {
                        返回 (局_右文本)
                    }
                    局_返回值 = 局_返回值 + 局_临时文本 + "; "  // 注意带有空格,按Cookie格式设置.
                }
            }
        }
        返回 (局_返回值)
    }

    方法 置Cookie <公开 注释 = "设置网页访问时协议头中的Cookie标头.">
    参数 所欲设置的值 <类型 = 文本型>
    {
        如果 (文本是否为空 (所欲设置的值) == 假)
        {
            如果 (是否以文本开头 (所欲设置的值, "Cookie:", 假))
            {
                所欲设置的值 = 取文本右边 (所欲设置的值, 取文本长度 (所欲设置的值) - 取文本长度 ("Cookie:"))
            }
            所欲设置的值 = 删首尾空 (所欲设置的值)
            如果 (文本是否为空 (所欲设置的值) == 假)
            {
                置协议头 ("Cookie", 所欲设置的值)
            }
        }
    }

    方法 发送字节集 <公开 类型 = 逻辑型 注释 = "发送字节集,执行开始访问.">
    参数 要发送的内容 <类型 = 字节集类 注释 = "要发送的内容">
    {
        变量 局_COM变体 <类型 = COM变体型>
        局_COM变体.置字节集 (要发送的内容)
        IWinHttpRequest对象.无返回值方法 ("Send", 局_COM变体)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 发送文本 <公开 类型 = 逻辑型 注释 = "发送文本,执行开始访问.">
    参数 要发送的内容 <类型 = 文本型 注释 = "要发送的内容">
    {
        IWinHttpRequest对象.无返回值方法 ("Send", 要发送的内容)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 发送 <公开 类型 = 逻辑型 注释 = "执行开始访问">
    {
        IWinHttpRequest对象.无参数及返回值方法 ("Send")
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 置代理策略 <公开 类型 = 逻辑型 注释 = "自动代理登录策略">
    参数 代理策略 <类型 = WinHttp代理策略 注释 = "WinHttp代理策略.*,指定当前的自动代理登录策略.">
    {
        IWinHttpRequest对象.无返回值方法 ("SetAutoLogonPolicy", 代理策略)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 置代理 <公开 类型 = 逻辑型 注释 = "设置代理服务器信息">
    参数 代理标志 <类型 = WinHttp代理标志 注释 = "WinHttp代理标志.*,指定怎样设置代理.">
    参数 代理服务器 <类型 = 文本型 注释 = "带端口号代理服务器,如:\"127.0.0.1:8888\"." "">
    参数 域绕过列表 <类型 = 文本型 注释 = "设置为域绕过列表,支持*通配符,如:\"*.microsoft.com\"." @默认值 = "">
    {
        IWinHttpRequest对象.无返回值方法 ("SetProxy", 代理标志, 代理服务器, 域绕过列表)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 置协议头 <公开 类型 = 逻辑型 注释 = "添加或更改 HTTP 请求标头.">
    参数 头名称 <类型 = 文本型 注释 = "指定要设置的标头的名称,例如\"depth\".此参数不应包含冒号,并且必须是\"HTTP\"标头的实际文本.如果为空文本,则表示用于多标头." @默认值 = "">
    参数 所欲设置的值 <类型 = 文本型 注释 = "指定要把\"头名称\"设置为标头所赋的值.如果\"头名称\"为空文本,则表示多行协议头,以换行符\"\\r\\n\"分隔,以\"头名称\"+\": \"+\"值\"为内容的形式." "">
    {
        如果 (头名称 == "")
        {
            变量 局_头数组 <类型 = 文本数组类>
            分割文本 (所欲设置的值, "\n", 局_头数组, 真, 真)
            局_头数组.枚举循环 ()
            {
                变量 局_设置值 <类型 = 文本型 值 = "">
                变量 局_头名称 <类型 = 文本型 值 = "">
                分割左右子文本 (局_头数组.取枚举值 (), ":", 局_头名称, 局_设置值, 真)
                IWinHttpRequest对象.无返回值方法 ("SetRequestHeader", 局_头名称, 局_设置值)
                如果 (IWinHttpRequest对象.是否成功 () == 假)
                {
                    返回 (假)
                }
            }
            返回 (真)
        }
        否则
        {
            IWinHttpRequest对象.无返回值方法 ("SetRequestHeader", 头名称, 所欲设置的值)
            返回 (IWinHttpRequest对象.是否成功 ())
        }
    }

    方法 删除协议头 <公开 注释 = "删除 HTTP 请求标头.">
    参数 头名称 <类型 = 文本型 注释 = "指定要删除的标头的名称,例如\"depth\".此参数不应包含冒号,并且必须是\"HTTP\"标头的实际文本." 注释 = "如果欲同时删除多个标头,请使用换行符\"\\r\\n\"分隔.">
    {
        变量 局_头数组 <类型 = 文本数组类>
        分割文本 (头名称, "\n", 局_头数组, 真, 真)
        局_头数组.枚举循环 ()
        {
            IWinHttpRequest对象.无返回值方法 ("SetRequestHeader", 局_头数组.取枚举值 (), "")
        }
    }

    方法 置超时时间 <公开 类型 = 逻辑型 注释 = "指定发送/接收操作的各个超时组件(以毫秒为单位),如果值为0或-1时,则表示无限等待.大于0的值则表示超时值.">
    参数 解析主机名 <类型 = 整数 注释 = "指定解析主机名时,DNS超时时间.默认为无限等待.以毫秒为单位." @默认值 = -1>
    参数 建立套接字 <类型 = 整数 注释 = "使用目标服务器建立通信套接字时应用的超时值,默认值为60秒.以毫秒为单位." @默认值 = 60000>
    参数 发送 <类型 = 整数 注释 = "在将通信套接字上的单个请求数据包发送到目标服务器应用时的超时值.如果使用分包发送:则适用于单独发送每个数据包超时时间.默认值为30秒.以毫秒为单位." @默认值 = 30000>
    参数 响应 <类型 = 整数 注释 = "从目标服务器接收响应数据包时应用的超时值.如果使用分包响应时,则适用于从套接字提取每个数据包的数据超时时间.默认值为30秒.以毫秒为单位." @默认值 = 30000>
    {
        IWinHttpRequest对象.无返回值方法 ("SetTimeouts", 解析主机名, 建立套接字, 发送, 响应)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 等待异步响应 <公开 类型 = 逻辑型 注释 = "等待异步发送方法完成(以秒为单位可选超时值)" 返回值注释 = "返回值为真时,表示已收到响应.返回值为假时,表示超过指定的超时期限.">
    参数 超时值 <类型 = 整数 注释 = "超时值,以秒为单位.默认超时是无限的." @默认值 = -1>
    {
        返回 (IWinHttpRequest对象.方法 ("WaitForResponse", 逻辑型, 超时值))
    }

    方法 置证书 <公开 类型 = 逻辑型 注释 = "用于HTTPS服务器选择要发送到安全超文本传输协议的客户端证书.">
    参数 证书位置 <类型 = 文本型 注释 = "指定客户端证书的位置、 证书存储和使用者.">
    {
        IWinHttpRequest对象.无返回值方法 ("SetClientCertificate", 证书位置)
        返回 (IWinHttpRequest对象.是否成功 ())
    }

    方法 置代理凭证 <公开 类型 = 逻辑型 注释 = "将凭据设置为与 HTTP 服务器一起使用,无论是代理服务器还是原始服务器.若要对服务器和代理进行身份验证,则必须分别调用两次.">
    参数 凭据对象 <类型 = WinHttp代理标识 注释 = "指定使用凭据传递给服务器或代理">
    参数 用户名 <类型 = 文本型 注释 = "指定身份验证的用户名">
    参数 密码 <类型 = 文本型 注释 = "指定身份验证的密码">
    {
        IWinHttpRequest对象.无返回值方法 ("SetCredentials", 用户名, 密码, 凭据对象)
        返回 (IWinHttpRequest对象.是否成功 ())
    }
}
