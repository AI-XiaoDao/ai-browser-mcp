        @视窗.外部库 = "third_party\\$(p)\\libcurl.lib\r\nthird_party\\$(p)\\libeay32.lib\r\nthird_party\\$(p)\\ssleay32.lib\r\nlib\\$(p)\\alibabacloud-oss-cpp-sdk-static-$(d).lib"
        @视窗.附属文件 = "third_party\\$(p)\\libcurl.dll\r\nthird_party\\$(p)\\libeay32.dll\r\nthird_party\\$(p)\\ssleay32.dll\r\nthird_party\\$(p)\\zlibwapi.dll"
        @视窗.需求VS版本 = "16-">
{

