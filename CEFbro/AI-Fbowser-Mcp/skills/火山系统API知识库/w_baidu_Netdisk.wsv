    方法 上传文件 <公开 类型 = 百度网盘上传结果类 注释 = "注意:本方法上传文件大小上限为2GB,本方法将触发\"开始上传\"事件.">
    参数 上传路径 <类型 = 文本型 注释 = "上传的文件绝对路径,例如: /apps/appName/filename.jpg" 注释 = "注意:上传文件只能上传到\"/apps/产品名称\"目录下.">
    参数 欲上传的文件 <类型 = 文本型>
    参数 上传策略 <类型 = 百度网盘文件策略 注释 = "注意\"百度网盘文件策略.跳过\"在当前方法无效." @默认值 = 百度网盘文件策略.失败>
    参数 令牌 <类型 = 文本型 注释 = "当调用过\"取令牌\"方法后,本参数可空." @默认值 = "">
    {
        变量 协议头 <类型 = 文本数组类>
        协议头.加入成员 ("Host: d.pcs.baidu.com")
        变量 本地文件 <类型 = 文本数组类>
        变量 文件名 <类型 = 文本数组类>
        变量 类型 <类型 = 文本数组类>
        本地文件.加入成员 (欲上传的文件)
        文件名.加入成员 ("file")
        类型.加入成员 ("application/x-www-form-urlencoded")
        变量 JSON <类型 = JSON对象类>
        JSON.创建自字节集 (网络.网页访问2 ("https://d.pcs.baidu.com/rest/2.0/pcs/file?method=upload&access_token=" + 选择 (文本是否为空 (令牌) || 文本是否为空对象 (令牌), 访问令牌, 令牌) + "&path=" + 网络.URL编码 (上传路径) + "&ondup=" + (文本型)上传策略, 网页访问方式.POST, , 协议头, , , , , , , , , 本地文件, 文件名, 类型).请求结果)
        变量 结果 <类型 = 百度网盘上传结果类>
        结果.文件路径 = JSON.取文本值 ("path")
        结果.文件尺寸 = JSON.取长整数值 ("size")
        结果.创建时间 = JSON.取整数值 ("ctime")
        结果.修改时间 = JSON.取整数值 ("mtime")
        结果.MD5 = JSON.取文本值 ("md5")
        结果.文件ID = JSON.取长整数值 ("fs_id")
        结果.请求ID = JSON.取长整数值 ("request_id")
        结果.结果码 = JSON.取整数值 ("error_code")
        结果.结果信息 = JSON.取文本值 ("error_msg")
        返回 (结果)
    }

    方法 网络访问类_访问进度改变 <接收事件 类型 = 整数 注释 = "在发送请求过程中如果请求进度发生改变,将会响应本事件." 返回值注释 = "返回0继续传输,返回非0值中止传输.">
    参数 来源对象 <类型 = 网络访问类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 下载总量 <类型 = 长整数 注释 = "预计需要下载的字节数.">
    参数 当前下载 <类型 = 长整数 注释 = "当前已下载的字节数.">
    参数 上传总量 <类型 = 长整数 注释 = "预计需要上传的字节数.">
    参数 当前上传 <类型 = 长整数 注释 = "当前已上传的字节数.">
    {
        如果 (上传总量 != 0 && 当前上传 != 0)  // 防止未获取的时候触发事件
        {
            如果 (开始上传 (上传总量, 当前上传) != 0)
            {
                返回 (1)
            }
        }
        如果 (下载总量 != 0 && 当前下载 != 0)  // 防止未获取的时候触发事件
        {
            如果 (开始下载 (下载总量, 当前下载) != 0)
            {
                返回 (1)
            }
        }
        返回 (0)
    }

    方法 继续 <公开 类型 = 逻辑型 注释 = "继续当前下载或上传任务." 返回值注释 = "失败返回假,可能是文件被占用.">
    参数 继续下载 <类型 = 逻辑型 注释 = "提供真则继续下载任务,否则表示继续上传任务.">
    {
        返回 (网络.继续 (继续下载))
    }

    方法 暂停 <公开 注释 = "暂停当前下载或上传任务,重新开始调用\"继续\"方法即可.">
    参数 是否关闭文件 <类型 = 逻辑型 注释 = "是否关闭文件占用,如果为上传任务本参数无效.">
    {
        网络.暂停 (是否关闭文件)
    }

    方法 下载文件 <公开 类型 = 整数 返回值注释 = "返回下载结果码,失败返回-1." 返回值注释 = "其它结果参考\"百度网盘结果码\"中的常量值.">
    参数 文件ID <类型 = 长整数 注释 = "提供文件唯一ID">
    参数 保存位置 <类型 = 文本型 注释 = "提供本地电脑的保存位置">
    参数 覆盖文件 <类型 = 逻辑型 注释 = "如果存在同名文件是否覆盖,如果设置为假,则尝试断点续传." @默认值 = 真>
    参数 令牌 <类型 = 文本型 注释 = "当调用过\"取令牌\"方法后,本参数可空." @默认值 = "">
    {
        变量 数组 <类型 = JSON数组类>
        数组.置入长整数值 (文件ID)
        变量 文件数组 <类型 = 百度网盘文件数组类>
        文件数组 = 查询文件信息 (数组, 令牌).文件数组
        如果 (文件数组.取成员数 () > 0)
        {
            变量 下载地址 <类型 = 文本型>
            下载地址 = 文件数组.取成员 (0).下载地址 + "&access_token=" + 选择 (文本是否为空 (令牌) || 文本是否为空对象 (令牌), 访问令牌, 令牌)
            变量 协议头 <类型 = 文本数组类>
            协议头.加入成员 ("Host: d.pcs.baidu.com", "User-Agent: pan.baidu.com")
            网络.下载文件 (下载地址, 网页访问方式.GET, , 协议头, , , , , , , , , 保存位置, 选择 (覆盖文件, 网页访问覆盖策略.覆盖文件, 网页访问覆盖策略.断点续传))
        }
        返回 (-1)  // 没有查询到任何文件
    }

    方法 创建文件夹 <公开 静态 类型 = 整数 返回值注释 = "参考\"百度网盘结果码\"中的常量值,返回0表示成功.">
