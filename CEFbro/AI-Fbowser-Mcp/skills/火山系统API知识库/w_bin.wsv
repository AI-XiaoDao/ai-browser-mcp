    {
        @ @<所欲操作本对象>.AddValue_@pdt<所欲添加的值> (@<所欲添加的值>)
    }

    方法 添加单精度小数到字节集 <公开 静态 注释 = "将所指定的单精度小数值添加到本字节集尾部" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲添加的值 <类型 = 小数 注释 = "提供所欲添加到本字节集尾部的值,该值将被强制转换为单精度小数后添加进去.">
    {
        @ @<所欲操作本对象>.AddValue_FLOAT ((FLOAT)@<所欲添加的值>)
    }

    方法 添加文本到字节集 <公开 静态 注释 = "将所指定文本内容添加到本字节集尾部" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲添加的文本 <类型 = 文本型 注释 = "提供所欲添加到本字节集尾部的文本内容">
    参数 是否添加结束零字符 <类型 = 逻辑型 注释 = "是否将文本尾部的结束零字符添加到字节集尾部" @默认值 = 假>
    {
        @ @<所欲操作本对象>.AddTextValue (@<所欲添加的文本>, @<是否添加结束零字符>)
    }

    方法 添加字节集空间 <公开 静态 类型 = 变整数 注释 = "将所指定尺寸的数据内容空间添加到字节集尾部" 返回值注释 = "  返回所添加内容空间部分的首地址指针值,除非必要且对指针概念有"
            返回值注释 = "透彻的了解,不要使用本返回值." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 内容空间尺寸 <类型 = 整数 注释 = "提供所欲添加内容空间的尺寸,必须大于等于0.">
    参数 是否清零 <类型 = 逻辑型 注释 = "是否将所添加的内容空间部分清除为字节值零" @默认值 = 真>
    {
        @ (INT_P)@<所欲操作本对象>.AddSpace (@<内容空间尺寸>, @<是否清零>)
    }

    方法 添加重复字符到字节集 <公开 静态 注释 = "添加指定数目的字符到本字节集尾部" @嵌入式方法 = "">
