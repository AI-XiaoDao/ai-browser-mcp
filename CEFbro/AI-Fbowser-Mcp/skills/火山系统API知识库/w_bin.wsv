    方法 指针插入字节集 <公开 静态 注释 = "将所指定指针处的数据插入到本字节集所指定偏移位置处." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集的长度.">
    参数 数据指针 <类型 = 变整数 注释 = "指向所欲插入数据的指针值">
    参数 所欲插入数据尺寸 <类型 = 整数 注释 = "  提供所欲插入数据的尺寸(单位字节),必须确保指针所指向地址处尺寸为本参数值" 注释 = "的地址空间可读.">
    {
        @ @<所欲操作本对象>.Insert (@<插入偏移位置>, (void*)@<数据指针>, @<所欲插入数据尺寸>)
    }

    方法 插入值到字节集 <公开 静态 注释 = "将所指定数据类型的值插入到本字节集所指定偏移位置处" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集的长度.">
    参数 所欲插入的值 <注释 = "提供具体所欲插入的值,如欲明确指定其数据类型,可以使用强制类型转换操作符." @匹配类型 = 通用非文本基本型>
    {
        @ @<所欲操作本对象>.InsertValue_@pdt<所欲插入的值> (@<插入偏移位置>, @<所欲插入的值>)
    }

    方法 插入单精度小数到字节集 <公开 静态 注释 = "将所指定的单精度小数值插入到本字节集所指定偏移位置处" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集的长度.">
    参数 所欲插入的值 <类型 = 小数 注释 = "提供具体所欲插入的值,该值将被强制转换为单精度小数后插入字节集中.">
    {
        @ @<所欲操作本对象>.InsertValue_FLOAT (@<插入偏移位置>, (FLOAT)@<所欲插入的值>)
    }

    方法 插入文本到字节集 <公开 静态 注释 = "将所指定文本内容插入到本字节集所指定偏移位置处." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集的长度.">
    参数 所欲插入的文本内容 <类型 = 文本型 注释 = "提供具体所欲插入的文本内容">
    参数 是否插入结束零字符 <类型 = 逻辑型 注释 = "是否将文本尾部的结束零字符插入进字节集" @默认值 = 假>
    {
        @ @<所欲操作本对象>.InsertTextValue (@<插入偏移位置>, @<所欲插入的文本内容>, @<是否插入结束零字符>)
    }

    方法 插入字节集空间 <公开 静态 类型 = 变整数 注释 = "将所指定尺寸的数据内容空间插入到字节集所指定位置处" 返回值注释 = "  返回所插入内容空间部分的首地址指针值,除非必要且对指针概念有透彻的了解,"
            返回值注释 = "不要使用本返回值." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集长度.">
    参数 内容空间尺寸 <类型 = 整数 注释 = "提供所欲插入内容空间的尺寸,必须大于等于0.">
    参数 是否清零 <类型 = 逻辑型 注释 = "是否将所插入的内容空间部分清除为字节值零" @默认值 = 真>
    {
        @ (INT_P)@<所欲操作本对象>.InsertSpace (@<插入偏移位置>, @<内容空间尺寸>, @<是否清零>)
    }

    方法 插入部分文本到字节集 <公开 静态 注释 = "将所指定文本的一部分插入到字节集所指定位置处" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集长度.">
    参数 所欲插入的文本 <类型 = 文本型 注释 = "提供所欲插入到本字节集中的文本数据">
    参数 所欲插入文本的长度 <类型 = 整数 注释 = "提供所欲插入文本的长度(单位字符),必须大于等于0且小于等于所指定文本长度.">
    {
        @ @<所欲操作本对象>.InsertOnlyText (@<插入偏移位置>, @<所欲插入的文本>.GetText (), @<所欲插入文本的长度>)
    }

    方法 指针插入文本到字节集 <公开 静态 注释 = "将所指定长度的文本内容插入到字节集所指定位置处." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供在本字节集中的具体插入偏移位置,必须大于等于0且小于等于本字节集长度.">
    参数 所欲插入的文本指针 <类型 = 变整数 注释 = "提供所欲插入到本字节集中的文本数据指针">
    参数 所欲插入文本的长度 <类型 = 整数 注释 = "  提供所欲插入文本的长度(单位字符),必须确保指针所指向地址处尺寸为" 注释 = "\"本参数值*单个字符数据尺寸\"的地址空间可读.">
    {
        @ @<所欲操作本对象>.InsertOnlyText (@<插入偏移位置>, (TCHAR*)@<所欲插入的文本指针>, @<所欲插入文本的长度>)
    }

    # 删除数据 ---

    方法 字节集删除 <公开 静态 注释 = "删除本字节集的某一部分内容" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 起始删除位置 <类型 = 整数 注释 = "提供被删除内容的起始偏移位置,必须大于等于-1." 注释 = "如果为-1,则从尾部开始向前逆向删除所指定尺寸.">
    参数 所欲删除数据的尺寸 <类型 = 整数 注释 = "提供具体的删除尺寸,单位字节,必须大于等于0.">
    {
        @ @<所欲操作本对象>.Remove (@<起始删除位置>, @<所欲删除数据的尺寸>)
    }

    方法 删除字节集尾部数据 <公开 静态 注释 = "保留当前字节集首部的指定尺寸数据,将后面的数据全部删除." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲保留数据的尺寸 <类型 = 整数 注释 = "  提供所欲保留的位于当前字节集首部的数据尺寸," 注释 = "必须大于等于0且小于等于本字节集的长度.">
    {
        @ @<所欲操作本对象>.RemoveToEnd (@<所欲保留数据的尺寸>)
    }

    方法 删除字节集尾字符零 <公开 静态 注释 = "如果当前字节集尾部为零字符,则将其删除,否则不进行任何操作." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ @<所欲操作本对象>.RemoveEndZeroChar ()
    }

    方法 取字节集哈希值 <公开 静态 类型 = 整数 注释 = "  计算并返回所指定字节集的哈希值." 注释 = "  字节集哈希值可以在需要快速比较两个字节集是否相同时使用(即如果"
            注释 = "两个字节集的哈希值不同,则两个字节集必定不相同)." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT)@<所欲操作本对象>.GetHash ()
    }

    方法 字节集到十六进制文本 <公开 静态 类型 = 文本型 注释 = "将本字节集的内容转换为十六进制格式的连续文本" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ @<所欲操作本对象>.ToHexStr (CVolString ())
    }

    方法 十六进制文本到字节集 <公开 静态 类型 = 字节集类 注释 = "根据\"字节集到十六进制文本\"方法返回的文本内容创建并返回一个字节集" @嵌入式方法 = "">
    参数 十六进制文本 <类型 = 文本型 注释 = "必须为\"字节集到十六进制文本\"所返回的格式文本">
    {
        @ CVolMem::sFromHexStr (@<十六进制文本>.GetText (), CVolMem ())
    }

    方法 添加十六进制文本到字节集 <公开 静态 类型 = 字节集类 注释 = "根据\"字节集到十六进制文本\"方法返回的文本内容创建一个字节集并将其添加到本字节集的尾部" 返回值注释 = "返回添加后的本字节集对象" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 十六进制文本 <类型 = 文本型 注释 = "必须为\"字节集到十六进制文本\"所返回的格式文本">
    {
        @ @<所欲操作本对象>.AppendFromHexStr (@<十六进制文本>.GetText ())
    }

    方法 字节集到BASE64文本 <公开 静态 类型 = 文本型 注释 = "返回本字节集数据所对应的BASE64编码格式文本内容" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 编码格式 <类型 = BASE64编码方式 注释 = "提供具体的编码格式" @默认值 = BASE64编码方式.标准>
    参数 每行最大字符数 <类型 = 整数 注释 = "指定每行编码文本的最大字符数,小于0表示无限制,等于0表示使用默认每行字符数(76)." @默认值 = 0>
    {
        @ CVolString ().EncodeBase64 (@<所欲操作本对象>, @<每行最大字符数>, @<编码格式>)
    }

    方法 BASE64文本到字节集 <公开 静态 类型 = 字节集类 注释 = "将所指定的BASE64编码格式文本解码为对应的字节集后返回" @嵌入式方法 = "">
    参数 BASE64编码文本 <类型 = 文本型 注释 = "提供所欲解码的BASE64编码文本">
    参数 编码格式 <类型 = BASE64编码方式 注释 = "提供具体的编码格式,必须与编码时指定的格式相同." @默认值 = BASE64编码方式.标准>
    {
        @ @<BASE64编码文本>.DecodeBase64 (CVolMem (), @<编码格式>)
    }

    方法 字节集到Quoted文本 <公开 静态 类型 = 文本型 注释 = "返回本字节集数据所对应的Quoted-Printable编码格式文本内容" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 每行最大字符数 <类型 = 整数 注释 = "指定每行编码文本的最大字符数,小于0表示无限制,等于0表示使用默认每行字符数(76)." @默认值 = 0>
    {
        @ CVolString ().EncodeQuoted (@<所欲操作本对象>, @<每行最大字符数>)
    }

    方法 Quoted文本到字节集 <公开 静态 类型 = 字节集类 注释 = "将所指定的Quoted-Printable编码格式文本解码为对应的字节集后返回" @嵌入式方法 = "">
    参数 Quoted编码文本 <类型 = 文本型 注释 = "提供所欲解码的Quoted-Printable编码文本">
    {
        @ @<Quoted编码文本>.DecodeQuoted (CVolMem ())
    }
}
