    参数 所欲添加的字符 <类型 = 字符 注释 = "提供所欲添加的具体字符">
    参数 所欲添加的次数 <类型 = 整数 注释 = "提供所欲添加的次数,必须大于等于0.">
    {
        @ @<所欲操作本对象>.AddManyChars (@<所欲添加的字符>, @<所欲添加的次数>)
    }

    方法 添加部分文本到字节集 <公开 静态 注释 = "将所指定文本的部分内容添加到本字节集尾部" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
