<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "本文件提供视窗项目的相关字节集操作支持功能">

类 BASE64编码方式 <公开 @文档 = "category = \"字节集操作.辅助类\"" @常量类 = 整数>
{
    常量 标准 <公开 值 = 0 注释 = "标准Base64编码格式">
    常量 URL专用 <公开 值 = 1 注释 = "URL专用的Base64编码格式">
    常量 正则专用 <公开 值 = 2 注释 = "正则表达式专用的Base64编码格式">
}

类 字节集类 <公开 注释 = "用作保存一段字节数据的字节集类" @文档 = "category = \"字节集操作\"" @别名 = "@an<CVolMem>" @全局类 = 真>
{
    方法 取字节集预分配尺寸 <公开 静态 类型 = 整数 注释 = "  返回本字节集为了快速进行数据的添加/删除处理使用的空间分配尺寸," 注释 = "每次字节集需要调整其空间大小时,都使用本属性值作为空间调整基准尺"
            注释 = "寸.值越大,批量加入/删除数据时所实际需要重分配空间的次数就越少,操" 注释 = "作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT)@<所欲操作本对象>.GetMemAlignSize ()
    }

    方法 置字节集预分配尺寸 <公开 静态 注释 = "  设置本字节集为了快速进行数据的添加/删除处理使用的空间分配尺寸," 注释 = "每次字节集需要调整其空间大小时,都使用本属性值作为空间调整基准尺"
            注释 = "寸.值越大,批量加入/删除数据时所实际需要重分配空间的次数就越少,操" 注释 = "作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲设置的预分配尺寸 <类型 = 整数 注释 = "提供所欲设置的预分配尺寸,必须大于等于0.">
    {
        @ @<所欲操作本对象>.SetMemAlignSize (@<所欲设置的预分配尺寸>)
    }

    # 建立 ---

    方法 到字节集 <公开 静态 类型 = 字节集类 注释 = "根据所指定基本数据类型数据生成并返回对应的字节集." 注释 = "注意: 如果是文本型数据,其尾部的结束零字符不会被加入." @嵌入式方法 = "">
    参数 所欲转换的数据 <@匹配类型 = 通用基本型>
    {
        @ @an<CVolMem> (@<所欲转换的数据>)
    }

    方法 创建字节集 <公开 静态 类型 = 字节集类 注释 = "根据所提供的一系列整数字节值建立并返回一个字节集对象" @嵌入式方法 = "">
    参数 字节数值 <类型 = 整数 注释 = "提供所欲加入的所有字节值,注意所提供值必须在0到255之间." @可扩展 = "">
    {
        @ CVolMem ().AddManyBytes (@sn<pm_count>, @<字节数值>)
    }

    方法 组合字节集 <公开 静态 类型 = 字节集类 注释 = "将所提供的一系列数据组合起来建立并返回一个字节集对象" 编辑时信息 = "13EA96, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲组合的所有数据 <注释 = "提供所欲组合的所有数据,可以为基本数据类型或字节集类数据." 编辑时信息 = "13EA96, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>), @<欲组合的所有数据>)
    }

    方法 添加字节集内容 <公开 静态 类型 = 字节集类 注释 = "将所提供的一系列整数字节值添加到本字节集对象现有内容的尾部" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 字节数值 <类型 = 整数 注释 = "提供所欲添加的所有字节值,注意所提供值必须在0到255之间." @可扩展 = "">
    {
        @ @<所欲操作本对象>.AddManyBytes (@sn<pm_count> - 1, @<字节数值>)
    }

    方法 数组到字节集 <公开 静态 类型 = 字节集类 注释 = "根据所指定非文本基本数据类型数组数据生成并返回对应的字节集" @嵌入式方法 = "">
    参数 所欲转换的数据 <@匹配类型 = 通用非文本基本型数组>
    {
        @ @an<CVolMem> (_VOL_GET_ARY_VAR_ADR_AND_SIZE (@<所欲转换的数据>))
    }

    方法 指针到字节集 <公开 静态 类型 = 字节集类 注释 = "根据所指定指针处的数据建立并返回一个对应的字节集对象." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 数据指针 <类型 = 变整数 注释 = "指向欲加入数据的指针值">
    参数 数据尺寸 <类型 = 整数 注释 = "  提供所欲加入数据的尺寸(单位字节),必须确保指针所指向地址处尺寸" 注释 = "为本参数值的地址空间有效.">
    {
        @ @an<CVolMem> ((void*)@<数据指针>, @<数据尺寸>)
    }

    方法 字节集内容是否相同 <公开 静态 类型 = 逻辑型 注释 = "判断两个字节集的内容是否相同." 注释 = "注: 调用\"对象内容是否相同\"方法是同样的效果." @嵌入式方法 = "">
    参数 字节集1 <类型 = 字节集类>
    参数 字节集2 <类型 = 字节集类>
    {
        @ (BOOL)@<字节集1>.IsEqual (@<字节集2>)
    }

    方法 文件资源到字节集 <公开 静态 类型 = 逻辑型 注释 = "载入所指定的字节集数据资源,返回是否载入成功." @嵌入式方法 = "">
    参数 所欲载入的数据资源 <类型 = 视窗文件资源 注释 = "用作提供所欲载入的RCDATA类型资源,如果为\"空资源.空文件\",将返回空字节集.">
    参数 所欲写出到的字节集 <类型 = 字节集类 注释 = "用作接收所载入的资源数据,其中的原有内容将被覆盖.">
    {
        @ (BOOL)g_objVolApp.LoadResData (@<所欲载入的数据资源>, @<所欲写出到的字节集>)
    }

    方法 取字节集左边 <公开 静态 类型 = 字节集类 注释 = "返回一个字节集,其中包含指定字节集中从左边算起指定数量的字节." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 欲取出字节的数目 <类型 = 整数 注释 = "提供欲取出字节的数目,必须大于等于0.">
    {
        @ @<所欲操作本对象>.GetBinLeft (@<欲取出字节的数目>)
    }

    方法 取字节集右边 <公开 静态 类型 = 字节集类 注释 = "返回一个字节集,其中包含指定字节集中从右边算起指定数量的字节." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 欲取出字节的数目 <类型 = 整数 注释 = "提供欲取出字节的数目,必须大于等于0.">
    {
        @ @<所欲操作本对象>.GetBinRight (@<欲取出字节的数目>)
    }

    方法 取字节集中间 <公开 静态 类型 = 字节集类 注释 = "返回一个字节集,其中包含指定字节集中从指定位置算起指定数量的字节." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 起始取出索引位置 <类型 = 整数 注释 = "提供所欲取出的首字节在字节集中的偏移位置,必须大于等于0且小于等于字节集长度.">
    参数 欲取出字节的数目 <类型 = 整数 注释 = "提供欲取出字节的数目,必须大于等于0.">
    {
        @ @<所欲操作本对象>.GetBinMid (@<起始取出索引位置>, @<欲取出字节的数目>)
    }

    # 基本操作 ---

    方法 分配字节集 <公开 静态 类型 = 变整数 注释 = "为本字节集分配所指定尺寸的数据内容空间,其中的原有内容将被覆盖." 返回值注释 = "返回所分配字节集内容空间的指针值.除非必要且对指针概念有透彻的了解,不要使用该返回值."
            @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲分配空间尺寸 <类型 = 整数 注释 = "提供所欲分配的数据内容空间尺寸,必须大于等于0.">
    参数 是否清零 <类型 = 逻辑型 注释 = "是否将所分配的内容空间清除为字节值零." 注释 = "如果本参数值为假,所分配的字节集内容空间将为随机值." @默认值 = 真>
    {
        @ (INT_P)@<所欲操作本对象>.Alloc (@<所欲分配空间尺寸>, @<是否清零>)
    }

    方法 重分配字节集 <公开 静态 类型 = 变整数 注释 = "  为本字节集重新分配所指定尺寸的数据内容空间." 注释 = "  与\"分配字节集\"不同的是: 位于重分配空间中的字节集原有数据内容将被保留不受"
            注释 = "影响.如果相比先前尺寸存在多余部分,该部分将为随机值.如果相比先前尺寸更小,则" 注释 = "原有尾部数据内容将会被剪切掉." 返回值注释 = "  返回重分配字节集数据内容空间后的指针值.除非必要且对指针概念有透彻的了解,"
            返回值注释 = "不要使用该返回值." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲重分配空间尺寸 <类型 = 整数 注释 = "提供所欲重新分配的数据内容空间尺寸,必须大于等于0.">
    {
        @ (INT_P)@<所欲操作本对象>.Realloc (@<所欲重分配空间尺寸>)
    }

    方法 释放字节集 <公开 静态 注释 = "删除本字节集中的所有当前内容,并释放所占用的对应内存空间." 注释 = "本方法调用后,本字节集的长度将为0." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ @<所欲操作本对象>.Free ()
    }

    方法 清空字节集 <公开 静态 注释 = "  删除本字节集中的所有当前内容,与\"释放字节集\"不同的是本方法" 注释 = "并不立即释放所占用的对应内存空间." 注释 = "  如果后面会继续使用本字节集,使用本方法清空字节集内容可以避"
            注释 = "免频繁分配/释放所占用的内存空间,加快处理速度." 注释 = "  本方法调用后,本字节集的长度将为0." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ @<所欲操作本对象>.Empty ()
    }

    方法 取字节集指针 <公开 静态 类型 = 变整数 注释 = "返回当前字节集数据内容的指针值,如果当前字节集内容为空,将返回0." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT_P)@<所欲操作本对象>.GetPtr ()
    }

    方法 取字节集尾指针 <公开 静态 类型 = 变整数 注释 = "  返回当前字节集数据内容的尾部指针值(最后一个字节后面)," 注释 = "如果当前字节集内容为空,将返回0." 注释 = " 除非必要且对指针概念有透彻的了解,不要使用本方法."
            @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT_P)@<所欲操作本对象>.GetEndPtr ()
    }

    方法 为字节集尾字符 <公开 静态 类型 = 逻辑型 注释 = "返回位于当前字节集尾部的字符是否为所指定的字符." 注释 = "如果当前字节集的尺寸比一个字符的尺寸小,将直接返回假." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲检测的字符 <类型 = 字符 注释 = "提供所欲检测的字符值">
    {
        @ (BOOL)@<所欲操作本对象>.EndCharOf (@<所欲检测的字符>)
    }

    方法 指针数据位于字节集 <公开 静态 类型 = 逻辑型 注释 = "返回指针所指向的指定尺寸数据是否全部位于本字节集内" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 数据指针 <类型 = 变整数 注释 = "指向欲检测的指针值">
    参数 数据尺寸 <类型 = 整数 注释 = "提供所欲检测的数据尺寸(单位字节)">
    {
        @ (BOOL)@<所欲操作本对象>.IsInside ((void*)@<数据指针>, @<数据尺寸>)
    }

    方法 偏移数据位于字节集 <公开 静态 类型 = 逻辑型 注释 = "返回所指定偏移位置处的指定尺寸数据是否全部位于本字节集内" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 数据偏移 <类型 = 整数 注释 = "指向欲检测的数据偏移位置值">
    参数 数据尺寸 <类型 = 整数 注释 = "提供所欲检测的数据尺寸(单位字节)">
    {
        @ (BOOL)@<所欲操作本对象>.IsOffsetInside (@<数据偏移>, @<数据尺寸>)
    }

    方法 取字节集长度 <公开 静态 类型 = 整数 注释 = "返回本字节集中已有数据内容的尺寸(单位字节)" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT)@<所欲操作本对象>.GetSize ()
    }

    方法 取字节集值数目 <公开 静态 类型 = 整数 注释 = "返回字节集中包含所指定基本数据类型数据值的数目" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲检查的数据类型 <注释 = "提供所欲获取其存在数目的数据类型." 注释 = "注意: 如果为文本型,则固定返回0." @需求类型 = 数据类型 @匹配类型 = 通用基本型>
    {
        @ (INT)@<所欲操作本对象>.GetCount_@<所欲检查的数据类型> ()
    }

    方法 取字节集单精度小数数目 <公开 静态 类型 = 整数 注释 = "返回字节集中包含单精度小数值的数目" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (INT)@<所欲操作本对象>.GetCount_FLOAT ()
    }

    方法 字节集是否为空 <公开 静态 类型 = 逻辑型 注释 = "返回当前字节集的数据内容是否为空" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ (BOOL)@<所欲操作本对象>.IsEmpty ()
    }

    方法 寻找字节集 <公开 静态 类型 = 整数 注释 = "返回所指定字节集在本字节集中最先出现的偏移位置,如果未找到则返回-1." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲查找的字节集 <类型 = 字节集类 注释 = "提供所欲查找的字节集内容">
    参数 起始查找位置 <类型 = 整数 注释 = "提供起始查找偏移位置,必须大于等于0." @默认值 = 0>
    {
        @ (INT)@<所欲操作本对象>.FindBin (@<所欲查找的字节集>, @<起始查找位置>)
    }

    方法 倒找字节集 <公开 静态 类型 = 整数 注释 = "返回所指定字节集在本字节集中最后出现的偏移位置,如果未找到则返回-1." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲查找的字节集 <类型 = 字节集类 注释 = "提供所欲查找的字节集内容">
    参数 起始查找位置 <类型 = 整数 注释 = "  提供起始查找偏移位置,如果超出当前字节集的尺寸,则从当前字节集的尾" 注释 = "部开始. 必须大于等于0." @默认值 = 数值范围.最大整数值>
    {
        @ (INT)@<所欲操作本对象>.ReverseFindBin (@<所欲查找的字节集>, @<起始查找位置>)
    }

    方法 分割字节集 <公开 静态 类型 = 整数 注释 = "  将本字节集进行分割,将分割后的所有子字节集存放入\"结果存放字节集数组\"" 注释 = "参数所指定的数组对象中,返回所存放进去的子字节集对象数目." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 用作分割的字节集 <类型 = 字节集类 注释 = "本方法将基于此字节集内容对本字节集进行分割">
    参数 结果存放字节集数组 <类型 = 字节集数组类 注释 = "用作存放所获得的子字节集对象,其中原有内容将被清空.">
    参数 欲返回子字节集数目 <类型 = 整数 注释 = "提供所欲返回子字节集的最大数目,为0表示返回全部被分割后的子字节集." @默认值 = 0>
    {
        @ (INT)@<所欲操作本对象>.SplitBin (@<用作分割的字节集>, @<欲返回子字节集数目>, @<结果存放字节集数组>)
    }

    方法 从文件读字节集 <公开 静态 类型 = 整数 注释 = "从所指定路径文件中读入指定尺寸的数据,成功返回所实际读入数据尺寸,失败返回-1." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲读取文件名 <类型 = 文本型 注释 = "提供所欲读取文件的路径名称">
    参数 所欲读取数据尺寸 <类型 = 整数 注释 = "提供所欲读取数据的尺寸,为-1表示全部读取." @默认值 = -1>
    {
        @ (INT)@<所欲操作本对象>.ReadFromFile (@<所欲读取文件名>, @<所欲读取数据尺寸>)
    }

    方法 写字节集到文件 <公开 静态 类型 = 逻辑型 注释 = "将本字节集的内容写入到所指定路径的文件中,返回是否写出成功." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 所欲写到文件名 <类型 = 文本型 注释 = "提供所欲写到文件的路径名称">
    参数 所欲写出数据尺寸 <类型 = 整数 注释 = "提供所欲写出数据的尺寸,为-1表示全部写出." @默认值 = -1>
    {
        @ (BOOL)@<所欲操作本对象>.WriteIntoFile (@<所欲写到文件名>, @<所欲写出数据尺寸>)
    }

    方法 取空白字节集 <公开 静态 类型 = 字节集类 注释 = "返回具有所指定次数的零字节值重复数据的字节集">
    参数 零字节数目 <类型 = 整数 注释 = "指定所欲重置为的零字节数目,必须大于等于0.">
    {
        变量 结果变量 <类型 = 字节集类>
        结果变量.置为空白字节集 (零字节数目)
        返回 (结果变量)
    }

    方法 取重复字节集 <公开 静态 类型 = 字节集类 注释 = "返回具有所指定次数的指定字节集重复数据的字节集">
    参数 待重复的字节集 <类型 = 字节集类 注释 = "提供所欲重复添加的字节集">
    参数 重复次数 <类型 = 整数 注释 = "提供重复添加的次数">
    {
        变量 结果变量 <类型 = 字节集类>
        结果变量.置为重复字节集 (待重复的字节集, 重复次数)
        返回 (结果变量)
    }

    # 修改内容 ---

    方法 清零字节集 <公开 静态 注释 = "将本字节集的当前数据内容全部清除为字节值零" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    {
        @ @<所欲操作本对象>.Zero ()
    }

    方法 字节集替换 <公开 静态 注释 = "将本字节集的某一部分用其它的字节集替换" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 起始替换位置 <类型 = 整数 注释 = "提供被替换内容的起始偏移位置,必须大于等于0且小于等于字节集长度.">
    参数 替换尺寸 <类型 = 整数 注释 = "提供具体的替换尺寸,单位字节,必须大于等于0.">
    参数 用作替换的字节集 <类型 = 字节集类 注释 = "提供用来替换本字节集所指定部分内容的字节集">
    {
        @ @<所欲操作本对象>.Replace (@<起始替换位置>, @<替换尺寸>, @<用作替换的字节集>)
    }

    方法 指针字节集替换 <公开 静态 注释 = "将本字节集的某一部分用指针所指向的数据替换." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 起始替换位置 <类型 = 整数 注释 = "提供被替换内容的起始偏移位置,必须大于等于0.">
    参数 替换尺寸 <类型 = 整数 注释 = "提供具体的替换尺寸,单位字节,必须大于等于0.">
    参数 用作替换数据的指针 <类型 = 变整数 注释 = "指向用来替换本字节集所指定部分内容的数据地址">
    参数 用作替换数据的尺寸 <类型 = 整数 注释 = "提供替换数据的尺寸,调用方必须确保所指定指针指向地址处尺寸为本参数值的内容空间可读.">
    {
        @ @<所欲操作本对象>.Replace (@<起始替换位置>, @<替换尺寸>, (void*)@<用作替换数据的指针>, @<用作替换数据的尺寸>)
    }

    方法 子字节集替换 <公开 静态 注释 = "将本字节集中为指定子字节集的内容替换成另一子字节集所指定的内容" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 欲被替换的子字节集 <类型 = 字节集类 注释 = "提供所欲被替换的字节集内容,本字节集中的所有此内容将被替换.">
    参数 用作替换的子字节集 <类型 = 字节集类 注释 = "提供用作替换的字节集内容">
    参数 进行替换的起始位置 <类型 = 整数 注释 = "提供被替换子字节集的起始搜索位置,必须大于等于0." @默认值 = 0>
    参数 替换进行的次数 <类型 = 整数 注释 = "提供欲进行替换的次数,为0表示进行所有可能的替换." @默认值 = 0>
    {
        @ @<所欲操作本对象>.ReplaceBin (@<欲被替换的子字节集>, @<用作替换的子字节集>, @<进行替换的起始位置>, @<替换进行的次数>)
    }

    方法 取字节集数据 <公开 静态 注释 = "取出字节集中指定位置指定数据类型的数据" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 数据偏移位置 <类型 = 整数 注释 = "提供所欲获取数据在本字节集中的偏移位置,必须大于等于0." @默认值 = 0>
    参数 所欲获取数据的类型 <注释 = "提供所欲获取数据的数据类型" @需求类型 = 数据类型 @匹配类型 = 通用基本型 @返回值类型 = 0>
    {
        @ @<所欲操作本对象>.Get_@<所欲获取数据的类型> (@<数据偏移位置>)
    }

    方法 置字节集值 <公开 静态 注释 = "设置字节集中指定位置处的指定数据类型值" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
    参数 数据偏移位置 <类型 = 整数 注释 = "提供所欲设置数据在本字节集中的偏移位置,必须大于等于0." @默认值 = 0>
    参数 所欲设置的值 <注释 = "提供具体所欲设置的值,如欲明确指定其数据类型,可以使用强制类型转换操作符." @匹配类型 = 通用非文本基本型>
    {
        @ @<所欲操作本对象>.SetValue_@pdt<所欲设置的值> (@<数据偏移位置>, @<所欲设置的值>)
    }

    方法 取字节集小数 <公开 静态 类型 = 小数 注释 = "取出字节集中指定位置的小数值" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 字节集类 注释 = "提供所欲操作的字节集对象">
