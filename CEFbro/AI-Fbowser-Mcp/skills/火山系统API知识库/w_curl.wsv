    方法 SSL客户端证书 <公开 属性写 注释 = "设置从内存中加载所欲使用的SSL客户端证书数据.">
    参数 数据 <类型 = 字节集类 注释 = "提供证书数据,提供空对象表示禁用.">
    {
        @ if (@<数据>.IsNullObject())
        @ {
        @     curl_easy_setopt(data().GetCurl(), CURLOPT_SSLCERT_BLOB, NULL);
        @     return;
        @ }
        @ struct curl_blob stblob;
        @ stblob.data = @<数据>.GetPtr();
        @ stblob.len = (size_t)@<数据>.GetSize();
        @ stblob.flags = CURL_BLOB_COPY;    //拷贝传递,不必保留该结构体
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_SSLCERT_BLOB, &stblob);
    }

