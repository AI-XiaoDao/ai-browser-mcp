    方法 传输进度发生改变 <公开 定义事件 类型 = 整数 注释 = "当传输进度发生改变时,本事件将被调用多次直到整个传输结束." 注释 = "本事件默认未被启用,如欲启用,请设置\"进度反馈\"属性值为真."
            返回值注释 = "返回0继续传输,返回非0值中止传输.">
    参数 下载总量 <类型 = 长整数 注释 = "预计需要下载的字节数">
    参数 当前下载 <类型 = 长整数 注释 = "当前已下载的字节数">
    参数 上传总量 <类型 = 长整数 注释 = "预计需要上传的字节数">
    参数 当前上传 <类型 = 长整数 注释 = "当前已上传的字节数">

    方法 全局初始化 <公开 静态 类型 = 整数 注释 = "该方法调用后将会初始化libcurl运行所需的程序环境." 注释 = "注意:" 注释 = "  1. 除非为编译DLL动态链接库,本方法不需要用户显式调用,系统类库会自动调用;"
            注释 = "  2. 本方法必须与\"全局清理\"方法成对使用;" 注释 = "  3. 该方法非线程安全,请务必在程序主线程中主动调用,如果未主动调用,在使用任何功能时将会自动执行(不保证线程安全)."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    {
        @ (INT)curl_global_init(CURL_GLOBAL_DEFAULT)
    }

    方法 全局清理 <公开 静态 注释 = "本方法调用后会释放libcurl所占用的资源,应该在程序退出前(不再使用该类进行网络访问时)调用." 注释 = "注意:"
            注释 = "  1. 除非为编译DLL动态链接库,本方法不需要用户显式调用,系统类库会自动调用;" 注释 = "  2. 本方法必须与\"全局初始化\"方法成对使用;" 注释 = "  3. 该方法非线程安全,请务必在程序主线程中主动调用."
            @嵌入式方法 = "">
    {
        @ curl_global_cleanup()
    }

    方法 取版本信息 <公开 静态 类型 = 文本型 注释 = "获取当前libcurl库的版本号信息." @嵌入式方法 = "">
    {
        @ @an<CVolString> (curl_version())
    }

    方法 取错误描述 <公开 静态 类型 = 文本型 注释 = "根据指定的返回值代码获取对应的描述内容." @嵌入式方法 = "">
    参数 错误码 <类型 = 整数>
    {
        @ @an<CVolString> (curl_easy_strerror((CURLcode)@<错误码>))
    }

    # 属性 ---

    方法 详细模式 <公开 属性写 注释 = "设置详细模式(通常在调试模式下启用,获取各种详细信息)的开关.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_VERBOSE, @<启用>);
    }

    方法 包含响应头输出 <公开 属性写 注释 = "指定返回内容中是否包含响应标头信息.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_HEADER, @<启用>);
    }

    方法 进度反馈 <公开 属性写 注释 = "是否启用进度反馈,只有启用了进度反馈,才会发送\"传输进度发生改变\"事件." 注释 = "本属性默认值为假(不启用).">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt (data ().GetCurl (), CURLOPT_NOPROGRESS, (@<启用> ? 0L : 1L));
        @ if (@<启用>)
        @     data ().SetXferinfoFunction ((INT_P)this, ProgressFn);
        @ else
        @     data ().SetXferinfoFunction (0, NULL);
    }

    方法 信号处理 <公开 属性写 注释 = "是否启用信号处理">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_NOSIGNAL, !@<启用>);
    }

    方法 通配符匹配 <公开 属性写 注释 = "是否启用目录通配符传输">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_WILDCARDMATCH, @<启用>);
    }

    方法 不跳过失败请求 <公开 属性写 注释 = "如果返回的HTTP响应码设置为400或大于400,启用该属性将会返回请求失败.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_FAILONERROR, @<启用>);
    }

    方法 忽略错误继续发送 <公开 属性写 注释 = "HTTP响应码>=300时,是否忽略错误继续发送请求体.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_KEEP_SENDING_ON_ERROR, @<启用>);
    }

    方法 地址 <公开 属性写 注释 = "设置所欲发送请求的目标网址.">
    参数 内容 <类型 = 文本型 注释 = "例如:http://www.voldp.com/">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_URL, GetMbsText (@<内容>.GetText (), CVolMem(), NULL));
    }

    方法 不处理点序列 <公开 属性写 注释 = "是否不处理地址路径中的点序列,即\"../\".">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_PATH_AS_IS, @<启用>);
    }

    方法 代理隧道传输 <公开 属性写 注释 = "是否启用代理隧道.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_HTTPPROXYTUNNEL, @<启用>);
    }

    方法 代理协商保护 <公开 属性写 注释 = "设置socks代理gssapi协商保护.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_SOCKS5_GSSAPI_NEC, @<启用>);
    }

    方法 代理服务名称 <公开 属性写 注释 = "设置代理身份验证服务名称.">
    参数 名称 <类型 = 文本型 注释 = "提供空文本表示禁用.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_PROXY_SERVICE_NAME, (@<名称>.IsEmpty() ? NULL : GetMbsText (@<名称>.GetText (), CVolMem(), NULL)));
    }

    方法 认证服务名称 <公开 属性写 注释 = "设置认证服务名称.">
    参数 名称 <类型 = 文本型 注释 = "提供空文本表示禁用.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_SERVICE_NAME, (@<名称>.IsEmpty() ? NULL : GetMbsText (@<名称>.GetText (), CVolMem(), NULL)));
    }

    方法 网络接口名称 <公开 属性写 注释 = "设置所欲使用的网络接口.">
    参数 接口名称 <类型 = 文本型 注释 = "例如:eth0,提供空文本表示恢复默认.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_INTERFACE, (@<接口名称>.IsEmpty() ? NULL : GetMbsText (@<接口名称>.GetText (), CVolMem(), NULL)));
    }

    方法 本地端口 <公开 属性写 注释 = "设置用于套接字的本地端口号.">
    参数 端口号 <类型 = 整数>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_LOCALPORT, @<端口号>);
    }

    方法 本地端口范围 <公开 属性写 注释 = "设置要尝试的其他本地端口数.">
    参数 数量 <类型 = 整数>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_LOCALPORTRANGE, @<数量>);
    }

    方法 DOH地址 <公开 属性写 注释 = "提供HTTPS上的DNS URL.">
    参数 地址 <类型 = 文本型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_DOH_URL, GetMbsText (@<地址>.GetText (), CVolMem(), NULL));
    }

    方法 写入缓冲区尺寸 <公开 属性写 注释 = "指定写入数据缓冲区的尺寸.">
    参数 尺寸 <类型 = 整数 注释 = "最大不能超过512kb,该参数单位为b.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_BUFFERSIZE, @<尺寸>);
    }

    方法 远程端口 <公开 属性写 注释 = "指定请求所欲使用的端口号.">
    参数 端口 <类型 = 整数>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_PORT, @<端口>);
    }

    方法 快速打开 <公开 属性写 注释 = "是否启用TCP快速打开.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_TCP_FASTOPEN, @<启用>);
    }

    方法 无延迟模式 <公开 属性写 注释 = "是否启用TCP无延迟模式.">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_TCP_NODELAY, @<启用>);
    }

    方法 地址范围 <公开 属性写 注释 = "指定在连接到IPv6地址时要使用的作用域ID值.">
    参数 范围 <类型 = 整数>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_ADDRESS_SCOPE, @<范围>);
    }

    方法 保活探测 <公开 属性写 注释 = "启用TCP保持活动探测(Keep-Alive).">
    参数 启用 <类型 = 逻辑型>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_TCP_KEEPALIVE, @<启用>);
    }

    方法 保活探测空闲超时 <公开 属性写 注释 = "设置TCP保持活动探测(Keep-Alive)空闲时间的超时等待.">
    参数 超时 <类型 = 整数 注释 = "单位:秒.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_TCP_KEEPIDLE, @<超时>);
    }

    方法 保活探测间隔 <公开 属性写 注释 = "设置TCP保持活动探测(Keep-Alive)间隔时间.">
    参数 间隔 <类型 = 整数 注释 = "单位:秒.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_TCP_KEEPINTVL, @<间隔>);
    }

    方法 UNIX套接字路径 <公开 属性写 注释 = "设置Unix域套接字">
    参数 路径 <类型 = 文本型 注释 = "提供空文本表示禁用.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_UNIX_SOCKET_PATH, (@<路径>.IsEmpty() ? NULL : GetMbsText (@<路径>.GetText (), CVolMem(), NULL)));
    }

    方法 UNIX抽象套接字路径 <公开 属性写 注释 = "设置抽象的Unix域套接字.">
    参数 路径 <类型 = 文本型 注释 = "提供空文本表示禁用.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_ABSTRACT_UNIX_SOCKET, (@<路径>.IsEmpty() ? NULL : GetMbsText (@<路径>.GetText (), CVolMem(), NULL)));
    }

    方法 DNS缓存超时 <公开 属性写 注释 = "设置DNS缓存条目的有效时间.">
    参数 时长 <类型 = 整数 注释 = "单位:秒,为0表示禁用缓存,-1表示永久缓存.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_DNS_CACHE_TIMEOUT, @<时长>);
    }

    方法 允许协议 <公开 属性写 注释 = "设置允许使用的协议类型.">
    参数 协议类型 <类型 = 整数 注释 = "请参考\"网络访问协议类型\"所提供的常量,可使用其单个或多个组合值." @默认值 = 网络访问协议类型.所有>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_PROTOCOLS, @<协议类型>);
    }

    方法 允许重定向协议 <公开 属性写 注释 = "设置允许重定向使用的协议类型.">
    参数 协议类型 <类型 = 整数 注释 = "请参考\"网络访问协议类型\"所提供的常量,可使用其单个或多个组合值.">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_REDIR_PROTOCOLS, @<协议类型>);
    }

    方法 默认协议名称 <公开 属性写 注释 = "当\"地址\"属性没有给出具体协议时,所欲使用的默认协议.">
    参数 协议名称 <类型 = 文本型 注释 = "支持使用以下协议(方案)名称之一:"
            注释 = "dict, file, ftp, ftps, gopher, http, https, imap, imaps, ldap, ldaps, pop3, pop3s, rtsp, scp, sftp, smb, smbs, smtp, smtps, telnet, tftp">
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_DEFAULT_PROTOCOL, GetMbsText (@<协议名称>.GetText (), CVolMem(), NULL));
    }

    方法 代理地址 <公开 属性写 注释 = "设置所欲使用的代理地址,地址可包含协议名称以及端口号,也可单独设置.">
