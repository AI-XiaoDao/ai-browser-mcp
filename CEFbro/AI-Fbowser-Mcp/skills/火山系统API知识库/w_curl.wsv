类 FTP操作类 <公开 注释 = "用作支持进行FTP网络操作" @视窗.外部头文件 = "vol\\ftp\\vol_curl_ftp.h" @视窗.外部源文件 = "vol\\ftp\\vol_curl_ftp.cpp">
{
    变量 FTP服务器 <公开 类型 = 文本型 注释 = "提供所欲登录的FTP服务器地址. 如\"\"ftp://example.com\"." @属性变量 = 真>
    变量 用户名 <公开 类型 = 文本型 注释 = "提供登录FTP服务器的用户名,如无则为空文本." 注释 = "注意: 如果是匿名FTP服务器,可以提供用户名为\"anonymous\",密码提供自己的电子邮件地址或者不提供."
            @属性变量 = 真>
    变量 密码 <公开 类型 = 文本型 注释 = "提供登录FTP服务器的密码,如无则为空文本." @属性变量 = 真>
    变量 账户 <公开 类型 = 文本型 注释 = "提供某些FTP服务器登录时所需要的特定账户信息,如无则为空文本." @属性变量 = 真>
    变量 ""
    变量 成员_传输对象 <类型 = 网络传输类 注释 = "所使用的网络传输对象">

    方法 超时时间 <公开 属性写 注释 = "指定向FTP服务器发送完命令并等待其返回数据限定的超时时间">
    参数 最大允许时间 <类型 = 整数 注释 = "单位:毫秒. 小于等于0表示不限制,默认值为0.">
    {
        成员_传输对象.请求超时 = 取较大值 (0, 最大允许时间)
    }

    方法 服务器响应超时 <公开 属性写 注释 = "设置当发送命令到FTP服务器后等待服务器响应的超时时间." 注释 = "一般情况下,可以将本属性值设置为小于\"超时时间\"属性的值.">
    参数 最大允许时间 <类型 = 整数 注释 = "单位:毫秒. 小于等于0表示未设置,默认值为0.">
    {
        成员_传输对象.服务器响应超时 = 取较大值 (0, 最大允许时间)
    }

    方法 上传文件 <公开 类型 = 整数 注释 = "上传所指定文件到FTP服务器" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 本地文件路径 <类型 = 文本型 注释 = "提供所欲上传的本地文件路径">
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲上传到的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 是否续传 <类型 = 逻辑型 注释 = "指定如果所指定FTP文件已经存在,是否从其尾部开始续传." @默认值 = 假>
    参数 重试次数 <类型 = 整数 注释 = "指定如果传输失败,进行重试的数目." @默认值 = 0>
    {
        如果 (文件是否存在 (本地文件路径) == 假)
        {
            返回 (执行状态码.读入错误)
        }
        返回 (上传 (读入文件 (本地文件路径), FTP文件路径, 是否续传, 重试次数))
    }

    方法 下载文件 <公开 类型 = 整数 注释 = "下载FTP服务器上的所指定文件到本地" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲下载的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 本地文件路径 <类型 = 文本型 注释 = "提供所欲存放到的本地文件路径">
    {
        变量 下载结果数据 <类型 = 字节集类>
        变量 下载结果码 <类型 = 整数>
        下载结果码 = 下载 (FTP文件路径, 下载结果数据)
        如果 (下载结果码 != 执行状态码.成功)
        {
            返回 (下载结果码)
        }
        返回 (选择 (写到文件 (本地文件路径, 下载结果数据, ), 执行状态码.成功, 执行状态码.写入错误))
    }

    方法 批量下载文件 <公开 类型 = 整数 注释 = "下载FTP服务器上所指定的一批文件到本地" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 FTP文件路径 <类型 = 文本型 注释 = "  提供所欲下载的FTP服务器上的文件路径,可以携带通配符(\'*\'或\'?\'字符)."
            注释 = "如\"*\", \"/temp/*.txt\", \"/temp/photo?.jpg\" 等." 注释 = "  如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 本地目录路径 <类型 = 文本型 注释 = "提供所批量下载的文件欲存放到的本地目录路径">
    {
        @ return CVolCurlFTP::sMutilDownload (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (), @<FTP文件路径>.GetText (), @<本地目录路径>.GetText ());
    }

    方法 上传 <公开 类型 = 整数 注释 = "上传所指定数据到FTP服务器" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 所欲上传数据 <类型 = 字节集类 注释 = "提供所欲上传的数据内容">
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲上传到的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如果文件路径中的目录尚不存在,将尝试自动创建."
            注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 是否续传 <类型 = 逻辑型 注释 = "指定如果所指定FTP文件已经存在,是否从其尾部开始续传." @默认值 = 假>
    参数 重试次数 <类型 = 整数 注释 = "指定如果传输失败,进行重试的数目." @默认值 = 0>
    {
        @ return CVolCurlFTP::sUpload (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (),
        @         @<FTP文件路径>.GetText (), @<所欲上传数据>.GetPtr (), @<所欲上传数据>.GetSize (), @<是否续传>, @<重试次数>);
    }

    方法 下载 <公开 类型 = 整数 注释 = "下载FTP服务器上的所指定文件数据到本地" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲下载的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 结果存放字节集 <类型 = 字节集类 注释 = "提供所下载文件内容数据存放到的结果字节集">
    {
        @ return CVolCurlFTP::sDownload (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (), @<FTP文件路径>.GetText (), @<结果存放字节集>);
    }

    方法 删除文件 <公开 类型 = 整数 注释 = "删除FTP服务器上的所指定文件. 注意所登录用户需要在FTP服务器上有对应权限." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供FTP服务器上待删除文件的路径,如: \"/temp/temp.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        返回 (发送命令 ("DELE " + 规范化FTP路径 (FTP文件路径), 真))
    }

    方法 修改文件名 <公开 类型 = 整数 注释 = "将FTP服务器上的所指定文件修改为另外一个名称. 注意所登录用户需要在FTP服务器上有对应权限."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 欲修改FTP文件名 <类型 = 文本型 注释 = "提供FTP服务器上待修改名称的文件路径,如: \"/temp/temp1.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 修改到FTP文件名 <类型 = 文本型 注释 = "提供FTP服务器上修改到名称的文件路径,如: \"/temp/temp2.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        返回 (发送命令 ("RNFR " + 规范化FTP路径 (欲修改FTP文件名) + "\nRNTO " + 规范化FTP路径 (修改到FTP文件名), 真))
    }

    方法 创建目录 <公开 类型 = 整数 注释 = "创建FTP服务器上的所指定目录. 注意所登录用户需要在FTP服务器上有对应权限." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP目录路径 <类型 = 文本型 注释 = "提供FTP服务器上待创建目录的路径,如: \"/temp\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        返回 (发送命令 ("MKD " + 规范化FTP路径 (FTP目录路径), 真))
    }

    方法 删除目录 <公开 类型 = 整数 注释 = "删除FTP服务器上的所指定目录. 注意所登录用户需要在FTP服务器上有对应权限." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP目录路径 <类型 = 文本型 注释 = "提供FTP服务器上待删除目录的路径,如: \"/temp\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        返回 (发送命令 ("RMD " + 规范化FTP路径 (FTP目录路径), 真))
    }

    方法 删除目录及内容 <公开 类型 = 整数 注释 = "删除FTP服务器上的所指定目录及其中的所有内容,删除后将无法恢复. 注意所登录用户需要在FTP服务器上有对应权限."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP目录路径 <类型 = 文本型 注释 = "提供FTP服务器上待删除目录的路径,如: \"/temp\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        变量 规范FTP路径 <类型 = 文本型>
        变量 目录内容结果 <类型 = FTP文件数组类>
        规范FTP路径 = 规范化FTP路径 (FTP目录路径)
        取目录内容 (规范FTP路径, 目录内容结果)
        目录内容结果.枚举循环 ()
        {
            变量 FTP文件 <类型 = FTP文件类>
            FTP文件 = (FTP文件类)目录内容结果.取枚举值 ()
            如果 (FTP文件.是否为文件)
            {
                发送命令 ("DELE " + 规范FTP路径 + "/" + FTP文件.文件名, 真)  // 删除文件
            }
            否则
            {
                删除目录及内容 (规范FTP路径 + "/" + FTP文件.文件名)
            }
        }
        返回 (发送命令 ("RMD " + 规范FTP路径, 真))
    }

    方法 置服务器为UTF8编码 <公开 类型 = 整数 注释 = "设置FTP服务器的字符集编码是否为UTF8格式" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 是否为UTF8 <类型 = 逻辑型 注释 = "  指定是否为UTF8编码格式." 注释 = "  本类使用UTF8编码和FTP服务器进行交互,绝大多数现代FTP服务器均使用UTF8编码格式,"
            注释 = "如果某些服务器(譬如IIS的FTP服务器)不是,则调用本方法可以尝试将其切换到UTF8编码格式," 注释 = "以正确处理中文文件名,否则中文文件名将为乱码." 注释 = "注意:"
            注释 = "  1. IIS 7.5版本之前的 FTP 服务器不支持UTF8编码,如果希望 IIS FTP 服务器支持,则需要" 注释 = "升级其版本到 7.5 以上;"
            注释 = "  2. 本方法只是将相应请求发送到 FTP 服务器,其是否正确处理则依赖服务器自身. 最好的" 注释 = "方法是直接在 FTP 服务器上将其编码格式设置为 UTF-8 (如 IIS FTP 服务器).">
    {
        返回 (发送命令 (选择 (是否为UTF8, "OPTS UTF8 ON", "OPTS UTF8 OFF"), 假))
    }

    方法 取目录内容 <公开 类型 = 整数 注释 = "返回FTP服务器上所指定目录中内容解析后的列表信息" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 FTP目录路径 <类型 = 文本型 注释 = "提供FTP服务器上所指定目录的路径,如: \"/temp\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 目录内容结果 <类型 = FTP文件数组类 注释 = "用作保存所获得的目录内容列表结果数组">
    {
        @ std::vector<CVolCurlFTP::FTPFileEntry> fileEntries;
        @ CURLcode code = (CURLcode)CVolCurlFTP::sGetFTPFileList (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (), @<FTP目录路径>.GetText (), fileEntries);
        @ if (code != CURLE_OK)  return (INT)code;
        @ const size_t size = fileEntries.size ();
        @ for (size_t i = 0; i < size; ++i) {
        @     const CVolCurlFTP::FTPFileEntry& entry = fileEntries [i];
        @     @dt<FTP文件类> file;
        @     file.@n<FTP文件类.文件名>.SetText ((const U8CHAR*)entry.name.c_str ());
        @     file.@n<FTP文件类.文件尺寸> = (@dt<长整数>)entry.size;
        @     file.@n<FTP文件类.文件时间> = entry.modifyTime;
        @     file.@n<FTP文件类.是否为文件> = (entry.isFile == true);
        @     @<目录内容结果>.Add (file, NULL);
        @ }
        @ return (INT)CURLE_OK;
    }

    方法 取目录内容2 <公开 类型 = 整数 注释 = "返回FTP服务器上所指定目录中的原样内容列表" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义).">
    参数 FTP目录路径 <类型 = 文本型 注释 = "提供FTP服务器上所指定目录的路径,如: \"/temp\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 目录内容结果 <类型 = 文本型 注释 = "用作保存所获得的目录内容列表结果">
    {
        返回 (发送命令 ("LIST " + 规范化FTP路径 (FTP目录路径), 假, 目录内容结果))
    }

    方法 取文件信息 <公开 类型 = 整数 注释 = "返回FTP服务器上所指定文件的信息" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲检查的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    参数 文件尺寸 <类型 = 长整数类 注释 = "如果不为空对象,用作返回所获取的文件尺寸,单位字节.">
    参数 文件时间 <类型 = 小数类 注释 = "如果不为空对象,用作返回所获取的文件时间." @默认值 = 空对象>
    {
        @ return CVolCurlFTP::sGetFileInfo (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (),
        @         @<FTP文件路径>.GetText (), (@<文件尺寸>.IsNullObject () ? NULL : &@<文件尺寸.值>), (@<文件时间>.IsNullObject () ? NULL : &@<文件时间.值>));
    }

    方法 发送命令 <公开 类型 = 整数 注释 = "连接所指定的FTP服务器,发送命令文本并获取其返回结果文本." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 所欲发送的命令 <类型 = 文本型 注释 = "提供所欲发送的命令文本">
    参数 是否为前置命令 <类型 = 逻辑型 注释 = "指定是否在FTP传输前发送此命令文本. 如果本参数值为真,\"所欲发送的命令\"参数中可以使用基于换行符(\'\\n\')分隔的多条命令.">
    参数 结果存放文本 <类型 = 文本型 注释 = "  用作存放所发送命令被FTP服务器处理后的结果文本,如果为空对象,则表明不需要结果文本."
            注释 = "  注意: 如果所发送命令被FTP服务器处理后没有返回结果文本而此处参数提供的又不是空对象(需要结果文本),则本方法将"
            注释 = "一直等待所指定的超时时间(由\"超时时间\"属性指定)才会返回,如果\"超时时间\"属性值小于等于0(无限等待),则本方法将卡死." @默认值 = 空对象>
    {
        @ return CVolCurlFTP::sSendCommand (@<成员_传输对象>.data ().GetCurl (), @<FTP服务器>.GetText (), @<用户名>.GetText (), @<密码>.GetText (), @<账户>.GetText (),
        @         @<所欲发送的命令>.GetText (), @<是否为前置命令>, (@<结果存放文本>.IsNullObject () ? NULL : &@<结果存放文本>));
    }

    方法 清理 <公开 注释 = "清理本对象,断开与FTP服务器的连接." 注释 = "注意:" 注释 = "  1. 本方法调用不是必需的,本类对象被销毁时会自动进行清理;"
            注释 = "  2. 调用本方法后,所有先前对\"传输对象\"进行过的属性设置需要重新设置.">
    {
        成员_传输对象.清理 ()
    }

    方法 规范化FTP路径 <静态 类型 = 文本型 注释 = "规范化所指定的FTP文件路径" 返回值注释 = "返回规范化后的FTP文件路径结果" @嵌入式方法 = "">
    参数 FTP文件路径 <类型 = 文本型 注释 = "提供所欲规范化的FTP服务器上的文件路径. 如\"\"/temp/uploading.txt\"." 注释 = "如为相对路径,则相对登录FTP服务器后的根目录.">
    {
        @ CVolCurlFTP::sNormalizeFtpFileName (@<FTP文件路径>.GetText (), CVolString ())
    }
}

类 FTP文件数组类 <公开 基础类 = 对象数组模板类 @文档 = "category = \"辅助类\"" @模板实现类 = "FTP文件类">

类 FTP文件类 <公开 @文档 = "category = \"辅助类\"">
{
    变量 文件名 <公开 类型 = 文本型 注释 = "文件名或目录名">
    变量 文件尺寸 <公开 类型 = 长整数 注释 = "如果是目录或无法取出则返回0">
    变量 文件时间 <公开 类型 = 小数 注释 = "返回文件时间,如果无法取出则为0.">
    变量 是否为文件 <公开 类型 = 逻辑型 注释 = "真表示为文件,假表示为目录.">
}
