    方法 CA证书数据 <公开 属性写 注释 = "指定颁发者SSL证书文件数据.">
    参数 数据 <类型 = 字节集类 注释 = "提供空对象表示禁用.">
    {
        @ if (@<数据>.IsNullObject())
        @ {
        @     curl_easy_setopt(data().GetCurl(), CURLOPT_ISSUERCERT_BLOB, NULL);
        @     return;
        @ }
        @ struct curl_blob stblob;
        @ stblob.data = @<数据>.GetPtr();
        @ stblob.len = (size_t)@<数据>.GetSize();
        @ stblob.flags = CURL_BLOB_COPY;
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_ISSUERCERT_BLOB, &stblob);
    }

