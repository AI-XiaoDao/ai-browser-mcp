{
    常量 自动选择 <公开 类型 = 整数 值 = 0 注释 = "默认自动选择">
    常量 SSL优先 <公开 类型 = 整数 值 = 1 注释 = "优先SSL,失败后使用TLS.">
    常量 TLS优先 <公开 类型 = 整数 值 = 2 注释 = "优先TLS,失败后使用SSL.">
}

类 多用途扩展格式类 <公开 注释 = "用于构建邮件或HTTP多部分表单的内容." @文档 = "category = \"辅助类\"" @强制依赖 = "网络传输类">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CCurlMimeWraper)

    方法 创建 <公开 类型 = 逻辑型 注释 = "根据指定网络访问对象进行初始化." 返回值注释 = "返回是否创建成功." @禁止流程检查 = 真>
    参数 网络对象 <类型 = 网络传输类>
    {
        @ if (data().mime == NULL) 
        @     data().mime = curl_mime_init(@<网络对象>.data().GetCurl());
        @ return (data().mime != NULL);
    }
}

类 多用途扩展格式片段类 <公开 注释 = "用于构建邮件或HTTP多部分表单的分段内容." @文档 = "category = \"辅助类\"" @强制依赖 = "网络传输类">
{

    # @begin
    # <> <include>
    # curl_mimepart* part = NULL;
    # CRefObject* m_pMime = NULL;
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom);
    # inline_ void @an<_OnCleanupExtra> ()  { m_pMime->SafeRelease (); }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return (part == objCompare.part); }
    # <> </include>
    # void @sn<current_class>::@an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     part = objCopyFrom.part;
    #     CRefObject* pOldMime = m_pMime;
    #     m_pMime = objCopyFrom.m_pMime;
    #     if (m_pMime != NULL)  m_pMime->AddRef ();
    #     pOldMime->SafeRelease ();
    # }
    # @end

    方法 创建 <公开 类型 = 逻辑型 注释 = "根据指定多用途扩展格式实例进行初始化,使用任何方法之前必须先调用本方法." 返回值注释 = "返回是否创建成功." @禁止流程检查 = 真>
    参数 格式对象 <类型 = 多用途扩展格式类 注释 = "提供所基于的多用途扩展格式类对象,该对象必需已经调用其\"创建\"方法成功初始化.">
    {
        @ if (part == NULL && @<格式对象>.data().mime != NULL) {
        @     part = curl_mime_addpart (@<格式对象>.data().mime);
        @     if (part != NULL) {
        @         ASSERT (m_pMime == NULL);
        @         m_pMime = @<格式对象>.GetRefObject ();
        @         m_pMime->AddRef ();
        @     }
        @ }
        @ return (part != NULL);
    }

    方法 置数据 <公开 类型 = 整数 注释 = "将指定数据置入该片段中" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ return (part != NULL ? curl_mime_data(part, (const char *)@<数据>.GetPtr(), (size_t)@<数据>.GetSize()) : CURLE_OBJECT_NOT_INIT);
    }

    方法 置文件数据 <公开 类型 = 整数 注释 = "同\"置数据\"方法,该方法可直接提供文件名以将文件数据置入." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型>
    {
        @ return (part != NULL ? curl_mime_filedata(part, GetMbsText (@<文件名>.GetText (), CVolMem(), NULL)) : CURLE_OBJECT_NOT_INIT);
    }

    方法 置远程文件字段名称 <公开 类型 = 整数 注释 = "设置远程文件字段名称." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 字段名 <类型 = 文本型>
    {
        @ return (part != NULL ? curl_mime_filename(part, GetMbsText (@<字段名>.GetText (), CVolMem(), NULL)) : CURLE_OBJECT_NOT_INIT);
    }

    方法 置请求头 <公开 类型 = 整数 注释 = "设置当前片段数据所欲使用的自定义标头." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本数组类 注释 = "一个成员表示一个头,例如\"Custom-Header: NO\"">
    {
        @ return (part != NULL ? curl_mime_headers(part, CCurlWraper::s_create_slist (@<内容>.data ()), TRUE) : CURLE_OBJECT_NOT_INIT);
    }

    方法 编码内容 <公开 类型 = 整数 注释 = "将当前片段中的内容在传输之前进行编码." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 选项 <类型 = 文本型 注释 = "可选值:\"binary\",\"8bit\",\"7bit\",\"base64\",\"quoted-printable\".">
    {
        @ return (part != NULL ? curl_mime_encoder(part, GetMbsText (@<选项>.GetText (), CVolMem(), NULL)) : CURLE_OBJECT_NOT_INIT);
    }

    方法 置片段名称 <公开 类型 = 整数 注释 = "设置当前片段的名称." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 名称 <类型 = 文本型>
    {
        @ return (part != NULL ? curl_mime_name(part, GetMbsText (@<名称>.GetText (), CVolMem(), NULL)) : CURLE_OBJECT_NOT_INIT);
    }

    方法 置片段类型 <公开 类型 = 整数 注释 = "设置当前片段的名类型." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 类型 <类型 = 文本型 注释 = "例如:image/png">
    {
        @ return (part != NULL ? curl_mime_type(part, GetMbsText (@<类型>.GetText (), CVolMem(), NULL)) : CURLE_OBJECT_NOT_INIT);
    }

    方法 添加子片段 <公开 类型 = 整数 注释 = "添加一个子片段." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 扩展对象 <类型 = 多用途扩展格式类 注释 = "提供所欲添加子片段所在的扩展实例,注意添加完毕后本对象将被清空.">
    {
        @ INT nResult = CURLE_OBJECT_NOT_INIT;
        @ if (part != NULL && @<扩展对象>.data().mime != NULL) {
        @     nResult = curl_mime_subparts (part, @<扩展对象>.data().mime);
        @     if (nResult == CURLE_OK)  // 添加成功?
        @         @<扩展对象>.data().mime = NULL;  // 已经被片段接管,避免其自动释放.
        @ }
        @ return nResult;
    }
}

类 网络访问类 <公开 注释 = "对\"网络传输类\"的一个简单封装,提供一个请求网页资源的方法.">
{
    变量 传输对象 <公开 类型 = 网络传输类 进度反馈 = 真 快速打开 = 真>

    方法 Cookie管理文件 <公开 属性写 注释 = "提供Cookie管理文件,如果为空对象则不会管理Cookie内容(可使用\"提交协议头/提交Cookie\"参数自行提交)."
            注释 = "如提供空文本则表示在内存中管理Cookie(非持久化储存),如果指定了文件则表示持久化储存管理Cookie.">
    参数 文件 <类型 = 文本型 @默认值 = 空对象>
    {
        如果 (文本是否为空对象 (文件) == 假)
        {
            如果 (文本是否为空 (文件))
            {
                传输对象.置读Cookie文件 ()
                传输对象.置写Cookie文件 ()
            }
            否则
            {
                传输对象.置读Cookie文件 (文件)
                传输对象.置写Cookie文件 (文件)
            }
        }
        否则
        {
            传输对象.置读Cookie文件 (文件)  // 空对象置入过去等于清除原设置
            传输对象.置写Cookie文件 (文件)
        }
    }

    方法 网页访问 <公开 类型 = 网页访问响应类 注释 = "对指定网址发送请求并获取响应内容." 返回值注释 = "返回访问网页的结果.">
    参数 网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容." 编辑时信息 = "B3FF4, 0, 0, 0">
    参数 访问方式 <类型 = 网页访问方式 注释 = "提供所欲使用的请求方式." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 网页访问方式.GET>
    参数 提交信息 <类型 = 文本型 注释 = "设置本次请求所提交的数据,非POST请求也支持提交请求体,如需携带请求体务必保证该参数不为空对象,如果需要提交空请求体提供空文本内容即可." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = 空对象>
    参数 提交协议头 <类型 = 文本数组类 注释 = "提供本次请求所欲使用的附加协议头,每个成员表示一个协议." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 空对象>
    参数 提交Cookie <类型 = 文本型 注释 = "提供本次请求所欲使用的Cookie内容,注意该参数提交的内容不会同步到\"Cookie管理文件\"(不会写出至管理文件)." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = "">
    参数 内容编码 <类型 = 文本型 注释 = "指定所欲请求服务器使用的内容编码(压缩)方式,即\"Accept-Encoding\"协议内容,例如\"gzip, deflate, br\",提供空文本则自动选择,提供空对象则禁用."
            @默认值 = "">
    参数 代理地址 <类型 = 文本型 注释 = "提供所欲使用的代理地址,支持多种协议(http,https,socks4,socks4a,socks5,socks5h),例如(http协议):http://127.0.0.1:8080"
            编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理账号 <类型 = 文本型 注释 = "提供代理地址所需的用户名." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理密码 <类型 = 文本型 注释 = "提供代理地址所需的用户密码." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "指定本次完成整个请求所限定的超时时间,为-1时不限制,单位:毫秒." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 重定向次数 <类型 = 整数 注释 = "欲遵循网站重定向的最大次数,为-1时无限制,为0时禁止重定向." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 忽略SSL错误 <类型 = 逻辑型 注释 = "是否忽略任何SSL验证相关错误,即不验证证书也不验证服务器(如使用了代理将会被一同忽略)." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 真>
    参数 欲上传的本地文件 <类型 = 文本数组类 注释 = "不需要上传文件留空即可." 注释 = "提供本地文件绝对路径数组." @默认值 = 空对象>
    参数 文件对应name值 <类型 = 文本数组类 注释 = "在上传文件时通常需要提供一个\"name\"值,通常为\"file\"." 注释 = "注意:" 注释 = "    本参数的成员数务必和\"欲上传的本地文件\"成员数保持一致."
            注释 = "    当本参数为空,且\"欲上传的本地文件\"参数不为空时,本参数默认提供\"file\"." 注释 = "    多个文件依次提供\"file\",\"file-1\",\"file-N\"..." @默认值 = 空对象>
    参数 内容类型 <类型 = 文本数组类 注释 = "提供Content-Type值,留空提供\"application/x-www-form-urlencoded\"."
            注释 = "注意:本参数的成员数务必和\"欲上传的本地文件\"成员数保持一致." @默认值 = 空对象>
    {
        变量 提交内容 <类型 = 字节集类>
        如果 (文本是否为空对象 (提交信息) == 假)
        {
            如果 (文本是否为空 (提交信息) == 假)
            {
                提交内容 = 文本到多字节 (提交信息, 假)
            }
            // 否则提供0长度,空请求体
        }
        否则
        {
            提交内容.重置为空对象 ()  // 空对象标志
        }
        返回 (网页访问2 (网址, 访问方式, 提交内容, 提交协议头, 提交Cookie, 内容编码, 代理地址, 代理账号, 代理密码, 超时时间, 重定向次数, 忽略SSL错误, 欲上传的本地文件, 文件对应name值, 内容类型))
    }

    方法 网页访问2 <公开 类型 = 网页访问响应类 注释 = "与\"网页访问\"命令基本一致,不同的是本方法提交的请求体内容为字节集类型." 返回值注释 = "返回访问网页的结果.">
    参数 网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容." 编辑时信息 = "B3FF4, 0, 0, 0">
    参数 访问方式 <类型 = 网页访问方式 注释 = "提供所欲使用的请求方式." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 网页访问方式.GET>
    参数 提交信息 <类型 = 字节集类 注释 = "设置本次请求所提交的数据,非POST请求也支持提交请求体,如需携带请求体务必保证该参数不为空对象,如果需要提交空请求体提供空字节集即可." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = 空对象>
    参数 提交协议头 <类型 = 文本数组类 注释 = "提供本次请求所欲使用的附加协议头,每个成员表示一个协议." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 空对象>
    参数 提交Cookie <类型 = 文本型 注释 = "提供本次请求所欲使用的Cookie内容,注意该参数提交的内容不会同步到\"Cookie管理文件\"(不会写出至管理文件)." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = "">
    参数 内容编码 <类型 = 文本型 注释 = "指定所欲请求服务器使用的内容编码(压缩)方式,即\"Accept-Encoding\"协议内容,例如\"gzip, deflate, br\",提供空文本则自动选择,提供空对象则禁用."
            @默认值 = "">
    参数 代理地址 <类型 = 文本型 注释 = "提供所欲使用的代理地址,支持多种协议(http,https,socks4,socks4a,socks5,socks5h),例如(http协议):http://127.0.0.1:8080"
            编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理账号 <类型 = 文本型 注释 = "提供代理地址所需的用户名." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理密码 <类型 = 文本型 注释 = "提供代理地址所需的用户密码." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "指定本次完成整个请求所限定的超时时间,为-1时不限制,单位:毫秒." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 重定向次数 <类型 = 整数 注释 = "欲遵循网站重定向的最大次数,为-1时无限制,为0时禁止重定向." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 忽略SSL错误 <类型 = 逻辑型 注释 = "是否忽略任何SSL验证相关错误,即不验证证书也不验证服务器(如使用了代理将会被一同忽略)." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 真>
    参数 欲上传的本地文件 <类型 = 文本数组类 注释 = "不需要上传文件留空即可." 注释 = "提供本地文件绝对路径数组." 折叠2 @默认值 = 空对象>
    参数 文件对应name值 <类型 = 文本数组类 注释 = "在上传文件时通常需要提供一个\"name\"值,通常为\"file\"." 注释 = "注意:" 注释 = "    本参数的成员数务必和\"欲上传的本地文件\"成员数保持一致."
            注释 = "    当本参数为空,且\"欲上传的本地文件\"参数不为空时,本参数默认提供\"file\"." 注释 = "    多个文件依次提供\"file\",\"file-1\",\"file-N\"..." 折叠2
            @默认值 = 空对象>
    参数 内容类型 <类型 = 文本数组类 注释 = "提供Content-Type值,留空提供\"application/x-www-form-urlencoded\"."
            注释 = "注意:本参数的成员数务必和\"欲上传的本地文件\"成员数保持一致." 折叠2 @默认值 = 空对象>
    {
        传输对象.地址 = 网址
        如果 (访问方式 == 网页访问方式.GET)
        {
            传输对象.置请求方式 ("GET")
        }
        否则 (访问方式 == 网页访问方式.POST)
        {
            传输对象.置请求方式 ("POST")
        }
        否则 (访问方式 == 网页访问方式.HEAD)
        {
            传输对象.置请求方式 ("HEAD")
        }
        否则 (访问方式 == 网页访问方式.PUT)
        {
            传输对象.置请求方式 ("PUT")
        }
        否则 (访问方式 == 网页访问方式.OPTIONS)
        {
            传输对象.置请求方式 ("OPTIONS")
        }
        否则 (访问方式 == 网页访问方式.DELETE)
        {
            传输对象.置请求方式 ("DELETE")
        }
        否则 (访问方式 == 网页访问方式.TRACE)
        {
            传输对象.置请求方式 ("TRACE")
        }
        否则 (访问方式 == 网页访问方式.CONNECT)
        {
            传输对象.置请求方式 ("CONNECT")
        }
        否则 (访问方式 == 网页访问方式.PATCH)
        {
            传输对象.置请求方式 ("PATCH")
        }
        否则
        {
            传输对象.置请求方式 ("GET")
        }
        传输对象.置请求头 (提交协议头)
        传输对象.置Cookie内容 (提交Cookie)
        如果 (是否为空对象 (提交信息) == 假)
        {
            如果 (提交信息.取字节集长度 () > 0)
            {
                传输对象.置提交数据 (提交信息)
            }
            否则
            {
                传输对象.置提交数据 (空对象, 假)
                传输对象.置提交数据尺寸 (0)
            }
        }
        否则
        {
            传输对象.置提交数据尺寸 (0)
        }
        如果 (访问方式 == 网页访问方式.HEAD)
        {
            传输对象.忽略主体请求 = 真
        }
        否则
        {
            传输对象.忽略主体请求 = 假
        }
        传输对象.编码内容 = 内容编码  // 覆盖提交协议头里的Accept-Encoding,如果仅提交协议头返回的内容不会自动解码!
        如果 (重定向次数 == 0)
        {
            传输对象.遵循重定向 = 假
        }
        否则
        {
            传输对象.遵循重定向 = 真
            传输对象.重定向最大次数 = 重定向次数
        }
        传输对象.代理地址 = 代理地址
        传输对象.代理身份验证账号 = 代理账号
        传输对象.代理身份验证密码 = 代理密码
        如果 (超时时间 <= 0)
        {
            传输对象.请求超时 = 0
        }
        否则
        {
            传输对象.请求超时 = 超时时间
        }
        如果 (忽略SSL错误)
        {
            传输对象.SSL证书检查 = 假
            传输对象.SSL验证证书主机名 = 假
            传输对象.SSL代理证书检查 = 假
            传输对象.SSL代理验证证书主机名 = 假
        }
        变量 表单 <类型 = 多用途扩展格式类>
        如果 (欲上传的本地文件 != 空对象)
        {
            表单.创建 (传输对象)  // 必须先根据传输对象创建表单
            欲上传的本地文件.枚举循环 ()
            {
                变量 子片段 <类型 = 多用途扩展格式片段类>
                子片段.创建 (表单)  // 基于此表单添加一个片段
                子片段.置文件数据 (欲上传的本地文件.取枚举值 ())  // 直接添加欲上传的文件
                如果 (文件对应name值 == 空对象)
                {
                    如果 (欲上传的本地文件.取枚举索引 () == 0)
                    {
                        子片段.置片段名称 ("file")  // 对应name值
                    }
                    否则
                    {
                        子片段.置片段名称 ("file-" + 到文本 (欲上传的本地文件.取枚举索引 ()))  // 对应name值
                    }
                }
                否则
                {
                    如果 (欲上传的本地文件.取成员数 () <= 文件对应name值.取成员数 ())  // 防止索引超出成员数
                    {
                        子片段.置片段名称 (文件对应name值.取成员 (欲上传的本地文件.取枚举索引 ()))
                    }
                }
                如果 (内容类型 == 空对象)
                {
                    子片段.置片段类型 ("application/x-www-form-urlencoded")
                }
                否则
                {
                    如果 (欲上传的本地文件.取成员数 () <= 内容类型.取成员数 ())  // 防止索引超出成员数
                    {
                        子片段.置片段类型 (内容类型.取成员 (欲上传的本地文件.取枚举索引 ()))  // 对应Content-Type头
                    }
                }
                子片段.置远程文件字段名称 (传输对象.URL编码 (文本到UTF8 (取文件名无路径部分 (欲上传的本地文件.取枚举值 ()), 假)))  // 对应filename
            }
            传输对象.置表单数据 (表单)  // 将组合完毕的表单置入,直接发送请求即可
        }
        变量 返回结果 <类型 = 网页访问响应类>
        传输对象.发送请求 (返回结果.请求结果, 返回结果.响应头)
        // 返回结果.Cookies = 传输对象.取所有Cookie ()    //会同时取出整个持久化管理的Cookie
        返回结果.响应头.枚举循环 ()
        {
            变量 当前值 <类型 = 文本型>
            当前值 = 返回结果.响应头.取枚举值 ()
            变量 键名 <类型 = 文本型>
            变量 键值 <类型 = 文本型>
            分割左右文本 (当前值, ':', 键名, 键值)
            如果 (键名 == "Set-Cookie")
            {
                返回结果.Cookies.加入成员 (键值)
            }
            如果 (键名 == "Location")
            {
                返回结果.重定向地址 = 键值
            }
            如果 (键名 == "Content-Type")
            {
                返回结果.内容类型 = 键值
            }
            如果 (键名 == "Content-MD5")
            {
                返回结果.内容MD5 = 键值
            }
            如果 (键名 == "Content-Encoding")
            {
                返回结果.内容编码 = 键值
            }
            如果 (键名 == "Content-Length")
            {
                返回结果.内容长度 = 文本到长整数 (键值)
            }
        }
        返回结果.重定向次数 = 传输对象.取重定向次数 ()
        如果 (文本是否为空 (返回结果.重定向地址))
        {
            返回结果.重定向地址 = 传输对象.取重定向地址 ()  // 返回的协议头里面没有,尝试通过内置方法获取.
        }
        // 返回结果.重定向地址 = 传输对象.取重定向地址 ()    //Curl对象无法获取,改用请求头方式取
        返回结果.响应码 = 传输对象.取上次请求响应码 ()
        返回结果.请求耗时 = 传输对象.取接收时长 ()
        返回 (返回结果)
    }

    变量 文件读写 <静态 类型 = 文件读写类>
    变量 文件下载保存位置 <类型 = 文本型 注释 = "当下载文件的时候,本变量用于临时存储文件下载保存位">

    方法 下载文件 <公开 类型 = 网页访问响应类 注释 = "与\"网页访问\"命令基本一致,不同的是本方法用于下载文件." 注释 = "如果需要暂停,调用\"暂停下载\"即可."
            返回值注释 = "返回访问网页的结果,注意本方法的返回\"请求结果\"无数据,访问结果将直接保存成文件.">
    参数 网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容." 编辑时信息 = "B3FF4, 0, 0, 0">
    参数 访问方式 <类型 = 网页访问方式 注释 = "提供所欲使用的请求方式." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 网页访问方式.GET>
    参数 提交信息 <类型 = 字节集类 注释 = "设置本次请求所提交的数据,非POST请求也支持提交请求体,如需携带请求体务必保证该参数不为空对象,如果需要提交空请求体提供空字节集即可." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = 空对象>
    参数 提交协议头 <类型 = 文本数组类 注释 = "提供本次请求所欲使用的附加协议头,每个成员表示一个协议." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 空对象>
    参数 提交Cookie <类型 = 文本型 注释 = "提供本次请求所欲使用的Cookie内容,注意该参数提交的内容不会同步到\"Cookie管理文件\"(不会写出至管理文件)." 编辑时信息 = "B3FF4, 0, 0, 0"
            @默认值 = "">
    参数 内容编码 <类型 = 文本型 注释 = "指定所欲请求服务器使用的内容编码(压缩)方式,即\"Accept-Encoding\"协议内容,例如\"gzip, deflate, br\",提供空文本则自动选择,提供空对象则禁用."
            @默认值 = "">
    参数 代理地址 <类型 = 文本型 注释 = "提供所欲使用的代理地址,支持多种协议(http,https,socks4,socks4a,socks5,socks5h),例如(http协议):http://127.0.0.1:8080"
            编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理账号 <类型 = 文本型 注释 = "提供代理地址所需的用户名." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 代理密码 <类型 = 文本型 注释 = "提供代理地址所需的用户密码." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "指定本次完成整个请求所限定的超时时间,为-1时不限制,单位:毫秒." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 重定向次数 <类型 = 整数 注释 = "欲遵循网站重定向的最大次数,为-1时无限制,为0时禁止重定向." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = -1>
    参数 忽略SSL错误 <类型 = 逻辑型 注释 = "是否忽略任何SSL验证相关错误,即不验证证书也不验证服务器(如使用了代理将会被一同忽略)." 编辑时信息 = "B3FF4, 0, 0, 0" @默认值 = 真>
    参数 文件保存位置 <类型 = 文本型 注释 = "提供保存到本地的文件名">
    参数 覆盖策略 <类型 = 网页访问覆盖策略 注释 = "提供下载覆盖策略,默认为覆盖文件." 注释 = "如果提供的参数值为\"网页访问覆盖策略.自定义断点续传\",某些服务器可能需要自定义协议头才能进行断点续传."
            注释 = "这时需要您在\"提交协议头\"参数中提供对应的协议头信息." @默认值 = 网页访问覆盖策略.覆盖文件>
    {
        文件下载保存位置 = 文件保存位置
        变量 网络文件尺寸 <类型 = 长整数>
        网络文件尺寸 = 网页访问2 (网址, 网页访问方式.HEAD, 提交信息, 提交协议头, 提交Cookie, 内容编码, 代理地址, 代理账号, 代理密码, 超时时间, 重定向次数, 忽略SSL错误).内容长度
        传输对象.置请求方式 (多项选择 ((整数)访问方式, "GET", "POST", "HEAD", "PUT", "OPTIONS", "DELETE", "TRACE", "CONNECT", "PATCH"))
        传输对象.忽略主体请求 = 访问方式 == 网页访问方式.HEAD
        如果 (文件读写.是否已打开 () == 假)
        {
            文件读写.打开文件 (文件保存位置, 选择 (文件是否存在 (文件保存位置) && 覆盖策略 == 网页访问覆盖策略.覆盖文件, 文件打开方式.重写, 文件打开方式.改写))
        }
        如果 (文件读写.取文件长度 () > 0 && 文件读写.取文件长度 () < 网络文件尺寸)  // 尝试使用内置的断点续传方式
        {
            如果 (覆盖策略 == 网页访问覆盖策略.断点续传)
            {
                传输对象.请求数据范围 = 到文本 (文件读写.取文件长度 ()) + "-" + 到文本 (网络文件尺寸)  // 指定所欲下载文件的范围(不是所有服务器都支持!)    //格式为 "起始下载位置-文件总尺寸"
            }
        }
        否则 (文件读写.取文件长度 () > 网络文件尺寸)  // 文件尺寸异常?
        {
            文件读写.打开文件 (文件保存位置, 文件打开方式.重写)
        }
        传输对象.置写入数据回调函数 (写入数据回调)
        变量 返回结果 <类型 = 网页访问响应类>
        传输对象.发送请求 (, 返回结果.响应头)  // 这里不能返回响应数据否则会导致下载无效.
        <折叠> 返回结果.响应头.枚举循环 ()
        {
            变量 当前值 <类型 = 文本型>
            当前值 = 返回结果.响应头.取枚举值 ()
            变量 键名 <类型 = 文本型>
            变量 键值 <类型 = 文本型>
            分割左右文本 (当前值, ':', 键名, 键值)
            如果 (键名 == "Set-Cookie")
            {
                返回结果.Cookies.加入成员 (键值)
            }
            如果 (键名 == "Location")
            {
                返回结果.重定向地址 = 键值
            }
            如果 (键名 == "Content-Type")
            {
                返回结果.内容类型 = 键值
            }
            如果 (键名 == "Content-MD5")
            {
                返回结果.内容MD5 = 键值
            }
            如果 (键名 == "Content-Encoding")
            {
                返回结果.内容编码 = 键值
            }
            如果 (键名 == "Content-Length")
            {
                返回结果.内容长度 = 文本到长整数 (键值)
            }
        }
        返回结果.重定向次数 = 传输对象.取重定向次数 ()
        如果 (文本是否为空 (返回结果.重定向地址))
        {
            返回结果.重定向地址 = 传输对象.取重定向地址 ()  // 返回的协议头里面没有,尝试通过内置方法获取.
        }
        返回结果.响应码 = 传输对象.取上次请求响应码 ()
        返回结果.请求耗时 = 传输对象.取接收时长 ()
        返回 (返回结果)
    }

    方法 写入数据回调 <静态 类型 = 变整数 注释 = "\"置写入数据回调函数\"对应的方法模板." 返回值注释 = "返回所处理的数据长度." @视窗.前缀文本 = "@CDECL">
    参数 数据 <类型 = 变整数 注释 = "本次回调提供的数据指针.">
    参数 数据尺寸 <类型 = 变整数 注释 = "本次回调提供单个数据的长度,即总长度应为 \"数据尺寸\"*\"数据数量\".">
    参数 数据数量 <类型 = 变整数 注释 = "本次回调提供数据的个数.">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    {
        文件读写.移到文件尾 ()
        文件读写.写出字节集 (指针到字节集 (数据, (整数)数据尺寸 * (整数)数据数量))
        返回 (数据尺寸 * 数据数量)
    }

    方法 继续 <公开 类型 = 逻辑型 注释 = "继续当前下载或上传任务." 返回值注释 = "失败返回假,可能是文件被占用.">
    参数 继续下载 <类型 = 逻辑型 注释 = "提供真则继续下载任务,否则表示继续上传任务.">
    {
        如果 (继续下载 && 文件读写.是否已打开 () == 假)
        {
            如果 (文件读写.打开文件 (文件下载保存位置, 文件打开方式.改写) == 假)  // 打开失败?
            {
                返回 (假)
            }
        }
        返回 (传输对象.继续传输 () == 0)
    }

    方法 暂停 <公开 注释 = "暂停当前下载或上传任务,重新访问调用\"继续\"方法即可.">
    参数 是否关闭文件 <类型 = 逻辑型 注释 = "是否关闭文件占用,如果为上传任务本参数无效.">
    {
        传输对象.暂停传输 ()
        如果 (是否关闭文件)
        {
            文件读写.关闭文件 ()  // 主要针对下载任务关闭文件占用
        }
    }

    方法 URL编码 <公开 类型 = 文本型 注释 = "将指定文本内容进行URL编码后返回.">
    参数 欲编码内容 <类型 = 文本型 注释 = "提供所欲编码的文本内容.">
    参数 是否UTF8 <类型 = 逻辑型 注释 = "是否将该文本内容以UTF8方式编码." @默认值 = 真>
    {
        如果 (是否UTF8)
        {
            返回 (传输对象.URL编码 (文本到UTF8 (欲编码内容, 假)))
        }
        否则
        {
            返回 (传输对象.URL编码 (文本到多字节 (欲编码内容, 假)))
        }
    }

    方法 URL解码 <公开 类型 = 文本型 注释 = "将指定URL编码的内容进行解码后返回." 折叠>
    参数 欲解码内容 <类型 = 文本型 注释 = "提供所欲解码的文本内容.">
    参数 是否UTF8 <类型 = 逻辑型 注释 = "是否将该文本内容以UTF8方式解码." @默认值 = 真>
    {
        如果 (是否UTF8)
        {
            返回 (UTF8到文本 (传输对象.URL解码 (欲解码内容)))
        }
        否则
        {
            返回 (多字节到文本 (传输对象.URL解码 (欲解码内容)))
        }
    }

    方法 网络传输类_传输进度发生改变 <接收事件 类型 = 整数 注释 = "当传输进度发生改变时,本事件将被调用多次直到整个传输结束.">
    参数 来源对象 <类型 = 网络传输类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 下载总量 <类型 = 长整数 注释 = "预计需要下载的字节数.">
    参数 当前下载 <类型 = 长整数 注释 = "当前已下载的字节数.">
    参数 上传总量 <类型 = 长整数 注释 = "预计需要上传的字节数.">
    参数 当前上传 <类型 = 长整数 注释 = "当前已上传的字节数.">
    {
        如果 (下载总量 != 0 && 当前下载 >= 下载总量)
        {
            文件读写.关闭文件 ()  // 下载完毕关闭文件
        }
        返回 (访问进度改变 (下载总量, 当前下载, 上传总量, 当前上传))
    }

    方法 访问进度改变 <公开 定义事件 类型 = 整数 注释 = "在发送请求过程中如果请求进度发生改变,将会响应本事件.">
    参数 下载总量 <类型 = 长整数 注释 = "预计需要下载的字节数.">
    参数 当前下载 <类型 = 长整数 注释 = "当前已下载的字节数.">
    参数 上传总量 <类型 = 长整数 注释 = "预计需要上传的字节数.">
    参数 当前上传 <类型 = 长整数 注释 = "当前已上传的字节数.">
}

类 网页访问响应类 <公开 基础类 = 扩展对象类 注释 = "包含网页访问所返回的结果内容.">
{
    变量 请求结果 <公开 类型 = 字节集类 注释 = "本次请求所返回的结果数据." @属性变量 = 真>
    变量 Cookies <公开 类型 = 文本数组类 注释 = "本次请求所返回的Cookie内容." @属性变量 = 真>
    变量 响应头 <公开 类型 = 文本数组类 注释 = "本次请求所接收到服务器的响应头内容." @属性变量 = 真>
    变量 重定向地址 <公开 类型 = 文本型 注释 = "本次请求最终的重定向地址." @属性变量 = 真>
    变量 重定向次数 <公开 类型 = 整数 注释 = "本次请求所遵循重定向的次数." @属性变量 = 真>
    变量 响应码 <公开 类型 = 整数 注释 = "本次请求的HTTP状态码." @属性变量 = 真>
    变量 请求耗时 <公开 类型 = 长整数 注释 = "本次请求所耗时长(毫秒)." @属性变量 = 真>
    变量 内容类型 <公开 类型 = 文本型 注释 = "响应内容类型(Content-Type)" @属性变量 = 真>
    变量 内容MD5 <公开 类型 = 文本型 注释 = "响应内容md5(Content-MD5)" @属性变量 = 真>
    变量 内容编码 <公开 类型 = 文本型 注释 = "响应内容的编码方式，例如gzip、compress等(Content-Encoding)" @属性变量 = 真>
    变量 内容长度 <公开 类型 = 长整数 注释 = "响应内容字节长度(Content-Length)" @属性变量 = 真>

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = UTF8到文本 (请求结果)
    }

    方法 取结果文本 <公开 类型 = 文本型 注释 = "取出请求结果所对应的文本内容">
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供网页编码类型,默认为utf8编码,如果是gbk网页请使用\"文本编码类型.多字节\"." @默认值 = 文本编码类型.UTF8>
    {
        如果 (文本编码 == 文本编码类型.多字节)
        {
            返回 (多字节到文本 (请求结果))
        }
        否则 (文本编码 == 文本编码类型.UTF16)
        {
            返回 (字节集到文本 (请求结果))
        }
        返回 (UTF8到文本 (请求结果))
    }
}

类 网页访问覆盖策略 <公开 注释 = "主要为\"下载文件\"方法提供下载策略支持." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 覆盖文件 <公开 值 = 0 注释 = "当文件存在的时候覆盖文件">
    常量 断点续传 <公开 值 = 1 注释 = "如果文件存在的时候尝试断点续传,文件不存在直接下载.">
    常量 自定义断点续传 <公开 值 = 2 注释 = "某些服务器可能需要自定义协议头才能进行断点续传." 注释 = "提供本常亮后需要您自行在\"下载文件\"方法的\"提交协议头\"参数中提供相应的协议信息可以实现断点续传.">
}

类 网页访问方式 <公开 注释 = "包含网页访问的请求方式." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 GET <公开 值 = 0>
    常量 POST <公开 值 = 1>
    常量 HEAD <公开 值 = 2>
    常量 PUT <公开 值 = 3>
    常量 OPTIONS <公开 值 = 4>
    常量 DELETE <公开 值 = 5>
    常量 TRACE <公开 值 = 6>
    常量 CONNECT <公开 值 = 7>
    常量 PATCH <公开 值 = 8>
}

# ===

类 邮件发送类 <公开 注释 = "支持基于SMTP协议发送邮件." 注释 = "电子邮件接收请使用\"电子邮件接收\"类库中的\"邮件接收类\"." @视窗.外部头文件 = "vol\\mail\\vol_curl_send_mail.h"
        @视窗.外部源文件 = "vol\\mail\\vol_curl_send_mail.cpp">
{
    变量 发信服务器 <公开 类型 = 文本型 注释 = "提供所使用的SMTP服务器地址" @属性变量 = 真>
    变量 端口号 <公开 类型 = 整数 值 = 25 注释 = "指定欲连接到SMTP邮件服务器上的端口号(smtp默认25,smtps默认是465)" @属性变量 = 真>
    变量 用户名 <公开 类型 = 文本型 注释 = "提供登录发信服务器的用户名,如无则为空文本." @属性变量 = 真>
    变量 密码 <公开 类型 = 文本型 注释 = "提供登录发信服务器的密码,如无则为空文本." @属性变量 = 真>
    变量 ""
    变量 成员_传输对象 <类型 = 网络传输类 注释 = "所使用的网络传输对象" 启用SSL级别 = 3 SSL版本 = SSL版本类型.TLSv1_3 SSL证书检查 = 假 SSL验证证书主机名 = 假>
    变量 成员_发信人邮件地址 <类型 = 文本型 注释 = "提供发信人的邮件地址,本属性值不能为空.">
    变量 成员_发信人友好名称 <类型 = 文本型 注释 = "提供发信人的友好名称,如: \"递归软件开发有限公司\",为空文本表示无.">
    变量 成员_邮件回复地址 <类型 = 文本型 注释 = "提供邮件的回复邮件地址,为空文本表示无.">
    变量 成员_邮件标题 <类型 = 文本型 注释 = "提供所发送邮件的标题文本">
    变量 成员_邮件正文 <类型 = 文本型 注释 = "提供所发送邮件的正文内容">
    变量 成员_邮件正文媒体格式 <类型 = 文本型 值 = "text/plain" 注释 = "提供所发送邮件正文内容的媒体格式,常用的有如下几种:" 注释 = "  \"text/plain\": 纯文本"
            注释 = "  \"text/html\": html文本" 注释 = "  \"text/xml\": xml文本">
    变量 成员_附件数据数组 <类型 = 字节集数组类>
    变量 成员_附件文件名 <类型 = 文本数组类>

    方法 传输对象 <公开 属性读 类型 = 网络传输类 注释 = "提供所使用的网络传输对象,用户可以修改此对象的各种属性值以指定相关网络传输参数.">
    {
        返回 (成员_传输对象)
    }

    方法 发信人邮件地址 <公开 属性读 类型 = 文本型 注释 = "提供发信人的邮件地址">
    {
        返回 (成员_发信人邮件地址)
    }

    方法 发信人邮件地址 <公开 属性写 注释 = "设置发信人的邮件地址,本属性值不能为空.">
    参数 发信人邮件地址内容 <类型 = 文本型>
    {
        如果 (成员_发信人邮件地址 != 发信人邮件地址内容)
        {
            成员_发信人邮件地址 = 发信人邮件地址内容
            @ m_u8strPrepareContent.Empty ();  // 清空所准备的预处理内容
        }
    }

    方法 发信人友好名称 <公开 属性读 类型 = 文本型 注释 = "提供发信人的友好名称,如: \"递归软件开发有限公司\",为空文本表示无.">
    {
        返回 (成员_发信人友好名称)
    }

    方法 发信人友好名称 <公开 属性写 注释 = "设置发信人的友好名称,如: \"递归软件开发有限公司\",为空文本表示无.">
    参数 发信人友好名称内容 <类型 = 文本型>
    {
        如果 (成员_发信人友好名称 != 发信人友好名称内容)
        {
            成员_发信人友好名称 = 发信人友好名称内容
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 邮件回复地址 <公开 属性读 类型 = 文本型 注释 = "提供邮件的回复邮件地址,为空文本表示无.">
    {
        返回 (成员_邮件回复地址)
    }

    方法 邮件回复地址 <公开 属性写 注释 = "设置即将发送邮件的回复邮件地址,为空文本表示无.">
    参数 邮件回复地址内容 <类型 = 文本型>
    {
        如果 (成员_邮件回复地址 != 邮件回复地址内容)
        {
            成员_邮件回复地址 = 邮件回复地址内容
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 邮件标题 <公开 属性读 类型 = 文本型 注释 = "提供所发送邮件的标题文本">
    {
        返回 (成员_邮件标题)
    }

    方法 邮件标题 <公开 属性写 注释 = "设置即将发送邮件的标题文本">
    参数 邮件标题内容 <类型 = 文本型>
    {
        如果 (成员_邮件标题 != 邮件标题内容)
        {
            成员_邮件标题 = 邮件标题内容
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 邮件正文 <公开 属性读 类型 = 文本型 注释 = "返回所设置的邮件正文内容">
    {
        返回 (成员_邮件正文)
    }

    方法 邮件正文 <公开 属性写 注释 = "设置即将发送邮件的正文内容">
    参数 正文内容 <类型 = 文本型>
    {
        如果 (成员_邮件正文 != 正文内容)
        {
            成员_邮件正文 = 正文内容
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 正文媒体格式 <公开 属性读 类型 = 文本型 注释 = "返回所设置的邮件正文媒体格式">
    {
        返回 (成员_邮件正文媒体格式)
    }

    方法 正文媒体格式 <公开 属性写 注释 = "设置即将发送邮件的正文媒体格式. 本属性值不能为空.">
    参数 媒体格式 <类型 = 文本型 注释 = "提供所欲设置的邮件正文媒体格式,常用的有如下几种:" 注释 = "  \"text/plain\": 纯文本 (为本属性默认值)" 注释 = "  \"text/html\": html文本">
    {
        如果 (成员_邮件正文媒体格式 != 媒体格式)
        {
            成员_邮件正文媒体格式 = 媒体格式
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 添加附件 <公开 类型 = 逻辑型 注释 = "添加即将发送邮件的附件数据" 返回值注释 = "成功返回真,失败返回假.">
    参数 附件数据 <类型 = 字节集类 注释 = "提供所欲添加的附件数据,不能为空.">
    参数 附件文件名 <类型 = 文本型 注释 = "提供附件数据所对应的文件名,其路径部分将被去除.">
    {
        如果 (字节集是否为空 (附件数据))
        {
            返回 (假)
        }
        成员_附件数据数组.加入成员 (附件数据)
        成员_附件文件名.加入成员 (取文件名无路径部分 (附件文件名))
        @ m_u8strPrepareContent.Empty ();
        返回 (真)
    }

    方法 添加文件附件 <公开 类型 = 逻辑型 注释 = "读入所指定文件的数据,将其添加到即将发送邮件的附件中." 返回值注释 = "成功返回真,失败返回假.">
    参数 附件文件名 <类型 = 文本型>
    {
        返回 (添加附件 (读入文件 (附件文件名), 附件文件名))
    }

    方法 删除所有附件 <公开 注释 = "删除即将发送邮件的所有附件数据">
    {
        如果 (成员_附件数据数组.是否为空 () == 假)
        {
            成员_附件数据数组.删除所有成员 ()
            成员_附件文件名.删除所有成员 ()
            @ m_u8strPrepareContent.Empty ();
        }
    }

    方法 发送邮件 <公开 类型 = 整数 注释 = "  发送邮件到所指定邮件地址." 注释 = "  注意: 为了最大限度地支持资源重用和提高邮件批量发送速度,邮件发送完毕后"
            注释 = "并不会立即释放相关资源及与SMTP服务器断开连接,因此当本对象持续存在且本批" 注释 = "次所有邮件均发送完毕暂时不会再发送邮件时,最好手动调用\"清理\"方法释放相关"
            注释 = "资源并通知所连接的SMTP服务器断开连接,以避免由于连接空闲太长时间而导致" 注释 = "SMTP服务器主动超时出错断开." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    参数 收件人邮件地址 <类型 = 文本型 注释 = "提供所有收件人邮件地址,多个邮件地址之间使用逗号分隔. 不能为空.">
    参数 抄送邮件地址 <类型 = 文本型 注释 = "提供所有抄送到的邮件地址,多个邮件地址之间使用逗号分隔. 为空文本表示无." @默认值 = "">
    参数 密送邮件地址 <类型 = 文本型 注释 = "提供所有秘密送达的邮件地址,多个邮件地址之间使用逗号分隔. 为空文本表示无." 注释 = "密送的邮件地址,上面的收件人/抄送人/其它密送人都看不到." @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "指定发送完邮件所限定的超时时间,小于等于0表示不限制,单位:毫秒." @默认值 = 0>
    {
        如果 (端口号 == 465)
        {
            如果 (是否以文本开头 (发信服务器, "smtp://", 假))  // 使用了加密端口,判断是否使用了错误的协议.
            {
                子文本替换 (发信服务器, "smtp://", "smtps://", , 1, 假)  // 替换为正确协议
            }
            否则 (是否以文本开头 (发信服务器, "smtps://", 假) == 假)
            {
                发信服务器 = "smtps://" + 发信服务器
            }
        }
        @ if (m_u8strPrepareContent.IsEmpty ()) {  // 尚未进行预处理?
        @     if (CVolCurlMailSender::sPrepareSendingMail (@<成员_发信人邮件地址>.GetText (), @<成员_发信人友好名称>.GetText (), @<成员_邮件回复地址>.GetText (),
        @             @<成员_邮件标题>.GetText (), @<成员_邮件正文>.GetText (), @<成员_邮件正文媒体格式>.GetText (), @<成员_附件数据数组>, @<成员_附件文件名>.data (), m_u8strPrepareContent) == FALSE)
        @         return CURLE_INVALID_PARAM;
        @ }
        成员_传输对象.请求超时 = 取较大值 (0, 超时时间)
        @ return CVolCurlMailSender::sSendMail (@<成员_传输对象>.data ().GetCurl (), @<发信服务器>.GetText (), @<端口号>, @<用户名>.GetText (), @<密码>.GetText (), @<成员_发信人邮件地址>.GetText (),
        @         @<收件人邮件地址>.GetText (), @<抄送邮件地址>.GetText (), @<密送邮件地址>.GetText (), m_u8strPrepareContent.GetText ());
    }

    方法 清理 <公开 注释 = "  为了最大限度地支持资源重用和提高邮件批量发送速度,邮件发送完毕后并不会" 注释 = "立即释放相关资源及与SMTP服务器断开连接,因此当本批次所有邮件均发送完毕暂"
            注释 = "时不会再发送邮件时,最好手动调用本方法释放相关资源并通知所连接的SMTP服务" 注释 = "器断开连接,以避免由于连接空闲太长时间而导致SMTP服务器主动超时出错断开." 注释 = "注意:"
            注释 = "  1. 本方法调用不是必需的,本类对象被销毁时会自动进行清理;" 注释 = "  2. 调用本方法后,所有先前对\"传输对象\"进行过的属性设置需要重新设置.">
    {
        传输对象.清理 ()
        @ InitCurlAttr ();
    }

    # @ <include>
    # @ CU8String m_u8strPrepareContent;  // 用作记录即将发送邮件的预处理内容
    # @ inline_ void @an<_OnInitExtra> () { InitCurlAttr (); }
    # @ inline_ void InitCurlAttr () {
    # @     CURL* pCurl = @<成员_传输对象>.data ().GetCurl ();
    # @     curl_easy_setopt (pCurl, CURLOPT_LOGIN_OPTIONS, "AUTH=LOGIN");
    # @     curl_easy_setopt (pCurl, CURLOPT_SSL_VERIFYPEER, 0L);
    # @     curl_easy_setopt (pCurl, CURLOPT_SSL_VERIFYHOST, 0L);
    # @ }
    # @ </include>
}

