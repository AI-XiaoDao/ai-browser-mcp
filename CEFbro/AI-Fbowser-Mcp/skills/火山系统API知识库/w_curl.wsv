    参数 内容 <类型 = 文本型 注释 = "提供所欲禁用的代理地址,如需禁用多个请使用逗号(,)分隔,如需禁用所有代理请提供*通配符,提供空文本表示禁用该功能.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_NOPROXY, (@<内容>.IsEmpty() ? NULL : GetMbsText (@<内容>.GetText (), CVolMem(), NULL)));
    }

    方法 URL编码 <公开 类型 = 文本型 注释 = "将指定的数据进行URL编码后返回." 返回值注释 = "如编码失败将返回空文本.">
    参数 待编码内容 <类型 = 字节集类 注释 = "提供所欲进行URL编码的数据.">
    {
        如果 (待编码内容.取字节集长度 () == 0)
        {
            返回 ("")
        }
        变量 内容 <类型 = 文本型>
        @ char * en = curl_easy_escape(data().GetCurl(), (const CHAR*)@<待编码内容>.GetPtr(), (INT)@<待编码内容>.GetSize());
        @ @<内容>.SetText(en);
        @ curl_free(en);
        返回 (内容)
    }

    方法 URL解码 <公开 类型 = 字节集类 注释 = "将指定的URL编码的文本内容进行URL解码后返回." 返回值注释 = "如解码失败将返回空数据." @禁止流程检查 = 真>
    参数 待解码内容 <类型 = 文本型 注释 = "提供所欲进行URL解码的数据.">
    {
        @ @an<CVolMem> mem;
        @ if (@<待解码内容>.IsEmpty ())
        @     return mem;
        @ INT_P len;
        @ const CHAR* ps = GetMbsText (@<待解码内容>.GetText (), mem, &len);
        @ INT outLen;
        @ char * en = curl_easy_unescape(data().GetCurl(), ps, (INT)len, &outLen);
        @ @an<CVolMem> buf(en, outLen);
        @ curl_free(en);
        @ return buf;
    }

