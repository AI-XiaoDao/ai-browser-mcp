    方法 取所有Cookie <公开 类型 = 文本数组类 注释 = "获取当前已有的所有Cookie信息." @禁止流程检查 = 真>
    {
        @ @dt<文本数组类> ret;
        @ struct curl_slist * cookies;
        @ if ((curl_easy_getinfo(data().GetCurl(), CURLINFO_COOKIELIST, &cookies) == CURLE_OK) && cookies) {
        @     struct curl_slist *each = cookies;
        @     while (each) {
        @         ret.data ().Add (GetWideText (each->data, CVolMem (), NULL));
        @         each = each->next;
        @     }
        @     curl_slist_free_all(cookies);
        @ }
        @ return ret;
    }

    方法 取最后输入路径 <公开 类型 = 文本型 注释 = "获取FTP服务器中的输入路径." @禁止流程检查 = 真>
