    方法 取SSL加密引擎列表 <公开 类型 = 文本数组类 注释 = "获取OpenSSL加密引擎的列表." @禁止流程检查 = 真>
    {
        @ @dt<文本数组类> ret;
        @ struct curl_slist * engines;
        @ if ((curl_easy_getinfo(data().GetCurl(), CURLINFO_SSL_ENGINES, &engines) == CURLE_OK) && engines) {
        @     struct curl_slist *each = engines;
        @     while (each) {
        @         ret.data ().Add (GetWideText (each->data, CVolMem (), NULL));
        @         each = each->next;
        @     }
        @     curl_slist_free_all(engines);
        @ }
        @ return ret;
    }

