    方法 继续传输 <公开 类型 = 整数 注释 = "继续被暂停的网络传输" 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    {
        @ return curl_easy_pause(data().GetCurl(), CURLPAUSE_CONT);
    }

    方法 暂停传输 <公开 类型 = 整数 注释 = "暂停或取消当前连接." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 选项 <类型 = 整数 注释 = "提供1表示仅暂停数据的接收." 注释 = "提供4表示仅暂停数据的发送." 注释 = "提供5表示暂停所有." @默认值 = 5>
    {
        @ return curl_easy_pause(data().GetCurl(), @<选项>);
    }

    方法 发送请求 <公开 类型 = 整数 注释 = "在所有选项配置完毕后,调用本方法以发送本次请求." 注释 = "注意:本方法将会阻塞直到请求结束."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 返回结果 <类型 = 字节集类 注释 = "  提供空对象则不会返回所请求的内容,提供非空变量则将请求所返回内容数据写" 注释 = "入该变量,此时如果使用了\"置写入数据回调函数\"设置过自定义函数时,该函数回调"
            注释 = "时\"用户数据\"参数将会成为该变量的地址(即设置时所提供的\"用户数据\"参数将被覆盖)." @默认值 = 空对象>
    参数 响应头 <类型 = 文本数组类 注释 = "提供空对象则不会返回响应头数据,提供非空变量则将所获取的响应头写入该变量." @默认值 = 空对象>
    {
        @ const BOOL_P blpNeedHeader = (@<响应头>.IsNullObject () == FALSE);
        @ if (blpNeedHeader)  data ().SetHeaderFunction ((INT_P)&@<响应头>.data (), HeaderFn);
        @ const BOOL_P blpNeedResultData = (@<返回结果>.IsNullObject () == FALSE);
        @ if (blpNeedResultData)  data ().SetWriteFunction ((INT_P)&@<返回结果>, WriteFn);
        @ const CURLcode res = curl_easy_perform (data ().GetCurl ());
        @ if (blpNeedHeader)  data ().SetHeaderFunction (0, NULL);
        @ if (blpNeedResultData)  data ().SetWriteFunction (0, NULL);
        @ return (INT)res;
    }

    方法 接收数据 <公开 类型 = " 整数" 注释 = "从已建立的连接接收数据,通常与\"发送数据\"成对使用,以实现自定义协议." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类 注释 = "所获取的数据将会置入该参数中.">
    {
        @ size_t dataLen = 0;
        @ INT ret = curl_easy_recv(data().GetCurl(), @<缓冲区>.GetPtr(), (size_t)@<缓冲区>.GetSize(), &dataLen);
        @ if (dataLen > 0)
        @     @<缓冲区>.Realloc(dataLen);
        @ return ret;
    }

    方法 发送数据 <公开 类型 = 整数 注释 = "通过已建立的连接发送任意数据,通常与\"接收数据\"成对使用,以实现自定义协议." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲发送的数据.">
    {
        @ return curl_easy_send(data().GetCurl(), @<数据>.GetPtr(), (size_t)@<数据>.GetSize(), NULL);
    }

    方法 连接维护检查 <公开 类型 = 整数 注释 = "一些协议具有\"维持连接\"机制,这些机制通常在现有连接上发送一些流量,以使其保持活动状态." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    {
        @ return curl_easy_upkeep(data().GetCurl());
    }

    方法 置提交数据 <公开 类型 = 整数 注释 = "设置带请求体的请求方式所欲提交的数据." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲提交的数据内容,提供空对象表示恢复默认.">
    参数 复制数据 <类型 = 逻辑型 注释 = "是否将\"数据\"参数复制(不能超过8MB),如采用不复制则必须确保\"数据\"参数在发送POST请求之前有效(未被释放),否则将出现异常" @默认值 = 真>
    {
        @ curl_easy_setopt(data().GetCurl(), CURLOPT_POSTFIELDSIZE, (INT)@<数据>.GetSize());    //必须先定义尺寸,否则会被认为是文本...不要使用_LARGE版本,在32位下会出现问题!!!
        @ return curl_easy_setopt(data().GetCurl(), (@<复制数据> ? CURLOPT_COPYPOSTFIELDS : CURLOPT_POSTFIELDS), (@<数据>.IsNullObject() ? NULL : (char *)@<数据>.GetPtr()));
    }

    方法 置提交数据尺寸 <公开 类型 = 整数 注释 = "设置\"置提交数据\"所提供的数据尺寸,无必要时无需调用本方法." @禁止流程检查 = 真>
    参数 尺寸 <类型 = 整数>
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_POSTFIELDSIZE, @<尺寸>);
    }

    方法 置请求头 <公开 类型 = 整数 注释 = "设置请求所欲使用的请求头." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本数组类 注释 = "一个成员表示一个头,例如\"content-type: text/html\"">
    {
        @ data().ClearHeaderList();
        @ data().headers = CCurlWraper::s_create_slist (@<内容>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_HTTPHEADER, data().headers);
    }

    方法 置代理请求头 <公开 类型 = 整数 注释 = "设置请求所欲使用的代理请求头." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本数组类 注释 = "一个成员表示一个头,例如\"content-type: text/html\"">
    {
        @ data().ClearProxyHeaderList();
        @ data().proxyHeaders = CCurlWraper::s_create_slist (@<内容>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_PROXYHEADER, data().proxyHeaders);
    }

    方法 置Cookie内容 <公开 类型 = 整数 注释 = "设置请求所欲使用的Cookie内容." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "例如:name1 = content1; name2 = content2; 提供空文本表示恢复默认NULL.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIE, (@<内容>.IsEmpty() ? NULL : GetMbsText (@<内容>.GetText (), CVolMem(), NULL)));
    }

    方法 添加新Cookie <公开 类型 = 整数 注释 = "将单个Cookie添加到内存中." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "提供空文本表示禁用.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIELIST, (@<内容>.IsEmpty() ? NULL : GetMbsText (@<内容>.GetText (), CVolMem(), NULL)));
    }

    方法 操作Cookie <公开 类型 = 整数 注释 = "对Cookie进行指定操作." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 类型 <类型 = 文本型 注释 = "指定所欲操作的类型." 注释 = "可选值:" 注释 = "\"ALL\":表示清除当前内存中所有Cookie." 注释 = "\"SESS\":表示清除内存中保存所有会话Cookie."
            注释 = "\"FLUSH\":将内存中所有Cookie立即写出到\"置写Cookie文件\"方法指定的文件中." 注释 = "\"RELOAD\":从\"置读Cookie文件\"方法指定的文件载入Cookie到内存中."
            @默认值 = "RELOAD">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIELIST, GetMbsText (@<类型>.GetText (), CVolMem(), NULL));
    }

    方法 置读Cookie文件 <公开 类型 = 整数 注释 = "设置请求从中读取Cookie内容的文件." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 文件 <类型 = 文本型 注释 = "例如:\"/tmp/cookie.txt\",如果为空文本则在内存中读取,空对象表示禁用." @默认值 = "">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIEFILE, (@<文件>.IsNullObject() ? NULL : GetMbsText (@<文件>.GetText (), CVolMem(), NULL)));
    }

    方法 置写Cookie文件 <公开 类型 = 整数 注释 = "指定将Cookie内容写入储存的文件." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 文件 <类型 = 文本型 注释 = "例如:\"/tmp/cookie.txt\",如果为空文本则在内存中储存,空对象表示禁用." @默认值 = "">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIEJAR, (@<文件>.IsNullObject() ? NULL : GetMbsText (@<文件>.GetText (), CVolMem(), NULL)));
    }

    方法 置新Cookie会话 <公开 类型 = 整数 注释 = "指定是否强制忽略上一次请求所保留下的Cookie内容,以确保下一次请求不会发送这些Cookie."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 忽略 <类型 = 逻辑型>
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_COOKIESESSION, @<忽略>);
    }

    方法 置连接协议 <公开 类型 = 整数 注释 = "连接到特定的服务器和端口,即\"CONNECT_TO\",与请求的地址与端口并非一致." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    参数 内容 <类型 = 文本数组类 注释 = "一个成员表示一个服务器,例如:example.com::server1.example.com.">
    {
        @ data().ClearConnectToList();
        @ data().connect_to = CCurlWraper::s_create_slist (@<内容>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_CONNECT_TO, data().connect_to);
    }

    方法 置请求成功别名列表 <公开 类型 = 整数 注释 = "设置所欲将其视为HTTP 200响应的结果别名列表." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本数组类 注释 = "一个成员表示一个别名,例如:ICY 200 OK">
    {
        @ data().ClearAliasesList();
        @ data().aliases = CCurlWraper::s_create_slist (@<内容>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_HTTP200ALIASES, data().aliases);
    }

    方法 置SMTP收件人列表 <公开 类型 = 整数 注释 = "设置SMTP收件人地址列表." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 地址 <类型 = 文本数组类 注释 = "每个成员表示一个收件人地址.">
    {
        @ data().ClearRcptsList();
        @ data().rcpts = CCurlWraper::s_create_slist (@<地址>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_MAIL_RCPT, data().rcpts);
    }

    方法 置FTP预运行命令 <公开 类型 = 整数 注释 = "设置在连接到FTP后,所欲在传输之前执行的命令列表." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 命令 <类型 = 文本数组类 注释 = "一个成员表示一个命令.">
    {
        @ data().ClearFtpPreQuoteCmdsList();
        @ data().ftpPreQuoteCmds = CCurlWraper::s_create_slist (@<命令>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_PREQUOTE, data().ftpPreQuoteCmds);
    }

    方法 置FTP传输前命令 <公开 类型 = 整数 注释 = "指定在FTP发出任何其他命令之前完成(甚至在FTP的CWD命令之前完成)." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)."
            @禁止流程检查 = 真>
    参数 命令 <类型 = 文本数组类 注释 = "一个成员表示一个命令.">
    {
        @ data().ClearFtpQuoteCmdsList();
        @ data().ftpQuoteCmds = CCurlWraper::s_create_slist (@<命令>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_QUOTE, data().ftpQuoteCmds);
    }

    方法 置FTP传输后命令 <公开 类型 = 整数 注释 = "指定在FTP传输请求之后运行的命令." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 命令 <类型 = 文本数组类 注释 = "一个成员表示一个命令.">
    {
        @ data().ClearFtpPostQuoteCmdsList();
        @ data().ftpPostQuoteCmds = CCurlWraper::s_create_slist (@<命令>.data ());
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_QUOTE, data().ftpPostQuoteCmds);
    }

    方法 置请求方式 <公开 类型 = 整数 注释 = "设置自定义请求方式." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 请求方法 <类型 = 文本型 注释 = "例如HTTP请求方法:HEAD." 注释 = "例如FTP请求:LIST" 注释 = "提供空文本表示恢复默认值NULL.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_CUSTOMREQUEST, (@<请求方法>.IsEmpty() ? NULL : GetMbsText (@<请求方法>.GetText (), CVolMem(), NULL)));
    }

    方法 置表单数据 <公开 类型 = 整数 注释 = "提供一个多段数据形式的MIME对象,在请求中发送." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 数据 <类型 = 多用途扩展格式类 注释 = "务必确保该对象在发送请求之前未被释放,提供空对象表示恢复默认值NULL.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_MIMEPOST, (@<数据>.IsNullObject() ? NULL : @<数据>.data().mime));
    }

    方法 置DNS首选服务器 <公开 类型 = 整数 注释 = "提供自定义DNS服务器,以代替系统默认使用的DNS服务器." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 DNS <类型 = 文本型 注释 = "例如:\"192.168.1.100:53,192.168.1.101\",提供空文本表示恢复默认.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_DNS_SERVERS, (@<DNS>.IsEmpty() ? NULL : GetMbsText (@<DNS>.GetText (), CVolMem(), NULL)));
    }

    方法 置SSL选项 <公开 类型 = 整数 注释 = "设置SSL的行为选项." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 选项 <类型 = 整数 注释 = "请参考\"SSL行为选项类型\"所提供的常量,接受其一个或多个组合值.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_SSL_OPTIONS, @<选项>);
    }

    方法 置代理SSL选项 <公开 类型 = 整数 注释 = "设置代理SSL的行为选项." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @禁止流程检查 = 真>
    参数 选项 <类型 = 整数 注释 = "请参考\"SSL行为选项类型\"所提供的常量,接受其一个或多个组合值.">
    {
        @ return curl_easy_setopt(data().GetCurl(), CURLOPT_PROXY_SSL_OPTIONS, @<选项>);
    }

    方法 清理 <公开 注释 = "  将传输对象所使用相关资源全部释放,如果明确不再使用可以调用" 注释 = "本方法主动释放,以避免内存占用." 注释 = "  本方法调用不是必需的,对象释放时会自动进行清理,但是当长久"
            注释 = "不使用本对象时,建议手动调用本方法以提前释放相关资源." @嵌入式方法 = "">
    {
        @ @sn<this>.data().Cleanup ()
    }

    # 自定义回调函数相关 ---

    方法 置写入数据回调函数 <公开 类型 = 整数 注释 = "自定义写入所接收数据(下载数据)的回调方法,设置成功后\"发送请求\"方法的返回结果参数将会无效!"
            注释 = "注意:除非明确了解本方法设置的后果,否则不要调用该方法设置自定义回调函数." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    参数 目标方法 <注释 = "提供对应的回调函数.注意:定义该回调方法时务必定义为\"CDECL\"调用方式,定义方法见对应的模板匹配方法." @匹配方法 = "写入数据回调函数模板">
    参数 用户数据 <类型 = 变整数 注释 = "提供回调函数中的用户数据参数内容." @默认值 = 0>
    {
        @ @sn<this>.data().SetWriteFunction (@<用户数据>, (curl_write_callback)&@<目标方法>)
    }

    方法 写入数据回调函数模板 <静态 类型 = 变整数 注释 = "\"置写入数据回调函数\"对应的方法模板." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式." 返回值注释 = "返回所处理的数据长度."
            @视窗.前缀文本 = "@CDECL">
    参数 数据 <类型 = 变整数 注释 = "本次回调提供的数据指针.">
    参数 数据尺寸 <类型 = 变整数 注释 = "本次回调提供单个数据的长度,即总长度应为 \"数据尺寸\"*\"数据数量\".">
    参数 数据数量 <类型 = 变整数 注释 = "本次回调提供数据的个数.">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    {
        返回 (数据尺寸 * 数据数量)
    }

    方法 置读取数据回调函数 <公开 类型 = 整数 注释 = "自定义读取数据的回调方法,当上传数据时将会回调该方法." 注释 = "注意:除非明确了解本方法设置的后果,否则不要调用该方法设置自定义回调函数."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    参数 目标方法 <注释 = "提供对应的回调函数.注意:定义该回调方法时务必定义为\"CDECL\"调用方式,定义方法见对应的模板匹配方法." @匹配方法 = "读取数据回调函数模板">
    参数 用户数据 <类型 = 变整数 注释 = "提供回调函数中的用户数据参数内容." @默认值 = 0>
    {
        @ @sn<this>.data().SetReadFunction(@<用户数据>, (curl_read_callback)&@<目标方法>)
    }

    方法 读取数据回调函数模板 <静态 类型 = 变整数 注释 = "\"置读取数据回调函数\"对应的方法模板." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式." 返回值注释 = "返回读入的数据长度."
            @视窗.前缀文本 = "@CDECL">
    参数 缓冲区 <类型 = 变整数 注释 = "数据读入缓冲区.">
    参数 数据尺寸 <类型 = 变整数 注释 = "本次回调提供单个数据的长度,即总长度应为 \"数据尺寸\"*\"数据数量\".">
    参数 数据数量 <类型 = 变整数 注释 = "本次回调提供数据的个数.">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    {
        返回 (数据尺寸 * 数据数量)
    }

    方法 置输入流搜索回调函数 <公开 类型 = 整数 注释 = "设置在输入流中进行搜索时的回调方法." 注释 = "注意:除非明确了解本方法设置的后果,否则不要调用该方法设置自定义回调函数."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    参数 目标方法 <注释 = "提供对应的回调函数.注意:定义该回调方法时务必定义为\"CDECL\"调用方式,定义方法见对应的模板匹配方法." @匹配方法 = "输入流搜索回调函数模板">
    参数 用户数据 <类型 = 变整数 注释 = "提供回调函数中的用户数据参数内容." @默认值 = 0>
    {
        @ @sn<this>.data().SetSeekFunction(@<用户数据>, (curl_seek_callback)&@<目标方法>)
    }

    方法 输入流搜索回调函数模板 <静态 类型 = 整数 注释 = "在输入流中进行搜索时将会回调该方法." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式." 返回值注释 = "返回0成功."
            返回值注释 = "返回1将会传输失败." 返回值注释 = "返回2表示无法搜寻." @视窗.前缀文本 = "@CDECL">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    参数 偏移量 <类型 = 变整数>
    参数 原点 <类型 = 整数>
    {
        返回 (0)
    }

    方法 置传输进度回调函数 <公开 类型 = 整数 注释 = "设置在传输过程中回调进度数据的方法,设置成功后本类的\"传输进度发生改变\"事件将失效." 注释 = "注意:"
            注释 = "  1. 除非明确了解本方法设置的后果,否则不要调用该方法设置自定义回调函数;" 注释 = "  2. 在调用本方法前,需要先设置\"进度反馈\"属性值为真以启用进度反馈."
            返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    参数 目标方法 <注释 = "提供对应的回调函数.注意:定义该回调方法时务必定义为\"CDECL\"调用方式,定义方法见对应的模板匹配方法." @匹配方法 = "传输进度回调函数模板">
    参数 用户数据 <类型 = 变整数 注释 = "提供回调函数中的用户数据参数内容." @默认值 = 0>
    {
        @ @sn<this>.data().SetXferinfoFunction (@<用户数据>, (curl_xferinfo_callback)&@<目标方法>)
    }

    方法 传输进度回调函数模板 <静态 类型 = 整数 注释 = "传输进度发生变化时将会调用该方法." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式." 返回值注释 = "返回0继续传输,返回非0则中止传输."
            @视窗.前缀文本 = "@CDECL">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    参数 下载总量 <类型 = 长整数 注释 = "预计所需下载数据的总尺寸.">
    参数 当前下载 <类型 = 长整数 注释 = "当前所下载的数据尺寸.">
    参数 上传总量 <类型 = 长整数 注释 = "预计所需上传数据的总尺寸.">
    参数 当前上传 <类型 = 长整数 注释 = "当前所上传的数据尺寸.">
    {
        返回 (0)
    }

    方法 置接收响应头回调函数 <公开 类型 = 整数 注释 = "设置在传输过程中收到服务器发送的响应头时回调的方法,设置成功后\"发送请求\"方法的响应头参数将会无效!"
            注释 = "注意:除非明确了解本方法设置的后果,否则不要调用该方法设置自定义回调函数." 返回值注释 = "成功返回0,失败返回非0值(请参考\"执行状态码\"中所提供的常量定义)." @嵌入式方法 = "">
    参数 目标方法 <注释 = "提供对应的回调函数.注意:定义该回调方法时务必定义为\"CDECL\"调用方式,定义方法见对应的模板匹配方法." @匹配方法 = "接收响应头回调函数模板">
    参数 用户数据 <类型 = 变整数 注释 = "提供回调函数中的用户数据参数内容." @默认值 = 0>
    {
        @ @sn<this>.data().SetHeaderFunction (@<用户数据>, (curl_read_callback)&@<目标方法>)
    }

    方法 接收响应头回调函数模板 <静态 类型 = 整数 注释 = "\"置接收响应头回调函数\"对应的方法模板,每解析完成一个响应头时本方法被调用一次." 注释 = "注意:定义该回调方法时务必定义为\"CDECL\"调用方式."
            返回值注释 = "返回响应头数据长度." @视窗.前缀文本 = "@CDECL">
    参数 缓冲区 <类型 = 变整数 注释 = "响应头内容.">
    参数 数据尺寸 <类型 = 整数 注释 = "本次回调提供单个数据的长度,即总长度应为 \"数据尺寸\"*\"数据数量\".">
    参数 数据数量 <类型 = 整数 注释 = "本次回调提供数据的个数.">
    参数 用户数据 <类型 = 变整数 注释 = "设置回调函数所传入的\"用户数据\"参数.">
    {
        返回 (数据尺寸 * 数据数量)
    }
}

类 执行状态码 <公开 注释 = "本类提供网络传输类中的一些结果码返回值定义." @文档 = "category = \"辅助类\"">
{
    常量 成功 <公开 类型 = 整数 值 = 0 注释 = "表示执行成功.">
    常量 对象未初始化 <公开 类型 = 整数 值 = @CURLE_OBJECT_NOT_INIT 注释 = "所使用对象尚未初始化">
    常量 参数无效 <公开 类型 = 整数 值 = @CURLE_INVALID_PARAM 注释 = "所提供的参数无效">
    常量 不支持协议 <公开 类型 = 整数 值 = 1 注释 = "表示服务器不接受该协议访问.">
    常量 初始化失败 <公开 类型 = 整数 值 = 2 注释 = "表示请求对象初始化失败.">
    常量 地址格式错误 <公开 类型 = 整数 值 = 3 注释 = "提供的请求地址格式不正确.">
    常量 非内置功能 <公开 类型 = 整数 值 = 4 注释 = "不是内置的功能.">
    常量 无法解析代理 <公开 类型 = 整数 值 = 5 注释 = "无法解析的代理.">
    常量 无法解析主机 <公开 类型 = 整数 值 = 6 注释 = "无法解析的主机.">
    常量 无法连接 <公开 类型 = 整数 值 = 7 注释 = "无法连接到服务器.">
    常量 意外服务器回复 <公开 类型 = 整数 值 = 8 注释 = "表示服务器的回复无法处理.">
    常量 拒绝远程访问 <公开 类型 = 整数 值 = 9 注释 = "远程访问被拒绝.">
    常量 拒绝FTP访问 <公开 类型 = 整数 值 = 10 注释 = "访问FTP被拒绝.">
    常量 FTP意外回复 <公开 类型 = 整数 值 = 11 注释 = "指示FTP返回了意外的代码.">
    常量 FTP等待超时 <公开 类型 = 整数 值 = 12 注释 = "FTP等待会话超时.">
    常量 FTP服务器缺陷 <公开 类型 = 整数 值 = 13 注释 = "FTP服务器的回复是意外的结果.">
    常量 FTP无法解析227 <公开 类型 = 整数 值 = 14 注释 = "无法解析FTP服务器返回的227行.">
    常量 FTP内部故障 <公开 类型 = 整数 值 = 15 注释 = "内部故障查找主机使用新的连接.">
    常量 HTTP2协议错误 <类型 = 整数 值 = 16 注释 = "HTTP2协议层出现错误.">
    常量 FTP传输类型错误 <公开 类型 = 整数 值 = 17 注释 = "FTP设置传送模式时失败.">
    常量 FTP文件部分 <公开 类型 = 整数 值 = 18 注释 = "文件传输的尺寸小于或大于预期尺寸,数据不匹配.">
    常量 FTP无法检索文件 <公开 类型 = 整数 值 = 19 注释 = "FTP无法检索目标文件.">
    常量 返回命令错误 <公开 类型 = 整数 值 = 21 注释 = "远程命令返回错误.">
    常量 HTTP返回错误 <公开 类型 = 整数 值 = 22 注释 = "HTTP返回错误.">
    常量 写入错误 <公开 类型 = 整数 值 = 23 注释 = "数据写入错误.">
    常量 上传命令错误 <公开 类型 = 整数 值 = 25 注释 = "上传命令错误.">
    常量 读入错误 <公开 类型 = 整数 值 = 26 注释 = "无法打开/读取指定文件.">
    常量 内存不足 <公开 类型 = 整数 值 = 27 注释 = "表示内存不足无法申请空间.">
