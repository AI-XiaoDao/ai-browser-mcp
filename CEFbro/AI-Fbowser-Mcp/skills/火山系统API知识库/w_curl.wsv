<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.网络

类 网络传输类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "" 注释 = "如果用户程序中调用了本类中的\"使用新版本\"静态方法,将使用 curl 8.15 版,其特性如下:"
        注释 = "编译基于的相关库版本: curl 8.15.0-DEV (Windows) libcurl/8.15.0-DEV OpenSSL/3.5.0 zlib/1.3.1 brotli/1.1.0 zstd/1.5.7 WinIDN libssh2/1.11.1_DEV nghttp2/1.66.0 ;"
        注释 = "所支持协议: dict file ftp ftps gopher gophers http https imap imaps ipfs ipns ldap ldaps mqtt pop3 pop3s rtsp scp sftp smb smbs smtp smtps telnet tftp ws wss ;"
        注释 = "所支持特性: alt-svc AsynchDNS brotli HSTS HTTP2 HTTPS-proxy IDN IPv6 Largefile libz NTLM SSL threadsafe TLS-SRP Unicode UnixSockets zstd ."
        注释 = "" 注释 = "如果用户程序中未调用本类中的\"使用新版本\"静态方法,将使用 curl 7.74 版,其特性如下:"
        注释 = "编译基于的相关库版本: libcurl/7.74.0 OpenSSL/1.1.1h zlib/1.2.11 libssh2/1.9.0 ." 注释 = "" 编辑时信息 = "1E6A8C, 0, 0, 0"
        @视窗.外部头文件 = "vol\\vol_curl.h" @视窗.外部源文件 = "vol\\vol_curl.cpp" @视窗.后缀文本 = "public IVolNoticeReceiver"
        @视窗.使用静态运行时库.static = 真 @视窗.需求VS版本.static = "16-" "" "@视窗.头文件搜寻目录.d:!_VOL_CURL_VER2" = "lib\\curl_include"
        "@视窗.附属文件.non_static - d:!_VOL_CURL_VER2" = "lib\\$(p)\\libcurl.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll"
        "@视窗.外部库.non_static - d:!_VOL_CURL_VER2" = "lib\\$(p)\\libcurl.lib"
        "@视窗.外部库.static - d:!_VOL_CURL_VER2" = "lib\\$(p)\\static\\libcurl-$(d).lib\r\nCrypt32.lib\r\nWldap32.lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib\r\nws2_32.lib"
        "" "@视窗.头文件搜寻目录.d:_VOL_CURL_VER2" = "lib2\\curl_include"
        "@视窗.附属文件.non_static - d:_VOL_CURL_VER2" = "lib2\\$(p)\\dll\\libcurl.dll"
        "@视窗.外部库.non_static - d:_VOL_CURL_VER2" = "lib2\\$(p)\\dll\\libcurl.lib"
        "@视窗.附属文件.static-debug - d:_VOL_CURL_VER2" = "lib2\\$(p)\\dll\\libcurl.dll"
        "@视窗.外部库.static-debug - d:_VOL_CURL_VER2" = "lib2\\$(p)\\dll\\libcurl.lib"
        "@视窗.外部库.static-release - d:_VOL_CURL_VER2" = "lib2\\$(p)\\lib\\libcurl-release.lib\r\nlib2\\$(p)\\lib\\brotlicommon.lib\r\nlib2\\$(p)\\lib\\brotlidec.lib\r\nlib2\\$(p)\\lib\\libcrypto.lib\r\nlib2\\$(p)\\lib\\libssh2.lib\r\nlib2\\$(p)\\lib\\libssl.lib\r\nlib2\\$(p)\\lib\\nghttp2.lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zstd.lib\r\nwldap32.lib\r\nnormaliz.lib\r\nws2_32.lib\r\niphlpapi.lib\r\nbcrypt.lib\r\ncrypt32.lib\r\n">
{
    方法 使用新版本 <公开 静态 注释 = "调用本方法指示编译器使用curl最新8.15版进行编译(不支持静态火山模块链接方式),如果不调用本方法,将使用curl 7.74版进行编译. 具体参见\"网络传输类\"处的说明."
            注释 = "注意: 本方法为编译时处理方法,系统在编译时只要检测到用户程序实际执行流程中任意位置调用了此方法,就启用对应的编译特性,和方法本身是否被执行到没有任何关系." 注释 = "" @视窗.预定义宏 = "_VOL_CURL_VER2"
            @视窗.编译信息 = "基于 CURL 8.15 版本编译" "@视窗.预定义宏.static-release" = "CURL_STATICLIB">
    {

    }

    常量 暂停数据写入 <公开 类型 = 整数 值 = @CURL_WRITEFUNC_PAUSE 注释 = "仅用于写入数据回调函数的返回值.">

