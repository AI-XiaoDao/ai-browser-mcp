    方法 取证书信息 <公开 类型 = 对象数组类 注释 = "获取TLS证书链." 返回值注释 = "取出证书链信息,每个成员表示一个证书信息列表,即\"文本数组类\"作为成员." @禁止流程检查 = 真>
    {
        @ @dt<对象数组类> ret;
        @ struct curl_certinfo * ci;
        @ if ((curl_easy_getinfo(data().GetCurl(), CURLINFO_CERTINFO, &ci) == CURLE_OK) && ci) {
        @     for (INT i = 0; i < ci->num_of_certs; i++)
        @     {
        @         @dt<文本数组类>* pvolList = new @dt<文本数组类>;
        @         struct curl_slist *temp;
        @         for(temp = ci->certinfo[i]; temp; temp = temp->next)
        @             pvolList->data ().Add (GetWideText (temp->data, CVolMem (), NULL));
        @         ret.AddTakeOverObject(pvolList);
        @     }
        @ }
        @ return ret;
    }

