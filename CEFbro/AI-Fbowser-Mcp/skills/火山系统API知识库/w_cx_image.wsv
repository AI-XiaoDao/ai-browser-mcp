    }

    方法 抖动 <公开 类型 = 逻辑型 注释 = "随机抖动处理图像,即为每个像素点添加一个随机偏移量." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 阀值 <类型 = 整数 注释 = "所产生的随机偏移量最大值." @默认值 = 2>
    {
        @ @sn<this>.GetCxImage()->Jitter(@<阀值>)
    }

    方法 对比度 <公开 类型 = 逻辑型 注释 = "改变当前图像的亮度以及对比度." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 亮度 <类型 = 整数 注释 = "取值范围:-255 - 255之间,负数表示图像变暗,反之变亮.">
    参数 对比 <类型 = 整数 注释 = "对比度,取值范围:-100 - 100之间." @默认值 = 0>
