类 GIF图像类 <公开 基础类 = 图像处理类 注释 = "本类实例表示一个GIF图像.">
{

    # @ @m<图像处理类.DECLARE_CXIMAGE_CLASS>(CxGifImageWrapper, CxImageGIF)
    #

    方法 载入GIF图像文件 <公开 类型 = 逻辑型 注释 = "将指定图像文件解码载入." 返回值注释 = "返回载入是否成功." @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "提供图像文件的完整路径.">
    参数 打开方式 <类型 = 文本型 注释 = "指定所欲使用的文件打开方式." @默认值 = "rb">
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<路径>.GetText() ,@<打开方式>.GetText());
        @ return GetCxImageGIF()->Decode(&ioFile);
    }

    方法 载入GIF图像数据 <公开 类型 = 逻辑型 注释 = "将指定图像数据解码载入." 返回值注释 = "返回载入是否成功." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供图像文件的完整路径.">
    {
        @ CxMemFile mem((uint8_t*)@<数据>.GetPtr(), (uint32_t)@<数据>.GetSize());
        @ return GetCxImageGIF()->Decode(&mem);
    }

    方法 写出GIF图像文件 <公开 类型 = 逻辑型 注释 = "将当前图像对象的数据写出到本地文件." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "提供所欲将图像文件写出的路径,如果文件存在将会被覆盖.">
    参数 打开方式 <类型 = 文本型 注释 = "指定所欲使用的文件打开方式." @默认值 = "wb">
    参数 写出所有帧 <类型 = 逻辑型 注释 = "指定是否写出所有帧,如提供假则仅会写出当前单帧图像." @默认值 = 假>
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<路径>.GetText() ,@<打开方式>.GetText());
        @ if (@<写出所有帧> && GetCxImageGIF()->GetNumFrames() > 1)
        @ {
        @     INT num = GetCxImageGIF()->GetNumFrames();
        @     CxImage** frames = new CxImage*[num];
        @     for (INT i = 0; i < num; i++)
        @         frames[i] = GetCxImageGIF()->GetFrame(i);
        @     BOOL ret = GetCxImageGIF()->Encode(&ioFile, frames, num);
        @     delete[] frames;
        @     return ret;
        @ }else
        @     return GetCxImageGIF()->Encode(&ioFile);
    }

    方法 写出GIF图像数据 <公开 类型 = 逻辑型 注释 = "将当前图像对象的数据写出到指定字节集中存放." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类 注释 = "提供所欲存放图像数据的字节集.">
    参数 写出所有帧 <类型 = 逻辑型 注释 = "指定是否写出所有帧,如提供假则仅会写出当前单帧图像." @默认值 = 假>
    {
        @ CxMemFile mem;
        @ if (mem.Open())
        @ {
        @     BOOL ret = 0;
        @     if (@<写出所有帧> && GetCxImageGIF()->GetNumFrames() > 1)
        @     {
        @         INT num = GetCxImageGIF()->GetNumFrames();
        @         CxImage** frames = new CxImage*[num];
        @         for (INT i = 0; i < num; i++)
        @             frames[i] = GetCxImageGIF()->GetFrame(i);
        @         ret = GetCxImageGIF()->Encode(&mem, frames, num);
        @         delete[] frames;
        @     }else
        @         ret = GetCxImageGIF()->Encode(&mem);
        @     if (ret)
        @     {
        @         @<缓冲区>.CopyFrom(mem.GetBuffer(FALSE), mem.Size());    //GetBuffer(FALSE),原数据交由CxMemFile析构释放
        @         return TRUE;
        @     }
        @ }
        @ return FALSE;
    }

    方法 置循环次数 <公开 注释 = "设置GIF图像的循环次数." @嵌入式方法 = "">
    参数 次数 <类型 = 整数>
    {
        @ @sn<this>.GetCxImageGIF()->SetLoop(@<次数>)
    }

    方法 取循环次数 <公开 类型 = 整数 注释 = "获取GIF图像的循环次数." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCxImageGIF()->GetLoops()
    }

    方法 置注释信息 <公开 注释 = "设置GIF图像的注释文本信息." @嵌入式方法 = "">
    参数 内容 <类型 = 文本型 注释 = "注意:最大支持255个字节,超出将被丢弃.">
    {
        @ @sn<this>.GetCxImageGIF()->SetComment(GetMbsText(@<内容>, CVolMem(), NULL))
    }

    方法 取注释信息 <公开 类型 = 文本型 注释 = "设置GIF图像的注释文本信息." @禁止流程检查 = 真>
    {
        @ char comment[255];
        @ GetCxImageGIF()->GetComment(comment);
        @ INT_P len;
        @ CVolMem mem;
        @ const WCHAR* pws = GetWideText (comment, mem, &len);
        @ return @an<CVolString> (pws, len);
    }
}

类 MNG图像类 <公开 基础类 = 图像处理类 注释 = "本类实例表示一个MNG图像.">
{

    # @ @m<图像处理类.DECLARE_CXIMAGE_CLASS>(CxMngImageWrapper, CxImageMNG)
    #

    方法 载入MNG图像文件 <公开 类型 = 逻辑型 注释 = "将指定图像文件解码载入." 返回值注释 = "返回载入是否成功." @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "提供图像文件的完整路径.">
    参数 打开方式 <类型 = 文本型 注释 = "指定所欲使用的文件打开方式." @默认值 = "rb">
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<路径>.GetText() ,@<打开方式>.GetText());
        @ return GetCxImageMNG()->Decode(&ioFile);
    }

    方法 载入MNG图像数据 <公开 类型 = 逻辑型 注释 = "将指定图像数据解码载入." 返回值注释 = "返回载入是否成功." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供图像文件的完整路径.">
    {
        @ CxMemFile mem((uint8_t*)@<数据>.GetPtr(), (uint32_t)@<数据>.GetSize());
        @ return GetCxImageMNG()->Decode(&mem);
    }

    方法 写出MNG图像文件 <公开 类型 = 逻辑型 注释 = "将当前图像对象的数据写出到本地文件." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "提供所欲将图像文件写出的路径,如果文件存在将会被覆盖.">
    参数 打开方式 <类型 = 文本型 注释 = "指定所欲使用的文件打开方式." @默认值 = "wb">
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<路径>.GetText() ,@<打开方式>.GetText());
        @ return GetCxImageMNG()->Encode(&ioFile);
    }

    方法 写出MNG图像数据 <公开 类型 = 逻辑型 注释 = "将当前图像对象的数据写出到指定字节集中存放." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类 注释 = "提供所欲存放图像数据的字节集.">
    参数 写出所有帧 <类型 = 逻辑型 注释 = "指定是否写出所有帧,如提供假则仅会写出当前单帧图像." @默认值 = 假>
    {
        @ CxMemFile mem;
        @ if (mem.Open())
        @ {
        @     if (GetCxImageMNG()->Encode(&mem))
        @     {
        @         @<缓冲区>.CopyFrom(mem.GetBuffer(FALSE), mem.Size());    //GetBuffer(FALSE),原数据交由CxMemFile析构释放
        @         return TRUE;
        @     }
        @ }
        @ return FALSE;
    }

    方法 置播放速度 <公开 注释 = "设置MNG图像的播放速度." @嵌入式方法 = "">
    参数 速度 <类型 = 小数 注释 = "取值范围0.1-10之间.">
    {
        @ @sn<this>.GetCxImageMNG()->SetSpeed((float)@<速度>)
    }
}

