类 图像处理插值算法 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 相邻像素 <公开 值 = @"@CxImage::InterpolationMethod::IM_NEAREST_NEIGHBOUR" 注释 = "为位置相邻的像素.">
    常量 双线性 <公开 值 = @"@CxImage::InterpolationMethod::IM_BILINEAR" 注释 = "为四个位置相邻的像素,能够使像素比特效果变柔和.">
    常量 样条曲线 <公开 值 = @"@CxImage::InterpolationMethod::IM_BSPLINE" 注释 = "B样条曲线,为16个位置相邻的像素,能够使像素比特效果变柔和洗涤颜色,使用双三次插值算法.">
    常量 双三次 <公开 值 = @"@CxImage::InterpolationMethod::IM_BICUBIC" 注释 = "为16个位置相邻的像素,能够使像素比特效果有光晕.">
    常量 双三次2 <公开 值 = @"@CxImage::InterpolationMethod::IM_BICUBIC2" 注释 = "为16个位置相邻的像素,能够使像素比特效果有光晕,但少于\"双三次\"算法.">
    常量 Lanczos <公开 值 = @"@CxImage::InterpolationMethod::IM_LANCZOS" 注释 = "为12*12的像素,能够使像素比特效果缓慢和明亮.">
    常量 BOX <公开 值 = @"@CxImage::InterpolationMethod::IM_BOX" 注释 = "BOX插值算法.">
    常量 Hermite <公开 值 = @"@CxImage::InterpolationMethod::IM_HERMITE">
    常量 加重平衡 <公开 值 = @"@CxImage::InterpolationMethod::IM_HAMMING">
    常量 Sinc <公开 值 = @"@CxImage::InterpolationMethod::IM_SINC">
    常量 BlackMan <公开 值 = @"@CxImage::InterpolationMethod::IM_BLACKMAN">
