    }

    方法 交换索引 <公开 注释 = "互换两个点像素的索引值." @嵌入式方法 = "">
    参数 索引一 <类型 = 字节>
    参数 索引二 <类型 = 字节>
    {
        @ @sn<this>.GetCxImage()->SwapIndex((BYTE)@<索引一>, (BYTE)@<索引二>)
    }

    方法 是否为索引图 <公开 类型 = 逻辑型 注释 = "获取当前图像颜色是否小于或等于256色." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->IsIndexed()
    }

    方法 是否有相同调色板 <公开 类型 = 逻辑型 注释 = "检测与另外一个图像处理对象是否有相同的调色板." 返回值注释 = "相同则返回真,否则返回假." @嵌入式方法 = "">
    参数 比较对象 <类型 = 图像处理类 注释 = "提供欲检查的另一图像.">
    参数 检查透明通道 <类型 = 逻辑型 注释 = "是否同时检查透明通道." @默认值 = 真>
    {
        @ @sn<this>.GetCxImage()->IsSamePalette(*@<比较对象>.GetCxImage(), @<检查透明通道>)
    }

    方法 置调色板 <公开 注释 = "设置当前所欲使用的调色板.">
    参数 颜色组 <类型 = 图像颜色数组类 注释 = "提供所欲使用的调色板数组,成员数与颜色数保持一致.">
    参数 颜色数 <类型 = 整数 注释 = "指定调色板颜色数,默认为256色." @默认值 = 256>
    {
        @ ASSERT(@<颜色组>.GetCount() > 0);
        @ RGBQUAD* rgbs = new RGBQUAD[(INT)@<颜色组>.GetCount()];
        @ for (INT i = 0; i < (INT)@<颜色组>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<颜色组>.GetAt(i)).ToRgbQuad();
        @ GetCxImage()->SetPalette(rgbs, @<颜色数>);
        @ delete[] rgbs;
    }

    方法 像素点颜色混合 <公开 注释 = "将指定像素点颜色与新颜色混合." @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数 注释 = "提供目标像素点的横坐标.">
    参数 纵坐标 <类型 = 整数 注释 = "提供目标像素点的纵坐标.">
    参数 混合颜色 <类型 = 图像颜色类 注释 = "提供所欲与其混合的新颜色.">
    参数 混合比 <类型 = 小数 注释 = "提供0-1之间(百分比),0表示不混合,1完全混合.">
    参数 透明分量 <类型 = 逻辑型 注释 = "是否同时混合透明分量(Alpha)." @默认值 = 假>
    {
        @ @sn<this>.GetCxImage()->BlendPixelColor(@<横坐标>, @<纵坐标>, @<混合颜色>.ToRgbQuad(), (float)@<混合比>, @<透明分量>)
    }

    方法 画直线 <公开 注释 = "画一条指定颜色的直线." @嵌入式方法 = "">
    参数 起始横坐标 <类型 = 整数 注释 = "提供所欲画直线的起始横坐标位置.">
    参数 终点横坐标 <类型 = 整数 注释 = "提供所欲画直线的终点横坐标位置.">
    参数 起始纵坐标 <类型 = 整数 注释 = "提供所欲画直线的起始纵坐标位置.">
    参数 终点纵坐标 <类型 = 整数 注释 = "提供所欲画直线的终点纵坐标位置.">
    参数 颜色值 <类型 = 整数 注释 = "提供所欲画直线的颜色值.">
    {
        @ @sn<this>.GetCxImage()->DrawLine(@<起始横坐标>, @<终点横坐标>, @<起始纵坐标>, @<终点纵坐标>, @<颜色值>)
    }

    方法 画直线2 <公开 注释 = "画一条指定颜色的直线." @嵌入式方法 = "">
    参数 起始横坐标 <类型 = 整数 注释 = "提供所欲画直线的起始横坐标位置.">
    参数 终点横坐标 <类型 = 整数 注释 = "提供所欲画直线的终点横坐标位置.">
