        @ @sn<this>.GetCxImage()->AlphaPaletteSplit(@<存放图像>.GetCxImage())
    }

    方法 Alpha导出 <公开 类型 = 逻辑型 注释 = "将当前Alpha通道导出为一个8位灰度图像." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 存放图像 <类型 = 图像处理类 注释 = "所导出的图像将会置入该变量.">
    {
        @ @sn<this>.GetCxImage()->AlphaSplit(@<存放图像>.GetCxImage())
    }

