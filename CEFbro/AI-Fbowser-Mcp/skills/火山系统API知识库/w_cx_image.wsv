    {
        @ @sn<this>.GetCxImage()->ShiftRGB(@<红色分量>, @<绿色分量>, @<蓝色分量>)
    }

    方法 阀值 <公开 类型 = 逻辑型 注释 = "对当前图像对比度阀值调整." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
