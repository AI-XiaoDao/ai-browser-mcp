        @ @sn<this>.GetCxImage()->AlphaInvert()
    }

    方法 Alpha是否有效 <公开 类型 = 逻辑型 注释 = "检查当前透明通道是否有效." 返回值注释 = "有效返回真,反之假." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->AlphaIsValid()
    }

    方法 Alpha镜像 <公开 类型 = 逻辑型 注释 = "水平翻转当前透明通道." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->AlphaMirror()
    }

    方法 Alpha调色板清除 <公开 注释 = "重置Alpha调色板." @嵌入式方法 = "">
