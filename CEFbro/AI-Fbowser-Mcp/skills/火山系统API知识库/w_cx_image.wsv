    }

    方法 虚光蒙版 <公开 类型 = 逻辑型 注释 = "作用主要是调整图像锐度,清晰度." 返回值注释 = "返回操作是否成功." 编辑时信息 = "86AA2, 0, 0, 0" @嵌入式方法 = "">
    参数 影响半径 <类型 = 小数 注释 = "本次操作所欲影响的半径." 编辑时信息 = "86AA2, 0, 0, 0" @默认值 = 5>
    参数 等级 <类型 = 小数 注释 = "0-1.0之间." 编辑时信息 = "86AA2, 0, 0, 0" @默认值 = 0.5>
    参数 阀值 <类型 = 整数 注释 = "提供所欲指定的一个阀值." 编辑时信息 = "86AA2, 0, 0, 0" @默认值 = 1>
    {
        @ @sn<this>.GetCxImage()->UnsharpMask((float)@<影响半径>, (float)@<等级>, @<阀值>)
    }

    # 颜色 ---

    方法 提取CMYK <公开 类型 = 逻辑型 注释 = "从当前图像中提取CMYK通道,每个通道是一个8位的灰度图像." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 通道C <类型 = 图像处理类 注释 = "通道C数据将会写入至该图像对象中.">
