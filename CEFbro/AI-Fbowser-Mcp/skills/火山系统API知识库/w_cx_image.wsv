    }

    方法 显示查找表 <公开 类型 = 逻辑型 注释 = "自定义像素灰度值的映射表,即LUT." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 表 <类型 = 字节集类 注释 = "提供256字节的查找表.">
    {
        @ @sn<this>.GetCxImage()->Lut((uint8_t*)@<表>.GetPtr())
    }

    方法 显示查找表2 <公开 类型 = 逻辑型 注释 = "自定义像素灰度值的映射表(本方法独立指定每个颜色通道),即LUT." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 红色表 <类型 = 字节集类 注释 = "提供256字节的查找表.">
    参数 绿色表 <类型 = 字节集类 注释 = "提供256字节的查找表.">
    参数 蓝色表 <类型 = 字节集类 注释 = "提供256字节的查找表.">
    参数 透明表 <类型 = 字节集类 注释 = "提供256字节的查找表,提供空对象表示不指定." @默认值 = 空对象>
    {
        @ return GetCxImage()->Lut((uint8_t*)@<红色表>.GetPtr(), (uint8_t*)@<绿色表>.GetPtr(), (uint8_t*)@<蓝色表>.GetPtr(), (BOOL)@<透明表>.IsNullObject() ? NULL : (uint8_t*)@<透明表>.GetPtr());
    }

    方法 取平均亮度 <公开 类型 = 小数 注释 = "获取当前图像的平均明亮度." @嵌入式方法 = "">
    {
        @ (DOUBLE)@sn<this>.GetCxImage()->Mean()
    }

    方法 中值 <公开 类型 = 逻辑型 注释 = "将图像每个像素的强度调整为其周围像素的中值强度." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 内核尺寸 <类型 = 整数 注释 = "提供所欲使用的内核尺寸." @默认值 = 3>
    {
        @ @sn<this>.GetCxImage()->Median(@<内核尺寸>)
    }

    方法 混合 <公开 注释 = "将当前图像与另一张图混合." @嵌入式方法 = "">
    参数 图像 <类型 = 图像处理类 注释 = "提供欲与其混合的另一张图像.">
    参数 混合方式 <类型 = 图像混合方式 注释 = "提供所欲使用的图像混合方式.">
    参数 水平偏移 <类型 = 整数 注释 = "图像的水平偏移量." @默认值 = 0>
    参数 垂直偏移 <类型 = 整数 注释 = "图像的垂直偏移量." @默认值 = 0>
    参数 透明混合 <类型 = 逻辑型 注释 = "如果所欲混合的图像存在透明图层,是否一同混合." @默认值 = 假>
    {
        @ @sn<this>.GetCxImage()->Mix(*@<图像>.GetCxImage(), @<混合方式>, @<水平偏移>, @<垂直偏移>, @<透明混合>)
    }

    方法 合并混合 <公开 注释 = "将当前图像与另一张图进行合并" @嵌入式方法 = "">
    参数 图像 <类型 = 图像处理类 注释 = "提供欲与其合并的另一张图像.">
    参数 水平偏移 <类型 = 整数 注释 = "提供合并欲使用的水平偏移量." @默认值 = 0>
    参数 垂直偏移 <类型 = 整数 注释 = "提供合并欲使用的垂直偏移量." @默认值 = 0>
    {
        @ @sn<this>.GetCxImage()->MixFrom(*@<图像>.GetCxImage(), @<水平偏移>, @<垂直偏移>)
    }

    方法 噪点 <公开 类型 = 逻辑型 注释 = "为当前图像均匀添加噪点." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 等级 <类型 = 整数 注释 = "提供噪点等级,取值范围0 - 255之间.">
    {
        @ @sn<this>.GetCxImage()->Noise(@<等级>)
    }

    方法 修复 <公开 类型 = 逻辑型 注释 = "智能修复当前图像,删除某些小缺陷,抖动等." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 半径比 <类型 = 小数 注释 = "修复的半径范围,0.01 - 0.5之间." @默认值 = 0.25>
    参数 补偿 <类型 = 整数 注释 = "提供一个补偿值,确保将被消除的像素点满足该公式:半径比 * 补偿 < 1" @默认值 = 1>
    参数 颜色空间 <类型 = 整数 注释 = "提供所欲使用的颜色空间, 0=RGB, 1=HSL, 2=YUV, 3=YIQ, 4=XYZ" @默认值 = 0>
    {
        @ @sn<this>.GetCxImage()->Repair((float)@<半径比>, @<补偿>, @<颜色空间>)
    }

    方法 调整三基色 <公开 类型 = 逻辑型 注释 = "调整或修改三基色." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
