    方法 是否为透明像素 <公开 类型 = 逻辑型 注释 = "检查指定像素点是否为透明." @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数 注释 = "欲检查像素横坐标位置.">
    参数 纵坐标 <类型 = 整数 注释 = "欲检查像素纵坐标位置.">
    {
        @ @sn<this>.GetCxImage()->IsTransparent(@<横坐标>, @<纵坐标>)
    }

    方法 取区域插值颜色 <公开 类型 = 图像颜色类 注释 = "与\"取像素插值颜色\"相似,但本方法可以正确处理二次抽样." 注释 = "如需从原图采样多于一个点像素时,应使用本方法而不是\"取像素插值颜色\"."
            注释 = "当图像面积的高度和宽度都小于像素时,本方法将取像素插值颜色." 注释 = "当图像面积的高度和宽度都大于1,本方法将计算区域内颜色的平均值." 返回值注释 = "返回目标区域颜色."
            编辑时信息 = "9D54B, 0, 0, 0" @禁止流程检查 = 真>
    参数 中心横坐标 <类型 = 小数 注释 = "提供所欲取区域(矩形)的中心横坐标." 编辑时信息 = "9D54B, 0, 0, 0">
    参数 中心纵坐标 <类型 = 小数 注释 = "提供所欲取区域(矩形)的中心纵坐标." 编辑时信息 = "9D54B, 0, 0, 0">
    参数 宽度 <类型 = 小数 注释 = "提供所欲取区域(矩形)的宽度." 编辑时信息 = "9D54B, 0, 0, 0">
    参数 高度 <类型 = 小数 注释 = "提供所欲取区域(矩形)的高度." 编辑时信息 = "9D54B, 0, 0, 0">
    参数 插值算法 <类型 = 图像处理插值算法 注释 = "提供所欲使用的插值算法." 编辑时信息 = "9D54B, 0, 0, 0">
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法(仅在检索单个像素时使用)." 编辑时信息 = "9D54B, 0, 0, 0" @默认值 = 图像处理溢出算法.背景>
    参数 替换颜色 <类型 = 图像颜色数组类 注释 = "提供所欲使用的替换颜色列(在溢出算法为\"颜色\"时使用)." 编辑时信息 = "9D54B, 0, 0, 0" @默认值 = 空对象>
    {
        @ RGBQUAD* rgbs = (BOOL)@<替换颜色>.IsNullObject() ? NULL : new RGBQUAD[(INT)@<替换颜色>.GetCount()];
        @ for (INT i = 0; i < (INT)@<替换颜色>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<替换颜色>.GetAt(i)).ToRgbQuad();
        @ RGBQUAD ret = GetCxImage()->GetAreaColorInterpolated((float)@<中心横坐标>, (float)@<中心纵坐标>, (float)@<宽度>, (float)@<高度>, (CxImage::InterpolationMethod)@<插值算法>, (CxImage::OverflowMethod)@<溢出算法>, rgbs);
        @ if (rgbs) 
        @     delete[] rgbs;
        @ return @dt<图像颜色类>(ret);
    }

    方法 取像素插值颜色 <公开 类型 = 图像颜色类 注释 = "本方法将会根据所使用的插值算法重建图像,如果所指定的像素点位于图像之外,将会根据溢出算法计算最终颜色." 返回值注释 = "返回目标像素点颜色." @禁止流程检查 = 真>
    参数 横坐标 <类型 = 小数 注释 = "提供所欲取其颜色的像素横坐标.">
    参数 纵坐标 <类型 = 小数 注释 = "提供所欲取其颜色的像素纵坐标.">
    参数 插值算法 <类型 = 图像处理插值算法 注释 = "提供所欲使用的插值算法." @默认值 = 图像处理插值算法.双线性>
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." @默认值 = 图像处理溢出算法.背景>
    参数 替换颜色 <类型 = 图像颜色数组类 注释 = "提供所欲使用的替换颜色列(在溢出算法为\"颜色\"时使用)." @默认值 = 空对象>
    {
        @ RGBQUAD* rgbs = (BOOL)@<替换颜色>.IsNullObject() ? NULL : new RGBQUAD[(INT)@<替换颜色>.GetCount()];
        @ for (INT i = 0; i < (INT)@<替换颜色>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<替换颜色>.GetAt(i)).ToRgbQuad();
        @ RGBQUAD ret = GetCxImage()->GetPixelColorInterpolated((float)@<横坐标>, (float)@<纵坐标>, (CxImage::InterpolationMethod)@<插值算法>, (CxImage::OverflowMethod)@<溢出算法>, rgbs);
        @ if (rgbs)
        @     delete[] rgbs;
        @ return @dt<图像颜色类>(ret);
    }

    方法 取像素溢出颜色 <公开 类型 = 图像颜色类 注释 = "本方法不使用插值算法重建,仅会在像素点超出边界时使用溢出算法计算颜色,如有透明通道将会一同获取." 返回值注释 = "返回目标像素点颜色." @禁止流程检查 = 真>
    参数 横坐标 <类型 = 整数 注释 = "提供所欲取其颜色的像素横坐标.">
    参数 纵坐标 <类型 = 整数 注释 = "提供所欲取其颜色的像素纵坐标.">
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." @默认值 = 图像处理溢出算法.背景>
    参数 替换颜色 <类型 = 图像颜色数组类 注释 = "提供所欲使用的替换颜色列(在溢出算法为\"颜色\"时使用)." @默认值 = 空对象>
    {
        @ RGBQUAD* rgbs = (BOOL)@<替换颜色>.IsNullObject() ? NULL : new RGBQUAD[(INT)@<替换颜色>.GetCount()];
        @ for (INT i = 0; i < (INT)@<替换颜色>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<替换颜色>.GetAt(i)).ToRgbQuad();
        @ RGBQUAD ret = GetCxImage()->GetPixelColorWithOverflow(@<横坐标>, @<纵坐标>, (CxImage::OverflowMethod)@<溢出算法>, rgbs);
        @ if (rgbs)
        @     delete[] rgbs;
        @ return @dt<图像颜色类>(ret);
    }

    方法 溢出像素匹配 <公开 注释 = "提供指定的溢出算法计算溢出的像素坐标." "">
    参数 计算结果 <类型 = 位置类 注释 = "计算后的横纵坐标结果将会写入至该变量.">
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." "">
    {
        @ int32_t x, y;
        @ GetCxImage()->OverflowCoordinates(x, y, (CxImage::OverflowMethod)@<溢出算法>);
        @ @<计算结果>.@n<计算结果.设置>(x, y);
    }

    方法 溢出像素匹配2 <公开 注释 = "提供指定的溢出算法计算溢出的像素坐标(小数)." "">
    参数 计算结果 <类型 = 小数位置类 注释 = "计算后的横纵坐标结果将会写入至该变量.">
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." "">
    {
        @ float x, y;
        @ GetCxImage()->OverflowCoordinates(x, y, (CxImage::OverflowMethod)@<溢出算法>);
        @ @<计算结果.设置>((DOUBLE)x, (DOUBLE)y);
    }

    # 绘图 ---

    方法 拉伸绘图 <公开 类型 = 逻辑型 注释 = "把图像(拉伸)画出到指定的场景设备,支持alpha通道,alpha调色板,透明度,暗度." 返回值注释 = "返回是否绘制成功." @禁止流程检查 = 真>
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 横向偏移 <类型 = 整数 注释 = "所欲绘制当前图像的起始横向偏移量." @默认值 = 0>
    参数 纵向偏移 <类型 = 整数 注释 = "所欲绘制当前图像的起始纵向偏移量." @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "提供所欲绘制图像的宽度,提供小于0将默认使用当前图像的原始宽度." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "提供所欲绘制图像的高度,提供小于0将默认使用当前图像的原始高度." @默认值 = -1>
    参数 绘制区域 <类型 = 矩形类 注释 = "提供所欲限制的绘制区域,绘制的内容将会被限定到该区域中." @默认值 = 空对象>
    参数 平滑绘制 <类型 = 逻辑型 注释 = "是否启用双线性滤光器使其看起来平滑." @默认值 = 假>
    参数 垂直翻转 <类型 = 逻辑型 注释 = "是否垂直翻转图像." @默认值 = 假>
    {
        @ RECT clipRect = {@<绘制区域.左边>, @<绘制区域.顶边>, @<绘制区域.右边>, @<绘制区域.底边>};
        @ return (BOOL)GetCxImage()->Draw((HDC)@<设备句柄>, @<横向偏移>, @<纵向偏移>, @<宽度>, @<高度>, (BOOL)@<绘制区域>.IsNullObject() ? NULL : &clipRect, @<平滑绘制>, @<垂直翻转>);
    }

    方法 拉伸绘图2 <公开 类型 = 逻辑型 注释 = "画出(拉伸)图像,仅支持透明." 返回值注释 = "返回是否绘制成功." @嵌入式方法 = "">
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 横向偏移 <类型 = 整数 注释 = "所欲绘制当前图像的起始横向偏移量." @默认值 = 0>
    参数 纵向偏移 <类型 = 整数 注释 = "所欲绘制当前图像的起始纵向偏移量." @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "提供所欲绘制图像的宽度,提供小于0将默认使用当前图像的原始宽度." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "提供所欲绘制图像的高度,提供小于0将默认使用当前图像的原始高度." @默认值 = -1>
    {
        @ (BOOL)@sn<this>.GetCxImage()->Draw2((HDC)@<设备句柄>, @<横向偏移>, @<纵向偏移>, @<宽度>, @<高度>);
    }

    方法 拉伸绘图3 <公开 类型 = 逻辑型 注释 = "与\"拉伸绘图\"一致,参数提供坐标而非矩形区域." 返回值注释 = "返回是否绘制成功." @禁止流程检查 = 真>
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 图像区域 <类型 = 矩形类 注释 = "提供所欲绘制当前图像的区域,提供空对象将会使用当前图像的原始宽高,横纵偏移为0." @默认值 = 空对象>
    参数 绘制区域 <类型 = 矩形类 注释 = "提供所欲限制的绘制区域,绘制的内容将会被限定到该区域中,提供空对象不限制." @默认值 = 空对象>
    参数 平滑绘制 <类型 = 逻辑型 注释 = "是否启用双线性滤光器使其看起来平滑." @默认值 = 假>
    参数 垂直翻转 <类型 = 逻辑型 注释 = "是否垂直翻转图像." @默认值 = 假>
    {
        @ RECT rect = {0, 0, (LONG)GetCxImage()->GetWidth(), (LONG)GetCxImage()->GetHeight()};
        @ if (!(BOOL)@<图像区域>.IsNullObject())
        @ {
        @     rect.left = @<图像区域.左边>;
        @     rect.right = @<图像区域.右边>;
        @     rect.top = @<图像区域.顶边>;
        @     rect.bottom = @<图像区域.底边>;
        @ }
        @ RECT clipRect = {@<绘制区域.左边>, @<绘制区域.顶边>, @<绘制区域.右边>, @<绘制区域.底边>};
        @ return (BOOL)GetCxImage()->Draw((HDC)@<设备句柄>, rect, (BOOL)@<绘制区域>.IsNullObject() ? NULL : &clipRect, @<平滑绘制>, @<垂直翻转>);
    }

    方法 拉伸绘图4 <公开 类型 = 逻辑型 注释 = "与\"拉伸绘图2\"一致,参数提供坐标而非矩形区域." 返回值注释 = "返回是否绘制成功." @禁止流程检查 = 真>
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 图像区域 <类型 = 矩形类 注释 = "提供所欲绘制当前图像的区域,提供空对象将会使用当前图像的原始宽高,横纵偏移为0." @默认值 = 空对象>
    {
        @ RECT rect = {0, 0, (LONG)GetCxImage()->GetWidth(), (LONG)GetCxImage()->GetHeight()};
        @ if (!(BOOL)@<图像区域>.IsNullObject())
        @ {
        @     rect.left = @<图像区域.左边>;
        @     rect.right = @<图像区域.右边>;
        @     rect.top = @<图像区域.顶边>;
        @     rect.bottom = @<图像区域.底边>;
        @ }
        @ return (BOOL)GetCxImage()->Draw2((HDC)@<设备句柄>, rect);
    }

    方法 平铺绘图 <公开 类型 = 逻辑型 注释 = "把图像(平铺)画出到指定的场景设备." 返回值注释 = "返回是否绘制成功." @禁止流程检查 = 真>
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 绘制区域 <类型 = 矩形类 注释 = "提供所欲限制的绘制区域,绘制的内容将会被限定到该区域中.">
    {
        @ RECT clipRect = {@<绘制区域.左边>, @<绘制区域.顶边>, @<绘制区域.右边>, @<绘制区域.底边>};
        @ return (BOOL)GetCxImage()->Tile((HDC)@<设备句柄>, &clipRect);
    }

    方法 画文本 <公开 类型 = 逻辑型 注释 = "将指定文本内容画出到指定的场景设备." @嵌入式方法 = "">
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲使用的设备句柄.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲绘制的文本内容.">
    参数 横坐标 <类型 = 整数 注释 = "提供所欲绘制文字的起始横坐标.">
    参数 纵坐标 <类型 = 整数 注释 = "提供所欲绘制文字的起始纵坐标.">
    参数 字体颜色 <类型 = 图像颜色类 注释 = "提供所欲绘制文字的内容颜色.">
    参数 字体描述 <类型 = 文本型 注释 = "提供所欲使用的字体类型,可通过\"取字体描述文本()\"获取.">
    参数 字体高度 <类型 = 整数 注释 = "提供所欲绘制内容的高度." @默认值 = 0>
    参数 线条宽度 <类型 = 整数 注释 = "提供所欲绘制内容的字体线条的宽度." @默认值 = 400>
    参数 斜体 <类型 = 逻辑型 注释 = "是否使用斜体方式绘制内容." @默认值 = 假>
    参数 下划线 <类型 = 逻辑型 注释 = "是否在内容下方显示下划线." @默认值 = 假>
    参数 透明通道 <类型 = 逻辑型 注释 = "是否启用透明支持." @默认值 = 假>
    {
        @ (BOOL)@sn<this>.GetCxImage()->DrawString((HDC)@<设备句柄>, @<横坐标>, @<纵坐标>, @<内容>.GetText(), @<字体颜色>.ToRgbQuad(), @<字体描述>.GetText(), @<字体高度>, @<线条宽度>, (BYTE)@<斜体>, (BYTE)@<下划线>, @<透明通道>)
    }

    # 基本变换 ---

    方法 上下翻转 <公开 类型 = 逻辑型 注释 = "将当前图像进行上下翻转变换" 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 翻转选区 <类型 = 逻辑型 注释 = "是否同时翻转选区." @默认值 = 假>
    参数 透明通道 <类型 = 逻辑型 注释 = "是否同时翻转透明通道." @默认值 = 真>
    {
        @ @sn<this>.GetCxImage()->Flip(@<翻转选区>, @<透明通道>)
    }

    方法 左右翻转 <公开 类型 = 逻辑型 注释 = "将当前图像进行左右翻转变换" 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 翻转选区 <类型 = 逻辑型 注释 = "是否同时翻转选区." @默认值 = 假>
    参数 透明通道 <类型 = 逻辑型 注释 = "是否同时翻转透明通道." @默认值 = 真>
    {
        @ @sn<this>.GetCxImage()->Mirror(@<翻转选区>, @<透明通道>)
    }

    方法 底片 <公开 类型 = 逻辑型 注释 = "将当前图像进行底片变换." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->Negative()
    }

    方法 灰度 <公开 类型 = 逻辑型 注释 = "将当前图像进行灰度变换." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->GrayScale()
    }

    方法 左旋转 <公开 类型 = 逻辑型 注释 = "基于当前图像进行左旋转变换." 返回值注释 = "返回操作是否成功." 编辑时信息 = "51550, 0, 0, 0" @禁止流程检查 = 真>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次变换的结果将会放至该目标图像中(本对象将不会变换),如果为空对象则使当前本对象进行变换." 编辑时信息 = "51550, 0, 0, 0" @默认值 = 空对象>
    {
        @ return GetCxImage()->RotateLeft((BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 右旋转 <公开 类型 = 逻辑型 注释 = "基于当前图像进行右旋转变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次变换的结果将会放至该目标图像中(本对象将不会变换),如果为空对象则使当前本对象进行变换." 编辑时信息 = "51550, 0, 0, 0" @默认值 = 空对象>
    {
        @ return GetCxImage()->RotateRight((BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    # 高阶变换 ---

    方法 圆形变换 <公开 类型 = 逻辑型 注释 = "将当前图像进行圆形变换." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 类型 <类型 = 图像圆形变换类型>
    参数 影响半径 <类型 = 整数 注释 = "指定本次变换所欲影响的最大半径,如果为0则处理整张图像." @默认值 = 0>
    参数 KO系数 <类型 = 小数 注释 = "仅在使用涡状圆形变换时使用." @默认值 = 1>
    {
        @ @sn<this>.GetCxImage()->CircleTransform(@<类型>, @<影响半径>, (float)@<KO系数>)
    }

    方法 裁剪 <公开 类型 = 逻辑型 注释 = "基于当前图像进行裁剪." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次裁剪的结果将会放至该目标图像中(本对象将不会裁剪),如果为空对象则使当前本对象进行裁剪." @默认值 = 空对象>
    {
        @ return GetCxImage()->Crop(@<左边>, @<顶边>, @<右边>, @<底边>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 裁剪2 <公开 类型 = 逻辑型 注释 = "基于当前图像进行裁剪." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 裁剪区域 <类型 = 矩形类 注释 = "提供所欲裁剪的图像区域.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次裁剪的结果将会放至该目标图像中(本对象将不会裁剪),如果为空对象则使当前本对象进行裁剪." @默认值 = 空对象>
    {
        @ RECT rect = {@<裁剪区域.左边>, @<裁剪区域.顶边>, @<裁剪区域.右边>, @<裁剪区域.底边>};
        @ return GetCxImage()->Crop(rect, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 裁剪旋转矩形 <公开 类型 = 逻辑型 注释 = "基于当前图像进行矩形裁剪旋转变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 最左边 <类型 = 整数 注释 = "矩形的最左端位置.">
    参数 最顶边 <类型 = 整数 注释 = "矩形的最顶端位置.">
    参数 宽度 <类型 = 整数 注释 = "矩形的右边尺寸,顺时针围绕着最左边和最顶边位置.">
    参数 高度 <类型 = 整数 注释 = "矩形的左边尺寸,顺时针围绕着最左边和最顶边位置.">
    参数 角度 <类型 = 小数 注释 = "矩形右边的角度,相对于最左边和最顶边位置.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次裁剪的结果将会放至该目标图像中(本对象将不会裁剪),如果为空对象则使当前本对象进行裁剪." @默认值 = 空对象>
    {
        @ return GetCxImage()->CropRotatedRectangle(@<最左边>, @<最顶边>, @<宽度>, @<高度>, (float)@<角度>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 减少位深度 <公开 类型 = 逻辑型 注释 = "降低当前图像的位深度(每个像素比特减少到指定数目)." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 位深度 <类型 = 整数 注释 = "提供目标位深度.">
    参数 误差扩散 <类型 = 逻辑型 注释 = "处理图像的方式.">
    参数 调色板 <类型 = 图像颜色数组类 注释 = "提供所欲使用的调色板,位深度为1,4,8时分别需要提供2,16,256个成员,提供空对象将使用默认调色板." @默认值 = 空对象>
    参数 重要颜色数 <类型 = 整数 注释 = "提供所欲使用的重要颜色数,在索引图像时用到." @默认值 = 0>
    {
        @ RGBQUAD* rgbs = (BOOL)@<调色板>.IsNullObject() ? NULL : new RGBQUAD[(INT)@<调色板>.GetCount()];
        @ for (INT i = 0; i < (INT)@<调色板>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<调色板>.GetAt(i)).ToRgbQuad();
        @ BOOL ret = GetCxImage()->DecreaseBpp(@<位深度>, @<误差扩散>, rgbs, @<重要颜色数>);
        @ if (rgbs)
        @     delete[] rgbs;
        @ return ret;
    }

    方法 高频振动 <公开 类型 = 逻辑型 注释 = "用指定的黑白处理方法变换当前图像." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 类型 <类型 = 图像处理抖动类型>
    {
        @ @sn<this>.GetCxImage()->Dither(@<类型>)
    }

    方法 扩展 <公开 类型 = 逻辑型 注释 = "基于当前图像进行扩展变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 左边增量 <类型 = 整数 注释 = "将在当前左边基础上加上该值.">
    参数 顶边增量 <类型 = 整数 注释 = "将在当前顶边基础上加上该值.">
    参数 右边增量 <类型 = 整数 注释 = "将在当前右边基础上加上该值.">
    参数 底边增量 <类型 = 整数 注释 = "将在当前底边基础上加上该值.">
    参数 边框颜色 <类型 = 图像颜色类 注释 = "提供所欲使用的边框颜色.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次扩展的结果将会放至该目标图像中(本对象将不会扩展),如果为空对象则使当前本对象进行扩展." @默认值 = 空对象>
    {
        @ return GetCxImage()->Expand(@<左边增量>, @<顶边增量>, @<右边增量>, @<底边增量>, @<边框颜色>.ToRgbQuad(), (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 扩展2 <公开 类型 = 逻辑型 注释 = "基于当前图像进行扩展变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 新宽度 <类型 = 整数 注释 = "提供所欲扩展到的一个新宽度.">
    参数 新高度 <类型 = 整数 注释 = "提供所欲扩展到的一个新高度.">
    参数 边框颜色 <类型 = 图像颜色类 注释 = "提供所欲使用的边框颜色.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次扩展的结果将会放至该目标图像中(本对象将不会扩展),如果为空对象则使当前本对象进行扩展." @默认值 = 空对象>
    {
        @ return GetCxImage()->Expand(@<新宽度>, @<新高度>, @<边框颜色>.ToRgbQuad(), (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 增加位深度 <公开 类型 = 逻辑型 注释 = "增加当前图像的位深度(每个像素比特增加到指定数目)." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 位深度 <类型 = 整数>
    {
        @ @sn<this>.GetCxImage()->IncreaseBpp(@<位深度>)
    }

    方法 缩放 <公开 类型 = 逻辑型 注释 = "缩放图像至一个新的宽高尺寸并填充边框." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 新宽度 <类型 = 整数 注释 = "提供缩小后图像的宽度.">
    参数 新高度 <类型 = 整数 注释 = "提供缩小后图像的高度.">
    参数 边框颜色 <类型 = 图像颜色类 注释 = "提供所欲使用的边框颜色.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次缩放的结果将会放至该目标图像中(本对象将不会缩放),如果为空对象则使当前本对象进行缩放." @默认值 = 空对象>
    {
        @ return GetCxImage()->Thumbnail(@<新宽度>, @<新高度>, @<边框颜色>.ToRgbQuad(), (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 缩放_QI <公开 类型 = 逻辑型 注释 = "高清晰度缩小图像并且效率非常高,对于速度比较重要的场景(缩略图和映射视图)有用,本方法对三基色24位真彩图像效果最好." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 新宽度 <类型 = 整数 注释 = "提供缩小后图像的宽度.">
    参数 新高度 <类型 = 整数 注释 = "提供缩小后图像的高度.">
    参数 改变深度 <类型 = 逻辑型 注释 = "是否在缩小的同时改变位深度." @默认值 = 假>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次缩放的结果将会放至该目标图像中(本对象将不会缩放),如果为空对象则使当前本对象进行缩放." @默认值 = 空对象>
    {
        @ return GetCxImage()->QIShrink(@<新宽度>, @<新高度>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage(), @<改变深度>);
    }

    方法 去除红眼 <公开 类型 = 逻辑型 注释 = "去除人类或动物相片里经常出现的红眼现象." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 强度 <类型 = 小数 注释 = "0-1之间,1表示强度最高." @默认值 = 0.8>
    {
        @ @sn<this>.GetCxImage()->RedEyeRemove((float)@<强度>)
    }

    方法 重定义尺寸 <公开 类型 = 逻辑型 注释 = "基于当前图像对其宽高尺寸重新定义,即重新采样." 返回值注释 = "返回操作是否成功." 编辑时信息 = "5FFFA, 0, 0, 0" @禁止流程检查 = 真>
    参数 新宽度 <类型 = 整数 注释 = "提供改变后图像的新宽度." 编辑时信息 = "5FFFA, 0, 0, 0">
    参数 新高度 <类型 = 整数 注释 = "提供改变后图像的新宽度." 编辑时信息 = "5FFFA, 0, 0, 0">
    参数 模式 <类型 = 图像尺寸重定义模式 注释 = "提供所欲使用的处理模式." 编辑时信息 = "5FFFA, 0, 0, 0" @默认值 = 图像尺寸重定义模式.相邻像素>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次操作的结果将会放至该目标图像中(本对象将不会操作),如果为空对象则使当前本对象进行操作." 编辑时信息 = "5FFFA, 0, 0, 0" @默认值 = 空对象>
    {
        @ return GetCxImage()->Resample(@<新宽度>, @<新高度>, @<模式>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 重定义尺寸2 <公开 类型 = 逻辑型 注释 = "基于当前图像对其宽高尺寸重新定义,即重新采样." 返回值注释 = "返回操作是否成功." 编辑时信息 = "151540, 0, 0, 0" @禁止流程检查 = 真>
    参数 新宽度 <类型 = 整数 注释 = "提供改变后图像的新宽度." 编辑时信息 = "151540, 0, 0, 0">
    参数 新高度 <类型 = 整数 注释 = "提供改变后图像的新宽度." 编辑时信息 = "151540, 0, 0, 0">
    参数 插值算法 <类型 = 图像处理插值算法 注释 = "提供所欲使用的插值算法." 编辑时信息 = "151540, 0, 0, 0" @默认值 = 图像处理插值算法.双三次2>
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." 编辑时信息 = "151540, 0, 0, 0" @默认值 = 图像处理溢出算法.重复>
    参数 禁用均分 <类型 = 逻辑型 注释 = "收缩图像时不强制均分(会产生混叠)." 编辑时信息 = "151540, 0, 0, 0" @默认值 = 假>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次操作的结果将会放至该目标图像中(本对象将不会操作),如果为空对象则使当前本对象进行操作." 编辑时信息 = "151540, 0, 0, 0" @默认值 = 空对象>
    {
        @ return GetCxImage()->Resample2(@<新宽度>, @<新高度>, (CxImage::InterpolationMethod)@<插值算法>, (CxImage::OverflowMethod)@<溢出算法>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage(), @<禁用均分>);
    }

    方法 旋转 <公开 类型 = 逻辑型 注释 = "基于当前图像对其进行旋转变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 角度 <类型 = 小数 注释 = "提供所欲旋转的角度.">
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次旋转的结果将会放至该目标图像中(本对象将不会旋转),如果为空对象则使当前本对象进行旋转." @默认值 = 空对象>
    {
        @ return GetCxImage()->Rotate((float)@<角度>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 旋转180 <公开 类型 = 逻辑型 注释 = "基于当前图像对其进行旋转180度变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次旋转的结果将会放至该目标图像中(本对象将不会旋转),如果为空对象则使当前本对象进行旋转." @默认值 = 空对象>
    {
        @ return GetCxImage()->Rotate180((BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 旋转2 <公开 类型 = 逻辑型 注释 = "基于当前图像对其进行旋转变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 角度 <类型 = 小数 注释 = "提供所欲旋转的角度.">
    参数 插值算法 <类型 = 图像处理插值算法 注释 = "提供所欲使用的插值算法." @默认值 = 图像处理插值算法.双三次2>
    参数 溢出算法 <类型 = 图像处理溢出算法 注释 = "提供所欲使用的溢出算法." @默认值 = 图像处理溢出算法.重复>
    参数 替换颜色 <类型 = 图像颜色数组类 注释 = "提供所欲使用的替换颜色列(在溢出算法为\"颜色\"时使用)." @默认值 = 空对象>
    参数 优化直角 <类型 = 逻辑型 注释 = "是否启用优化直角选项." @默认值 = 真>
    参数 保持原图 <类型 = 逻辑型 注释 = "是否强制保持原图的尺寸." @默认值 = 假>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次旋转的结果将会放至该目标图像中(本对象将不会旋转),如果为空对象则使当前本对象进行旋转." @默认值 = 空对象>
    {
        @ RGBQUAD* rgbs = (BOOL)@<替换颜色>.IsNullObject() ? NULL : new RGBQUAD[(INT)@<替换颜色>.GetCount()];
        @ for (INT i = 0; i < (INT)@<替换颜色>.GetCount(); i++)
        @     rgbs[i] = ((@dt<图像颜色类>&)@<替换颜色>.GetAt(i)).ToRgbQuad();
        @ BOOL ret = GetCxImage()->Rotate2((float)@<角度>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage(), (CxImage::InterpolationMethod)@<插值算法>, (CxImage::OverflowMethod)@<溢出算法>, rgbs, @<优化直角>, @<保持原图>);
        @ if (rgbs)
        @     delete[] rgbs;
        @ return ret;
    }

    方法 倾斜 <公开 类型 = 逻辑型 注释 = "基于当前图像进行倾斜变换." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 水平倾斜比 <类型 = 小数 注释 = "提供0-1之间的值,表示一个百分比.">
    参数 垂直倾斜比 <类型 = 小数 注释 = "提供0-1之间的值,表示一个百分比.">
    参数 支点横坐标 <类型 = 整数 注释 = "提供所欲使用倾斜支点的横坐标." @默认值 = 0>
    参数 支点纵坐标 <类型 = 整数 注释 = "提供所欲使用倾斜支点的纵坐标." @默认值 = 0>
    参数 双线性插值 <类型 = 逻辑型 注释 = "是否启用双线性插值." @默认值 = 假>
    {
        @ @sn<this>.GetCxImage()->Skew((float)@<水平倾斜比>, (float)@<垂直倾斜比>, @<支点横坐标>, @<支点纵坐标>, @<双线性插值>)
    }

    方法 高斯模糊 <公开 类型 = 逻辑型 注释 = "基于当前图像进行高斯模糊处理." 返回值注释 = "返回是否操作成功." @禁止流程检查 = 真>
    参数 模糊半径 <类型 = 小数 注释 = "即控制模糊程度一个系数." @默认值 = 1.0>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次处理的结果将会放至该目标图像中(本对象将不会处理),如果为空对象则使当前本对象进行处理." @默认值 = 空对象>
    {
        @ return GetCxImage()->GaussianBlur((float)@<模糊半径>, (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 文字模糊 <公开 类型 = 逻辑型 注释 = "基于当前图像进行文字模糊处理." 返回值注释 = "返回是否操作成功." @禁止流程检查 = 真>
    参数 阀值 <类型 = 整数 注释 = "提供所欲使用的阀值." @默认值 = 100>
    参数 衰变 <类型 = 整数 注释 = "提供所欲使用的衰变值." @默认值 = 2>
    参数 最大深度 <类型 = 整数 注释 = "指定所欲模糊的最大深度." @默认值 = 5>
    参数 水平模糊 <类型 = 逻辑型 注释 = "是否进行水平方向模糊." @默认值 = 真>
    参数 垂直模糊 <类型 = 逻辑型 注释 = "是否进行垂直方向模糊." @默认值 = 真>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次处理的结果将会放至该目标图像中(本对象将不会处理),如果为空对象则使当前本对象进行处理." @默认值 = 空对象>
    {
        @ return GetCxImage()->TextBlur((uint8_t)@<阀值>, (uint8_t)@<衰变>, (uint8_t)@<最大深度>, @<水平模糊>, @<垂直模糊>, @<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 选择模糊 <公开 类型 = 逻辑型 注释 = "在对比度阈值内选择性模糊图像,类似于非锐化蒙版,在对比度高于一定阀值时锐化所有." @禁止流程检查 = 真>
    参数 模糊半径 <类型 = 小数 注释 = "即控制模糊程度一个系数." @默认值 = 1.0>
    参数 阀值 <类型 = 整数 注释 = "提供所欲使用的阀值." @默认值 = 25>
    参数 目标图像 <类型 = 图像处理类 注释 = "如果提供非空对象,本次处理的结果将会放至该目标图像中(本对象将不会处理),如果为空对象则使当前本对象进行处理." @默认值 = 空对象>
    {
        @ return GetCxImage()->SelectiveBlur((float)@<模糊半径>, (uint8_t)@<阀值>, @<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage());
    }

    方法 曝光 <公开 类型 = 逻辑型 注释 = "将当前图像进行曝光处理,即将所有高于一定亮度的颜色转换成底片." @嵌入式方法 = "">
    参数 等级 <类型 = 整数 注释 = "提供所欲使用的曝光等级,0-255之间." @默认值 = 128>
    参数 保留颜色 <类型 = 逻辑型 @默认值 = 真>
    {
        @ @sn<this>.GetCxImage()->Solarize((uint8_t)@<等级>, @<保留颜色>)
    }

    方法 选择填充 <公开 类型 = 逻辑型 注释 = "选择并填充图像." 注释 = "注意:如果不透明度为0并且加入选区为真,即作为魔术棒功能." @嵌入式方法 = "">
    参数 起始横坐标 <类型 = 整数 注释 = "提供填充的起始横坐标.">
    参数 起始纵坐标 <类型 = 整数 注释 = "提供填充的起始纵坐标.">
    参数 填充颜色 <类型 = 图像颜色类 注释 = "提供所欲使用的填充颜色.">
    参数 颜色偏移 <类型 = 整数 注释 = "从起点的颜色偏移." @默认值 = 0>
    参数 不透明度 <类型 = 整数 注释 = "提供所欲使用的不透明度,0-255之间,255表示完全不透明." @默认值 = 255>
    参数 加入选区 <类型 = 逻辑型 注释 = "是否同时将所填充区域作为选区." @默认值 = 假>
    参数 选区等级 <类型 = 整数 注释 = "指定所欲使用的选区等级." @默认值 = 255>
    {
        @ @sn<this>.GetCxImage()->FloodFill(@<起始横坐标>, @<起始纵坐标>, @<填充颜色>.ToRgbQuad(), @<颜色偏移>, @<不透明度>, @<加入选区>, @<选区等级>)
    }

    方法 饱和 <公开 类型 = 逻辑型 注释 = "改变当前图像进度饱和度." @嵌入式方法 = "">
    参数 饱和度 <类型 = 整数 注释 = "提供所欲设置的饱和度,-100 - 100之间.">
    参数 颜色空间 <类型 = 整数 注释 = "提供1表示使用HSL,2表示使用YUV." @默认值 = 1>
    {
        @ @sn<this>.GetCxImage()->Saturate(@<饱和度>, @<颜色空间>)
    }

    方法 颜色匹配对象 <公开 类型 = 逻辑型 注释 = "根据指定的颜色匹配是否有相应对象." 返回值注释 = "返回匹配结果." @嵌入式方法 = "">
    参数 对象颜色 <类型 = 图像颜色类>
    参数 轮廓颜色 <类型 = 图像颜色类>
    {
        @ @sn<this>.GetCxImage()->Trace(@<对象颜色>.ToRgbQuad(), @<轮廓颜色>.ToRgbQuad())
    }

    # 色彩 ---

    方法 调色 <公开 类型 = 逻辑型 注释 = "替换图像原来的色调和饱和度值." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 色调 <类型 = 字节 注释 = "提供所欲设置的新色调.">
    参数 饱和度 <类型 = 字节 注释 = "提供所欲设置的新饱和度.">
    参数 混合度 <类型 = 小数 注释 = "提供所欲设置的混合度,0-1之间,表示百分比." @默认值 = 1>
    {
        @ @sn<this>.GetCxImage()->Colorize((BYTE)@<色调>, (BYTE)@<饱和度>, (float)@<混合度>)
    }

    方法 合并 <公开 类型 = 逻辑型 注释 = "将不同的颜色图像组合起来." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 红色图层 <类型 = 图像处理类>
    参数 绿色图层 <类型 = 图像处理类>
    参数 蓝色图层 <类型 = 图像处理类>
    参数 Alpha图层 <类型 = 图像处理类 注释 = "透明图层,可以为空对象." @默认值 = 空对象>
    参数 颜色空间 <类型 = 整数 注释 = "提供所欲使用的颜色空间, 0=RGB, 1=HSL, 2=YUV, 3=YIQ, 4=XYZ" @默认值 = 0>
    {
        @ return GetCxImage()->Combine(@<红色图层>.GetCxImage(), @<绿色图层>.GetCxImage(), @<蓝色图层>.GetCxImage(), (BOOL)@<Alpha图层>.IsNullObject() ? NULL : @<Alpha图层>.GetCxImage(), @<颜色空间>);
    }

    方法 轮廓 <公开 类型 = 逻辑型 注释 = "增强相临两个像素的变化值.效果和\"过滤器\"方法类似,但算法和\"边缘\"方法不同." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->Contour()
    }

    方法 扩张 <公开 类型 = 逻辑型 注释 = "增强图像的光区." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 内核尺寸 <类型 = 整数 注释 = "提供所欲使用的内核尺寸." @默认值 = 2>
    {
        @ @sn<this>.GetCxImage()->Dilate(@<内核尺寸>)
    }

    方法 边缘 <公开 类型 = 逻辑型 注释 = "增强相邻像素之间的差异." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 内核尺寸 <类型 = 整数 注释 = "提供所欲使用的内核尺寸." @默认值 = 2>
    {
        @ @sn<this>.GetCxImage()->Edge(@<内核尺寸>)
    }

    方法 侵蚀 <公开 类型 = 逻辑型 注释 = "增强图像的暗区." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 内核尺寸 <类型 = 整数 注释 = "提供所欲使用的内核尺寸." @默认值 = 2>
    {
        @ @sn<this>.GetCxImage()->Erode(@<内核尺寸>)
    }

    方法 傅里叶变换 <公开 类型 = 逻辑型 注释 = "基于当前图像进行二维傅里叶变换." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 原始图 <类型 = 图像处理类 注释 = "提供原始图用于计算,可以提供空对象,与\"图像\"不能同时为空对象." @默认值 = 空对象>
    参数 图像 <类型 = 图像处理类 注释 = "提供图像用于计算,可以提供空对象,与\"原始图\"不能同时为空对象." @默认值 = 空对象>
    参数 目标原图 <类型 = 图像处理类 注释 = "提供变换后的图像变量,变换结果将会存入该变量,如果为空将会变换当前本对象." @默认值 = 空对象>
    参数 目标图像 <类型 = 图像处理类 注释 = "提供变换后的图像变量,变换结果将会存入该变量,如果为空将会变换当前本对象." @默认值 = 空对象>
    参数 逆向变换 <类型 = 逻辑型 注释 = "指定方向是否为逆向." @默认值 = 假>
    参数 强制变换 <类型 = 逻辑型 注释 = "指定是否进行强制变换,即图像将会被重定义尺寸,使其为2的幂." @默认值 = 真>
    参数 重点 <类型 = 逻辑型 注释 = "如果为真,实部返回大小,虚部返回相位." @默认值 = 真>
    {
        @ CxImage* srcReal = (BOOL)@<原始图>.IsNullObject() ? NULL : @<原始图>.GetCxImage();
        @ CxImage* srcImag = (BOOL)@<图像>.IsNullObject() ? NULL : @<图像>.GetCxImage();
        @ CxImage* dstReal = (BOOL)@<目标原图>.IsNullObject() ? NULL : @<目标原图>.GetCxImage();
        @ CxImage* dstImag = (BOOL)@<目标图像>.IsNullObject() ? NULL : @<目标图像>.GetCxImage();
        @ return GetCxImage()->FFT2(srcReal, srcImag, dstReal, dstImag, @<逆向变换> ? -1 : 1, @<强制变换>, @<重点>);
    }

    方法 滤波 <公开 类型 = 逻辑型 注释 = "二维线性滤波器." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 核心阵列 <类型 = 整数数组类 注释 = "提供行格式的矩阵数组,提供多少个数值为一行由参数二决定." 注释 = "例如柔化滤镜为:" 注释 = "核心矩阵列" 注释 = " 1 1 1" 注释 = " 1 8 1"
            注释 = " 1 1 1">
    参数 核心尺寸 <类型 = 整数 注释 = "提供核心尺寸,即阵列每行成员数.">
    参数 因数 <类型 = 整数 注释 = "归一化常数.">
    参数 偏移 <类型 = 整数 注释 = "偏移量.">
    {
        @ INT kernelCount = (INT)@<核心阵列>.data().GetCount();
        @ ASSERT(kernelCount > 0);
        @ int32_t* kernel = new int32_t[kernelCount];
        @ for (INT i = 0; i < kernelCount; i++)
        @     kernel[i] = @<核心阵列>.data().GetAt(i);
        @ BOOL ret = GetCxImage()->Filter(kernel, @<核心尺寸>, @<因数>, @<偏移>);
        @ delete[] kernel;
        @ return ret;
    }

    方法 伽玛系数 <公开 类型 = 逻辑型 注释 = "调整图像的颜色平衡." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 系数 <类型 = 小数 注释 = "取值范围:0.1 - 5.0之间.">
    {
        @ @sn<this>.GetCxImage()->Gamma((float)@<系数>)
    }

    方法 伽玛系数2 <公开 类型 = 逻辑型 注释 = "调整图像的颜色平衡." 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    参数 红色分量 <类型 = 小数 注释 = "取值范围:0.1 - 5.0之间.">
    参数 绿色分量 <类型 = 小数 注释 = "取值范围:0.1 - 5.0之间.">
    参数 蓝色分量 <类型 = 小数 注释 = "取值范围:0.1 - 5.0之间.">
    {
        @ @sn<this>.GetCxImage()->GammaRGB((float)@<红色分量>, (float)@<绿色分量>, (float)@<蓝色分量>)
    }

    方法 柱状 <公开 类型 = 整数 @禁止流程检查 = 真>
    参数 红色 <类型 = 整数数组类 注释 = "提供整数数组变量,返回的结果将会放入该变量.">
    参数 绿色 <类型 = 整数数组类 注释 = "提供整数数组变量,返回的结果将会放入该变量,提供空对象表示不获取该数据." @默认值 = 空对象>
    参数 蓝色 <类型 = 整数数组类 注释 = "提供整数数组变量,返回的结果将会放入该变量,提供空对象表示不获取该数据." @默认值 = 空对象>
    参数 灰色 <类型 = 整数数组类 注释 = "提供整数数组变量,返回的结果将会放入该变量,提供空对象表示不获取该数据." @默认值 = 空对象>
    参数 颜色空间 <类型 = 整数 注释 = "提供所欲使用的颜色空间, 0=RGB, 1=HSL, 2=YUV, 3=YIQ, 4=XYZ" @默认值 = 0>
    {
        @ ASSERT((INT)@<红色>.data.GetCount() > 0);
        @ int32_t* red = new int32_t[256];
        @ int32_t* green = (BOOL)@<绿色>.IsNullObject() ? NULL : new int32_t[256];
        @ int32_t* blue = (BOOL)@<蓝色>.IsNullObject() ? NULL : new int32_t[256];
        @ int32_t* gray = (BOOL)@<灰色>.IsNullObject() ? NULL : new int32_t[256];
        @ INT ret = GetCxImage()->Histogram(red, green, blue, gray, @<颜色空间>);
        @ for (INT i = 0; i < 256; i++)
        @ {
        @     @<红色>.data().Add(red[i]);
        @     if (green) @<绿色>.data().Add(green[i]);
        @     if (blue) @<蓝色>.data().Add(blue[i]);
        @     if (gray) @<灰色>.data().Add(gray[i]);
        @ }
        @ delete[] red;
        @ if (green) delete[] green;
        @ if (blue) delete[] blue;
        @ if (gray) delete[] gray;
        @ return ret;
    }

    方法 柱状平衡 <公开 类型 = 逻辑型 注释 = "柱状平衡" 返回值注释 = "返回操作是否成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->HistogramEqualize()
    }

