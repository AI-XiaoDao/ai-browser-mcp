<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.图像处理

类 图像处理类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "支持多种格式的图像处理." 编辑时信息 = "157762, 0, 0, 0"
        @视窗.外部库.static = "lib\\$(p)\\cximage-$(lm)-$(d).lib\r\nlib\\$(p)\\jpeg-$(lm)-$(d).lib\r\nlib\\$(p)\\png-$(lm)-$(d).lib\r\nlib\\$(p)\\mng-$(lm)-$(d).lib\r\nlib\\$(p)\\tiff-$(lm)-$(d).lib\r\nlib\\$(p)\\jasper-$(lm)-$(d).lib\r\nlib\\$(p)\\libdcr-$(lm)-$(d).lib\r\nlib\\$(p)\\libpsd-$(lm)-$(d).lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib"
        @视窗.需求VS版本.static = "16-" @视窗.外部库.non_static = "lib\\$(p)\\cximagecrt.lib"
        @视窗.附属文件.non_static = "lib\\$(p)\\cximagecrt.dll" @视窗.外部头文件 = "vol_cximage.h" @视窗.头文件搜寻目录 = "lib\\include">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CxImageWrapper)
    #
    # <> <include>
    # public:
    #     inline_ @sn<current_class>(CxImage* pImage):@sn<current_class>()
    #     {
    #         data().TakeOverImageWithPtr(pImage);
    #     }
    #
    #     virtual CxImage* GetCxImage() { return data().GetImagePtr(); }
    # <> </include>
    #
    # //用作定义CxImage子类.
    # @def_macro DECLARE_CXIMAGE_CLASS(vol_wrapper_class, cx_class_name)                  \
    #     @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (vol_wrapper_class)                      \
    # <>     <include>                                                                       \
    #     virtual CxImage* GetCxImage() override { return Get##cx_class_name(); }         \
    #     inline_ cx_class_name* Get##cx_class_name() { return data().GetImagePtr(); }    \
    # <>     </include>
    #
    # @end
    #
    # 创建 ---

    方法 创建自空白图像 <公开 类型 = 逻辑型 注释 = "根据指定尺寸信息以及图像类型创建一张空白图像." 返回值注释 = "返回是否创建成功." 编辑时信息 = "6D54E, 0, 0, 0" @嵌入式方法 = "">
    参数 宽度 <类型 = 整数 注释 = "提供所欲创建图像的宽度." 编辑时信息 = "6D54E, 0, 0, 0">
    参数 高度 <类型 = 整数 注释 = "提供所欲创建图像的高度." 编辑时信息 = "6D54E, 0, 0, 0">
    参数 位深度 <类型 = 整数 注释 = "提供所欲创建图像的位深度,即每个像素点可表示的颜色比特位数,支持1, 4, 8, 24." 编辑时信息 = "6D54E, 0, 0, 0" @默认值 = 8>
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供所欲创建图像的图像类型." 编辑时信息 = "6D54E, 0, 0, 0" @默认值 = 图像格式类型.未知格式>
    {
        @ @sn<this>.GetCxImage()->Create(@<宽度>, @<高度>, @<位深度>, @<图像类型>) != NULL
    }

    方法 创建自图像文件 <公开 类型 = 逻辑型 注释 = "载入外部文件的指定图像数据." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 文件 <类型 = 文本型 注释 = "提供图像文件的完整路径.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供该图像文件的图像类型.">
    {
        @ @sn<this>.GetCxImage()->Load(@<文件>.GetText(), @<图像类型>)
    }

    方法 创建自图像数据 <公开 类型 = 逻辑型 注释 = "以指定的图像数据创建." 返回值注释 = "返回是否创建成功." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供图像数据.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供该图像文件的图像类型.">
    {
        @ CxMemFile mem((uint8_t*)@<数据>.GetPtr(), (uint32_t)@<数据>.GetSize());
        @ return GetCxImage()->Decode(&mem, @<图像类型>);
    }

    方法 创建自文件资源 <公开 类型 = 逻辑型 注释 = "从指定的资源载入对应的图像数据." 返回值注释 = "返回是否创建成功." @禁止流程检查 = 真>
    参数 资源 <类型 = 视窗文件资源 注释 = "提供所欲载入的图像资源.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供该图像文件的图像类型.">
    {
        @ HMODULE hModule = g_objVolApp.GetInstanceHandle ();
        @ HRSRC hSrc = FindResource (hModule, MAKEINTRESOURCE ((WORD)@<资源>), RT_RCDATA);
        @ return hSrc != NULL ? GetCxImage()->LoadResource(hSrc, @<图像类型>, hModule) : FALSE;
    }

    方法 创建自通用缓冲区 <公开 类型 = 逻辑型 注释 = "从通用缓冲区创建图像." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 数据 <类型 = 字节集类 注释 = "提供图像数据.">
    参数 宽度 <类型 = 整数 注释 = "提供所欲创建图像的宽度.">
    参数 高度 <类型 = 整数 注释 = "提供所欲创建图像的高度.">
    参数 位深度 <类型 = 整数 注释 = "提供所欲创建图像的位深度,即每个像素点可表示的颜色比特位数,支持1, 4, 8, 24.">
    参数 行对齐 <类型 = 整数 注释 = "指定所提供的图像数据单行排列的字节数.">
    参数 翻转 <类型 = 逻辑型 注释 = "指定是否翻转图像.">
    {
        @ @sn<this>.GetCxImage()->CreateFromArray(@<数据>.GetPtr(), @<宽度>, @<高度>, @<位深度>, @<行对齐>, @<翻转>)
    }

    方法 创建自矩阵数据 <公开 类型 = 逻辑型 注释 = "从矩阵数据创建图像." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 矩阵 <类型 = 变整数 注释 = "提供所欲使用的矩阵位图数据,提供包含数据(BYTE*)的数组.">
    参数 宽度 <类型 = 整数 注释 = "提供所欲创建图像的宽度.">
    参数 高度 <类型 = 整数 注释 = "提供所欲创建图像的高度.">
    参数 位深度 <类型 = 整数 注释 = "提供所欲创建图像的位深度,即每个像素点可表示的颜色比特位数,支持1, 4, 8, 24.">
    参数 行对齐 <类型 = 整数 注释 = "指定所提供的图像数据单行排列的字节数.">
    参数 翻转 <类型 = 逻辑型 注释 = "指定是否翻转图像.">
    {
        @ @sn<this>.GetCxImage()->CreateFromMatrix((uint8_t**)@<矩阵>, @<宽度>, @<高度>, @<位深度>, @<行对齐>, @<翻转>)
    }

    方法 创建自内存句柄 <公开 类型 = 逻辑型 注释 = "从指定的内存句柄创建图像." 注释 = "注意:本方法会复制内存创建,所提供的句柄必须自行释放,当前对象不会释放所提供的内存句柄." 返回值注释 = "返回是否创建成功."
            @嵌入式方法 = "">
    参数 句柄值 <类型 = 变整数 注释 = "提供所欲使用的内存句柄值(必须为CF_DIB格式).">
    {
        @ @sn<this>.GetCxImage()->CreateFromHANDLE((HANDLE)@<句柄值>)
    }

    方法 创建自位图对象 <公开 类型 = 逻辑型 注释 = "以指定的位图对象创建图像." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 位图 <类型 = 位图对象类 注释 = "提供目标位图对象.">
    {
        @ @sn<this>.GetCxImage()->CreateFromHBITMAP((HBITMAP)@<位图>.GetGDIHandle())    //拷贝创建,不会持久引用或释放该句柄
    }

    方法 创建自图标对象 <公开 类型 = 逻辑型 注释 = "以指定的图标对象创建图像." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 图标 <类型 = 图标对象类 注释 = "提供目标图标对象.">
    {
        @ @sn<this>.GetCxImage()->CreateFromHICON((HICON)@<图标>.GetGDIHandle())
    }

    方法 检查图像格式 <公开 类型 = 逻辑型 注释 = "检查指定图像文件是否与指定图像类型相匹配." 返回值注释 = "如果匹配则返回真,反之假." @禁止流程检查 = 真>
    参数 文件 <类型 = 文本型 注释 = "提供图像文件的完整路径.">
    参数 匹配类型 <类型 = 图像格式类型 注释 = "提供所欲匹配的图像格式类型.">
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<文件>.GetText() ,_T("rb"));
        @ return GetCxImage()->CheckFormat(&ioFile, @<匹配类型>);
    }

    方法 检查图像数据格式 <公开 类型 = 逻辑型 注释 = "检查指定图像数据是否与指定图像类型相匹配." 返回值注释 = "如果匹配则返回真,反之假." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲检查的图像数据.">
    参数 匹配类型 <类型 = 图像格式类型 注释 = "提供所欲匹配的图像格式类型.">
    {
        @ CxMemFile mem((uint8_t*)@<数据>.GetPtr(), (uint32_t)@<数据>.GetSize());
        @ return GetCxImage()->CheckFormat(&mem, @<匹配类型>);
    }

    方法 复制创建 <公开 注释 = "复制另一图像对象所有属性到当前对象中." @嵌入式方法 = "">
    参数 目标图像 <类型 = 图像处理类 注释 = "提供所欲复制的目标对象.">
    参数 复制像素 <类型 = 逻辑型 注释 = "是否复制所有像素." @默认值 = 真>
    参数 复制选区 <类型 = 逻辑型 注释 = "是否同时复制目标图像的选区." @默认值 = 真>
    参数 透明通道 <类型 = 逻辑型 注释 = "是否同时复制目标图像的透明通道." @默认值 = 真>
    {
        @ @sn<this>.GetCxImage()->Copy(*@<目标图像>.GetCxImage(), @<复制像素>, @<透明通道>)
    }

    # 导出 ---

    方法 到位图对象 <公开 类型 = 位图对象类 注释 = "将当前图像数据拷贝创建为一个位图对象." 返回值注释 = "返回复制的结果." @嵌入式方法 = "">
    {
        @ @dt<位图对象类> (@sn<this>.GetCxImage()->MakeBitmap(), GOADT_DELETE_OBJECT)
    }

    方法 到内存句柄 <公开 类型 = 变整数 注释 = "将当前图像数据拷贝到系统内存并返回该句柄." 注释 = "注意:所返回内存句柄不会被自动释放,必须确保外部可以正常释放该句柄,请谨慎调用该方法." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.GetCxImage()->CopyToHandle()
    }

    方法 到图像数据 <公开 类型 = 逻辑型 注释 = "将当前图像数据写出到指定字节集中储存." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类 注释 = "用作存放所获得的图像数据.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供当前图像的格式类型.">
    {
        @ CxMemFile mem;
        @ if (mem.Open())
        @ {
        @     BOOL ret = GetCxImage()->Encode(&mem, @<图像类型>);
        @     if (ret)
        @     {
        @         @<缓冲区>.CopyFrom(mem.GetBuffer(FALSE), mem.Size());    //GetBuffer(FALSE),原数据交由CxMemFile析构释放
        @         return TRUE;
        @     }
        @ }
        @ return FALSE;
    }

    方法 到多帧图像数据 <公开 类型 = 逻辑型 注释 = "将指定的图像数组(多帧)写出到指定字节集中储存." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 图像帧 <类型 = 图像处理数组类 注释 = "提供所欲写出的多个图像帧.">
    参数 缓冲区 <类型 = 字节集类 注释 = "用作存放所获得的图像数据.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供所欲保存的图像类型.">
    {
        @ INT imageCount = (INT)@<图像帧>.GetCount();
        @ ASSERT(imageCount > 0);
        @ CxImage** pImages = new CxImage*[imageCount];
        @ for (INT i = 0; i < imageCount; i++)
        @     pImages[i] = ((@dt<图像处理类>&)@<图像帧>.GetAt(i)).GetCxImage();
        @ CxMemFile mem;
        @ BOOL ret = 0;
        @ if (mem.Open())
        @ {
        @     ret = GetCxImage()->Encode(&mem, pImages, imageCount, @<图像类型>);
        @     if (ret)
        @         @<缓冲区>.CopyFrom(mem.GetBuffer(FALSE), mem.Size());    //GetBuffer(FALSE),原数据交由CxMemFile析构释放
        @ }
        @ delete[] pImages;
        @ return ret;
    }

    方法 到RGBA图像数据 <公开 类型 = 逻辑型 注释 = "将当前图像数据编码导出为RGBA图像格式数据至指定字节集中储存." 返回值注释 = "返回是否写出成功." @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类 注释 = "用作存放所获得的图像数据.">
    {
        @ CxMemFile mem;
        @ BOOL ret = 0;
        @ if (mem.Open())
        @ {
        @     ret = GetCxImage()->Encode2RGBA(&mem);
        @     if (ret)
        @         @<缓冲区>.CopyFrom(mem.GetBuffer(FALSE), mem.Size());
        @ }
        @ return ret;
    }

    方法 保存到文件 <公开 类型 = 逻辑型 注释 = "将当前图像编码写出保存至目标文件." 返回值注释 = "返回是否写出保存成功." @嵌入式方法 = "">
    参数 保存路径 <类型 = 文本型 注释 = "提供所欲保存图像的完整路径.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供所欲保存的图像类型.">
    {
        @ @sn<this>.GetCxImage()->Save(@<保存路径>.GetText(), @<图像类型>)
    }

    方法 保存多帧图像到文件 <公开 类型 = 逻辑型 注释 = "将指定的图像数组(多帧)写出保存至目标文件(例如GIF格式图像)." 返回值注释 = "返回是否写出保存成功." @禁止流程检查 = 真>
    参数 图像帧 <类型 = 图像处理数组类 注释 = "提供所欲写出的多个图像帧.">
    参数 保存路径 <类型 = 文本型 注释 = "提供所欲保存图像的完整路径.">
    参数 图像类型 <类型 = 图像格式类型 注释 = "提供所欲保存的图像类型.">
    {
        @ INT imageCount = (INT)@<图像帧>.GetCount();
        @ ASSERT(imageCount > 0);
        @ CxImage** pImages = new CxImage*[imageCount];
        @ for (INT i = 0; i < imageCount; i++)
        @     pImages[i] = ((@dt<图像处理类>&)@<图像帧>.GetAt(i)).GetCxImage();
        @ //写到文件
        @ CxIOFile ioFile;
        @ ioFile.Open(@<保存路径>.GetText() ,_T("wb"));
        @ BOOL ret = GetCxImage()->Encode(&ioFile, pImages, imageCount, @<图像类型>);
        @ delete[] pImages;
        @ return ret;
    }

    方法 保存RGBA图像到文件 <公开 类型 = 逻辑型 注释 = "将当前图像数据编码导出为RGBA图像格式文件,主要用于OpenGL程序." 返回值注释 = "返回是否写出保存成功." @禁止流程检查 = 真>
    参数 保存路径 <类型 = 文本型 注释 = "提供所欲保存图像的完整路径.">
    {
        @ CxIOFile ioFile;
        @ ioFile.Open(@<保存路径>.GetText() ,_T("wb"));
        @ return GetCxImage()->Encode2RGBA(&ioFile);
    }

    方法 取图像信息 <公开 类型 = 图像信息类 注释 = "获取图像的Exif信息." @嵌入式方法 = "">
    {
        @ @dt<图像信息类>(@sn<this>.GetCxImage()->GetExifInfo())
    }

    方法 释放图像 <公开 类型 = 逻辑型 注释 = "释放当前图像所占用资源,调用后图像需要重新创建." 返回值注释 = "如果当前图像存在多帧,必须在调用之前使用\"释放所有帧\",否则将释放失败." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->Destroy()
    }

    方法 释放所有帧 <公开 类型 = 逻辑型 注释 = "释放当前图像中的所有帧数据." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->DestroyFrames()
    }

    # ---

    方法 置禁用 <公开 注释 = "指定当前图像的启用/禁用状态." @嵌入式方法 = "">
    参数 是否禁用 <类型 = 逻辑型>
    {
        @ @sn<this>.GetCxImage()->Enable(!@<是否禁用>)
    }

    方法 取禁用 <公开 类型 = 逻辑型 注释 = "获取当前图像的启用/禁用状态." @嵌入式方法 = "">
    {
        @ !@sn<this>.GetCxImage()->IsEnabled ()
    }

    方法 清除 <公开 注释 = "设置当前图像的比特到指定的值." @嵌入式方法 = "">
    参数 比特 <类型 = 字节>
    {
        @ @sn<this>.GetCxImage()->Clear(@<比特>)
    }

    方法 取像素指针 <公开 类型 = 变整数 注释 = "获取当前图像指定行的像素指针." @嵌入式方法 = "">
    参数 行索引 <类型 = 整数 注释 = "提供指定行数." @默认值 = 0>
    {
        @ (INT_P)@sn<this>.GetCxImage()->GetBits(@<行索引>)
    }

    方法 取位深度 <公开 类型 = 整数 注释 = "返回当前图像的位深度." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCxImage()->GetBpp()
    }

    方法 置重要颜色数 <公开 注释 = "设置最大重要颜色数,在索引图像时用到." @嵌入式方法 = "">
    参数 颜色数目 <类型 = 整数 注释 = "应小于2^位深度,提供0表示所有颜色都将标为重要颜色.">
    {
        @ @sn<this>.GetCxImage()->SetClrImportant(@<颜色数目>)
    }

    方法 取重要颜色数 <公开 类型 = 整数 注释 = "获取所设置的最大重要颜色数量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCxImage()->GetClrImportant()
    }

    方法 置编解码选项 <公开 类型 = 逻辑型 注释 = "设置某些格式图像的编解码设置项." 返回值注释 = "返回是否设置成功." @嵌入式方法 = "">
    参数 选项 <类型 = 图像编解码选项 注释 = "提供所欲设置的选项.">
    参数 图像格式 <类型 = 图像格式类型 注释 = "仅支持JPG格式,GIF格式以及TIF格式.">
    {
        @ @sn<this>.GetCxImage()->SetCodecOption(@<选项>, @<图像格式>)
    }

    方法 取编解码选项 <公开 类型 = 图像编解码选项 注释 = "获取某些格式图像的编解码设置项." @嵌入式方法 = "">
    参数 图像格式 <类型 = 图像格式类型 注释 = "仅支持JPG格式,GIF格式以及TIF格式.">
    {
        @ @sn<this>.GetCxImage()->GetCodecOption(@<图像格式>)
    }

    方法 取颜色类型 <公开 类型 = 字节 注释 = "获取当前图像的颜色类型." 返回值注释 = "返回1表示索引色(indexed),返回2表示三基色(RGB),返回4表示RGBA." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->GetColorType()
    }

    方法 取DIB <公开 类型 = 变整数 注释 = "取当前图像内部使用的DIB指针." 返回值注释 = "返回一个DIB指针,包含头信息." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.GetCxImage()->GetDIB()
    }

    方法 取对齐宽度 <公开 类型 = 整数 注释 = "获取当前图像的对齐宽度" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCxImage()->GetEffWidth()
    }

    方法 置退出码 <公开 注释 = "设置退出码以用来退出太慢的循环或编码过程." @嵌入式方法 = "">
    参数 退出码 <类型 = 整数 注释 = "-1表示在解码之前获取到图像宽高后强制退出,仅用于指定的图像格式(BMP, JPG, GIF, TIF)." @默认值 = -1>
    {
        @ @sn<this>.GetCxImage()->SetEscape(@<退出码>)
    }

    方法 取退出码 <公开 类型 = 整数 注释 = "获取所设置的退出码." @嵌入式方法 = "">
    {
