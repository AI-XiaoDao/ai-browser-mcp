        @ @sn<this>.GetCxImage()->AlphaPaletteEnable(@<是否启用>)
    }

    方法 取Alpha调色板是否启用 <公开 类型 = 逻辑型 注释 = "获取当前是否已启用Alpha调色板(将会影响到\"绘制\"系列方法)." 返回值注释 = "返回真表示已启用,反之未启用." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->AlphaPaletteIsEnabled()
    }

    方法 Alpha调色板是否有效 <公开 类型 = 逻辑型 注释 = "检查当前图像是否具有有效的Alpha调色板." 返回值注释 = "返回是否有效." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->AlphaPaletteIsValid()
    }

    方法 Alpha调色板导出 <公开 类型 = 逻辑型 注释 = "将当前Alpha调色板导出为一个8位灰度图像." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 存放图像 <类型 = 图像处理类 注释 = "所导出的图像将会置入该变量.">
