    # 选区 ---

    方法 选区添加颜色 <公开 类型 = 逻辑型 注释 = "提供指定颜色,将所有匹配该颜色的像素添加至选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 颜色 <类型 = 图像颜色类 注释 = "提供所欲添加至选区的像素颜色.">
    {
        @ @sn<this>.GetCxImage()->SelectionAddColor(@<颜色>.ToRgbQuad())
    }

    方法 选区添加椭圆 <公开 类型 = 逻辑型 注释 = "圈定一个椭圆,将该区域添加至选区." 返回值注释 = "返回是否操作成功." @禁止流程检查 = 真>
    参数 区域 <类型 = 矩形类 注释 = "提供所欲添加至选区的椭圆区域.">
    {
        @ RECT rect = {@<区域.左边>, @<区域.顶边>, @<区域.右边>, @<区域.底边>};
        @ return GetCxImage()->SelectionAddEllipse(rect);
    }

    方法 选区添加像素 <公开 类型 = 逻辑型 注释 = "将指定的一个像素点添加至选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数 注释 = "提供所欲添加像素的横坐标.">
    参数 纵坐标 <类型 = 整数 注释 = "提供所欲添加像素的纵坐标.">
    {
        @ @sn<this>.GetCxImage()->SelectionAddPixel(@<横坐标>, @<纵坐标>)
    }

    方法 选区添加多边形 <公开 类型 = 逻辑型 注释 = "提供多个顶点,连接起来成为一个多边形添加至选区." 返回值注释 = "返回是否操作成功." @禁止流程检查 = 真>
    参数 顶点数组 <类型 = 位置数组类 注释 = "提供所欲圈定多边形的所有顶点.">
    {
        @ INT count = (INT)@<顶点数组>.GetCount();
        @ ASSERT(count > 3)    //小于3个顶点无法圈定一个图形
        @ POINT* points = new POINT[count];
        @ BOOL ret = 0;
        @ for (INT i = 0; i < count; i++)
        @ {
        @     POINT point;
        @     ((@dt<位置类>&)@<顶点数组>.GetAt(i)).Out(&point);
        @     points[i] = point;
        @ }
        @ ret = GetCxImage()->SelectionAddPolygon(points, count);
        @ delete[] points;
        @ return ret;
    }

    方法 选区添加矩形 <公开 类型 = 逻辑型 注释 = "圈定一个矩形,将该矩形区域添加至选区." 返回值注释 = "返回是否操作成功." @禁止流程检查 = 真>
    参数 区域 <类型 = 矩形类 注释 = "提供所欲添加至选区的矩形区域.">
    {
        @ RECT rect = {@<区域.左边>, @<区域.顶边>, @<区域.右边>, @<区域.底边>};
        @ return GetCxImage()->SelectionAddRect(rect);
    }

    方法 选区清空 <公开 类型 = 逻辑型 注释 = "清空当前选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->SelectionClear()
    }

    方法 选区复制 <公开 类型 = 逻辑型 注释 = "从另外一个图像复制一个已经存在的选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 图像 <类型 = 图像处理类 注释 = "提供所欲复制其选区的图像.">
    {
        @ @sn<this>.GetCxImage()->SelectionCopy(*@<图像>.GetCxImage())
    }

    方法 选区创建 <公开 类型 = 逻辑型 注释 = "分配创建一个空选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->SelectionCreate()
    }

    方法 选区删除 <公开 类型 = 逻辑型 注释 = "释放并删除当前选区." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->SelectionDelete()
    }

    方法 选区范围 <公开 类型 = 矩形类 注释 = "以矩形方式返回当前的选区范围." 返回值注释 = "返回当前的选区范围." @禁止流程检查 = 真>
    {
        @ RECT rect;
        @ GetCxImage()->SelectionGetBox(rect);
        @ return @dt<矩形类>(&rect);
    }

    方法 选区反选 <公开 类型 = 逻辑型 注释 = "反选当前选区,即将原有未选择的区域选中,已选择的区域取消选择." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->SelectionInvert()
    }

    方法 选区之内 <公开 类型 = 逻辑型 注释 = "指定一个像素点,判断其是否处于当前选区之中." 返回值注释 = "处于选区中返回真,反之假." @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数 注释 = "提供所欲该像素点的横坐标.">
    参数 纵坐标 <类型 = 整数 注释 = "提供所欲该像素点的纵坐标.">
    {
        @ @sn<this>.GetCxImage()->SelectionIsInside(@<横坐标>, @<纵坐标>)
    }

    方法 选区是否有效 <公开 类型 = 逻辑型 注释 = "检查当前图像上的选区是否有效." 返回值注释 = "返回选区是否有效." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->SelectionIsValid()
    }

    方法 选区导出 <公开 类型 = 逻辑型 注释 = "将当前选定的区域导出为一个8位灰度图像." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 存放图像 <类型 = 图像处理类 注释 = "所导出的图像将会置入该变量.">
    {
        @ @sn<this>.GetCxImage()->SelectionSplit(@<存放图像>.GetCxImage())
    }

    方法 选区到区域句柄 <公开 类型 = 变整数 注释 = "将当前选区转换至一个区域句柄(HRGN)." 注释 = "注意:所返回句柄务必自行调用DeleteObject释放,不理解指针概念请勿调用本方法."
            返回值注释 = "执行成功返回句柄值,失败返回0." @禁止流程检查 = 真>
    {
        @ HRGN hrgn = NULL;
        @ if (GetCxImage()->SelectionToHRGN(hrgn))
        @     return (INT_P)hrgn;
        @ if (hrgn)    //避免接口返回FLASE但句柄被分配.
        @     ::DeleteObject (hrgn);
        @ return 0;
    }

    # 透明通道 ---

    方法 Alpha清除 <公开 注释 = "清除透明通道." @嵌入式方法 = "">
