        @ @sn<this>.GetCxImage()->AlphaStrip()
    }

    # 图层 ---

    方法 取指定图层 <公开 类型 = 图像处理类 注释 = "取指定图层的图像." 返回值注释 = "返回该图层的图像对象." @嵌入式方法 = "">
    参数 索引 <类型 = 整数 注释 = "提供所欲获取的图层索引,小于0表示获取最后一个图层.">
    {
        @ @dt<图像处理类>(@sn<this>.GetCxImage()->GetLayer(@<索引>))
    }

    方法 取图层数量 <公开 类型 = 整数 注释 = "获取当前图像所存在图层的数量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCxImage()->GetNumLayers()
    }

    方法 取图层父对象 <公开 类型 = 图像处理类 注释 = "如果当前本对象为一个图层对象,则取他所属的父对象." @嵌入式方法 = "">
    {
        @ @dt<图像处理类>(@sn<this>.GetCxImage()->GetParent())
    }

    方法 新建空图层 <公开 类型 = 逻辑型 注释 = "创建一个新的空白图层." 返回值注释 = "返回是否创建成功." @嵌入式方法 = "">
    参数 插入位置 <类型 = 整数 注释 = "提供所创建的图层所欲插入的索引位置,小于0表示放置在最后." @默认值 = -1>
    {
        @ @sn<this>.GetCxImage()->LayerCreate(@<插入位置>)
    }

    方法 删除图层 <公开 类型 = 逻辑型 注释 = "删除指定索引处的图层." 返回值注释 = "返回是否删除成功." @嵌入式方法 = "">
    参数 索引 <类型 = 整数 注释 = "提供所欲删除图层的索引位置,小于0表示删除最后的一个图层." @默认值 = -1>
    {
        @ @sn<this>.GetCxImage()->LayerDelete(@<索引>)
    }

    方法 删除所有图层 <公开 注释 = "删除全部的图层." @嵌入式方法 = "">
    {
        @ @sn<this>.GetCxImage()->LayerDeleteAll()
    }

    # 静态方法 ---

    方法 HSL到RGB <公开 静态 类型 = 图像颜色类 注释 = "将HSL颜色转到RGB颜色." 返回值注释 = "返回转换后的颜色." @嵌入式方法 = "">
    参数 颜色 <类型 = 图像颜色类 注释 = "提供所欲转换的颜色.">
    {
        @ @dt<图像颜色类>(CxImage::HSLtoRGB(@<颜色>.ToRgbQuad()))
    }

    方法 HSL颜色值到RGB <公开 静态 类型 = 图像颜色类 注释 = "将HSL颜色值转到RGB颜色." 返回值注释 = "返回转换后的颜色." @嵌入式方法 = "">
