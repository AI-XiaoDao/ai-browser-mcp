<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <@文档 = "category = \"设备操作\"">

类 串口流控制模式 <公开 @文档 = "category = \"串口通讯.辅助类\"" @常量类 = 整数>
{
    常量 默认 <公开 值 = 0>
    常量 禁止 <公开 值 = 1>
    常量 启用 <公开 值 = 2>
}

类 串口流控制方案 <公开 @文档 = "category = \"串口通讯.辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = 0>
    常量 CtsRts <公开 值 = 1>
    常量 CtsDtr <公开 值 = 2>
    常量 DsrRts <公开 值 = 3>
    常量 DsrDtr <公开 值 = 4>
    常量 XonXoff <公开 值 = 5>
}

类 串口停止位数 <公开 注释 = "提供串口停止位的数目" @文档 = "category = \"串口通讯.辅助类\"" @常量类 = 整数>
{
    常量 一位 <公开 值 = 1 注释 = "1位">
    常量 一点五位 <公开 值 = 2 注释 = "1.5位">
    常量 二位 <公开 值 = 3 注释 = "2位">
}

类 串口奇偶校验方式 <公开 @文档 = "category = \"串口通讯.辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = 0>
    常量 奇校验 <公开 值 = 1>
    常量 偶校验 <公开 值 = 2>
    常量 标志校验 <公开 值 = 3>
    常量 空白校验 <公开 值 = 4>
}

类 串口类 <公开 注释 = "提供对串口操作的支持" @文档 = "category = \"串口通讯\"" @视窗.后缀文本 = "public IVolSerialEventInterface"
        @视窗.外部头文件 = "libs\\serial\\vol_serial.h" @视窗.外部源文件 = "libs\\serial\\vol_serial.cpp">
{
    变量 端口号 <公开 类型 = 整数 值 = 1 注释 = "提供所欲访问的端口号,从 1 开始." @属性变量 = 真>
    变量 波特率 <公开 类型 = 整数 值 = 19200 注释 = "指定通信端口所使用的波特率,比较常用的波特率有:"
            注释 = "  110, 300, 600, 1200, 2400, 4800, 9600, 14400, 19200, 38400, 56000, 57600, 115200, 128000, 256000." @属性变量 = 真>
    变量 数据位数 <公开 类型 = 整数 值 = 8 @属性变量 = 真>
    变量 停止位数 <公开 类型 = 串口停止位数 值 = 串口停止位数.一位 @属性变量 = 真>
    变量 奇偶校验 <公开 类型 = 逻辑型 值 = 假 注释 = "指定通信时对数据是否进行奇偶校验" @属性变量 = 真>
    变量 事件字符 <公开 类型 = 字符 值 = '\0' 注释 = "指定用作触发事件的字符,必须为ASCII字符,为\'\\0\'表示不支持事件字符." @属性变量 = 真>
    变量 等待时间 <公开 类型 = 整数 值 = 1000 注释 = "指定在进行端口读写操作时最长等待时间,单位毫秒.为0表示无限等待." @属性变量 = 真>
    变量 奇偶校验方案 <公开 类型 = 串口奇偶校验方式 值 = 串口奇偶校验方式.无 注释 = "指定通信时所使用的具体奇偶校验位方案" @属性变量 = 真>
    变量 流控制方案 <公开 类型 = 串口流控制方案 值 = 串口流控制方案.无 注释 = "指定通信时所使用的流控制方案" @属性变量 = 真>
    变量 Rts流控制 <公开 类型 = 串口流控制模式 值 = 串口流控制模式.默认 注释 = "指定通信时是否启用Rts流控制" @属性变量 = 真>
    变量 Dtr流控制 <公开 类型 = 串口流控制模式 值 = 串口流控制模式.默认 注释 = "指定通信时是否启用Dtr流控制" @属性变量 = 真>

    方法 收到信号 <公开 定义事件 类型 = 整数 注释 = "当通信端口的信号状态发生改变时,会产生本事件.">
    参数 信号类型 <类型 = 整数 注释 = "指示具体检测到信号状态的类型,为以下值之一:"
            注释 = "   1: BREAK信号; 2:CTS上升沿信号;  3: DSR上升沿信号; 4: ERR信号; 5: RING信号; 6: RLSD上升沿信号; 7: 事件字符到达; 8: CTS下降沿信号; 9: DSR下降沿信号; 10: RLSD下降沿信号.">

    方法 数据到达 <公开 定义事件 类型 = 整数 注释 = "每当通信端口接收到一个数据字节,就会产生本事件.">
    参数 数据字节值 <类型 = 整数 注释 = "提供所接收到的数据字节值">

    方法 启动 <公开 类型 = 逻辑型 注释 = "启动或重新启动对指定端口的操作. 在对端口进行操作之前必须首先启动,如在端口启动后又更改了端口属性必须重新启动." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    {
        @ return (BOOL)m_objSerial.init (this, MAX (1, @<端口号>), MAX (0, @<波特率>), @<奇偶校验>, @<数据位数>, CLIP (@<停止位数>, 1, 3), (char)@<事件字符>,
        @         MAX (0, @<等待时间>), CLIP (@<奇偶校验方案>, 0, 4), CLIP (@<流控制方案>, 0, 5), CLIP (@<Rts流控制>, 0, 2), CLIP (@<Dtr流控制>, 0, 2));
    }

    方法 停止 <公开 注释 = "关闭已经启动的指定端口" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objSerial.Cleanup ()
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "从端口发送指定的数据" 返回值注释 = "成功返回真,失败返回假." 编辑时信息 = "ABFF5, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 所欲发送的所有数据 <注释 = "提供所欲发送的所有数据,可以为基本数据类型或字节集类数据." 注释 = "注意: 文本型数据为Unicode编码且包括结束零字符,如需以其它编码或格式发送文本,请将其转换为相应字节集."
            编辑时信息 = "ABFF5, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.m_objSerial.WriteData (CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>), @<所欲发送的所有数据>))
    }

    方法 信号操作 <公开 类型 = 逻辑型 注释 = "本命令可以设置或清除通讯端口上指定信号的状态" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 操作类型 <类型 = 整数 注释 = "本参数可以为以下值之一:  1: 清除信号;  2: 发送或置位.">
    参数 欲操作信号类型 <类型 = 整数 注释 = "本参数可以为以下值之一:  1: DTR信号;  2: RTS信号; 3: Break信号">
    {
        @ (BOOL)@sn<this>.m_objSerial.EscapeComm (@<操作类型>, @<欲操作信号类型>)
    }

    方法 取可用串口 <公开 静态 类型 = 整数 注释 = "从注册表中获取系统中当前所有可用串口列表" 返回值注释 = "返回所获得串口名称的数目">
    参数 结果存储参数 <类型 = 文本排序数组类 注释 = "本参数用作存储所有获得的串口名称">
    {
        结果存储参数.删除所有成员 ()
        @ HKEY hkey;
        @ if (SUCCEEDED (RegOpenKeyEx(HKEY_LOCAL_MACHINE, _T("Hardware\\DeviceMap\\SerialComm"), NULL, KEY_READ, &hkey)))
        @ {
        @     TCHAR portName [256], commName [256];
        @     for (INT nIndex = 0; ; nIndex++)
        @     {
        @         DWORD dwSize = NUM_ELEMENTS_OF (portName);
        @         DWORD dwLong = dwSize;
        @         if (RegEnumValue (hkey, nIndex, portName, &dwLong, NULL, NULL, (LPBYTE)commName, &dwSize) != ERROR_SUCCESS)
        @             break;
        @         @<结果存储参数>.data ().Add (commName);
        @     }
        @     RegCloseKey (hkey);
        @ }
        返回 (结果存储参数.取成员数 ())
    }

    # @ <include>
    # @ CVolSerial m_objSerial;
    # @ virtual void OnEvent (INT nEventType) override  { @<收到信号> (nEventType); }
    # @ virtual void OnRecvByte (INT byte) override  { @<数据到达> (byte); }
    # @ </include>
}
