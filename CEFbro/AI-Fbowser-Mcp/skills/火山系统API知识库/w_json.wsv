    常量 逻辑值 <公开 值 = 5 注释 = "表示逻辑型">
    常量 键值列表 <公开 值 = 6 注释 = "表示JSON数组类">
    常量 键值表 <公开 值 = 7 注释 = "表示JSON对象类">
}
