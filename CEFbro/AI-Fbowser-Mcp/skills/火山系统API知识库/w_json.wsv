类 JSON基础类 <公开 注释 = "不要直接使用本类,请使用\"JSON数组类\"或\"JSON对象类\",来操作JSON数据." 注释 = "2021.05.12升级至jsoncpp-1.9.4."
        注释 = "2025.08.09升级至jsoncpp-1.9.7." 编辑时信息 = "1FD535, 0, 0, 0" @文档 = "category = \"辅助类\""
