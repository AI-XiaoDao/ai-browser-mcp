    方法 启用顺序输出 <公开 静态 注释 = "调用本方法以启用JSON顺序输出文本,即\"到可读文本\"时键值的顺序将遵循添加该键值时的顺序." @视窗.预定义宏 = "JSON_CPP_SEQUE_OUTPUT">

    方法 启用线程安全 <公开 静态 注释 = "   如果调用了此方法,那么模块内部会自动加锁,多线程操作时会处于安全状态." 注释 = "   如果不调用此方法,则模块不保证线程安全."
            注释 = "   此时用户应该自行确保不同线程操作的时候,不要出现一个线程读一个线程写,另外一个线程" 注释 = "删除的情况,否则会引起程序的崩溃." @视窗.预定义宏 = "JSON_CPP_THREAD_SAFE">

    方法 到可读文本 <公开 类型 = 文本型 注释 = " 把JSON转换成可读文本并格式化数据." 注释 = " 例如:" 注释 = " {" 注释 = "  \"query\": \"VolDev\","
            注释 = "  \"locations\": [" 注释 = "     100," 注释 = "     101" 注释 = "  ]" 注释 = " }" @嵌入式方法 = "">
    参数 是否格式化 <类型 = 逻辑型 注释 = "提供真将会进行格式化操作,则会用空格换行进行格式化." @默认值 = 假>
    参数 是否不转义 <类型 = 逻辑型 注释 = "如果假,遇到中文则会以这种方式显示\"\\0xfbfe\\0xfafd\",填写真将显示为正常的中文字符." @默认值 = 真>
    {
        @ @an<CVolString>( @sn<this>.ToStringW(@<是否格式化>,@<是否不转义>).c_str() )
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把JSON格式化成UTF8的字节集" @禁止流程检查 = 真>
    参数 是否格式化 <类型 = 逻辑型 注释 = "如果格式化,则会用空格换行进行格式化操作." @默认值 = 假>
    参数 是否使用UTF8编码 <类型 = 逻辑型 注释 = "如果真将进行UTF8编码字节集." @默认值 = 假>
    {
        @ std::string& str = ToStringA(@<是否格式化>,@<是否使用UTF8编码>);
        @ return CVolMem (str.c_str(),str.length());
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "从一段UTF8字节集载入,务必保证载入的字节集数据是JSON数据." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "必须是utf8的字节集">
    {
        变量 文本指针 <类型 = 变整数>
        变量 文本长度 <类型 = 整数>
        文本指针 = 取字节集指针 (数据)
        文本长度 = 取字节集长度 (数据)
        @ return LoadFromStringA((const char*)@<文本指针>,@<文本长度>);
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "从JSON文本创建,返回是否成功." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "必须是Json格式的文本">
    {
        变量 文本指针 <类型 = 变整数>
        变量 文本长度 <类型 = 整数>
        文本指针 = 取文本指针 (内容)
        文本长度 = 取文本长度 (内容)
        @ return LoadFromStringW((const wchar_t*)@<文本指针>,@<文本长度>);
    }

    方法 清空 <公开 注释 = "清空本对象中的数据" @嵌入式方法 = "">
    {
        @ @sn<this>.clear()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象的内容是否为空" @嵌入式方法 = "">
    {
        @ @sn<this>.IsEmpty()
    }

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "如果操作当前属性的是\"JSON对象类\",则返回键数量.如果是\"JSON数组类\",则返回数组成员数." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetCount()
    }
}

类 JSON数组类 <公开 基础类 = JSON基础类 注释 = "通过本类可对JSON数组进行操作" @输出到部件 = 假>
{
    方法 到文本数组 <公开 静态 注释 = "  将当前JSON数组的每个成员取出,转换成文本数组," 注释 = "并将其存放到所指定的结果文本数组参数中." 折叠>
    参数 所操作的本对象 <类型 = JSON数组类>
    参数 结果数组 <类型 = 文本数组类 注释 = "结果保存在此参数中">
    {
        结果数组.删除所有成员 ()
        变量 索引值 <类型 = 整数>
        循环 (, 所操作的本对象.成员数, 索引值)
        {
            结果数组.加入成员 (所操作的本对象.取文本值 (索引值))
        }
    }

    方法 删除成员 <公开 静态 注释 = "删除指定索引位置处的成员" 编辑时信息 = "8DFF7, 0, 0, 0" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = JSON数组类 编辑时信息 = "8DFF7, 0, 0, 0">
    参数 所删除成员索引位置 <类型 = 整数 注释 = "索引位置从0开始" 编辑时信息 = "8DFF7, 0, 0, 0" "">
    {
        @ @<所操作的本对象>.Remove((UINT)@<所删除成员索引位置>)
    }

    方法 删除路径成员 <公开 静态 注释 = "删除指定路径处的成员" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = JSON数组类>
    参数 所删除成员路径 <类型 = 文本型 注释 = "提供JSON路径">
    {
        @ @<所操作的本对象>.Remove(@<所删除成员路径>)
    }

