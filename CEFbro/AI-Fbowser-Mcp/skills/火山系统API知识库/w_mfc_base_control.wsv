    常量 手动调节器 <公开 值 = 2>
}

类 编辑框气泡图标 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = @TTI_NONE>
    常量 信息 <公开 值 = @TTI_INFO>
    常量 警告 <公开 值 = @TTI_WARNING>
    常量 错误 <公开 值 = @TTI_ERROR>
}

类 编辑框 <公开 基础类 = 窗口组件 注释 = "编辑框窗口组件类" 编辑时信息 = "183FE7, 0, 0, 0" @视窗.后缀文本 = "public IEditEventListener"
        @视窗.窗口组件 = "icon=\"@56\"\r\ndefault_size = \"80, 20\"\r\ndefault_event = \"内容被改变\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Edit, IEditEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 内容被改变 <公开 定义事件 类型 = 整数 注释 = "编辑框内容被改变后本事件被发送">

    方法 调节钮被按下 <公开 定义事件 类型 = 整数 注释 = "  当编辑框的调节器方式为\"手动调节器\"时才会产生此事件," 注释 = "用作发送编辑框一侧的调节器按钮被单击通知.">
    参数 被单击调节按钮 <类型 = 整数 注释 = "如果按下的是调节器的向上箭头按钮,参数值为1,否则为-1.">

    # 属性 --

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.白色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_Edit*)GetMfcWndPtr ())->SetBackColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值." 注释 = "如果本组件未曾设置过文本颜色,则默认为黑色." @视窗.设置时机 = 组件创建前后 @值细节类型 = 颜色>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_Edit*)pWnd)->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "返回本组件的当前内容文本. 本属性等同于窗口组件类中的标题属性.">
    {
        返回 (标题)
    }

    方法 内容 <公开 属性写 注释 = "设置本组件的当前内容文本. 本属性等同于窗口组件类中的标题属性." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的内容 <类型 = 文本型>
    {
        标题 = 所欲设置的内容
    }

    方法 是否允许多行 <公开 属性读 类型 = 逻辑型 注释 = "返回编辑框是否允许输入多行文本" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_blpMutiLines
    }

    方法 是否允许多行 <公开 属性写 注释 = "设置编辑框是否允许输入多行文本." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 允许多行 <类型 = 逻辑型 注释 = "为真表示允许输入多行文本,为假不允许.">
    {
        @ ((CVWnd_Edit*)GetMfcWndPtr ())->m_blpMutiLines = @<允许多行>;
    }

    方法 隐藏选择 <公开 属性读 类型 = 逻辑型 注释 = "返回编辑框失去输入焦点后是否不再显示当前被选择的区域" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & ES_NOHIDESEL) == 0
    }

    方法 隐藏选择 <公开 属性写 注释 = "设置编辑框失去输入焦点后是否不再显示当前被选择的区域." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 是否隐藏选择 <类型 = 逻辑型>
    {
        @ if (@<是否隐藏选择>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~ES_NOHIDESEL;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= ES_NOHIDESEL;
    }

    方法 最大允许长度 <公开 属性读 类型 = 整数 注释 = "返回先前所设置的编辑框最大允许输入到其中的字符数目,如为0则输入字符数目不受限制." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npMaxAllowLength
    }

    方法 最大允许长度 <公开 属性写 注释 = "设置编辑框最大允许输入到其中的字符数目,如为0则输入字符数目不受限制." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的最大长度 <类型 = 整数>
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_Edit*)pWnd)->m_npMaxAllowLength = MAX (0, @<所欲设置的最大长度>);
        @ if (pWnd->m_hWnd != NULL)
        @     ((CVWnd_Edit*)pWnd)->SetLimitText ((UINT)((CVWnd_Edit*)pWnd)->m_npMaxAllowLength);
    }

    方法 滚动条 <公开 属性读 类型 = 滚动条类型 注释 = "返回编辑框在多行模式下所显示滚动条的类型" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npScrollBarMode
    }

    方法 滚动条 <公开 属性写 注释 = "设置编辑框在多行模式下所显示滚动条的类型." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的类型 <类型 = 滚动条类型>
    {
        @ ((CVWnd_Edit*)GetMfcWndPtr ())->m_npScrollBarMode = @<所欲设置的类型>;
    }

    方法 对齐方式 <公开 属性读 类型 = 横向对齐模式 注释 = "返回编辑框内所显示内容的横向对齐方式" @禁止流程检查 = 真>
    {
        @ const DWORD dwStyle = (GetMfcWndObject ()->m_dwAttrInitialStyle & (ES_LEFT | ES_CENTER | ES_RIGHT));
        @ return (dwStyle == ES_CENTER ? @<横向对齐模式.居中> :
        @         dwStyle == ES_RIGHT ? @<横向对齐模式.右边> :
        @         @<横向对齐模式.左边>);
    }

    方法 对齐方式 <公开 属性写 注释 = "设置编辑框内所显示内容的横向对齐方式." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 对齐方式 <类型 = 横向对齐模式>
    {
        @ const DWORD dwNewStyle = (@<对齐方式> == @<横向对齐模式.左边> ? ES_LEFT : @<对齐方式> == @<横向对齐模式.右边> ? ES_RIGHT : ES_CENTER);
        @ GetMfcWndObject ()->m_dwAttrInitialStyle = ((GetMfcWndObject ()->m_dwAttrInitialStyle & ~(ES_LEFT | ES_RIGHT | ES_CENTER)) | dwNewStyle);
    }

    方法 输入方式 <公开 属性读 类型 = 编辑框输入方式 注释 = "返回编辑框的当前输入方式" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npInputMode
    }

    方法 输入方式 <公开 属性写 注释 = "设置编辑框的当前输入方式" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的输入方式 <类型 = 编辑框输入方式>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ pWnd->m_npInputMode = CLIP (@<所欲设置的输入方式>, 0, 13);

        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     if (pWnd->m_npInputMode == 2)  // 为密码输入方式?
        @         pWnd->SetPasswordChar ((TCHAR)pWnd->m_chPassWordChar);
        @     else
        @         pWnd->SetPasswordChar ('\0');
        @     pWnd->SetReadOnly (pWnd->m_npInputMode == 1);  // 处理只读方式
        @     pWnd->Invalidate ();
        @ }
    }

    方法 密码遮盖字符 <公开 属性读 类型 = 字符 注释 = "返回当输入方式为\"密码输入\"时输入字符后显示在编辑框中的替代字符" @嵌入式方法 = "">
    {
        @ ((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_chPassWordChar
    }

    方法 密码遮盖字符 <公开 属性写 注释 = "设置当输入方式为\"密码输入\"时输入字符后显示在编辑框中的替代字符" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的遮盖字符 <类型 = 字符 注释 = "如果为\'\\0\',则取消当前遮盖字符.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ pWnd->m_chPassWordChar = @<所欲设置的遮盖字符>;

        @ if (pWnd->m_hWnd != NULL && pWnd->m_npInputMode == 2)  // 为密码输入方式?
        @ {
        @     pWnd->SetPasswordChar (pWnd->m_chPassWordChar);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 转换方式 <公开 属性读 类型 = 编辑框转换方式 注释 = "返回编辑框内容的自动转换方式" @禁止流程检查 = 真>
    {
        @ const DWORD dwStyle = GetMfcWndObject ()->m_dwAttrInitialStyle;
        @ return ((dwStyle & ES_LOWERCASE) != 0 ? @<编辑框转换方式.大写到小写> :
        @         (dwStyle & ES_UPPERCASE) != 0 ? @<编辑框转换方式.小写到大写> :
        @         @<编辑框转换方式.无>);
    }

    方法 转换方式 <公开 属性写 注释 = "设置编辑框内容的自动转换方式." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的转换方式 <类型 = 编辑框转换方式>
    {
        @ const DWORD dwNewStyle = (@<所欲设置的转换方式> == @<编辑框转换方式.大写到小写> ? ES_LOWERCASE : @<所欲设置的转换方式> == @<编辑框转换方式.小写到大写> ? ES_UPPERCASE : 0);
        @ GetMfcWndObject ()->m_dwAttrInitialStyle = ((GetMfcWndObject ()->m_dwAttrInitialStyle & ~(ES_LOWERCASE | ES_UPPERCASE)) | dwNewStyle);
    }

    方法 调节器方式 <公开 属性读 类型 = 编辑框调节器方式 注释 = "返回编辑框的调节器方式" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npSpinMode
    }

    方法 调节器方式 <公开 属性写 注释 = "设置编辑框的调节器方式." 注释 = "注意: 本属性仅当在编辑框组件被创建前设置有效" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的方式 <类型 = 编辑框调节器方式>
    {
