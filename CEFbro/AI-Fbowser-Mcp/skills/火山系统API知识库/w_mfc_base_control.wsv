类 图片框 <公开 基础类 = 组件布局器 @视窗.窗口组件 = "icon=\"@38\"\r\ndefault_size = \"120, 100\"">
{

    # 属性 ---

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值." 注释 = "本属性等同于\"组件布局器\"类中的\"底色\"属性.">
    {
        返回 (底色)
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.默认色\"." 注释 = "本属性等同于\"组件布局器\"类中的\"底色\"属性."
            @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        底色 = 所欲设置颜色值
    }

    方法 图片 <公开 属性写 注释 = "设置显示在本组件背景上的位图." 注释 = "本属性等同于\"组件布局器\"类中的\"底图\"属性." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        底图 = 所欲设置的位图
    }

    方法 显示方式 <公开 属性读 类型 = 图片放置方式 注释 = "返回本组件上图片的放置方式." 注释 = "本属性等同于\"组件布局器\"类中的\"底图方式\"属性.">
    {
        返回 (底图方式)
    }

    方法 显示方式 <公开 属性写 注释 = "设置本组件上图片的放置方式." 注释 = "本属性等同于\"组件布局器\"类中的\"底图方式\"属性." @视窗.设置时机 = 组件创建前后>
    参数 放置方式 <类型 = 图片放置方式>
    {
        底图方式 = 放置方式
    }
}

