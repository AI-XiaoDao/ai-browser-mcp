类 影像框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IBaseEventListener" @视窗.窗口组件 = "icon=\"@58\"\r\ndefault_size = \"240, 200\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Animate, IBaseEventListener, 0, 0, 0, 0)
    #
    # ---

    方法 文件名 <公开 属性读 类型 = 文本型 注释 = "返回欲播放影像文件的名称" @嵌入式方法 = "">
    {
        @ ((CVWnd_Animate*)@sn<this>.GetMfcWndPtr ())->m_strAnimFileName
    }

    方法 文件名 <公开 属性写 注释 = "设置欲播放影像文件的名称" @视窗.设置时机 = 组件创建前后 @值细节类型 = 文件名 @附加文本 = "影像文件(*.avi)|*.avi|">
    参数 所欲播放的文件名 <类型 = 文本型>
    {
        @ ((CVWnd_Animate*)GetMfcWndPtr ())->OpenAnimFile (@<所欲播放的文件名>);
    }

    方法 居中播放 <公开 属性读 类型 = 逻辑型 注释 = "返回是否居中播放影像文件" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Animate*)@sn<this>.GetMfcWndPtr ())->m_blpCenter
    }

    方法 居中播放 <公开 属性写 注释 = "设置是否居中播放影像文件" @视窗.设置时机 = 组件创建前>
    参数 是否居中播放 <类型 = 逻辑型>
    {
        @ ((CVWnd_Animate*)GetMfcWndPtr ())->m_blpCenter = @<是否居中播放>;
    }

    方法 透明背景 <公开 属性读 类型 = 逻辑型 注释 = "返回是否使用透明背景" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Animate*)@sn<this>.GetMfcWndPtr ())->m_blpTransparent
    }

    方法 透明背景 <公开 属性写 注释 = "设置是否使用透明背景" @视窗.设置时机 = 组件创建前>
    参数 是否使用透明背景 <类型 = 逻辑型>
    {
        @ ((CVWnd_Animate*)GetMfcWndPtr ())->m_blpTransparent = @<是否使用透明背景>;
    }

    方法 播放 <公开 属性读 类型 = 逻辑型 注释 = "返回当前播放状态" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Animate*)@sn<this>.GetMfcWndPtr ())->m_blpPlay
    }

    方法 播放 <公开 属性写 注释 = "如果指定了有效的影像文件,通过改变此属性可控制其播放或停止." 注释 = "如在设计时置本属性为真,运行时影像文件在影像框被创建后即自动开始播放." @视窗.设置时机 = 组件创建前后>
    参数 是否播放 <类型 = 逻辑型>
    {
        @ ((CVWnd_Animate*)GetMfcWndPtr ())->SetPlayState (@<是否播放>);
    }

    方法 播放次数 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的播放次数. 如为-1,则无限次地循环播放." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Animate*)@sn<this>.GetMfcWndPtr ())->m_npPlayCount
    }

    方法 播放次数 <公开 属性写 注释 = "指定影像的播放次数. 如为-1,则无限次地循环播放." @视窗.设置时机 = 组件创建前后>
    参数 所需要播放的次数 <类型 = 整数 注释 = "如为-1,则无限次地循环播放.">
    {
        @ ((CVWnd_Animate*)GetMfcWndPtr ())->SetPlayCount (@<所需要播放的次数>);
    }
}

