    参数 是否允许 <类型 = 逻辑型>
    {
        @ CVWnd_FileBox* pWnd = (CVWnd_FileBox*)GetMfcWndPtr ();
        @ pWnd->m_blpAllowSysFile = @<是否允许>;
        @ pWnd->Update ();
    }

    方法 隐藏 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许设置了隐藏文件属性的文件进入" @嵌入式方法 = "">
    {
