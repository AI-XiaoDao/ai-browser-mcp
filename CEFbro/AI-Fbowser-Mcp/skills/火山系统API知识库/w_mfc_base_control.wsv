    方法 填充矩形 <公开 注释 = "将画板上指定的矩形区域用当前刷子填充" @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->FillRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>)
    }

    方法 画圆角矩形 <公开 注释 = "使用当前画笔在画板上画一个圆角矩形,圆角矩形的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    参数 圆角宽度 <类型 = 整数>
    参数 圆角高度 <类型 = 整数 注释 = "参数值如果为-1,则等同于圆角宽度." @默认值 = -1>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawRoundRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>, @<圆角宽度>, @<圆角高度>)
    }

    方法 翻转矩形区 <公开 注释 = "将画板上指定矩形区域的颜色翻转过来" @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->InvertRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>)
    }

    方法 画多边形 <公开 注释 = "使用当前画笔在画板上画一个多边形,多边形的内部使用当前刷子填充." 注释 = "如果该多边形没有闭合,将自动闭合." @嵌入式方法 = "">
    参数 多边形顶点数组 <类型 = 整数数组类 注释 = "本参数数组顺序记录多边形各个顶点的横向及纵向坐标值">
    参数 顶点数目 <类型 = 整数 注释 = "本参数指定多边形顶点的总数目,如果为-1则为数组中记录的所有顶点数目." @默认值 = -1>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawPolygon (@<多边形顶点数组>.data (), @<顶点数目>)
    }

    方法 置写出位置 <公开 注释 = "设置下次使用\"写文本行\"或\"写出\"命令输出数据时的起始位置" @嵌入式方法 = "">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->SetWritePos (@<横向写出位置>, @<纵向写出位置>)
    }

    方法 写文本行 <公开 注释 = "在当前写出位置写出指定的数据,并将现行写出位置调整到下行行首." @嵌入式方法 = "">
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->PrintText (0, 0, 0, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 滚动写行 <公开 注释 = "  在当前写出位置写出指定的数据,并将现行写出位置调整到下行行首.如果" 注释 = "现行画板高度无法容纳当前所要写出的行,则自动向上滚动画板内容." @嵌入式方法 = "">
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->PrintText (1, 0, 0, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 写出 <公开 注释 = "在当前写出位置写出指定的数据,并将现行写出位置调整到所写出数据的结束位置." @嵌入式方法 = "">
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->PrintText (2, 0, 0, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 定位写出 <公开 注释 = "在所指定位置写出指定的数据,不改变现行写出位置." @嵌入式方法 = "">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->PrintText (3, @<横向写出位置>, @<纵向写出位置>, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 取宽度 <公开 类型 = 整数 注释 = "返回指定数据的写出宽度,使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()).cx
    }

    方法 取高度 <公开 类型 = 整数 注释 = "返回指定数据的写出高度,使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()).cy
    }

    方法 取尺寸 <公开 类型 = 尺寸类 注释 = "返回指定数据的写出尺寸,使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ @dt<尺寸类> (&((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()))
    }

    方法 画图片 <公开 注释 = "在所指定位置绘制图片" @嵌入式方法 = "">
    参数 所欲绘制的位图 <类型 = 位图对象类 注释 = "提供所欲绘制的位图对象">
    参数 图片左边画出位置 <类型 = 整数>
    参数 图片顶边画出位置 <类型 = 整数>
    参数 图片画出宽度 <类型 = 整数 注释 = "如果本参数为-1,则使用图片本身宽度." @默认值 = -1>
    参数 图片画出高度 <类型 = 整数 注释 = "如果本参数为-1,则使用图片本身高度." @默认值 = -1>
    参数 图片画出方法 <类型 = 整数 注释 = "  本参数定义绘制图片时对图片执行的位操作,可以为\"图像复制方法\"类中的" 注释 = "各个整数常量值,或者其它自定义操作码(请自行查阅相关技术文档)."
            注释 = "  本参数也可以为一个颜色值,用作指定图片中的透明色(即具有此颜色的像素" 注释 = "将不会被绘制),但必须使用其负值. 如: -取颜色 (255, 255, 255) ,此参数"
            注释 = "值即指定在画板上画出图片中除白色外的所有颜色." 注释 = "  如果本参数值为\"图像复制方法.拷贝\",则支持对透明/半透明图片(如png)的绘制." @默认值 = 图像复制方法.拷贝>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawPic ((HBITMAP)@<所欲绘制的位图>.GetGDIHandle (), @<图片左边画出位置>, @<图片顶边画出位置>, @<图片画出宽度>, @<图片画出高度>, @<图片画出方法>)
    }

    方法 取图片宽度 <公开 类型 = 整数 注释 = "返回指定图片的宽度,使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()).cx
    }

    方法 取图片高度 <公开 类型 = 整数 注释 = "返回指定图片的高度,使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()).cy
    }

    方法 取图片尺寸 <公开 类型 = 尺寸类 注释 = "返回指定图片的尺寸,使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ @dt<尺寸类> (&((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()))
    }

    方法 复制 <公开 注释 = "  将源画板(本方法的调用画板对象)中指定区域的内容快速复制到目的画板中" 注释 = "的指定位置,使用源和目的画板各自的当前绘画单位. 如果源画板当前不可视," 注释 = "其\"自动重画\"属性必须为真."
            @嵌入式方法 = "">
    参数 欲复制区域的左边 <类型 = 整数 @默认值 = 0>
    参数 欲复制区域的顶边 <类型 = 整数 @默认值 = 0>
    参数 欲复制区域的宽度 <类型 = 整数 注释 = "如果本参数为-1,则使用源画板的本身宽度." @默认值 = -1>
    参数 欲复制区域的高度 <类型 = 整数 注释 = "如果本参数为-1,则使用源画板的本身高度." @默认值 = -1>
    参数 复制到的目的画板 <类型 = 画板 注释 = "提供复制到的目的画板,可以为本画板对象自身.">
    参数 欲复制到位置左边 <类型 = 整数 @默认值 = 0>
    参数 欲复制到位置顶边 <类型 = 整数 @默认值 = 0>
    参数 复制方法 <类型 = 整数 注释 = "  本参数定义在将画板内容复制到目的画板上时对图像执行的位操作,可以为\"图像复制方法\"" 注释 = "类中的各个整数常量值,或者其它自定义操作码(请自行查阅相关技术文档)."
            @默认值 = 图像复制方法.拷贝>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->CopyPainter (@<欲复制区域的左边>, @<欲复制区域的顶边>, @<欲复制区域的宽度>, @<欲复制区域的高度>,
        @         (CVWnd_Painter*)@<复制到的目的画板>.GetMfcWndPtr (), @<欲复制到位置左边>, @<欲复制到位置顶边>, @<复制方法>)
    }

    方法 取图片 <公开 类型 = 逻辑型 注释 = "取回本画板上所有现有显示内容的图片对象" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 所取回图片 <类型 = 位图对象类 注释 = "画板上所有现有显示内容将被填入到此对象中">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "所取得图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如"
            注释 = "果大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "所取得图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如"
            注释 = "果大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ @<所取回图片.置位图句柄值> ((INT_P)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetPicBitmap (@<输出宽度>, @<输出高度>), TRUE)
    }

    方法 单位转换 <公开 类型 = 整数 注释 = "将像素单位坐标值转换到当前绘画单位,或将当前绘画单位坐标值转换到像素单位." @嵌入式方法 = "">
    参数 欲转换的坐标值 <类型 = 整数 注释 = "提供欲转换的横向或纵向坐标值">
    参数 欲转换坐标值的类型 <类型 = 坐标转换类型 注释 = "  根据所提供的类型值,将进行相反的单位转换,即将绘画单位转换到像素单位,将" 注释 = "像素单位转换到绘画单位.">
    {
        @ (INT)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->UnitConvert (@<欲转换的坐标值>, @<欲转换坐标值的类型>)
    }

    方法 逻辑尺寸到像素 <公开 类型 = 尺寸类 注释 = "将所指定的基于当前绘画单位的尺寸值转换到像素单位并返回" @嵌入式方法 = "">
    参数 所欲转换的尺寸 <类型 = 尺寸类 注释 = "此尺寸基于当前绘画单位">
    {
        @ @dt<尺寸类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->LPSizeToDP (&@<所欲转换的尺寸>.ToSize ()))
    }

    方法 像素尺寸到逻辑 <公开 类型 = 尺寸类 注释 = "将所指定的基于像素单位的尺寸值转换到当前绘画单位并返回" @嵌入式方法 = "">
    参数 所欲转换的尺寸 <类型 = 尺寸类 注释 = "此尺寸基于像素单位">
    {
        @ @dt<尺寸类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DPSizeToLP (&@<所欲转换的尺寸>.ToSize ()))
    }

    方法 逻辑位置到像素 <公开 类型 = 位置类 注释 = "将所指定的基于当前绘画单位的位置转换到像素单位并返回" @嵌入式方法 = "">
    参数 所欲转换的位置 <类型 = 位置类 注释 = "此位置基于当前绘画单位">
    {
        @ @dt<位置类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->LPPointToDP (&@<所欲转换的位置>.ToPoint ()))
    }

    方法 像素位置到逻辑 <公开 类型 = 位置类 注释 = "将所指定的基于像素单位的位置转换到当前绘画单位并返回" @嵌入式方法 = "">
    参数 所欲转换的位置 <类型 = 位置类 注释 = "此位置基于像素单位">
    {
        @ @dt<位置类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DPPointToLP (&@<所欲转换的位置>.ToPoint ()))
    }

    方法 逻辑矩形到像素 <公开 类型 = 矩形类 注释 = "将所指定的基于当前绘画单位的矩形位置转换到像素单位并返回" @嵌入式方法 = "">
    参数 所欲转换的矩形 <类型 = 矩形类 注释 = "此矩形位置基于当前绘画单位">
    {
        @ @dt<矩形类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->LPRectToDP (&@<所欲转换的矩形>.ToRect ()))
    }

    方法 像素矩形到逻辑 <公开 类型 = 矩形类 注释 = "将所指定的基于像素单位的矩形位置转换到当前绘画单位并返回" @嵌入式方法 = "">
    参数 所欲转换的矩形 <类型 = 矩形类 注释 = "此矩形位置基于像素单位">
    {
        @ @dt<矩形类> (((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DPRectToLP (&@<所欲转换的矩形>.ToRect ()))
    }

    # --
    #
    # @ <include>
    # @ virtual void OnPaint (const RECT* prtPaint) override;
    # @ </include>
    # @ void @sn<current_class>::OnPaint (const RECT* prtPaint)  { @<绘画> (@dt<矩形类> (prtPaint)); }
}

# ===

类 滚动条 <公开 基础类 = 窗口组件 注释 = "横纵向滚动条的基础类" @视窗.后缀文本 = "public IScrollBarEventListener" @禁止创建对象 = 真>
{

    # 事件 ---

    方法 位置被改变 <公开 定义事件 类型 = 整数 注释 = "当滚动条位置被改变后本事件被发送">

    # 属性 ---

    方法 最小位置 <公开 属性读 类型 = 整数 注释 = "返回滚动条当前所允许的最小位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMin;
        @ INT nMinPos = 0, nMaxPos;
        @ pWnd->GetScrollRange (&nMinPos, &nMaxPos);
        @ return nMinPos;
    }

    方法 最小位置 <公开 属性写 注释 = "设置滚动条当前所允许的最小位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMin = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetScrollRange (&nMinPos, &nMaxPos);
        @     pWnd->SetScrollRange (@<所欲设置的位置值>, nMaxPos);
        @ }
    }

    方法 最大位置 <公开 属性读 类型 = 整数 注释 = "返回滚动条当前所允许的最大位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMax;
        @ INT nMinPos, nMaxPos = 0;
        @ pWnd->GetScrollRange (&nMinPos, &nMaxPos);
        @ return nMaxPos;
    }

    方法 最大位置 <公开 属性写 注释 = "设置滚动条当前所允许的最大位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMax = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetScrollRange (&nMinPos, &nMaxPos);
        @     pWnd->SetScrollRange (nMinPos, @<所欲设置的位置值>);
        @ }
    }

    方法 页改变值 <公开 属性读 类型 = 整数 注释 = "返回当用户在滚动条的空隙处单击后滚动条位置的增减数值" @嵌入式方法 = "">
