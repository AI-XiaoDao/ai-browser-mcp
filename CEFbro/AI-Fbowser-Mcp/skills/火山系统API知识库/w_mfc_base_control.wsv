类 进度条 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IBaseEventListener" @视窗.窗口组件 = "icon=\"@44\"\r\ndefault_size = \"120, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ProgressBar, IBaseEventListener, 0, 0, 0, 0)
    #
    # 属性 ---

    方法 方向 <公开 属性读 类型 = 进度条方向 注释 = "返回进度条的当前方向" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & PBS_VERTICAL) == 0 ? @<进度条方向.横向> : @<进度条方向.纵向>
    }

    方法 方向 <公开 属性写 注释 = "设置进度条的当前方向" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的方向 <类型 = 进度条方向>
    {
        如果 (所欲设置的方向 == 进度条方向.纵向)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= PBS_VERTICAL;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~PBS_VERTICAL;
        }
    }

    方法 显示方式 <公开 属性读 类型 = 进度条显示方式 注释 = "返回进度条的当前显示方式" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & PBS_SMOOTH) == 0 ? @<进度条显示方式.分块> : @<进度条显示方式.连续>
    }

    方法 显示方式 <公开 属性写 注释 = "设置进度条的当前显示方式" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的显示方式 <类型 = 进度条显示方式>
    {
        如果 (所欲设置的显示方式 == 进度条显示方式.连续)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= PBS_SMOOTH;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~PBS_SMOOTH;
        }
    }

    方法 最小位置 <公开 属性读 类型 = 整数 注释 = "返回进度条当前所允许的最小位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_ProgressBar* pWnd = (CVWnd_ProgressBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMin;
        @ INT nMinPos = 0, nMaxPos;
        @ pWnd->GetRange (nMinPos, nMaxPos);
        @ return nMinPos;
    }

    方法 最小位置 <公开 属性写 注释 = "设置进度条当前所允许的最小位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ProgressBar* pWnd = (CVWnd_ProgressBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMin = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetRange (nMinPos, nMaxPos);
        @     pWnd->SetRange32 (@<所欲设置的位置值>, nMaxPos);
        @ }
    }

    方法 最大位置 <公开 属性读 类型 = 整数 注释 = "返回进度条当前所允许的最大位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_ProgressBar* pWnd = (CVWnd_ProgressBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMax;
        @ INT nMinPos, nMaxPos = 0;
        @ pWnd->GetRange (nMinPos, nMaxPos);
        @ return nMaxPos;
    }

    方法 最大位置 <公开 属性写 注释 = "设置进度条当前所允许的最大位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ProgressBar* pWnd = (CVWnd_ProgressBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMax = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetRange (nMinPos, nMaxPos);
        @     pWnd->SetRange32 (nMinPos, @<所欲设置的位置值>);
        @ }
    }

    方法 位置 <公开 属性读 类型 = 整数 注释 = "返回进度条的当前进度位置" @禁止流程检查 = 真>
    {
        @ CVWnd_ProgressBar* pWnd = (CVWnd_ProgressBar*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialPos : pWnd->GetPos ());
    }

    方法 位置 <公开 属性写 注释 = "设置进度条的当前进度位置" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
