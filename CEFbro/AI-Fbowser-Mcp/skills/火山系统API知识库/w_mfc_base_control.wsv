类 图形按钮类型 <公开 注释 = "用作提供图形按钮的具体类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 按钮 <公开 值 = 0>
    常量 选择框 <公开 值 = 1>
}

类 图形按钮 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IPicButtonEventListener" @视窗.窗口组件 = "icon=\"@38\"\r\ndefault_size = \"80, 32\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_PicButton, IPicButtonEventListener, 0, 0, WS_TABSTOP, 0)
    #
    # 事件 --

    方法 被单击 <公开 定义事件 类型 = 整数 注释 = "图形按钮被单击后将发送本事件.">

    # 属性 --

    方法 类型 <公开 属性读 类型 = 图形按钮类型 注释 = "返回图形按钮的当前类型" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_PicButton*)@sn<this>.GetMfcWndPtr ())->m_npButtonType
    }

    方法 类型 <公开 属性写 注释 = "设置图形按钮的当前类型" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的类型 <类型 = 图形按钮类型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->m_npButtonType = CLIP (@<所欲设置的类型>, 0, 1);
    }

    方法 选中 <公开 属性读 类型 = 逻辑型 注释 = "当类型为选择框时,返形按钮的当前选中状态." @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_PicButton*)@sn<this>.GetMfcWndPtr ())->m_blpPressed
    }

    方法 选中 <公开 属性写 注释 = "当类型为选择框时,设置按钮的当前选中状态." @视窗.设置时机 = 组件创建前后>
    参数 是否被选中 <类型 = 逻辑型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->SetPressState (@<是否被选中>);
    }

    方法 正常图片 <公开 属性写 注释 = "指定在正常情况下所显示图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_NORMAL_BITMAP, (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 点燃图片 <公开 属性写 注释 = "当类型为按钮时,指定当鼠标移动到按钮上时所显示图片." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_HIGHLIGHT_BITMAP, (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 按下图片 <公开 属性写 注释 = "指定当选择框被选中或者按钮被按下后所显示图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_PRESSED_BITMAP, (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 禁止图片 <公开 属性写 注释 = "指定当按钮被禁止后所显示图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_DISABLED_BITMAP, (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 透明颜色 <公开 属性读 类型 = 整数 注释 = "返回所有图片中透明部分所对应的颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_PicButton*)@sn<this>.GetMfcWndPtr ())->m_clrTransColor
    }

    方法 透明颜色 <公开 属性写 注释 = "  设置所有图片中透明部分所对应的颜色,图片中的透明部分将" 注释 = "被摈除在按钮组件范围之外." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定图片中没有透明色.">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->SetTransColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_PicButton*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.默认色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CVWnd_PicButton* pWnd = (CVWnd_PicButton*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)  pWnd->Invalidate ();
    }

    方法 置禁止图片数据 <公开 注释 = "指定当按钮被禁止后所显示图片">
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所设置的图片字节集">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_DISABLED_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置正常图片数据 <公开 注释 = "指定在正常情况下所显示图片数据">
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所设置的图片字节集">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_NORMAL_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置点燃图片数据 <公开 注释 = "当类型为按钮时,指定当鼠标移动到按钮上时所显示图片.">
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所设置的图片字节集">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_HIGHLIGHT_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置按下图片数据 <公开 注释 = "指定当选择框被选中或者按钮被按下后所显示图片">
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所设置的图片字节集">
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_PRESSED_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    # --
    #
    # @ <include>
    # @ virtual void OnClick () override  {  @<被单击> ();  }
    # @ </include>
}

