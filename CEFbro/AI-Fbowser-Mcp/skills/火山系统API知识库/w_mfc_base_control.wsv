# ===

类 按钮基础类 <公开 基础类 = 窗口组件 注释 = "按钮系列窗口组件的基础类" @文档 = "category = \"窗口组件.基础类\"" @视窗.后缀文本 = "public IButtonEventListener"
        @禁止创建对象 = 真>
{

    # 属性 ---

    方法 图标 <公开 属性写 注释 = "设置显示在本按钮上的图标">
    参数 所欲设置的图标 <类型 = 图标资源 注释 = "提供所欲设置的图标资源,如果该资源值为\"空资源.空图标\",则将清除所显示的图标.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const HICON hIcon = (HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<所欲设置的图标>);
        @     pWnd->ModifyStyle ((BS_TEXT | BS_BITMAP | BS_ICON), (hIcon != NULL ? BS_ICON : BS_TEXT),
        @             (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED | SWP_DRAWFRAME));
        @     pWnd->SendMessage (BM_SETIMAGE, IMAGE_ICON, (LPARAM)hIcon);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 图片 <公开 属性写 注释 = "设置显示在本按钮上的位图图片">
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将清除所显示的位图.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const HBITMAP hBitmap = (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>);
        @     pWnd->ModifyStyle ((BS_TEXT | BS_BITMAP | BS_ICON), (hBitmap != NULL ? BS_BITMAP : BS_TEXT),
        @             (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED | SWP_DRAWFRAME));
        @     pWnd->SendMessage (BM_SETIMAGE, IMAGE_BITMAP, (LPARAM)hBitmap);
        @     pWnd->Invalidate ();
        @     if (hBitmap != NULL)
        @         ::DeleteObject (hBitmap);
        @ }
    }

    方法 横向对齐方式 <公开 属性读 类型 = 横向对齐模式 注释 = "返回按钮上所显示内容的横向对齐方式" @禁止流程检查 = 真>
    {
        @ const DWORD dwStyle = (GetControlStyle () & (BS_LEFT | BS_RIGHT | BS_CENTER));
        @ return (dwStyle == BS_LEFT ? @<横向对齐模式.左边> :
        @      dwStyle == BS_RIGHT ? @<横向对齐模式.右边> :
        @      @<横向对齐模式.居中>);
    }

    方法 横向对齐方式 <公开 属性写 注释 = "设置按钮上所显示内容的横向对齐方式" @视窗.设置时机 = 组件创建前后>
