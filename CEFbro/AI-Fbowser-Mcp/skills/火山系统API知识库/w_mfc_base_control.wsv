    方法 透明度 <公开 属性写 注释 = "设置本窗口的透明度">
    参数 透明度 <类型 = 整数 注释 = "为0到255之间的整数. 0:完全透明; 255: 完全不透明">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->ModifyStyleEx (0, WS_EX_LAYERED, SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE);
        @     SetLayeredWindowAttributes (pWnd->m_hWnd, 0, CLIP (@<透明度>, 0, 255), LWA_ALPHA);
        @ }
    }

    # 方法 --

    方法 创建窗口 <公开 类型 = 逻辑型 注释 = "创建本窗口类的对象(非主窗口)" 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用设计时宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用设计时高度." @默认值 = 数值范围.最小整数值>
    参数 所欲使用的菜单 <类型 = 菜单类 注释 = "提供所欲同时设置的窗口菜单,为空对象表示无." @默认值 = 空对象>
    {
        @ @sn<this>.CreateVolWindow (NULL, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<所欲使用的菜单>.GetVolMenuCheckNull ())
    }

    方法 创建有菜单窗口 <公开 类型 = 逻辑型 注释 = "创建本窗口类的对象(非主窗口)" 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 窗口菜单 <类型 = 菜单类 注释 = "提供窗口的菜单类数据类型,应该为\"菜单类\"的继承类." @需求类型 = 数据类型>
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
