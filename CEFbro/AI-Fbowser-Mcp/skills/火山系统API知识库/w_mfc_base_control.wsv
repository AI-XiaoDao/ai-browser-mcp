        @ GetMfcWndObject ()->m_dwAttrInitialStyle = ((GetMfcWndObject ()->m_dwAttrInitialStyle & ~(BS_LEFT | BS_RIGHT | BS_CENTER)) | dwNewStyle);
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->ModifyStyle ((BS_LEFT | BS_RIGHT | BS_CENTER), dwNewStyle, (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE));
        @     pWnd->Invalidate ();
