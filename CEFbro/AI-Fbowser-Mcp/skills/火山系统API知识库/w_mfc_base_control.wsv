    # 方法 ---

    方法 置底图文件 <公开 注释 = "设置显示在画板背景上的位图文件">
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_Painter*)GetMfcWndPtr ())->TakeOverBackBitmap ((HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置底图数据 <公开 注释 = "设置显示在画板背景上的位图文件数据">
    参数 所欲设置的位图文件数据 <类型 = 字节集类>
    {
        @ ((CVWnd_Painter*)GetMfcWndPtr ())->TakeOverBackBitmap (g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图文件数据>));
    }

    方法 取设备句柄 <公开 类型 = 变整数 注释 = "  如当前用户程序正在处理本画板所产生的\"绘画\"事件," 注释 = "则返回画板所对应的设备句柄(即HDC),否则返回0." @禁止流程检查 = 真>
    {
        @ CVWnd_Painter* pWnd = (CVWnd_Painter*)GetMfcWndPtr ();
        @ return (pWnd->m_pPaintDC == NULL ? 0 : (INT_P)pWnd->m_pPaintDC->m_hDC);
    }

    方法 清除 <公开 注释 = "清除画板上指定区域的内容并将当前文本写出位置移动到被清除区左上角" @嵌入式方法 = "">
    参数 清除区左边坐标 <类型 = 整数 注释 = "单位为像素" @默认值 = 0>
    参数 清除区顶边坐标 <类型 = 整数 注释 = "单位为像素" @默认值 = 0>
    参数 清除区宽度 <类型 = 整数 注释 = "为-1表示为清除区左边到画板右边之间的宽度,单位为像素." @默认值 = -1>
    参数 清除区高度 <类型 = 整数 注释 = "为-1表示为清除区顶边到画板底边之间的高度,单位为像素." @默认值 = -1>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->CleanPainter (@<清除区左边坐标>, @<清除区顶边坐标>, @<清除区宽度>, @<清除区高度>)
    }

    方法 取点 <公开 类型 = 整数 注释 = "返回画板上指定点的颜色值." 注释 = "如果画板尚未创建或所指定位置超出有效范围,将返回-1." @嵌入式方法 = "">
    参数 点横坐标 <类型 = 整数>
    参数 点纵坐标 <类型 = 整数>
    {
        @ (INT)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->GetPixel (@<点横坐标>, @<点纵坐标>)
    }

    方法 画点 <公开 注释 = "在画板上指定位置绘制一个点" @嵌入式方法 = "">
    参数 点横坐标 <类型 = 整数>
    参数 点纵坐标 <类型 = 整数>
    参数 欲画入点的颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->SetPixel (@<点横坐标>, @<点纵坐标>, (COLORREF)@<欲画入点的颜色值>)
    }

    方法 画直线 <公开 注释 = "使用当前画笔在画板上画一条直线" @嵌入式方法 = "">
    参数 起始点横坐标 <类型 = 整数>
    参数 起始点纵坐标 <类型 = 整数>
    参数 结束点横坐标 <类型 = 整数>
    参数 结束点纵坐标 <类型 = 整数>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawLine (@<起始点横坐标>, @<起始点纵坐标>, @<结束点横坐标>, @<结束点纵坐标>)
    }

    方法 画椭圆 <公开 注释 = "使用当前画笔在画板上画一个椭圆" @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawEllipse (@<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>)
    }

    方法 画弧线 <公开 注释 = "使用当前画笔在画板上画一条弧线" @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawArcChordPie (0, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>)
    }

    方法 画弦 <公开 注释 = "使用当前画笔在画板上画一个弦,弦的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "弦的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "弦的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "弦的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "弦的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ ((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->DrawArcChordPie (1, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>)
    }

    方法 画饼 <公开 注释 = "使用当前画笔在画板上画一个饼,饼的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
