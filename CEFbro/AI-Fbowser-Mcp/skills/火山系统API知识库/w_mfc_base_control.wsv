        @ pWnd->m_blpAllowReadOnlyFile = @<是否允许>;
        @ pWnd->Update ();
    }

    方法 系统 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许设置了系统文件属性的文件进入" @嵌入式方法 = "">
