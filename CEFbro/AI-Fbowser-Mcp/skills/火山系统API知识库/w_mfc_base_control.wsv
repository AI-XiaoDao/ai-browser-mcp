类 OCX组件 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IOcxControlEventListener"
        @视窗.窗口组件 = "icon = \"@73\"\r\ndefault_size = \"120, 100\"\r\npreview_unsupported">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_OcxControl, IOcxControlEventListener, 0, 0, 0, 0)

    变量 组件接口 <公开 类型 = COM对象类 注释 = "提供OCX组件创建完毕后的组件接口对象">

    # 事件 --

    方法 接收到事件 <公开 定义事件 类型 = 整数 注释 = "当接收到OCX组件的COM事件时,本事件被触发." 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">

    # 属性 --

    方法 组件类型 <公开 属性读 类型 = 文本型 注释 = "返回所设置的OCX组件类型文本" @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_strOcxTypeName
    }

    方法 组件类型 <公开 属性写 注释 = "  设置OCX组件的类型文本,可以为其可识别名称: 譬如\"Excel.Application\"/\"Word.Application\","
            注释 = "也可以是其CLSID,如\"{0003088F-0000-0000-C000-000000000058}\"." @视窗.设置时机 = 组件创建前>
    参数 组件类型文本 <类型 = 文本型 注释 = "  提供OCX组件的类型文本,可以为其可识别名称: 譬如\"Excel.Application\"/\"Word.Application\","
            注释 = "也可以是其CLSID,如\"{0003088F-0000-0000-C000-000000000058}\".">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_strOcxTypeName.SetText (@<组件类型文本>);
    }

    方法 组件文件 <公开 属性读 类型 = 文本型 注释 = "返回所设置的OCX组件文件名,为空文本表示无." @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_strOCXFileName
    }

    方法 组件文件 <公开 属性写 注释 = "设置OCX组件的文件名,如果不为空文本,则当创建组件前会首先自动尝试将其登记." 注释 = "如果创建组件之前能够确认该OCX组件已经登记到了Windows系统中,则无需设置本属性."
            注释 = "注意: 如果执行程序时所登录的Windows用户不为管理员身份,可能会登记组件失败." @视窗.设置时机 = 组件创建前>
    参数 组件文件名 <类型 = 文本型 注释 = "提供OCX组件的文件名,如果不为空文本,则当创建组件前会首先自动尝试将其登记.">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_strOCXFileName.SetText (@<组件文件名>);
    }

    方法 授权码 <公开 属性读 类型 = 文本型 注释 = "返回所设置的OCX组件授权码,为空文本表示无." @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_strLicKey
    }

    方法 授权码 <公开 属性写 注释 = "如果该OCX组件需要授权码才能创建其实例,则需要通过本属性设置." @视窗.设置时机 = 组件创建前>
    参数 授权码文本 <类型 = 文本型 注释 = "提供OCX组件的授权码,为空文本表示无.">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_strLicKey.SetText (@<授权码文本>);
    }

    方法 是否需要TAB键 <公开 属性读 类型 = 逻辑型 注释 = "返回本OCX组件是否需要Tab或Shift+Tab键事件" @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_TAB]
    }

    方法 是否需要TAB键 <公开 属性写 注释 = "  Tab或Shift+Tab键用作在窗口中的组件之间移动输入焦点时使用,会被类" 注释 = "库提前截获,如果本OCX组件需要处理此按键事件,需要设置本属性为真."
            @视窗.设置时机 = 组件创建前后>
    参数 是否需要此键 <类型 = 逻辑型 注释 = "指定本OCX组件是否需要此按键事件">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_TAB] = @<是否需要此键>;
    }

    方法 是否需要光标键 <公开 属性读 类型 = 逻辑型 注释 = "返回本OCX组件是否需要上下左右光标键事件" @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_ARROW]
    }

    方法 是否需要光标键 <公开 属性写 注释 = "  上下左右光标键用作在窗口中位于分组框内的组件之间移动输入焦点时使用," 注释 = "会被类库提前截获,如果本OCX组件需要处理此按键事件,需要设置本属性为真."
            @视窗.设置时机 = 组件创建前后>
    参数 是否需要此键 <类型 = 逻辑型 注释 = "指定本OCX组件是否需要此按键事件">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_ARROW] = @<是否需要此键>;
    }

    方法 是否需要回车键 <公开 属性读 类型 = 逻辑型 注释 = "返回本OCX组件是否需要回车键事件" @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_ENTER]
    }

    方法 是否需要回车键 <公开 属性写 注释 = "  回车键用作在窗口中自动触发具有默认风格的按钮,会被类库提前截获," 注释 = "如果本OCX组件需要处理此按键事件,需要设置本属性为真." @视窗.设置时机 = 组件创建前后>
    参数 是否需要此键 <类型 = 逻辑型 注释 = "指定本OCX组件是否需要此按键事件">
    {
        @ ((CVWnd_OcxControl*)GetMfcWndPtr ())->m_ablNeedSpecKeys [CVWnd_OcxControl::SKT_ENTER] = @<是否需要此键>;
    }

    # 方法 --

    方法 取对象 <公开 类型 = COM对象类 注释 = "  返回本OCX组件所对应的COM对象,如果该OCX组件未能成功创建," 注释 = "则所返回的COM对象为空(其\"是否为空\"方法返回真)." @嵌入式方法 = "">
    {
        @ ((CVWnd_OcxControl*)@sn<this>.GetMfcWndPtr ())->GetComObject (CVolComObject ())
    }

    方法 使用版本2 <公开 静态 注释 = "指定是否使用本类的第2个封装版本" @视窗.预定义宏 = "_USE_MFC_OCX_CONTROL_VER2">

    # --
    #
    # @ <include>
    # @ virtual BOOL OnOcxEvent (INT dispIdMember, CVolObjectArray& aryParamVariants) override  {  return (@<接收到事件> (dispIdMember, aryParamVariants) != 0);  }
    # @ virtual void OnAfterNativeWndCreate (CWnd* pWnd, const CVolNativeWndCreateParam* pCreateParam) override {
    # @     BaseClass::OnAfterNativeWndCreate (pWnd, pCreateParam);
    # @     @<组件接口>.SetUnknownObject (((CVWnd_OcxControl*)GetMfcWndPtr ())->GetComObject (CVolComObject ()).m_pUnknownObject);
    # @ }
    # @ </include>
}

# ===

类 热键框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IBaseEventListener" @视窗.窗口组件 = "icon=\"@44\"\r\ndefault_size = \"120, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_HotKey, IBaseEventListener, 0, 0, 0, 0)

    方法 当前键 <公开 属性读 类型 = 整数 注释 = "获取热键框中的当前键代码,为\"按键码.空\"表示未设置热键." 返回值注释 = "返回具体键代码,为\"按键码\"及\"辅助键状态\"类中常量值的组合." @嵌入式方法 = "">
    {
        @ ((CVWnd_HotKey*)@sn<this>.GetMfcWndPtr ())->GetCurrentHotKey ()
    }

    方法 当前键 <公开 属性写 注释 = "设置热键框中的当前键代码">
    参数 所欲设置键代码 <类型 = 整数 注释 = "为\"按键码\"及\"辅助键状态\"类中常量值的组合,提供\"按键码.空\"表示清空已设置热键.">
    {
        @ ((CVWnd_HotKey*)GetMfcWndPtr ())->SetCurrentHotKey (@<所欲设置键代码>);
    }

    方法 置无效辅助键 <公开 注释 = "指定无效辅助键,用户将无法在本组件中设置为该辅助键状态的热键." @嵌入式方法 = "">
    参数 无效辅助键 <类型 = 整数 注释 = "  提供所欲过滤的无效辅助键,为\"辅助键状态\"类中常量值的组合或" 注释 = "\"按键码.空\"(表示为无辅助键).">
    参数 替换辅助键 <类型 = 整数 注释 = "  提供当用户输入了前参数所指定的无效辅助键后,将会自动替换为" 注释 = "的辅助键状态,为\"辅助键状态\"类中常量值的组合或\"按键码.空\"(表" 注释 = "示替换为无辅助键).">
    {
        @ ((CVWnd_HotKey*)@sn<this>.GetMfcWndPtr ())->SetInvalidHotKeyModifiers (@<无效辅助键>, @<替换辅助键>)
    }
}
