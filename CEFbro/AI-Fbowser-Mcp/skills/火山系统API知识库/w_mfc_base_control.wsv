类 列表框 <公开 基础类 = 列表框基础类 编辑时信息 = "139541, 0, 0, 0" @视窗.后缀文本 = "public IListBoxEventListener"
        @视窗.窗口组件 = "icon=\"@26\"\r\ndefault_size = \"100, 120\"\r\ndefault_event = \"列表项被选择\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ListBox, IListBoxEventListener, 0, 0, WS_TABSTOP | WS_VSCROLL, WS_EX_CLIENTEDGE)
