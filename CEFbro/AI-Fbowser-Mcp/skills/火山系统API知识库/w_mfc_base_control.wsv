}

# ===

类 组合框类型 <公开 注释 = "提供组合框的各种类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 可编辑列表式 <公开 值 = 0>
    常量 可编辑下拉式 <公开 值 = 1>
    常量 不可编辑下拉式 <公开 值 = 2>
}

类 组合框 <公开 基础类 = 窗口组件 注释 = "组合框窗口组件类" 编辑时信息 = "19BFE6, 0, 0, 0" @视窗.后缀文本 = "public IComboEventListener"
        @视窗.窗口组件 = "icon=\"@6\"\r\ndefault_size = \"100, 20\"\r\ndefault_event = \"列表项被选择\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ComboBox, IComboEventListener, 0, 0, WS_TABSTOP | CBS_DROPDOWN, 0)
    #
    # 事件 --

    方法 列表项被选择 <公开 定义事件 类型 = 整数 注释 = "当某列表项被选择后发送此事件">

    方法 编辑内容被改变 <公开 定义事件 类型 = 整数 注释 = "当列表框的编辑框中的内容被改变后发送此事件">

    方法 将弹出列表 <公开 定义事件 类型 = 整数 注释 = "在将弹出组合框的列表部分之前发送此事件. 在处理此事件时,可以即时填充组合框中的列表项目.">

    方法 列表被关闭 <公开 定义事件 类型 = 整数 注释 = "在列表框所弹出的列表被关闭后发送此事件">

    方法 双击选择 <公开 定义事件 类型 = 整数 注释 = "当使用鼠标左键在某列表项目上双击时发送此事件">

    # 属性 --

    方法 类型 <公开 属性读 类型 = 组合框类型 注释 = "返回组合框的当前类型." 注释 = "如果未设置,则本属性默认值为\"可编辑下拉式\"." @禁止流程检查 = 真>
    {
        @ const DWORD dwComboBoxStyle = (GetMfcWndObject ()->m_dwAttrInitialStyle & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST));
        @ return (dwComboBoxStyle == CBS_SIMPLE ? 0 :
        @         dwComboBoxStyle == CBS_DROPDOWNLIST ? 2 :
        @         1);
    }

    方法 类型 <公开 属性写 注释 = "设置组合框的当前类型." 注释 = "如果未设置,则本属性默认值为\"可编辑下拉式\"." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的类型 <类型 = 组合框类型>
    {
        @ const DWORD dwNewStyle = (@<所欲设置的类型> == @<组合框类型.可编辑列表式> ? CBS_SIMPLE : @<所欲设置的类型> == @<组合框类型.不可编辑下拉式> ? CBS_DROPDOWNLIST : CBS_DROPDOWN);
        @ GetMfcWndObject ()->m_dwAttrInitialStyle = ((GetMfcWndObject ()->m_dwAttrInitialStyle & ~(CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) | dwNewStyle);
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "返回在组合框编辑部分中的文本内容." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效.">
    {
        返回 (标题)
    }

    方法 内容 <公开 属性写 注释 = "设置在组合框编辑部分中的文本内容." 注释 = "本属性等同于\"窗口组件\"类中的\"标题\"属性." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的内容 <类型 = 文本型>
    {
        标题 = 所欲设置的内容
    }

    方法 最大文本长度 <公开 属性写 注释 = "设置在组合框编辑部分所允许输入的最大文本长度." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效.">
    参数 所欲设置的最大长度 <类型 = 整数 注释 = "提供所欲设置的最大长度,为0表示没有限制.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @     pWnd->LimitText (@<所欲设置的最大长度>);
    }

    方法 起始选择位置 <公开 属性读 类型 = 整数 注释 = "  返回组合框编辑部分中当前被选择文本的起始索引位置," 注释 = "从0开始.如果没有文本被选中,则提供光标当前位置."
            注释 = "  当类型为\"不可编辑下拉式\"时,本属性无效." @禁止流程检查 = 真>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     const DWORD dw = pWnd->GetEditSel ();
        @     return (dw != CB_ERR ? (INT)LOW_SHORT (dw) : 0);
        @ }
        @ return 0;
    }

    方法 起始选择位置 <公开 属性写 注释 = "设置组合框编辑部分中当前被选择文本的起始索引位置." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效.">
    参数 所欲设置的索引位置 <类型 = 整数 注释 = "从0开始,如果为-1,则将当前光标位置移动到文本尾部.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     if (@<所欲设置的索引位置> < 0)
        @     {
        @         CString str;
        @         pWnd->GetWindowText (str);
        @         pWnd->SetEditSel (str.GetLength (), str.GetLength ());
        @     }
        @     else
        @     {
        @         const DWORD dw = pWnd->GetEditSel ();
        @         if (dw != CB_ERR)
        @             pWnd->SetEditSel (@<所欲设置的索引位置>, @<所欲设置的索引位置> + (INT)(HIGH_SHORT (dw) - LOW_SHORT (dw)));
        @     }
        @ }
    }

    方法 被选择字符数 <公开 属性读 类型 = 整数 注释 = "返回组合框编辑部分中当前被选择文本的字符数." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效." @禁止流程检查 = 真>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     const DWORD dw = pWnd->GetEditSel ();
        @     return (dw != CB_ERR ? (INT)(HIGH_SHORT (dw) - LOW_SHORT (dw)) : 0);
        @ }
        @ return 0;
    }

    方法 被选择字符数 <公开 属性写 注释 = "设置组合框编辑部分中当前被选择文本的字符数." 注释 = "当类型为\"不可编辑下拉式\"时,本属性无效.">
    参数 所被选择的字符数 <类型 = 整数 注释 = "如果为-1,则选择组合框编辑部分内的所有字符.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     if (@<所被选择的字符数> < 0)
        @     {
        @         pWnd->SetEditSel (0, -1);
        @     }
        @     else
        @     {
        @         const DWORD dw = pWnd->GetEditSel ();
        @         if (dw != CB_ERR)
        @             pWnd->SetEditSel ((INT)LOW_SHORT (dw), (INT)LOW_SHORT (dw) + @<所被选择的字符数>);
        @     }
        @ }
    }

    方法 被选择文本 <公开 属性读 类型 = 文本型 注释 = "  返回组合框编辑部分中当前被选择区域内的文本," 注释 = "如果没有被选择区域,则返回空文本." 注释 = "  当类型为\"不可编辑下拉式\"时,本属性无效."
            @禁止流程检查 = 真>
    {
        @ CVolString strResult;
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     const DWORD dw = pWnd->GetEditSel ();
        @     if (dw != CB_ERR)
        @     {
        @         CString str;
        @         pWnd->GetWindowText (str);
        @         strResult.SetText (str.Mid ((INT)LOW_SHORT (dw), (INT)(HIGH_SHORT (dw) - LOW_SHORT (dw))));
        @     }
        @ }
        @ return strResult;
    }

    方法 被选择文本 <公开 属性写 注释 = "  将组合框编辑部分中当前被选择区域内的文本替换为所指定文本," 注释 = "如果没有被选择区域,则在当前光标位置插入所指定文本." 注释 = "  当类型为\"不可编辑下拉式\"时,本属性无效.">
    参数 所替换文本 <类型 = 文本型 注释 = "提供用作替换当前被选择区域的文本内容">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & (CBS_SIMPLE | CBS_DROPDOWN | CBS_DROPDOWNLIST)) != CBS_DROPDOWNLIST)
        @ {
        @     const DWORD dw = pWnd->GetEditSel ();
        @     if (dw != CB_ERR)
        @     {
        @         INT nSelStart = LOWORD (dw);
        @         const INT nSelEnd = HIWORD (dw);
        @         CString str;
        @         pWnd->GetWindowText (str);
        @         pWnd->SetWindowText (str.Left (nSelStart) + @<所替换文本>.GetText () + str.Right (str.GetLength () - nSelEnd));
        @         nSelStart += (INT)@<所替换文本>.GetLength ();
        @         pWnd->SetEditSel (nSelStart, nSelStart);
        @     }
        @ }
    }

    方法 自动排序 <公开 属性读 类型 = 逻辑型 注释 = "返回是否对组合框中的列表项目进行自动排序" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & CBS_SORT) != 0
    }

    方法 自动排序 <公开 属性写 注释 = "设置是否对组合框中的列表项目进行自动排序" @视窗.设置时机 = 组件创建前>
    参数 是否自动排序 <类型 = 逻辑型>
    {
        @ if (@<是否自动排序>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= CBS_SORT;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~CBS_SORT;
    }

    方法 行间距 <公开 属性读 类型 = 整数 注释 = "返回组合框的列表项目之间的纵向间距尺寸." 注释 = "如果未被设置,则本属性的初始值为1." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ComboBox*)@sn<this>.GetMfcWndPtr ())->m_npRowExtra
    }

    方法 行间距 <公开 属性写 注释 = "设置组合框的列表项目之间的纵向间距尺寸." 注释 = "如果未被设置,则本属性的初始值为1." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的间距 <类型 = 整数>
    {
        @ ((CVWnd_ComboBox*)GetMfcWndPtr ())->m_npRowExtra = CLIP (@<所欲设置的间距>, 0, _VOL_SHRT_MAX);
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ComboBox*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.默认色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_ComboBox*)GetMfcWndPtr ())->SetBackColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ComboBox*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值." 注释 = "如果本组件未曾设置过文本颜色,则默认为黑色." @视窗.设置时机 = 组件创建前后 @值细节类型 = 颜色>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_ComboBox*)pWnd)->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 现行选中项 <公开 属性读 类型 = 整数 注释 = "  返回组合框的下拉列表部分中现行被选中列表项目的索引位置," 注释 = "位置值从0开始,-1表示现行没有被选中的列表项." @禁止流程检查 = 真>
    {
        @ COMPILE_TIME_ASSERT (CB_ERR == -1);
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->GetCurSel ());
    }

    方法 现行选中项 <公开 属性写 注释 = "  设置组合框的下拉列表部分中现行被选中列表项目的索引位置," 注释 = "位置值从0开始,-1表示现行没有被选中的列表项.">
    参数 所欲选中项目的位置 <类型 = 整数 注释 = "必须大于等于-1且小于\"取项目数\"方法的返回值.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetCurSel (@<所欲选中项目的位置>);
    }

    方法 "// 列表项目" <公开 属性读 类型 = 文本型 注释 = "返回组合框下拉列表部分中的列表项目内容." 注释 = "由于一旦组件创建完毕,为了节省空间,此属性值将被清空,因此本属性不支持读取."
            返回值注释 = "  所返回文本内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 返回值注释 = "分别指定一个列表项目的标题文本和关联数值." @嵌入式方法 = "">
    {
        @ ((CVWnd_ComboBox*)@sn<this>.GetMfcWndPtr ())->m_strItems
    }

    方法 列表项目 <公开 属性写 注释 = "设置组合框下拉列表部分中的列表项目内容" 编辑时信息 = "157FEA, 0, 0, 0" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "designer\\mfc_designer_x64.dll\r\ndesigner\\mfc_designer_win32.dll\r\nListItemsManager\r\n0">
    参数 所欲设置的列表内容 <类型 = 文本型 注释 = "  列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 注释 = "分别指定一个列表项目的标题文本和关联数值." 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_ComboBox*)GetMfcWndPtr ())->ResetListItems (@<所欲设置的列表内容>);
    }

    方法 提示横幅 <公开 属性读 类型 = 文本型 注释 = "返回组合框中编辑部份内容为空时所显示的文本提示内容" @禁止流程检查 = 真>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? CVolString ((LPCTSTR)pWnd->GetCueBanner ()) : CVolString ());
    }

    方法 提示横幅 <公开 属性写 注释 = "设置组合框中编辑部份内容为空时所显示的文本提示内容">
    参数 文本提示 <类型 = 文本型>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetCueBanner (@<文本提示>.GetText ());
    }

    方法 最小列表项目数 <公开 属性读 类型 = 整数 注释 = "返回组合框的下拉列表部分中最少可显示的列表项数目" @禁止流程检查 = 真>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetMinVisible ());
    }

    方法 最小列表项目数 <公开 属性写 注释 = "设置组合框的下拉列表部分中最少可显示的列表项数目">
    参数 可视项目数 <类型 = 整数>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetMinVisibleItems (MAX (0, @<可视项目数>));
    }

    方法 编辑框对齐方式 <公开 属性写 注释 = "设置组合框内编辑框中所显示内容的横向对齐方式">
    参数 对齐方式 <类型 = 横向对齐模式>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const HWND hEditWnd = ::FindWindowEx (pWnd->m_hWnd, NULL, _T ("Edit"), NULL);
        @     if (hEditWnd != NULL)
        @     {
        @         const DWORD dwNewStyle = (@<对齐方式> == @<横向对齐模式.左边> ? ES_LEFT : @<对齐方式> == @<横向对齐模式.右边> ? ES_RIGHT : ES_CENTER);
        @         ::SetWindowLong (hEditWnd, GWL_STYLE, ((::GetWindowLong (hEditWnd, GWL_STYLE) & ~(ES_LEFT | ES_RIGHT | ES_CENTER)) | dwNewStyle));
        @         ::RedrawWindow (hEditWnd, NULL, NULL, (RDW_INVALIDATE | RDW_FRAME | RDW_ERASE));
        @     }
        @ }
    }

    # 方法 --

    方法 取顶端可见项目 <公开 类型 = 整数 注释 = "返回组合框列表部分中当前最顶端可见项目的索引." 返回值注释 = "所返回索引值从0开始,失败返回-1." @禁止流程检查 = 真>
    {
        @ COMPILE_TIME_ASSERT (CB_ERR == -1);
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetTopIndex () : -1);
    }

    方法 置顶端可见项目 <公开 类型 = 逻辑型 注释 = "设置组合框列表部分中当前最顶端的可见项目,必要时将自动滚动组合框的列表部分." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "提供所欲操作列表项目的索引位置值,从0开始.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL && pWnd->SetTopIndex (@<所操作项目位置>) != CB_ERR);
    }

    方法 取项目数 <公开 类型 = 整数 注释 = "返回组合框中当前列表项目的数目" @禁止流程检查 = 真>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetCount () : 0);
    }

    方法 取项目数值 <公开 类型 = 变整数 注释 = "返回与指定列表项目相关联的数值" @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)pWnd->GetItemData (@<所操作项目位置>) : 0);
    }

    方法 置项目数值 <公开 注释 = "设置与指定列表项目相关联的数值">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 欲置入的项目数值 <类型 = 变整数 注释 = "该项目数值将与所指定列表项目相关联">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetItemData (@<所操作项目位置>, (DWORD_PTR)@<欲置入的项目数值>);
    }

    方法 取项目文本 <公开 类型 = 文本型 注释 = "返回指定列表项目的内容文本" @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CString str;
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->GetLBText (@<所操作项目位置>, str);
        @ return CVolString ((const TCHAR*)str);
    }

    方法 置项目文本 <公开 注释 = "设置指定列表项目的内容文本">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 所欲设置的文本内容 <类型 = 文本型>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT nCurSel = pWnd->GetCurSel ();
        @     CString strOld;
        @     pWnd->GetLBText (@<所操作项目位置>, strOld);
        @     if (_tcscmp (@<所欲设置的文本内容>.GetText (), (const TCHAR*)strOld) != 0)
        @     {
        @         const DWORD_PTR upItemData = pWnd->GetItemData (@<所操作项目位置>);
        @         pWnd->DeleteString (@<所操作项目位置>);
        @         pWnd->SetItemData (pWnd->InsertString (@<所操作项目位置>, @<所欲设置的文本内容>.GetText ()), upItemData);
        @         if (nCurSel != CB_ERR)
        @             pWnd->SetCurSel (nCurSel);
        @     }
        @ }
    }

    方法 加入项目 <公开 类型 = 整数 注释 = "  加入指定项目到组合框列表部分的尾部,成功返回加入" 注释 = "后该项目所处的索引位置,失败返回-1." @禁止流程检查 = 真>
    参数 欲加入项目的文本 <类型 = 文本型 注释 = "提供所欲加入项目的文本内容">
    参数 相关数值 <类型 = 变整数 注释 = "提供与欲加入项目相关的数值" @默认值 = 0>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT nIndex = pWnd->AddString (@<欲加入项目的文本>.GetText ());
        @     if (nIndex >= 0)
        @     {
        @         pWnd->SetItemData (nIndex, (DWORD_PTR)@<相关数值>);
        @         return nIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 插入项目 <公开 类型 = 整数 注释 = "  插入指定项目到组合框列表部分的指定位置处,成功返回插入" 注释 = "后该项目所处的索引位置,失败返回-1." @禁止流程检查 = 真>
    参数 欲插入项目的位置 <类型 = 整数 注释 = "  提供所欲插入项目在组合框列表部分中的索引位置,从0开始," 注释 = "必须大于等于0且小于等于\"取项目数\"方法的返回值.">
    参数 欲插入项目的文本 <类型 = 文本型 注释 = "提供所欲插入项目的文本内容">
    参数 相关数值 <类型 = 变整数 注释 = "提供与欲插入项目相关的数值" @默认值 = 0>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT nIndex = pWnd->InsertString (@<欲插入项目的位置>, @<欲插入项目的文本>.GetText ());
        @     if (nIndex >= 0)
        @     {
        @         pWnd->SetItemData (nIndex, (DWORD_PTR)@<相关数值>);
        @         return nIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 删除项目 <公开 注释 = "删除组合框列表部分指定位置处的项目">
    参数 所欲删除项目的位置 <类型 = 整数 注释 = "  提供所欲删除项目在组合框列表部分中的索引位置,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteString (@<所欲删除项目的位置>);
    }

    方法 清空 <公开 注释 = "删除组合框列表部分中的所有项目以及编辑部分中的现有内容">
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->ResetContent ();
    }

    方法 选择 <公开 类型 = 整数 注释 = "  在组合框列表部分所有项目中寻找首部包含指定文本的项目," 注释 = "如找到,则将其选中并返回该项目的位置索引,否则返回-1." @禁止流程检查 = 真>
    参数 欲选择项目的首部文本 <类型 = 文本型>
    {
        @ COMPILE_TIME_ASSERT (CB_ERR == -1);
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->SelectString (-1, @<欲选择项目的首部文本>.GetText ()) : -1);
    }

    方法 静默置内容 <公开 注释 = "  正常情况下,只要修改本组件的内容或标题属性,就会导致\"编辑内容被改变\"事件被发送," 注释 = "使用本方法修改本组件的内容将不会发送此事件.">
    参数 所欲设置的内容 <类型 = 文本型>
    {
        @ CVWnd_ComboBox* pWnd = (CVWnd_ComboBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SlientSetWindowText (@<所欲设置的内容>.GetText ());
    }

