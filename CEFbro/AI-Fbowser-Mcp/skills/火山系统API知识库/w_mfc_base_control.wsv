    # 方法 --

    方法 调用反馈事件 <公开 类型 = 整数 注释 = "  产生标签的\"反馈事件\",以调用此标签该事件的处理方法,可以用作在" 注释 = "多线程处理中将控制权转移到程序主线程上去执行."
            返回值注释 = "  返回用户\"反馈事件\"事件处理子程序所返回的值,如果没有相应的事件" 返回值注释 = "处理子程序或采用投递方式传递事件消息(\"等待事件处理完毕\"参数为假)," 返回值注释 = "将返回0."
            @禁止流程检查 = 真>
    参数 参数1 <类型 = 变整数 注释 = "为反馈事件所提供的第1个参数值" @默认值 = 0>
    参数 参数2 <类型 = 变整数 注释 = "为反馈事件所提供的第2个参数值" @默认值 = 0>
    参数 等待事件处理完毕 <类型 = 逻辑型 注释 = "  为真则采用发送方式传递事件消息,此时本方法将一直等待到所产生的" 注释 = "\"反馈事件\"用户事件处理方法处理完毕后才返回,为假则采用投递方式传"
            注释 = "递事件消息,此时本命令将直接返回且不等待用户事件处理方法处理完毕" 注释 = "(用户事件处理方法将在空闲时被调用)." @默认值 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<等待事件处理完毕>)
        @         return (INT)pWnd->SendMessage (MWM_LABEL_MESSAGE, (WPARAM)@<参数1>, (LPARAM)@<参数2>);
        @     pWnd->PostMessage (MWM_LABEL_MESSAGE, (WPARAM)@<参数1>, (LPARAM)@<参数2>);
        @ }
        @ return 0;
    }

    方法 重画标签 <公开 注释 = "  如果需要重画本组件,不要调用基础类中的\"重画\"方法,而需要调用本方法," 注释 = "这样才能保证在\"透明\"属性被设置为真时正常刷新本组件的显示." @嵌入式方法 = "">
    {
        @ ((CVWnd_Label*)@sn<this>.GetMfcWndPtr ())->RedrawLabel ()
    }

    方法 置底图文件 <公开 注释 = "设置显示在画板背景上的位图文件">
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_Label*)GetMfcWndPtr ())->TakeOverBackBitmap ((HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置底图数据 <公开 注释 = "设置显示在画板背景上的位图文件数据">
    参数 所欲设置的位图文件数据 <类型 = 字节集类>
    {
        @ ((CVWnd_Label*)GetMfcWndPtr ())->TakeOverBackBitmap (g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图文件数据>));
    }

