    }

    方法 创建有菜单子对话框 <公开 类型 = 整数 注释 = "以模态对话框的方式创建并显示本窗口类的对象,并一直等待所创建窗口关闭后才会返回." 注释 = "注意: 以本方式创建并显示的窗口,不能去动态调整尺寸和位置,并将初始在屏幕中间显示."
            返回值注释 = "返回用户程序调用\"关闭窗口\"方法关闭所显示对话框时所提供的\"结果值\"参数值." 返回值注释 = "以下几种情况下,将固定返回值-1:"
            返回值注释 = "  1. 对话框为用户直接按 Alt+F4 / ESC 键或点击对话框右上角关闭按钮关闭;" 返回值注释 = "  2. 程序中直接调用相关方法关闭了本窗口;" 返回值注释 = "  3. 创建本窗口或对话框失败."
            @嵌入式方法 = "">
    参数 父窗口组件 <类型 = 窗口组件 注释 = "提供所创建窗口的父窗口组件,如果该窗口组件尚未被创建,则认为无父窗口组件.">
    参数 窗口菜单 <类型 = 菜单类 注释 = "提供窗口的菜单类数据类型,应该为\"菜单类\"的继承类." @需求类型 = 数据类型>
    参数 强制使用对话框风格 <类型 = 逻辑型 注释 = "  是否强制所创建窗口使用固定的对话框风格." 注释 = "  如果参数值为真,则强制使用以下风格: 有标题栏 + 尺寸不可调整 + 只有关闭按钮,"
            注释 = "否则使用本窗口对象在调用本方法前所设置的窗口风格." @默认值 = 真>
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用设计时宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用设计时高度." @默认值 = 数值范围.最小整数值>
    {
        @ @sn<this>.CreateVolDialogWithNewMenu (&@<父窗口组件>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, VOL_RUNTIME_CLASS (@<窗口菜单>), @<强制使用对话框风格>)
    }

    方法 置菜单 <公开 注释 = "设置本窗口的菜单" @嵌入式方法 = "">
    参数 所欲设置的菜单 <类型 = 菜单类 注释 = "提供所欲设置菜单类的数据类型,应该为\"菜单类\"的继承类." @需求类型 = 数据类型>
    {
        @ @sn<this>.SetWndMenuClass (VOL_RUNTIME_CLASS (@<所欲设置的菜单>))
    }

    方法 置实例菜单 <公开 注释 = "设置本窗口的菜单" @嵌入式方法 = "">
    参数 所欲设置的菜单 <类型 = 菜单类 注释 = "提供所欲设置的菜单类对象">
    {
        @ @sn<this>.SetWndMenu (@<所欲设置的菜单>.GetVolMenu ())
    }

    方法 重置菜单 <公开 注释 = "将本窗口的菜单内容重置到其被置入时的初始状态">
    {
        变量 窗口菜单变量 <类型 = 菜单类>
        窗口菜单变量 = 取菜单 ()
        窗口菜单变量.重载 ()
        置实例菜单 (窗口菜单变量)
    }

    方法 清除菜单 <公开 注释 = "清除本窗口中所已经设置的菜单" @嵌入式方法 = "">
    {
        @ @sn<this>.SetWndMenu (NULL)
    }

    方法 取菜单 <公开 类型 = 菜单类 注释 = "返回本窗口中被置入的菜单对象" @嵌入式方法 = "">
    {
        @ @dt<菜单类> (((CVWnd_WinForm*)@sn<this>.GetMfcWndPtr ())->GetWndMenu ())
    }

    方法 关闭窗口 <公开 注释 = "尝试关闭本窗口." 注释 = "注意:" 注释 = "  1. 本方法被调用后窗口不会被立即关闭,而会延迟等待到下一次消息循环时才会关闭."
            注释 = "  3. 如果用户程序处理了本窗口对象的\"可否被关闭\"/\"窗口可否被关闭\"事件并返回非零值,则此方法将关闭失败.">
    参数 结果值 <类型 = 整数 注释 = "如果本窗口为以模态对话框方式显示,提供显示本窗口时所调用的对应\"创建对话框\"序列方法的返回值,否则没有意义." @默认值 = 0>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     ((CVWnd_WinForm*)pWnd)->CloseWinForm (@<结果值>);
    }

    方法 置托盘图标 <公开 注释 = "设置本窗口在系统托盘中的图标">
    参数 所欲设置的图标 <类型 = 图标资源 注释 = "  本参数提供具体所欲设置的图标,如果该资源值为\"空资源.空图标\"," 注释 = "则将清除本窗口在系统托盘中已经设置的图标.">
    参数 提示信息 <类型 = 文本型 注释 = "本参数指定当鼠标移动到图标上后所显示的提示信息" @默认值 = "">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     ((CVWnd_WinForm*)pWnd)->SetTrayIcon ((HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<所欲设置的图标>), @<提示信息>);
    }

    方法 置托盘图标对象 <公开 注释 = "设置本窗口在系统托盘中的图标">
    参数 所欲设置的图标 <类型 = 图标对象类 注释 = "  本参数提供具体所欲设置的图标对象." 注释 = "  注意: 在窗口存在期间必须保证本图标对象不被释放(可以将此对象保存在窗口类的成员变量中)," 注释 = "否则所置入图标将失效.">
    参数 提示信息 <类型 = 文本型 注释 = "本参数指定当鼠标移动到图标上后所显示的提示信息" @默认值 = "">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     ((CVWnd_WinForm*)pWnd)->SetTrayIcon (::CopyIcon ((HICON)@<所欲设置的图标>.GetGDIHandle ()), @<提示信息>);
    }

    方法 显示托盘通知 <公开 注释 = "如果本窗口已经设置了有效的托盘图标,则可以基于此图标显示相应的托盘通知信息." @嵌入式方法 = "">
    参数 标题 <类型 = 文本型>
    参数 信息 <类型 = 文本型>
    参数 图标类型 <类型 = 整数 注释 = "0: 信息图标; 1: 警告图标; 2: 错误图标." @默认值 = 0>
    参数 显示时间 <类型 = 整数 注释 = "信息显示时间长度,单位秒. 有效值从10到30之间." @默认值 = 10>
    {
        @ ::ShowTrayBalloonTip (@sn<this>.GetMfcWndHandle (), @<标题>.GetText (), @<信息>.GetText (), @<图标类型>, @<显示时间>)
    }

    方法 隐藏托盘通知 <公开 注释 = "提前隐藏所已经显示的托盘通知信息" @嵌入式方法 = "">
    {
        @ ::HideTrayBalloonTip (@sn<this>.GetMfcWndHandle ())
    }

    方法 置外形图片 <公开 注释 = "使用图片来设置窗口的外形,图片的轮廓应该尽量简单,以免影响窗口的刷新速度.">
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将清除所设置的外形图片.">
    参数 透明颜色 <类型 = 整数 注释 = "指定图片中透明部分的颜色" @默认值 = 颜色类.白色>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const HBITMAP hBitmap = (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>);
        @     const HRGN hRgn = BitmapToRegion (hBitmap, @<透明颜色>);
        @     if (pWnd->SetWindowRgn (hRgn, TRUE) == FALSE)  // 设置失败?
        @         ::DeleteObject (hRgn);
        @     if (hBitmap != NULL)
        @         ::DeleteObject (hBitmap);
        @ }
    }

    方法 置外形图片2 <公开 注释 = "使用图片来设置窗口的外形,图片的轮廓应该尽量简单,以免影响窗口的刷新速度.">
    参数 所欲设置的位图 <类型 = 字节集类 注释 = "提供所欲设置的位图数据,如果为空字节集,则将清除所设置的外形图片.">
    参数 透明颜色 <类型 = 整数 注释 = "指定图片中透明部分的颜色" @默认值 = 颜色类.白色>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const HBITMAP hBitmap = g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图>);
        @     const HRGN hRgn = BitmapToRegion (hBitmap, @<透明颜色>);
        @     if (pWnd->SetWindowRgn (hRgn, TRUE) == FALSE)  // 设置失败?
        @         ::DeleteObject (hRgn);
        @     if (hBitmap != NULL)
        @         ::DeleteObject (hBitmap);
        @ }
    }

    方法 开始移动窗口 <公开 注释 = "使本窗口进入随意移动模式,一般在用户在窗口上按下鼠标左键时调用.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->PostMessage (161, 2, 0);
    }

    方法 浏览选择目录 <公开 类型 = 文本型 注释 = "打开对话框选择所指定的目录,成功返回所选择目录,失败或用户取消关闭对话框则返回空文本." @禁止流程检查 = 真>
    参数 初始目录 <类型 = 文本型 注释 = "提供初始目录路径,为空文本表示无." @默认值 = "">
    {
        @ CVolString strDir;
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CFolderPickerDialog dlg (@<初始目录>.GetText (), 0, pWnd);
        @     if (dlg.DoModal () == IDOK)
        @         strDir.SetText (dlg.GetPathName ());
        @ }
        @ return strDir;
    }

