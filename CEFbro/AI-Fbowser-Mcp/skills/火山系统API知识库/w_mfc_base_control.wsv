    #                     ::WinHelp (pwndParent->m_hWnd, szHelpFileName, (@<帮助命令> == 1 ? HELP_CONTEXT : HELP_CONTEXTPOPUP), @<帮助标志值>);
    #                 break;
    #             case 3:
    #                 // pwndParent->m_blpHelpOpened = TRUE;
    #                 ::WinHelp (pwndParent->m_hWnd, szHelpFileName, HELP_FORCEFILE, 0);
