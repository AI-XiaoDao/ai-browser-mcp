        @ GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_POPUP;
        @ return CreateVolWindow (&@<父窗口组件>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<所欲使用的菜单>.GetVolMenuCheckNull ());
    }

