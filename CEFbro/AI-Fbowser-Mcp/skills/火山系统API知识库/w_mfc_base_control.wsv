    }

    方法 滚动 <公开 注释 = "垂直滚动多行编辑框中的内容显示区域">
    参数 行数 <类型 = 整数 注释 = "指定欲滚动行数,可以为负数(向前滚动).">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->LineScroll (@<行数>, 0);
    }

    方法 复制 <公开 注释 = "将现行被选择文本复制到剪辑板">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Copy ();
    }

    方法 剪切 <公开 注释 = "将现行被选择文本剪切到剪辑板">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Cut ();
    }

    方法 删除 <公开 注释 = "删除现行被选择文本">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Clear ();
    }

    方法 粘贴 <公开 注释 = "将剪辑板中的现行内容粘贴到光标位置">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Paste ();
    }

    方法 清空撤消数据 <公开 注释 = "清除编辑框中为支持撤消上次更改操作所保存的所有数据,本方法执行后无法再撤消上次所更改的操作.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->EmptyUndoBuffer ();
    }

    方法 撤消 <公开 注释 = "撤消编辑框中最后一次的更改操作">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Undo ();
    }

    方法 可否撤消 <公开 类型 = 逻辑型 注释 = "返回当前编辑框中是否存在可以被撤消的更改操作" @禁止流程检查 = 真>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->CanUndo ());
    }

