    {
        @ ((CVWnd_ScrollBar*)GetMfcWndPtr ())->m_npLineStep = CLIP (@<所欲设置的改变值>, 1, _VOL_SHRT_MAX);
    }

    方法 位置 <公开 属性读 类型 = 整数 注释 = "返回滚动条的当前滚动位置" @禁止流程检查 = 真>
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialPos : pWnd->GetScrollPos ());
    }

    方法 位置 <公开 属性写 注释 = "设置滚动条的当前滚动位置" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialPos = @<所欲设置的位置值>;
        @ else
        @ {
        @     const BOOL_P blpEnable = pWnd->IsWindowEnabled ();
        @     pWnd->SetScrollPos (@<所欲设置的位置值>);
        @     if (blpEnable == FALSE)
        @         pWnd->EnableWindow (FALSE);
        @ }
    }

    方法 允许拖动跟踪 <公开 属性读 类型 = 逻辑型 注释 = "返回当用户拖动滚动条的位置盒的过程中是否产生位置改变事件" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_ScrollBar*)@sn<this>.GetMfcWndPtr ())->m_blpAllowTrack
    }

    方法 允许拖动跟踪 <公开 属性写 注释 = "设置当用户拖动滚动条的位置盒的过程中是否产生位置改变事件" @视窗.设置时机 = 组件创建前后>
    参数 是否允许拖动跟踪 <类型 = 逻辑型>
    {
        @ ((CVWnd_ScrollBar*)GetMfcWndPtr ())->m_blpAllowTrack = @<是否允许拖动跟踪>;
    }

    # 方法 ---

    方法 置滚动范围 <公开 注释 = "设置滚动条当前所允许的最小和最大位置值">
    参数 所允许的最小位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    参数 所允许的最大位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_ScrollBar* pWnd = (CVWnd_ScrollBar*)GetMfcWndPtr ();
        @ @<所允许的最小位置值> = CLIP (@<所允许的最小位置值>, 0, _VOL_SHRT_MAX);
        @ @<所允许的最大位置值> = CLIP (@<所允许的最大位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @ {
        @     pWnd->m_npInitialMin = @<所允许的最小位置值>;
        @     pWnd->m_npInitialMax = @<所允许的最大位置值>;
        @ }
        @ else
        @     pWnd->SetScrollRange (@<所允许的最小位置值>, @<所允许的最大位置值>);
    }

    # ---
    #
    # @ <include>
    # @ virtual BOOL OnNativeWndMsg (MSG* pMsg) override  {  return OnProcessNativeWndMsg (pMsg);  }
    # @ virtual void OnScroll () override  {  @<位置被改变> ();  }
    # @ </include>
}

