类 选择列表框 <公开 基础类 = 列表框基础类 @视窗.外部资源文件 = "src\\res\\mfc_check_list.rc" @视窗.后缀文本 = "public ICheckListBoxEventListener"
        @视窗.窗口组件 = "icon=\"@4\"\r\ndefault_size = \"100, 120\"\r\ndefault_event = \"列表项被选择\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_CheckListBox, ICheckListBoxEventListener, 0, 0, WS_TABSTOP | WS_VSCROLL, WS_EX_CLIENTEDGE)
    #
    # 事件 ---

    方法 选中状态被改变 <公开 定义事件 类型 = 整数 注释 = "当任一列表项左侧选择框的选中状态(选中/未选中/不确定)被改变后发送此事件">

    # 属性 ---

    方法 行间距 <公开 属性读 类型 = 整数 注释 = "返回列表框的列表项目之间的纵向间距尺寸." 注释 = "如果未被设置,则本属性的初始值为2." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CheckListBox*)@sn<this>.GetMfcWndPtr ())->m_npRowExtra
    }

    方法 行间距 <公开 属性写 注释 = "设置列表框的列表项目之间的纵向间距尺寸." 注释 = "如果未被设置,则本属性的初始值为2." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的间距 <类型 = 整数>
    {
        @ ((CVWnd_CheckListBox*)GetMfcWndPtr ())->m_npRowExtra = CLIP (@<所欲设置的间距>, 0, _VOL_SHRT_MAX);
    }

    方法 单选 <公开 属性读 类型 = 逻辑型 注释 = "返回列表框是否只允许设置一个列表项左侧的选择框为选中状态" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_CheckListBox*)@sn<this>.GetMfcWndPtr ())->m_blpOnlyCheckOne
    }

    方法 单选 <公开 属性写 注释 = "设置列表框是否只允许设置一个列表项左侧的选择框为选中状态" @视窗.设置时机 = 组件创建前后>
    参数 是否只能单选 <类型 = 逻辑型>
    {
        @ ((CVWnd_CheckListBox*)GetMfcWndPtr ())->SetOnlyCheckOne (@<是否只能单选>);
    }

    方法 "// 列表项目" <公开 属性读 类型 = 文本型 注释 = "  返回列表框中的列表项目内容." 注释 = "  由于一旦组件创建完毕,为了节省空间,此属性值将被清空," 注释 = "因此本属性不支持读取."
            返回值注释 = "  所返回文本内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 返回值注释 = "分别指定一个列表项目的标题文本和关联数值." @嵌入式方法 = "">
    {
        @ ((CVWnd_CheckListBox*)@sn<this>.GetMfcWndPtr ())->m_strItems
    }

    方法 列表项目 <公开 属性写 注释 = "设置列表框中的列表项目内容" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "designer\\mfc_designer_x64.dll\r\ndesigner\\mfc_designer_win32.dll\r\nListItemsManager\r\n0">
    参数 所欲设置的列表内容 <类型 = 文本型 注释 = "  列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 注释 = "分别指定一个列表项目的标题文本和关联数值." 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_CheckListBox*)GetMfcWndPtr ())->ResetListItems (@<所欲设置的列表内容>);
    }

    # 方法 ---

    方法 置项目文本2 <公开 注释 = "设置指定列表项目的内容文本." 注释 = "本方法与基础类中的\"置项目文本\"方法不同之处在于会自动保持指定列表项目的当前选中和允许状态.">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 所欲设置的文本内容 <类型 = 文本型>
    {
        变量 原选中状态 <类型 = 三态选中状态>
        变量 原允许状态 <类型 = 逻辑型>
        原选中状态 = 取选中状态 (所操作项目位置)
        原允许状态 = 是否被允许 (所操作项目位置)
        如果 (置项目文本 (所操作项目位置, 所欲设置的文本内容))
        {
            置选中状态 (所操作项目位置, 原选中状态)
            允许 (所操作项目位置, 原允许状态)
        }
    }

    方法 是否被选中 <公开 类型 = 逻辑型 注释 = "如果指定列表项目左侧的选择框被选中,返回真,否则返回假." @禁止流程检查 = 真>
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : (pWnd->GetCheck (@<所操作项目索引>) == 1));
    }

    方法 选中项目 <公开 注释 = "选中或取消选中指定列表项目左侧的选择框">
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    参数 是否选中 <类型 = 逻辑型 注释 = "是否选中指定列表项目左侧的选择框" @默认值 = 真>
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetCheck (@<所操作项目索引>, (@<是否选中> ? 1 : 0));
    }

    方法 取选中状态 <公开 类型 = 三态选中状态 注释 = "返回指定列表项目左侧选择框的选中状态" @禁止流程检查 = 真>
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetCheck (@<所操作项目索引>));
    }

    方法 置选中状态 <公开 注释 = "设置指定列表项目左侧选择框的选中状态">
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    参数 所欲设置选中状态 <类型 = 三态选中状态 注释 = "提供所欲设置的具体选中状态" @默认值 = 三态选中状态.选中>
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetCheck (@<所操作项目索引>, @<所欲设置选中状态>);
    }

    方法 是否被允许 <公开 类型 = 逻辑型 注释 = "如果指定列表项目左侧的选择框被允许操作,返回真,否则返回假." @禁止流程检查 = 真>
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->IsEnabled (@<所操作项目索引>));
    }

    方法 允许 <公开 注释 = "允许或禁止对指定项目左侧的选择框进行操作">
    参数 所操作项目索引 <类型 = 整数 注释 = "项目索引值从0开始">
    参数 是否允许 <类型 = 逻辑型 注释 = "是否允许对指定列表项目左侧的选择框进行操作" @默认值 = 真>
    {
        @ CVWnd_CheckListBox* pWnd = (CVWnd_CheckListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Enable (@<所操作项目索引>, @<是否允许>);
    }

    # --
    #
    # @ <include>
    # @ virtual void OnSelchange ()  { @<列表项被选择> (); }
    # @ virtual void OnDblClk ()  { @<双击选择> (); }
    # @ virtual void OnCheckStateChanged ()  { @<选中状态被改变> (); }
    # @ </include>
}

