    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值. 如果本组件未曾设置过文本颜色,则默认为黑色." @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_FileBox*)pWnd)->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    # ---
    #
    # @ <include>
    # @ virtual void OnSelFileChanged () override  {  @<选择文件被改变> ();  }
    # @ virtual void OnDblClickItem  () override  {  @<双击选择> ();  }
    # @ </include>
}

