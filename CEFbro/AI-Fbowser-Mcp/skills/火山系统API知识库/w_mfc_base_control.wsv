    }

    方法 标题颜色 <公开 属性读 类型 = 整数 注释 = "返回月历所使用的标题文本颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_clrTitleText
    }

    方法 标题颜色 <公开 属性写 注释 = "设置月历所使用的标题文本颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_clrTitleText =  @<所欲设置的颜色>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetColor (MCSC_TITLETEXT, pWnd->m_clrTitleText);
    }

    方法 标题背景颜色 <公开 属性读 类型 = 整数 注释 = "返回月历所使用的标题背景颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_clrTitleBack
    }

    方法 标题背景颜色 <公开 属性写 注释 = "设置月历所使用的标题背景颜色" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_clrTitleBack =  @<所欲设置的颜色>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetColor (MCSC_TITLEBK, GetRealBackColor (pWnd->m_clrTitleBack));
    }

    方法 非本月颜色 <公开 属性读 类型 = 整数 注释 = "返回月历中非本月部分所使用的文本颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_clrTrailingText
    }

    方法 非本月颜色 <公开 属性写 注释 = "设置月历中非本月部分所使用的文本颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_clrTrailingText =  @<所欲设置的颜色>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetColor (MCSC_TRAILINGTEXT, pWnd->m_clrTrailingText);
    }

    # 方法 ---

    方法 置日期范围 <公开 注释 = "设置月历所能显示的最小和最大时间">
    参数 所允许的最小时间 <类型 = 小数 注释 = "提供月历所能显示的最小时间,如果为0,则无限制.">
    参数 所允许的最大时间 <类型 = 小数 注释 = "提供月历所能显示的最大时间,如果为0,则无限制.">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_dbMinDate = @<所允许的最小时间>;
        @ pWnd->m_dbMaxDate = @<所允许的最大时间>;
        @ pWnd->UpdateDateRange ();
    }

    # ---
    #
    # @ <include>
    # @ virtual void OnDateChanged () override  {  @<选择日期被改变> ();  }
    # @ </include>
}

