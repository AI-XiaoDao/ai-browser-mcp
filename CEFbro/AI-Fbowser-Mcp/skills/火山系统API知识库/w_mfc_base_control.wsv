        @ if (pWnd != NULL)
        @     pWnd->ReplaceSel (@<所替换文本>.GetText ());
    }

    方法 左边空 <公开 属性读 类型 = 整数 注释 = "返回编辑框中左边的空白间距尺寸" @禁止流程检查 = 真>
