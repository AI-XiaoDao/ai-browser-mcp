类 打印机 <公开 基础类 = 参考对象类 注释 = "打印机操作支持类." 注释 = "注意:" 注释 = "  1. 如未特殊说明,本类中所有坐标位置及尺寸均使用当前\"绘画单位\"属性所设置的单位;"
        注释 = "  2. 本类所使用的绘制坐标系的轴方向: 横向为从左到右,纵向为从上到下." @文档 = "category = \"常用功能\"" @视窗.外部头文件 = "src\\mfc_ui_printer.h"
        @视窗.外部源文件 = "src\\mfc_ui_printer.cpp" @视窗.后缀文本 = "public IPrintingProgress">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CVol_Printer)
    #
    # 事件 --

    方法 打印开始 <公开 定义事件 类型 = 整数 注释 = "当打印成功开始后,本事件被发送.">

    方法 打印完一页 <公开 定义事件 类型 = 整数 注释 = "  当成功打印完一页后,将发送本事件." 注释 = "  可以在事件接收处理方法中读取\"打印作业名\",\"当前页号\",\"已打印份数\","
            注释 = "\"设备名称\",\"端口名称\"等属性来获取当前相关信息.">

    方法 打印结束 <公开 定义事件 类型 = 整数 注释 = "当打印结束或被中止后,本事件被发送.">
    参数 是否为被中止 <类型 = 逻辑型 注释 = "  参数值为真表示打印被中止(中途打印失败或调用了\"取消打印\"方法)," 注释 = "否则表示打印正常结束.">

    # 属性 --

    方法 绘画单位 <公开 属性读 类型 = 绘画单位类型 注释 = "返回绘画时所使用的单位" @嵌入式方法 = "">
