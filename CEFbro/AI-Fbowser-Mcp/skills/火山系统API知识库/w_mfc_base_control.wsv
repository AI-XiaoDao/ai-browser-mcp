    方法 创建主窗口 <公开 类型 = 逻辑型 注释 = "创建本窗口类的对象并将其作为程序的主窗口." 注释 = "注意:" 注释 = "  1. 程序中必须存在且只能存在一个主窗口,调用本方法后,主窗口将被设置为本窗口;"
            注释 = "  2. 主窗口必须在程序的\"启动类\"中存在成员变量定义,避免其在程序退出前被释放," 注释 = "否则将可能导致程序运行时崩溃." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用设计时宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用设计时高度." @默认值 = 数值范围.最小整数值>
    参数 所欲使用的菜单 <类型 = 菜单类 注释 = "提供所欲同时设置的窗口菜单,为空对象表示无." @默认值 = 空对象>
    {
        @ @sn<this>.CreateMainVolWindow (@<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<所欲使用的菜单>.GetVolMenuCheckNull ())
    }

    方法 创建有菜单主窗口 <公开 类型 = 逻辑型 注释 = "创建本窗口类的对象并将其作为程序的主窗口." 注释 = "注意:" 注释 = "  1. 程序中必须存在且只能存在一个主窗口,调用本方法后,主窗口将被设置为本窗口;"
            注释 = "  2. 主窗口必须在程序的\"启动类\"中存在成员变量定义,避免其在程序退出前被释放," 注释 = "否则将可能导致程序运行时崩溃." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 窗口菜单 <类型 = 菜单类 注释 = "提供窗口的菜单类数据类型,应该为\"菜单类\"的继承类." @需求类型 = 数据类型>
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用设计时宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用设计时高度." @默认值 = 数值范围.最小整数值>
    {
        @ @sn<this>.CreateMainVolWindowWithNewMenu (@<左边位置>, @<顶边位置>, @<宽度>, @<高度>, VOL_RUNTIME_CLASS (@<窗口菜单>))
    }

    方法 置为主窗口 <公开 注释 = "将本窗口设置为程序的主窗口." 注释 = "注意:" 注释 = "  1. 程序中必须存在且只能存在一个主窗口,调用本方法后,主窗口将被设置为本窗口;"
            注释 = "  2. 主窗口必须在程序的\"启动类\"中存在成员变量定义,避免其在程序退出前被释放," 注释 = "否则将可能导致程序运行时崩溃.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && AfxGetApp () != NULL)
        @     AfxGetApp ()->m_pMainWnd = pWnd;
    }

    方法 创建对话框 <公开 类型 = 整数 注释 = "以模态对话框的方式创建并显示本窗口类的对象,并一直等待所创建窗口关闭后才会返回." 注释 = "注意: 以本方式创建并显示的窗口,不能去动态调整尺寸和位置,并将初始在屏幕中间显示."
            返回值注释 = "返回用户程序调用\"关闭窗口\"方法关闭所显示对话框时所提供的\"结果值\"参数值." 返回值注释 = "以下几种情况下,将固定返回值-1:"
            返回值注释 = "  1. 对话框为用户直接按 Alt+F4 / ESC 键或点击对话框右上角关闭按钮关闭;" 返回值注释 = "  2. 程序中直接调用相关方法关闭了本窗口;" 返回值注释 = "  3. 创建本窗口或对话框失败."
            @嵌入式方法 = "">
    参数 强制使用对话框风格 <类型 = 逻辑型 注释 = "  是否强制所创建窗口使用固定的对话框风格." 注释 = "  如果参数值为真,则强制使用以下风格: 有标题栏 + 尺寸不可调整 + 只有关闭按钮,"
            注释 = "否则使用本窗口对象在调用本方法前所设置的窗口风格." @默认值 = 真>
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示横向居中." @默认值 = 数值范围.最小整数值>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示纵向居中." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用设计时宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用设计时高度." @默认值 = 数值范围.最小整数值>
    参数 所欲使用的菜单 <类型 = 菜单类 注释 = "提供所欲同时设置的对话框菜单,为空对象表示无." @默认值 = 空对象>
    {
        @ @sn<this>.CreateVolDialog (NULL, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<所欲使用的菜单>.GetVolMenuCheckNull (), @<强制使用对话框风格>)
    }

