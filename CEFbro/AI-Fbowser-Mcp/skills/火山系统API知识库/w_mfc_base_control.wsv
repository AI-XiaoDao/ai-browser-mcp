}

# ===

类 列表框基础类 <公开 基础类 = 窗口组件 编辑时信息 = "1DEA8C, 0, 0, 0" @文档 = "category = \"窗口组件.基础类\"" @禁止创建对象 = 真>
{

    # 事件 --

    方法 列表项被选择 <公开 定义事件 类型 = 整数 注释 = "当某列表项被选择后发送此事件">

    方法 双击选择 <公开 定义事件 类型 = 整数 注释 = "当使用鼠标左键在某列表项目上双击时发送此事件">

    # 属性 --

    方法 自动排序 <公开 属性读 类型 = 逻辑型 注释 = "返回是否对列表框中的列表项目进行自动排序" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & LBS_SORT) != 0
    }

    方法 自动排序 <公开 属性写 注释 = "设置是否对列表框中的列表项目进行自动排序" @视窗.设置时机 = 组件创建前>
    参数 是否自动排序 <类型 = 逻辑型>
    {
        @ if (@<是否自动排序>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= LBS_SORT;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~LBS_SORT;
    }

    方法 多列 <公开 属性读 类型 = 逻辑型 注释 = "返回当前组件是否为支持水平滚动的多列列表框" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & LBS_MULTICOLUMN) != 0
    }

    方法 多列 <公开 属性写 注释 = "设置当前组件是否为支持水平滚动的多列列表框" @视窗.设置时机 = 组件创建前>
    参数 是否为多列 <类型 = 逻辑型>
    {
        @ if (@<是否为多列>)
        @ {
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~WS_VSCROLL;
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= (LBS_MULTICOLUMN | WS_HSCROLL);
        @ }
        @ else
        @ {
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~(LBS_MULTICOLUMN | WS_HSCROLL);
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_VSCROLL;
        @ }
    }

    方法 允许选择多项 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许用户同时选择列表框中的多个列表项" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & LBS_EXTENDEDSEL) != 0
    }

    方法 允许选择多项 <公开 属性写 注释 = "设置是否允许用户同时选择列表框中的多个列表项" @视窗.设置时机 = 组件创建前>
    参数 是否允许多选 <类型 = 逻辑型>
    {
        @ if (@<是否允许多选>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= LBS_EXTENDEDSEL;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~LBS_EXTENDEDSEL;
    }

    方法 现行选中项 <公开 属性读 类型 = 整数 注释 = "返回列表框中现行被选中列表项目的索引位置,位置值从0开始,-1表示现行没有被选中的列表项." @禁止流程检查 = 真>
    {
        @ COMPILE_TIME_ASSERT (LB_ERR == -1);
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->GetCurSel ());
    }

    方法 现行选中项 <公开 属性写 注释 = "设置列表框中现行被选中列表项目的索引位置,位置值从0开始,-1表示现行没有被选中的列表项.">
    参数 所欲选中项目的位置 <类型 = 整数 注释 = "必须大于等于-1且小于\"取项目数\"方法的返回值">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetCurSel (@<所欲选中项目的位置>);
    }

    # 方法 --

    方法 取顶端可见项目 <公开 类型 = 整数 注释 = "返回列表框中当前最顶端可见项目的索引." 返回值注释 = "所返回索引值从0开始,失败返回-1." @禁止流程检查 = 真>
    {
        @ COMPILE_TIME_ASSERT (LB_ERR == -1);
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetTopIndex () : -1);
    }

    方法 置顶端可见项目 <公开 类型 = 逻辑型 注释 = "设置列表框中当前最顶端的可见项目,必要时将自动滚动列表框." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "提供所欲操作列表项目的索引位置值,从0开始.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL && pWnd->SetTopIndex (@<所操作项目位置>) != LB_ERR);
    }

    方法 取项目数 <公开 类型 = 整数 注释 = "返回列表框中当前列表项目的数目" @禁止流程检查 = 真>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetCount () : 0);
    }

    方法 取项目数值 <公开 类型 = 变整数 注释 = "返回与指定列表项目相关联的数值" @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)pWnd->GetItemData (@<所操作项目位置>) : 0);
    }

    方法 置项目数值 <公开 注释 = "设置与指定列表项目相关联的数值">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 欲置入的项目数值 <类型 = 变整数 注释 = "该项目数值将与所指定列表项目相关联">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetItemData (@<所操作项目位置>, (DWORD_PTR)@<欲置入的项目数值>);
    }

    方法 查找项目数值 <公开 类型 = 整数 注释 = "在列表框中查找第一个具有指定项目数值的列表项,找到返回其索引位置,未找到返回-1." @禁止流程检查 = 真>
    参数 欲查找的项目数值 <类型 = 变整数>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT_P npCount = pWnd->GetCount ();
        @     for (INT_P npIndex = 0; npIndex < npCount; npIndex++)
        @     {
        @         if ((INT_P)pWnd->GetItemData ((INT)npIndex) == @<欲查找的项目数值>)
        @             return (INT)npIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 取项目文本 <公开 类型 = 文本型 注释 = "返回指定列表项目的内容文本" 返回值注释 = "如果所指定列表项目不存在,将返回空文本." @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CString str;
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && @<所操作项目位置> >= 0)
        @     pWnd->GetText (@<所操作项目位置>, str);
        @ return CVolString ((const TCHAR*)str);
    }

    方法 置项目文本 <公开 类型 = 逻辑型 注释 = "设置指定列表项目的内容文本" 返回值注释 = "返回是否进行了实际列表项内容文本修改">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 所欲设置的文本内容 <类型 = 文本型>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd == NULL)
        @     return FALSE;
        @ if (@<所操作项目位置> >= 0 && @<所操作项目位置> < pWnd->GetCount ())
        @ {
        @     CString strOld;
        @     pWnd->GetText (@<所操作项目位置>, strOld);
        @     if (_tcscmp (strOld, @<所欲设置的文本内容>.GetText ()) != 0)
        @     {
        @         const INT nCurSel = pWnd->GetCurSel ();
        @         const INT nTopIndex = pWnd->GetTopIndex ();
        @         const INT nCaretIndex = pWnd->GetCaretIndex ();
        @         const DWORD_PTR dw = pWnd->GetItemData (@<所操作项目位置>);
        @         pWnd->DeleteString (@<所操作项目位置>);
        @         pWnd->SetItemData (pWnd->InsertString (@<所操作项目位置>, @<所欲设置的文本内容>.GetText ()), dw);
        @         if (nCurSel != LB_ERR)
        @             pWnd->SetCurSel (nCurSel);
        @         if (nTopIndex != LB_ERR)
        @             pWnd->SetTopIndex (nTopIndex);
        @         if (nCaretIndex != LB_ERR)
        @             pWnd->SetCaretIndex (nCaretIndex);
        @         return TRUE;
        @     }
        @ }
        返回 (假)
    }

    方法 取已选择项目数 <公开 类型 = 整数 注释 = "返回当前已选择项目数" @禁止流程检查 = 真>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if ((pWnd->GetStyle () & (LBS_EXTENDEDSEL | LBS_MULTIPLESEL)) != 0)
        @     {
        @         const INT nCount = pWnd->GetSelCount ();
        @         return (nCount == LB_ERR ? 0 : nCount);
        @     }
        @     else
        @         return (pWnd->GetCurSel () == LB_ERR ? 0 : 1);
        @ }
    }

    方法 取所有被选择项目 <公开 类型 = 整数 注释 = "将所有当前被选择项目的位置索引填入到所提供的整数数组对象内" 返回值注释 = "返回填入到所提供数组内的位置索引数目">
    参数 被选择项目数组 <类型 = 整数数组类 注释 = "用作接收所有当前被选择项目的位置索引">
    {
        被选择项目数组.删除所有成员 ()
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if ((pWnd->GetStyle () & (LBS_EXTENDEDSEL | LBS_MULTIPLESEL)) != 0)
        @     {
        @         const INT_P npCount = pWnd->GetCount ();
        @         for (INT_P npIndex = 0; npIndex < npCount; npIndex++)
        @         {
        @             if (pWnd->GetSel ((INT)npIndex) > 0)
        @                 @<被选择项目数组>.data ().Add ((INT)npIndex);
        @         }
        @     }
        @     else
        @     {
        @         INT nCurSel = pWnd->GetCurSel ();
        @         if (nCurSel != LB_ERR)
        @             @<被选择项目数组>.data ().Add (nCurSel);
        @     }
        @ }
        返回 (被选择项目数组.取成员数 ())
    }

    方法 是否被选择 <公开 类型 = 逻辑型 注释 = "如果指定项目被选择,返回真,否则返回假." @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL && @<所操作项目位置> >= 0 && @<所操作项目位置> < pWnd->GetCount () && pWnd->GetSel (@<所操作项目位置>) > 0);
    }

    方法 选择项目 <公开 注释 = "选择或取消选择所指定项目">
    参数 所操作项目位置 <类型 = 整数 注释 = "  提供所欲操作列表项目的索引位置值,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    参数 是否选中 <类型 = 逻辑型 注释 = "参数值为真,则选择该项目,否则取消对该项目的选择." @默认值 = 真>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if ((pWnd->GetStyle () & (LBS_EXTENDEDSEL | LBS_MULTIPLESEL)) != 0)
        @         pWnd->SetSel (@<所操作项目位置>, @<是否选中>);
        @     else
        @     {
        @         if (@<是否选中>)
        @             pWnd->SetCurSel (@<所操作项目位置>);
        @         else if (pWnd->GetCurSel () == @<所操作项目位置>)
        @             pWnd->SetCurSel (-1);
        @     }
        @ }
    }

    方法 取焦点项目 <公开 类型 = 整数 注释 = "本方法仅在多选列表框中使用,用作返回当前焦点项目的位置索引." 注释 = "如果在单选列表框中使用本命令,将返回当前被选择项目的位置索引."
            返回值注释 = "所返回索引值从0开始,失败返回-1." @禁止流程检查 = 真>
    {
        @ COMPILE_TIME_ASSERT (LB_ERR == -1);
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetCaretIndex () : -1);
    }

    方法 置焦点项目 <公开 类型 = 逻辑型 注释 = "本方法仅在多选列表框中使用,用作设置当前焦点项目." 注释 = "如果在单选列表框中使用本方法,将设置当前被选择项目." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所操作项目位置 <类型 = 整数 注释 = "提供所欲操作列表项目的索引位置值,从0开始.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if ((pWnd->GetStyle () & (LBS_EXTENDEDSEL | LBS_MULTIPLESEL)) != 0)
        @         return (pWnd->SetCaretIndex (@<所操作项目位置>) != LB_ERR);
        @     else
        @         return (pWnd->SetCurSel (@<所操作项目位置>) != LB_ERR);
        @ }
        @ return FALSE;

    }

    方法 加入项目 <公开 类型 = 整数 注释 = "  加入指定项目到列表框的尾部,成功返回加入" 注释 = "后该项目所处的索引位置,失败返回-1." @禁止流程检查 = 真>
    参数 欲加入项目的文本 <类型 = 文本型 注释 = "提供所欲加入项目的文本内容">
    参数 相关数值 <类型 = 变整数 注释 = "提供与欲加入项目相关的数值" @默认值 = 0>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT nIndex = pWnd->AddString (@<欲加入项目的文本>.GetText ());
        @     if (nIndex >= 0)
        @     {
        @         pWnd->SetItemData (nIndex, (DWORD_PTR)@<相关数值>);
        @         return nIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 插入项目 <公开 类型 = 整数 注释 = "  插入指定项目到列表框的指定位置处,成功返回插入" 注释 = "后该项目所处的索引位置,失败返回-1." @禁止流程检查 = 真>
    参数 欲插入项目的位置 <类型 = 整数 注释 = "  提供所欲插入项目在列表框中的索引位置,从0开始," 注释 = "必须大于等于0且小于等于\"取项目数\"方法的返回值.">
    参数 欲插入项目的文本 <类型 = 文本型 注释 = "提供所欲插入项目的文本内容">
    参数 相关数值 <类型 = 变整数 注释 = "提供与欲插入项目相关的数值" @默认值 = 0>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT nIndex = pWnd->InsertString (@<欲插入项目的位置>, @<欲插入项目的文本>.GetText ());
        @     if (nIndex >= 0)
        @     {
        @         pWnd->SetItemData (nIndex, (DWORD_PTR)@<相关数值>);
        @         return nIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 删除项目 <公开 注释 = "删除列表框指定位置处的项目">
    参数 所欲删除项目的位置 <类型 = 整数 注释 = "  提供所欲删除项目在列表框中的索引位置,从0开始," 注释 = "必须大于等于0且小于\"取项目数\"方法的返回值.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteString (@<所欲删除项目的位置>);
    }

    方法 清空 <公开 注释 = "删除列表框中的所有项目以及编辑部分中的现有内容">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->ResetContent ();
    }

    方法 选择 <公开 类型 = 整数 注释 = "  在列表框所有项目中寻找首部包含指定文本的项目,如找到," 注释 = "则将其选中并返回该项目的位置索引,否则返回-1." @禁止流程检查 = 真>
    参数 欲选择项目的首部文本 <类型 = 文本型>
    {
        @ COMPILE_TIME_ASSERT (LB_ERR == -1);
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->SelectString (-1, @<欲选择项目的首部文本>.GetText ()) : -1);
    }

    方法 置列宽 <公开 注释 = "如果列表框当前为多列方式(\"多列\"属性值为真),则设定所有列的宽度.">
    参数 所欲设置的列宽 <类型 = 整数>
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & LBS_MULTICOLUMN) != 0)
        @     pWnd->SetColumnWidth (@<所欲设置的列宽>);
    }

    方法 计算设置列宽 <公开 注释 = "  如果列表框当前为多列方式(\"多列\"属性值为真),则根据当前所有" 注释 = "列表项文本的最大宽度来设定所有列的宽度.">
    {
        @ CListBox* pWnd = (CListBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && (pWnd->GetStyle () & LBS_MULTICOLUMN) != 0)
        @ {
        @     CString str;
        @     CSize size;
        @     INT nMaxWidth = 0;
        @     CDC* pDC = pWnd->GetDC ();
        @     const INT_P npNumItems = pWnd->GetCount ();
        @     for (INT_P npIndex = 0; npIndex < npNumItems; npIndex++)
        @     {
        @         pWnd->GetText ((INT)npIndex, str);
        @         size = pDC->GetTextExtent (str);
        @         if (size.cx > nMaxWidth)
        @             nMaxWidth = size.cx;
        @     }
        @     pWnd->ReleaseDC (pDC);
        @     pWnd->SetColumnWidth (nMaxWidth * 4 / 3);  // 预留1/3的宽度余量
        @ }
    }
}

