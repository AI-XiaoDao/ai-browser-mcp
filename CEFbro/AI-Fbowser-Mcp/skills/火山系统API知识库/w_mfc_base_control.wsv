类 颜色选择器 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_color_picker.h" @视窗.外部源文件 = "src\\tr_mfc_ui_color_picker.cpp"
        @视窗.后缀文本 = "public IColorEventListener" @视窗.窗口组件 = "icon=\"@5\"\r\ndefault_size = \"80, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ColorPicker, IColorEventListener, 0, 0, WS_TABSTOP, 0)
    #
    # 事件 --

    方法 颜色被改变 <公开 定义事件 类型 = 整数 注释 = "  当用户选中了某颜色后本事件被触发,在事件处理方法中" 注释 = "可以通过读取\"颜色\"属性来获取用户所选择的颜色.">

    # 属性 --

    方法 颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所选择的颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ColorPicker*)@sn<this>.GetMfcWndPtr ())->GetCurrentColor ()
    }

    方法 颜色 <公开 属性写 注释 = "设置当前所选择的颜色" @值细节类型 = 颜色支持透明 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值." 注释 = "本属性的默认值为黑色.">
    {
        @ ((CVWnd_ColorPicker*)GetMfcWndPtr ())->SetCurrentColor (@<所欲设置的颜色值>);
    }

    方法 允许透明 <公开 属性读 类型 = 逻辑型 注释 = "  返回是否允许透明色. 如果允许透明色,则当用户选择透明色时," 注释 = "本属性的值将为\"颜色类.透明色\"常量值." @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_ColorPicker*)@sn<this>.GetMfcWndPtr ())->m_blpAllowTransparent
    }

    方法 允许透明 <公开 属性写 注释 = "  设置是否允许透明色. 如果允许透明色,则当用户选择透明色时," 注释 = "本属性的值将为\"颜色类.透明色\"常量值." 注释 = "  本属性的默认值为假." @视窗.设置时机 = 组件创建前后>
    参数 是否允许透明色 <类型 = 逻辑型>
    {
        @ ((CVWnd_ColorPicker*)GetMfcWndPtr ())->SetAllowTransparent (@<是否允许透明色>);
    }

    方法 透明色标题 <公开 属性读 类型 = 文本型 注释 = "返回当允许透明色时,显示在颜色选择框上的具体文本." @嵌入式方法 = "">
    {
        @ ((CVWnd_ColorPicker*)@sn<this>.GetMfcWndPtr ())->m_strTransparentCaption
    }

    方法 透明色标题 <公开 属性写 注释 = "设置当允许透明色时,显示在颜色选择框上的具体文本." 注释 = "本属性的默认值为\"透明色\"." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的标题 <类型 = 文本型>
    {
        @ ((CVWnd_ColorPicker*)GetMfcWndPtr ())->SetTransparentCaption (@<所欲设置的标题>);
    }

    # --
    #
    # @ <include>
    # @ virtual void OnColorChanged () override  {  @<颜色被改变> ();  }
    # @ </include>
}

