    方法 字体 <公开 属性写 注释 = "设置打印文本时所使用的字体" @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ data ().SetPaintFont (@<字体描述文本>);
    }

    方法 打印作业名 <公开 属性读 类型 = 文本型 注释 = "  在打印过程中,本属性的内容将显示在由类库自动提供的打印" 注释 = "状态对话框及Windows打印管理器中." 注释 = "  如果为空,默认为\"未命名打印作业\"."
            @嵌入式方法 = "">
    {
        @ @sn<this>.data ().m_strPrintTitle
    }

    方法 打印作业名 <公开 属性写 注释 = "  在打印过程中,本属性的内容将显示在由类库自动提供的打印" 注释 = "状态对话框及Windows打印管理器中.">
    参数 所欲设置名称 <类型 = 文本型 注释 = "提供具体的打印作业名称,如果为空,默认为\"未命名打印作业\".">
