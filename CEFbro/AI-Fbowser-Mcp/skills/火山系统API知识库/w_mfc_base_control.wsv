    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ListBox*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.白色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_ListBox*)GetMfcWndPtr ())->SetBackColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ListBox*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值." 注释 = "如果本组件未曾设置过文本颜色,则默认为黑色." @视窗.设置时机 = 组件创建前后 @值细节类型 = 颜色>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_ListBox*)pWnd)->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 "// 列表项目" <公开 属性读 类型 = 文本型 注释 = "  返回列表框中的列表项目内容." 注释 = "  由于一旦组件创建完毕,为了节省空间,此属性值将被清空," 注释 = "因此本属性不支持读取."
            返回值注释 = "  所返回文本内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 返回值注释 = "分别指定一个列表项目的标题文本和关联数值." @嵌入式方法 = "">
    {
        @ ((CVWnd_ListBox*)@sn<this>.GetMfcWndPtr ())->m_strItems
    }

    方法 列表项目 <公开 属性写 注释 = "设置列表框中的列表项目内容" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "designer\\mfc_designer_x64.dll\r\ndesigner\\mfc_designer_win32.dll\r\nListItemsManager\r\n0">
    参数 所欲设置的列表内容 <类型 = 文本型 注释 = "  列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 注释 = "分别指定一个列表项目的标题文本和关联数值." 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_ListBox*)GetMfcWndPtr ())->ResetListItems (@<所欲设置的列表内容>);
    }

    # --
