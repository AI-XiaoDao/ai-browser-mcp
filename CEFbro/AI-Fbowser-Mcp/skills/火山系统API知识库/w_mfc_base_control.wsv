    }

    方法 调节器底限值 <公开 属性读 类型 = 整数 注释 = "编辑框如果具有调节器,返回其所能够设置的最小值." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npSpinMin
    }

    方法 调节器底限值 <公开 属性写 注释 = "编辑框如果具有调节器,设置其所能够设置的最小值." 注释 = "本属性的默认值为0." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的底限值 <类型 = 整数 注释 = "提供所欲设置的底限值,不能超出短整数的表达范围.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ pWnd->m_npSpinMin = CLIP (@<所欲设置的底限值>, _VOL_SHRT_MIN, _VOL_SHRT_MAX);
        @ if (pWnd->m_spin.m_hWnd != NULL)
        @     pWnd->m_spin.SetRange ((INT)MIN (pWnd->m_npSpinMin, pWnd->m_npSpinMax), (INT)MAX (pWnd->m_npSpinMin, pWnd->m_npSpinMax));
    }

    方法 调节器上限值 <公开 属性读 类型 = 整数 注释 = "编辑框如果具有调节器,返回其所能够设置的最大值." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Edit*)@sn<this>.GetMfcWndPtr ())->m_npSpinMax
    }

    方法 调节器上限值 <公开 属性写 注释 = "编辑框如果具有调节器,设置其所能够设置的最大值." 注释 = "本属性的默认值为100." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的上限值 <类型 = 整数 注释 = "提供所欲设置的底限值,不能超出短整数的表达范围.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ pWnd->m_npSpinMax = CLIP (@<所欲设置的上限值>, _VOL_SHRT_MIN, _VOL_SHRT_MAX);
        @ if (pWnd->m_spin.m_hWnd != NULL)
        @     pWnd->m_spin.SetRange ((INT)MIN (pWnd->m_npSpinMin, pWnd->m_npSpinMax), (INT)MAX (pWnd->m_npSpinMin, pWnd->m_npSpinMax));
    }

    方法 起始选择位置 <公开 属性读 类型 = 整数 注释 = "返回编辑框中当前被选择文本的起始索引位置,从0开始." 注释 = "如果没有文本被选中,则提供光标当前位置." @禁止流程检查 = 真>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     INT nStartChar = 0, nEndChar;
        @     pWnd->GetSel (nStartChar, nEndChar);
        @     return nStartChar;
        @ }
        @ return 0;
    }

    方法 起始选择位置 <公开 属性写 注释 = "设置编辑框中当前被选择文本的起始索引位置">
    参数 所欲设置的索引位置 <类型 = 整数 注释 = "从0开始,如果为-1,则将当前光标位置移动到文本尾部.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<所欲设置的索引位置> < 0)
        @     {
        @         CString str;
        @         pWnd->GetWindowText (str);
        @         pWnd->SetSel (str.GetLength (), str.GetLength ());
        @     }
        @     else
        @     {
        @         INT nStartChar = 0, nEndChar = 0;
        @         pWnd->GetSel (nStartChar, nEndChar);
        @         pWnd->SetSel (@<所欲设置的索引位置>, @<所欲设置的索引位置> + MAX (0, nEndChar - nStartChar));
        @     }
        @ }
    }

    方法 被选择字符数 <公开 属性读 类型 = 整数 注释 = "返回编辑框中当前被选择文本的字符数" @禁止流程检查 = 真>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     INT nStartChar = 0, nEndChar = 0;
        @     pWnd->GetSel (nStartChar, nEndChar);
        @     return nEndChar - nStartChar;
        @ }
        @ return 0;
    }

    方法 被选择字符数 <公开 属性写 注释 = "设置编辑框中当前被选择文本的字符数">
    参数 所被选择的字符数 <类型 = 整数 注释 = "如果为-1,则选择编辑框内的所有字符.">
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<所被选择的字符数> < 0)
        @     {
        @         pWnd->SetSel (0, -1);
        @     }
        @     else
        @     {
        @         INT nStartChar = 0, nEndChar;
        @         pWnd->GetSel (nStartChar, nEndChar);
        @         pWnd->SetSel (nStartChar, nStartChar + @<所被选择的字符数>);
        @     }
        @ }
    }

    方法 被选择文本 <公开 属性读 类型 = 文本型 注释 = "返回编辑框中当前被选择区域内的文本,如果没有被选择区域,则返回空文本." @禁止流程检查 = 真>
    {
        @ CVolString strResult;
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     INT nStartChar = 0, nEndChar = 0;
        @     pWnd->GetSel (nStartChar, nEndChar);
        @     CString str;
        @     pWnd->GetWindowText (str);
        @     strResult.SetText (str.Mid (nStartChar, nEndChar - nStartChar));
        @ }
        @ return strResult;
    }

    方法 被选择文本 <公开 属性写 注释 = "  将编辑框中当前被选择区域内的文本替换为所指定文本," 注释 = "如果没有被选择区域,则在当前光标位置插入所指定文本.">
