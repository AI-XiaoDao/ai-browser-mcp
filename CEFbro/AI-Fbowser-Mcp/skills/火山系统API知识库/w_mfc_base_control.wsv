        @ pWnd->m_dtEndSel =  @<所欲设置的尾选择日>;
        @ pWnd->UpdateSelRange ();
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回月历所使用的文本颜色" @嵌入式方法 = "">
