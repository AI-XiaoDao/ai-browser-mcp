<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.基本 <注释 = "本程序提供视窗项目MFC界面的窗口支持功能" @文档 = "category = \"窗口组件\"">

类 图片放置方式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 图片居左上 <公开 值 = 0>
    常量 图片平铺 <公开 值 = 1>
    常量 图片居中 <公开 值 = 2>
    常量 缩放图片 <公开 值 = 3>
}

类 空布局 <公开 基础类 = 组件布局器 注释 = "一个空白内容的布局" 隐藏值属性 = "0" @视窗.布局 = "client_size = \"898, 584\"">

类 组件布局器 <公开 基础类 = 窗口容器组件 注释 = "提供一个通用的窗口容器组件" 编辑时信息 = "10EA99, 0, 0, 0" 隐藏值属性 = "0" @视窗.布局 = "client_size = \"600, 420\""
        @视窗.后缀文本 = "public IContainerEventListener"
        @视窗.窗口组件 = "icon=\"@55\"\r\ndefault_size = \"120, 100\"\r\ndefault_event = \"创建完毕\"\r\n"
        @可插入程序类 = "icon=\"res\\layout.bmp\"\r\nexplain=\"在所插入新布局器类上单击鼠标右键,选择\\\"设计xxx的界面布局\\\"菜单项即可可视化设计该布局器的界面内容.\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Container, IContainerEventListener, 0, 0, 0, 0)
    #
    # 属性 --

    方法 底色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Container*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 底色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.默认色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CVWnd_Container* pWnd = (CVWnd_Container*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ pWnd->RedrawContainer ();
    }

    方法 底图 <公开 属性写 注释 = "设置显示在本组件背景上的位图" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TakeOverBackBitmap ((HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 底图方式 <公开 属性读 类型 = 图片放置方式 注释 = "返回本组件上底图的放置方式" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Container*)@sn<this>.GetMfcWndPtr ())->m_enBackPicPaintMode
    }

    方法 底图方式 <公开 属性写 注释 = "设置本组件上底图的放置方式" @视窗.设置时机 = 组件创建前后>
    参数 放置方式 <类型 = 图片放置方式>
    {
        @ CVWnd_Container* pWnd = (CVWnd_Container*)GetMfcWndPtr ();
        @ pWnd->m_enBackPicPaintMode = (VOL_PIC_PAINT_MODE)@<放置方式>;
        @ pWnd->RedrawContainer ();
    }

    方法 透明 <公开 属性读 类型 = 逻辑型 注释 = "返回本组件背景是否透明" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Container*)@sn<this>.GetMfcWndPtr ())->m_blpTransparent
    }

    方法 透明 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本属性值设置为真,则\"背景颜色\"属性将不起作用." 注释 = "注意本属性不支持在界面设计器中预览,不支持在顶层窗口上使用."
            @视窗.设置时机 = 组件创建前后>
    参数 是否透明 <类型 = 逻辑型>
    {
        @ CVWnd_Container* pWnd = (CVWnd_Container*)GetMfcWndPtr ();
        @ pWnd->m_blpTransparent = (COLORREF)@<是否透明>;
        @ #ifndef _VOL_FOR_UI_DESIGNER  // 不为编译布局设计器专用版本?
        @ if (pWnd->m_hWnd != NULL) {
        @     pWnd->ModifyStyleEx ((@<是否透明> ? 0 : WS_EX_TRANSPARENT), (@<是否透明> ? WS_EX_TRANSPARENT : 0));
        @     pWnd->RedrawContainer  ();
        @ }
        @ #endif
    }

    # 提示框相关属性 --

    方法 提示框弹出时间 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "显示提示框前的等待时间(此时鼠标必须在该子组件内保持静止状态).">
    参数 延迟时间 <类型 = 整数 注释 = "设置具体延迟时间,单位毫秒.">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetDelayTime (TTDT_INITIAL, @<延迟时间>);
    }

    方法 提示框保持时间 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "提示框的显示时间(此时鼠标必须在该子组件内保持静止状态).">
    参数 延迟时间 <类型 = 整数 注释 = "设置具体延迟时间,单位毫秒.">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetDelayTime (TTDT_AUTOPOP, @<延迟时间>);
    }

    方法 提示框切换时间 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "鼠标位置从一个有提示文本的子组件移动到另一个有提示文本的子组件时的提示框切"
            注释 = "换显示延迟时间.">
    参数 延迟时间 <类型 = 整数 注释 = "设置具体延迟时间,单位毫秒.">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetDelayTime (TTDT_RESHOW, @<延迟时间>);
    }

    方法 提示框边空 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "提示框中所显示文本内容的周边空白尺寸.">
    参数 空白尺寸 <类型 = 整数 注释 = "单位像素">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetMargin (_DPISIZE (@<空白尺寸>));
    }

    方法 提示框最大宽度 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "提示框的最大显示宽度."
            注释 = "  注意: 只有设置了本属性值,显示多行或超宽提示文本时才会自动换行.">
    参数 最大宽度 <类型 = 整数 注释 = "单位像素">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetMaxTipWidth (_DPISIZE (@<最大宽度>));
    }

    方法 提示框背景颜色 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "提示框的背景颜色." @值细节类型 = 颜色>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetTipBkColor (@<所欲设置颜色值>);
    }

    方法 提示框文本颜色 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时," 注释 = "提示框中所显示文本内容的颜色." @值细节类型 = 颜色>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TTSetTipTextColor (@<所欲设置颜色值>);
    }

    方法 提示框禁用系统主题 <公开 属性写 注释 = "  设置在显示本组件中子组件的提示文本(由该子组件的\"提示信息\"属性提供)时,提示" 注释 = "框是否禁止使用Windows系统主题. 默认属性值为真."
            注释 = "  注意: 如果将本属性值设置为假,则\"提示框边空\",\"提示框背景颜色\",\"提示框文本颜色\"" 注释 = "属性将失去效果." @视窗.设置时机 = 组件创建前>
    参数 是否禁用 <类型 = 逻辑型>
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->m_blDisableToolTipCtrlWinTheme = @<是否禁用>;
    }

    # 事件 --

    方法 创建完毕 <公开 定义事件 类型 = 整数 注释 = "当本组件及其中所有子组件均被创建完毕后发送此事件.">

    方法 将被销毁 <公开 定义事件 类型 = 整数 注释 = "当本组件被销毁前发送此事件">

    方法 已被销毁 <公开 定义事件 类型 = 整数 注释 = "  当本组件被最终销毁时发送此事件." 注释 = "  本事件为窗口组件所接收到的最后一个事件,在接收到本事件时,本窗口组件所对应的窗"
            注释 = "口句柄已经被关闭,因此在接收到本事件后不要对组件进行任何窗口句柄相关的操作." 注释 = "  可以在本事件中对本组件的相关数据进行最终清理."
            注释 = "  注意: 如果本窗口组件不为自然销毁(因为自身或自身的父窗口被用户关闭)而是因为本" 注释 = "窗口组件对象被释放而被动销毁,将不会接收到此事件.">

    方法 位置被改变 <公开 定义事件 类型 = 整数 注释 = "当本组件的位置被改变后发送此事件">

    方法 尺寸被改变 <公开 定义事件 类型 = 整数 注释 = "当本组件的尺寸被改变后发送此事件">

    方法 被显示 <公开 定义事件 类型 = 整数 注释 = "当本组件被显示后发送此事件">

    方法 被隐藏 <公开 定义事件 类型 = 整数 注释 = "当本组件被隐藏后发送此事件">

    方法 接收到子组件命令 <公开 定义事件 类型 = 整数 注释 = "当本组件布局器上的子组件,譬如按钮被单击或者对应快捷键被按下时,发送此事件." 返回值注释 = "所通知的对应命令被处理返回1,否则返回0."
            返回值注释 = "注意: 如果本处的事件处理方法返回1,则所处窗口将不会再接收到\"接收到命令\"事件.">
    参数 命令代码 <类型 = 整数 注释 = " 提供命令所对应的子组件ID值">

    # --

    方法 重画布局器 <公开 注释 = "  如果需要重画本组件,不要调用基础类中的\"重画\"方法,而需要调用本方法," 注释 = "这样才能保证在\"透明\"属性被设置为真时正常刷新本组件的显示." @嵌入式方法 = "">
    {
        @ ((CVWnd_Container*)@sn<this>.GetMfcWndPtr ())->RedrawContainer ()
    }

    方法 取底图 <公开 类型 = 逻辑型 注释 = "取回本组件上通过\"底图\"属性所置入的图片数据" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 所取回图片 <类型 = 位图对象类 注释 = "组件上通过\"底图\"属性所置入的图片数据将被填入到此对象中">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "所取得图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如"
            注释 = "果大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "所取得图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如"
            注释 = "果大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ @<所取回图片.置位图句柄值> ((INT_P)((CVWnd_Container*)@sn<this>.GetMfcWndPtr ())->CloneBackBitmap (@<输出宽度>, @<输出高度>), TRUE)
    }

    方法 置底图文件 <公开 注释 = "设置显示在本组件背景上的位图文件">
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TakeOverBackBitmap ((HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置底图数据 <公开 注释 = "设置显示在本组件背景上的位图文件数据">
    参数 所欲设置的位图文件数据 <类型 = 字节集类>
    {
        @ ((CVWnd_Container*)GetMfcWndPtr ())->TakeOverBackBitmap (g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图文件数据>));
    }

    # --
    #
    # @begin
    # <> <include>
    #
    # // 用作实现 IContainerEventListener 事件监听接口
    # virtual void OnCreate () override  {  @an<OnWinContainerCreated> ();  @<创建完毕> ();  }
    # virtual void OnDestroy () override  {  @<将被销毁> ();  }
    # virtual void OnPostNcDestroy () override  {  @<已被销毁> ();  }
    # virtual void OnSize () override  {  @<尺寸被改变> ();  }
    # virtual void OnShow (BOOL_P blpShown) override  {  if (blpShown)  @<被显示> ();  else  @<被隐藏> ();  }
    # virtual void OnMove () override  {  @<位置被改变> ();  }
    # virtual BOOL OnCommand (const INT nCommandID) override  { return (@<接收到子组件命令> (nCommandID) != 0); }
    #
    # virtual void OnBeforeNativeWndCreate (CVolNativeWndCreateParam* pCreateParam) override
    # {
    #     BaseClass::OnBeforeNativeWndCreate (pCreateParam);
    #
    #     //   由于必须接收窗口被创建事件以调用 @an<OnWinContainerCreated> 创建被设计内容,
    #     // 而事件只有当用户程序定义了该事件的接收方法时才会挂接,因此此处强制挂接事件.
    #     AttachEventListenerIfNone ();
    # }
    #
    # <> </include>
    # @end
}

# ===

类 窗口边框类型 <公开 注释 = "提供窗口的各种边框类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无边框 <公开 值 = 0>
    常量 普通可调边框 <公开 值 = 1>
    常量 普通固定边框 <公开 值 = 2>
    常量 窄标题可调边框 <公开 值 = 3>
    常量 窄标题固定边框 <公开 值 = 4>
    常量 镜框式可调边框 <公开 值 = 5>
    常量 镜框式固定边框 <公开 值 = 6>
}

类 窗口位置类型 <公开 注释 = "提供窗口的各种当前位置状态" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 通常 <公开 值 = 0>
    常量 居中 <公开 值 = 1>
    常量 最小化 <公开 值 = 2>
    常量 最大化 <公开 值 = 3>
}

类 窗口外形类型 <公开 注释 = "提供窗口的各种常用外形" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 矩形 <公开 值 = 0 注释 = "正常的窗口外形">
    常量 椭圆 <公开 值 = 1>
    常量 圆角矩形 <公开 值 = 2>
}

类 窗口位置限制信息 <公开 注释 = "提供窗口的位置限制信息,成员单位均为像素." @文档 = "category = \"辅助类\"">
{
    变量 最大尺寸 <公开 类型 = 尺寸类 注释 = "指定窗口所允许的最大宽度和高度">
    变量 最大位置 <公开 类型 = 位置类 注释 = "指定窗口最大化时的左边和顶边位置">
    变量 最小调节尺寸 <公开 类型 = 尺寸类 注释 = "指定当拖动边框调节窗口尺寸时所允许的最小窗口尺寸">
    变量 最大调节尺寸 <公开 类型 = 尺寸类 注释 = "指定当拖动边框调节窗口尺寸时所允许的最大窗口尺寸">

    # @begin
    # <> <include>
    # inline_ @sn<current_class> (const MINMAXINFO* lpMMI) : @sn<current_class> ()  { Copy (lpMMI); }
    # void Copy (const MINMAXINFO* lpMMI);
    # void Out (MINMAXINFO* lpMMI) const;
    # <> </include>
    #
    # void @sn<current_class>::Copy (const MINMAXINFO* lpMMI)
    # {
    #     @<最大尺寸>.Copy ((const SIZE*)&lpMMI->ptMaxSize);
    #     @<最大位置>.Copy (&lpMMI->ptMaxPosition);
    #     @<最小调节尺寸>.Copy ((const SIZE*)&lpMMI->ptMinTrackSize);
    #     @<最大调节尺寸>.Copy ((const SIZE*)&lpMMI->ptMaxTrackSize);
    # }
    #
    # void @sn<current_class>::Out (MINMAXINFO* lpMMI) const
    # {
    #     @<最大尺寸>.Out ((SIZE*)&lpMMI->ptMaxSize);
    #     @<最大位置>.Out (&lpMMI->ptMaxPosition);
    #     @<最小调节尺寸>.Out ((SIZE*)&lpMMI->ptMinTrackSize);
    #     @<最大调节尺寸>.Out ((SIZE*)&lpMMI->ptMaxTrackSize);
    # }
    # @end
}

类 窗口 <公开 基础类 = 组件布局器 注释 = "提供一个顶层窗口类组件" 编辑时信息 = "1F3FE0, 0, 0, 0" @输出名 = "@CVolWinForm"
        @视窗.后缀文本 = "public IWinFormEventListener" @视窗.窗口组件 = "icon=\"@10\""
        @可插入程序类 = "icon=\"res\\win_form.bmp\"\r\nexplain=\"在所插入新窗口类上单击鼠标右键,选择\\\"设计xxx的界面布局\\\"菜单项即可可视化设计该窗口的界面内容.\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_WinForm, IWinFormEventListener, 0, 0, 0, 0)
    #
    # 事件 --

    方法 接收到命令 <公开 定义事件 类型 = 整数 注释 = "当本窗口上的菜单项(包括弹出子菜单)/工具条按钮被单击或者对应快捷键被按下时,发送此事件." 返回值注释 = "所通知的对应命令被处理返回1,否则返回0.">
    参数 命令代码 <类型 = 整数 注释 = "  提供所对应命令的ID值,对于菜单项或其快捷键来说,就是对应菜单项设计时提供的引用常量ID值," 注释 = "对于工具条来说,就是对应按钮设计时提供的引用常量ID值.">

    方法 命令被选中 <公开 定义事件 类型 = 整数 注释 = "  当本窗口上的菜单项(包括弹出子菜单)/工具条按钮处于被选中状态(鼠标移动到" 注释 = "其上方)时,发送此事件."
            注释 = "  可以在接收到此事件后进行譬如显示对应提示文本之类的操作.">
    参数 命令代码 <类型 = 整数 注释 = "  提供所对应命令的ID值,对于菜单项来说,就是对应菜单项设计时提供的引用常量" 注释 = "ID值,对于工具条来说,就是对应按钮设计时提供的引用常量ID值."
            注释 = "  注意: 当所弹出菜单被关闭或用户鼠标移动到一个非程序命令菜单项(如下级子菜" 注释 = "单进入项/分隔线菜单项/系统菜单项)时,将接收到一个本参数值为0的事件,用户可"
            注释 = "以在接收到此事件时进行一些清理工作(譬如清除掉当前所显示的提示文本).">

    方法 可否被关闭 <公开 定义事件 类型 = 整数 注释 = "在本窗口及计算机被关闭之前发送此事件,用于询问该关闭操作是否允许被继续." 注释 = "本事件包括了\"窗口可否被关闭\"通知,但是相对其多了在计算机被关闭之前的通知."
            返回值注释 = "返回1不允许关闭,返回0允许关闭.">

    方法 窗口可否被关闭 <公开 定义事件 类型 = 整数 注释 = "在本窗口被关闭之前发送此事件,用于询问该关闭操作是否允许被继续." 注释 = "本事件不包括在计算机被关闭之前的通知." 返回值注释 = "返回1不允许关闭,返回0允许关闭.">

    方法 首次激活 <公开 定义事件 类型 = 整数 注释 = "当窗口创建完毕后被首次激活显示时发送此事件,在接收到此事件后用户可以开始在窗口内的画板组件上写出内容.">

    方法 被激活 <公开 定义事件 类型 = 整数 注释 = "当窗口转换为激活状态时发送此事件">

    方法 被取消激活 <公开 定义事件 类型 = 整数 注释 = "当窗口转换为非激活状态时发送此事件">

    方法 托盘事件 <公开 定义事件 类型 = 整数 注释 = "当用户用鼠标单击或双击本窗口对象的\"置托盘图标\"方法所设置的图标后即发送此事件">
    参数 操作类型 <类型 = 整数 注释 = "提供用户的具体操作类型,可能为的值为: 1.单击左键; 2.双击左键; 3.单击右键">

    方法 位置限制 <公开 定义事件 类型 = 整数 注释 = "用户可以在处理本事件时修改所提供的参数信息,以限定本窗口的对应尺寸或位置." 返回值注释 = "返回1表示已经处理,返回0表示未处理.">
    参数 位置限制信息 <类型 = 窗口位置限制信息 注释 = "用户可以在处理本事件时修改本参数的内容,以指定其中的某些位置限制参数.">

    方法 对话框已初始化 <公开 定义事件 类型 = 整数 注释 = "当以对话框方式创建本窗口时,对话框创建完毕后将发送本事件." 注释 = "用户可以在处理本事件时初始化窗口中的内容.">

    # 虚拟方法 --

    方法 消息过滤 <公开 类型 = 逻辑型 注释 = "用户的窗口类可以覆盖此方法以过滤处理本窗口及其所有子组件中的消息(仅限键盘/鼠标输入类信息)" 返回值注释 = "返回真表示允许消息继续向后传递并处理,返回假表示取消掉该消息的后续处理."
            @虚拟方法 = 可覆盖>
    参数 窗口句柄 <类型 = 变整数 注释 = "提供消息所对应的窗口句柄(HWND),必定为本窗口或其直接/间接下属子窗口.">
    参数 消息值 <类型 = 整数 注释 = "提供消息的具体值">
    参数 消息参数1 <类型 = 变整数 注释 = "提供消息所附带的参数1的值">
    参数 消息参数2 <类型 = 变整数 注释 = "提供消息所附带的参数2的值">
    参数 消息地址 <类型 = 变整数 注释 = "提供消息的具体 MSG* 地址指针,用作备用.">
    {
        返回 (真)
    }

