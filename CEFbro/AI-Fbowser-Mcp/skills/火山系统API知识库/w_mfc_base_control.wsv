类 日期框附件类型 <公开 注释 = "提供日期框的各种附件类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 下拉月历 <公开 值 = 0>
    常量 调节器 <公开 值 = 1>
}

类 日期框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IDatePickerEventListener" @视窗.窗口组件 = "icon=\"@65\"\r\ndefault_size = \"120, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_DatePicker, IDatePickerEventListener, 0, 0, DTS_LONGDATEFORMAT, 0)
    #
    # 事件 ---

    方法 选择日期被改变 <公开 定义事件 类型 = 整数 注释 = "当现行被选择的日期被改变后发送此事件">

    # 属性 ---

    方法 允许编辑 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许对日期框中的内容进行编辑" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & DTS_APPCANPARSE) != 0
    }

    方法 允许编辑 <公开 属性写 注释 = "设置是否允许对日期框中的内容进行编辑" @视窗.设置时机 = 组件创建前>
    参数 是否允许编辑 <类型 = 逻辑型>
    {
        如果 (是否允许编辑)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= DTS_APPCANPARSE;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~DTS_APPCANPARSE;
        }
    }

    方法 附件类型 <公开 属性读 类型 = 日期框附件类型 注释 = "返回日期框的附件类型" @嵌入式方法 = "">
    {
        @ ((@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & DTS_UPDOWN) != 0 ? 1 : 0)
    }

    方法 附件类型 <公开 属性写 注释 = "设置日期框的附件类型" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的附件类型 <类型 = 日期框附件类型>
    {
        如果 (所欲设置的附件类型 == 日期框附件类型.调节器)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= DTS_UPDOWN;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~DTS_UPDOWN;
        }
    }

    方法 今天 <公开 属性读 类型 = 小数 注释 = "返回日期框中的现行时间,如果为0表示为当前系统时间." @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CVWnd_DatePicker* pWnd = (CVWnd_DatePicker*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     COleDateTime time;
        @     pWnd->GetTime (time);
        @     return (DATE)time;
        @ }
        @ return pWnd->m_dbCurrentDate;
    }

    方法 今天 <公开 属性写 注释 = "设置日期框中的现行时间" @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的时间,如果为0,则设置为当前系统时间.">
    {
        @ CVWnd_DatePicker* pWnd = (CVWnd_DatePicker*)GetMfcWndPtr ();
        @ pWnd->m_dbCurrentDate = @<所欲设置的时间>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetTime (IsDoubleEqualZero (pWnd->m_dbCurrentDate) ? COleDateTime::GetCurrentTime () : COleDateTime (pWnd->m_dbCurrentDate));
    }

    方法 最小日期 <公开 属性读 类型 = 小数 注释 = "返回日期框所能显示的最小时间,如果为0,则无限制." @设计时隐藏 = 真 @嵌入式方法 = "">
    {
        @ ((CVWnd_DatePicker*)@sn<this>.GetMfcWndPtr ())->m_dbMinDate
    }

    方法 最小日期 <公开 属性写 注释 = "设置日期框所能显示的最小时间" @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的最小时间,如果为0,则无限制.">
    {
        @ CVWnd_DatePicker* pWnd = (CVWnd_DatePicker*)GetMfcWndPtr ();
        @ pWnd->m_dbMinDate = @<所欲设置的时间>;
        @ pWnd->UpdateRange ();
    }

    方法 最大日期 <公开 属性读 类型 = 小数 注释 = "返回日期框所能显示的最大时间,如果为0,则无限制." @设计时隐藏 = 真 @嵌入式方法 = "">
    {
        @ ((CVWnd_DatePicker*)@sn<this>.GetMfcWndPtr ())->m_dbMaxDate
    }

    方法 最大日期 <公开 属性写 注释 = "设置日期框所能显示的最大时间" @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的最大时间,如果为0,则无限制.">
    {
        @ CVWnd_DatePicker* pWnd = (CVWnd_DatePicker*)GetMfcWndPtr ();
        @ pWnd->m_dbMaxDate = @<所欲设置的时间>;
        @ pWnd->UpdateRange ();
    }

    # 方法 ---

    方法 置日期范围 <公开 注释 = "设置日期框所能显示的最小和最大时间">
    参数 所允许的最小时间 <类型 = 小数 注释 = "提供日期框所能显示的最小时间,如果为0,则无限制.">
    参数 所允许的最大时间 <类型 = 小数 注释 = "提供日期框所能显示的最大时间,如果为0,则无限制.">
    {
        @ CVWnd_DatePicker* pWnd = (CVWnd_DatePicker*)GetMfcWndPtr ();
        @ pWnd->m_dbMinDate = @<所允许的最小时间>;
        @ pWnd->m_dbMaxDate = @<所允许的最大时间>;
        @ pWnd->UpdateRange ();
    }

    # ---
    #
    # @ <include>
    # @ virtual void OnDateChanged () override  {  @<选择日期被改变> ();  }
    # @ </include>
}

# ===

类 月历 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IMonthCalEventListener" @视窗.窗口组件 = "icon=\"@66\"\r\ndefault_size = \"280, 200\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_MonthCal, IMonthCalEventListener, 0, 0, 0, 0)
    #
    # 事件 ---

    方法 选择日期被改变 <公开 定义事件 类型 = 整数 注释 = "  当现行被选择的日期被改变后发送此事件,在事件处理方法中可以" 注释 = "通过读取\"首选择日\"和\"尾选择日\"属性获得现行被选择的日期.">

    # 属性 ---

    方法 不显示今天 <公开 属性读 类型 = 逻辑型 注释 = "返回是否不显示今天" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & MCS_NOTODAY) != 0
    }

    方法 不显示今天 <公开 属性写 注释 = "设置是否不显示今天" @视窗.设置时机 = 组件创建前>
    参数 是否不显示今天 <类型 = 逻辑型>
    {
        如果 (是否不显示今天)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= MCS_NOTODAY;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~MCS_NOTODAY;
        }
    }

    方法 不圈注今天 <公开 属性读 类型 = 逻辑型 注释 = "返回是否不圈注今天" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & MCS_NOTODAYCIRCLE) != 0
    }

    方法 不圈注今天 <公开 属性写 注释 = "设置是否不圈注今天" @视窗.设置时机 = 组件创建前>
    参数 是否不圈注今天 <类型 = 逻辑型>
    {
        如果 (是否不圈注今天)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= MCS_NOTODAYCIRCLE;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~MCS_NOTODAYCIRCLE;
        }
    }

    方法 开始星期首日 <公开 属性读 类型 = 星期类 注释 = "返回星期几为每个星期的第一日" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_npFirstDayOfWeek
    }

    方法 开始星期首日 <公开 属性写 注释 = "设置星期几为每个星期的第一日" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的星期首日 <类型 = 星期类>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_npFirstDayOfWeek = CLIP (@<所欲设置的星期首日>, 0, 6);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetFirstDayOfWeek ((INT)pWnd->m_npFirstDayOfWeek);
    }

    方法 显示星期序号 <公开 属性读 类型 = 逻辑型 注释 = "返回是否显示星期序号" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & MCS_WEEKNUMBERS) != 0
    }

    方法 显示星期序号 <公开 属性写 注释 = "设置是否显示星期序号" @视窗.设置时机 = 组件创建前>
    参数 是否显示星期序号 <类型 = 逻辑型>
    {
        如果 (是否显示星期序号)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= MCS_WEEKNUMBERS;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~MCS_WEEKNUMBERS;
        }
    }

    方法 允许选择多天 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许选择多天" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & MCS_MULTISELECT) != 0
    }

    方法 允许选择多天 <公开 属性写 注释 = "设置是否允许选择多天" @视窗.设置时机 = 组件创建前>
    参数 是否允许选择多天 <类型 = 逻辑型>
    {
        如果 (是否允许选择多天)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= MCS_MULTISELECT;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~MCS_MULTISELECT;
        }
    }

    方法 滚动月数 <公开 属性读 类型 = 整数 注释 = "返回当按下滚动按钮改变当前显示月时,一次跳过的月的数目." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_npMonthDelta
    }

    方法 滚动月数 <公开 属性写 注释 = "设置当按下滚动按钮改变当前显示月时,一次跳过的月的数目." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的滚动月数 <类型 = 整数>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_npMonthDelta = CLIP (@<所欲设置的滚动月数>, 0, 1200);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetMonthDelta ((INT)pWnd->m_npMonthDelta);
    }

    方法 今天 <公开 属性读 类型 = 小数 注释 = "返回月历中的现行时间,如果为0表示为当前系统时间." 注释 = "注意: 本属性仅当在\"允许选择多天\"属性为假时才能读取." @禁止流程检查 = 真 @设计时隐藏 = 真>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd != NULL && (pWnd->GetStyle () & MCS_MULTISELECT) == 0)
        @ {
        @     COleDateTime time;
        @     pWnd->GetToday (time);
        @     return (DATE)time;
        @ }
        @ return pWnd->m_dbCurrentDate;
    }

    方法 今天 <公开 属性写 注释 = "设置月历中的现行时间." @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的时间,如果为0,则设置为当前系统时间.">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_dbCurrentDate = @<所欲设置的时间>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetToday (IsDoubleEqualZero (pWnd->m_dbCurrentDate) ? COleDateTime::GetCurrentTime () : COleDateTime (pWnd->m_dbCurrentDate));
    }

    方法 最小日期 <公开 属性读 类型 = 小数 注释 = "返回月历所能显示的最小时间,如果为0,则无限制." @设计时隐藏 = 真 @嵌入式方法 = "">
    {
        @ ((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_dbMinDate
    }

    方法 最小日期 <公开 属性写 注释 = "设置月历所能显示的最小时间" @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的最小时间,如果为0,则无限制.">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_dbMinDate = @<所欲设置的时间>;
        @ pWnd->UpdateDateRange ();
    }

    方法 最大日期 <公开 属性读 类型 = 小数 注释 = "返回月历所能显示的最大时间,如果为0,则无限制." @设计时隐藏 = 真 @嵌入式方法 = "">
    {
        @ ((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_dbMaxDate
    }

    方法 最大日期 <公开 属性写 注释 = "设置月历所能显示的最大时间" @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的时间 <类型 = 小数 注释 = "提供所欲设置的最大时间,如果为0,则无限制.">
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_dbMaxDate = @<所欲设置的时间>;
        @ pWnd->UpdateDateRange ();
    }

    方法 最多选择天数 <公开 属性读 类型 = 整数 注释 = "返回最多允许选择的天数" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_MonthCal*)@sn<this>.GetMfcWndPtr ())->m_npMaxSelDayCount
    }

    方法 最多选择天数 <公开 属性写 注释 = "设置最多允许选择的天数" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的最多选择天数 <类型 = 整数>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_npMaxSelDayCount = MAX (1, @<所欲设置的最多选择天数>);
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetMaxSelCount ((INT)pWnd->m_npMaxSelDayCount);
        @     pWnd->UpdateSelRange ();
        @ }
    }

    方法 首选择日 <公开 属性读 类型 = 小数 注释 = "返回现行被选择区域的首日期" @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return pWnd->m_dtBeginSel;
        @ COleDateTime time, timeMax;
        @ if ((pWnd->GetStyle () & MCS_MULTISELECT) == 0)  // 不允许选择多天?
        @     pWnd->GetCurSel (time);
        @ else
        @     pWnd->GetSelRange (time, timeMax);
        @ return (DATE)time;
    }

    方法 首选择日 <公开 属性写 注释 = "  设置现行被选择区域的首日期.如果不允许选择多天(由\"允许选择多天\"属性指定)," 注释 = "则本属性设置现行被选择的日期." @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的首选择日 <类型 = 小数>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ pWnd->m_dtBeginSel =  @<所欲设置的首选择日>;
        @ pWnd->UpdateSelRange ();
    }

    方法 尾选择日 <公开 属性读 类型 = 小数 注释 = "返回现行被选择区域的尾日期" @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CVWnd_MonthCal* pWnd = (CVWnd_MonthCal*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return pWnd->m_dtEndSel;
        @ COleDateTime time, timeMin;
        @ if ((pWnd->GetStyle () & MCS_MULTISELECT) == 0)  // 不允许选择多天?
        @     pWnd->GetCurSel (time);
        @ else
        @     pWnd->GetSelRange (timeMin, time);
        @ return (DATE)time;
    }

    方法 尾选择日 <公开 属性写 注释 = "  设置现行被选择区域的尾日期.如果不允许选择多天(由\"允许选择多天\"属性指定)," 注释 = "则本属性设置现行被选择的日期." @设计时隐藏 = 真 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的尾选择日 <类型 = 小数>
    {
