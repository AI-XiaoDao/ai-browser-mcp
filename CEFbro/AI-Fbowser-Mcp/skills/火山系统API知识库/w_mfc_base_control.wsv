    方法 打印区尺寸 <公开 属性读 类型 = 尺寸类 注释 = "  本属性提供了打印纸实际可打印区域的尺寸,其中宽度值减去左右边空," 注释 = "高度值减去上下边空,使用现行绘画单位."
            注释 = "  本属性仅在打印作业过程中有效,如果当前没有进行打印,将返回0尺寸." @禁止流程检查 = 真>
    {
        @ return @dt<尺寸类> (&data ().GetPrintingPageSize ());
    }

    # 下列属性如果开始打印时显示了打印设置对话框将被改写 --

    方法 打印份数 <公开 属性读 类型 = 整数 注释 = "  如果已经开始打印且开始打印时显示了打印设置对话框,则返回用户在打印" 注释 = "设置对话框内打印份数编辑框中输入的值,否则返回先前所设置的初始值." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().m_npCopies
    }

    方法 打印份数 <公开 属性写 注释 = "  本属性用作为打印设置对话框中的打印份数编辑框提供初始值,当用户从打印设置对话" 注释 = "框中确认返回后,属性值提供用户所实际输入的需要打印份数.如果开始打印时没有显示打"
            注释 = "印设置对话框,本属性值保持先前所设置的初始值不变." 注释 = "  需了解的是: 如果被选定打印机硬件支持多份拷贝功能,无论用户设置打印份数为多少,"
            注释 = "打印设置对话框永远返回1,多份打印被转交给打印机硬件去自动完成.如果在进入打印设" 注释 = "置对话框前置属性值为-1,表明现行程序不支持多份打印,此时类库会自动检查当前所选择"
            注释 = "打印机硬件,如果该打印机硬件支持多份拷贝,将允许用户指定打印份数并启用硬件多份拷" 注释 = "贝功能,否则不允许.">
    参数 所欲打印份数 <类型 = 整数 注释 = "必须大于等于-1,具体解释参见属性说明.">
    {
        @ data ().m_npCopies = CLIP (@<所欲打印份数>, -1, 32627);
    }

    方法 多份打印方式 <公开 属性读 类型 = 逻辑型 注释 = "  如果已经开始打印且开始打印时显示了打印设置对话框,则返回用户在打印设置对话框内" 注释 = "\"份数\"组中的\"分页\"选择框上的选中状态值,否则返回先前所设置的初始值."
            @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().m_blpCollate
    }

    方法 多份打印方式 <公开 属性写 注释 = "  本属性用作为打印设置对话框中\"份数\"组中的\"分页\"选择框提供初始值,当用户从" 注释 = "打印设置对话框中确认返回后,属性值提供用户所实际输入的值.如果开始打印时没"
            注释 = "有显示打印设置对话框,本属性值保持先前所设置的初始值不变.">
    参数 是否多份打印 <类型 = 逻辑型>
    {
        @ data ().m_blpCollate = @<是否多份打印>;
    }

    方法 首页页号 <公开 属性读 类型 = 整数 注释 = "  如果已经开始打印且开始打印时显示了打印设置对话框,则返回用户在打印设置对话框" 注释 = "内首打印页页号编辑框中输入的值,如果用户未选择在指定页号范围内打印,将返回-1."
            注释 = "  如果尚未开始打印或开始打印时没有显示打印设置对话框,将返回先前所设置的初始值." 注释 = "  从打印设置对话框中确认返回后,通过判断本属性值是否不为-1即可得知当前是否被限" 注释 = "定在指定页号范围内打印."
            @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().m_npFromPage
    }

    方法 首页页号 <公开 属性写 注释 = "  本属性用作为打印设置对话框中的首打印页页号编辑框提供初始值." 注释 = "  当用户从打印设置对话框中确认返回且用户选择在指定页号范围内打印时,属性值提供用户"
            注释 = "所实际输入的首打印页号,如果用户未选择在指定页号范围内打印,属性值将填入-1." 注释 = "  从打印设置对话框中确认返回后,通过判断本属性值是否不为-1即可得知当前是否被限定在" 注释 = "指定页号范围内打印."
            注释 = "  如果使用\"开始打印\"方法进入打印时没有显示打印设置对话框,本属性保持其所初始设置的" 注释 = "值不变.">
    参数 所欲设置的页号 <类型 = 整数>
    {
        @ data ().m_npFromPage = CLIP (@<所欲设置的页号>, 1, 32627);
    }

    方法 末页页号 <公开 属性读 类型 = 整数 注释 = "  如果已经开始打印且开始打印时显示了打印设置对话框,则返回用户在打印设置对话框" 注释 = "内末打印页页号编辑框中输入的值,如果用户未选择在指定页号范围内打印,将返回-1."
            注释 = "  如果尚未开始打印或开始打印时没有显示打印设置对话框,将返回先前所设置的初始值." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().m_npToPage
    }

    方法 末页页号 <公开 属性写 注释 = "  本属性用作为打印设置对话框中的末打印页页号编辑框提供初始值,如果为-1表示未提供初始值." 注释 = "  当用户从打印设置对话框中确认返回且用户选择在指定页号范围内打印时,属性值提供用户所实际输"
            注释 = "入的末打印页号,如果用户未选择在指定页号范围内打印,属性值将填入-1." 注释 = "  如果使用\"开始打印\"方法进入打印时没有显示打印设置对话框,本属性保持其所初始设置的值不变.">
    参数 所欲设置的页号 <类型 = 整数>
    {
        @ data ().m_npToPage = CLIP (@<所欲设置的页号>, -1, 32627);
    }

    方法 打印选择区 <公开 属性读 类型 = 整数 注释 = "  如果已经开始打印且开始打印时显示了打印设置对话框,则返回用户在打印设置对话框内" 注释 = "\"选择的范围\"选择框上的选中状态值(1或0),否则返回先前所设置的初始值."
            注释 = "  从打印设置对话框中确认返回后,通过判断本属性值是否为1即可得知当前是否限定仅打印" 注释 = "选择区域内容." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().m_npPrintSelection
    }

    方法 打印选择区 <公开 属性写 注释 = "  本属性用作为打印设置对话框中\"选择的范围\"选择框提供初始值,为1表示真,为0表示假." 注释 = "当用户从打印设置对话框中确认返回后,属性值提供用户所实际设置的值(1或0).如果在进"
            注释 = "入打印设置对话框前置属性值为-1,打印设置对话框中将不允许用户选取该选择框." 注释 = "  从打印设置对话框中确认返回后,通过判断本属性值是否为1即可得知当前是否限定仅打" 注释 = "印选择区域内容."
            注释 = "  如果使用\"开始打印\"方法进入打印时没有显示打印设置对话框,本属性保持其所初始设置" 注释 = "的值不变.">
    参数 所欲设置的打印选择区 <类型 = 整数>
    {
        @ data ().m_npPrintSelection = CLIP (@<所欲设置的打印选择区>, -1, 1);
    }

    # 方法 --

    方法 是否全部打印 <公开 类型 = 逻辑型 注释 = "  如果成功开始打印且调用\"开始打印\"方法时显示了打印设置对话框," 注释 = "则返回用户是否选择了打印全部内容.">
    {
        返回 (首页页号 == -1 && 打印选择区 != 1)
    }

    方法 是否打印选择区 <公开 类型 = 逻辑型 注释 = "  如果成功开始打印且调用\"开始打印\"方法时显示了打印设置对话框," 注释 = "则返回用户是否选择了打印当前所选择区域内容.">
    {
        返回 (打印选择区 == 1)
    }

    方法 是否打印页范围 <公开 类型 = 逻辑型 注释 = "  如果成功开始打印且调用\"开始打印\"方法时显示了打印设置对话框," 注释 = "则返回用户是否选择了打印所指定页范围中的内容."
            注释 = "  具体页范围可以通过读取\"首页页号\"和\"末页页号\"属性值获得.">
    {
        返回 (首页页号 != -1)
    }

    方法 取设备句柄 <公开 类型 = 变整数 注释 = "如当前用户程序正在进行打印作业,则返回打印机所对应的设备句柄(即HDC),否则返回0." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().m_dcPrint.m_hDC
    }

    方法 开始打印 <公开 类型 = 逻辑型 注释 = "  开始进入打印作业,返回真表示已经成功进入,否则表示失败," 注释 = "  进入打印作业后文本写出位置将被重置为0.如果执行本命令时已经在打"
            注释 = "印作业中或者用户在打印设置对话框中选择了取消,返回假." 注释 = "  进入打印后必须调用\"结束打印\"或者\"取消打印\"方法来退出打印." 注释 = "  进入打印前程序进行的所有打印绘画操作都将被忽略."
            @禁止流程检查 = 真>
    参数 父窗口组件 <类型 = 窗口组件 注释 = "如果显示打印设置对话框,本参数用作提供该对话框的父窗口组件.">
    参数 是否显示打印设置对话框 <类型 = 逻辑型 注释 = "  指定在进入打印之前是否先显示打印设置对话框对打印机及相关打印" 注释 = "参数进行设置."
            注释 = "  如果参数值为假,将自动使用Windows系统默认打印机,但如果取Windows" 注释 = "系统默认打印机失败,仍然会显示打印设置对话框." @默认值 = 真>
    参数 纸张类型 <类型 = 打印机纸张类型 注释 = "  指定所使用的打印纸类型. 如果打印纸类型为\"自定义纸张\",则必须在" 注释 = "后续参数中明确指定纸张的尺寸."
            注释 = "  注意如果所选择纸张得不到打印机的支持,打印机将会自动选择尺寸最" 注释 = "接近的纸张." @默认值 = 打印机纸张类型.默认纸>
    参数 纸张方向 <类型 = 打印机纸张方向 注释 = "指定打印机纸张的具体放置方向" @默认值 = 打印机纸张方向.纵向>
    参数 自定义纸张宽度 <类型 = 整数 注释 = "  指定自定义纸张的宽度,单位为0.1毫米. 只有当前面的\"纸张\"参数值为" 注释 = "\"打印机纸张类型.自定义纸张\"时,本参数才有作用且必须提供具体值." @默认值 = 0>
    参数 自定义纸张高度 <类型 = 整数 注释 = "  指定自定义纸张的高度,单位为0.1毫米. 只有当前面的\"纸张\"参数值为" 注释 = "\"打印机纸张类型.自定义纸张\"时,本参数才有作用且必须提供具体值." @默认值 = 0>
    {
        @ return (BOOL)data ().StartPrint (@<父窗口组件>.GetMfcWndPtrWithValidHWnd (), @<是否显示打印设置对话框>, @<纸张类型>, @<纸张方向>, @<自定义纸张宽度>, @<自定义纸张高度>, this);
    }

    方法 结束打印 <公开 注释 = "如果当前已经进入了打印作业,调用本命令可完成此作业." 注释 = "结束打印后程序进行的后续打印绘画操作都将被忽略." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().EndPrint (FALSE)
    }

    方法 取消打印 <公开 注释 = "  如果当前已经进入了打印作业,调用本命令可立即中止且取消该作业." 注释 = "如果操作系统的打印管理器正在处理该打印作业(打印管理器正在运行"
            注释 = "并且允许后台打印),那么该作业将被删除且使打印机不接收任何信息." 注释 = "如果打印管理器未正在处理该作业(没有选用后台打印),部分或全部数" 注释 = "据可能在此之前已发送到打印机.此时,打印机驱动程序将尽可能使打印"
            注释 = "机立即复位并终止该作业." 注释 = "  取消打印后易程序进行的后续打印绘画操作都将被忽略." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().EndPrint (TRUE)
    }

    方法 换页 <公开 类型 = 逻辑型 注释 = "调用本命令使打印机完成当前页的打印,文本写出位置被重置为0,并走纸到下一页左上角." 注释 = "换页成功返回真,否则将自动取消打印并返回假." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().ToNextPage ()
    }

    方法 开始下一份 <公开 类型 = 逻辑型 注释 = "  调用本命令后将结束在当前页上的打印作业,并将当前打印份数加一," 注释 = "当前页号置回到首页页号,以进入下一份拷贝的打印."
            注释 = "  成功返回真,失败将自动取消打印并返回假." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().ToNextCopy ()
    }

    方法 画点 <公开 注释 = "在打印设备上指定位置绘制一个点" @嵌入式方法 = "">
    参数 点横坐标 <类型 = 整数>
    参数 点纵坐标 <类型 = 整数>
    参数 欲画入点的颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ @sn<this>.data ().SetPixel (@<点横坐标>, @<点纵坐标>, (COLORREF)@<欲画入点的颜色值>)
    }

    方法 画直线 <公开 注释 = "使用当前画笔在打印设备上画一条直线" @嵌入式方法 = "">
    参数 起始点横坐标 <类型 = 整数>
    参数 起始点纵坐标 <类型 = 整数>
    参数 结束点横坐标 <类型 = 整数>
    参数 结束点纵坐标 <类型 = 整数>
    {
        @ @sn<this>.data ().DrawLine (@<起始点横坐标>, @<起始点纵坐标>, @<结束点横坐标>, @<结束点纵坐标>)
    }

    方法 画椭圆 <公开 注释 = "使用当前画笔在打印设备上画一个椭圆" @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    {
        @ @sn<this>.data ().DrawEllipse (@<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>)
    }

    方法 画弧线 <公开 注释 = "使用当前画笔在打印设备上画一条弧线" @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ @sn<this>.data ().DrawArcChordPie (0, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>)
    }

    方法 画弦 <公开 注释 = "使用当前画笔在打印设备上画一个弦,弦的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "弦的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "弦的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "弦的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "弦的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ @sn<this>.data ().DrawArcChordPie (1, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>)
    }

    方法 画饼 <公开 注释 = "使用当前画笔在打印设备上画一个饼,饼的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 椭圆左上角横坐标 <类型 = 整数>
    参数 椭圆左上角纵坐标 <类型 = 整数>
    参数 椭圆右下角横坐标 <类型 = 整数>
    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "饼的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "饼的弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "饼的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "饼的弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ @sn<this>.data ().DrawArcChordPie (2, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>)
    }

    方法 画矩形 <公开 注释 = "使用当前画笔在打印设备上画一个矩形,矩形的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ @sn<this>.data ().DrawRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>)
    }

    方法 填充矩形 <公开 注释 = "将打印设备上指定的矩形区域用当前刷子填充" @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ @sn<this>.data ().FillRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>)
    }

    方法 画圆角矩形 <公开 注释 = "使用当前画笔在打印设备上画一个圆角矩形,圆角矩形的内部使用当前刷子填充." @嵌入式方法 = "">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    参数 圆角宽度 <类型 = 整数>
    参数 圆角高度 <类型 = 整数 注释 = "参数值如果为-1,则等同于圆角宽度." @默认值 = -1>
    {
        @ @sn<this>.data ().DrawRoundRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>, @<圆角宽度>, @<圆角高度>)
    }

    方法 画多边形 <公开 注释 = "使用当前画笔在打印设备上画一个多边形,多边形的内部使用当前刷子填充." 注释 = "如果该多边形没有闭合,将自动闭合." @嵌入式方法 = "">
    参数 多边形顶点数组 <类型 = 整数数组类 注释 = "本参数数组顺序记录多边形各个顶点的横向及纵向坐标值">
    参数 顶点数目 <类型 = 整数 注释 = "本参数指定多边形顶点的总数目,如果为-1则为数组中记录的所有顶点数目." @默认值 = -1>
    {
        @ @sn<this>.data ().DrawPolygon (@<多边形顶点数组>.data (), @<顶点数目>)
    }

    方法 置写出位置 <公开 注释 = "设置下次使用\"写文本行\"或\"写出\"命令输出数据时的起始位置" @嵌入式方法 = "">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    {
        @ @sn<this>.data ().SetWritePos (@<横向写出位置>, @<纵向写出位置>)
    }

    方法 写文本行 <公开 注释 = "在当前写出位置写出指定的数据,并将现行写出位置调整到下行行首." 注释 = "如果当前打印页已经无法容纳当前行,则将自动换页." @嵌入式方法 = "">
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ @sn<this>.data ().PrintText (0, 0, 0, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 写出 <公开 注释 = "在当前写出位置写出指定的数据,并将现行写出位置调整到所写出数据的结束位置." @嵌入式方法 = "">
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ @sn<this>.data ().PrintText (1, 0, 0, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 定位写出 <公开 注释 = "在所指定位置写出指定的数据,不改变现行写出位置." @嵌入式方法 = "">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数为\"数值范围.最大整数值\",则使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    参数 所欲写出的数据 <@匹配类型 = 通用基本型>
    参数 行间距 <类型 = 整数 注释 = "提供文本行与行之间的纵向间距,单位像素." @默认值 = 2>
    {
        @ @sn<this>.data ().PrintText (2, @<横向写出位置>, @<纵向写出位置>, @an<CVolString> (@<所欲写出的数据>).GetText (), @<行间距>)
    }

    方法 取宽度 <公开 类型 = 整数 注释 = "返回指定数据的写出宽度. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ @sn<this>.data ().GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()).cx
    }

    方法 取高度 <公开 类型 = 整数 注释 = "返回指定数据的写出高度. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ @sn<this>.data ().GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()).cy
    }

    方法 取尺寸 <公开 类型 = 尺寸类 注释 = "返回指定数据的写出尺寸. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 欲获取其绘制尺寸的数据 <@匹配类型 = 通用基本型>
    {
        @ @dt<尺寸类> (&@sn<this>.data ().GetTextDrawSize (@an<CVolString> (@<欲获取其绘制尺寸的数据>).GetText ()))
    }

    方法 画图片 <公开 注释 = "在所指定位置绘制图片" @嵌入式方法 = "">
    参数 所欲绘制的位图 <类型 = 位图对象类 注释 = "提供所欲绘制的位图对象">
    参数 图片左边画出位置 <类型 = 整数>
    参数 图片顶边画出位置 <类型 = 整数>
    参数 图片画出宽度 <类型 = 整数 注释 = "如果本参数为-1,则使用图片本身宽度." @默认值 = -1>
    参数 图片画出高度 <类型 = 整数 注释 = "如果本参数为-1,则使用图片本身高度." @默认值 = -1>
    参数 图片画出方法 <类型 = 整数 注释 = "  本参数定义绘制图片时对图片执行的位操作,可以为\"图像复制方法\"类中的" 注释 = "各个整数常量值,或者其它自定义操作码(请自行查阅相关技术文档)."
            注释 = "  本参数也可以为一个颜色值,用作指定图片中的透明色(即具有此颜色的像素" 注释 = "将不会被绘制),但必须使用其负值. 如: -取颜色 (255, 255, 255) ,此参数"
            注释 = "值即指定在打印设备上画出图片中除白色外的所有颜色." 注释 = "  如果本参数值为\"图像复制方法.拷贝\",则支持对透明/半透明图片(如png)的绘制." @默认值 = 图像复制方法.拷贝>
    {
        @ @sn<this>.data ().DrawPic ((HBITMAP)@<所欲绘制的位图>.GetGDIHandle (), @<图片左边画出位置>, @<图片顶边画出位置>, @<图片画出宽度>, @<图片画出高度>, @<图片画出方法>)
    }

    方法 取图片宽度 <公开 类型 = 整数 注释 = "返回指定图片的宽度. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ @sn<this>.data ().GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()).cx
    }

    方法 取图片高度 <公开 类型 = 整数 注释 = "返回指定图片的高度. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ @sn<this>.data ().GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()).cy
    }

    方法 取图片尺寸 <公开 类型 = 尺寸类 注释 = "返回指定图片的尺寸. 如果调用本方法时尚未进入打印,使用像素点为单位,否则使用当前绘画单位." @嵌入式方法 = "">
    参数 所欲处理的位图 <类型 = 位图对象类 注释 = "提供所欲处理的位图对象">
    {
        @ @dt<尺寸类> (&@sn<this>.data ().GetPicDrawSize ((HBITMAP)@<所欲处理的位图>.GetGDIHandle ()))
    }

    方法 单位转换 <公开 类型 = 整数 注释 = "将像素单位坐标值转换到当前绘画单位,或将当前绘画单位坐标值转换到像素单位." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 欲转换的坐标值 <类型 = 整数 注释 = "提供欲转换的横向或纵向坐标值">
    参数 欲转换坐标值的类型 <类型 = 坐标转换类型 注释 = "  根据所提供的类型值,将进行相反的单位转换,即将绘画单位转换到像素单位,将" 注释 = "像素单位转换到绘画单位.">
    {
        @ (INT)@sn<this>.data ().UnitConvert (@<欲转换的坐标值>, @<欲转换坐标值的类型>)
    }

    方法 逻辑尺寸到像素 <公开 类型 = 尺寸类 注释 = "将所指定的基于当前绘画单位的尺寸值转换到像素单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的尺寸 <类型 = 尺寸类 注释 = "此尺寸基于当前绘画单位">
    {
        @ @dt<尺寸类> (@sn<this>.data ().LPSizeToDP (&@<所欲转换的尺寸>.ToSize ()))
    }

    方法 像素尺寸到逻辑 <公开 类型 = 尺寸类 注释 = "将所指定的基于像素单位的尺寸值转换到当前绘画单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的尺寸 <类型 = 尺寸类 注释 = "此尺寸基于像素单位">
    {
        @ @dt<尺寸类> (@sn<this>.data ().DPSizeToLP (&@<所欲转换的尺寸>.ToSize ()))
    }

    方法 逻辑位置到像素 <公开 类型 = 位置类 注释 = "将所指定的基于当前绘画单位的位置转换到像素单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的位置 <类型 = 位置类 注释 = "此位置基于当前绘画单位">
    {
        @ @dt<位置类> (@sn<this>.data ().LPPointToDP (&@<所欲转换的位置>.ToPoint ()))
    }

    方法 像素位置到逻辑 <公开 类型 = 位置类 注释 = "将所指定的基于像素单位的位置转换到当前绘画单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的位置 <类型 = 位置类 注释 = "此位置基于像素单位">
    {
        @ @dt<位置类> (@sn<this>.data ().DPPointToLP (&@<所欲转换的位置>.ToPoint ()))
    }

    方法 逻辑矩形到像素 <公开 类型 = 矩形类 注释 = "将所指定的基于当前绘画单位的矩形位置转换到像素单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的矩形 <类型 = 矩形类 注释 = "此矩形位置基于当前绘画单位">
    {
        @ @dt<矩形类> (@sn<this>.data ().LPRectToDP (&@<所欲转换的矩形>.ToRect ()))
    }

    方法 像素矩形到逻辑 <公开 类型 = 矩形类 注释 = "将所指定的基于像素单位的矩形位置转换到当前绘画单位并返回." 注释 = "调用本方法时必须已经开始打印." @嵌入式方法 = "">
    参数 所欲转换的矩形 <类型 = 矩形类 注释 = "此矩形位置基于像素单位">
    {
        @ @dt<矩形类> (@sn<this>.data ().DPRectToLP (&@<所欲转换的矩形>.ToRect ()))
    }

    方法 置字体对象 <公开 注释 = "设置打印文本时所使用的字体" @嵌入式方法 = "">
    参数 所欲设置的字体 <类型 = 字体对象类>
    {
        @ @sn<this>.data ().SetPaintFontHandle ((HFONT)@<所欲设置的字体>.GetGDIHandle ())
    }

    # --
    #
    # @ <include>
    # @ virtual void OnStartPrinting () override  {  @<打印开始> ();  }
    # @ virtual void OnPrintPageEnd () override  {  @<打印完一页> ();  }
    # @ virtual void OnEndPrinting (const BOOL_P blpAbort) override  {  @<打印结束> ((BOOL)blpAbort);  }
    # @ </include>
}

