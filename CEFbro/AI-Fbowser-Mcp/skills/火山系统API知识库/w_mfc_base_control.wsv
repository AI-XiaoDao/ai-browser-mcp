        @     if (@<所被选择的字符数> < 0)
        @         pWnd->SetSel (0, -1);
        @     else
        @         pWnd->SetSel (@<起始字符索引>, @<起始字符索引> + @<所被选择的字符数>);
        @ }
    }

    方法 加入文本 <公开 注释 = "将所指定文本加入到编辑框的尾部">
