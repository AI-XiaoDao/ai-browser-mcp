{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Label, ILabelEventListener, WS_BORDER, 0, 0, 0)
    #
    # 事件 ---

    方法 反馈事件 <公开 定义事件 类型 = 整数 注释 = "当在程序中调用本对象的\"调用反馈事件\"方法基于Windows消息进行通讯时,本事件将被触发." 返回值注释 = "所返回值将返回到\"调用反馈事件\"方法的调用方">
    参数 参数1 <类型 = 变整数 注释 = "\"调用反馈事件\"方法所提供的参数1值">
    参数 参数2 <类型 = 变整数 注释 = "\"调用反馈事件\"方法所提供的参数2值">

    # 属性 ---

    方法 透明 <公开 属性读 类型 = 逻辑型 注释 = "返回本组件背景是否透明" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Label*)@sn<this>.GetMfcWndPtr ())->m_blpTransparent
    }

    方法 透明 <公开 属性写 注释 = "设置本组件的背景是否透明." 注释 = "如果本属性值设置为真,则\"背景颜色\"属性将不起作用." 注释 = "注意本属性不支持在界面设计器中预览." @视窗.设置时机 = 组件创建前后>
    参数 是否透明 <类型 = 逻辑型>
    {
        @ CVWnd_Label* pWnd = (CVWnd_Label*)GetMfcWndPtr ();
        @ pWnd->m_blpTransparent = (COLORREF)@<是否透明>;
        @ #ifndef _VOL_FOR_UI_DESIGNER  // 不为编译布局设计器专用版本?
        @ if (pWnd->m_hWnd != NULL) {
        @     pWnd->ModifyStyleEx ((@<是否透明> ? 0 : WS_EX_TRANSPARENT), (@<是否透明> ? WS_EX_TRANSPARENT : 0));
        @     pWnd->RedrawLabel ();
        @ }
        @ #endif
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
