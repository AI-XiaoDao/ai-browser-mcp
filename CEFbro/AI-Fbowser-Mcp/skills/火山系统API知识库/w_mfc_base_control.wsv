类 滚动条类型 <公开 注释 = "提供滚动条的各种类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = 0>
    常量 横向滚动条 <公开 值 = 1>
    常量 纵向滚动条 <公开 值 = 2>
    常量 横向及纵向滚动条 <公开 值 = 3>
}

类 编辑框输入方式 <公开 注释 = "提供编辑框的各种输入方式" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 通常方式 <公开 值 = 0>
    常量 只读方式 <公开 值 = 1>
    常量 密码输入 <公开 值 = 2>
    常量 整数文本输入 <公开 值 = 3>
    常量 小数文本输入 <公开 值 = 4>
    常量 输入字节 <公开 值 = 5>
    常量 输入短整数 <公开 值 = 6>
    常量 输入整数 <公开 值 = 7>
    常量 输入长整数 <公开 值 = 8>
    常量 输入单精度小数 <公开 值 = 9>
    常量 输入双精度小数 <公开 值 = 10>
    常量 输入中文日期时间 <公开 值 = 11 注释 = "输入中文格式的日期时间,具体格式见\"日期时间操作类.到时间\"方法中的说明.">
    常量 输入英文日期时间 <公开 值 = 12 注释 = "输入非中文格式的日期时间,具体格式见\"日期时间操作类.到时间\"方法中的说明.">
    常量 输入十六进制整数 <公开 值 = 13>
}

