类 文件框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IFileBoxEventListener" @视窗.窗口组件 = "icon=\"@17\"\r\ndefault_size = \"160, 120\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_FileBox, IFileBoxEventListener, 0, 0, 0, WS_EX_CLIENTEDGE)
    #
    # 事件 ---

    方法 选择文件被改变 <公开 定义事件 类型 = 整数 注释 = "当现行被选择的文件被改变后发送此事件">

    方法 双击选择 <公开 定义事件 类型 = 整数 注释 = "当使用鼠标左键在某列表项目上双击时产生此事件">

    # 属性 ---

    方法 目录 <公开 属性读 类型 = 文本型 注释 = "返回当前显示其内容的目录" @嵌入式方法 = "">
    {
        @ ((CVWnd_FileBox*)@sn<this>.GetMfcWndPtr ())->m_strPath
    }

    方法 目录 <公开 属性写 注释 = "设置当前显示其内容的目录." 注释 = "本属性的默认值为空." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的目录 <类型 = 文本型 注释 = "提供当前显示其内容的目录,为空将自动使用现行系统目录">
    {
        @ CVWnd_FileBox* pWnd = (CVWnd_FileBox*)GetMfcWndPtr ();
        @ pWnd->m_strPath.SetText (@<所欲设置的目录>);
        @ pWnd->m_strPath.RemoveEndPathChar ();  // 删除多余的尾部路径字符
        @ pWnd->m_strCurSelFiles.Empty ();  // 丢弃先前的被选择文件
        @ pWnd->Update ();
    }

    方法 被选择文件 <公开 属性读 类型 = 文本型 注释 = "  返回当前被选择的所有文件,注意不包含路径.如果有多个" 注释 = "文件被选择,各文件名之间用分号隔开." 注释 = "  本属性只读." @嵌入式方法 = "">
    {
        @ ((CVWnd_FileBox*)@sn<this>.GetMfcWndPtr ())->m_strCurSelFiles
    }

    方法 允许选择多项 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许选择多项" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_FileBox*)@sn<this>.GetMfcWndPtr ())->m_blpAllowSelMutilFile
    }

    方法 允许选择多项 <公开 属性写 注释 = "设置是否允许选择多项. 本属性的默认值为假." @视窗.设置时机 = 组件创建前>
    参数 是否允许选择多项 <类型 = 逻辑型>
    {
        @ ((CVWnd_FileBox*)GetMfcWndPtr ())->m_blpAllowSelMutilFile = @<是否允许选择多项>;
    }

    方法 通配符 <公开 属性读 类型 = 文本型 注释 = "返回允许进入文件框的文件类型." 注释 = "可能同时包括多个通配符,各通配符之间用分号隔开." @嵌入式方法 = "">
    {
        @ ((CVWnd_FileBox*)@sn<this>.GetMfcWndPtr ())->m_strPatterns
    }

    方法 通配符 <公开 属性写 注释 = "设置允许进入文件框的文件类型. 本属性的默认值为空文本." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的通配符 <类型 = 文本型 注释 = "  可以同时指定多个通配符(中间可以包含\'*\'或\'?\'字符的文件名匹配文本)," 注释 = "各通配符之间用分号隔开."
            注释 = "  如果为空文本,则默认为所有名称的文件(\"*.*\").">
    {
        @ CVWnd_FileBox* pWnd = (CVWnd_FileBox*)GetMfcWndPtr ();
        @ pWnd->m_strPatterns.SetText (@<所欲设置的通配符>);
        @ pWnd->Update ();
    }

    方法 通常 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许没有设置存档、只读、系统、隐藏属性的文件进入" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_FileBox*)@sn<this>.GetMfcWndPtr ())->m_blpAllowNormalFile
    }

    方法 通常 <公开 属性写 注释 = "设置是否允许没有设置存档、只读、系统、隐藏属性的文件进入. 本属性的默认值为真." @视窗.设置时机 = 组件创建前后>
