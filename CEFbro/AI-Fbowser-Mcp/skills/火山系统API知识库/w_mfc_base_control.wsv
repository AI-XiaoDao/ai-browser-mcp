    方法 取行数 <公开 类型 = 整数 注释 = "返回编辑框中当前内容的行数" @禁止流程检查 = 真>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? 0 : pWnd->GetLineCount ());
    }

    方法 取行文本 <公开 类型 = 文本型 注释 = "返回编辑框中指定行的文本内容">
    参数 行号 <类型 = 整数 注释 = "行号从0开始,用作指定编辑框中的某一行. 即:0指定第一行,1指定第二行,依此类推.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TCHAR buf [4096 * 2];
        @     ZERO_MEM (buf, sizeof (buf));
        @     pWnd->GetLine (@<行号>, buf, NUM_ELEMENTS_OF (buf) - 3);
        @     @<结果变量>.SetText (buf);
        @ }
        返回 (结果变量)
    }

    方法 取字符所在行 <公开 类型 = 整数 注释 = "返回编辑框中指定位置字符所在行的行号,行号值从0开始." @禁止流程检查 = 真>
    参数 字符位置 <类型 = 整数 注释 = "  字符位置为指定字符在编辑框全部内容中的索引位置,该索引位置从0开始." 注释 = "如果为-1,则自动取当前光标所在字符位置." @默认值 = -1>
    {
        @ CVWnd_Edit* pWnd = (CVWnd_Edit*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? 0 : pWnd->LineFromChar (MAX (@<字符位置>, -1)));
    }

