类 调节器方向 <公开 注释 = "提供调节器的按钮方向" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 横向 <公开 值 = 0>
    常量 纵向 <公开 值 = 1>
}

类 调节器 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public ISpinEventListener" @视窗.窗口组件 = "icon=\"@33\"\r\ndefault_size = \"20, 20\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Spin, ISpinEventListener, 0, 0, 0, 0)
    #
    # 事件 --

    方法 调节钮被按下 <公开 定义事件 类型 = 整数 注释 = "当用户单击调节钮上的按钮时本事件被发送">
    参数 按钮值 <类型 = 整数 注释 = "如果按下的是调节器的向上箭头按钮,参数值为1,否则为-1.">

    # 属性 --

    方法 方向 <公开 属性读 类型 = 调节器方向 注释 = "返回当前所设置的调节器方向" @嵌入式方法 = "">
    {
        @ ((@sn<this>.GetControlStyle () & UDS_HORZ) != 0 ? 0 : 1)
    }

    方法 方向 <公开 属性写 注释 = "设置调节器的当前按钮方向" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的方向 <类型 = 调节器方向>
    {
        @ if (@<所欲设置的方向> == 0)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= UDS_HORZ;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~UDS_HORZ;
    }

    方法 热点跟踪 <公开 属性读 类型 = 逻辑型 注释 = "返回当鼠标移动到组件上时是否显示热点状态" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & UDS_HOTTRACK) != 0
    }

    方法 热点跟踪 <公开 属性写 注释 = "设置当鼠标移动到组件上时是否显示热点状态" @视窗.设置时机 = 组件创建前>
    参数 是否热点跟踪 <类型 = 逻辑型>
    {
        @ if (@<是否热点跟踪>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= UDS_HOTTRACK;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~UDS_HOTTRACK;
    }

    # --
    #
    # @ <include>
    # @ virtual void OnDeltapos (const INT_P npButton) override  {  @<调节钮被按下> ((INT)npButton);  }
    # @ </include>
}

