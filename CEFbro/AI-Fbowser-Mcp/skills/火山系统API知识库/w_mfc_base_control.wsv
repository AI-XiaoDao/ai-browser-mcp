类 画板 <公开 基础类 = 窗口组件 注释 = "画板窗口组件类." 注释 = "注意:" 注释 = "  1. 如未特殊说明,本类中所有坐标位置及尺寸均使用当前\"绘画单位\"属性所设置的单位;"
        注释 = "  2. 本类所使用的绘制坐标系的轴方向: 横向为从左到右,纵向为从上到下." @视窗.外部头文件 = "src\\mfc_ui_painter.h" @视窗.外部源文件 = "src\\mfc_ui_painter.cpp"
        @视窗.后缀文本 = "public IPainterEventListener" @视窗.窗口组件 = "icon=\"@5\"\r\ndefault_size = \"120, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Painter, IPainterEventListener, 0, 0, 0, 0)
    #
    # 事件 ---

    方法 绘画 <公开 定义事件 类型 = 整数 注释 = "当画板中的全部或一部分区域需要被重新绘制时即产生此事件." 注释 = "用户程序在响应此事件期间在画板上所进行的任何绘制操作均被限制在\"重画区\"参数所指定的区域内.">
    参数 重画区 <类型 = 矩形类 注释 = "提供目前画板中需要更新的矩形区域,使用画板的现行绘画单位,相对画板用户区的左上角." 注释 = "用作在绘制过程中跳过不需要绘制的部分以提高速度,一般情况下可以不处理.">

    # 属性 ---

    方法 画板背景色 <公开 属性读 类型 = 整数 注释 = "提供画板的当前背景颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 画板背景色 <公开 属性写 注释 = "设置画板的当前背景颜色." 注释 = "本属性的默认值为\"颜色类.默认色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_Painter*)GetMfcWndPtr ())->SetPaintBackColor (@<所欲设置颜色值>);
    }

    方法 底图 <公开 属性写 注释 = "设置显示在本组件背景上的位图" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消底图.">
    {
        @ ((CVWnd_Painter*)GetMfcWndPtr ())->TakeOverBackBitmap ((HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲设置的位图>));
    }

    方法 底图方式 <公开 属性读 类型 = 图片放置方式 注释 = "返回本组件上底图的放置方式" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->m_enBackPicPaintMode
    }

    方法 底图方式 <公开 属性写 注释 = "设置本组件上底图的放置方式" @视窗.设置时机 = 组件创建前后>
    参数 放置方式 <类型 = 图片放置方式>
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_Painter*)pWnd)->m_enBackPicPaintMode = (VOL_PIC_PAINT_MODE)@<放置方式>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 自动重画 <公开 属性读 类型 = 逻辑型 注释 = "返回本组件是否自动保存并重新绘制先前所绘画内容" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Painter*)@sn<this>.GetMfcWndPtr ())->m_blpAutoRedraw
    }

    方法 自动重画 <公开 属性写 注释 = "  设置本组件是否自动保存并重新绘制先前所绘画内容." 注释 = "  如果本属性设置为真,系统将自动把所有在画板上进行的绘画操作的结果保存到内存中,"
            注释 = "当以后需要重画时,系统简单地把所保存的绘画结果复制到画板上,而不再产生\"绘画\"事件." 注释 = "采用本属性需要消耗一定数量的内存.另外,如果本属性为真且在底图方式为居中时调整画"
            注释 = "板尺寸,将无法保留以前的绘画数据." 注释 = "  本属性的默认值为假." @视窗.设置时机 = 组件创建前后>
    参数 是否自动重画 <类型 = 逻辑型>
    {
        @ ((CVWnd_Painter*)GetMfcWndPtr ())->SetPaintAutoRedraw (@<是否自动重画>);
    }

