类 驱动器类型 <公开 注释 = "提供驱动器的各种类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 全部驱动器 <公开 值 = 0>
    常量 可抽取式驱动器 <公开 值 = 1>
    常量 固定驱动器 <公开 值 = 2>
    常量 光盘驱动器 <公开 值 = 3>
    常量 网络驱动器 <公开 值 = 4>
    常量 内存虚拟驱动器 <公开 值 = 5>
}

类 驱动器框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public IDriveBoxEventListener" @视窗.窗口组件 = "icon=\"@40\"\r\ndefault_size = \"120, 20\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_DriveBox, IDriveBoxEventListener, 0, 0, 0, 0)
    #
    # 事件 ---

    方法 驱动器被改变 <公开 定义事件 类型 = 整数 注释 = "当现行被选择的驱动器被改变后发送此事件">

    # 属性 ---

    方法 驱动器 <公开 属性读 类型 = 文本型 注释 = "返回当前所选择的驱动器,为大小写字母\'A\'到\'Z\'." 注释 = "如果未选择任何驱动器,则返回系统现行目录所处的驱动器." @嵌入式方法 = "">
    {
        @ ((CVWnd_DriveBox*)@sn<this>.GetMfcWndPtr ())->GetCurrentDrive ()
    }

    方法 驱动器 <公开 属性写 注释 = "设置当前所选择的驱动器" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的驱动器 <类型 = 文本型 注释 = "提供所欲设置的驱动器符,为大小写字母\'A\'到\'Z\'.">
    {
        @ ((CVWnd_DriveBox*)GetMfcWndPtr ())->SetCurrentDrive (@<所欲设置的驱动器>.GetText ());
    }

    方法 类型 <公开 属性读 类型 = 驱动器类型 注释 = "返回当前所欲匹配驱动器的类型" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_DriveBox*)@sn<this>.GetMfcWndPtr ())->m_npMatchDriveType
    }

    方法 类型 <公开 属性写 注释 = "设置当前所欲匹配驱动器的类型" @视窗.设置时机 = 组件创建前后>
    参数 所欲匹配的驱动器类型 <类型 = 驱动器类型>
    {
        @ ((CVWnd_DriveBox*)GetMfcWndPtr ())->SetMatchDriveType (@<所欲匹配的驱动器类型>);
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_DriveBox*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件的背景颜色值." 注释 = "如果本组件未曾设置过背景颜色,则默认为\"颜色类.默认色\"." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_DriveBox*)GetMfcWndPtr ())->SetBackColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_DriveBox*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值. 如果本组件未曾设置过文本颜色,则默认为黑色." @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_DriveBox*)pWnd)->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    # ---
    #
    # @ <include>
    # @ virtual void OnDriveChanged () override  {  @<驱动器被改变> ();  }
    # @ </include>
}

