类 滑块条方向 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 横向 <公开 值 = 0>
    常量 纵向 <公开 值 = 1>
}

类 滑块条刻度类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = 0>
    常量 上或左 <公开 值 = 1>
    常量 下或右 <公开 值 = 2>
    常量 双向 <公开 值 = 3>
}

类 滑块条 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public ISliderBarEventListener" @视窗.窗口组件 = "icon=\"@61\"\r\ndefault_size = \"120, 40\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_SliderBar, ISliderBarEventListener, 0, 0, TBS_HORZ | TBS_RIGHT | TBS_AUTOTICKS, 0)
    #
    # 事件 ---

    方法 位置被改变 <公开 定义事件 类型 = 整数 注释 = "当滑块条位置被改变后本事件被发送">

    # 属性 ---

    方法 方向 <公开 属性读 类型 = 滑块条方向 注释 = "返回滑块条的当前方向" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & (TBS_HORZ | TBS_VERT)) == TBS_VERT ? @<滑块条方向.纵向> : @<滑块条方向.横向>
    }

    方法 方向 <公开 属性写 注释 = "设置滑块条的当前方向" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的方向 <类型 = 滑块条方向>
    {
        @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~(TBS_HORZ | TBS_VERT);
        如果 (所欲设置的方向 == 滑块条方向.纵向)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_VERT;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_HORZ;
        }
    }

    方法 刻度类型 <公开 属性读 类型 = 滑块条刻度类型 注释 = "返回滑块条的当前刻度类型" @禁止流程检查 = 真>
    {
        @ const DWORD dwStyle = (GetMfcWndObject ()->m_dwAttrInitialStyle & (TBS_NOTICKS | TBS_LEFT | TBS_TOP | TBS_RIGHT | TBS_BOTTOM | TBS_BOTH));
        @ switch (dwStyle)
        @ {
        @ case TBS_NOTICKS:
        @     return @<滑块条刻度类型.无>;
        @ case TBS_LEFT:
        @     COMPILE_TIME_ASSERT (TBS_LEFT == TBS_TOP);
        @     return @<滑块条刻度类型.上或左>;
        @ case TBS_BOTH:
        @     return @<滑块条刻度类型.双向>;
        @ default:
        @     COMPILE_TIME_ASSERT (TBS_RIGHT == TBS_BOTTOM);
        @     ASSERT (dwStyle == TBS_RIGHT);
        @     return @<滑块条刻度类型.下或右>;
        @  }
    }

    方法 刻度类型 <公开 属性写 注释 = "设置滑块条的当前刻度类型" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的刻度类型 <类型 = 滑块条刻度类型>
    {
        @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~(TBS_NOTICKS | TBS_LEFT | TBS_TOP | TBS_RIGHT | TBS_BOTTOM | TBS_BOTH);
        @ switch (@<所欲设置的刻度类型>)
        @ {
        @ case 0:  // 滑块条刻度类型.无
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_NOTICKS;
        @     break;
        @ case 1:  // 滑块条刻度类型.上或左
        @     COMPILE_TIME_ASSERT (TBS_LEFT == TBS_TOP);
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_LEFT;
        @     break;
        @ case 3:  // 滑块条刻度类型.双向
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_BOTH;
        @     break;
        @ default:
        @     COMPILE_TIME_ASSERT (TBS_RIGHT == TBS_BOTTOM);
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_RIGHT;
        @     break;
        @ }
    }

    方法 单位刻度值 <公开 属性读 类型 = 整数 注释 = "返回滑块条每个刻度单位所对应的长度" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_SliderBar*)@sn<this>.GetMfcWndPtr ())->m_npTickFreq
    }

    方法 单位刻度值 <公开 属性写 注释 = "设置滑块条每个刻度单位所对应的长度" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的单位刻度值 <类型 = 整数 注释 = "参数值必须大于0">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ pWnd->m_npTickFreq = MAX (1, @<所欲设置的单位刻度值>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetTicFreq ((INT)pWnd->m_npTickFreq);
    }

    方法 允许选择 <公开 属性读 类型 = 逻辑型 注释 = "返回滑块条是否支持用户选择其中的区域" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & TBS_ENABLESELRANGE) != 0
    }

    方法 允许选择 <公开 属性写 注释 = "设置滑块条是否支持用户选择其中的区域" @视窗.设置时机 = 组件创建前>
    参数 是否允许选择 <类型 = 逻辑型>
    {
        如果 (是否允许选择)
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle |= TBS_ENABLESELRANGE;
        }
        否则
        {
            @ GetMfcWndObject ()->m_dwAttrInitialStyle &= ~TBS_ENABLESELRANGE;
        }
    }

    方法 首选择位置 <公开 属性读 类型 = 整数 注释 = "如果滑块条支持用户选择其中的区域,返回当前选择区域的起始位置." @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialSelStart;
        @ INT nMin = 0, nMax;
        @ pWnd->GetSelection (nMin, nMax);
        @ return nMin;
    }

    方法 首选择位置 <公开 属性写 注释 = "如果滑块条支持用户选择其中的区域,设置当前选择区域的起始位置." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialSelStart = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMin, nMax = 0;
        @     pWnd->GetSelection (nMin, nMax);
        @     pWnd->SetSelection (@<所欲设置的位置值>, nMax);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 选择长度 <公开 属性读 类型 = 整数 注释 = "如果滑块条支持用户选择其中的区域,返回当前选择区域的长度." @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialSelLength;
        @ INT nMin = 0, nMax = 0;
        @ pWnd->GetSelection (nMin, nMax);
        @ return nMax - nMin;
    }

    方法 选择长度 <公开 属性写 注释 = "如果滑块条支持用户选择其中的区域,设置当前选择区域的长度." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的长度 <类型 = 整数>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的长度> = CLIP (@<所欲设置的长度>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialSelLength = @<所欲设置的长度>;
        @ else
        @ {
        @     INT nMin = 0, nMax;
        @     pWnd->GetSelection (nMin, nMax);
        @     pWnd->SetSelection (nMin, nMin + @<所欲设置的长度>);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 最小位置 <公开 属性读 类型 = 整数 注释 = "返回滑块条当前所允许的最小位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMin;
        @ INT nMinPos = 0, nMaxPos;
        @ pWnd->GetRange (nMinPos, nMaxPos);
        @ return nMinPos;
    }

    方法 最小位置 <公开 属性写 注释 = "设置滑块条当前所允许的最小位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMin = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetRange (nMinPos, nMaxPos);
        @     pWnd->SetRange (@<所欲设置的位置值>, nMaxPos);
        @ }
    }

    方法 最大位置 <公开 属性读 类型 = 整数 注释 = "返回滑块条当前所允许的最大位置值" @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd == NULL)
        @     return (INT)pWnd->m_npInitialMax;
        @ INT nMinPos, nMaxPos = 0;
        @ pWnd->GetRange (nMinPos, nMaxPos);
        @ return nMaxPos;
    }

    方法 最大位置 <公开 属性写 注释 = "设置滑块条当前所允许的最大位置值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialMax = @<所欲设置的位置值>;
        @ else
        @ {
        @     INT nMinPos = 0, nMaxPos = 0;
        @     pWnd->GetRange (nMinPos, nMaxPos);
        @     pWnd->SetRange (nMinPos, @<所欲设置的位置值>);
        @ }
    }

    方法 页改变值 <公开 属性读 类型 = 整数 注释 = "返回当用户在滑块条的空隙处单击后滑块条位置的增减数值" @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialPageStep : pWnd->GetPageSize ());
    }

    方法 页改变值 <公开 属性写 注释 = "设置当用户在滑块条的空隙处单击后滑块条位置的增减数值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的改变值 <类型 = 整数 注释 = "有效值的范围在1到32627之间">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的改变值> = CLIP (@<所欲设置的改变值>, 1, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialPageStep = @<所欲设置的改变值>;
        @ else
        @     pWnd->SetPageSize (@<所欲设置的改变值>);
    }

    方法 行改变值 <公开 属性读 类型 = 整数 注释 = "返回当用户拖动滑块时滑块条位置的每次增减数值" @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialLineStep : pWnd->GetLineSize ());
    }

    方法 行改变值 <公开 属性写 注释 = "设置当用户拖动滑块时滑块条位置的每次增减数值" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的改变值 <类型 = 整数 注释 = "有效值的范围在1到32627之间">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的改变值> = CLIP (@<所欲设置的改变值>, 1, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialLineStep = @<所欲设置的改变值>;
        @ else
        @     pWnd->SetLineSize (@<所欲设置的改变值>);
    }

    方法 位置 <公开 属性读 类型 = 整数 注释 = "返回滑块条的当前滑块位置" @禁止流程检查 = 真>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialPos : pWnd->GetPos ());
    }

    方法 位置 <公开 属性写 注释 = "设置滑块条的当前滑块位置" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位置值 <类型 = 整数 注释 = "有效值的范围在0到32627之间">
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<所欲设置的位置值> = CLIP (@<所欲设置的位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialPos = @<所欲设置的位置值>;
        @ else
        @     pWnd->SetPos (@<所欲设置的位置值>);
    }

    # 方法 ---

    方法 置刻度范围 <公开 注释 = "设置滑块条当前所允许的最小和最大位置值">
    参数 最小位置值 <类型 = 整数>
    参数 最大位置值 <类型 = 整数>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<最小位置值> = CLIP (@<最小位置值>, 0, _VOL_SHRT_MAX);
        @ @<最大位置值> = CLIP (@<最大位置值>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @ {
        @     pWnd->m_npInitialMin = @<最小位置值>;
        @     pWnd->m_npInitialMax = @<最大位置值>;
        @ }
        @ else
        @ {
        @     pWnd->SetRange (@<最小位置值>, @<最大位置值>);
        @ }
    }

    方法 置选择区域 <公开 注释 = "如果滑块条支持用户选择其中的区域,设置当前选择区域.">
    参数 选择区域起始位置 <类型 = 整数>
    参数 选择区域长度 <类型 = 整数>
    {
        @ CVWnd_SliderBar* pWnd = (CVWnd_SliderBar*)GetMfcWndPtr ();
        @ @<选择区域起始位置> = CLIP (@<选择区域起始位置>, 0, _VOL_SHRT_MAX);
        @ @<选择区域长度> = CLIP (@<选择区域长度>, 0, _VOL_SHRT_MAX);
        @ if (pWnd->m_hWnd == NULL)
        @ {
        @     pWnd->m_npInitialSelStart = @<选择区域起始位置>;
        @     pWnd->m_npInitialSelLength = @<选择区域长度>;
        @ }
        @ else
        @ {
        @     pWnd->SetSelection (@<选择区域起始位置>, @<选择区域起始位置> + @<选择区域长度>);
        @     pWnd->Invalidate ();
        @ }
    }

    # ---
    #
    # @ <include>
    # @ virtual void OnScroll () override  {  @<位置被改变> ();  }
    # @ </include>
}

# ===

类 选择夹表头方向 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 上 <公开 值 = 0>
    常量 下 <公开 值 = 1>
    常量 左 <公开 值 = 2>
    常量 右 <公开 值 = 3>
}

类 子夹内容位置 <公开 注释 = "提供当插入子夹时,将内容组件放置在子夹中的具体位置." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 填满 <公开 值 = 0 注释 = "改变内容组件的尺寸以填满整个子夹内容区域">
    常量 左上 <公开 值 = 1>
    常量 居中 <公开 值 = 2>
    常量 右下 <公开 值 = 3>
}

类 选择夹 <公开 基础类 = 窗口容器组件 @视窗.后缀文本 = "public ITabEventListener" @视窗.窗口组件 = "icon=\"@70\"\r\ndefault_size = \"240, 200\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Tab, ITabEventListener, 0, 0, 0, 0)
    #
    # 事件 ---

    方法 被单击 <公开 定义事件 类型 = 整数 注释 = "当在选择夹上单击后发送此事件">

    方法 将改变子夹 <公开 定义事件 类型 = 整数 注释 = "当现行被选择子夹即将被改变时发送此事件." 注释 = "事件处理程序返回 1 中止此改变,返回 0 则允许此改变.">

    方法 子夹被改变 <公开 定义事件 类型 = 整数 注释 = "当现行被选择子夹已经被改变时发送此事件">

    # 属性 ---

    方法 表头方向 <公开 属性读 类型 = 选择夹表头方向 注释 = "返回表头的当前方向" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_Tab*)@sn<this>.GetMfcWndPtr ())->m_npTabOrientation
    }

    方法 表头方向 <公开 属性写 注释 = "设置表头的当前方向" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的表头方向 <类型 = 选择夹表头方向>
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->m_npTabOrientation = CLIP (@<所欲设置的表头方向>, 0, 3);
    }

    方法 允许多行表头 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许多行表头" @嵌入式方法 = "">
    {
        @ (BOOL)((CVWnd_Tab*)@sn<this>.GetMfcWndPtr ())->m_blpMutiLineHeader
    }

    方法 允许多行表头 <公开 属性写 注释 = "设置是否允许多行表头" @视窗.设置时机 = 组件创建前>
    参数 是否允许多行表头 <类型 = 逻辑型>
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->m_blpMutiLineHeader = @<是否允许多行表头>;
    }

    方法 "// 子夹项目" <公开 属性读 类型 = 文本型 注释 = "返回选择夹中的各个子夹项目及其名称" 注释 = "由于一旦组件创建完毕,为了节省空间,此属性值将被清空,因此本属性不支持读取."
            返回值注释 = "  所返回列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员分别指定一个子夹" 返回值注释 = "的标题文本和其左侧图标在当前图片组(通过\"图片组\"属性设置)中的索引位置." @嵌入式方法 = "">
    {
        @ ((CVWnd_Tab*)@sn<this>.GetMfcWndPtr ())->m_strItems
    }

    方法 子夹项目 <公开 属性写 注释 = "设置选择夹中的各个子夹项目及其名称" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "designer\\mfc_designer_x64.dll\r\ndesigner\\mfc_designer_win32.dll\r\nListItemsManager\r\n1">
    参数 所欲设置的列表内容 <类型 = 文本型 注释 = "  列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员分别指定一个子夹的标题" 注释 = "文本和其左侧图标在当前图片组(通过\"图片组\"属性设置)中的索引位置."
            编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->ResetChildTabs (@<所欲设置的列表内容>);
    }

    方法 现行子夹 <公开 属性读 类型 = 整数 注释 = "返回选择夹的现行子夹索引,从0开始." @禁止流程检查 = 真>
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? (INT)pWnd->m_npInitialSel : pWnd->GetCurSel ());
    }

    方法 现行子夹 <公开 属性写 注释 = "设置选择夹的现行子夹索引,从0开始." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的子夹索引 <类型 = 整数 注释 = "索引值从0开始">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtr ();
        @ @<所欲设置的子夹索引> = MAX (0, @<所欲设置的子夹索引>);
        @ if (pWnd->m_hWnd == NULL)
        @     pWnd->m_npInitialSel = @<所欲设置的子夹索引>;
        @ else if (@<所欲设置的子夹索引> != pWnd->GetCurSel ())
        @ {
        @     pWnd->SetCurSel (@<所欲设置的子夹索引>);
        @     pWnd->ShowCurrentContentControl (TRUE);
        @     ::NotifyParentCurrentChildTabChanged (pWnd->m_hWnd, FALSE);
        @ }
    }

    方法 图片组 <公开 属性写 注释 = "设置在本选择夹的各个子夹左侧显示图标用的图片组" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组 <类型 = 图片组资源 注释 = "对图片组图片格式的要求请参见\"图片组资源\"类中的说明">
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->TakeOverImageList ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲设置的图片组>));
    }

    方法 图片组文件 <公开 属性写 注释 = "设置在本选择夹的各个子夹左侧显示图标用的图片组" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组文件 <类型 = 文本型 注释 = "  提供用作保存图片组的图片文件名,该图片文件的格式必须符合" 注释 = "\"图片组资源\"类中所说明的要求.">
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->TakeOverImageList ((HIMAGELIST)g_objVolApp.LoadResImageFile (VRIT_IMAGE_LIST, @<所欲设置的图片组文件>.GetText ()));
    }

    方法 置图片组 <公开 注释 = "设置在本选择夹的各个子夹左侧显示图标用的图片组">
    参数 所欲设置的图片组 <类型 = 图片组对象类 注释 = "注意该参数对象内的图片组将被移交给本对象管理">
    {
        @ ((CVWnd_Tab*)GetMfcWndPtr ())->TakeOverImageList ((HIMAGELIST)@<所欲设置的图片组>.DetachGDIHandle ());
    }

    # 方法 ---

    方法 置现行子夹并发送事件 <公开 注释 = "设置选择夹的现行子夹索引,本方法可以触发\"子夹被改变\"事件.">
    参数 所欲设置的子夹索引 <类型 = 整数 注释 = "索引值从0开始">
    {
        现行子夹 = 所欲设置的子夹索引
        子夹被改变 ()
    }

    方法 刷新子夹内容 <公开 注释 = "本方法可以更新当前子夹内容的显示状态,一般情况下无需调用,仅用作在手动调整了子夹中组件的可视状态后使用.">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  ::NotifyParentCurrentChildTabChanged (pWnd->m_hWnd, FALSE);
    }

    方法 取子夹数目 <公开 类型 = 整数 注释 = "返回选择夹的当前子夹数目,选择夹必须已经被创建." @禁止流程检查 = 真>
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetItemCount () : 0);
    }

    方法 取子夹名称 <公开 类型 = 文本型 注释 = "返回选择夹中所指定索引位置处子夹的名称,选择夹必须已经被创建.">
    参数 所欲操作子夹索引 <类型 = 整数>
    {
        变量 子夹名称 <类型 = 文本型>
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TCHAR buf [256];
        @     buf [0] = '\0';
        @     TCITEM tcItem;
        @     tcItem.mask = TCIF_TEXT;
        @     tcItem.pszText = buf;
        @     tcItem.cchTextMax = NUM_ELEMENTS_OF (buf) - 1;
        @     if (pWnd->GetItem (@<所欲操作子夹索引>, &tcItem))
        @         @<子夹名称>.SetText (tcItem.pszText);
        @ }
        返回 (子夹名称)
    }

    方法 置子夹名称 <公开 注释 = "设置选择夹中所指定索引位置处子夹的标题,选择夹必须已经被创建.">
    参数 所欲操作子夹索引 <类型 = 整数>
    参数 所欲设置的名称 <类型 = 文本型>
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TCITEM tcItem;
        @     tcItem.mask = TCIF_TEXT;
        @     tcItem.pszText = (LPTSTR)@<所欲设置的名称>.GetText ();
        @     if (pWnd->SetItem (@<所欲操作子夹索引>, &tcItem))
        @         pWnd->Invalidate (FALSE);
        @ }
    }

    方法 取子夹图标索引 <公开 类型 = 整数 注释 = "  返回选择夹中所指定索引位置处子夹的图标在所设置" 注释 = "图片组中的索引位置,选择夹必须已经被创建." 返回值注释 = "如果选择夹尚未创建或者所指定子夹不存在,将返回-1."
            @禁止流程检查 = 真>
    参数 所欲操作子夹索引 <类型 = 整数>
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd == NULL ||  pWnd->m_lstImages.m_hImageList == NULL)  // 未设有图片组?
        @     return -1;
        @ TCITEM tcItem;
        @ tcItem.mask = TCIF_IMAGE;
        @ tcItem.iImage = -1;
        @ return (pWnd->GetItem (@<所欲操作子夹索引>, &tcItem) ? tcItem.iImage : -1);
    }

    方法 置子夹图标索引 <公开 注释 = "  设置选择夹中所指定索引位置处子夹的图标在所设置" 注释 = "图片组中的索引位置,选择夹必须已经被创建.">
    参数 所欲操作子夹索引 <类型 = 整数>
    参数 所欲设置的图标索引 <类型 = 整数>
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_lstImages.m_hImageList != NULL)  // 设置有图片组?
        @ {
        @     TCITEM tcItem;
        @     tcItem.mask = TCIF_IMAGE;
        @     tcItem.iImage = (INT)@<所欲设置的图标索引>;
        @     if (pWnd->SetItem (@<所欲操作子夹索引>, &tcItem))
        @         pWnd->Invalidate (FALSE);
        @ }
    }

    方法 取子夹标签位置 <公开 类型 = 矩形类 注释 = "  返回所指定索引位置处子夹的标签在选择夹中的位置矩形," 注释 = "相对选择夹的左上角.选择夹必须已经被创建.">
    参数 所欲操作子夹索引 <类型 = 整数>
    {
        变量 子夹位置 <类型 = 矩形类>
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     if (pWnd->GetItemRect (@<所欲操作子夹索引>, &rt))
        @         @<子夹位置>.Copy (&rt);
        @ }
        返回 (子夹位置)
    }

    方法 取内容区位置 <公开 类型 = 矩形类 注释 = "  返回选择夹内除去子夹标签部分后用作放置其中内容子组件的" 注释 = "区域矩形,相对选择夹的左上角.选择夹必须已经被创建.">
    {
        变量 内容区位置 <类型 = 矩形类>
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     pWnd->ScreenToClient (&rt);
        @     pWnd->AdjustRect (FALSE, &rt);
        @     @<内容区位置>.Copy (&rt);
        @ }
        返回 (内容区位置)
    }

    方法 计算整体尺寸 <公开 类型 = 尺寸类 注释 = "根据所提供的内容区尺寸计算对应的选择夹整体尺寸." 注释 = "选择夹必须已经被创建.">
    参数 所需求的内容区宽度 <类型 = 整数>
    参数 所需求的内容区高度 <类型 = 整数>
    {
        变量 整体尺寸 <类型 = 尺寸类>
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CMRect rt (0, 0, @<所需求的内容区宽度>, @<所需求的内容区高度>);
        @     pWnd->AdjustRect (TRUE, &rt);
        @     @<整体尺寸.宽度> = rt.Width ();
        @     @<整体尺寸.高度> = rt.Height ();
        @ }
        返回 (整体尺寸)
    }

    方法 添加子夹 <公开 类型 = 整数 注释 = "在选择夹中加入一个具有所指定内容的子夹.选择夹必须已经被创建." 返回值注释 = "成功返回所加入子夹的索引位置,失败返回-1." @嵌入式方法 = "">
    参数 子夹标题 <类型 = 文本型 注释 = "提供子夹的标题文本">
    参数 子夹图标索引 <类型 = 整数 注释 = "提供所插入子夹左侧图标在所设置图片组中的索引位置" @默认值 = 0>
    参数 子夹内容组件类型 <类型 = 窗口容器组件 注释 = "提供所欲插入到当前子夹中的容器组件类型" @需求类型 = 数据类型>
    参数 内容组件位置 <类型 = 子夹内容位置 注释 = "提供将所指定的内容组件放置在子夹中的具体位置" @默认值 = 子夹内容位置.填满>
    {
        @ (INT)@sn<this>.InsertChildTab (-1, @<子夹标题>.GetText (), @<子夹图标索引>, NULL, VOL_RUNTIME_CLASS (@<子夹内容组件类型>), @<内容组件位置>)
    }

    方法 插入子夹 <公开 类型 = 整数 注释 = "在选择夹中指定位置插入一个具有所指定内容的子夹.选择夹必须已经被创建." 返回值注释 = "成功返回所加入子夹的索引位置,失败返回-1." @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "  提供具体的插入位置,必须大于等于0且小于等于\"取子夹数目\"方法返回值," 注释 = "为-1表示在最后一个子夹后面插入.">
    参数 子夹标题 <类型 = 文本型 注释 = "提供子夹的标题文本">
    参数 子夹图标索引 <类型 = 整数 注释 = "提供所插入子夹左侧图标在所设置图片组中的索引位置" @默认值 = 0>
    参数 子夹内容组件类型 <类型 = 窗口容器组件 注释 = "提供所欲插入到当前子夹中的容器组件类型" @需求类型 = 数据类型>
    参数 内容组件位置 <类型 = 子夹内容位置 注释 = "提供将所指定的内容组件放置在子夹中的具体位置" @默认值 = 子夹内容位置.填满>
    {
        @ (INT)@sn<this>.InsertChildTab (@<插入索引位置>, @<子夹标题>.GetText (), @<子夹图标索引>, NULL, VOL_RUNTIME_CLASS (@<子夹内容组件类型>), @<内容组件位置>)
    }

    方法 添加子夹2 <公开 类型 = 整数 注释 = "在选择夹中加入一个具有所指定内容的子夹.选择夹必须已经被创建." 返回值注释 = "成功返回所加入子夹的索引位置,失败返回-1." @嵌入式方法 = "">
    参数 子夹标题 <类型 = 文本型 注释 = "提供子夹的标题文本">
    参数 子夹图标索引 <类型 = 整数 注释 = "提供所插入子夹左侧图标在所设置图片组中的索引位置" @默认值 = 0>
    参数 子夹内容组件 <类型 = 窗口容器组件 注释 = "  提供所欲插入到当前子夹中的容器组件,该容器组件必须已经创建且" 注释 = "将被自动设置为本子夹的子窗口. 注意同一内容组件不能重复加入.">
    参数 内容组件位置 <类型 = 子夹内容位置 注释 = "提供将所指定的内容组件放置在子夹中的具体位置" @默认值 = 子夹内容位置.填满>
    {
        @ (INT)@sn<this>.InsertChildTab (-1, @<子夹标题>.GetText (), @<子夹图标索引>, &@<子夹内容组件>, NULL, @<内容组件位置>)
    }

    方法 插入子夹2 <公开 类型 = 整数 注释 = "在选择夹中指定位置插入一个具有所指定内容的子夹.选择夹必须已经被创建." 返回值注释 = "成功返回所加入子夹的索引位置,失败返回-1." @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "  提供具体的插入位置,必须大于等于0且小于等于\"取子夹数目\"方法返回值," 注释 = "为-1表示在最后一个子夹后面插入.">
    参数 子夹标题 <类型 = 文本型 注释 = "提供子夹的标题文本">
    参数 子夹图标索引 <类型 = 整数 注释 = "提供所插入子夹左侧图标在所设置图片组中的索引位置" @默认值 = 0>
    参数 子夹内容组件 <类型 = 窗口容器组件 注释 = "  提供所欲插入到当前子夹中的容器组件,该容器组件必须已经创建且将被自" 注释 = "动设置为本子夹的子窗口. 注意同一内容组件不能重复加入.">
    参数 内容组件位置 <类型 = 子夹内容位置 注释 = "提供将所指定的内容组件放置在子夹中的具体位置" @默认值 = 子夹内容位置.填满>
    {
        @ (INT)@sn<this>.InsertChildTab (@<插入索引位置>, @<子夹标题>.GetText (), @<子夹图标索引>, &@<子夹内容组件>, NULL, @<内容组件位置>)
    }

    方法 取子夹内容组件 <公开 类型 = 逻辑型 注释 = "获取并返回所指定子夹中的内容组件" 返回值注释 = "返回是否获取成功" @禁止流程检查 = 真>
    参数 子夹索引 <类型 = 整数 注释 = "指定所欲处理的子夹索引位置,从0开始.">
    参数 所返回组件 <类型 = 窗口容器组件 注释 = "如果本方法返回真,则将所获取到的对应内容组件填入到本参数中.">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const INT_P npContentControlIndex = FindContentControlIndex (@<子夹索引>);
        @     return (npContentControlIndex != -1 && @<所返回组件>.CheckCopyFrom (pWnd->m_aryControls [npContentControlIndex]));
        @ }
        @ return FALSE;
    }

    方法 取子夹内容组件参考 <公开 类型 = 窗口容器组件 注释 = "  获取并返回所指定子夹中的内容组件的参考对象,可以用作挂接事件. 挂接方法如下:"
            注释 = "  挂接事件 ((您的子夹内容组件类名)选择夹组件.取子夹内容组件参考 (有效子夹索引值))" 注释 = "  注意: 调用本方法时,必须确保本组件已经被创建而且所提供的子夹索引有效,否则运行时" 注释 = "程序将崩溃."
            @禁止流程检查 = 真 @视窗.返回参考 = 真>
    参数 子夹索引 <类型 = 整数 注释 = "指定所欲处理的子夹索引位置,从0开始,必须有效.">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ ASSERT (pWnd != NULL);
        @ const INT_P npContentControlIndex = FindContentControlIndex (@<子夹索引>);
        @ ASSERT (npContentControlIndex != -1);
        @ return (@dt<窗口容器组件>&)pWnd->m_aryControls [npContentControlIndex];
    }

    方法 子夹是否为空 <公开 类型 = 逻辑型 注释 = "返回所指定索引位置处的子夹中是否存在内容组件" @嵌入式方法 = "">
    参数 子夹索引 <类型 = 整数 注释 = "指定所欲处理的子夹索引位置,从0开始.">
    {
        @ @sn<this>.FindContentControlIndex (@<子夹索引>) == -1
    }

    方法 删除子夹 <公开 注释 = "删除所指定索引位置处的子夹">
    参数 子夹索引 <类型 = 整数 注释 = "指定所欲处理的子夹索引位置,从0开始.">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->RemoveChildTab (@<子夹索引>);
    }

    方法 删除所有子夹 <公开 注释 = "删除选择夹中的所有子夹">
    {
        @ CVWnd_Tab* pWnd = (CVWnd_Tab*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->RemoveAllChildTabs ();
    }

    方法 显示现行子夹内容 <公开 注释 = "根据设计时的子组件分组自动切换显示现行子夹的内容,本方法必须配合界面的设计时分组来使用,具体如下:"
            注释 = "在界面设计器中对本选择夹中的所有子组件根据其所处具体子夹进行对应分组: 位于子夹0中的所有子组件分组到组0,位于子夹1中的所有子组件分组到组1,以此类推."
            注释 = "设计时可以使用界面设计器的\"设计时隐藏\"功能来辅助在同一界面区域同时设计多份内容." 注释 = "注意: 使用本方法就不能同时使用添加/插入子夹系列方法动态加入子夹.">
    {
        显示子组件组 (现行子夹)
    }

    # ---
