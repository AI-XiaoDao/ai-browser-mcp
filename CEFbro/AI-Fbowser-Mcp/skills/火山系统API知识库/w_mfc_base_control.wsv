    方法 是否正在打印 <公开 属性读 类型 = 逻辑型 注释 = "返回当前是否正在进行打印" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().m_dcPrint.m_hDC != NULL
    }

    方法 当前页号 <公开 属性读 类型 = 整数 注释 = "  本属性提供现行打印页的页号,由类库自行维护. 页号值从\"首页页号\"属性值开始," 注释 = "如果\"最小页号\"属性值被置为-1,则页号值从1开始."
            注释 = "  在以下情况下属性值被自动增一:" 注释 = "  1.使用\"写文本行\"方法打印一行文本并且要打印文本行的高度当前页容纳不下(此时" 注释 = "将会首先自动换页);" 注释 = "  2.使用\"换页\"方法."
            注释 = "  本属性仅在打印作业过程中有效,如果当前没有进行打印,将返回0." @禁止流程检查 = 真>
    {
        @ return (INT)(data ().m_dcPrint.m_hDC == NULL ? 0 : data ().m_npCurPageNum);
    }

    方法 已打印份数 <公开 属性读 类型 = 整数 注释 = "  本属性提供现行所已经打印的份数(含当前份),由类库自行维护." 注释 = "在调用\"开始下一份\"方法后,本属性值被自动加一."
            注释 = "  本属性仅在打印作业过程中有效,如果当前没有进行打印,将返回0." @禁止流程检查 = 真>
    {
        @ return (INT)(data ().m_dcPrint.m_hDC == NULL ? 0 : data ().m_npCurCopies);
    }

    方法 打印区宽度 <公开 属性读 类型 = 整数 注释 = "本属性提供了打印纸实际可打印区域宽度减去左右边空后的值,使用现行绘画单位." 注释 = "本属性仅在打印作业过程中有效,如果当前没有进行打印,将返回0." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetPrintingPageSize ().cx
    }

    方法 打印区高度 <公开 属性读 类型 = 整数 注释 = "本属性提供了打印纸实际可打印区域高度减去上下边空后的值,使用现行绘画单位." 注释 = "本属性仅在打印作业过程中有效,如果当前没有进行打印,将返回0." @嵌入式方法 = "">
