类 选择框 <公开 基础类 = 按钮基础类 注释 = "选择框窗口组件类" @视窗.窗口组件 = "icon=\"@3\"\r\ndefault_size = \"80, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Button, IButtonEventListener, 0, 0, WS_TABSTOP | BS_AUTOCHECKBOX | BS_MULTILINE, 0)

    方法 标题居左 <公开 属性读 类型 = 逻辑型 注释 = "返回选择框的标题文本是否位于图标的左边" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & BS_LEFTTEXT) != 0
    }

    方法 标题居左 <公开 属性写 注释 = "设置选择框的标题文本是否位于图标的左边" @视窗.设置时机 = 组件创建前后>
    参数 标题是否居左 <类型 = 逻辑型>
    {
        @ SetButtonStyle (BS_LEFTTEXT, @<标题是否居左>);
    }

    方法 按钮形式 <公开 属性读 类型 = 逻辑型 注释 = "返回选择框的外形是否为按压外形" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & BS_PUSHLIKE) != 0
    }

    方法 按钮形式 <公开 属性写 注释 = "设置选择框的外形是否为按压外形" @视窗.设置时机 = 组件创建前后>
    参数 是否为按压外形 <类型 = 逻辑型>
    {
        @ SetButtonStyle (BS_PUSHLIKE, @<是否为按压外形>);
    }

    方法 平面 <公开 属性读 类型 = 逻辑型 注释 = "返回选择框的外形是否为平面方式" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & BS_FLAT) != 0
    }

    方法 平面 <公开 属性写 注释 = "设置选择框的外形是否为平面方式" @视窗.设置时机 = 组件创建前后>
    参数 是否为平面外形 <类型 = 逻辑型>
    {
        @ SetButtonStyle (BS_FLAT, @<是否为平面外形>);
    }

    方法 选中 <公开 属性读 类型 = 逻辑型 注释 = "返回选择框当前是否处于被选中状态" @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     return (((CVWnd_Button*)pWnd)->GetCheck () == 1);
        @ return FALSE;
    }

    方法 选中 <公开 属性写 注释 = "设置选择框当前是否处于被选中状态">
    参数 是否选中 <类型 = 逻辑型>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     ((CVWnd_Button*)pWnd)->SetCheck (@<是否选中> ? 1 : 0);
    }

    方法 手动 <公开 属性读 类型 = 逻辑型 注释 = "  返回选择框当前是否处于手动选择方式." 注释 = "  在手动选择方式下,最终用户的单击操作并不会对选择框的状态造成改变,"
            注释 = "选择框的状态需要在程序中接收到\"被单击\"事件后进行手动设置." @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const UINT uButtonType = (((CVWnd_Button*)pWnd)->GetButtonStyle  () & BS_TYPEMASK);
        @     return (uButtonType == BS_CHECKBOX || uButtonType == BS_RADIOBUTTON || uButtonType == BS_3STATE);
        @ }
        @ return FALSE;
    }

    方法 手动 <公开 属性写 注释 = "  设置选择框当前是否处于手动选择方式." 注释 = "  在手动选择方式下,最终用户的单击操作并不会对选择框的状态造成改变,"
            注释 = "选择框的状态需要在程序中接收到\"被单击\"事件后进行手动设置.">
    参数 是否为手动模式 <类型 = 逻辑型>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     const UINT uOldButtonStyle = ((CVWnd_Button*)pWnd)->GetButtonStyle ();
        @     const UINT uOldButtonType = (uOldButtonStyle & BS_TYPEMASK);
        @     UINT uNewButtonType = uOldButtonType;
        @     if (uOldButtonType == BS_CHECKBOX || uOldButtonType == BS_AUTOCHECKBOX)
        @         uNewButtonType = (@<是否为手动模式> ? BS_CHECKBOX : BS_AUTOCHECKBOX);
        @     else if (uOldButtonType == BS_RADIOBUTTON || uOldButtonType == BS_AUTORADIOBUTTON)
        @         uNewButtonType = (@<是否为手动模式> ? BS_RADIOBUTTON : BS_AUTORADIOBUTTON);
        @     else if (uOldButtonType == BS_3STATE || uOldButtonType == BS_AUTO3STATE)
        @         uNewButtonType = (@<是否为手动模式> ? BS_3STATE : BS_AUTO3STATE);

        @     if (uNewButtonType != uOldButtonType)
        @         ((CVWnd_Button*)pWnd)->SetButtonStyle ((uOldButtonStyle & ~BS_TYPEMASK) | uNewButtonType);
        @ }
    }
}

