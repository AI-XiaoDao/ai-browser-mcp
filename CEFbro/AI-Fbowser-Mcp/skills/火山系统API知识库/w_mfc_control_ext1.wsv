类 分隔条 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_splitter_bar.h" @视窗.外部源文件 = "src\\mfc_ui_splitter_bar.cpp"
        @视窗.后缀文本 = "public ISplitterBarEventListener" @视窗.外部资源文件 = "src\\res\\vol_splitter_bar.rc"
        @视窗.窗口组件 = "icon=\"@52\"\r\ndefault_size = \"100, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_SplitterBar, ISplitterBarEventListener, 0, 0, 0, 0)

    方法 被拖动 <公开 定义事件 类型 = 整数 注释 = "当分隔条被拖动到一个新的位置后即产生此事件">
    参数 原位置 <类型 = 整数 注释 = "  本参数值提供分隔条被拖动前的原位置坐标,单位为像素.该坐标值相对于其所在窗口或父组件用户区的左上角."
            注释 = "如果分隔条的方向为横向,则本参数提供分隔条顶边纵坐标值,否则为分隔条左边横坐标值.">
    参数 目的位置 <类型 = 整数 注释 = "  本参数值提供分隔条被拖动到的目的位置坐标,单位为像素.该坐标值相对于其所在窗口或父组件用户区的左上角."
            注释 = "如果分隔条的方向为横向,则本参数提供分隔条顶边纵坐标值,否则为分隔条左边横坐标值.">

    # 属性 --

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回分隔条的背景颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_SplitterBar*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置分隔条的背景颜色" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"来指定使用默认背景颜色.">
    {
        @ CVWnd_SplitterBar* pWnd = (CVWnd_SplitterBar*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = GetRealBackColor (@<所欲设置颜色值>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 方向 <公开 属性读 类型 = 分隔条方向 注释 = "返回分隔条的方向" @嵌入式方法 = "">
    {
        @ ((CVWnd_SplitterBar*)@sn<this>.GetMfcWndPtr ())->m_nOrientation
    }

    方法 方向 <公开 属性写 注释 = "设置分隔条的方向" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的方向 <类型 = 分隔条方向>
    {
        @ ((CVWnd_SplitterBar*)GetMfcWndPtr ())->m_nOrientation = CLIP (@<所欲设置的方向>, 0, 1);
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnMove (INT nOldPos, INT nNewPos) override  { @<被拖动> (nOldPos, nNewPos); }
    # <> </include>
    # @end
}

