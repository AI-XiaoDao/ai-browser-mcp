    方法 标准音提示 <公开 属性读 类型 = 逻辑型 注释 = "返回当鼠标单击按钮或移动到非立体风格按钮上时是否同时发出默认的标准声音." @嵌入式方法 = "">
    {
        @ ((CVWnd_SupperButton*)@sn<this>.GetMfcWndPtr ())->m_blUseStandardSound
    }

    方法 标准音提示 <公开 属性写 注释 = "设置当鼠标单击按钮或移动到非立体风格按钮上时是否同时发出默认的标准声音." @视窗.设置时机 = 组件创建前后>
    参数 是否提示标准音 <类型 = 逻辑型>
    {
        @ ((CVWnd_SupperButton*)GetMfcWndPtr ())->m_blUseStandardSound = @<是否提示标准音>;
    }

    方法 经过提示音 <公开 属性写 注释 = "设置当鼠标移动到非立体风格按钮上时所发出的声音." 注释 = "注意本属性仅当\"标准音提示\"属性值为假时才有效." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的声音 <类型 = WAV资源>
    {
        @ ((CVWnd_SupperButton*)GetMfcWndPtr ())->m_nSoundDataResID [0] = @<所欲设置的声音>;
    }

    方法 单击提示音 <公开 属性写 注释 = "设置当鼠标单击按钮时所发出的声音." 注释 = "注意本属性仅当\"标准音提示\"属性值为假时才有效." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的声音 <类型 = WAV资源>
    {
        @ ((CVWnd_SupperButton*)GetMfcWndPtr ())->m_nSoundDataResID [1] = @<所欲设置的声音>;
    }

    方法 提示文本 <公开 属性读 类型 = 文本型 注释 = "返回当鼠标停留在按钮上时动态显示的提示文本" @嵌入式方法 = "">
    {
        @ ((CVWnd_SupperButton*)@sn<this>.GetMfcWndPtr ())->m_strToolTip
    }

    方法 提示文本 <公开 属性写 注释 = "设置当鼠标停留在按钮上时动态显示的提示文本" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的文本 <类型 = 文本型>
    {
        @ CVWnd_SupperButton* pWnd = (CVWnd_SupperButton*)GetMfcWndPtr ();
        @ pWnd->m_strToolTip.SetText (@<所欲设置的文本>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetTooltipText (pWnd->m_strToolTip);
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnClick () override  { @<被单击> (); }
    # <> </include>
    # @end
}

