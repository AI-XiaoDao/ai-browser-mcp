}

类 超级列表框检测状态 <公开 @文档 = "category = \"辅助类\"">
{
    常量 用户区上方 <公开 类型 = 整数 值 = @LVHT_ABOVE 注释 = "所检测位置位于列表框用户区的上方">
    常量 用户区下方 <公开 类型 = 整数 值 = @LVHT_BELOW 注释 = "所检测位置位于列表框用户区的下方">
    常量 用户区左方 <公开 类型 = 整数 值 = @LVHT_TOLEFT 注释 = "所检测位置位于列表框用户区的左方">
    常量 用户区右方 <公开 类型 = 整数 值 = @LVHT_TORIGHT 注释 = "所检测位置位于列表框用户区的右方">
    常量 无对应列表项 <公开 类型 = 整数 值 = @LVHT_NOWHERE 注释 = "所检测位置位于列表框用户区内部,但是不位于任何一个列表项的上面.">
    常量 列表项图标 <公开 类型 = 整数 值 = @LVHT_ONITEMICON 注释 = "所检测位置位于某列表项的图标上">
    常量 列表项文本 <公开 类型 = 整数 值 = @LVHT_ONITEMLABEL 注释 = "所检测位置位于某列表项的标题文本上">
    常量 列表项状态图标 <公开 类型 = 整数 值 = @LVHT_ONITEMSTATEICON 注释 = "所检测位置位于某列表项的状态图标上">
}

类 超级列表框检测结果 <公开 @文档 = "category = \"辅助类\"">
{
    变量 状态 <公开 类型 = 整数 注释 = "本成员值为\"超级列表框检测状态\"类中各个常量值的组合,用作表明具体所检测点的具体位置.">
    变量 行 <公开 类型 = 整数 注释 = "如果检测点位于某个列表项上,提供其行索引位置.小于0表示不位于列表项上.">
    变量 列 <公开 类型 = 整数 注释 = "如果检测点位于报表型列表框的某个列表项上,提供具体的列索引位置.">
}

类 超级列表框 <公开 基础类 = 窗口组件 注释 = "超级列表框窗口组件类" @视窗.外部头文件 = "src\\mfc_ui_list_view.h" @视窗.外部源文件 = "src\\mfc_ui_list_view.cpp"
        @视窗.后缀文本 = "public IListViewEventListener" @视窗.窗口组件 = "icon=\"@27\"\r\ndefault_size = \"240, 200\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ListView, IListViewEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 当前表项被改变 <公开 定义事件 类型 = 整数 注释 = "  如果当前焦点所处表项被改变即产生此事件,接收到此事件后读取" 注释 = "\"现行选中项\"属性即可获得当前表项的索引.">

    方法 表项被激活 <公开 定义事件 类型 = 整数 注释 = "  在下列情况下会产生本事件:  1.双击某表项; 2.选中某表项后按回车; 3.当\"热点跟踪\"属性为真时单击某表项."
            注释 = "接收到此事件后读取\"现行选中项\"属性即可获得当前被激活表项的索引.">

    方法 表头被单击 <公开 定义事件 类型 = 整数 注释 = "当使用鼠标左键在报表型列表框的某表头列上单击时产生此事件">
    参数 被单击列索引 <类型 = 整数 注释 = "提供被单击表头列的索引位置,从0开始.">

    方法 表项跟踪 <公开 定义事件 类型 = 整数 注释 = "  当\"热点跟踪\"属性为真时移动鼠标到某表项上后即产生本事件," 注释 = "注意如果鼠标不处于任何表项上,\"表项索引\"参数值将为-1.">
    参数 表项索引 <类型 = 整数 注释 = "提供当前鼠标位置所处表项的索引位置,从0开始.">

    方法 左键单击表项 <公开 定义事件 类型 = 整数 注释 = "  当用鼠标左键单击某表项时即产生此事件,接收到此事件后读取" 注释 = "\"现行选中项\"属性即可获得被单击表项的索引.">

    方法 右键单击表项 <公开 定义事件 类型 = 整数 注释 = "  当用鼠标右键单击某表项时即产生此事件,接收到此事件后读取" 注释 = "\"现行选中项\"属性即可获得被单击表项的索引.">

    方法 双击表项 <公开 定义事件 类型 = 整数 注释 = "  当用鼠标双击某表项时即产生此事件,接收到此事件后读取" 注释 = "\"现行选中项\"属性即可获得被单击表项的索引.">

    方法 开始编辑 <公开 定义事件 类型 = 整数 注释 = "  当表项进入标题编辑状态前产生此事件,要产生本事件\"允许编辑\"属性必须" 注释 = "为真.事件处理方法返回1则不允许进入编辑状态,返回0允许进入.">
    参数 表项索引 <类型 = 整数 注释 = "提供即将进入编辑状态的表项的索引位置,从0开始.">

    方法 结束编辑 <公开 定义事件 类型 = 整数 注释 = "  当表项结束标题编辑状态前产生此事件,要产生本事件\"允许编辑\"" 注释 = "属性必须为真. 事件处理方法返回1不允许使用编辑后的内容替换原"
            注释 = "有标题,返回0则允许替换.">
    参数 表项索引 <类型 = 整数 注释 = "提供即将结束编辑状态的表项的索引位置,从0开始.">
    参数 结束编辑文本 <类型 = 文本型 注释 = "标题被编辑后的内容">

    方法 开始子项编辑 <公开 定义事件 类型 = 整数 注释 = "  当表项进入标题编辑状态前产生此事件,要产生本事件\"允许编辑子项目\"属性必须" 注释 = "为真.事件处理方法返回1则不允许进入编辑状态,返回0允许进入.">
    参数 表项索引 <类型 = 整数 注释 = "提供即将进入编辑状态的表项的索引位置,从0开始.">
    参数 列索引 <类型 = 整数 注释 = "提供即将进入编辑状态的子项的列索引位置,从0开始.">

    方法 结束子项编辑 <公开 定义事件 类型 = 整数 注释 = "  当报表型列表框中子项结束标题编辑状态前产生此事件,要产生本事件\"允许编辑子项目\""
            注释 = "属性必须为真. 事件处理方法返回1不允许使用编辑后的内容替换原有标题,返回0则允许替换.">
    参数 表项索引 <类型 = 整数 注释 = "提供即将结束编辑状态的子项的行索引位置,从0开始.">
    参数 列索引 <类型 = 整数 注释 = "提供即将结束编辑状态的子项的列索引位置,从0开始.">
    参数 结束编辑文本 <类型 = 文本型 注释 = "子项标题被编辑后的内容">

    方法 检查框状态被改变 <公开 定义事件 类型 = 整数 注释 = "  当用户操作(如被鼠标单击/双击/右击,或按下键盘空格键)导致检查框" 注释 = "选中状态被改变时产生此事件. 仅在属性\"是否有检查框\"值为真的情况下"
            注释 = "才可能产生此事件.通过代码设置检查框状态不会触发此事件.">
    参数 表项索引 <类型 = 整数 注释 = "提供其检查框状态发生变化的表项索引位置,从0开始.">
    参数 检查框状态 <类型 = 整数 注释 = "0:未选中; 1:选中; 如果为当前列表框开启了虚拟化数据则始终为-1.">

    方法 即将绘制 <公开 定义事件 类型 = 整数 注释 = "  在超级列表框即将绘制某项目之前被发送,用户可以修改所提供参数中的" 注释 = "\"文本颜色\"和\"背景颜色\"成员值以修改在绘制时所实际使用的颜色值.">
    参数 绘制参数 <类型 = 超级列表框绘制参数 注释 = "  用户可以修改本参数中的\"文本颜色\"和\"背景颜色\"成员值以修改在绘制" 注释 = "时所实际使用的颜色值."
            注释 = "  注意: 如果修改了本参数中的\"文本颜色\"和\"背景颜色\"成员值,将会对" 注释 = "当前表项的当前列及其后所有列均造成影响.">

    方法 虚拟表项填充 <公开 定义事件 类型 = 整数 注释 = "  在超级列表框即将绘制某虚拟项目之前被发送,用户可以修改所提供参数中的\"项目文本\"、\"表项数值\"、"
            注释 = "\"图片索引\"和\"检查框状态\"成员值以修改在绘制时所实际使用的表项数据." 注释 = "  本事件仅当\"虚拟化数据\"属性为真时才会发送.">
    参数 表项参数 <类型 = 超级列表框表项填充 注释 = "  用户可以修改本参数中的\"项目文本\"、\"表项数值\"、\"图片索引\"和\"检查框状态\"成员值以修改在绘制" 注释 = "时所实际使用的表项数据."
            注释 = "  注意: 如果修改了本参数中的\"项目文本\"、\"表项数值\"、\"图片索引\"和\"检查框状态\"成员值,将会对" 注释 = "当前表项的当前列及其后所有列均造成影响.">

    # 属性 --

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ListView*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtr ();
        @ pWnd->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetTextColor (pWnd->m_clrText);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 文本背景色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本背景颜色值" @嵌入式方法 = "">
