        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_clrCaptionText
    }

    方法 标题文本颜色 <公开 属性写 注释 = "设置本组件的标题文本颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件标题文本颜色.">
    {
        @ ((CVWnd_AdvGroupBox*)GetMfcWndPtr ())->SetTextColor ((COLORREF)@<所欲设置颜色值>);
    }
}

