    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->CanPaste ());
    }

    方法 加入文本 <公开 注释 = "将所指定文本加入到编辑框尾部">
    参数 所欲加入的文本 <类型 = 文本型 注释 = "提供所欲加入的文本内容">
    参数 所欲设置的字符格式 <类型 = 超级编辑框字符格式 注释 = "提供所加入文本的字符格式,如为空对象表示使用当前所设置的默认字符格式." @默认值 = 空对象>
    参数 所欲设置的段落格式 <类型 = 超级编辑框段落格式 注释 = "提供所加入文本的段落格式,如为空对象表示无." @默认值 = 空对象>
    参数 自动滚动到尾部 <类型 = 逻辑型 注释 = "指定加入文本后是否自动将编辑框内容滚动到尾部" @默认值 = 真>
    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd == NULL || @<所欲加入的文本>.IsEmpty ())
        @     return;
        @ const INT nOldNumRows = pWnd->GetLineCount ();
        @ LONG lFirstIndex = pWnd->GetTextLength (), l;
        @ pWnd->SetSel (lFirstIndex, lFirstIndex);
        @ pWnd->GetSel (l, lFirstIndex);
        @ pWnd->ReplaceSel (@<所欲加入的文本>.GetText (), FALSE);
        @ const LONG lNewTextLength = pWnd->GetTextLength ();
        @ CHARFORMAT cf;
        @ if (@<所欲设置的字符格式>.IsNullObject ())
        @ {
        @     ZERO_MEM (&cf, sizeof (cf));
        @     cf.cbSize = sizeof (cf);
        @     cf.dwMask = CFM_ALL;
        @     pWnd->GetDefaultCharFormat (cf);
        @ }
        @ else
        @     sVol2CharFormat (&@<所欲设置的字符格式>, &cf);
        @ pWnd->SetSel (lFirstIndex, lNewTextLength);
        @ pWnd->SetSelectionCharFormat (cf);
        @ if (@<所欲设置的段落格式>.IsNullObject () == FALSE)
        @ {
        @     pWnd->SetSel (lFirstIndex, lNewTextLength);
        @     PARAFORMAT2 pf;
        @     sVol2ParaFormat (&@<所欲设置的段落格式>, &pf);
        @     pWnd->SetParaFormat (pf);
        @ }
        @ pWnd->SetSel (lNewTextLength, lNewTextLength);
        @ if (@<自动滚动到尾部>)
        @     pWnd->LineScroll (pWnd->GetLineCount () - nOldNumRows, 0);
    }

    方法 加入文本行 <公开 注释 = "将所指定文本行加入到编辑框的尾部">
    参数 所欲加入的文本 <类型 = 文本型>
    参数 所欲设置的字符格式 <类型 = 超级编辑框字符格式 注释 = "提供所加入文本的字符格式,如为空对象表示使用当前所设置的默认字符格式." @默认值 = 空对象>
    参数 所欲设置的段落格式 <类型 = 超级编辑框段落格式 注释 = "提供所加入文本的段落格式,如为空对象表示无." @默认值 = 空对象>
    参数 自动滚动到尾部 <类型 = 逻辑型 注释 = "指定加入文本后是否自动将编辑框内容滚动到尾部" @默认值 = 真>
    {
        加入文本 (所欲加入的文本 + "\r\n", 所欲设置的字符格式, 所欲设置的段落格式, 自动滚动到尾部)
    }

    方法 选择文本 <公开 注释 = "选择编辑框中所指定区域内的文本">
    参数 起始字符索引 <类型 = 整数 注释 = "提供所欲选择区域的首字符索引位置,从0开始.">
    参数 所被选择的字符数 <类型 = 整数 注释 = "提供所欲选择区域中的字符数目,为-1表示选择编辑框中的所有内容.">
    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<所被选择的字符数> < 0)
        @         pWnd->SetSel (0, -1);
        @     else
        @         pWnd->SetSel (@<起始字符索引>, @<起始字符索引> + @<所被选择的字符数>);
        @ }
    }

    方法 取选择文本 <公开 类型 = 文本型 注释 = "返回当前被选择的文本">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     @<结果变量>.SetText (pWnd->GetSelText ());
        返回 (结果变量)
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnChange () override  { @<内容被改变> (); }
    # virtual void OnSelChange () override  { @<选择区被改变> (); }
    # static void sCharFormat2Vol (const CHARFORMAT* pcf, @dt<超级编辑框字符格式>* pInf);
    # static void sVol2CharFormat (const @dt<超级编辑框字符格式>* pInf, CHARFORMAT* pcf);
    # static void sParaFormat2Vol (const PARAFORMAT2* ppf, @dt<超级编辑框段落格式>* pInf);
    # static void sVol2ParaFormat (const @dt<超级编辑框段落格式>* pInf, PARAFORMAT2* ppf);
