        @ pWnd->m_ilstItem.Attach ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲设置的图片组>));
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetImageList (&pWnd->m_ilstItem, (pWnd->m_nType == 0 ? TVSIL_NORMAL : LVSIL_SMALL));
