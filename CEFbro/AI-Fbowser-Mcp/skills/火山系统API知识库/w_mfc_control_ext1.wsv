        @     cf.cbSize = sizeof (cf);
        @     cf.dwMask = (CFM_BOLD | CFM_COLOR | CFM_FACE | CFM_ITALIC | CFM_OFFSET | CFM_PROTECTED | CFM_SIZE | CFM_STRIKEOUT | CFM_UNDERLINE);
        @     pWnd->GetDefaultCharFormat (cf);
        @     sCharFormat2Vol (&cf, &@<结果变量>);
        @ }
        返回 (结果变量)
    }

