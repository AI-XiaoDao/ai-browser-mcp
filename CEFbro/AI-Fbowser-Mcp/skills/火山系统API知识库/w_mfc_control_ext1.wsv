类 超级编辑框内容格式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 纯文本 <公开 值 = 0>
    常量 RTF丰富文本 <公开 值 = 1>
}

类 超级编辑框字符效果 <公开 @文档 = "category = \"辅助类\"">
{
    常量 粗体 <公开 类型 = 整数 值 = 1>
    常量 斜体 <公开 类型 = 整数 值 = 2>
    常量 下划线 <公开 类型 = 整数 值 = 4>
    常量 删除线 <公开 类型 = 整数 值 = 8>
    常量 禁止更改 <公开 类型 = 整数 值 = 16>
}

类 超级编辑框段落对齐方式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 段落居左 <公开 值 = 1>
    常量 段落居中 <公开 值 = 2>
    常量 段落居右 <公开 值 = 3>
}

类 超级编辑框字符格式 <公开 注释 = "本类用作指定超级编辑框中字符文本的表现格式" @文档 = "category = \"辅助类\"">
{
    变量 字体名称 <公开 类型 = 文本型 值 = "宋体">
    变量 字体大小 <公开 类型 = 整数 值 = 9 注释 = "单位为点(1/72英寸)">
    变量 纵向偏移 <公开 类型 = 整数 注释 = "  指定字符相对于基线的纵向偏移值,单位为点(1/72英寸).如果为正值," 注释 = "则字符表现为上标,如果为负值,则字符表现为下标.">
    变量 效果 <公开 类型 = 整数 注释 = "为\"超级编辑框字符效果\"类中各个常量值之一或之和,为0表示无效果.">
    变量 文本颜色 <公开 类型 = 整数 值 = 颜色类.默认色 注释 = "  指定字符显示时使用的前景颜色,可以使用\"颜色类\"所提供的颜色值," 注释 = "使用\"颜色类.默认色\"来指定使用Windows系统默认文本颜色.">
}

类 超级编辑框段落格式 <公开 注释 = "本类用作指定文本段落的表现格式" @文档 = "category = \"辅助类\"">
{
    变量 段落引导符 <公开 类型 = 逻辑型>
    变量 首行缩进 <公开 类型 = 整数 注释 = "指定段落首行相对于编辑框左边框的缩进量,单位为点(1/72英寸).">
    变量 非首行缩进 <公开 类型 = 整数 注释 = "指定段落中所有非首行相对于首行的缩进量,单位为点(1/72英寸),可为负数以达到首行缩进的效果.">
    变量 右边缩进 <公开 类型 = 整数 注释 = "指定段落右边相对于编辑框右边框的缩进量,单位为点(1/72英寸).">
    变量 对齐方式 <公开 类型 = 超级编辑框段落对齐方式 注释 = "指定段落的对齐方式">
    变量 ""
    变量 存在扩展信息 <公开 类型 = 逻辑型 注释 = "为真则表示下面的扩展信息成员变量有效,为假表示没有使用.">
    变量 上间距 <公开 类型 = 整数 注释 = "指定段落上方间距的尺寸,单位为点(1/72英寸). 有效值必须大于等于0. 注意本成员仅当\"存在扩展信息\"成员值为真时才会被使用.">
    变量 下间距 <公开 类型 = 整数 注释 = "指定段落下方间距的尺寸,单位为点(1/72英寸). 有效值必须大于等于0. 注意本成员仅当\"存在扩展信息\"成员值为真时才会被使用.">
    变量 行间距类型 <公开 类型 = 整数 注释 = "本成员的值指定\"行间距\"成员的值意义,具体为:" 注释 = "  0: 单间距. \"行间距\"成员被忽略;" 注释 = "  1: 1.5倍间距. \"行间距\"成员被忽略;"
            注释 = "  2: 双倍间距. \"行间距\"成员被忽略;" 注释 = "  3: \"行间距\"成员指定行之间距离的具体值(以1/72英寸为单位),但如果所指定的值小于单间距,将使用单行距;"
            注释 = "  4: \"行间距\"成员指定行之间距离的具体值(以1/72英寸为单位),即使所指定的值小于单间距;"
            注释 = "  5: \"行间距\"成员除以20后的值用作指定单间距的倍数. 譬如将\"行间距\"成员设置为 20 会使用单行距, 40 使用双倍间距, 60 使用三倍间距,以此类推."
            注释 = "注意本成员仅当\"存在扩展信息\"成员值为真时才会被使用.">
    变量 行间距 <公开 类型 = 整数 注释 = "指定段落中行之间的间距. 本成员的具体意义由\"行间距类型\"成员值决定. 注意本成员仅当\"存在扩展信息\"成员值为真时才会被使用.">
}

类 超级编辑框 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_rich_edit.h" @视窗.外部源文件 = "src\\mfc_ui_rich_edit.cpp"
        @视窗.后缀文本 = "public IRichEditEventListener" @视窗.窗口组件 = "icon=\"@47\"\r\ndefault_size = \"100, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_RichEdit, IRichEditEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 内容被改变 <公开 定义事件 类型 = 整数 注释 = "当编辑框的内容被修改后即产生此事件">

    方法 选择区被改变 <公开 定义事件 类型 = 整数 注释 = "当编辑框的当前选择区被改变后即产生此事件">

    # 属性 --

    方法 纯文本模式 <公开 属性读 类型 = 逻辑型 注释 = "返回当前编辑框是否使用纯文本模式,为真表示使用纯文本模式,为假表示使用丰富格式文本(默认模式)." @嵌入式方法 = "">
    {
        @ ((CVWnd_RichEdit*)@sn<this>.GetMfcWndPtr ())->m_blPlainTextMode
    }

    方法 纯文本模式 <公开 属性写 注释 = "设置当前编辑框是否使用纯文本模式,为真表示使用纯文本模式,为假表示使用丰富格式文本(默认模式)." 注释 = "注意: 设置了纯文本模式后就不能再使用丰富格式文本." @视窗.设置时机 = 组件创建前>
    参数 是否纯文本 <类型 = 逻辑型>
    {
        @ ((CVWnd_RichEdit*)GetMfcWndPtr ())->m_blPlainTextMode = @<是否纯文本>;
    }

    方法 内容格式 <公开 属性读 类型 = 超级编辑框内容格式 注释 = "返回对编辑框的内容进行读写时所使用的文本格式" @嵌入式方法 = "">
    {
        @ ((CVWnd_RichEdit*)@sn<this>.GetMfcWndPtr ())->m_nContentType
    }

    方法 内容格式 <公开 属性写 注释 = "设置对编辑框的内容进行读写时所使用的文本格式" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的格式 <类型 = 超级编辑框内容格式>
    {
        @ ((CVWnd_RichEdit*)GetMfcWndPtr ())->m_nContentType = CLIP (@<所欲设置的格式>, 0, 1);
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "返回编辑框中的当前内容,其格式由\"内容格式\"属性值决定.">
    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolString strContent;
        @     pWnd->GetContent (strContent, FALSE);
        @     return strContent;
        @ }
        返回 (标题)
    }

    方法 内容 <公开 属性写 注释 = "设置编辑框中的当前内容,其格式由\"内容格式\"属性值指定." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的内容 <类型 = 文本型 注释 = "本参数的内容格式由\"内容格式\"属性值指定">
    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtr ();
