    方法 寻找 <公开 类型 = 整数 注释 = "  在编辑框中寻找指定的文本,如找到则返回该文本首字符" 注释 = "所处的位置索引(从0开始),未找到则返回-1." @禁止流程检查 = 真>
    参数 起始寻找位置 <类型 = 整数 注释 = "参数值为以0开始的字符位置索引" @默认值 = 0>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定寻找时是否区分英文字母大小写" @默认值 = 真>
    参数 是否匹配单词 <类型 = 逻辑型 注释 = "指定寻找时是否只允许单词才能匹配" @默认值 = 假>
    参数 所欲寻找的文本 <类型 = 文本型>
    {
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd == NULL)
        @     return -1;
        @ DWORD dwFlags = 0;
        @ if (@<是否区分大小写>)  dwFlags |= FR_MATCHCASE;
        @ if (@<是否匹配单词>)  dwFlags |= FR_WHOLEWORD;
        @ FINDTEXTEX inf;
        @ inf.chrg.cpMin = MAX (0, @<起始寻找位置>);
        @ inf.chrg.cpMax = pWnd->GetTextLength ();
        @ inf.lpstrText = @<所欲寻找的文本>.GetText ();
        @ inf.chrgText.cpMin = 0;
        @ inf.chrgText.cpMax = -1;
        @ return pWnd->FindText (dwFlags | FR_DOWN, &inf);
    }

