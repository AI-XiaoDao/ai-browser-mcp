类 IP编辑框 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_ip_edit.h" @视窗.外部源文件 = "src\\mfc_ui_ip_edit.cpp"
        @视窗.后缀文本 = "public IIPEditEventListener" @视窗.窗口组件 = "icon=\"@67\"\r\ndefault_size = \"100, 20\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_IPEdit, IIPEditEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 地址被改变 <公开 定义事件 类型 = 整数 注释 = "编辑框中的地址被改变后本事件被发送">

    # 属性 --

    方法 地址 <公开 属性读 类型 = 文本型 注释 = "返回IP编辑框中的IP地址内容" @禁止流程检查 = 真>
    {
        @ CVWnd_IPEdit* pWnd = (CVWnd_IPEdit*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     if (pWnd->IsBlank ())
        @     {
        @         pWnd->m_strIP.Empty ();
        @     }
        @     else
        @     {
        @         BYTE fd1, fd2, fd3, fd4;
        @         fd1 = fd2 = fd3 = fd4 = 0;
        @         pWnd->GetAddress (fd1, fd2, fd3, fd4);
        @         pWnd->m_strIP.Format (_T ("%d.%d.%d.%d"), (INT)(DWORD)fd1, (INT)(DWORD)fd2, (INT)(DWORD)fd3, (INT)(DWORD)fd4);
        @     }
        @ }
        @ return pWnd->m_strIP;
    }

    方法 地址 <公开 属性写 注释 = "设置IP编辑框中的IP地址内容." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的IP <类型 = 文本型 注释 = "提供格式为\"x.x.x.x\"的IP地址文本,其中\"x\"为0到255之间的整数." 注释 = "如果所提供文本格式违规,则将把IP编辑框内容清空.">
    {
        @ CVWnd_IPEdit* pWnd = (CVWnd_IPEdit*)GetMfcWndPtr ();
        @ INT_P anpIP [4];
        @ if (CVWnd_IPEdit::sCheckIPAddress (@<所欲设置的IP>.GetText (), anpIP))
        @ {
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->SetAddress ((BYTE)anpIP [0], (BYTE)anpIP [1], (BYTE)anpIP [2], (BYTE)anpIP [3]);
        @     pWnd->m_strIP.Format (_T ("%d.%d.%d.%d"), (INT)anpIP [0], (INT)anpIP [1], (INT)anpIP [2], (INT)anpIP [3]);
        @ }
        @ else
        @ {
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->ClearAddress ();
        @     pWnd->m_strIP.Empty ();
        @ }
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnChange () override  { @<地址被改变> (); }
    # <> </include>
    # @end
}

