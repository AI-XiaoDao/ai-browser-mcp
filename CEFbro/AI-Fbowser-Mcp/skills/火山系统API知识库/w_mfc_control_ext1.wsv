        @ {
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = LVCF_FMT;
        @     return (pWnd->GetColumn (@<列索引>, &col) && (col.fmt & LVCFMT_BITMAP_ON_RIGHT) != 0);
