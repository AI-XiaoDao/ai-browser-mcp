{
    常量 最小 <公开 值 = 0>
    常量 较小 <公开 值 = 1>
    常量 中等 <公开 值 = 2>
    常量 较大 <公开 值 = 3>
    常量 最大 <公开 值 = 4>
}

类 IE浏览框命令 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 前进 <公开 值 = 0>
    常量 后退 <公开 值 = 1>
    常量 到首页 <公开 值 = 2>
    常量 到搜索页 <公开 值 = 3>
    常量 刷新 <公开 值 = 4>
    常量 停止 <公开 值 = 5>
    常量 另存为 <公开 值 = 6>
