        @ pWnd->m_clrTextBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetTextBkColor (GetRealBackColor (pWnd->m_clrTextBack));
        @     pWnd->Invalidate ();
        @ }
    }

