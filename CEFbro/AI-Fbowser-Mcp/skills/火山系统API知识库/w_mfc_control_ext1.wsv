        @         return (INT)pWnd->GetItemData (hItem);
        @ }
        @ return 0;
    }

    方法 置项目文本 <公开 类型 = 逻辑型 注释 = "设置指定项目的文本,返回是否成功." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    参数 所欲设置的文本 <类型 = 文本型>
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         return pWnd->SetItemText (hItem, @<所欲设置的文本>.GetText ());
        @ }
        @ return FALSE;
    }

    方法 置图片 <公开 类型 = 逻辑型 注释 = "设置在指定项目首部所显示图片的索引,返回是否成功." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    参数 所欲设置的图片索引 <类型 = 整数 注释 = "用于指定图片组属性中的某张图片,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @     {
        @         INT nImageIndex, nSelImageIndex;
        @         if (pWnd->GetItemImage (hItem, nImageIndex, nSelImageIndex))
        @             return pWnd->SetItemImage (hItem, MAX (0, @<所欲设置的图片索引>), nSelImageIndex);
        @     }
        @ }
        @ return FALSE;
    }

