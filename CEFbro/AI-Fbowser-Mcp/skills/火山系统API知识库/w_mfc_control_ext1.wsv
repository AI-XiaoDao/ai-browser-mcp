类 超级链接类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 电子信箱地址 <公开 值 = 0>
    常量 Internet地址 <公开 值 = 1>
}

类 超级链接框 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_hyperlink.h" @视窗.外部源文件 = "src\\mfc_ui_hyperlink.cpp"
        @视窗.后缀文本 = "public IHyperLinkEventListener" @视窗.窗口组件 = "icon=\"@64\"\r\ndefault_size = \"100, 24\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_HyperLink, IHyperLinkEventListener, 0, 0, 0, 0)
    #
    # 事件 --

    方法 开始跳转 <公开 定义事件 类型 = 整数 注释 = "当本组件进行跳转(被单击或执行\"跳转\"方法)时发送本事件" 返回值注释 = "返回1表示已经处理不再进行后续默认处理,返回0表示未处理,此时将进行后续默认跳转处理.">
    参数 所欲跳转到地址 <类型 = 文本型 注释 = "提供所欲跳转到的地址,必定不为空文本.">

    # 属性 --

    方法 类型 <公开 属性读 类型 = 超级链接类型 注释 = "返回当前超级链接文本的类型" @嵌入式方法 = "">
    {
        @ ((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_nType
    }

    方法 类型 <公开 属性写 注释 = "设置当前超级链接文本的类型" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的类型 <类型 = 超级链接类型>
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_nType = CLIP (@<所欲设置的类型>, 0, 1);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 电子信箱地址 <公开 属性读 类型 = 文本型 注释 = "返回当前所设置的电子信箱地址,仅当\"类型\"属性为\"超级链接类型.电子信箱地址\"时有效." @嵌入式方法 = "">
    {
        @ ((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_strEmail
    }

    方法 电子信箱地址 <公开 属性写 注释 = "设置电子信箱地址,仅当\"类型\"属性为\"超级链接类型.电子信箱地址\"时有效." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的地址 <类型 = 文本型>
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_strEmail.SetText (@<所欲设置的地址>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 Internet地址 <公开 属性读 类型 = 文本型 注释 = "返回当前所设置的Internet地址,仅当\"类型\"属性为\"超级链接类型.Internet地址\"时有效." @嵌入式方法 = "">
    {
        @ ((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_strURL
    }

    方法 Internet地址 <公开 属性写 注释 = "设置Internet地址,仅当\"类型\"属性为\"超级链接类型.Internet地址\"时有效." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的地址 <类型 = 文本型>
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_strURL.SetText (@<所欲设置的地址>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回正常情况下时的文本显示颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_clrLink
    }

    方法 文本颜色 <公开 属性写 注释 = "设置正常情况下时的文本显示颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_clrLink = @<所欲设置颜色值>;
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 访问后颜色 <公开 属性读 类型 = 整数 注释 = "返回被访问过后的文本显示颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_clrVisited
    }

    方法 访问后颜色 <公开 属性写 注释 = "设置被访问过后的文本显示颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_clrVisited = @<所欲设置颜色值>;
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 热点颜色 <公开 属性读 类型 = 整数 注释 = "返回鼠标移动到组件上时的文本显示颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_clrHover
    }

    方法 热点颜色 <公开 属性写 注释 = "设置鼠标移动到组件上时的文本显示颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_clrHover = @<所欲设置颜色值>;
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回组件背景颜色" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置组件背景颜色" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CVWnd_HyperLink* pWnd = (CVWnd_HyperLink*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = @<所欲设置颜色值>;
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    # 方法 --

    方法 跳转 <公开 类型 = 逻辑型 注释 = "跳转到当前所指定的超级链接地址." 注释 = "注意: 本方法亦会触发\"开始跳转\"事件." 返回值注释 = "返回是否成功跳转" @嵌入式方法 = "">
    {
        @ ((CVWnd_HyperLink*)@sn<this>.GetMfcWndPtr ())->GotoURL ()
    }

    # --
    # @begin
    # <> <include>
    # virtual BOOL OnGoto (const TCHAR* szURL) override  { return (@<开始跳转> (CVolString (szURL)) != 0); }
    # <> </include>
    # @end
}

