    方法 报表列 <公开 属性写 注释 = "初始设置报表列表框中各列的信息." 注释 = "注意:报表列表框只有在设置了列后才能显示出其中的内容" @视窗.设置时机 = 组件创建前 @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nListViewManager\r\n0">
    参数 所欲设置的报表列 <类型 = 文本型 注释 = "每列信息为以\'\\n\'字符分隔的字段,各个字段的意义为:" 注释 = "  1. 整数: 图标是否位于右边;" 注释 = "  2. 整数: 图标索引;"
            注释 = "  3. 整数: 对齐方式: 0:居左; 1:居中; 2:居右;" 注释 = "  4. 整数: 列宽度;" 注释 = "  5. 文本: 标题." 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_ListView*)GetMfcWndPtr ())->m_strCols.SetText (@<所欲设置的报表列>);
    }

