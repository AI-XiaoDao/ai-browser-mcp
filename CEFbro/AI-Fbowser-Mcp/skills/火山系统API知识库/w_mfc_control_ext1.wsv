    # @begin
    # <> <include>
    # virtual void OnButtonClick (INT nButtonIndex) override  { @<被单击> (nButtonIndex); }
    # virtual void OnDropDown (INT nButtonIndex, INT xPos, INT yPos) override  { @<被下拉> (nButtonIndex, xPos, yPos); }
    # <> </include>
    # @end
}

# ===

类 状态条位置 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 底边 <公开 值 = 0>
    常量 顶边 <公开 值 = 1>
    常量 自由 <公开 值 = 2>
}

类 状态条栏目外观类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 凹入 <公开 值 = 0>
    常量 无边框 <公开 值 = 1>
    常量 凸出 <公开 值 = 2>
}

类 状态条 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_stat_bar.h" @视窗.外部源文件 = "src\\mfc_ui_stat_bar.cpp"
        @视窗.后缀文本 = "public IBaseEventListener" @视窗.窗口组件 = "icon=\"@32\"\r\ndefault_size = \"120, 30\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_StatBar, IBaseEventListener, 0, 0, 0, 0)
    #
    # 属性 --

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件本身的背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件本身的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetBkColor (GetRealBackColor (pWnd->m_clrBack));
    }

    方法 位置 <公开 属性读 类型 = 状态条位置 注释 = "返回状态条的显示位置" @嵌入式方法 = "">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->m_nPosition
    }

    方法 位置 <公开 属性写 注释 = "设置状态条的显示位置" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的位置 <类型 = 状态条位置>
    {
        @ ((CVWnd_StatBar*)GetMfcWndPtr ())->m_nPosition = CLIP (@<所欲设置的位置>, 0, 2);
    }

    方法 尺寸调节器 <公开 属性读 类型 = 逻辑型 注释 = "返回是否在状态条右边提供用于调节窗口尺寸的调节器" @嵌入式方法 = "">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->m_blSizeGrip
    }

    方法 尺寸调节器 <公开 属性写 注释 = "  设置是否在状态条右边提供用于调节窗口尺寸的调节器,注意尺寸调节器" 注释 = "仅当窗口的边框可调(即为非固定边框)并且状态条位置在底边时才有效." @视窗.设置时机 = 组件创建前>
    参数 是否提供尺寸调节器 <类型 = 逻辑型>
    {
        @ ((CVWnd_StatBar*)GetMfcWndPtr ())->m_blSizeGrip = @<是否提供尺寸调节器>;
    }

    方法 图片组 <公开 属性写 注释 = "本属性为状态条各栏目提供标志图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组 <类型 = 图片组资源 注释 = "对图片组图片格式的要求请参见\"图片组资源\"类中的说明">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_illstColumns.DeleteImageList ();
        @ pWnd->m_illstColumns.Attach ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲设置的图片组>));
        @ pWnd->Fill ();
    }

    方法 图片组文件 <公开 属性写 注释 = "本属性为状态条各栏目提供标志图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组文件 <类型 = 文本型 注释 = "  提供用作保存图片组的图片文件名,该图片文件的格式必须符合" 注释 = "\"图片组资源\"类中所说明的要求.">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_illstColumns.DeleteImageList ();
        @ pWnd->m_illstColumns.Attach ((HIMAGELIST)g_objVolApp.LoadResImageFile (VRIT_IMAGE_LIST, @<所欲设置的图片组文件>.GetText ()));
        @ pWnd->Fill ();
    }

    方法 置图片组 <公开 注释 = "设置状态条各栏目所使用的标志图片">
    参数 所欲设置的图片组 <类型 = 图片组对象类 注释 = "注意该参数对象内的图片组将被移交给本对象管理">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_illstColumns.DeleteImageList ();
        @ pWnd->m_illstColumns.Attach ((HIMAGELIST)@<所欲设置的图片组>.DetachGDIHandle ());
        @ pWnd->Fill ();
    }

    方法 项目 <公开 属性读 类型 = 文本型 注释 = "返回状态条各栏目的信息" @嵌入式方法 = "">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->m_strColumns
    }

    方法 项目 <公开 属性写 注释 = "设置状态条各栏目的信息" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nStatBarManager\r\n0">
    参数 所欲设置的栏目 <类型 = 文本型 注释 = "每列信息为以\'\\n\'字符分隔的字段,各个字段的意义为:" 注释 = "  1. 整数: 宽度. 为-1表示本列右侧一直到组件的最右侧"
            注释 = "  2. 整数: 类型; 可以为以下值之一: 0 / SBT_NOBORDERS / SBT_POPOUT." 注释 = "  3. 整数: 记录图片组中的图片索引. -1表示本栏目无图片标志."
            注释 = "  4. 文本: 标题" 注释 = "  5. 文本: 提示" 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_strColumns.SetText (@<所欲设置的栏目>);
        @ pWnd->Fill ();
    }

    # 方法 --

    方法 清空 <公开 注释 = "删除状态条中的所有栏目">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ pWnd->m_strColumns.Empty ();
        @ pWnd->Fill ();
    }

    方法 更新位置 <公开 注释 = "如果状态条所处父窗口的尺寸被改变,需要调用本方法动态更新其实时位置." @嵌入式方法 = "">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->AutoSize ()
    }

    方法 加入栏目 <公开 类型 = 整数 注释 = "将指定栏目加入到状态条中,返回加入后该项目所处的索引位置." @禁止流程检查 = 真>
    参数 栏目文本 <类型 = 文本型 注释 = "提供栏目中的文本内容" @默认值 = "">
    参数 宽度 <类型 = 整数 注释 = "单位为像素,-1表示一直到窗口的最右边." @默认值 = 50>
    参数 提示文本 <类型 = 文本型 注释 = "提示文本仅当栏目只有图片但没有内容文本或者内容文本不能被全部显示的情况下才有效" @默认值 = "">
    参数 图片索引 <类型 = 整数 注释 = "用于指定图片组属性中的某张图片,该图片将被显示在栏目的首部. 索引值从0开始,-1表示无图片." @默认值 = -1>
    参数 外观类型 <类型 = 状态条栏目外观类型 注释 = "指定栏目的显示外观类型" @默认值 = 状态条栏目外观类型.凹入>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ const INT_P npNumColumns = pWnd->GetNumColumns ();
        @ if (pWnd->m_strColumns.IsEmpty () == FALSE)
        @     pWnd->m_strColumns.AddChar ('\n');
        @ pWnd->m_strColumns.AddIntText (MAX (-1, @<宽度>));
        @ pWnd->m_strColumns.AddChar ('\n');
        @ pWnd->m_strColumns.AddIntText (@<外观类型> == 1 ? SBT_NOBORDERS : @<外观类型> == 2 ? SBT_POPOUT : 0);
        @ pWnd->m_strColumns.AddChar ('\n');
        @ pWnd->m_strColumns.AddIntText (MAX (-1, @<图片索引>));
        @ pWnd->m_strColumns.AddChar ('\n');
        @ pWnd->m_strColumns.AddText (@<栏目文本>);
        @ pWnd->m_strColumns.AddChar ('\n');
        @ pWnd->m_strColumns.AddText (@<提示文本>);
        @ pWnd->Fill ();
        @ return (INT)npNumColumns;
    }

    方法 删除栏目 <公开 注释 = "删除指定位置处的栏目">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     saryFields.RemoveAt (npFieldIndex, 5);
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     pWnd->Fill ();
        @ }
    }

    方法 取栏目数 <公开 类型 = 整数 注释 = "返回状态条中栏目的总数" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetNumColumns ()
    }

    方法 取文本 <公开 类型 = 文本型 注释 = "返回指定栏目的内容文本">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        变量 结果文本 <类型 = 文本型>
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = ((CVWnd_StatBar*)GetMfcWndPtr ())->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @     @<结果文本>.SetText (saryFields [npFieldIndex + 3]);
        返回 (结果文本)
    }

    方法 取提示文本 <公开 类型 = 文本型 注释 = "返回指定栏目的提示文本">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        变量 结果文本 <类型 = 文本型>
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = ((CVWnd_StatBar*)GetMfcWndPtr ())->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @     @<结果文本>.SetText (saryFields [npFieldIndex + 4]);
        返回 (结果文本)
    }

    方法 取宽度 <公开 类型 = 整数 注释 = "返回指定栏目的宽度(单位为像素),-1表示一直到窗口的最右边." @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = ((CVWnd_StatBar*)GetMfcWndPtr ())->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ return (npFieldIndex != -1 ? _ttoi (saryFields [npFieldIndex]) : 0);
    }

    方法 取类型 <公开 类型 = 状态条栏目外观类型 注释 = "返回指定栏目的外观类型" @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = ((CVWnd_StatBar*)GetMfcWndPtr ())->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex == -1)
        @     return 0;
        @ const INT_P npType = _ttoi (saryFields [npFieldIndex + 1]);
        @ return (npType == SBT_NOBORDERS ? 1 : npType == SBT_POPOUT ? 2 : 0);
    }

    方法 取图片 <公开 类型 = 整数 注释 = "  返回指定栏目的图片索引,图片索引指向图片组属性中" 注释 = "的某一图片,从0开始,-1表示本栏目无图片标志." @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = ((CVWnd_StatBar*)GetMfcWndPtr ())->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ return (npFieldIndex != -1 ? _ttoi (saryFields [npFieldIndex + 2]) : -1);
    }

    方法 取栏目左边 <公开 类型 = 整数 注释 = "返回指定栏目在状态条中显示区域的左边位置,单位为像素." @嵌入式方法 = "">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetColumnRect (@<栏目索引>).left
    }

    方法 取栏目顶边 <公开 类型 = 整数 注释 = "返回指定栏目在状态条中显示区域的顶边位置,单位为像素." @嵌入式方法 = "">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetColumnRect (@<栏目索引>).top
    }

    方法 取栏目宽度 <公开 类型 = 整数 注释 = "返回指定栏目在状态条中显示区域的宽度,单位为像素." @嵌入式方法 = "">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetColumnRect (@<栏目索引>).Width ()
    }

    方法 取栏目高度 <公开 类型 = 整数 注释 = "返回指定栏目在状态条中显示区域的高度,单位为像素." @嵌入式方法 = "">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ ((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetColumnRect (@<栏目索引>).Height ()
    }

    方法 取栏目矩形 <公开 类型 = 矩形类 注释 = "返回指定栏目在状态条中显示区域的矩形位置,单位为像素." @嵌入式方法 = "">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    {
        @ @dt<矩形类> (&((CVWnd_StatBar*)@sn<this>.GetMfcWndPtr ())->GetColumnRect (@<栏目索引>))
    }

    方法 置文本 <公开 注释 = "设置指定栏目的内容文本">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    参数 所欲设置的文本 <类型 = 文本型>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     saryFields.SetAt (npFieldIndex + 3, @<所欲设置的文本>.GetText ());
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->SetText (@<所欲设置的文本>.GetText (), (INT)@<栏目索引>, _ttoi (saryFields [npFieldIndex + 1]));
        @ }
    }

    方法 置提示文本 <公开 注释 = "设置指定栏目的提示文本">
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    参数 所欲设置的提示文本 <类型 = 文本型>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     saryFields.SetAt (npFieldIndex + 4, @<所欲设置的提示文本>.GetText ());
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->SetTipText ((INT)@<栏目索引>, @<所欲设置的提示文本>.GetText ());
        @ }
    }

    方法 置宽度 <公开 注释 = "设置指定栏目的宽度(单位为像素),-1表示一直到窗口的最右边." @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    参数 所欲设置的宽度 <类型 = 整数 注释 = "单位为像素,-1表示一直到窗口的最右边." @默认值 = 50>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     CVolString str;
        @     str.AddIntText (MAX (-1, @<所欲设置的宽度>));
        @     saryFields.SetAt (npFieldIndex, str.GetText ());
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     pWnd->Fill ();
        @ }
    }

    方法 置类型 <公开 注释 = "设置指定栏目的外观类型" @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    参数 所欲设置的外观类型 <类型 = 状态条栏目外观类型 注释 = "指定栏目的显示外观类型" @默认值 = 状态条栏目外观类型.凹入>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     const INT_P npType = (@<所欲设置的外观类型> == 1 ? SBT_NOBORDERS : @<所欲设置的外观类型> == 2 ? SBT_POPOUT : 0);
        @     CVolString str;
        @     str.SetIntPText (npType);
        @     saryFields.SetAt (npFieldIndex + 1, str.GetText ());
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->SetText (saryFields [npFieldIndex + 3], (INT)@<栏目索引>, (INT)npType);
        @ }
    }

    方法 置图片 <公开 注释 = "设置指定栏目的图片索引" @禁止流程检查 = 真>
    参数 栏目索引 <类型 = 整数 注释 = "提供所欲操作栏目的索引位置,从0开始.">
    参数 所欲设置的图片索引 <类型 = 整数 注释 = "用于指定图片组属性中的某张图片,该图片将被显示在栏目的首部. 索引值从0开始,-1表示无图片." @默认值 = -1>
    {
        @ CVWnd_StatBar* pWnd = (CVWnd_StatBar*)GetMfcWndPtr ();
        @ CMStringArray saryFields;
        @ const INT_P npFieldIndex = pWnd->GetColumnFieldIndex (@<栏目索引>, saryFields);
        @ if (npFieldIndex != -1)
        @ {
        @     const INT nImageIndex = MAX (-1, @<所欲设置的图片索引>);
        @     CVolString str;
        @     str.AddIntText (nImageIndex);
        @     saryFields.SetAt (npFieldIndex + 2, str.GetText ());
        @     ComboStrings (saryFields, pWnd->m_strColumns, '\n', FALSE);
        @     if (pWnd->m_hWnd != NULL)
        @         pWnd->SetColumnIcon (@<栏目索引>, nImageIndex);
        @ }
    }
}

# ===

类 超级按钮风格 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 平面风格 <公开 值 = 0>
    常量 立体风格 <公开 值 = 1>
    常量 XP风格 <公开 值 = 2>
}

类 超级按钮对齐方式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 图左文右 <公开 值 = 0>
    常量 图上文下 <公开 值 = 1>
    常量 图右文左 <公开 值 = 2>
    常量 图文混排 <公开 值 = 3>
}

类 超级按钮压入方式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 从左到右 <公开 值 = 0>
    常量 从上到下 <公开 值 = 1>
}

类 超级按钮 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_supper_btn.h"
        @视窗.外部源文件 = "src\\mfc_ui_supper_btn.cpp\r\nsrc\\supper_btn\\vol_supper_btn.cpp"
        @视窗.后缀文本 = "public ISupperButtonEventListener" @视窗.外部资源文件 = "src\\res\\vol_super_btn.rc"
        @视窗.窗口组件 = "icon=\"@2\"\r\ndefault_size = \"80, 32\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_SupperButton, ISupperButtonEventListener, 0, 0, WS_TABSTOP | BS_PUSHBUTTON | BS_MULTILINE, 0)
    #

    方法 被单击 <公开 定义事件 类型 = 整数 注释 = "当按钮被单击后发送此事件">

    # 属性 --

    方法 按钮类型 <公开 属性读 类型 = 按钮类型 注释 = "返回按钮的当前类型" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & BS_DEFPUSHBUTTON) == 0 ? BS_PUSHBUTTON : BS_DEFPUSHBUTTON
    }

    方法 按钮类型 <公开 属性写 注释 = "设置按钮的当前类型" @视窗.设置时机 = 组件创建前>
    参数 所欲设置的类型 <类型 = 按钮类型>
    {
        @ GetMfcWndObject ()->m_dwAttrInitialStyle = ((GetMfcWndObject ()->m_dwAttrInitialStyle & ~BS_TYPEMASK) | (@<所欲设置的类型> & (BS_DEFPUSHBUTTON | BS_PUSHBUTTON)));
    }

    方法 按钮风格 <公开 属性读 类型 = 超级按钮风格 注释 = "返回当前按钮风格" @嵌入式方法 = "">
    {
        @ ((CVWnd_SupperButton*)@sn<this>.GetMfcWndPtr ())->m_nBtnStyle
    }

    方法 按钮风格 <公开 属性写 注释 = "设置当前按钮风格" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的风格 <类型 = 超级按钮风格>
    {
        @ CVWnd_SupperButton* pWnd = (CVWnd_SupperButton*)GetMfcWndPtr ();
        @ pWnd->m_nBtnStyle = CLIP (@<所欲设置的风格>, 0, 2);
        @ switch (pWnd->m_nBtnStyle)
        @ {
        @ case 1:  pWnd->m_bIsFlat = FALSE; pWnd->m_bIsXPButton = FALSE; break;
        @ case 2:  pWnd->m_bIsFlat = TRUE; pWnd->m_bIsXPButton = TRUE; break;
        @ default:  pWnd->m_bIsFlat = TRUE; pWnd->m_bIsXPButton = FALSE; break;
        @ }
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 选择框方式 <公开 属性读 类型 = 逻辑型 注释 = "返回按钮是否以选择框方式工作" @嵌入式方法 = "">
    {
        @ ((CVWnd_SupperButton*)@sn<this>.GetMfcWndPtr ())->m_blIsCheckBox
    }

    方法 选择框方式 <公开 属性写 注释 = "设置按钮是否以选择框方式工作" @视窗.设置时机 = 组件创建前>
    参数 是否为选择框方式 <类型 = 逻辑型>
    {
        @ ((CVWnd_SupperButton*)GetMfcWndPtr ())->m_blIsCheckBox = @<是否为选择框方式>;
    }

    方法 选中 <公开 属性读 类型 = 逻辑型 注释 = "当\"选择框方式\"属性为真时,返回当前是否已被选中." @禁止流程检查 = 真>
    {
        @ CVWnd_SupperButton* pWnd = (CVWnd_SupperButton*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd == NULL ? pWnd->m_blChecked : (pWnd->GetCheck () == 1));
    }

    方法 选中 <公开 属性写 注释 = "当\"选择框方式\"属性为真时,设置当前是否已被选中." @视窗.设置时机 = 组件创建前后>
    参数 是否选中 <类型 = 逻辑型>
    {
        @ CVWnd_SupperButton* pWnd = (CVWnd_SupperButton*)GetMfcWndPtr ();
        @ pWnd->m_blChecked = @<是否选中>;
        @ pWnd->m_nCheck = (pWnd->m_blChecked ? 1 : 0);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 对齐方式 <公开 属性读 类型 = 超级按钮对齐方式 注释 = "返回按钮中图片和文本的对齐方式" @嵌入式方法 = "">
    {
