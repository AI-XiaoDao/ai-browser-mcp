<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.扩展组件1 <注释 = "本程序提供视窗项目MFC扩展界面支持功能" 编辑时信息 = "17953D, 0, 0, 0">

类 GIF动画框 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_gif_wnd.h"
        @视窗.外部源文件 = "src\\mfc_ui_gif_wnd.cpp\r\nsrc\\gif\\PictureEx.cpp" @视窗.后缀文本 = "public IBaseEventListener"
        @视窗.窗口组件 = "icon=\"@38\"\r\ndefault_size = \"120, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_GifWnd, IBaseEventListener, WS_BORDER, 0, 0, 0)

    方法 底色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_GifWnd*)@sn<this>.GetMfcWndPtr ())->m_clrCtrlBackground
    }

    方法 底色 <公开 属性写 注释 = "设置本组件的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_GifWnd*)pWnd)->m_clrCtrlBackground = ::GetRealBackColor ((COLORREF)@<所欲设置颜色值>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 图片放置方式 <公开 属性读 类型 = 图片放置方式 注释 = "返回本组件上图片的放置方式" @嵌入式方法 = "">
    {
        @ ((CVWnd_GifWnd*)@sn<this>.GetMfcWndPtr ())->m_nBackPicPaintMode
    }

    方法 图片放置方式 <公开 属性写 注释 = "设置本组件上图片的放置方式" @视窗.设置时机 = 组件创建前后>
    参数 放置方式 <类型 = 图片放置方式>
    {
        @ CWnd* pWnd = GetMfcWndPtr ();
        @ ((CVWnd_GifWnd*)pWnd)->m_nBackPicPaintMode = @<放置方式>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 图片 <公开 属性写 注释 = "设置显示在本组件上的GIF图片" @视窗.设置时机 = 组件创建后>
    参数 所欲设置的图片 <类型 = 位图资源 注释 = "提供所欲设置的GIF图片资源,如果该资源值为\"空资源.空位图\",则将清除已有图片.">
    {
        置图片 (所欲设置的图片)
    }

    # --

    方法 是否正在播放 <公开 类型 = 逻辑型 注释 = "返回是否正在播放GIF动画" @禁止流程检查 = 真>
    {
        @ CVWnd_GifWnd* pWnd = (CVWnd_GifWnd*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->IsPlaying ());
    }

    方法 取图片尺寸 <公开 类型 = 尺寸类 注释 = "返回所已经置入图片的尺寸" @禁止流程检查 = 真>
    {
        @ CVWnd_GifWnd* pWnd = (CVWnd_GifWnd*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? @dt<尺寸类> (&pWnd->GetSize ()) : @dt<尺寸类> ());
    }

    方法 置图片 <公开 类型 = 逻辑型 注释 = "设置显示在本组件上的GIF图片. 本组件必须已经被成功创建." 返回值注释 = "返回是否成功">
    参数 所欲设置的GIF图片 <类型 = 位图资源 注释 = "提供所欲设置的GIF图片资源,如果该资源值为\"空资源.空位图\",则将清除已有图片.">
    参数 图片播放背景色 <类型 = 整数 注释 = "提供播放时所使用的图片区域背景颜色,如果为\"颜色类.默认色\"则使用GIF图片里面所设置的背景色." @默认值 = 颜色类.默认色>
    参数 自动开始播放 <类型 = 逻辑型 注释 = "指定置入后是否自动开始播放" @默认值 = 真>
    {
        @ if (GetMfcWndPtrWithValidHWnd () != NULL)
        @ {
        @     CVolMem memRes;
        @     g_objVolApp.LoadResData (@<所欲设置的GIF图片>, memRes);
        @     return @<置图片数据> (memRes, @<图片播放背景色>, @<自动开始播放>);
        @ }
        返回 (假)
    }

    方法 置图片文件 <公开 类型 = 逻辑型 注释 = "设置显示在本组件上的GIF图片文件. 本组件必须已经被成功创建." 返回值注释 = "返回是否成功">
    参数 所欲设置的GIF文件名 <类型 = 文本型 注释 = "提供所欲设置的GIF图片文件名">
    参数 图片播放背景色 <类型 = 整数 注释 = "提供播放时所使用的图片区域背景颜色,如果为\"颜色类.默认色\"则使用GIF图片里面所设置的背景色." @默认值 = 颜色类.默认色>
    参数 自动开始播放 <类型 = 逻辑型 注释 = "指定置入后是否自动开始播放" @默认值 = 真>
    {
        @ CVWnd_GifWnd* pWnd = (CVWnd_GifWnd*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (pWnd->Load (@<所欲设置的GIF文件名>.GetText ()))
        @     {
        @         if (@<图片播放背景色> != @<颜色类.默认色>)
        @             pWnd->SetBkColor ((COLORREF)@<图片播放背景色>);
        @         if (@<自动开始播放>)
        @             pWnd->Draw ();
        @         return TRUE;
        @     }
        @ }
        返回 (假)
    }

    方法 置图片数据 <公开 类型 = 逻辑型 注释 = "设置显示在本组件上的GIF图片数据. 本组件必须已经被成功创建." 返回值注释 = "返回是否成功">
    参数 所欲设置的GIF图片数据 <类型 = 字节集类 注释 = "提供所欲设置的GIF图片文件数据,为空字节集表示清除已有的图片.">
    参数 图片播放背景色 <类型 = 整数 注释 = "提供播放时所使用的图片区域背景颜色,如果为\"颜色类.默认色\"则使用GIF图片里面所设置的背景色." @默认值 = 颜色类.默认色>
    参数 自动开始播放 <类型 = 逻辑型 注释 = "指定置入后是否自动开始播放" @默认值 = 真>
    {
        @ CVWnd_GifWnd* pWnd = (CVWnd_GifWnd*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<所欲设置的GIF图片数据>.IsEmpty ()) {
        @         pWnd->UnLoad ();
        @         pWnd->Invalidate ();
        @         return TRUE;
        @     }
        @     const HGLOBAL hGlobal = @<所欲设置的GIF图片数据>.ToGlobalMem ();
        @     if (hGlobal == NULL)
        @         return FALSE;
        @     const BOOL_P blpSucceeded = pWnd->Load (hGlobal, (DWORD)@<所欲设置的GIF图片数据>.GetSize ());
        @     ::GlobalFree (hGlobal);
        @     if (blpSucceeded) {
        @         if (@<图片播放背景色> != @<颜色类.默认色>)
        @             pWnd->SetBkColor ((COLORREF)@<图片播放背景色>);
        @         if (@<自动开始播放>)
        @             pWnd->Draw ();
        @         return TRUE;
        @     }
        @ }
        返回 (假)
    }

    方法 播放 <公开 注释 = "开始或暂停播放GIF动画,本组件必须已经被成功创建.">
    参数 是否播放 <类型 = 逻辑型 注释 = "为真表示开始或继续播放,为假表示暂停播放." @默认值 = 真>
    {
        @ CVWnd_GifWnd* pWnd = (CVWnd_GifWnd*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->IsLoaded ())
        @ {
        @     if (@<是否播放>)
        @     {
        @         if (pWnd->IsPlaying () == FALSE)
        @             pWnd->Draw ();
        @     }
        @     else
        @         pWnd->Stop ();
        @ }
    }
}

