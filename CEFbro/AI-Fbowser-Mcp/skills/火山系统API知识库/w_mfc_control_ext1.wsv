    常量 页面设置 <公开 值 = 9>
}

类 IE浏览框 <公开 基础类 = 窗口组件 注释 = "基于IE的超文本浏览框组件." 注释 = "注意不要使用本组件浏览复杂的页面,本组件所基于的IE内核存在一些问题." 编辑时信息 = "23EA86, 0, 0, 0"
        @视窗.外部头文件 = "src\\mfc_ui_ie_browser.h" @视窗.外部源文件 = "src\\mfc_ui_ie_browser.cpp"
        @视窗.后缀文本 = "public IIEBrowserEventListener"
        @视窗.窗口组件 = "icon=\"@64\"\r\ndefault_size = \"200, 200\"\r\npreview_unsupported">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_IEBrowser, IIEBrowserEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 即将跳转 <公开 定义事件 类型 = 整数 注释 = "在浏览器即将跳转到另一个页面之前产生此事件,事件处理方法返回1不允许跳转,返回0允许跳转.">
    参数 地址 <类型 = 文本型 注释 = "提供即将跳转到的页面URL地址">

    方法 跳转完毕 <公开 定义事件 类型 = 整数 注释 = "当浏览器已跳转到另一个页面之后产生此事件">
    参数 地址 <类型 = 文本型 注释 = "提供已经跳转到的页面URL地址">

    方法 载入开始 <公开 定义事件 类型 = 整数 注释 = "本事件在\"即将跳转\"事件之后触发,表示浏览器已开始载入将要显示的文档." 注释 = "注意文档可能会被分批载入.">

    方法 载入进度改变 <公开 定义事件 类型 = 整数 注释 = "在浏览器载入文档的过程中,每当文档被载入一部分即触发本事件,用作通知载入进度.">
    参数 当前载入进度 <类型 = 整数 注释 = "提供当前文档已经被载入的百分比">

    方法 载入完毕 <公开 定义事件 类型 = 整数 注释 = "当将要显示在浏览器内的文档被载入完毕后触发本事件." 注释 = "注意文档可能会被分批载入,此事件发生时并不一定意味着整个文档被已载入完毕,另请参考\"已就绪\"事件.">

    方法 已就绪 <公开 定义事件 类型 = 整数 注释 = "当浏览器已经将所需显示的文档处理完毕后发送本事件">
    参数 地址 <类型 = 文本型 注释 = "提供已就绪页面的URL地址">

    方法 状态文本被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器的状态条文本被改变后发送本事件">
    参数 状态文本 <类型 = 文本型 注释 = "提供具体的状态文本内容">

    方法 标题被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器的标题文本被改变后发送本事件">
    参数 标题文本 <类型 = 文本型 注释 = "提供具体的标题文本内容">

    方法 命令状态被改变 <公开 定义事件 类型 = 整数 注释 = "  当\"前进\"/\"后退\"等命令的允许状态被改变后发送此事件," 注释 = "用户程序应该根据状态值允许或禁止对应的按钮或菜单项.">
    参数 命令类型 <类型 = 整数 注释 = "提供其允许状态被改变的命令类型. 0: 前进;  1: 后退.">
    参数 是否被允许 <类型 = 逻辑型 注释 = "提供所指定类型命令当前是否被允许">

    方法 即将打开新窗口 <公开 定义事件 类型 = 整数 注释 = "  在浏览器即将打开新窗口浏览另一个页面之前产生此事件," 注释 = "事件处理方法返回1不允许打开,返回0允许打开.">
    参数 地址 <类型 = 文本型 注释 = "提供即将打开新窗口的页面URL地址">

    # 属性 --

    方法 字体大小 <公开 属性读 类型 = IE浏览框字体尺寸 注释 = "返回浏览页面时所使用的字体尺寸" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->PropGetFontSuze ()
    }

    方法 字体大小 <公开 属性写 注释 = "设置浏览页面时所使用的字体尺寸" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的字体尺寸 <类型 = IE浏览框字体尺寸>
    {
        @ ((CVWnd_IEBrowser*)GetMfcWndPtr ())->PropSetFontSize (@<所欲设置的字体尺寸>);
    }

    方法 离线浏览 <公开 属性读 类型 = 逻辑型 注释 = "返回浏览器是否从缓存里面读取超文本页面数据" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->PropGetOffline ()
    }

    方法 离线浏览 <公开 属性写 注释 = "设置浏览器是否从缓存里面读取超文本页面数据" @视窗.设置时机 = 组件创建前后>
    参数 是否离线浏览 <类型 = 逻辑型>
    {
        @ ((CVWnd_IEBrowser*)GetMfcWndPtr ())->PropSetOffline (@<是否离线浏览>);
    }

    方法 静默 <公开 属性读 类型 = 逻辑型 注释 = "返回浏览过程中是否不允许浏览器显示自己的对话框" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->PropGetSilent ()
    }

    方法 静默 <公开 属性写 注释 = "设置浏览过程中是否不允许浏览器显示自己的对话框" @视窗.设置时机 = 组件创建前后>
    参数 是否静默浏览 <类型 = 逻辑型>
    {
        @ ((CVWnd_IEBrowser*)GetMfcWndPtr ())->PropSetSilent (@<是否静默浏览>);
    }

    方法 地址 <公开 属性读 类型 = 文本型 注释 = "返回欲显示的网络或本机超文本页面地址" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->PropGetURL ()
    }

    方法 地址 <公开 属性写 注释 = "设置欲显示的网络或本机超文本页面地址" @视窗.设置时机 = 组件创建前后 @值细节类型 = 文件名 @附加文本 = "网页文件(*.htm;*.html)|*.htm;*.html|">
    参数 所欲跳转到的地址 <类型 = 文本型>
    {
        @ ((CVWnd_IEBrowser*)GetMfcWndPtr ())->PropSetURL (@<所欲跳转到的地址>.GetText ());
    }

    # 方法 --

    方法 执行命令 <公开 注释 = "执行指定的浏览器命令">
    参数 所欲执行的命令 <类型 = IE浏览框命令>
    {
        @ CVWnd_IEBrowser* pWnd = (CVWnd_IEBrowser*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL) {
        @     switch (@<所欲执行的命令>) {
        @     case 0:  pWnd->GoForward (); break;
        @     case 1:  pWnd->GoBack (); break;
        @     case 2:  pWnd->GoHome (); break;
        @     case 3:  pWnd->GoSearch (); break;
        @     case 4:  pWnd->Refresh (); break;
        @     case 5:  pWnd->Stop (); break;
        @     case 6:  pWnd->RunCmd (OLECMDID_SAVEAS); break;
        @     case 7:  pWnd->RunCmd (OLECMDID_PRINT); break;
        @     case 8:  pWnd->RunCmd (OLECMDID_PRINTPREVIEW); break;
        @     case 9:  pWnd->RunCmd (OLECMDID_PAGESETUP); break;
        @     }
        @ }
    }

    方法 跳转 <公开 注释 = "打开互联网或者本机上指定位置处的文档">
    参数 欲打开文档地址 <类型 = 文本型 注释 = "指定文档位于互联网或本机上的地址">
    参数 CHM文件名称 <类型 = 文本型 注释 = "如果欲打开文档处于CHM文件内,本参数提供该CHM文件的名称." @默认值 = "">
    参数 目标窗口名称 <类型 = 文本型 注释 = "指定文档是否在单独窗口中打开,相同的名称指定相同的窗口." 注释 = "如果欲在浏览框内部打开,提供空文本参数值即可." @默认值 = "">
    {
        @ CVWnd_IEBrowser* pWnd = (CVWnd_IEBrowser*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL) {
        @     if (@<CHM文件名称>.IsEmpty ())
        @         pWnd->Navigate (@<欲打开文档地址>.GetText (), 0, @<目标窗口名称>.GetText ());
        @     else
        @         pWnd->NavigateChm (@<CHM文件名称>.GetText (), @<欲打开文档地址>.GetText (), @<目标窗口名称>.GetText ());
        @ }
    }

    方法 取文档类型 <公开 类型 = 文本型 注释 = "返回超文本浏览框中现行文档的类型文本" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->GetType ()
    }

    方法 是否正在下载 <公开 类型 = 逻辑型 注释 = "返回当前是否正在下载文档或执行页面跳转" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->GetBusy ()
    }

    方法 是否就绪 <公开 类型 = 逻辑型 注释 = "返回浏览框当前是否已经准备就绪" @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->GetReadyState () == READYSTATE_COMPLETE
    }

    方法 提交数据 <公开 类型 = 逻辑型 注释 = "使用HTTP POST方式提交数据,返回是否成功." @禁止流程检查 = 真>
    参数 欲打开文档地址 <类型 = 文本型 注释 = "指定文档位于互联网或本机上的地址">
    参数 所欲提交数据 <类型 = 字节集类>
    参数 数据头 <类型 = 文本型 注释 = "可以是多项数据的组合,每项数据的格式为\"名称: 值\",各项之间以换行符(\'\\n\')字符分隔.">
    {
        @ CVWnd_IEBrowser* pWnd = (CVWnd_IEBrowser*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : SUCCEEDED (pWnd->Navigate (@<欲打开文档地址>.GetText (), 0, NULL, @<数据头>.GetText (), @<所欲提交数据>.GetPtr (), (DWORD)@<所欲提交数据>.GetSize ())));
    }

    方法 取浏览器对象 <公开 类型 = COM对象类 注释 = "成功返回 IWebBrowser2 Application对象的 IDispatch 接口对象,失败返回空对象." @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->GetBrowserIDispathObject (CVolComObject ())
    }

    方法 取文档对象 <公开 类型 = COM对象类 注释 = "成功返回 IHTMLDocument2 Document对象的 IDispatch 接口对象,失败返回空对象." @嵌入式方法 = "">
    {
        @ ((CVWnd_IEBrowser*)@sn<this>.GetMfcWndPtr ())->GetDocumentIDispathObject (CVolComObject ())
    }

    # @begin
    # <> <include>
    # virtual void OnProgressChange (INT nProgress) override  { @<载入进度改变> (nProgress); }
    # virtual void OnCommandStateChange (INT nCommand, BOOL blEnabled) override  { @<命令状态被改变> (nCommand, blEnabled); }
    # virtual void OnDownloadBegin () override  { @<载入开始> (); }
    # virtual void OnDocumentComplete (CVolString& strURL) override  { @<已就绪> (strURL); }
    # virtual void OnDownloadComplete () override  { @<载入完毕> (); }
    # virtual void OnTitleChange (CVolString& strTitle) override  { @<标题被改变> (strTitle); }
    # virtual BOOL OnNewWindow (CVolString& strURL) override  { return (@<即将打开新窗口> (strURL) == 0); }
    # virtual BOOL OnBeforeNavigate (CVolString& strURL) override  { return (@<即将跳转> (strURL) == 0); }
    # virtual void OnStatusTextChange (CVolString& strStatusText) override  { @<状态文本被改变> (strStatusText); }
    # virtual void OnNavigateComplete (CVolString& strURL) override  { @<跳转完毕> (strURL); }
    # <> </include>
    # @end
}

# ===

类 列表框内置按钮 <公开 注释 = "提供列表框内置按钮的ID" @文档 = "category = \"辅助类\"">
{
    常量 新建按钮 <公开 类型 = 整数 值 = @AFX_VSLISTBOX_BTN_NEW_ID>
    常量 删除按钮 <公开 类型 = 整数 值 = @AFX_VSLISTBOX_BTN_DELETE_ID>
    常量 上移按钮 <公开 类型 = 整数 值 = @AFX_VSLISTBOX_BTN_UP_ID>
    常量 下移按钮 <公开 类型 = 整数 值 = @AFX_VSLISTBOX_BTN_DOWN_ID>
}

类 带按钮列表框 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_vs_list_box.h" @视窗.外部源文件 = "src\\mfc_ui_vs_list_box.cpp"
        @视窗.后缀文本 = "public IVSListBoxEventListener"
        @视窗.窗口组件 = "icon=\"@26\"\r\ndefault_size = \"100, 120\"\r\ndefault_event = \"列表项被选择\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_VSListBox, IVSListBoxEventListener, 0, 0, WS_TABSTOP, 0)
    #
    # 事件 --

    方法 浏览按钮被单击 <公开 定义事件 类型 = 整数 注释 = "编辑列表项内容时单击了编辑框右侧的浏览按钮后本事件被发送." 注释 = "该按钮只有当\"浏览按钮\"属性为真时才会被显示.">
    参数 项目索引位置 <类型 = 整数 注释 = "提供当前正在被编辑项目在列表框中的索引位置,必定有效.">

    方法 开始编辑项目 <公开 定义事件 类型 = 整数 注释 = "当开始编辑某列表项目时本事件被发送,返回0允许编辑,返回1不允许.">
    参数 项目索引位置 <类型 = 整数 注释 = "提供当前准备编辑的项目在列表框中的索引位置,必定有效.">

    方法 结束编辑项目 <公开 定义事件 类型 = 整数 注释 = "当编辑某列表项目完毕后本事件被发送">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所编辑完毕的项目在列表框中的索引位置,必定有效.">
    参数 项目内容 <类型 = 文本型 注释 = "  提供项目编辑完后的内容,该内容将被置回列表项目中," 注释 = "可以对其进行修改以更改被置回的内容." 注释 = "  注意如果本参数内容为空,将会忽略项目修改.">

    方法 列表项被选择 <公开 定义事件 类型 = 整数 注释 = "如果当前被选择表项被改变即产生此事件">
    参数 项目索引位置 <类型 = 整数 注释 = "提供最新被选择表项索引位置,必定有效.">

    方法 即将删除项目 <公开 定义事件 类型 = 整数 注释 = "在用户点击删除按钮即将删除项目前本事件被发送,返回0允许删除,返回1不允许.">
    参数 项目索引位置 <类型 = 整数 注释 = "提供即将被删除表项的索引位置,必定有效.">

    方法 加入项目后 <公开 定义事件 类型 = 整数 注释 = "在加入项目后本事件被发送">
    参数 项目索引位置 <类型 = 整数 注释 = "提供被加入表项的索引位置,必定有效.">

    方法 修改项目后 <公开 定义事件 类型 = 整数 注释 = "在项目内容被修改后本事件被发送">
    参数 项目索引位置 <类型 = 整数 注释 = "提供内容被修改的表项的索引位置,必定有效.">

    方法 上移项目后 <公开 定义事件 类型 = 整数 注释 = "在项目位置被向上移动后本事件被发送">
    参数 项目索引位置 <类型 = 整数 注释 = "提供被上移后的表项的索引位置,必定有效.">

    方法 下移项目后 <公开 定义事件 类型 = 整数 注释 = "在项目位置被向下移动后本事件被发送">
    参数 项目索引位置 <类型 = 整数 注释 = "提供被下移后的表项的索引位置,必定有效.">

    方法 按钮被单击 <公开 定义事件 类型 = 整数 注释 = "在列表框顶部的按钮被单击后,本事件被发送." 注释 = "返回0允许进行后续的默认按钮单击处理操作,返回1不允许.">
    参数 所单击按钮标识值 <类型 = 整数 注释 = "提供具体所单击按钮的具体ID值.为\"列表框内置按钮\"类中的常量值或用户自行加入按钮的ID值.">

    # 属性 ---

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_VSListBox*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_VSListBox* pWnd = (CVWnd_VSListBox*)GetMfcWndPtr ();
        @ pWnd->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_pWndList != NULL)
        @ {
        @     pWnd->m_pWndList->SetTextColor (pWnd->m_clrText);
        @     pWnd->m_pWndList->Invalidate ();
        @ }
    }

    方法 文本背景色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_VSListBox*)@sn<this>.GetMfcWndPtr ())->m_clrTextBack
    }

    方法 文本背景色 <公开 属性写 注释 = "设置本组件的文本背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_VSListBox* pWnd = (CVWnd_VSListBox*)GetMfcWndPtr ();
        @ pWnd->m_clrTextBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_pWndList != NULL)
        @ {
        @     pWnd->m_pWndList->SetTextBkColor (GetRealBackColor (pWnd->m_clrTextBack));
        @     pWnd->m_pWndList->Invalidate ();
        @ }
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件本身的背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_VSListBox*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件本身的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_VSListBox* pWnd = (CVWnd_VSListBox*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_pWndList != NULL)
        @ {
        @     pWnd->m_pWndList->SetBkColor (GetRealBackColor (pWnd->m_clrBack));
        @     pWnd->m_pWndList->Invalidate ();
        @ }
    }

    方法 "// 列表项目" <公开 属性读 类型 = 文本型 注释 = "  返回列表框中的列表项目内容." 注释 = "  由于一旦组件创建完毕,为了节省空间,此属性值将被清空," 注释 = "因此本属性不支持读取."
            返回值注释 = "  所返回文本内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 返回值注释 = "分别指定一个列表项目的标题文本和关联数值." @嵌入式方法 = "">
    {
        @ ((CVWnd_VSListBox*)@sn<this>.GetMfcWndPtr ())->m_strItems
    }

    方法 列表项目 <公开 属性写 注释 = "设置列表框中的列表项目内容" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nListItemsManager\r\n0">
    参数 所欲设置的列表内容 <类型 = 文本型 注释 = "  列表内容为以\'\\n\'字符分隔的文本数组,每两个数组成员" 注释 = "分别指定一个列表项目的标题文本和关联数值." 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_VSListBox*)GetMfcWndPtr ())->ResetListItems (@<所欲设置的列表内容>);
    }

    方法 新建按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定是否显示新建按钮" @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->m_blNewButton
    }

    方法 新建按钮 <公开 属性写 注释 = "指定是否显示新建按钮" @视窗.设置时机 = 组件创建前>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->m_blNewButton = @<欲设置属性值>;
    }

    方法 删除按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定是否显示删除按钮" @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->m_blDeleteButton
    }

    方法 删除按钮 <公开 属性写 注释 = "指定是否显示删除按钮" @视窗.设置时机 = 组件创建前>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->m_blDeleteButton = @<欲设置属性值>;
    }

    方法 上移按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定是否显示上移按钮" @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->m_blUpButton
    }

    方法 上移按钮 <公开 属性写 注释 = "指定是否显示上移按钮" @视窗.设置时机 = 组件创建前>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->m_blUpButton = @<欲设置属性值>;
    }

    方法 下移按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定是否显示下移按钮" @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->m_blDownButton
    }

    方法 下移按钮 <公开 属性写 注释 = "指定是否显示下移按钮" @视窗.设置时机 = 组件创建前>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->m_blDownButton = @<欲设置属性值>;
    }

    方法 浏览按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定在编辑列表项内容时在编辑框右侧是否显示一个浏览按钮,该按钮被单击后将发送\"浏览按钮被单击\"事件." @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->IsBrowseButton ()
    }

    方法 浏览按钮 <公开 属性写 注释 = "指定在编辑列表项内容时在编辑框右侧是否显示一个浏览按钮,该按钮被单击后将发送\"浏览按钮被单击\"事件." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->EnableBrowseButton (@<欲设置属性值>);
    }

    方法 变灰被禁止按钮 <公开 属性读 类型 = 逻辑型 注释 = "指定当按钮被禁止时,是否以灰色进行显示." @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->IsGrayDisabledButtons ()
    }

    方法 变灰被禁止按钮 <公开 属性写 注释 = "指定当按钮被禁止时,是否以灰色进行显示." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ ListBox ()->SetGrayDisabledButtons (@<欲设置属性值>);
    }

    方法 现行选中项 <公开 属性读 类型 = 整数 注释 = "列表框中现行被选中项目的位置,位置值从0开,-1表示现行没有被选中的项目." @禁止流程检查 = 真>
    {
        @ CVWnd_VSListBox* pWnd = ListBox ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetSelItem () : pWnd->m_nCurSel);
    }

    方法 现行选中项 <公开 属性写 注释 = "设置列表框中现行被选中项目的索引位置" @视窗.设置时机 = 组件创建前后>
    参数 所欲选中的项目 <类型 = 整数 注释 = "提供所欲选中项目的索引位置,位置值从0开.">
    {
        @ CVWnd_VSListBox* pWnd = ListBox ();
        @ pWnd->m_nCurSel = MAX (0, @<所欲选中的项目>);
        @ if (pWnd->m_hWnd != NULL)  pWnd->SelectItem (pWnd->m_nCurSel);
    }

    # 方法 --

    方法 禁止按钮 <公开 注释 = "禁止所指定的按钮" @嵌入式方法 = "">
    参数 所欲禁止的按钮 <类型 = 整数 注释 = "  提供所欲禁止的按钮的标识值,可以为\"列表框内置按钮\"类中的常量值," 注释 = "也可以为用户自行加入按钮的标识值.">
    参数 是否禁止 <类型 = 逻辑型 注释 = "为真则将所指定按钮禁止,为假则允许.">
    {
        @ @sn<this>.ListBox ()->MDisableButton (@<所欲禁止的按钮>, @<是否禁止>)
    }

    方法 全部删除 <公开 注释 = "删除所有的表项" @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->ResetContent ()
    }

    方法 插入项目 <公开 类型 = 整数 注释 = "插入一个项目到列表框中,成功返回其索引位置,失败返回-1." @嵌入式方法 = "">
    参数 项目文本 <类型 = 文本型 注释 = "提供所欲插入项目的文本内容">
    参数 用户数值 <类型 = 变整数 注释 = "提供关联该项目的用户自定义数值" @默认值 = 0>
    参数 插入索引位置 <类型 = 整数 注释 = "提供项目的具体插入位置,为-1表示在列表框尾部加入." @默认值 = -1>
    {
        @ @sn<this>.ListBox ()->AddItem (CString (@<项目文本>.GetText ()), (DWORD_PTR)@<用户数值>, @<插入索引位置>);
    }

    方法 删除项目 <公开 类型 = 逻辑型 注释 = "删除所指定索引位置处的项目,成功(该索引位置处存在项目)返回真,失败返回假." @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲删除项目所处的索引位置">
    {
        @ @sn<this>.ListBox ()->RemoveItem (@<项目索引位置>)
    }

    方法 取项目数 <公开 类型 = 整数 注释 = "返回列表框中的现有项目数目,如果列表框尚未创建,将返回-1." @嵌入式方法 = "">
    {
        @ @sn<this>.ListBox ()->GetCount ()
    }

    方法 取项目文本 <公开 类型 = 文本型 注释 = "返回所指定项目的文本内容" @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲获取其文本的项目索引位置">
    {
        @ @an<CVolString> ((LPCTSTR)@sn<this>.ListBox ()->GetItemText (@<项目索引位置>))
    }

    方法 置项目文本 <公开 注释 = "设置所指定项目的文本内容" @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲设置其文本的项目索引位置">
    参数 项目文本 <类型 = 文本型 注释 = "提供所欲设置的项目文本内容">
    {
        @ @sn<this>.ListBox ()->MSetItemText (@<项目索引位置>, @<项目文本>.GetText ())
    }

    方法 置用户数值 <公开 注释 = "设置与所指定项目关联的用户数值" @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲设置其关联用户数值的项目索引位置">
    参数 用户数值 <类型 = 变整数 注释 = "提供所欲设置的用户数值">
    {
        @ @sn<this>.ListBox ()->SetItemData (@<项目索引位置>, (DWORD_PTR)@<用户数值>)
    }

    方法 取用户数值 <公开 类型 = 变整数 注释 = "返回与所指定项目关联的用户数值" @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲获取其关联用户数值的项目索引位置">
    {
        @ (INT_P)@sn<this>.ListBox ()->GetItemData (@<项目索引位置>)
    }

    方法 编辑项目 <公开 类型 = 逻辑型 注释 = "开始编辑所指定的项目,返回是否成功." @嵌入式方法 = "">
    参数 项目索引位置 <类型 = 整数 注释 = "提供所欲开始编辑项目的索引位置">
    {
        @ @sn<this>.ListBox ()->CVSListBox::EditItem (@<项目索引位置>)
    }

    方法 加入按钮 <公开 类型 = 逻辑型 注释 = "添加新的自定义按钮到列表框,列表框必须已经被创建." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 图标 <类型 = BMP位图资源 注释 = "提供按钮的图标资源,必须有效." 注释 = "对图片的尺寸要求: 如果同时使用了列表框内置按钮,则尺寸必须为 13 x 12 像素,否则必须保证所有加入按钮的尺寸一致."
            注释 = "对图片的颜色要求: 底色为\"颜色类.浅灰色\"(红绿蓝值均为192),用作代表透明色.">
    参数 标识值 <类型 = 整数 注释 = "提供按钮的标识值,用作代表所加入的按钮.注意不能为0且不要与其它按钮和列表框内置按钮标识值冲突,否则会加入失败.">
    参数 提示文本 <类型 = 文本型 注释 = "提供按钮的提示文本" @默认值 = "">
    {
        @ return ((@<图标> != 0 && @<标识值> != 0 && ListBox ()->GetButtonNum ((UINT)@<标识值>) == -1) ?
        @         ListBox ()->AddButton ((UINT)@<图标>, @<提示文本>.GetText (), 0, 0, (UINT)@<标识值>) : FALSE);
    }

    # --
    #
    # @begin
    # <> <include>
    # virtual void OnBrowseItem (INT nIndex) override  { @<浏览按钮被单击> (nIndex); }
    # virtual BOOL OnBeginEditItem (INT nIndex) override  { return (@<开始编辑项目> (nIndex) == 0); }
    # virtual void OnEndEditItem (INT nIndex, CVolString& strNewText) override  { @<结束编辑项目> (nIndex, strNewText); }
    # virtual void OnSelectionChanged (INT nIndex) override  { @<列表项被选择> (nIndex); }
    # virtual BOOL OnBeforeRemoveItem (INT nIndex) override  { return (@<即将删除项目> (nIndex) == 0); }
    # virtual void OnAfterAddItem (INT nIndex) override  { @<加入项目后> (nIndex); }
    # virtual void OnAfterRenameItem (INT nIndex) override  { @<修改项目后> (nIndex); }
    # virtual void OnAfterMoveItemUp (INT nIndex) override  { @<上移项目后> (nIndex); }
    # virtual void OnAfterMoveItemDown (INT nIndex) override  { @<下移项目后> (nIndex); }
    # virtual BOOL OnClickButton (INT nButtonID) override  { return (@<按钮被单击> (nButtonID) == 0); }
    # inline_ CVWnd_VSListBox* ListBox ()  { return (CVWnd_VSListBox*)GetMfcWndPtr (); }
    # <> </include>
    # @end
}

#
