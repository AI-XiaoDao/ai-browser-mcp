    方法 现行选中项 <公开 属性读 类型 = 整数 注释 = "列表框中现行被选中项目的位置,位置值从0开,-1表示现行没有被选中的项目." @禁止流程检查 = 真>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     POSITION pos = pWnd->GetFirstSelectedItemPosition ();
        @     return (pos != NULL ? pWnd->GetNextSelectedItem (pos) : -1);
        @ }
        @ return pWnd->m_nCurSel;
    }

    方法 现行选中项 <公开 属性写 注释 = "设置列表框中现行被选中项目的位置." 注释 = "注意如果\"单一选择\"属性为假,则设置本属性没有效果." @视窗.设置时机 = 组件创建前后>
    参数 所欲选中的项目 <类型 = 整数 注释 = "提供所欲选中项目的索引位置,位置值从0开,-1表示取消当前所选中项目.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtr ();
        @ pWnd->m_nCurSel = MAX (-1, @<所欲选中的项目>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetCurSel (pWnd->m_nCurSel);
    }

