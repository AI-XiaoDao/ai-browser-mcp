    }

    # 方法 --

    方法 位置检测 <公开 类型 = 整数 注释 = "检测所指定位置在列表框中的行列位置及状态" 返回值注释 = "返回指定检测位置所位于的列表项行索引位置,如果不位于任何列表项上,返回-1." @禁止流程检查 = 真>
    参数 所欲检测横向位置 <类型 = 整数 注释 = "提供所欲检测的横向坐标位置,相对列表框用户区的左边.">
    参数 所欲检测纵向位置 <类型 = 整数 注释 = "提供所欲检测的纵向坐标位置,相对列表框用户区的顶边.">
    参数 检测结果 <类型 = 超级列表框检测结果 注释 = "所检测结果将存放进此参数中">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ LVHITTESTINFO inf;
        @ inf.pt.x = @<所欲检测横向位置>;
        @ inf.pt.y = @<所欲检测纵向位置>;
        @ inf.flags = 0;
        @ inf.iItem = -1;
        @ inf.iSubItem = 0;
        @ const INT nResult = (pWnd == NULL ? -1 : ListView_SubItemHitTest (pWnd->m_hWnd, &inf));
        @ @<检测结果.状态> = inf.flags;
        @ @<检测结果.行> = inf.iItem;
        @ @<检测结果.列> = inf.iSubItem;
        @ return nResult;
    }

    方法 取标题 <公开 类型 = 文本型 注释 = "取指定表项或子项的标题" @禁止流程检查 = 真>
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始,如果当前列表框类型不是报表型列表框,提供0值即可." @默认值 = 0>
    {
        @ CVolString str;
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     str.SetText (pWnd->GetCaption (@<表项索引>, @<列索引>, memBuf));
        @ }
        @ return str;
    }

    方法 取图片 <公开 类型 = 整数 注释 = "取回指定表项或子项的图片索引,图片索引指向图片组属性中的某一图片,从0开始,-1表示无图片." @禁止流程检查 = 真>
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始,如果当前列表框类型不是报表型列表框,提供0值即可." @默认值 = 0>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVITEM item;
        @     ZERO_MEM (&item, sizeof (item));
        @     item.iItem = @<表项索引>;
        @     item.iSubItem = @<列索引>;
        @     item.mask = LVIF_IMAGE;
        @     if (pWnd->GetItem (&item))
        @         return item.iImage;
        @ }
        @ return 0;
    }

    方法 取当前状态图片 <公开 类型 = 整数 注释 = "  取回指定表项的当前状态图片索引,图片索引指向状态图片组属性中的某一图片," 注释 = "从0开始,-1表示无图片. 如果\"是否有检查框\"属性为真,返回值是当前检查框的选"
            注释 = "中状态,1表示被选中,0表示未选中." @禁止流程检查 = 真>
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     return  (INT)(pWnd->SendMessage (LVM_GETITEMSTATE, (WPARAM)@<表项索引>, (LPARAM)LVIS_STATEIMAGEMASK) >> 12) - 1;
        @ return 0;
    }

    方法 取缩进数目 <公开 类型 = 整数 注释 = "取回指定表项的缩进数目" @禁止流程检查 = 真>
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVITEM item;
        @     ZERO_MEM (&item, sizeof (item));
        @     item.iItem = @<表项索引>;
        @     item.mask = LVIF_INDENT;
        @     if (pWnd->GetItem (&item))
        @         return item.iIndent;
        @ }
        @ return 0;
    }

    方法 取表项数值 <公开 类型 = 整数 注释 = "返回与指定表项相关联的数值,如果该表项不存在,返回0." @禁止流程检查 = 真>
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT)pWnd->GetItemData (@<表项索引>) : 0);
    }

    方法 置标题 <公开 注释 = "设置指定表项或子项的标题." 注释 = "注意当\"虚拟化数据\"属性为真时,本方法无效.">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始,如果当前列表框类型不是报表型列表框,提供0值即可." @默认值 = 0>
    参数 所欲设置的标题 <类型 = 文本型 @默认值 = "">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_blOwnerData == FALSE)
        @     pWnd->SetItemText (@<表项索引>, @<列索引>, @<所欲设置的标题>.GetText ());
    }

    方法 置图片 <公开 注释 = "设置指定表项或子项的图片,图片索引指向图片组属性中的某一图片,从0开始,-1表示无图片." 注释 = "注意当\"虚拟化数据\"属性为真时,本方法无效.">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始,如果当前列表框类型不是报表型列表框,提供0值即可." @默认值 = 0>
    参数 图片索引 <类型 = 整数 注释 = "用于指定\"图片组\"属性中的某张图片.索引值从0开始,-1表示无图片." @默认值 = -1>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_blOwnerData == FALSE)
        @ {
        @     LVITEM item;
        @     ZERO_MEM (&item, sizeof (item));
        @     item.iItem = @<表项索引>;
        @     item.iSubItem = @<列索引>;
        @     item.mask = LVIF_IMAGE;
        @     item.iImage = MAX (-1, @<图片索引>);
        @     pWnd->SetItem (&item);
        @     if (item.iImage == -1) pWnd->Invalidate ();
        @ }
    }

    方法 置状态图片 <公开 注释 = "  设置指定表项的状态图片.如果\"是否有检查框\"属性为真,调用\"置状态图片 (表项索引, 0)\"或"
            注释 = "\"置状态图片 (表项索引, 1)\"可以设置表项检查框的选中状态(前者为不选中,后者为选中)." 注释 = "  注意当\"虚拟化数据\"属性为真时,本方法无效.">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    参数 状态图片索引 <类型 = 整数 注释 = "用于指定\"状态图片组\"属性中的某张图片.索引值从0开始,最大为14,-1表示无图片." @默认值 = -1>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_blOwnerData == FALSE)
        @ {
        @     LVITEM item;
        @     ZERO_MEM (&item, sizeof (item));
        @     item.iItem = @<表项索引>;
        @     item.stateMask = LVIS_STATEIMAGEMASK;
        @     item.state = INDEXTOSTATEIMAGEMASK (MAX (0, @<状态图片索引> + 1));
        @     pWnd->SetItemState (@<表项索引>, &item);
        @ }
    }

    方法 置缩进数目 <公开 注释 = "设置指定表项的缩进数目." 注释 = "注意当\"虚拟化数据\"属性为真时,本方法无效.">
