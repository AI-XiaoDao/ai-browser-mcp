{
    常量 默认 <公开 值 = 0>
    常量 系统主题 <公开 值 = 1>
    常量 经典 <公开 值 = 2>
    常量 自定义 <公开 值 = 3>
}

类 高级分组框 <公开 基础类 = 窗口容器组件 @视窗.外部头文件 = "src\\mfc_ui_adv_group_box.h"
        @视窗.外部源文件 = "src\\mfc_ui_adv_group_box.cpp\r\nsrc\\AdvGroupBox\\AdvGroupBox.cpp" @视窗.后缀文本 = "public IBaseEventListener"
        @视窗.窗口组件 = "icon=\"@20\"\r\ndefault_size = \"120, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_AdvGroupBox, IBaseEventListener, 0, 0, 0, 0)

    方法 风格 <公开 属性读 类型 = 高级分组框风格 注释 = "返回当前所设置的本组件风格" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_nTheme
    }

    方法 风格 <公开 属性写 注释 = "设置本组件的风格" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的风格 <类型 = 高级分组框风格>
    {
        @ ((CVWnd_AdvGroupBox*)GetMfcWndPtr ())->SetThemeStyle (@<所欲设置的风格>);
    }

    方法 对齐方式 <公开 属性读 类型 = 横向对齐模式 注释 = "返回当前所设置的本组件标题对齐方式" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_nAlign
    }

    方法 对齐方式 <公开 属性写 注释 = "设置本组件的标题对齐方式" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的风格 <类型 = 横向对齐模式>
    {
        @ ((CVWnd_AdvGroupBox*)GetMfcWndPtr ())->SetAlign (@<所欲设置的风格>);
    }

    方法 底色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 底色 <公开 属性写 注释 = "设置本组件的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ ((CVWnd_AdvGroupBox*)GetMfcWndPtr ())->SetBackColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 边框颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件边框颜色值." 注释 = "注意: 本属性仅当\"风格\"属性为\"自定义\"时有效." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_clrFrame
    }

    方法 边框颜色 <公开 属性写 注释 = "设置本组件的边框颜色值." 注释 = "注意: 本属性仅当\"风格\"属性为\"自定义\"时有效." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件边框颜色.">
    {
        @ ((CVWnd_AdvGroupBox*)GetMfcWndPtr ())->SetFrameColor ((COLORREF)@<所欲设置颜色值>);
    }

    方法 标题背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件标题背景颜色值." 注释 = "注意: 本属性仅当\"风格\"属性为\"自定义\"时有效." @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_AdvGroupBox*)@sn<this>.GetMfcWndPtr ())->m_clrCaptionBack
    }

    方法 标题背景颜色 <公开 属性写 注释 = "设置本组件的标题背景颜色值." 注释 = "注意: 本属性仅当\"风格\"属性为\"自定义\"时有效." @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件标题背景颜色.">
    {
