    }

    方法 保证显示 <公开 注释 = "确保指定项目能够显示出来(如果当前未显示,将自动滚动并显示该项目)">
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         pWnd->EnsureVisible (hItem);
        @ }
    }

    方法 进入编辑 <公开 注释 = "让指定项目进入编辑状态,成功执行本方法的前提是\"允许编辑\"属性为真.">
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @     {
        @         if (::GetFocus () != pWnd->m_hWnd)
        @             pWnd->SetFocus ();
        @         pWnd->EditLabel (hItem);
        @     }
        @ }
    }

    方法 加入项目 <公开 类型 = 整数 注释 = "将指定项目加入到树型框中,成功返回该项目加入后所处的索引位置,失败返回-1." @禁止流程检查 = 真>
    参数 父项目索引 <类型 = 整数 注释 = "  指定欲加入项目所处的父项目索引位置,从0开始. 如果没有父项目(即欲加入项" 注释 = "目为顶层项目),请提供值-1." @默认值 = -1>
    参数 项目文本 <类型 = 文本型 注释 = "提供所欲加入项目的标题文本" @默认值 = "">
    参数 图片索引 <类型 = 整数 注释 = "用于指定欲加入项目所使用图片在图片组属性中的索引位置,从0开始." @默认值 = 0>
    参数 选中图片索引 <类型 = 整数 注释 = "  用于指定欲加入项目所使用选中状态图片在图片组属性中的索引位置,从0开始," 注释 = "为-1表示与\"图片索引\"参数值一致." @默认值 = -1>
    参数 项目数值 <类型 = 整数 注释 = "指定与欲加入项目相关联的数值" @默认值 = 0>
    参数 是否加粗 <类型 = 逻辑型 注释 = "指定欲加入项目标题是否加粗显示" @默认值 = 假>
    参数 检查框状态 <类型 = 整数 注释 = "指定本项目的检查框状态,仅在属性\"是否有检查框\"为真时生效,为-1表示无." 注释 = "0:未选中; 1:选中; 2:半选中" @默认值 = -1>
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TV_INSERTSTRUCT infItem;
        @     ZERO_MEM (&infItem, sizeof (infItem));
        @     infItem.item.mask = (TVIF_TEXT | TVIF_PARAM | TVIF_IMAGE | TVIF_SELECTEDIMAGE);
        @     infItem.hInsertAfter = TVI_LAST;
        @     infItem.hParent = (@<父项目索引> < 0 ? NULL : pWnd->FindTreeItemHandle (@<父项目索引>));
        @     infItem.item.pszText = (TCHAR*)@<项目文本>.GetText ();
        @     infItem.item.iImage = MAX (0, @<图片索引>);
        @     infItem.item.iSelectedImage = (@<选中图片索引> >= 0 ? @<选中图片索引> : infItem.item.iImage);
        @     infItem.item.lParam = @<项目数值>;
        @     infItem.item.state = 0;
        @     infItem.item.stateMask = (TVIS_BOLD | TVIS_STATEIMAGEMASK);
        @     if (@<是否加粗>)
        @         infItem.item.state |= TVIS_BOLD;
        @     if (@<检查框状态> >= 0)
        @         infItem.item.state |= INDEXTOSTATEIMAGEMASK (@<检查框状态> + 1);
        @     if (infItem.item.state != 0)
        @         infItem.item.mask |= TVIF_STATE;
        @     return pWnd->FindTreeItemIndex (pWnd->InsertItem (&infItem));
        @ }
        @ return -1;
    }

    方法 删除项目 <公开 类型 = 逻辑型 注释 = "删除树型框中的指定项目,返回是否成功." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         return pWnd->DeleteItem (hItem);
        @ }
        @ return FALSE;
    }

    方法 清空 <公开 注释 = "删除树型框中的所有项目">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteAllItems ();
    }

    方法 取父项目 <公开 类型 = 整数 注释 = "返回指定项目的父项目索引,如果该项目为顶层项目,将返回-1." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         return pWnd->FindTreeItemIndex (pWnd->GetParentItem (hItem));
        @ }
        @ return -1;
    }

    方法 是否有子项目 <公开 类型 = 逻辑型 注释 = "  返回指定项目是否存在子项目,如果本方法返回真,意味着" 注释 = "该项目的下一项目即为其第一个子项目." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     return (hItem != NULL && pWnd->ItemHasChildren (hItem));
        @ }
        @ return FALSE;
    }

    方法 是否已扩展 <公开 类型 = 逻辑型 注释 = "返回树型框中的指定项目是否具有子项目并已扩展显示" @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     return (hItem != NULL && pWnd->ItemHasChildren (hItem) && (pWnd->GetItemState (hItem, 0xffffffff) & TVIS_EXPANDED) != 0);
        @ }
        @ return FALSE;
    }

    方法 取检查框状态 <公开 类型 = 整数 注释 = "返回值表示检查框中选中状态. 默认情况下为: 0:未选中; 1:选中; 2:半选中." 注释 = "如果所指定项目位置无效,将返回-1." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         return ((pWnd->GetItemState (hItem, TVIS_STATEIMAGEMASK) >> 12) - 1);
        @ }
        @ return -1;
    }

    方法 置检查框状态 <公开 类型 = 逻辑型 注释 = "设置项目的检查框状态,返回是否成功." @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始." 注释 = "如果\"包括子项目\"参数值为真,此参数可为-1,表示同时设置所有项目的检查框状态.">
    参数 检查框状态 <类型 = 整数 注释 = "对应\"检查框图片组\"中某个图片的索引,从0开始." 注释 = "默认情况下: 0:未选中; 1:选中; 2:半选中.">
    参数 包括子项目 <类型 = 逻辑型 注释 = "  如果此参数为真,则参数\"项目索引\"所指定项目的所有直接/间接子项目也被一并" 注释 = "设置其检查框状态." @默认值 = 假>
    {
        @ ((CVWnd_TreeBox*)@sn<this>.GetMfcWndPtr ())->SetItemStateImageIndex (@<项目索引>, @<检查框状态>, @<包括子项目>)
    }

    # --
    #
    # @begin
    # <> <include>
    # virtual void OnRButtonClickItem () override  { @<右键单击项目> (); }
    # virtual INT OnItemCollapse (INT nItemIndex) override  { return @<即将收缩> (nItemIndex); }
    # virtual INT OnItemExpand (INT nItemIndex) override  { return @<即将扩展> (nItemIndex); }
    # virtual void OnSelchanged (INT nEventSourceType) override  { @<项目被选择> (nEventSourceType); }
    # virtual void OnCheckboxChanged (INT nItemIndex, INT nState) override  { @<检查框状态被改变> (nItemIndex, nState); }
    # virtual void OnDblClickItem () override  { @<双击项目> (); }
    # virtual INT OnBeginLabelEdit (INT nItemIndex) override  { return @<开始编辑> (nItemIndex); }
    # virtual INT OnEndLabelEdit (INT nItemIndex, CVolString& strNewLabel) override  { return @<结束编辑> (nItemIndex, strNewLabel); }
    # <> </include>
    # @end
}

# ===

类 增强树形框 <公开 基础类 = 窗口组件 注释 = "  本组件与\"树形框\"组件具有以下区别:" 注释 = "  1. 所有项目均以句柄值表达,处理速度要比\"树形框\"组件快;"
        注释 = "  2. 增加了以树形结构方式访问项目的对应方法;" 注释 = "  将使用\"树形框\"组件的程序转换为使用本组件,除了把组件数据类型由\"树形框\"改变为\"增强树形框\"之外,"
        注释 = "还需要将保存和处理树形框中项目的数据类型由\"整数\"改变为\"变整数\". 如果以前存在以索引方式遍历" 注释 = "访问项目的代码,需要将其改变为以树形结构方式访问."
        注释 = "  在使用本组件的过程中一定要确保所提供的项目句柄值有效." @视窗.外部头文件 = "src\\mfc_ui_tree_box2.h" @视窗.外部源文件 = "src\\mfc_ui_tree_box2.cpp"
        @视窗.外部资源文件 = "src\\res\\mfc_tree_box.rc" @视窗.后缀文本 = "public ITreeBoxEventListener2"
        @视窗.窗口组件 = "icon=\"@72\"\r\ndefault_size = \"100, 100\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_TreeBox2, ITreeBoxEventListener2, 0, 0, (WS_HSCROLL | WS_TABSTOP), WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 项目被选择 <公开 定义事件 类型 = 整数 注释 = "当前选择项目被改变时产生此事件">
    参数 选择方式 <类型 = 整数 注释 = "提供是如何操作导致当前选择项目被改变的:  0:键盘; 1:鼠标;  2:其它">

    方法 双击项目 <公开 定义事件 类型 = 整数 注释 = "  当使用鼠标左键在某项目上双击时产生此事件,在接收到此事件之前," 注释 = "当前被选中项目被修改到此被双击项目.">

    方法 开始编辑 <公开 定义事件 类型 = 整数 注释 = "  当项目进入标题编辑状态前产生此事件,要产生本事件\"允许编辑\"属性必须为真." 注释 = "事件处理子程序返回1不允许进入编辑状态,返回0允许.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供即将进入编辑状态项目的句柄值">

    方法 结束编辑 <公开 定义事件 类型 = 整数 注释 = "  当项目结束标题编辑状态前产生此事件,要产生本事件\"允许编辑\"属性必须为真." 注释 = "事件处理子程序返回1不允许使用编辑后的内容替换原有标题,返回0允许.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供即将结束编辑状态项目的句柄值">
    参数 编辑后内容 <类型 = 文本型 注释 = "提供编辑后的内容">

    方法 即将扩展 <公开 定义事件 类型 = 整数 注释 = "当某项目即将被展开以显示出下属子项目时产生本事件,返回1中止展开,返回0则允许.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供即将扩展显示下属子项目的项目句柄值">

    方法 即将收缩 <公开 定义事件 类型 = 整数 注释 = "当某项目即将被收缩以隐藏下属子项目时产生本事件,返回1中止收缩,返回0则允许.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供即将收缩显示下属子项目的项目句柄值">

    方法 右键单击项目 <公开 定义事件 类型 = 整数 注释 = "  当使用鼠标右键在某项目上单击时产生此事件,在接收到此事件之前," 注释 = "当前被选中项目被修改到此被单击项目.">

    方法 检查框状态被改变 <公开 定义事件 类型 = 整数 注释 = "  当用户操作(如被鼠标单击或按下键盘空格键)导致检查框选中状态被改变时" 注释 = "产生此事件. 仅在属性\"是否有检查框\"值为真的情况下才可能产生此事件.通"
            注释 = "过代码设置检查框状态不会触发此事件.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供其检查框状态发生变化的项目句柄值">
    参数 检查框状态 <类型 = 整数 注释 = "0:未选中; 1:选中; 2:半选中">

    # 属性 --

    方法 文本颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件文本颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_clrText
    }

    方法 文本颜色 <公开 属性写 注释 = "设置本组件的文本颜色值" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_clrText = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetTextColor (pWnd->m_clrText);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件本身的背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件本身的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetBkColor (GetRealBackColor (pWnd->m_clrBack));
        @     pWnd->Invalidate ();
        @ }
    }

    方法 显示加减框 <公开 属性读 类型 = 逻辑型 注释 = "返回是否显示加减框" @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_blShowButton
    }

    方法 显示加减框 <公开 属性写 注释 = "设置是否显示加减框" @视窗.设置时机 = 组件创建前后>
    参数 是否显示加减框 <类型 = 逻辑型>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_blShowButton = @<是否显示加减框>;
        @ if (pWnd->m_hWnd != NULL)
        @     SetWndStyle (pWnd, pWnd->m_blShowButton, TVS_HASBUTTONS);
    }

    方法 显示连线 <公开 属性读 类型 = 逻辑型 注释 = "返回是否显示连接线" @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_blShowLine
    }

    方法 显示连线 <公开 属性写 注释 = "设置是否显示连接线" @视窗.设置时机 = 组件创建前后>
    参数 是否显示连接线 <类型 = 逻辑型>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_blShowLine = @<是否显示连接线>;
        @ if (pWnd->m_hWnd != NULL)
        @     SetWndStyle (pWnd, pWnd->m_blShowLine, TVS_HASLINES);
    }

    方法 显示根部线 <公开 属性读 类型 = 逻辑型 注释 = "返回是否从根部显示连接线" @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_blShowRootLine
    }

    方法 显示根部线 <公开 属性写 注释 = "设置是否从根部显示连接线" @视窗.设置时机 = 组件创建前后>
    参数 是否显示根部线 <类型 = 逻辑型>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_blShowRootLine = @<是否显示根部线>;
        @ if (pWnd->m_hWnd != NULL)
        @     SetWndStyle (pWnd, pWnd->m_blShowRootLine, TVS_LINESATROOT);
    }

    方法 允许编辑 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许编辑标签内容" @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_blEditable
    }

    方法 允许编辑 <公开 属性写 注释 = "设置是否允许编辑标签内容" @视窗.设置时机 = 组件创建前后>
    参数 是否允许编辑 <类型 = 逻辑型>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_blEditable = @<是否允许编辑>;
        @ if (pWnd->m_hWnd != NULL)
        @     SetWndStyle (pWnd, pWnd->m_blEditable, TVS_EDITLABELS);
    }

    方法 始终显示选择项 <公开 属性读 类型 = 逻辑型 注释 = "返回是否始终显示当前被选择项目(即使树型框失去焦点)" @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->m_blShowSelAlways
    }

    方法 始终显示选择项 <公开 属性写 注释 = "设置是否始终显示当前被选择项目(即使树型框失去焦点)" @视窗.设置时机 = 组件创建前后>
    参数 是否始终显示选择项 <类型 = 逻辑型>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtr ();
        @ pWnd->m_blShowSelAlways = @<是否始终显示选择项>;
        @ if (pWnd->m_hWnd != NULL)
        @     SetWndStyle (pWnd, pWnd->m_blShowSelAlways, TVS_SHOWSELALWAYS);
    }

