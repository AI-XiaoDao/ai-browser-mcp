    方法 置列宽 <公开 注释 = "设置报表型列表框中指定列的宽度">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    参数 列宽 <类型 = 整数 注释 = "  本参数指定报表列的宽度,单位为像素. 如果参数值提供为-1," 注释 = "则根据列数据最大宽度自动调整列尺寸,如果参数值提供为-2,则" 注释 = "根据列标题宽度自动调整列尺寸."
            @默认值 = -1>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetColumnWidth (@<列索引>, MAX (-2, @<列宽>));
    }

    方法 置列图片 <公开 注释 = "设置报表型列表框中指定列的标志图片">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    参数 图片索引 <类型 = 整数 注释 = "图片索引用于指定\"表头图片组\"属性中的某张图片. 索引值从0开始,-1表示无图片." @默认值 = -1>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = LVCF_FMT;
        @     pWnd->GetColumn (@<列索引>, &col);
        @     col.mask |= LVCF_IMAGE;
        @     col.iImage = @<图片索引>;
        @     if (col.iImage >= 0)
        @         col.fmt |= LVCFMT_IMAGE;
        @     else
        @     {
        @         col.iImage = 0;
        @         col.fmt &= ~LVCFMT_IMAGE;
        @     }
        @     pWnd->SetColumn (@<列索引>, &col);
        @ }
    }

    方法 取列数 <公开 类型 = 整数 注释 = "返回报表型列表框中列的总数" @禁止流程检查 = 真>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetColCount () : 0);
    }

    方法 插入列 <公开 类型 = 整数 注释 = "在报表型列表框中指定位置插入新的列,成功返回新列的位置索引,失败返回-1.">
    参数 插入位置 <类型 = 整数 注释 = "指定新列插入时的位置索引,索引值从0开始.如果提供-1,则插入到尾部." @默认值 = -1>
    参数 标题 <类型 = 文本型 注释 = "指定报表列的标题文本" @默认值 = "">
    参数 列宽 <类型 = 整数 注释 = "指定报表列的宽度,单位为像素." @默认值 = 50>
    参数 对齐方式 <类型 = 列表框列对齐方式 @默认值 = 列表框列对齐方式.左对齐>
    参数 图片索引 <类型 = 整数 注释 = "图片索引用于指定\"表头图片组\"属性中的某张图片. 索引值从0开始,-1表示无图片." @默认值 = -1>
    参数 图片是否居右 <类型 = 逻辑型 注释 = "指定图片是否显示在右边" @默认值 = 假>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = (LVCF_TEXT | LVCF_SUBITEM | LVCF_WIDTH | LVCF_FMT);
        @     col.iSubItem = (@<插入位置> < 0 ? pWnd->GetColCount () : @<插入位置>);
        @     col.pszText = (TCHAR*)@<标题>.GetText ();
        @     col.cx = MAX (0, @<列宽>);
        @     col.fmt = (@<对齐方式> == 1 ? LVCFMT_CENTER : @<对齐方式> == 2 ? LVCFMT_RIGHT : LVCFMT_LEFT);
        @     col.iImage = MAX (-1, @<图片索引>);
        @     if (col.iImage != -1)
        @         col.mask |= LVCF_IMAGE;
        @     if (@<图片是否居右>)
        @         col.fmt |= LVCFMT_BITMAP_ON_RIGHT;
        @     return pWnd->InsertColumn (col.iSubItem, &col);
        @ }
        返回 (-1)
    }

    方法 删除列 <公开 注释 = "删除报表型列表框中指定位置处的列">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteColumn (@<列索引>);
    }

    方法 进入编辑 <公开 注释 = "让指定表项进入编辑状态,执行本命令成功的前提是\"允许编辑\"属性为真.">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (::GetFocus () != pWnd->m_hWnd)
        @         pWnd->SetFocus ();
        @     pWnd->EditLabel (@<表项索引>);
        @ }
    }

    方法 取可见表项数 <公开 类型 = 整数 注释 = "取当前在超级列表框的用户区中大约可以显示的项目数量" @禁止流程检查 = 真>
    {
        @ HWND hWnd = GetMfcWndHandle ();
        @ return (hWnd != NULL ? (INT)::SendMessage (hWnd, LVM_GETCOUNTPERPAGE, NULL, NULL) : 0);
    }

    方法 取可见首项索引 <公开 类型 = 整数 注释 = "取在当前超级列表框中显示的第一条项目的索引.失败返回-1" @禁止流程检查 = 真>
    {
        @ HWND hWnd = GetMfcWndHandle ();
        @ return (hWnd != NULL ? (INT)::SendMessage (hWnd, LVM_GETTOPINDEX, NULL, NULL) : -1);
    }

    方法 刷新表项 <公开 注释 = "重新绘制指定表项">
    参数 起始表项索引 <类型 = 整数 注释 = "用于指定列表框中欲重新绘制的起始项目索引,索引值从0开始.">
    参数 结束表项索引 <类型 = 整数 注释 = "用于指定列表框中欲重新绘制的结束项目索引,索引值从0开始." @默认值 = -1>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->RedrawItems (@<起始表项索引>, @<结束表项索引> == -1 ? @<起始表项索引> : @<结束表项索引>);
    }

    方法 刷新可见表项 <公开 注释 = "重新绘制可见区域表项">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     int nTopIndex = pWnd->GetTopIndex ();
        @     if (nTopIndex != -1)
        @         pWnd->RedrawItems (nTopIndex, nTopIndex + pWnd->GetCountPerPage ());
        @ }
    }

    # --
    #
