    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         pWnd->Expand (hItem, TVE_COLLAPSE);
        @ }
    }

    方法 保证显示 <公开 注释 = "确保指定项目能够显示出来(如果当前未显示,将自动滚动并显示该项目)">
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         pWnd->EnsureVisible (hItem);
        @ }
    }

    方法 进入编辑 <公开 注释 = "让指定项目进入编辑状态,成功执行本方法的前提是\"允许编辑\"属性为真.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @     {
        @         if (::GetFocus () != pWnd->m_hWnd)
        @             pWnd->SetFocus ();
        @         pWnd->EditLabel (hItem);
        @     }
        @ }
    }

    常量 首项目 <公开 类型 = 变整数 值 = @"@(INT_P)TVI_FIRST" 注释 = "本常量可以在插入新项目时作为插入位置使用,表明插入在父项目所有子项目的首部.">
    常量 尾项目 <公开 类型 = 变整数 值 = @"@(INT_P)TVI_LAST" 注释 = "本常量可以在插入新项目时作为插入位置使用,表明插入在父项目所有子项目的尾部.">
    常量 根项目 <公开 类型 = 变整数 值 = @"@(INT_P)TVI_ROOT" 注释 = "本常量可以在插入新项目时作为插入位置使用,表明插入为一个根项目.">
    常量 排序项目 <公开 类型 = 变整数 值 = @"@(INT_P)TVI_SORT" 注释 = "本常量可以在插入新项目时作为插入位置使用,表明插入到指定父项目后自动进行位置排序.">

    方法 加入项目 <公开 类型 = 变整数 注释 = "将指定项目加入到树型框中,成功返回该项目加入后所处的句柄值,失败返回-1." @禁止流程检查 = 真>
    参数 父项目句柄 <类型 = 变整数 注释 = "指定欲加入项目所处的父项目句柄值. 如果没有父项目(即欲加入项目为顶层项目),请提供值-1或0." @默认值 = -1>
    参数 项目文本 <类型 = 文本型 注释 = "提供所欲加入项目的标题文本" @默认值 = "">
    参数 图片索引 <类型 = 整数 注释 = "用于指定欲加入项目所使用图片在图片组属性中的索引位置,从0开始." @默认值 = 0>
    参数 选中图片索引 <类型 = 整数 注释 = "  用于指定欲加入项目所使用选中状态图片在图片组属性中的索引位置,从0开始," 注释 = "为-1表示与\"图片索引\"参数值一致." @默认值 = -1>
    参数 项目数值 <类型 = 整数 注释 = "指定与欲加入项目相关联的数值" @默认值 = 0>
    参数 是否加粗 <类型 = 逻辑型 注释 = "指定欲加入项目标题是否加粗显示" @默认值 = 假>
    参数 检查框状态 <类型 = 整数 注释 = "指定本项目的检查框状态,仅在属性\"是否有检查框\"为真时生效,为-1表示无." 注释 = "0:未选中; 1:选中; 2:半选中" @默认值 = -1>
    参数 插入位置项目句柄 <类型 = 变整数 注释 = "提供具体的插入位置项目句柄,新项目将在其后方插入."
            注释 = "可以为本类中以下特定常量值之一(具体作用参见该常量的注释): \"首项目\", \"尾项目\", \"根项目\", \"排序项目\"" @默认值 = 尾项目>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TV_INSERTSTRUCT infItem;
        @     ZERO_MEM (&infItem, sizeof (infItem));
        @     infItem.item.mask = (TVIF_TEXT | TVIF_PARAM | TVIF_IMAGE | TVIF_SELECTEDIMAGE);
        @     infItem.hInsertAfter = (HTREEITEM)@<插入位置项目句柄>;
        @     infItem.hParent = CVWnd_TreeBox2::sToItemHandle (@<父项目句柄>);
        @     infItem.item.pszText = (TCHAR*)@<项目文本>.GetText ();
        @     infItem.item.iImage = MAX (0, @<图片索引>);
        @     infItem.item.iSelectedImage = (@<选中图片索引> >= 0 ? @<选中图片索引> : infItem.item.iImage);
        @     infItem.item.lParam = @<项目数值>;
        @     infItem.item.state = 0;
        @     infItem.item.stateMask = (TVIS_BOLD | TVIS_STATEIMAGEMASK);
        @     if (@<是否加粗>)
        @         infItem.item.state |= TVIS_BOLD;
        @     if (@<检查框状态> >= 0)
        @         infItem.item.state |= INDEXTOSTATEIMAGEMASK (@<检查框状态> + 1);
        @     if (infItem.item.state != 0)
        @         infItem.item.mask |= TVIF_STATE;
        @     HTREEITEM hInsertedItem = pWnd->InsertItem (&infItem);
        @     return (hInsertedItem == NULL ? -1 : (INT_P)hInsertedItem);
        @ }
        @ return -1;
    }

    方法 删除项目 <公开 类型 = 逻辑型 注释 = "删除树型框中的指定项目,返回是否成功." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         return pWnd->DeleteItem (hItem);
        @ }
        @ return FALSE;
    }

    方法 清空 <公开 注释 = "删除树型框中的所有项目">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteAllItems ();
    }

    方法 是否已扩展 <公开 类型 = 逻辑型 注释 = "返回树型框中的指定项目是否具有子项目并已扩展显示" @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     return (hItem != NULL && pWnd->ItemHasChildren (hItem) && (pWnd->GetItemState (hItem, 0xffffffff) & TVIS_EXPANDED) != 0);
        @ }
        @ return FALSE;
    }

    方法 取检查框状态 <公开 类型 = 整数 注释 = "返回值表示检查框中选中状态. 默认情况下为: 0:未选中; 1:选中; 2:半选中." 注释 = "如果所指定项目位置无效,将返回-1." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         return ((pWnd->GetItemState (hItem, TVIS_STATEIMAGEMASK) >> 12) - 1);
        @ }
        @ return -1;
    }

    方法 置检查框状态 <公开 类型 = 逻辑型 注释 = "设置项目的检查框状态,返回是否成功." @嵌入式方法 = "">
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值" 注释 = "如果\"包括子项目\"参数值为真,此参数可为-1或0,表示同时设置所有项目的检查框状态.">
    参数 检查框状态 <类型 = 整数 注释 = "对应\"检查框图片组\"中某个图片的索引,从0开始." 注释 = "默认情况下: 0:未选中; 1:选中; 2:半选中.">
    参数 包括子项目 <类型 = 逻辑型 注释 = "  如果此参数为真,则参数\"项目句柄\"所指定项目的所有直接/间接子项目也被一并" 注释 = "设置其检查框状态." @默认值 = 假>
    {
        @ ((CVWnd_TreeBox2*)@sn<this>.GetMfcWndPtr ())->SetItemStateImageIndex (@<项目句柄>, @<检查框状态>, @<包括子项目>)
    }

    方法 取父项目 <公开 类型 = 变整数 注释 = "返回指定项目的父项目句柄值,如果该项目为顶层项目,将返回-1." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @     {
        @         hItem = pWnd->GetParentItem (hItem);
        @         return (hItem == NULL ? -1 : (INT_P)hItem);
        @     }
        @ }
        @ return -1;
    }

    方法 取首子项目 <公开 类型 = 变整数 注释 = "返回指定项目的第一个子项目句柄值,如果不存在,将返回0." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)  return (INT_P)pWnd->GetChildItem (hItem);
        @ }
        @ return 0;
    }

    方法 取前兄弟项目 <公开 类型 = 变整数 注释 = "返回指定项目的前方兄弟项目句柄值,如果不存在,将返回0." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)  return (INT_P)pWnd->GetPrevSiblingItem (hItem);
        @ }
        @ return 0;
    }

    方法 取后兄弟项目 <公开 类型 = 变整数 注释 = "返回指定项目的后方兄弟项目句柄值,如果不存在,将返回0." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)  return (INT_P)pWnd->GetNextSiblingItem (hItem);
        @ }
        @ return 0;
    }

    方法 取根项目 <公开 类型 = 变整数 注释 = "返回根项目的句柄值,如果不存在,将返回0." @禁止流程检查 = 真>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)pWnd->GetRootItem () : 0);
    }

    方法 是否有子项目 <公开 类型 = 逻辑型 注释 = "  返回指定项目是否存在子项目,如果本方法返回真,意味着" 注释 = "该项目的下一项目即为其第一个子项目." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     return (hItem != NULL && pWnd->ItemHasChildren (hItem));
        @ }
        @ return FALSE;
    }

    方法 排序子项目 <公开 类型 = 逻辑型 注释 = "将指定项目的所有子项目进行排序,返回是否成功." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         return pWnd->SortChildren (hItem);
        @ }
        @ return FALSE;
    }

    # --
    #
    # @begin
    # <> <include>
    # virtual void OnRButtonClickItem () override  { @<右键单击项目> (); }
    # virtual INT OnItemCollapse (INT_P npItemHandle) override  { return @<即将收缩> (npItemHandle); }
    # virtual INT OnItemExpand (INT_P npItemHandle) override  { return @<即将扩展> (npItemHandle); }
    # virtual void OnSelchanged (INT nEventSourceType) override  { @<项目被选择> (nEventSourceType); }
    # virtual void OnCheckboxChanged (INT_P npItemHandle, INT nState) override  { @<检查框状态被改变> (npItemHandle, nState); }
    # virtual void OnDblClickItem () override  { @<双击项目> (); }
    # virtual INT OnBeginLabelEdit (INT_P npItemHandle) override  { return @<开始编辑> (npItemHandle); }
    # virtual INT OnEndLabelEdit (INT_P npItemHandle, CVolString& strNewLabel) override  { return @<结束编辑> (npItemHandle, strNewLabel); }
    # <> </include>
    # @end
}

# ===

类 工具条位置 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 顶边 <公开 值 = 0>
    常量 底边 <公开 值 = 1>
    常量 自由 <公开 值 = 2>
}

类 工具条按钮类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 普通按钮 <公开 值 = 0>
    常量 多选按钮 <公开 值 = 1>
    常量 单选按钮 <公开 值 = 2>
    常量 下拉按钮 <公开 值 = 3>
    常量 分隔条 <公开 值 = 4>
}

类 工具条按钮状态 <公开 注释 = "提供工具条按钮的所有状态,这些状态值可以相加在一起组合使用." @文档 = "category = \"辅助类\"">
{
    常量 选中 <公开 类型 = 整数 值 = 1>
    常量 按下 <公开 类型 = 整数 值 = 2>
    常量 禁止 <公开 类型 = 整数 值 = 4>
    常量 隐藏 <公开 类型 = 整数 值 = 8>
    常量 变灰 <公开 类型 = 整数 值 = 16>
}

类 工具条 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_ui_tool_bar.h" @视窗.外部源文件 = "src\\mfc_ui_tool_bar.cpp"
        @视窗.后缀文本 = "public IToolBarEventListener" @视窗.窗口组件 = "icon=\"@67\"\r\ndefault_size = \"120, 30\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_ToolBar, IToolBarEventListener, 0, 0, 0, 0)
    #
    # 事件 --

    方法 被单击 <公开 定义事件 类型 = 整数 注释 = "当工具条按钮被单击时即产生此事件">
    参数 按钮索引 <类型 = 整数 注释 = "提供被单击按钮的索引位置,从0开始.">

    方法 被下拉 <公开 定义事件 类型 = 整数 注释 = "当下拉型按钮右侧向下箭头被单击时即产生此事件">
    参数 按钮索引 <类型 = 整数 注释 = "提供被下拉按钮的索引位置,从0开始.">
    参数 下拉横坐标 <类型 = 整数 注释 = "提供按钮被下拉的屏幕坐标位置,如果在事件处理子程序中需要弹出菜单或弹出子窗口,可以直接使用此位置.">
    参数 下拉纵坐标 <类型 = 整数 注释 = "提供按钮被下拉的屏幕纵向位置,如果在事件处理子程序中需要弹出菜单或弹出子窗口,可以直接使用此位置.">

    # 属性 --

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件本身的背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件本身的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<所欲设置颜色值>;
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 位置 <公开 属性读 类型 = 工具条位置 注释 = "返回当前所设置的工具条位置" @嵌入式方法 = "">
    {
        @ ((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->m_nPosition
    }

    方法 位置 <公开 属性写 注释 = "设置工具条的当前位置." 注释 = "注意本属性在设计器中始终为\"自由\"位置,但是在运行时将为所设置的实际效果." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的工具条位置 <类型 = 工具条位置>
    {
        @ ((CVWnd_ToolBar*)GetMfcWndPtr ())->m_nPosition = CLIP (@<所欲设置的工具条位置>, 0, 2);
    }

    方法 平面 <公开 属性读 类型 = 逻辑型 注释 = "返回是否以平面的方式显示工具条按钮" @嵌入式方法 = "">
    {
        @ ((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->m_blFlat
    }

    方法 平面 <公开 属性写 注释 = "设置是否以平面的方式显示工具条按钮" @视窗.设置时机 = 组件创建前>
    参数 是否显示平面按钮 <类型 = 逻辑型>
    {
        @ ((CVWnd_ToolBar*)GetMfcWndPtr ())->m_blFlat = @<是否显示平面按钮>;
    }

    方法 上边线 <公开 属性读 类型 = 逻辑型 注释 = "返回是否在工具条的顶部显示上边分隔线" @嵌入式方法 = "">
    {
        @ ((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->m_blDivider
    }

    方法 上边线 <公开 属性写 注释 = "设置是否在工具条的顶部显示上边分隔线" @视窗.设置时机 = 组件创建前>
    参数 是否显示上边线 <类型 = 逻辑型>
    {
        @ ((CVWnd_ToolBar*)GetMfcWndPtr ())->m_blDivider = @<是否显示上边线>;
    }

    方法 列表方式 <公开 属性读 类型 = 逻辑型 注释 = "返回在显示按钮时是否将标题文本显示在图片的右边" @嵌入式方法 = "">
    {
        @ ((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->m_blListMode
    }

