        @     pWnd->SetItemState (@<表项索引>, 0, LVIS_SELECTED);
    }

    方法 取表项数 <公开 类型 = 整数 注释 = "返回列表框中所有表项的数目" @禁止流程检查 = 真>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetItemCount ());
    }

    方法 插入表项 <公开 类型 = 整数 注释 = "在指定索引位置插入新表项,成功返回新表项的位置索引,失败返回-1." @禁止流程检查 = 真>
    参数 插入位置 <类型 = 整数 注释 = "指定新表项插入时的位置索引,索引值从0开始.如果提供-1,则插入到列表框的尾部."
            注释 = "注意: \"类型\"属性为\"大图标列表框\"或\"小图标列表框\"的情况下,将始终在所有表项的最后插入新的表项." @默认值 = -1>
    参数 标题 <类型 = 文本型 注释 = "提供所欲插入表项的标题文本" @默认值 = "">
    参数 图片索引 <类型 = 整数 注释 = "用于指定\"图片组\"属性中的某张图片. 索引值从0开始,-1表示无图片." @默认值 = -1>
    参数 状态图片索引 <类型 = 整数 注释 = "用于指定\"状态图片组\"属性中的某张图片. 索引值从0开始,最大为14,-1表示无图片." @默认值 = -1>
    参数 缩进数目 <类型 = 整数 注释 = "\"缩进数目\"仅在报表型列表框才有效,用作指定显示时在表项首部增加的空白数." @默认值 = 0>
    参数 表项数值 <类型 = 整数 注释 = "该数值与指定表项相关联,可以在以后使用代码读写." @默认值 = 0>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVITEM item;
        @     ZERO_MEM  (&item, sizeof (item));
        @     item.mask = (LVIF_TEXT | LVIF_PARAM | LVIF_IMAGE | LVIF_STATE | LVIF_INDENT);
        @     item.iItem = (@<插入位置> < 0 ? pWnd->GetItemCount () : @<插入位置>);
        @     item.pszText = (TCHAR*)@<标题>.GetText ();
        @     item.iImage = MAX (-1, @<图片索引>);
        @     item.state = INDEXTOSTATEIMAGEMASK (MAX (0, @<状态图片索引> + 1));
        @     item.iIndent = MAX (0, @<缩进数目>);
        @     item.lParam = @<表项数值>;
        @     return pWnd->InsertItem (&item);
        @ }
        @ return -1;
    }

    方法 删除表项 <公开 注释 = "删除指定位置的表项">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteItem (@<表项索引>);
    }

    方法 全部删除 <公开 注释 = "删除所有的表项">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DeleteAllItems ();
    }

    方法 查找表项 <公开 类型 = 整数 注释 = "查找具有指定标题的表项,成功返回被找到表项的位置索引,失败返回-1." @嵌入式方法 = "">
    参数 标题 <类型 = 文本型 注释 = "指定欲查找表项的标题文本">
    参数 起始查找位置 <类型 = 整数 注释 = "指定查找表项的起始索引位置" @默认值 = 0>
    参数 是否精确匹配 <类型 = 逻辑型 注释 = "  指定匹配标题文本时是否为精确匹配,如果本参数为假,则只要表项标题" 注释 = "首部包含指定文本即认为匹配成功." @默认值 = 真>
    参数 列索引 <类型 = 整数 注释 = "  本参数仅在报表模式下有效,用于指定查找表项中的哪一列. 如为-1,表" 注释 = "示查找所有列." @默认值 = 0>
    {
        @ ((CVWnd_ListView*)@sn<this>.GetMfcWndPtr ())->FindSpecifiedItem (@<标题>.GetText (), @<起始查找位置>, @<是否精确匹配>, @<列索引>)
    }

    方法 查找表项数值 <公开 类型 = 整数 注释 = "查找具有指定关联数值的表项,成功返回被找到表项的位置索引,失败返回-1.">
    参数 起始查找位置 <类型 = 整数 注释 = "指定查找表项的起始索引位置" @默认值 = 0>
    参数 欲查找表项数值 <类型 = 整数 注释 = "指定所欲查找的表项数值,该数值与表项相关联." @默认值 = 0>
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVFINDINFO fndinf;
        @     ZERO_MEM (&fndinf, sizeof (fndinf));
        @     fndinf.flags = LVFI_PARAM;
        @     fndinf.lParam = @<欲查找表项数值>;
        @     return pWnd->FindItem (&fndinf, MAX (0, @<起始查找位置>) - 1);
        @ }
        返回 (-1)
    }

    方法 保证显示 <公开 注释 = "确保指定表项能够显示出来,如果不能显示,则自动滚动并显示该表项.">
    参数 表项索引 <类型 = 整数 注释 = "用于指定列表框中的某一项目,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->EnsureVisible (@<表项索引>, FALSE);
    }

    方法 排列图标 <公开 注释 = "自动排列大图标或小图标列表框中的图标">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Arrange (LVA_DEFAULT);
    }

    方法 取列标题 <公开 类型 = 文本型 注释 = "返回报表型列表框中指定列的标题">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TCHAR buf [1024];
        @     buf [0] = '\0';
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = LVCF_TEXT;
        @     col.cchTextMax = NUM_ELEMENTS_OF (buf) - 1;
        @     col.pszText = buf;
        @     if (pWnd->GetColumn (@<列索引>, &col) == FALSE)
        @         buf [0] = '\0';
        @     @<结果变量>.SetText (buf);
        @ }
        返回 (结果变量)
    }

    方法 取列对齐方式 <公开 类型 = 列表框列对齐方式 注释 = "取回报表型列表框中指定列的对齐方式">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = LVCF_FMT;
        @     if (pWnd->GetColumn (@<列索引>, &col))
        @     {
        @         const INT_P npType = (col.fmt & LVCFMT_JUSTIFYMASK);
        @         return (npType == LVCFMT_CENTER ? 1 : npType == LVCFMT_RIGHT ? 2 : 0);
        @     }
        @ }
        返回 (列表框列对齐方式.左对齐)
    }

    方法 取列宽 <公开 类型 = 整数 注释 = "返回报表型列表框中指定列的宽度,如指定列不存在,返回0." @禁止流程检查 = 真>
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetColumnWidth (@<列索引>) : 0);
    }

    方法 取列图片 <公开 类型 = 整数 注释 = "返回报表型列表框中指定列的图片索引,如果出错或无则返回-1.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     LVCOLUMN col;
        @     ZERO_MEM (&col, sizeof (col));
        @     col.mask = (LVCF_IMAGE | LVCF_FMT);
        @     if (pWnd->GetColumn (@<列索引>, &col) && (col.fmt & LVCFMT_IMAGE) != 0)
        @         return col.iImage;
        @ }
        返回 (-1)
    }

    方法 图片是否居右 <公开 类型 = 逻辑型 注释 = "如果报表型列表框中指定列的图片居右显示,返回真.否则返回假.">
    参数 列索引 <类型 = 整数 注释 = "用作指定报表型列表框中项目所处的列,索引值从0开始.">
    {
        @ CVWnd_ListView* pWnd = (CVWnd_ListView*)GetMfcWndPtrWithValidHWnd ();
