    方法 工具条按钮 <公开 属性写 注释 = "初始设置工具条中的所有按钮内容" @视窗.设置时机 = 组件创建前 @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nToolBarManager\r\n0">
    参数 所欲设置的按钮 <类型 = 文本型 注释 = "每列信息为以\'\\n\'字符分隔的字段,各个字段的意义为:" 注释 = "  1. 整数: 图片索引,-1 表示本按钮无图片." 注释 = "  2. 整数: 按钮状态"
            注释 = "  3. 整数: 按钮风格" 注释 = "  4. 文本: 标题" 注释 = "  5. 文本: 提示" 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_ToolBar*)GetMfcWndPtr ())->m_strItems.SetText (@<所欲设置的按钮>);
    }

    # 方法 --

    方法 插入按钮 <公开 类型 = 整数 注释 = "将指定按钮插入到工具条中,成功返回插入后该按钮所处的位置,失败返回-1." 注释 = "本方法仅在工具条被创建后才能成功调用." @嵌入式方法 = "">
    参数 插入位置 <类型 = 整数 注释 = "指定新按钮插入的位置索引(从0开始). 如果提供-1,则插入到工具条的尾部." @默认值 = -1>
    参数 类型 <类型 = 工具条按钮类型 @默认值 = 工具条按钮类型.普通按钮>
    参数 图片索引 <类型 = 整数 注释 = "图片索引用于指定图片组属性中的某张图片,该图片将被显示在按钮表面." 注释 = "索引值从0开始,-1表示无图片." @默认值 = -1>
    参数 标题 <类型 = 文本型 注释 = "提供显示在按钮下的标题文本" @默认值 = "">
    参数 提示文本 <类型 = 文本型 注释 = "提供当鼠标移动到按钮上并停留一段时间后所动态显示的提示文本,空文本表示无." @默认值 = "">
    参数 按钮状态 <类型 = 整数 注释 = "  提供按钮的当前状态,状态值为0或\"工具条按钮状态\"类中各个常量的相加组合值." 注释 = "其中\"选中\"状态在类型为多选按钮或单选按钮时有效,\"按下\"状态在类型为普通按钮"
            注释 = "时有效." @默认值 = 0>
    {
        @ (INT)((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->InsertToolButton (@<插入位置>, @<类型>, @<图片索引>, @<标题>.GetText (), @<提示文本>.GetText (), @<按钮状态>)
    }

    方法 删除按钮 <公开 类型 = 逻辑型 注释 = "删除所指定位置处的按钮,返回是否成功." @嵌入式方法 = "">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        @ (BOOL)((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->RemoveToolButton (@<按钮索引>)
    }

    方法 取按钮数 <公开 类型 = 整数 注释 = "返回工具条中按钮的总共数目" @禁止流程检查 = 真>
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->GetButtonCount () : 0);
    }

    方法 取标题 <公开 类型 = 文本型 注释 = "返回指定按钮的标题文本">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     TCHAR buf [256];
        @     buf [0] = '\0';
        @     TBBUTTONINFO infButton;
        @     ZERO_MEM (&infButton, sizeof (infButton));
        @     infButton.cbSize = sizeof (infButton);
        @     infButton.dwMask = TBIF_TEXT;
        @     infButton.pszText = buf;
        @     infButton.cchText = NUM_ELEMENTS_OF (buf) - 1;
        @     if (pWnd->GetButtonInfo (nButtonID, &infButton) != -1)
        @         @<结果变量>.SetText (buf);
        @ }
        返回 (结果变量)
    }

    方法 置标题 <公开 注释 = "设置指定按钮的标题文本">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    参数 所欲设置的标题文本 <类型 = 文本型 @默认值 = "">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     TBBUTTONINFO infButton;
        @     infButton.cbSize = sizeof (TBBUTTONINFO);
        @     infButton.dwMask = TBIF_TEXT;
        @     infButton.pszText = (TCHAR*)@<所欲设置的标题文本>.GetText ();
        @     pWnd->SetButtonInfo (nButtonID, &infButton);
        @     TBBUTTON infDummyButton;
        @     infDummyButton.iBitmap = -1;
        @     infDummyButton.idCommand = 0;
        @     infDummyButton.fsState = TBSTATE_HIDDEN;
        @     infDummyButton.fsStyle = TBSTYLE_BUTTON;
        @     infDummyButton.iString = (INT_PTR)-1;
        @     pWnd->AddButtons (1, &infDummyButton);  // 刷新按钮宽度
        @     pWnd->DeleteButton (pWnd->GetButtonCount () - 1);
        @ }
    }

    方法 取提示文本 <公开 类型 = 文本型 注释 = "返回指定按钮的提示文本">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     const INT_P npIndex = pWnd->m_aryTipButtonIDs.FindElement (nButtonID);
        @     if (npIndex != -1)
        @         @<结果变量>.SetText (pWnd->m_saryButtonTips [npIndex]);
        @ }
        返回 (结果变量)
    }

    方法 取类型 <公开 类型 = 工具条按钮类型 注释 = "返回指定按钮的类型">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TBBUTTON infButton;
        @     if (pWnd->GetButton (@<按钮索引>, &infButton))
        @     {
        @         if ((infButton.fsStyle & TBSTYLE_CHECKGROUP) == TBSTYLE_CHECKGROUP)  return 2;
        @         if ((infButton.fsStyle & TBSTYLE_CHECK) != 0)  return 1;
        @         if ((infButton.fsStyle & TBSTYLE_DROPDOWN) != 0)  return 3;
        @         if ((infButton.fsStyle & TBSTYLE_SEP) != 0)  return 4;
        @     }
        @ }
        返回 (工具条按钮类型.普通按钮)
    }

    方法 取状态 <公开 类型 = 整数 注释 = "返回指定按钮的状态,状态值为0或\"工具条按钮状态\"类中各个常量的相加组合值." 注释 = "可以使用\"位与\"关键字检测按钮状态值中所指定的状态位是否被设置.">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        变量 结果变量 <类型 = 整数 值 = 0>
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     const INT nState = pWnd->GetState (nButtonID);
        @     if (nState != -1)
        @     {
        @         if (nState & TBSTATE_CHECKED)  @<结果变量> |= 1;
        @         if (nState & TBSTATE_PRESSED)  @<结果变量> |= 2;
        @         if ((nState & TBSTATE_ENABLED) == 0)  @<结果变量> |= 4;
        @         if (nState & TBSTATE_HIDDEN)  @<结果变量> |= 8;
        @         if (nState & TBSTATE_INDETERMINATE)  @<结果变量> |= 16;
        @     }
        @ }
        返回 (结果变量)
    }

    方法 取图片 <公开 类型 = 整数 注释 = "  返回指定按钮的图片索引位置,其指向图片组属性中的某一图片," 注释 = "从0开始,-1表示本按钮无图片标志.">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     TBBUTTONINFO infButton;
        @     ZERO_MEM (&infButton, sizeof (infButton));
        @     infButton.cbSize = sizeof (infButton);
        @     infButton.dwMask = TBIF_IMAGE;
        @     if (pWnd->GetButtonInfo (nButtonID, &infButton) != -1)
        @         return infButton.iImage;
        @ }
        返回 (-1)
    }

    方法 置提示文本 <公开 注释 = "设置指定按钮的提示文本">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    参数 所欲设置的提示文本 <类型 = 文本型 注释 = "提供所欲设置的提示文本,为空文本表示无." @默认值 = "">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtr ();
        @ INT nButtonID;
        @ if (pWnd->GerButtonID (@<按钮索引>, &nButtonID))
        @ {
        @     const INT_P npIndex = pWnd->m_aryTipButtonIDs.FindElement (nButtonID);
        @     if (npIndex != -1)
        @         pWnd->m_saryButtonTips.SetAt (npIndex, @<所欲设置的提示文本>.GetText ());
        @     else
        @     {
        @         pWnd->m_aryTipButtonIDs.Add (nButtonID);
        @         pWnd->m_saryButtonTips.Add (@<所欲设置的提示文本>.GetText ());
        @     }
        @ }
    }

    方法 加入状态 <公开 类型 = 逻辑型 注释 = "将指定状态值加入到按钮的当前状态中,返回是否成功." @嵌入式方法 = "">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    参数 所欲加入的按钮状态 <类型 = 整数 注释 = "  提供所欲加入的按钮状态,状态值为\"工具条按钮状态\"类中各个常量的相加组合值." 注释 = "其中\"选中\"状态在类型为多选按钮或单选按钮时有效,\"按下\"状态在类型为普通按钮"
            注释 = "时有效.">
    {
        @ (BOOL)((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->ModifyToolButtonState (@<按钮索引>, @<所欲加入的按钮状态>, FALSE)
    }

    方法 去除状态 <公开 类型 = 逻辑型 注释 = "将指定状态值从按钮的当前状态中删除,返回是否成功." @嵌入式方法 = "">
    参数 按钮索引 <类型 = 整数 注释 = "提供所欲操作按钮的索引位置,从0开始.">
    参数 所欲删除的按钮状态 <类型 = 整数 注释 = "提供所欲删除的按钮状态,状态值为\"工具条按钮状态\"类中各个常量的相加组合值.">
    {
        @ (BOOL)((CVWnd_ToolBar*)@sn<this>.GetMfcWndPtr ())->ModifyToolButtonState (@<按钮索引>, @<所欲删除的按钮状态>, TRUE)
    }

    方法 更新位置 <公开 注释 = "如果工具条所处父窗口的尺寸被改变,需要调用本方法动态更新其实时位置.">
    {
        @ CVWnd_ToolBar* pWnd = (CVWnd_ToolBar*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->AutoSize ();
    }

    # --
