        @     UINT uState = (pWnd->m_blSingleSel ? (LVIS_FOCUSED | LVIS_SELECTED) : LVIS_SELECTED);
        @     pWnd->SetItemState (@<表项索引>, uState, uState);
        @ }
    }

    方法 取消表项选择 <公开 注释 = "取消对指定表项的选择">
