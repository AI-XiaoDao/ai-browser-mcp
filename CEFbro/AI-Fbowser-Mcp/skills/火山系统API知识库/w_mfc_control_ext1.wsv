    方法 取行文本 <公开 类型 = 文本型 注释 = "返回编辑框中指定行的文本内容">
    参数 行号 <类型 = 整数 注释 = "行号从0开始,用作指定编辑框中的某一行. 即:0指定第一行,1指定第二行,依此类推.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_RichEdit* pWnd = (CVWnd_RichEdit*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     TCHAR buf [4096 * 2];
        @     ZERO_MEM (buf, sizeof (buf));
        @     pWnd->GetLine (@<行号>, buf, NUM_ELEMENTS_OF (buf) - 3);
        @     @<结果变量>.SetText (buf);
        @ }
        返回 (结果变量)
    }

