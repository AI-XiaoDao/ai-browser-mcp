    方法 检查框状态数 <公开 属性读 类型 = 整数 注释 = "返回检查框有几个状态,检查框将在各状态之间循环切换." @嵌入式方法 = "">
    {
        @ ((CVWnd_TreeBox*)@sn<this>.GetMfcWndPtr ())->m_nNumCheckBoxStates
    }

    方法 检查框状态数 <公开 属性写 注释 = "  设置检查框有几个状态.检查框将在各状态之间循环切换,每个状态分别使用\"检查框图片组\"中相"
            注释 = "应位置的图片. 本属性仅在\"是否有检查框\"属性为真时有效,初始默认值为2.如果使用默认检查框图" 注释 = "片组又想支持半选中状态(2),请将本属性值设置为3." @视窗.设置时机 = 组件创建前>
    参数 所欲设置的状态数 <类型 = 整数 注释 = "提供所欲设置的检查框状态数,如果为0则表示等于\"检查框图片组\"中的现有图片个数.">
    {
        @ ((CVWnd_TreeBox*)GetMfcWndPtr ())->m_nNumCheckBoxStates = MAX (0, @<所欲设置的状态数>);
    }

    # 方法 --

    方法 取项目数 <公开 类型 = 整数 注释 = "返回树型框中所有项目的数目" @禁止流程检查 = 真>
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetCount ());
    }

    方法 取缩进层次 <公开 类型 = 整数 注释 = "返回指定项目所处缩进层次,层次值从1开始. 如果未找到指定项目,返回0." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ INT nIndent = 0;
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     while (hItem != NULL)
        @     {
        @         nIndent++;
        @         hItem = pWnd->GetParentItem (hItem);
        @     }
        @ }
        @ return nIndent;
    }

    方法 取项目文本 <公开 类型 = 文本型 注释 = "返回指定项目的文本,如果该项目不存在,将返回空文本.">
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @         @<结果变量>.SetText (pWnd->GetItemText (hItem));
        @ }
        返回 (结果变量)
    }

    方法 取图片 <公开 类型 = 整数 注释 = "返回指定项目的图片索引,如果该项目不存在,将返回-1." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
        @ CVWnd_TreeBox* pWnd = (CVWnd_TreeBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = pWnd->FindTreeItemHandle (@<项目索引>);
        @     if (hItem != NULL)
        @     {
        @         INT nImageIndex = -1, nSelImageIndex;
        @         if (pWnd->GetItemImage (hItem, nImageIndex, nSelImageIndex))
        @             return nImageIndex;
        @     }
        @ }
        @ return -1;
    }

    方法 取选中图片 <公开 类型 = 整数 注释 = "返回指定项目被选中后的图片索引,如果该项目不存在,将返回-1." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供所指定项目的索引位置,从0开始.">
    {
