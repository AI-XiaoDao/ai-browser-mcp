    # virtual void OnItemActivate () override  {  @<表项被激活> ();  }
    # virtual void OnColClicked (INT nColIndex) override  {  @<表头被单击> (nColIndex);  }
    # virtual void OnHotTrack (INT nItemIndex) override  {  @<表项跟踪> (nItemIndex);  }
    # virtual void OnClick () override  {  @<左键单击表项> ();  }
    # virtual void OnRClick () override  {  @<右键单击表项> ();  }
    # virtual void OnDbClick () override  {  @<双击表项> ();  }
    # virtual INT OnBeginLabelEdit (INT nItemIndex) override  {  return @<开始编辑> (nItemIndex);  }
    # virtual INT OnEndlabelEdit (INT nItemIndex, CVolString& strEndEditContent) override  {  return @<结束编辑> (nItemIndex, strEndEditContent);  }
    # virtual void OnCheckboxChanged (INT nItemIndex, INT nState) override  {  @<检查框状态被改变> (nItemIndex, nState);  }
