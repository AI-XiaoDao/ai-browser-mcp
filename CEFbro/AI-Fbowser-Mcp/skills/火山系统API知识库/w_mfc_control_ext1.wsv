        @ pWnd->m_ilstHeader.DeleteImageList ();
        @ pWnd->m_ilstHeader.Attach ((HIMAGELIST)g_objVolApp.LoadResImageFile (VRIT_IMAGE_LIST, @<所欲设置的图片组文件>.GetText ()));
        @ pWnd->RefrushHeaderImageList ();
    }

