    # 方法 --

    方法 取项目数 <公开 类型 = 整数 注释 = "返回树型框中所有项目的数目" @禁止流程检查 = 真>
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetCount ());
    }

    方法 取缩进层次 <公开 类型 = 整数 注释 = "返回指定项目所处缩进层次,层次值从1开始. 如果未找到指定项目,返回0." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ INT nIndent = 0;
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     while (hItem != NULL)
        @     {
        @         nIndent++;
        @         hItem = pWnd->GetParentItem (hItem);
        @     }
        @ }
        @ return nIndent;
    }

    方法 取项目文本 <公开 类型 = 文本型 注释 = "返回指定项目的文本,如果该项目不存在,将返回空文本.">
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        变量 结果变量 <类型 = 文本型>
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @         @<结果变量>.SetText (pWnd->GetItemText (hItem));
        @ }
        返回 (结果变量)
    }

    方法 取图片 <公开 类型 = 整数 注释 = "返回指定项目的图片索引,如果该项目不存在,将返回-1." @禁止流程检查 = 真>
    参数 项目句柄 <类型 = 变整数 注释 = "提供所指定项目的句柄值">
    {
        @ CVWnd_TreeBox2* pWnd = (CVWnd_TreeBox2*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     HTREEITEM hItem = CVWnd_TreeBox2::sToItemHandle (@<项目句柄>);
        @     if (hItem != NULL)
        @     {
        @         INT nImageIndex = -1, nSelImageIndex;
        @         if (pWnd->GetItemImage (hItem, nImageIndex, nSelImageIndex))
        @             return nImageIndex;
        @     }
        @ }
        @ return -1;
    }

