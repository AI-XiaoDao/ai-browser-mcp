<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.属性表格

类 属性数据类型 <公开 注释 = "提供属性的类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 整数值 <公开 值 = @GP_DTYPE_INT>
    常量 小数值 <公开 值 = @GP_DTYPE_DOUBLE>
    常量 逻辑值 <公开 值 = @GP_DTYPE_BOOL>
    常量 文本值 <公开 值 = @GP_DTYPE_TEXT>
}

类 属性细节类型 <公开 注释 = "提供属性的细节类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = @GPDVT_NONE>
    常量 颜色 <公开 值 = @GPDVT_COLOR 注释 = "颜色值. 属性数据类型必须为\"整数值\".">
    常量 颜色支持透明 <公开 值 = @GPDVT_COLOR_WITH_TANS 注释 = "颜色值,支持使用透明色(颜色类.透明色). 属性数据类型必须为\"整数值\".">
    常量 颜色支持默认 <公开 值 = @GPDVT_COLOR_WITH_DEFAULT 注释 = "颜色值,支持使用默认色(颜色类.默认色). 属性数据类型必须为\"整数值\".">
    常量 打开文件名 <公开 值 = @GPDVT_OPEN_FILENAME 注释 = "欲打开文件名. 属性数据类型必须为\"文本值\".">
    常量 保存文件名 <公开 值 = @GPDVT_SAVE_FILENAME 注释 = "欲保存到文件名. 属性数据类型必须为\"文本值\".">
    常量 字体 <公开 值 = @GPDVT_FONT 注释 = "字体信息. 属性数据类型必须为\"文本值\".">
    常量 定宽字体 <公开 值 = @GPDVT_FIXED_PITCH_FONT 注释 = "定宽字体信息. 属性数据类型必须为\"文本值\".">
    常量 日期 <公开 值 = @GPDVT_DATE 注释 = "日期信息. 属性数据类型必须为\"文本值\".">
    常量 自定义 <公开 值 = @GPDVT_CUSTOM 注释 = "自定义文本信息. 属性数据类型必须为\"文本值\".">
}

# ===

类 属性表格 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\tr_vol_mfc_property_grid.h"
        @视窗.外部源文件 = "src\\tr_vol_mfc_color_popup.cpp\nsrc\\vol_mfc_property_grid.cpp"
        @视窗.后缀文本 = "public IPropertyGridEventListener"
        @视窗.窗口组件 = "icon=\"@66\"\ndefault_size = \"160, 240\"\ndefault_event = \"当前属性被改变\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_PropertyGrid, IPropertyGridEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 自定义属性按钮被单击 <公开 定义事件 类型 = 整数 注释 = "当细节类型为自定义的属性行右侧按钮被单击后,本事件被发送.">
    参数 属性标识值 <类型 = 变整数 注释 = "所单击属性的标识值,必定不为0.">
    参数 参数文本 <类型 = 文本型 注释 = "提供建立被单击属性时所提供的附加文本">
    参数 属性值 <类型 = 文本型 注释 = "  所单击属性的当前值内容,可以在事件处理程序中对其进行修改," 注释 = "修改后的内容会被置回属性值中.">

    方法 属性值被改变 <公开 定义事件 类型 = 整数 注释 = "当属性值被改变后,本事件被发送.">
    参数 属性标识值 <类型 = 变整数 注释 = "必定不为0">
    参数 属性值 <类型 = 文本型 注释 = "提供被修改后的属性值内容">

    方法 当前属性被改变 <公开 定义事件 类型 = 整数 注释 = "当前被选择属性被改变后,本事件被发送.">
    参数 当前选择属性标识值 <类型 = 变整数 注释 = "提供选择之后的当前属性,注意有可能为0,为0表示无.">
    参数 先前选择属性标识值 <类型 = 变整数 注释 = "提供选择之前的当前属性,注意有可能为0,为0表示无.">

    # 属性 --

    方法 背景色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.Grid ().m_clrBackground
    }

    方法 背景色 <公开 属性写 @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 整数 注释 = "可以使用\"颜色类\"中定义的常量值,使用\"颜色类.默认色\"以引用默认背景色.">
    {
        @ Grid ().m_clrBackground = (COLORREF)@<欲设置属性值>;
        @ UpdateColors ();
    }

    方法 文本色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.Grid ().m_clrText
    }

