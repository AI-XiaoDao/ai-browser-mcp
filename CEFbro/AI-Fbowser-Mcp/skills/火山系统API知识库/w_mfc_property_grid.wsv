    # 方法 --

    方法 刷新 <公开 注释 = "  更新属性表的布局,刷新属性表的显示." 注释 = "  如果\"修改后立即刷新\"属性值为假,则修改属性表内容后需要" 注释 = "调用本方法进行手动刷新,否则不需要调用本方法." @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().AdjustLayout ()
    }

    方法 加入属性 <公开 类型 = 变整数 注释 = "  加入一个属性到属性表中. 属性表窗口组件必须已经被创建." 注释 = "  加入后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则将不刷新需要用户在加入完"
            注释 = "所有属性后手动调用\"刷新\"方法刷新." 返回值注释 = "成功返回该属性的标识值(非0),失败返回0." @嵌入式方法 = "">
    参数 名称 <类型 = 文本型 注释 = "提供属性的名称">
    参数 类型 <类型 = 属性数据类型 注释 = "提供属性的数据类型">
    参数 细节类型 <类型 = 属性细节类型 注释 = "提供属性的细节类型" @默认值 = 属性细节类型.无>
    参数 属性值 <类型 = 文本型 注释 = "提供属性的初始值文本" @默认值 = "">
    参数 父属性标识值 <类型 = 变整数 注释 = "如果欲将新属性加入到一个父属性中,提供该父属性的标识值,为0表示无. 注意该属性必须为分组属性." @默认值 = 0>
    参数 备选项列表 <类型 = 文本型 注释 = "  当属性数据类型为\"文本值\"或\"整数值\"且属性细节类型为\"无\"时,用作提供属性所有待选择项的文" 注释 = "本项列表,各项目之间使用\'\\n\'换行符分隔." @默认值 = "">
    参数 附加文本 <类型 = 文本型 注释 = "  1. 当属性数据类型为\"文本值\"且属性细节类型为\"打开文件名\"或\"保存文件名\"时,用作提供文件" 注释 = "名过滤器文本. 该文本必须以\'|\'分隔和结束,类似以下格式:"
            注释 = "    \"JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|\"" 注释 = "    \"JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|GIF动画(*.gif)|*.gif|\""
            注释 = "    注意: 该文本在使用时尾部会自动加上匹配所有文件的过滤器." 注释 = "  2. 当属性数据类型为\"文本值\"且属性细节类型为\"自定义\"时,用作提供当用户单击值列右侧按钮"
            注释 = "时所触发\"自定义属性按钮被单击\"事件的\"参数文本\"参数值." @默认值 = "">
    参数 注释 <类型 = 文本型 注释 = "提供属性对应的注释文本" @默认值 = "">
    参数 用户数值 <类型 = 变整数 注释 = "提供关联到本属性的用户数值" @默认值 = 0>
    {
        @ @sn<this>.Grid ().AddNewGridProperty ((CMFCPropertyGridProperty*)@<父属性标识值>, @<名称>.GetText (), @<注释>.GetText (), (GP_VALUE_DATA_TYPE)@<类型>, 
        @         (GP_DETAIL_VALUE_TYPE)@<细节类型>, @<备选项列表>.GetText (), @<附加文本>.GetText (), @<用户数值>, @<属性值>.GetText ())
    }

    方法 加入文件属性 <公开 类型 = 变整数 注释 = "  加入一个可以用作获取欲打开/保存文件名的属性. 属性表窗口组件必须已经被创建." 注释 = "  注意从文件选择对话框中获得的文件名将受\"基准路径\"属性影响."
            注释 = "  加入后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则将不刷新需要用户在加入完" 注释 = "所有属性后手动调用\"刷新\"方法刷新." 返回值注释 = "成功返回该属性的标识值(非0),失败返回0.">
    参数 名称 <类型 = 文本型 注释 = "提供属性的名称">
    参数 是否为打开 <类型 = 逻辑型 注释 = "为真表示获取欲打开文件的名称,为假表示获取欲保存文件的名称." @默认值 = 真>
    参数 属性值 <类型 = 文本型 注释 = "提供属性的初始值文本" @默认值 = "">
    参数 父属性标识值 <类型 = 变整数 注释 = "如果欲将新属性加入到一个父属性中,提供该父属性的标识值,为0表示无. 注意该属性必须为分组属性." @默认值 = 0>
    参数 过滤器文本 <类型 = 文本型 注释 = "该文本必须以\'|\'分隔和结束,类似以下格式:" 注释 = "  \"JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|\""
            注释 = "  \"JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|GIF动画(*.gif)|*.gif|\"" 注释 = "  注意: 该文本在使用时尾部会自动加上匹配所有文件的过滤器." @默认值 = "">
    参数 注释 <类型 = 文本型 注释 = "提供属性对应的注释文本" @默认值 = "">
    参数 用户数值 <类型 = 变整数 注释 = "提供关联到本属性的用户数值" @默认值 = 0>
    {
        返回 (加入属性 (名称, 属性数据类型.文本值, 选择 (是否为打开, 属性细节类型.打开文件名, 属性细节类型.保存文件名), 属性值, 父属性标识值, , 过滤器文本, 注释, 用户数值))
    }

    方法 加入字体属性 <公开 类型 = 变整数 注释 = "  加入一个可以用作获取字体描述文本的属性. 属性表窗口组件必须已经被创建."
            注释 = "  加入后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则将不刷新需要用户在加入完" 注释 = "所有属性后手动调用\"刷新\"方法刷新." 注释 = "  属性值的格式为:"
            注释 = "    \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\"," 注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度."
            注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." 返回值注释 = "成功返回该属性的标识值(非0),失败返回0.">
    参数 名称 <类型 = 文本型 注释 = "提供属性的名称">
    参数 仅限定宽字体 <类型 = 逻辑型 注释 = "指定用户是否只能选择定宽字体" @默认值 = 假>
    参数 属性值 <类型 = 文本型 注释 = "提供属性的初始值文本" @默认值 = "">
    参数 父属性标识值 <类型 = 变整数 注释 = "如果欲将新属性加入到一个父属性中,提供该父属性的标识值,为0表示无. 注意该属性必须为分组属性." @默认值 = 0>
    参数 注释 <类型 = 文本型 注释 = "提供属性对应的注释文本" @默认值 = "">
    参数 用户数值 <类型 = 变整数 注释 = "提供关联到本属性的用户数值" @默认值 = 0>
