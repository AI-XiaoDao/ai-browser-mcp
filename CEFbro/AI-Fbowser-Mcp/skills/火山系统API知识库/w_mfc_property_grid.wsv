    方法 真值文本 <公开 属性读 类型 = 文本型 注释 = "指定属性表中用作代表逻辑值\"真\"的文本,如果为空,则默认为\"真\"." @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().m_strTrueLabel
    }

    方法 真值文本 <公开 属性写 注释 = "指定属性表中用作代表逻辑值\"真\"的文本,如果为空,则默认为\"真\"." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 文本型>
    {
        @ Grid ().m_strTrueLabel = @<欲设置属性值>;
        @ Grid ().UpdateTrueFalseLabal ();
    }

    方法 假值文本 <公开 属性读 类型 = 文本型 注释 = "指定属性表中用作代表逻辑值\"假\"的文本,如果为空,则默认为\"假\"." @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().m_strFalseLabel
    }

    方法 假值文本 <公开 属性写 注释 = "指定属性表中用作代表逻辑值\"假\"的文本,如果为空,则默认为\"假\"." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 文本型>
    {
        @ Grid ().m_strFalseLabel = @<欲设置属性值>;
        @ Grid ().UpdateTrueFalseLabal ();
    }

    方法 基准路径 <公开 属性读 类型 = 文本型 注释 = "指定当属性细节类型为\"打开文件名\"或\"保存文件名\"时,用作将用户所输入的绝对路径文件名转换为相对路径时使用的基准路径,为空表示不进行转换." @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().m_strBasePath
    }

    方法 基准路径 <公开 属性写 注释 = "指定当属性细节类型为\"打开文件名\"或\"保存文件名\"时,用作将用户所输入的绝对路径文件名转换为相对路径时使用的基准路径,为空表示不进行转换." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 文本型>
