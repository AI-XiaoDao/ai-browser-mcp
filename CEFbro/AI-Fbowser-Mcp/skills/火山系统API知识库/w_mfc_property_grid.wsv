    {
        @ @sn<this>.Grid ().IsAlwaysShowUserToolTip ()
    }

    方法 始终显示用户提示 <公开 属性写 注释 = "指定是否始终显示用户提示文本" @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ Grid ().AlwaysShowUserToolTip (@<欲设置属性值>);
