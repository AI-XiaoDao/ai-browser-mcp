            注释 = "  加入后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则将不刷新需要用户在加入完所有" 注释 = "属性后手动调用\"刷新\"方法刷新." 返回值注释 = "成功返回该属性的标识值(非0),失败返回0.">
    参数 名称 <类型 = 文本型 注释 = "提供属性的名称">
    参数 属性值 <类型 = 文本型 注释 = "  提供属性的日期文本,格式见\"到时间\"全局方法的中文格式说明,譬如:" 注释 = "\"1973年11月15日\", \"1973/11/15\", \"1973-11-15\"等."
            @默认值 = "">
    参数 父属性标识值 <类型 = 变整数 注释 = "如果欲将新属性加入到一个父属性中,提供该父属性的标识值,为0表示无. 注意该属性必须为分组属性." @默认值 = 0>
    参数 注释 <类型 = 文本型 注释 = "提供属性对应的注释文本" @默认值 = "">
    参数 用户数值 <类型 = 变整数 注释 = "提供关联到本属性的用户数值" @默认值 = 0>
    {
        返回 (加入属性 (名称, 属性数据类型.文本值, 属性细节类型.日期, 属性值, 父属性标识值, , , 注释, 用户数值))
    }

    方法 加入分组属性 <公开 类型 = 变整数 注释 = "  加入一个分组属性到属性表中. 分组属性中可以加入其它子属性." 注释 = "  只有本方法才能加入分组属性,其它方法所加入属性均为非分组属性."
            注释 = "  加入后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则将不刷新需要用户在加入完" 注释 = "所有属性后手动调用\"刷新\"方法刷新." 注释 = "  属性表窗口组件必须已经被创建."
            返回值注释 = "成功返回该属性的标识值(非0),失败返回0." @嵌入式方法 = "">
    参数 名称 <类型 = 文本型 注释 = "提供属性的名称">
    参数 父属性标识值 <类型 = 变整数 注释 = "如果欲将新属性加入到一个父属性中,提供该父属性的标识值,为0表示无. 注意该属性必须为分组属性." @默认值 = 0>
    参数 用户数值 <类型 = 变整数 注释 = "提供关联到本属性的用户数值" @默认值 = 0>
    {
        @ @sn<this>.Grid ().AddNewGridGroupProperty ((CMFCPropertyGridProperty*)@<父属性标识值>, @<名称>.GetText (), @<用户数值>)
    }

    方法 删除属性 <公开 类型 = 逻辑型 注释 = "  删除所指定的属性,成功(找到了该属性)删除返回真,失败返回假." 注释 = "  删除后,如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则需要用户"
            注释 = "在适当时候手动调用\"刷新\"方法刷新." @嵌入式方法 = "">
    参数 属性标识值 <类型 = 变整数 注释 = "提供所欲删除属性的标识值">
    {
        @ @sn<this>.Grid ().MRemoveProperty ((CMFCPropertyGridProperty*)@<属性标识值>)
    }

    方法 清空 <公开 注释 = "删除属性表中的所有属性" @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().RemoveAllProperties ()
    }

    方法 查找属性 <公开 类型 = 变整数 注释 = "查找返回属性表中第一个具有所指定用户数值的属性" 返回值注释 = "找到返回非0属性标识值值,未找到返回0" @嵌入式方法 = "">
    参数 欲查找用户数值 <类型 = 变整数 注释 = "提供所欲查找的用户数值">
    参数 是否查找子属性 <类型 = 逻辑型 注释 = "指定是否递归查找所有子属性(即非顶层属性)" @默认值 = 真>
    {
        @ @sn<this>.Grid ().FindPropertyByUserData (@<欲查找用户数值>, @<是否查找子属性>)
    }

    方法 置当前属性 <公开 注释 = "设置当前被选择属性,注意会触发\"当前属性被改变\"事件.">
    参数 所欲设置属性标识值 <类型 = 变整数 注释 = "如果为0,则取消被选择的当前属性.">
    {
        @ if (Grid ().m_hWnd != NULL)  Grid ().SetCurSel ((CMFCPropertyGridProperty*)@<所欲设置属性标识值>, TRUE);
    }

    方法 取当前属性 <公开 类型 = 变整数 注释 = "返回当前属性标识值,没有当前属性则返回0." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.Grid ().GetCurSel ()
    }

    方法 确保显示 <公开 注释 = "确保所指定的属性被显示">
    参数 属性标识值 <类型 = 变整数 注释 = "所欲确保其显示的属性标识值,该属性标识值值由所有属性加入方法返回.">
    参数 是否自动展开 <类型 = 逻辑型 注释 = "当所指定属性位于被折叠状态时,是否自动展开其所有父属性." @默认值 = 假>
    {
        @ if (@<属性标识值> != 0 && Grid ().m_hWnd != NULL)  Grid ().EnsureVisible ((CMFCPropertyGridProperty*)@<属性标识值>, @<是否自动展开>);
    }

    方法 全部展开 <公开 注释 = "展开或折叠所有分组属性." 注释 = "注意: 当\"自动排序\"属性为真时,本方法不起作用." @嵌入式方法 = "">
    参数 是否展开 <类型 = 逻辑型 注释 = "为真则展开,为假则折叠." @默认值 = 真>
    {
        @ @sn<this>.Grid ().ExpandAll (@<是否展开>)
    }

    方法 取用户数值 <公开 类型 = 变整数 注释 = "返回所指定属性的用户数值" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? 0 : CVolGridPropertyValue::sGetGridPropertyValue ((const CMFCPropertyGridProperty*)@<属性标识值>)->m_npUserData);
    }

    方法 置用户数值 <公开 注释 = "设置所指定属性的用户数值">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 所欲设置的用户数值 <类型 = 变整数>
    {
        @ if (@<属性标识值> != 0)  CVolGridPropertyValue::sGetGridPropertyValue ((CMFCPropertyGridProperty*)@<属性标识值>)->m_npUserData = @<所欲设置的用户数值>;
    }

    方法 取数据类型 <公开 类型 = 属性数据类型 注释 = "返回所指定属性的数据类型" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (INT)(@<属性标识值> == 0 ? GP_DTYPE_NONE : CVolGridPropertyValue::sGetGridPropertyValue ((const CMFCPropertyGridProperty*)@<属性标识值>)->m_enDataType);
    }

    方法 取细节类型 <公开 类型 = 属性细节类型 注释 = "返回所指定属性的细节类型" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值">
    {
        @ return (INT)(@<属性标识值> == 0 ? GPDVT_NONE : CVolGridPropertyValue::sGetGridPropertyValue ((const CMFCPropertyGridProperty*)@<属性标识值>)->m_enDetailType);
    }

    方法 取被扩展子属性数 <公开 类型 = 整数 注释 = "返回所指定分组属性的所有被展开的直接/间接子属性数目" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 是否包含隐藏属性 <类型 = 逻辑型 注释 = "指定是否包含所有被隐藏的子属性" @默认值 = 真>
    {
        @ return (@<属性标识值> == 0 ? 0 : ((CMFCPropertyGridProperty*)@<属性标识值>)->GetExpandedSubItems (@<是否包含隐藏属性>));
    }

    方法 添加属性备选项 <公开 类型 = 逻辑型 注释 = "添加一个属性值备选项" 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 备选项文本 <类型 = 文本型 注释 = "提供所欲添加备选项的文本内容">
    参数 是否要求唯一 <类型 = 逻辑型 注释 = "如果本参数值为真且所欲添加的备选项已经存在,则添加失败返回假." @默认值 = 真>
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->AddOption (@<备选项文本>.GetText (), @<是否要求唯一>));
    }

    方法 删除所有备选项 <公开 注释 = "删除指定属性的所有备选项">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ if (@<属性标识值> != 0)  ((CMFCPropertyGridProperty*)@<属性标识值>)->RemoveAllOptions ();
    }

    方法 取备选项数 <公开 类型 = 整数 注释 = "返回指定属性的当前备选项数目" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? 0 : ((CMFCPropertyGridProperty*)@<属性标识值>)->GetOptionCount ());
    }

    方法 取备选项 <公开 类型 = 文本型 注释 = "返回属性所指定索引位置处的备选项文本" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 备选项索引位置 <类型 = 整数 注释 = "提供所欲获取的备选项索引位置,必须大于等于0且小于\"取备选项数\"方法的返回值.">
    {
        @ return @an<CVolString> (@<属性标识值> == 0 ? _T ("") : ((CMFCPropertyGridProperty*)@<属性标识值>)->GetOption (@<备选项索引位置>));
    }

    方法 展开 <公开 注释 = "展开或折叠所指定的分组属性">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由\"加入分组属性\"方法返回的分组属性标识值值">
    参数 是否展开 <类型 = 逻辑型 注释 = "为真则展开,为假则折叠." @默认值 = 真>
    {
        @ if (@<属性标识值> != 0 && ((CMFCPropertyGridProperty*)@<属性标识值>)->IsGroup ())  ((CMFCPropertyGridProperty*)@<属性标识值>)->Expand (@<是否展开>);
    }

    方法 重绘属性 <公开 注释 = "重新绘制所指定的属性">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ if (@<属性标识值> != 0 && Grid ().m_hWnd != NULL)  ((CMFCPropertyGridProperty*)@<属性标识值>)->Redraw ();
    }

    方法 显示属性 <公开 注释 = "  显示或隐藏所指定的属性." 注释 = "  如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则需要用户" 注释 = "在适当时候手动调用\"刷新\"方法刷新." @嵌入式方法 = "">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 是否显示 <类型 = 逻辑型 注释 = "为真则显示,为假则隐藏.">
    {
        @ @sn<this>.Grid ().MShowProperty (@<属性标识值>, @<是否显示>)
    }

    方法 是否可视 <公开 类型 = 逻辑型 注释 = "返回所指定属性是否处于可视状态" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsVisible ());
    }

    方法 取属性名称 <公开 类型 = 文本型 注释 = "返回所指定属性的名称" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return @an<CVolString> (@<属性标识值> == 0 ? _T ("") : ((CMFCPropertyGridProperty*)@<属性标识值>)->GetName ());
    }

    方法 置属性名称 <公开 注释 = "  设置所指定属性的名称." 注释 = "  如果\"修改后立即刷新\"属性值为真,将立即刷新属性表,否则需要用户" 注释 = "在适当时候手动调用\"刷新\"方法刷新.">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 所欲设置名称 <类型 = 文本型>
    {
        @ if (@<属性标识值> != 0)  ((CMFCPropertyGridProperty*)@<属性标识值>)->SetName (@<所欲设置名称>.GetText (), Grid ().m_blRefrushAtOnce);
    }

    方法 取属性值 <公开 类型 = 文本型 注释 = "返回所指定属性的当前值" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ @an<CVolString> strPropValue;
        @ if (@<属性标识值> != 0)  CVolGridPropertyValue::sGetGridPropertyValue ((CMFCPropertyGridProperty*)@<属性标识值>)->GetPropValue (&strPropValue);
        @ return strPropValue;
    }

    方法 置属性值 <公开 注释 = "设置所指定属性的当前值. 属性表窗口组件必须已经被创建.">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 所欲设置的属性值 <类型 = 文本型>
    {
        @ if (@<属性标识值> != 0 && Grid ().m_hWnd != NULL)
        @     CVolGridPropertyValue::sGetGridPropertyValue ((CMFCPropertyGridProperty*)@<属性标识值>)->SetPropValue (@<所欲设置的属性值>.GetText ());
    }

    方法 取属性注释 <公开 类型 = 文本型 注释 = "返回所指定属性的注释内容" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ @an<CVolString> strPropValue;
        @ if (@<属性标识值> != 0)  strPropValue.SetText ((LPCTSTR)((CMFCPropertyGridProperty*)@<属性标识值>)->GetDescription ());
        @ return strPropValue;
    }

    方法 置属性注释 <公开 注释 = "设置所指定属性的注释内容">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 所欲设置的注释 <类型 = 文本型>
    {
        @ if (@<属性标识值> != 0)  ((CMFCPropertyGridProperty*)@<属性标识值>)->SetDescription (CString (@<所欲设置的注释>.GetText ()));
    }

    方法 是否为分组属性 <公开 类型 = 逻辑型 注释 = "返回所指定属性是否为分组属性" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsGroup ());
    }

    方法 是否被展开 <公开 类型 = 逻辑型 注释 = "返回所指定分组属性是否处于被展开状态" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsExpanded ());
    }

    方法 父属性是否被展开 <公开 类型 = 逻辑型 注释 = "返回所指定属性的所有直接/间接父属性是否均处于被展开状态" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsParentExpanded ());
    }

    方法 是否为当前属性 <公开 类型 = 逻辑型 注释 = "返回所指定属性是否为当前被选择属性" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsSelected ());
    }

    方法 取父属性数 <公开 类型 = 整数 注释 = "返回所指定属性直接/间接父属性的总共数目" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? 0 : ((CMFCPropertyGridProperty*)@<属性标识值>)->GetHierarchyLevel ());
    }

    方法 禁止属性 <公开 注释 = "禁止或许可用户对所指定属性进行操作">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 是否禁止 <类型 = 逻辑型 注释 = "为真禁止用户对所指定属性进行操作,为假则允许.">
    {
        @ if (@<属性标识值> != 0)  ((CMFCPropertyGridProperty*)@<属性标识值>)->Enable (@<是否禁止> == FALSE);
    }

    方法 属性是否被禁止 <公开 类型 = 逻辑型 注释 = "返回所指定属性是否禁止用户进行操作" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? TRUE : (((CMFCPropertyGridProperty*)@<属性标识值>)->IsEnabled () == FALSE));
    }

    方法 禁止编辑属性 <公开 注释 = "禁止或允许用户激活内嵌编辑框对所指定属性的内容进行编辑修改操作">
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    参数 是否禁止 <类型 = 逻辑型 注释 = "为真禁止用户对所指定属性的内容进行编辑修改操作,为假则允许.">
    {
        @ if (@<属性标识值> != 0)  ((CMFCPropertyGridProperty*)@<属性标识值>)->AllowEdit (@<是否禁止> == FALSE);
    }

    方法 属性是否可编辑 <公开 类型 = 逻辑型 注释 = "返回是否允许用户激活内嵌编辑框对所指定属性的内容进行编辑修改操作" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsAllowEdit ());
    }

    方法 取属性 <公开 类型 = 变整数 注释 = "返回所指定索引位置处的属性标识值" 返回值注释 = "成功返回非0属性标识值值,所提供索引位置无效则返回0." @禁止流程检查 = 真>
    参数 父属性标识值 <类型 = 变整数 注释 = "提供欲获取其直接子属性的父属性标识值,为0则去获取顶层属性." @默认值 = 0>
    参数 索引位置 <类型 = 整数 注释 = "提供所欲获取属性的索引位置,必须大于等于0且小于\"取属性数\"方法的返回值.">
    {
        @ return (@<父属性标识值> == 0 ? (INT_P)Grid ().GetProperty (@<索引位置>) : (INT_P)((CMFCPropertyGridProperty*)@<父属性标识值>)->GetSubItem (@<索引位置>));
    }

    方法 取属性数 <公开 类型 = 整数 注释 = "返回所具有属性的数目" @禁止流程检查 = 真>
    参数 父属性标识值 <类型 = 变整数 注释 = "提供欲获取其直接子属性数目的父属性标识值,为0则获取顶层属性的数目." @默认值 = 0>
    {
        @ return (@<父属性标识值> == 0 ? Grid ().GetPropertyCount () : ((CMFCPropertyGridProperty*)@<父属性标识值>)->GetSubItemsCount ());
    }

    方法 取父属性 <公开 类型 = 变整数 注释 = "返回指定属性的父属性标识值,如果不存在父属性,则返回0." @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? 0 : (INT_P)((CMFCPropertyGridProperty*)@<属性标识值>)->GetParent ());
    }

    方法 是否被修改 <公开 类型 = 逻辑型 注释 = "返回所指定属性是否处于被修改状态" @禁止流程检查 = 真>
    参数 属性标识值 <类型 = 变整数 注释 = "提供由所有属性加入方法返回的属性标识值值">
    {
        @ return (@<属性标识值> == 0 ? FALSE : ((CMFCPropertyGridProperty*)@<属性标识值>)->IsModified ());
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnCustomPropButtonClicked (PGRID_PROPERTY_ID idProperty, CVolString& strAdditional, CVolString& strPropValue) override { @<自定义属性按钮被单击> (idProperty, strAdditional, strPropValue); }
    # virtual void OnPropertyValueChanged (PGRID_PROPERTY_ID idProperty, CVolString& strPropValue) override  { @<属性值被改变> (idProperty, strPropValue); }
    # virtual void OnChangeSelection (PGRID_PROPERTY_ID idPropertyNewSel, PGRID_PROPERTY_ID idPropertyOldSel) override  { @<当前属性被改变> (idPropertyNewSel, idPropertyOldSel); }
    # inline_ CVolPropertyGridCtrl& Grid ()  { return ((CVWnd_PropertyGrid*)GetMfcWndPtr ())->m_grid; }
    # inline_ void UpdateColors ()  { Grid ().UpdateColors (); }
    # <> </include>
    # @end
}
