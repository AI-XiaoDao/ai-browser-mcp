    方法 修改后立即刷新 <公开 属性读 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().m_blRefrushAtOnce
    }

    方法 修改后立即刷新 <公开 属性写 注释 = "指定修改属性表内容(譬如加入新属性/删除属性/显示或隐藏属性等)后是否立即重新布局属性表并刷新其显示." 注释 = "在批量修改属性表内容前设置本属性值为假,可以提高修改速度并避免属性表闪烁."
            注释 = "如果本属性值被设置为假,在修改完属性表内容后,需要手动调用本对象的\"刷新\"方法以更新属性表的显示." 注释 = "当把本属性的值从假设置为真时,会自动刷新属性表." 注释 = "本属性默认值为真."
            @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ Grid ().SetRefrushAtOnce (@<欲设置属性值>);
    }

    方法 显示拖动上下文 <公开 属性读 类型 = 逻辑型 注释 = "指定在拖动属性表头部时是否显示拖动上下文" @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().IsShowDragContext ()
    }

