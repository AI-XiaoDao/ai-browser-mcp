    }

    方法 显示描述栏 <公开 属性写 注释 = "指定是否显示属性表底部的描述栏" @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ Grid ().EnableDescriptionArea (Grid ().m_blEnableDescriptionArea = @<欲设置属性值>);
    }

    方法 描述栏行数 <公开 属性读 类型 = 整数 注释 = "提供属性表底部描述栏的显示行数" @嵌入式方法 = "">
    {
        @ @sn<this>.Grid ().m_nNumDescriptionRows
    }

    方法 描述栏行数 <公开 属性写 注释 = "提供属性表底部描述栏的显示行数" @视窗.设置时机 = 组件创建前>
    参数 欲设置属性值 <类型 = 整数>
    {
