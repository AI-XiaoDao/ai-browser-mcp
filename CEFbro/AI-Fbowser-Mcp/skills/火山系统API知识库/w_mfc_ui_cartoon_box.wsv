    方法 文本背景颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr ())->m_clrTextBkColor
    }

    方法 文本背景颜色 <公开 属性写 @视窗.设置时机 = 组件创建前后 @值细节类型 = 颜色支持透明>
    参数 欲设置属性值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用" 注释 = "\"颜色类.透明色\"表示无文本背景颜色." @默认值 = 颜色类.透明色>
    {
        @ ((CVWnd_CartoonBox*)GetMfcWndPtr ())->m_clrTextBkColor = (COLORREF)@<欲设置属性值>;
    }

    方法 动画框字体 <公开 属性写 注释 = "如果指定了文字,本属性提供其字体." @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ GetFontDescTextInfo (@<字体描述文本>.GetText (), &pWnd->m_infFont);
        @ if (pWnd->m_hWnd != NULL)  pWnd->ReCreateFont ();
    }

    # 方法 --

    方法 创建物体 <公开 类型 = 整数 返回值注释 = "在动画框中创建指定动画物体,成功返回必定大于零的此新建物体标识值,失败返回-1." @禁止流程检查 = 真>
    参数 初始化数据 <类型 = 动画物体 注释 = "  本参数提供欲创建物体的初始化数据. 注意物体一旦创建完毕,即与此初始化数据脱离关系," 注释 = "以后对此初始化数据的任何更改均不会影响到已经创建的物体."
            注释 = "  本参数如果为空对象,将使用默认初始化数据." @默认值 = 空对象>
    参数 横坐标 <类型 = 整数 注释 = "本参数提供所创建物体左边的横坐标位置">
    参数 纵坐标 <类型 = 整数 注释 = "本参数提供所创建物体顶边的纵坐标位置">
    参数 是否显示 <类型 = 逻辑型 注释 = "本参数指定是否立即显示所创建物体" @默认值 = 真>
    参数 附加数据 <类型 = 文本型 注释 = "本参数提供随同所创建物体的附加文本数据" @默认值 = "">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->CreateObject ((@<初始化数据>.IsNullObject () ? NULL : &@<初始化数据>.m_inf), @<横坐标>, @<纵坐标>, @<是否显示>, @<附加数据>.GetText ()) : -1);
    }

    方法 销毁物体 <公开 注释 = "销毁动画框中已经被创建的指定标识值物体">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->DestroySpecIDObject (@<物体标识值>);
    }

    方法 销毁所有物体 <公开 注释 = "销毁动画框中所有已经被创建的物体">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->DestroyAllObject ();
    }

    方法 取物体数 <公开 类型 = 整数 注释 = "返回动画框中所有现存物体的数目" @禁止流程检查 = 真>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : (INT)pWnd->m_aryObjects.GetCount ());
    }

    方法 取标识值 <公开 类型 = 整数 注释 = "返回动画框中指定索引位置处物体的标识值,如果索引位置超出范围,将返回-1." 注释 = "注意动画框中物体的保存顺序是按照其层次的从小到大顺序排列的." @禁止流程检查 = 真>
    参数 索引值 <类型 = 整数 注释 = "参数值从0开始">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return ((pWnd == NULL || pWnd->m_aryObjects.IsIndexValid (@<索引值>) == FALSE) ? -1 : ((CCartoonObject*)pWnd->m_aryObjects [@<索引值>])->m_id);
    }

    方法 是否存在 <公开 类型 = 逻辑型 注释 = "如果动画框中存在指定标识值的物体,返回真,否则返回假." @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : (pWnd->FindSpecIDObjectIndex (@<物体标识值>) != -1));
    }

    方法 置文本 <公开 注释 = "设置动画框中指定物体上将显示的文本内容">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 欲设置文本 <类型 = 文本型 注释 = "本参数提供欲设置到物体上的文本内容,支持以换行符分隔的多行文本.">
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"."
            注释 = "  为空文本表示使用默认字体." @默认值 = "">
    参数 文本颜色 <类型 = 整数 注释 = "本参数提供物体上文本的颜色,如果为\"颜色类.默认色\",表示使用默认颜色." @默认值 = 颜色类.默认色>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectText (@<物体标识值>, @<欲设置文本>.GetText (), @<字体描述文本>.GetText (), @<文本颜色>);
    }

    方法 取文本 <公开 类型 = 文本型 注释 = "返回指定物体的文本内容" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return CVolString (pWnd == NULL ? _T ("") : pWnd->GetObjectText (@<物体标识值>));
    }

    方法 取文本颜色 <公开 类型 = 整数 注释 = "返回与指定物体相关文本的颜色" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectTextColor (@<物体标识值>));
    }

    方法 置图片 <公开 注释 = "设置动画框中指定物体上将显示的的图片内容">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 欲设置图片 <类型 = 字节集类 注释 = "  本参数提供欲设置到物体上的图片内容,如果该图片是GIF动画格式,其动画效果将默认关闭," 注释 = "可以使用播放动画命令进行播放. 如果为空对象/空字节集,此时将清除物体上的已有图片.">
    参数 透明色 <类型 = 整数 注释 = "本参数提供欲设置到物体上图片的透明色,可以使用\"颜色类\"所提供的颜色值."
            注释 = "如果提供值为-2,则自动取该图片最左上角点的颜色作为透明色,如果提供值为\"颜色类.透明色\"或-1,则为无透明色." @默认值 = 颜色类.透明色>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<欲设置图片>.IsNullObject ())
        @         pWnd->SetObjectPicture (@<物体标识值>, NULL, 0, (COLORREF)@<透明色>);
        @     else
        @         pWnd->SetObjectPicture (@<物体标识值>, @<欲设置图片>.GetPtr (), (INT)@<欲设置图片>.GetSize (), (COLORREF)@<透明色>);
        @ }
    }

    方法 置亮度 <公开 注释 = "设置动画框中指定物体的亮度">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 亮度 <类型 = 整数 注释 = "指定图片的亮度,值越小越暗,越大越亮,可以为负数,为0表示保持图片当前的亮度不变.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectLight (@<物体标识值>, @<亮度>);
    }

