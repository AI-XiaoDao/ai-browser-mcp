    参数 椭圆右下角纵坐标 <类型 = 整数>
    参数 弧线起始点横坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线起始点纵坐标 <类型 = 整数 注释 = "弧线从椭圆中心点至此起始点的直线与椭圆圆弧相交处开始绘制">
    参数 弧线终止点横坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    参数 弧线终止点纵坐标 <类型 = 整数 注释 = "弧线在椭圆中心点至此终止点的直线与椭圆圆弧相交处结束绘制">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_DrawArcChordPie (2, @<椭圆左上角横坐标>, @<椭圆左上角纵坐标>, @<椭圆右下角横坐标>, @<椭圆右下角纵坐标>, @<弧线起始点横坐标>, @<弧线起始点纵坐标>, @<弧线终止点横坐标>, @<弧线终止点纵坐标>);
    }

    方法 画矩形 <公开 注释 = "在动画框背景上画出一个矩形,矩形的内部使用当前刷子填充.">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_DrawRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>);
    }

    方法 填充矩形 <公开 注释 = "将动画框背景上指定的矩形区域用当前刷子填充,矩形的内部使用当前刷子填充.">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_FillRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>);
    }

    方法 画圆角矩形 <公开 注释 = "在动画框背景上画一个圆角矩形,圆角矩形的内部使用当前刷子填充.">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    参数 圆角宽度 <类型 = 整数>
    参数 圆角高度 <类型 = 整数 注释 = "如果本参数值小于0,则表示圆角高度等同于宽度." @默认值 = -1>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_DrawRoundRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>, @<圆角宽度>, @<圆角高度>);
    }

    方法 颜色翻转 <公开 注释 = "将动画框背景上指定矩形区域的颜色翻转过来">
    参数 矩形左上角横坐标 <类型 = 整数>
    参数 矩形左上角纵坐标 <类型 = 整数>
    参数 矩形右下角横坐标 <类型 = 整数>
    参数 矩形右下角纵坐标 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_InvertRect (@<矩形左上角横坐标>, @<矩形左上角纵坐标>, @<矩形右下角横坐标>, @<矩形右下角纵坐标>);
    }

    方法 画多边形 <公开 注释 = "在动画框背景上画一个多边形,如果所画的多边形没有闭合,将自动闭合.">
    参数 多边形顶点数组 <类型 = 整数数组类 注释 = "本参数数组顺序记录多边形各顶点的横向及纵向坐标值">
    参数 顶点数目 <类型 = 整数 注释 = "本参数指定多边形顶点的总数目. 如果小于0,表示等于多边形顶点数组中所记录的顶点数目." @默认值 = -1>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_DrawPolygon (@<多边形顶点数组>.data ().GetData (), (INT)@<多边形顶点数组>.data ().GetCount (), @<顶点数目>);
    }

    方法 置写出位置 <公开 注释 = "设置下次使用\"写文本行\"或\"写出\"命令输出数据时的位置">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数值为\"数值范围.最大整数值\",表示使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数值为\"数值范围.最大整数值\",表示使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_SetWritePos (@<横向写出位置>, @<纵向写出位置>);
    }

    方法 写文本行 <公开 注释 = "在动画框背景上当前写出位置写出指定的文本,并将现行写出位置调整到下行行首.">
    参数 欲写出文本 <类型 = 文本型 注释 = "如果本参数值为空文本,则写出一个空行.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_Print (0, @<欲写出文本>.GetText (), 0, 0);
    }

    方法 写出 <公开 注释 = "在动画框背景上当前写出位置处写出指定的文本,并自动调整现行写出位置到所写出文本的末位置.">
    参数 欲写出文本 <类型 = 文本型>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_Print (1, @<欲写出文本>.GetText (), 0, 0);
    }

    方法 定位写出 <公开 注释 = "在动画框背景上指定写出位置处写出指定的文本,不改变现行写出位置.">
    参数 横向写出位置 <类型 = 整数 注释 = "如果本参数值为\"数值范围.最大整数值\",表示使用现行横向写出位置." @默认值 = 数值范围.最大整数值>
    参数 纵向写出位置 <类型 = 整数 注释 = "如果本参数值为\"数值范围.最大整数值\",表示使用现行纵向写出位置." @默认值 = 数值范围.最大整数值>
    参数 欲写出文本 <类型 = 文本型>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_Print (2, @<欲写出文本>.GetText (), @<横向写出位置>, @<纵向写出位置>);
    }

    方法 取写出宽度 <公开 类型 = 整数 注释 = "返回指定文本的显示宽度" @禁止流程检查 = 真>
    参数 欲检测文本 <类型 = 文本型>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetTextDrawSize (TRUE, @<欲检测文本>.GetText ()));
    }

    方法 取写出高度 <公开 类型 = 整数 注释 = "返回指定文本的显示高度" @禁止流程检查 = 真>
    参数 欲检测文本 <类型 = 文本型>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetTextDrawSize (FALSE, @<欲检测文本>.GetText ()));
    }

    方法 复制背景 <公开 注释 = "将动画框背景中指定区域的内容复制到背景图上另一位置">
    参数 欲复制区域的左边 <类型 = 整数 @默认值 = 0>
    参数 欲复制区域的顶边 <类型 = 整数 @默认值 = 0>
    参数 欲复制区域的宽度 <类型 = 整数 注释 = "如果本参数值为\"数值范围,最大整数值\",表示使用动画框的宽度." @默认值 = 数值范围.最大整数值>
    参数 欲复制区域的高度 <类型 = 整数 注释 = "如果本参数值为\"数值范围,最大整数值\",表示使用动画框的高度." @默认值 = 数值范围.最大整数值>
    参数 欲复制到位置左边 <类型 = 整数 @默认值 = 0>
    参数 欲复制到位置顶边 <类型 = 整数 @默认值 = 0>
    参数 复制方法 <类型 = 整数 注释 = "本参数定义复制时对图像执行的位操作,可以为以下常量值之一或者其它自定义操作码:" 注释 = "1: 拷贝;   2: 翻转拷贝;  3: 位异或;  4: 位或;  5: 位与." @默认值 = 1>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->CartoonCopyBack (@<欲复制区域的左边>, @<欲复制区域的顶边>, @<欲复制区域的宽度>, @<欲复制区域的高度>, @<欲复制到位置左边>, @<欲复制到位置顶边>, (DWORD)@<复制方法>);
    }

    方法 键是否被按下 <公开 静态 类型 = 逻辑型 注释 = "如果指定键已经被按下,返回真,否则返回假." @禁止流程检查 = 真>
    参数 欲检查的按键 <类型 = 整数 注释 = "本参数提供欲检查其是否被按下的按键的代码值. 参见\"按键码\"类.">
    {
        @ return (GetKeyState ((INT)GetVirtualKeyFromKeyCode ((UINT_P)@<欲检查的按键>)) < 0);
    }

    方法 添加图片 <公开 注释 = "在动画框中指定物体上添加一张图片,从而使其与已有图片共同形成动画效果.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 欲添加图片 <类型 = 字节集类 注释 = "本参数提供欲添加到物体上的图片内容,如果该图片是GIF动画格式,则其中的所有帧都将被添加上去.">
    参数 透明色 <类型 = 整数 注释 = "本参数提供该图片的透明色,可以使用\"颜色类\"所提供的颜色值." 注释 = "如果提供值为-2,则自动取该图片最左上角点的颜色作为透明色,如果提供值为\"颜色类.透明色\"或-1,则为无透明色."
            @默认值 = 颜色类.透明色>
    参数 间隔时间 <类型 = 整数 注释 = "本参数指定显示本张图片后到显示下张图片之间需要等待的间隔时间,单位为毫秒." @默认值 = 10>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->AddObjectPicture (@<物体标识值>, @<欲添加图片>.GetPtr (), (INT)@<欲添加图片>.GetSize (), @<透明色>, @<间隔时间>);
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnObjectLButtonDown (INT nObjectID) override  { @<物体左键被按下> (nObjectID); }
    # virtual void OnObjectRButtonDown (INT nObjectID) override  { @<物体右键被按下> (nObjectID); }
    # virtual void OnObjectLButtonUp (INT nObjectID, INT nPressedObjectID) override  { @<物体左键被放开> (nObjectID, nPressedObjectID); }
    # virtual void OnObjectRButtonUp (INT nObjectID) override  { @<物体右键被放开> (nObjectID); }
    # virtual void OnObjectDblClick (INT nObjectID) override  { @<双击物体> (nObjectID); }
    # virtual void OnObjectEntry (INT nObjectID, INT nPressedObjectID) override  { @<进入物体> (nObjectID, nPressedObjectID); }
    # virtual void OnObjectLeave (INT nObjectID, INT nPressedObjectID) override  { @<离开物体> (nObjectID, nPressedObjectID); }
    # virtual void OnCartoonBoxMouseMove (INT x, INT y, INT nPressedObjectID) override  { @<动画框鼠标位置改变> (x, y, nPressedObjectID); }
    # virtual BOOL OnBeforeObjectPosChanged (INT nObjectID, INT x, INT y) override  { return (@<物体位置将改变> (nObjectID, x, y) == 0); }
    # virtual void OnAfterObjectPosChanged (INT nObjectID, INT x, INT y) override  { @<物体位置已改变> (nObjectID, x, y); }
    # virtual void OnObjectDestroy (INT nObjectID) override  { @<物体将销毁> (nObjectID); }
    # virtual void OnBumpIntoObject (INT nObjectID, INT x, INT y, INT nBumpIntoObjectID) override  { @<碰撞到物体> (nObjectID, x, y, nBumpIntoObjectID); }
    # virtual void OnBumpIntoBorder (INT nObjectID, INT x, INT y, INT nBumpIntoBorderFlag) override  { @<碰撞到边界> (nObjectID, x, y, nBumpIntoBorderFlag); }
    # virtual void OnObjectOutBorder (INT nObjectID) override  { @<越出边界> (nObjectID); }
    # virtual void OnObjectAutoForwardStopped (INT nObjectID) override  { @<自动前进停止> (nObjectID); }
    # virtual void OnObjectAutoRotateStopped (INT nObjectID) override  { @<自动旋转停止> (nObjectID); }
    # virtual void OnObjectAnimPlayOver (INT nObjectID) override  { @<动画播放完毕> (nObjectID); }
    # virtual void OnWatchedKeyPressed (INT nKeyCode, INT nAuxKeyState) override  { @<监视键被按下> (nKeyCode, nAuxKeyState); }
    # <> </include>
