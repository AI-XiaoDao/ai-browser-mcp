<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.动画框 <编辑时信息 = "15AA95, 0, 0, 0" @视窗.外部头文件 = "src\\vol_mfc_cartoon_box.h"
        @视窗.外部源文件 = "src\\vol_mfc_cartoon_box.cpp\r\nsrc\\vol_gif_loader.cpp">

类 动画物体 <公开 注释 = "用作提供动画框中的物体">
{
    方法 文字 <公开 属性读 类型 = 文本型 @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_strText
    }

    方法 文字 <公开 属性写 注释 = "指定在物体上显示文字,支持以换行符分隔的多行文本.如果同时提供了文字和图片,将仅显示文字.">
    参数 欲设置属性值 <类型 = 文本型>
    {
        @ m_inf.SetText (@<欲设置属性值>.GetText ());
    }

    方法 字体 <公开 属性写 注释 = "如果指定了文字,本属性提供其字体." @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ m_inf.SetFont (@<字体描述文本>.GetText ());
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.m_inf.m_clrTextColor
    }

    方法 文本颜色 <公开 属性写 注释 = "如果指定了文字,本属性提供其前景颜色." @值细节类型 = 颜色>
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.SetTextColor ((COLORREF)@<欲设置属性值>);
    }

    方法 图片数据 <公开 属性读 类型 = 字节集类 @禁止流程检查 = 真>
    {
        @ return m_inf.m_memPicData;
    }

    方法 图片 <公开 属性写 注释 = "指定在物体上显示图片,如果该图片是GIF动画格式,其动画效果将得到体现.">
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消图片.">
    {
        @ g_objVolApp.LoadResData (@<所欲设置的位图>, m_inf.m_memPicData);
        @ m_inf.FreeLoadedPic ();
    }

    方法 图片数据 <公开 属性写 注释 = "指定在物体上显示图片,如果该图片是GIF动画格式,其动画效果将得到体现.">
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所欲设置的位图数据,如果为空,则将取消图片.">
    {
        @ m_inf.m_memPicData.CopyFrom (@<所欲设置的位图数据>);
        @ m_inf.FreeLoadedPic ();
    }

    方法 图片文件 <公开 属性写 注释 = "指定在物体上显示图片,如果该图片是GIF动画格式,其动画效果将得到体现." 编辑时信息 = "FD545, 0, 0, 0" @值细节类型 = 文件名
            @附加文本 = "所有图片文件|*.gif;*.bmp;*.emf;*.wmf;*.jpg;*.jpeg;*.png;*.tif;*.ico|GIF文件(*.gif)|*.gif|BMP文件(*.bmp)|*.bmp|EMF文件(*.emf)|*.emf|WMF文件(*.wmf)|*.wmf|JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|PNG文件(*.png)|*.png|TIFF文件(*.tif)|*.tif|ICO文件(*.ico)|*.ico|">
    参数 所欲设置的位图文件名 <类型 = 文本型 注释 = "提供所欲设置的位图文件名,如果为空文本,将取消图片." 编辑时信息 = "FD545, 0, 0, 0">
    {
        @ m_inf.m_memPicData.Free ();
        @ m_inf.m_memPicData.ReadFromFile (@<所欲设置的位图文件名>.GetText ());
        @ m_inf.FreeLoadedPic ();
    }

    方法 自动取透明色 <公开 属性读 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_blAutoGetTransColor
    }

    方法 自动取透明色 <公开 属性写 注释 = "如果指定了图片且设置本属性为真,则自动取该图片最左上角点的颜色作为透明色.">
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ m_inf.SetAutoGetTransColor (@<欲设置属性值>);
    }

    方法 透明色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.m_inf.m_clrTransparent
    }

    方法 透明色 <公开 属性写 注释 = "如果指定了图片且自动取透明色属性为假,本属性提供其中透明部分的具体颜色.如果此时设置本属性值为默认底色,则说明该图片无透明色." @值细节类型 = 颜色支持默认>
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.SetTransparentColor ((COLORREF)@<欲设置属性值>);
    }

    方法 播放动画 <公开 属性读 类型 = 逻辑型 注释 = "如果所指定图片是GIF动画格式,则本属性指定是否自动播放它." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_blPlayGIF
    }

    方法 播放动画 <公开 属性写 注释 = "如果所指定图片是GIF动画格式,则本属性指定是否自动播放它.">
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ m_inf.m_blPlayGIF = @<欲设置属性值>;
    }

    方法 动画间隔时间 <公开 属性读 类型 = 整数 注释 = "如果所指定图片是GIF动画格式,则本属性指定在每次播放之间插入的间隔延迟时间,单位为毫秒." @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.m_inf.m_dwGIFDelay
    }

    方法 动画间隔时间 <公开 属性写 注释 = "如果所指定图片是GIF动画格式,则本属性指定在每次播放之间插入的间隔延迟时间,单位为毫秒.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_dwGIFDelay = (DWORD)@<欲设置属性值>;
    }

    方法 动画自动销毁 <公开 属性读 类型 = 整数 注释 = "如果所指定图片是GIF动画格式,则本属性指定当该GIF动画播放几次后自动销毁该物体." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nGIFAutoDestroyTimes
    }

    方法 动画自动销毁 <公开 属性写 注释 = "如果所指定图片是GIF动画格式,则本属性指定当该GIF动画播放几次后自动销毁该物体.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nGIFAutoDestroyTimes = @<欲设置属性值>;
    }

    方法 趋向色 <公开 属性读 类型 = 整数 注释 = "指定图片中所有颜色所共同趋向的一个颜色" @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.m_inf.m_clrTrendColor
    }

    方法 趋向色 <公开 属性写 注释 = "指定图片中所有颜色所共同趋向的一个颜色" @值细节类型 = 颜色>
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_clrTrendColor = (COLORREF)@<欲设置属性值>;
    }

    方法 趋向程度 <公开 属性读 类型 = 整数 注释 = "指定图片中所有颜色向趋向色转变的百分比程度,值范围应该在0到100之间. 如果为0,表明不作任何趋向颜色转换." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nTrendDepth
    }

    方法 趋向程度 <公开 属性写 注释 = "指定图片中所有颜色向趋向色转变的百分比程度,值范围应该在0到100之间. 如果为0,表明不作任何趋向颜色转换.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nTrendDepth = @<欲设置属性值>;
    }

    方法 亮度 <公开 属性读 类型 = 整数 注释 = "指定图片的亮度,值越小越暗,越大越亮,可以为负数,为0表示保持图片当前的亮度不变." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nLight
    }

    方法 亮度 <公开 属性写 注释 = "指定图片的亮度,值越小越暗,越大越亮,可以为负数,为0表示保持图片当前的亮度不变.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nLight = @<欲设置属性值>;
    }

    方法 透明度 <公开 属性读 类型 = 整数 注释 = "本属性提供物体透明度的百分比,值范围从0到100. 0表示完全不透明,此时其下层物体将被完全遮盖,为100表示完全透明,此时下层物体将被完全显示." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nAlpha
    }

    方法 透明度 <公开 属性写 注释 = "本属性提供物体透明度的百分比,值范围从0到100. 0表示完全不透明,此时其下层物体将被完全遮盖,为100表示完全透明,此时下层物体将被完全显示.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nAlpha = @<欲设置属性值>;
    }

    方法 缩放比 <公开 属性读 类型 = 整数 注释 = "本属性提供对物体进行缩放的千分比例" @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nZoom
    }

    方法 缩放比 <公开 属性写 注释 = "本属性提供对物体进行缩放的千分比例">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nZoom = @<欲设置属性值>;
    }

    方法 层次 <公开 属性读 类型 = 整数 注释 = "指定物体在动画框中所处的层次,值越小表示所处层次越低. 注意碰撞只可能在同层物体之间产生." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nLayer
    }

    方法 层次 <公开 属性写 注释 = "指定物体在动画框中所处的层次,值越小表示所处层次越低. 注意碰撞只可能在同层物体之间产生.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nLayer = @<欲设置属性值>;
    }

    方法 角度 <公开 属性读 类型 = 整数 注释 = "指定物体在动画框中基于纵轴顺时针的向前移动角度,值应该在-360到360之间." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nAngle
    }

    方法 角度 <公开 属性写 注释 = "指定物体在动画框中基于纵轴顺时针的向前移动角度,值应该在-360到360之间.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nAngle = @<欲设置属性值>;
    }

    方法 旋转跟随 <公开 属性读 类型 = 逻辑型 注释 = "指定当物体向前移动角度被调整时,是否自动将物体本身图片同时旋转到该角度." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_blRotateFollow
    }

    方法 旋转跟随 <公开 属性写 注释 = "指定当物体向前移动角度被调整时,是否自动将物体本身图片同时旋转到该角度.">
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ m_inf.m_blRotateFollow = @<欲设置属性值>;
    }

    方法 翻转 <公开 属性读 类型 = 整数 注释 = "指定物体图片的翻转方式" @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nTurnType
    }

    方法 翻转 <公开 属性写 注释 = "指定物体图片的翻转方式" @列表选择项 = "不翻转\n左右翻转\n上下翻转\n上下左右翻转">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nTurnType = @<欲设置属性值>;
    }

    方法 生存时间 <公开 属性读 类型 = 整数 注释 = "指自物体被创建后在动画框中的生存时间,当此时间达到后该物体将被自动销毁,单位为毫秒. 0表示无限制." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nExistTime
    }

    方法 生存时间 <公开 属性写 注释 = "指自物体被创建后在动画框中的生存时间,当此时间达到后该物体将被自动销毁,单位为毫秒. 0表示无限制.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nExistTime = @<欲设置属性值>;
    }

    方法 创建声音 <公开 属性写 注释 = "指定当物体在动画框中被创建时播放的声音资源(wav格式)">
    参数 欲设置属性值 <类型 = WAV资源>
    {
        @ g_objVolApp.LoadResData (@<欲设置属性值>, m_inf.m_memCreateSound, _T ("WAVE"));
    }

    方法 创建声音数据 <公开 属性写 注释 = "指定当物体在动画框中被创建时播放的声音数据(wav格式)">
    参数 声音数据 <类型 = 字节集类>
    {
        @ m_inf.m_memCreateSound.CopyFrom (@<声音数据>);
    }

    方法 创建声音文件 <公开 属性写 注释 = "指定当物体在动画框中被创建时播放的声音文件(wav格式)" @值细节类型 = 文件名 @附加文本 = "WAV声音文件(*.wav)|*.wav|">
    参数 声音文件名 <类型 = 文本型>
    {
        @ m_inf.m_memCreateSound.Free ();
        @ m_inf.m_memCreateSound.ReadFromFile (@<声音文件名>.GetText ());
    }

    方法 销毁声音 <公开 属性写 注释 = "指定当物体在动画框中被销毁时播放的声音资源(wav格式)">
    参数 欲设置属性值 <类型 = WAV资源>
    {
        @ g_objVolApp.LoadResData (@<欲设置属性值>, m_inf.m_memDestroySound, _T ("WAVE"));
    }

    方法 销毁声音数据 <公开 属性写 注释 = "指定当物体在动画框中被销毁时播放的声音数据(wav格式)">
    参数 声音数据 <类型 = 字节集类>
    {
        @ m_inf.m_memDestroySound.CopyFrom (@<声音数据>);
    }

    方法 销毁声音文件 <公开 属性写 注释 = "指定当物体在动画框中被销毁时播放的声音文件(wav格式)" @值细节类型 = 文件名 @附加文本 = "WAV声音文件(*.wav)|*.wav|">
    参数 声音文件名 <类型 = 文本型>
    {
        @ m_inf.m_memDestroySound.Free ();
        @ m_inf.m_memDestroySound.ReadFromFile (@<声音文件名>.GetText ());
    }

    方法 允许碰撞 <公开 属性读 类型 = 逻辑型 注释 = "指定当物体向前移动后与同层另外一个不同类型值物体相互交叠时是否启动碰撞处理机制,注意:"
            注释 = "  1. 物体是否被显示并不影响到碰撞处理,也就是说如果允许碰撞,即使物体被隐藏也会启动碰撞处理;" 注释 = "  2. 被碰撞到的物体必须也同时允许碰撞才会触发碰撞机制;"
            注释 = "  3. 只有当物体进行前进动作时(“前进”或“自动前进”命令引发)才会进行碰撞检测,其它情况下不会去检测碰撞." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_blCollideAllowed
    }

    方法 允许碰撞 <公开 属性写 注释 = "指定当物体向前移动后与同层另外一个不同类型值物体相互交叠时是否启动碰撞处理机制,注意:" 注释 = "  1. 物体是否被显示并不影响到碰撞处理,也就是说如果允许碰撞,即使物体被隐藏也会启动碰撞处理;"
            注释 = "  2. 被碰撞到的物体必须也同时允许碰撞才会触发碰撞机制;" 注释 = "  3. 只有当物体进行前进动作时(“前进”或“自动前进”命令引发)才会进行碰撞检测,其它情况下不会去检测碰撞.">
    参数 欲设置属性值 <类型 = 逻辑型>
    {
        @ m_inf.m_blCollideAllowed = @<欲设置属性值>;
    }

    方法 碰撞声音 <公开 属性写 注释 = "如果允许碰撞,指定当物体向前移动碰撞到其它物体时播放的声音(wav格式).">
    参数 欲设置属性值 <类型 = WAV资源>
    {
        @ g_objVolApp.LoadResData (@<欲设置属性值>, m_inf.m_memCollidedSound, _T ("WAVE"));
    }

    方法 碰撞声音数据 <公开 属性写 注释 = "如果允许碰撞,指定当物体向前移动碰撞到其它物体时播放的声音数据(wav格式).">
    参数 声音数据 <类型 = 字节集类>
    {
        @ m_inf.m_memCollidedSound.CopyFrom (@<声音数据>);
    }

    方法 碰撞声音文件 <公开 属性写 注释 = "如果允许碰撞,指定当物体向前移动碰撞到其它物体时播放的声音文件(wav格式)." @值细节类型 = 文件名 @附加文本 = "WAV声音文件(*.wav)|*.wav|">
    参数 声音文件名 <类型 = 文本型>
    {
        @ m_inf.m_memCollidedSound.Free ();
        @ m_inf.m_memCollidedSound.ReadFromFile (@<声音文件名>.GetText ());
    }

    方法 类型值 <公开 属性读 类型 = 整数 注释 = "所有动画框中的物体均有类型值,该值可以是任意整数,物体之间的碰撞仅在具有不同类型值的同层物体之间产生." @嵌入式方法 = "">
    {
        @ @sn<this>.m_inf.m_nType
    }

    方法 类型值 <公开 属性写 注释 = "所有动画框中的物体均有类型值,该值可以是任意整数,物体之间的碰撞仅在具有不同类型值的同层物体之间产生.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ m_inf.m_nType = @<欲设置属性值>;
    }

    # --

    方法 初始化 <公开 注释 = "重新将本对象的内容初始为默认内容">
    {
        @ m_inf.init ();
    }

    方法 取内容宽度 <公开 类型 = 整数 注释 = "返回当前文字或图片内容的显示宽度,单位为像素." @禁止流程检查 = 真>
    {
        @ return m_inf.CheckLoadPic ()->m_nWidth;
    }

    方法 取内容高度 <公开 类型 = 整数 注释 = "返回当前文字或图片内容的显示高度,单位为像素." @禁止流程检查 = 真>
    {
        @ return m_inf.CheckLoadPic ()->m_nHeight;
    }

    # --
    #
    # @ <include>
    # @ CCartoonObjectInfo m_inf;
    # @ </include>
}

类 动画框 <公开 基础类 = 窗口组件 @视窗.后缀文本 = "public ICartoonBoxEventListener"
        @视窗.窗口组件 = "icon=\"res\\cartoon_box.bmp\"\ndefault_size = \"200, 240\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_CartoonBox, ICartoonBoxEventListener, 0, 0, WS_TABSTOP, 0)
    #
    # 事件 --

    方法 物体左键被按下 <公开 定义事件 类型 = 整数 注释 = "当在物体上按下鼠标左键后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">

    方法 物体右键被按下 <公开 定义事件 类型 = 整数 注释 = "当在物体上按下鼠标右键后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">

    方法 物体左键被放开 <公开 定义事件 类型 = 整数 注释 = "当在物体上放开鼠标左键后产生此事件." 注释 = "如果事件的两个参数值大于0且相同,则可以确认在该物体上发生了左键单击事件.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">
    参数 已被按下物体 <类型 = 整数 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置处于某物体上,则本参数提供该物体的标识值;" 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置不处于任何物体上,则本参数值为-1;"
            注释 = "如果当前鼠标左键未被按下,则本参数值为0.">

    方法 物体右键被放开 <公开 定义事件 类型 = 整数 注释 = "当在物体上放开鼠标右键后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">

    方法 双击物体 <公开 定义事件 类型 = 整数 注释 = "物体被鼠标左键双击后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">

    方法 进入物体 <公开 定义事件 类型 = 整数 注释 = "当鼠标位置移动进入到某物体内时产生此事件." 注释 = "如果该事件的\"已被按下物体\"参数值大于0且不等于\"物体标识值\"参数值,则可以确认有另外物体被鼠标拖曳进了当前物体.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">
    参数 已被按下物体 <类型 = 整数 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置处于某物体上,则本参数提供该物体的标识值;" 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置不处于任何物体上,则本参数值为-1;"
            注释 = "如果当前鼠标左键未被按下,则本参数值为0.">

    方法 离开物体 <公开 定义事件 类型 = 整数 注释 = "当鼠标位置离开某物体时产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供鼠标事件发生位置所在相关物体的标识值,小于等于0表示无相关物体.">
    参数 已被按下物体 <类型 = 整数 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置处于某物体上,则本参数提供该物体的标识值;" 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置不处于任何物体上,则本参数值为-1;"
            注释 = "如果当前鼠标左键未被按下,则本参数值为0.">

    方法 动画框鼠标位置改变 <公开 定义事件 类型 = 整数 注释 = "当在动画框上移动鼠标位置时产生此事件">
    参数 横坐标 <类型 = 整数 注释 = "本参数提供当前鼠标的横坐标位置,相对于所处动画框左边框.">
    参数 纵坐标 <类型 = 整数 注释 = "本参数提供当前鼠标的纵坐标位置,相对于所处动画框上边框.">
    参数 已被按下物体 <类型 = 整数 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置处于某物体上,则本参数提供该物体的标识值;" 注释 = "如果当前鼠标左键已经被按下,且鼠标左键按下时位置不处于任何物体上,则本参数值为-1;"
            注释 = "如果当前鼠标左键未被按下,则本参数值为0.">

    方法 物体位置将改变 <公开 定义事件 类型 = 整数 注释 = "当物体位置即将被改变时产生此事件,返回0允许此改变,返回1不允许.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">
    参数 横坐标 <类型 = 整数 注释 = "本参数提供相关物体左边移动到的横坐标位置,相对于所处动画框左边框.">
    参数 纵坐标 <类型 = 整数 注释 = "本参数提供相关物体顶边移动到的纵坐标位置,相对于所处动画框上边框.">

    方法 物体位置已改变 <公开 定义事件 类型 = 整数 注释 = "当物体位置已经被改变后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">
    参数 横坐标 <类型 = 整数 注释 = "本参数提供相关物体左边移动到的横坐标位置,相对于所处动画框左边框.">
    参数 纵坐标 <类型 = 整数 注释 = "本参数提供相关物体顶边移动到的纵坐标位置,相对于所处动画框上边框.">

    方法 物体将销毁 <公开 定义事件 类型 = 整数 注释 = "某物体将被销毁前产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">

    方法 碰撞到物体 <公开 定义事件 类型 = 整数 注释 = "某物体前进第一次碰撞到另一同层不同类型值物体时产生此事件."
            注释 = "注意只有当物体进行前进动作时(\"前进\"或\"自动前进\"命令引发)才会进行碰撞检测.其它情况下不会去检测碰撞.">
    参数 碰撞物体标识值 <类型 = 整数 注释 = "本参数提供主动碰撞方物体的标识值">
    参数 碰撞前横坐标 <类型 = 整数 注释 = "本参数提供碰撞前主动碰撞方物体的横坐标位置,相对于所处动画框左边框.">
    参数 碰撞前纵坐标 <类型 = 整数 注释 = "本参数提供碰撞前主动碰撞方物体的纵坐标位置,相对于所处动画框左边框.">
    参数 被碰撞物体标识值 <类型 = 整数 注释 = "本参数提供被碰撞物体的标识值">

    方法 碰撞到边界 <公开 定义事件 类型 = 整数 注释 = "当某物体前进碰撞到动画框边框后产生此事件." 注释 = "注意只有当物体进行前进动作时(\"前进\"或\"自动前进\"命令引发)才会进行碰撞检测.其它情况下不会去检测碰撞.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">
    参数 碰撞前横坐标 <类型 = 整数 注释 = "本参数提供碰撞前该物体的横坐标位置,相对于所处动画框左边框.">
    参数 碰撞前纵坐标 <类型 = 整数 注释 = "本参数提供碰撞前该物体的纵坐标位置,相对于所处动画框左边框.">
    参数 边界类型 <类型 = 整数 注释 = "  本参数提供碰撞到边界的类型: 1:左边界; 2:上边界; 4:右边界; 8:下边界." 注释 = "注意有可能同时碰撞到几个边界,所以应该通过检测相应位来查看具体碰撞到了哪些边界.">

    方法 越出边界 <公开 定义事件 类型 = 整数 注释 = "当某物体前进越出动画框边框外后产生此事件." 注释 = "注意只有当物体进行前进动作时(\"前进\"或\"自动前进\"命令引发)才会进行此检测.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">

    方法 自动前进停止 <公开 定义事件 类型 = 整数 注释 = "当物体自动前进被停止后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">

    方法 自动旋转停止 <公开 定义事件 类型 = 整数 注释 = "当物体自动旋转被停止后产生此事件">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">

    方法 动画播放完毕 <公开 定义事件 类型 = 整数 注释 = "当某物体上由\"播放动画\"命令所指定次数的动画被播放完毕后,产生此事件.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供相关物体的标识值">

    方法 监视键被按下 <公开 定义事件 类型 = 整数 注释 = "  此事件当用户按下一个监视键后发生." 注释 = "  监视键被按下事件与普通的按下某键事件相比有以下不同: 假设你在按下A键后再同时按下B键,"
            注释 = "然后放开B键但仍然保持A键的按下状态,那么普通的按下某键事件将不会再发送A键被按下事件," 注释 = "但此时如果A键已被设置为监视键,那么将继续发送A监视键被按下事件.">
    参数 键代码 <类型 = 整数 注释 = "提供具体的按键代码值. 参见\"按键码\"类.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    # 属性 --
    #

    方法 背景颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_clrBackColor
    }

    方法 背景颜色 <公开 属性写 @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认背景颜色.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ pWnd->m_clrBackColor = (COLORREF)@<欲设置属性值>;
        @ if (pWnd->m_hWnd != NULL)  { pWnd->CreateBackBitmap (); pWnd->Invalidate (FALSE); }
    }

    方法 背景图片 <公开 属性写 注释 = "本属性指定显示在动画框上的背景图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图 <类型 = 位图资源 注释 = "提供所欲设置的位图资源,如果该资源值为\"空资源.空位图\",则将取消图片.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ g_objVolApp.LoadResData (@<所欲设置的位图>, pWnd->m_memPicData);
        @ if (pWnd->m_hWnd != NULL)  { pWnd->CreateBackBitmap (); pWnd->Invalidate (FALSE); }
    }

    方法 背景图片数据 <公开 属性写 注释 = "本属性指定显示在动画框上的背景图片" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的位图数据 <类型 = 字节集类 注释 = "提供所欲设置的位图数据,如果为空,则将取消图片.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ pWnd->m_memPicData.CopyFrom (@<所欲设置的位图数据>);
        @ if (pWnd->m_hWnd != NULL)  { pWnd->CreateBackBitmap (); pWnd->Invalidate (FALSE); }
    }

    方法 背景图片文件 <公开 属性写 注释 = "本属性指定显示在动画框上的背景图片" @视窗.设置时机 = 组件创建前后 @值细节类型 = 文件名
            @附加文本 = "所有图片文件|*.gif;*.bmp;*.emf;*.wmf;*.jpg;*.jpeg;*.png;*.tif;*.ico|GIF文件(*.gif)|*.gif|BMP文件(*.bmp)|*.bmp|EMF文件(*.emf)|*.emf|WMF文件(*.wmf)|*.wmf|JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|PNG文件(*.png)|*.png|TIFF文件(*.tif)|*.tif|ICO文件(*.ico)|*.ico|">
    参数 所欲设置的位图文件名 <类型 = 文本型 注释 = "提供所欲设置的位图文件名,如果为空文本,将取消图片." 编辑时信息 = "FD545, 0, 0, 0">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ pWnd->m_memPicData.Free ();
        @ pWnd->m_memPicData.ReadFromFile (@<所欲设置的位图文件名>.GetText ());
        @ if (pWnd->m_hWnd != NULL)  { pWnd->CreateBackBitmap (); pWnd->Invalidate (FALSE); }
    }

    方法 显示方式 <公开 属性读 类型 = 整数 注释 = "如果设定了背景图片,本属性指定其起始显示方式." @嵌入式方法 = "">
    {
        @ ((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_nPicShowMode
    }

    方法 显示方式 <公开 属性写 注释 = "如果设定了背景图片,本属性指定其起始显示方式." @视窗.设置时机 = 组件创建前后 @列表选择项 = "图片居左上\n缩放图片\n图片居中\n图片平铺">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ pWnd->m_nPicShowMode = CLIP (@<欲设置属性值>, 0, 3);
        @ if (pWnd->m_hWnd != NULL)  { pWnd->CreateBackBitmap (); pWnd->Invalidate (FALSE); }
    }

    方法 画笔类型 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ ((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_nPenStyle
    }

    方法 画笔类型 <公开 属性写 @视窗.设置时机 = 组件创建前后 @列表选择项 = "空笔\n直线\n划线\n点线\n点划线\n双点划线\n内直线">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ const INT nPenStyle = CLIP (@<欲设置属性值>, 0, 6);
        @ if (nPenStyle != pWnd->m_nPenStyle)
        @ {
        @      pWnd->m_nPenStyle = nPenStyle;
        @      if (pWnd->m_hWnd != NULL)  pWnd->ReCreatePen ();
        @ }
    }

    方法 画出方式 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ ((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_nDrawRop2
    }

    方法 画出方式 <公开 属性写 注释 = "有关各种画出方式的说明为:" 注释 = "  0. 黑色: 始终画出黑色; 1. 非或笔: 或笔的相反; 2. 与非笔: 背景色以及画笔反相二者共有颜色的组合;"
            注释 = "  3. 非复制笔: 复制笔的相反; 4. 与笔非: 画笔以及已有颜色反相二者共有颜色的组合;" 注释 = "  5. 反转: 已有颜色的反相; 6. 异或笔: 画笔的颜色以及已有颜色的组合，只取其一;"
            注释 = "  7. 非与笔: 与笔的相反; 8. 与笔: 画笔和已有二者共有颜色的组合; 9. 非异或笔: 异或笔的相反;"
            注释 = "  10. 无操作: 原有保持不变。该设置实际上关闭画笔; 11. 或非笔: 已有颜色与画笔颜色反相的组合;" 注释 = "  12. 复制笔（缺省值）: 画笔颜色; 13. 或笔非: 画笔颜色与已有颜色的反相的组合;"
            注释 = "  14. 或笔: 画笔颜色与已有颜色的组合; 15. 白色: 始终画出白色" 编辑时信息 = "127FED, 0, 0, 0" @视窗.设置时机 = 组件创建前后
            @列表选择项 = "黑色\n非或笔\n与非笔\n非复制笔\n与笔非\n反转\n异或笔\n非与笔\n与笔\n非异或笔\n无操作\n或非笔\n复制笔\n或笔非\n或笔\n白色">
    参数 欲设置属性值 <类型 = 整数 编辑时信息 = "127FED, 0, 0, 0">
    {
        @ ((CVWnd_CartoonBox*)GetMfcWndPtr ())->m_nDrawRop2 = CLIP (@<欲设置属性值>, 0, 15);
    }

    方法 画笔粗细 <公开 属性读 类型 = 整数 注释 = "单位为像素,如果为0,表示画笔的粗细为一个像素点." 注释 = "注意: 当画笔类型为划线、点线、点划线、双点划线时,本属性无效,画笔宽度始终为一个像素点." @嵌入式方法 = "">
    {
        @ ((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_nPenWidth
    }

    方法 画笔粗细 <公开 属性写 注释 = "单位为像素,如果为0,表示画笔的粗细为一个像素点." 注释 = "注意: 当画笔类型为划线、点线、点划线、双点划线时，本属性无效,画笔宽度始终为一个像素点." @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 整数>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ const INT nPenWidth = CLIP (@<欲设置属性值>, 0, 0x7fff);
        @ if (nPenWidth != pWnd->m_nPenWidth)
        @ {
        @      pWnd->m_nPenWidth = nPenWidth;
        @      if (pWnd->m_hWnd != NULL)  pWnd->ReCreatePen ();
        @ }
    }

    方法 画笔颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_clrPen
    }

    方法 画笔颜色 <公开 属性写 @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 欲设置属性值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ if (@<欲设置属性值> != (INT)pWnd->m_clrPen)
        @ {
        @      pWnd->m_clrPen = (COLORREF)@<欲设置属性值>;
        @      if (pWnd->m_hWnd != NULL)  pWnd->ReCreatePen ();
        @ }
    }

    方法 刷子类型 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ ((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_nBrushStyle
    }

    方法 刷子类型 <公开 属性写 注释 = "各种格式刷子将使用当前文本背景颜色作为刷子背景颜色" 编辑时信息 = "FBFF0, 0, 0, 0" @视窗.设置时机 = 组件创建前后
            @列表选择项 = "空刷子\n颜色刷子\n右斜线\n直交叉线\n斜交叉线\n左斜线\n横线\n竖线\n5%色点\n10%色点\n20%色点\n25%色点\n30%色点\n40%色点\n50%色点\n60%色点\n70%色点\n75%色点\n80%色点\n90%色点\n浅色上对角线\n浅色下对角线\n深色上对角线\n深色下对角线\n宽上对角线\n宽下对角线\n浅色竖线\n浅色横线\n窄竖线\n窄横线\n深色竖线\n深色横线\n上对角虚线\n下对角虚线\n横虚线\n竖虚线\n小纸屑\n大纸屑\n之字形\n波浪线\n对角砖形\n横向砖形\n纺织物\n方格呢\n草皮\n虚格线\n点式菱形\n瓦形\n棚架\n球体\n小网格\n大网格\n小棋盘\n大棋盘\n空心菱形\n实心菱形">
    参数 欲设置属性值 <类型 = 整数 编辑时信息 = "FBFF0, 0, 0, 0">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ const INT nBrushStyle = CLIP (@<欲设置属性值>, 0, 55);
        @ if (nBrushStyle != pWnd->m_nBrushStyle)
        @ {
        @      pWnd->m_nBrushStyle = nBrushStyle;
        @      if (pWnd->m_hWnd != NULL)  pWnd->ReCreateBrush ();
        @ }
    }

    方法 刷子颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CartoonBox*)@sn<this>.GetMfcWndPtr  ())->m_clrBrush
    }

    方法 刷子颜色 <公开 属性写 @视窗.设置时机 = 组件创建前后 @值细节类型 = 颜色>
    参数 欲设置属性值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtr ();
        @ if (@<欲设置属性值> != (INT)pWnd->m_clrBrush)
        @ {
        @      pWnd->m_clrBrush = (COLORREF)@<欲设置属性值>;
        @      if (pWnd->m_hWnd != NULL)  pWnd->ReCreateBrush ();
        @ }
    }

    方法 文本颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
