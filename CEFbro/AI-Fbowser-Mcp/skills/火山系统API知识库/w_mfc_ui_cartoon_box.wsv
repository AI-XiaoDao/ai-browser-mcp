    方法 取附加文本 <公开 类型 = 文本型 注释 = "返回与指定物体相关的附加文本数据" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return CVolString (pWnd == NULL ? _T ("") : pWnd->GetObjectExtraText (@<物体标识值>));
    }

    方法 置物体位置 <公开 注释 = "设置动画框中指定物体的当前位置">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 横坐标 <类型 = 整数 注释 = "本参数指定物体左边的新横坐标位置">
    参数 纵坐标 <类型 = 整数 注释 = "本参数指定物体顶边的新纵坐标位置">
    参数 是否进行碰撞检测 <类型 = 逻辑型 注释 = "  默认情况下,当物体不是进行前进动作时,动画框将不进行碰撞检测,此检测包括越出边界、" 注释 = "边界碰撞、物体碰撞,设置本参数为真可以强制在位置改变后进行此检测并发送相应事件."
            @默认值 = 假>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<是否进行碰撞检测> == FALSE)
        @         pWnd->SetObjectPosition (@<物体标识值>, @<横坐标>, @<纵坐标>);
        @     else
        @         pWnd->ForwardCheckSetPostion (@<物体标识值>, @<横坐标>, @<纵坐标>);
        @ }
    }

    方法 取物体左边 <公开 类型 = 整数 注释 = "返回指定物体左边在动画框中的当前位置" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectLeft (@<物体标识值>));
    }

    方法 取物体顶边 <公开 类型 = 整数 注释 = "返回指定物体顶边在动画框中的当前位置" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectTop (@<物体标识值>));
    }

    方法 取物体宽度 <公开 类型 = 整数 注释 = "返回指定物体的当前宽度" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectWidth (@<物体标识值>));
    }

    方法 取物体高度 <公开 类型 = 整数 注释 = "返回指定物体的当前高度" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectHeight (@<物体标识值>));
    }

    方法 置碰撞管理 <公开 注释 = "设置指定物体的前进碰撞管理机制">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 是否允许碰撞 <类型 = 逻辑型 注释 = "指定当物体向前移动后与同层另外一个不同类型值物体相互交叠时是否启动碰撞处理机制,注意:"
            注释 = "  1. 物体是否被显示并不影响到碰撞处理,也就是说如果允许碰撞,即使物体被隐藏也会启动碰撞处理;" 注释 = "  2. 被碰撞到的物体必须也同时允许碰撞才会触发碰撞机制;"
            注释 = "  3. 只有当物体进行前进动作时(\"前进\"或\"自动前进\"命令引发)才会进行碰撞检测,其它情况下不会去检测碰撞.">
    参数 碰撞声音 <类型 = 字节集类 注释 = "如果允许碰撞,指定当物体向前移动碰撞到其它物体时播放的声音." 注释 = "如果参数值为空对象,则不改变原设置声音." @默认值 = 空对象>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectCollideMode (@<物体标识值>, @<是否允许碰撞>, @<碰撞声音>);
    }

    方法 置销毁声音 <公开 注释 = "设置当指定物体被销毁前所发出的声音">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 销毁声音 <类型 = 字节集类 注释 = "如果参数值为空对象或空字节集,则表示清除原有销毁声音." @默认值 = 空对象>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetDestroySound (@<物体标识值>, @<销毁声音>.GetPtr (), (INT)@<销毁声音>.GetSize ());
    }

    方法 置角度 <公开 注释 = "设置指定物体向前移动时的角度">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 角度 <类型 = 整数 注释 = "本参数指定物体向前移动时的角度,单位为度,值在-360到360之间.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectAngle (@<物体标识值>, @<角度>);
    }

    方法 取角度 <公开 类型 = 整数 注释 = "返回指定物体向前移动时的角度" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectAngle (@<物体标识值>));
    }

    方法 转向 <公开 注释 = "相对改变动画框中指定物体向前移动时的角度">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 转向角度 <类型 = 整数 注释 = "本参数指定物体向前移动方向顺时针转向的相对角度,为负数则表示为逆时针转向.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectAngle (@<物体标识值>, pWnd->GetObjectAngle (@<物体标识值>) + @<转向角度>);
    }

    方法 置旋转跟随 <公开 注释 = "设置当物体向前移动角度被调整时,是否自动将物体本身图片同时旋转到该角度.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 是否旋转跟随 <类型 = 逻辑型 注释 = "本参数指定当物体向前移动角度被调整时,是否自动将物体本身图片同时旋转到该角度.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectRotateFollow (@<物体标识值>, @<是否旋转跟随>);
    }

    方法 取旋转跟随 <公开 类型 = 逻辑型 注释 = "返回指定物体的当前旋转跟随状态" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->GetObjectRotateFollow (@<物体标识值>));
    }

    方法 前进 <公开 注释 = "向前移动动画框中的指定物体">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 移动距离 <类型 = 整数 注释 = "本参数指定物体向前移动的距离,为负数则表示向后移动,移动方向为该物体的当前角度.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->forward (@<物体标识值>, @<移动距离>);
    }

    方法 缩放 <公开 注释 = "缩放动画框中指定物体">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 横向缩放比例 <类型 = 整数 注释 = "本参数指定对物体横向进行缩放的千分比">
    参数 纵向缩放比例 <类型 = 整数 注释 = "本参数指定对物体纵向进行缩放的千分比,如果为0,表示等同于横向缩放比." @默认值 = 0>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->zoom (@<物体标识值>, @<横向缩放比例>, (@<纵向缩放比例> <= 0 ? @<横向缩放比例> : @<纵向缩放比例>));
    }

    方法 取横向缩放比 <公开 类型 = 整数 注释 = "返回动画框中指定物体当前的横向缩放千分比" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 1000 : pWnd->GetXZoom (@<物体标识值>));
    }

    方法 取纵向缩放比 <公开 类型 = 整数 注释 = "返回动画框中指定物体当前的纵向缩放千分比" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 1000 : pWnd->GetYZoom (@<物体标识值>));
    }

    方法 自动前进 <公开 注释 = "以当前角度或指定路线自动向前移动动画框中指定物体">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 每次前进距离 <类型 = 整数 注释 = "本参数指定每次将物体向前移动的距离,单位为像素点. 参数值必须大于0.">
    参数 每次前进间隔时间 <类型 = 整数 注释 = "本参数指定物体每前进一次后等待的间隔时间,单位为毫秒.">
    参数 最大前进距离 <类型 = 整数 注释 = "本参数指定物体自动向前移动的最大距离,单位为像素点. 如果值为0,表示不限制距离." 注释 = "如果设置了路线,则将在本参数设置值和路线的总长度之间取最小值作为最大移动距离." @默认值 = 0>
    参数 最大前进时间 <类型 = 整数 注释 = "本参数指定物体自动向前移动的最大时间,单位为毫秒. 如果值为0,表示不限制时间." @默认值 = 0>
    参数 碰撞停止 <类型 = 逻辑型 注释 = "指定当物体碰撞到其它物体时是否停止向前移动" @默认值 = 假>
    参数 边界停止 <类型 = 整数 注释 = "  指定当物体到达或越过动画框边界时是否停止向前移动." 注释 = "  参数值为1表示当物体碰撞到边界时停止移动,为2表示当物体完全越过边界后停止移动."
            注释 = "  注意无论本参数如何设置,一旦物体在没有限制最大前进距离和最大前进时间且没有设" 注释 = "置路线的情况下越过动画框边框外,将自动停止移动." @默认值 = 0>
    参数 自动销毁 <类型 = 逻辑型 注释 = "本参数指定物体自动向前移动停止后,是否自动销毁." @默认值 = 假>
    参数 路线 <类型 = 整数数组类 注释 = "本参数描述物体具体的自动向前移动路线,路线可以是直线或曲线或两者的组合体." 注释 = "如果设置了路线,物体的当前角度将在前进过程中被自动调整."
            注释 = "参数数组中的数据描述整个前进路线,其每一部分的数据格式如下:" 注释 = "  1. 第1个整数描述此部分路线的类型,0表示为直线,1表示为曲线(二次方贝塞尔曲线);"
            注释 = "  2. 如果类型为直线,则后续2个整数记录该直线终点坐标位置(相对于路线起点);" 注释 = "  3. 如果类型为曲线,则后续4个整数分别记录该曲线的控制点和终点坐标位置(相对于路线起点)."
            注释 = "如果本参数为空对象或空数组,此时将按当前角度直线向前移动." @默认值 = 空对象>
    参数 路线重复次数 <类型 = 整数 注释 = "如果上一参数指定了路线,则本参数指定将此路线重复执行的次数,0表示无限次重复执行." @默认值 = 1>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->AutoForward (@<物体标识值>, @<每次前进距离>, @<每次前进间隔时间>, @<最大前进距离>, @<最大前进时间>,
        @         @<碰撞停止>, @<边界停止>, @<自动销毁>, @<路线>.data ().GetData (), (INT)@<路线>.data ().GetCount (), @<路线重复次数>);
        @ }
    }

    方法 停止自动前进 <公开 注释 = "停止动画框中指定物体的自动向前移动">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->StopAutoForward (@<物体标识值>);
    }

    方法 自动旋转 <公开 注释 = "自动旋转动画框中指定物体." 注释 = "注意: 该物体的旋转跟随状态会被自动设置为真">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 每次旋转距离 <类型 = 整数 注释 = "本参数指定每次将物体旋转的角度数,单位为度,为负值表示逆时针旋转,绝对值越大物体将被旋转得越快.">
    参数 每次旋转间隔时间 <类型 = 整数 注释 = "本参数指定每将物体旋转一次等待的间隔时间,单位为毫秒.">
    参数 总旋转距离 <类型 = 整数 注释 = "本参数指定欲将物体旋转的总角度数,单位为度. 如果参数值为0,表示为无限距离旋转." @默认值 = 0>
    参数 总旋转时间 <类型 = 整数 注释 = "本参数指定欲将物体旋转的最大时间,单位为毫秒. 如果参数值为0,表示为无限时旋转." @默认值 = 0>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->BeginAutoRotate (@<物体标识值>, @<每次旋转距离>, @<每次旋转间隔时间>, @<总旋转距离>, @<总旋转时间>);
    }

    方法 停止自动旋转 <公开 注释 = "停止动画框中指定物体的自动旋转">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->StopAutoRotate (@<物体标识值>);
    }

    方法 自动方向键移动 <公开 注释 = "设置指定物体将获得方向键控制移动的自动支持,同一时间只有一个物体能够获得此支持."
            注释 = "注意: 1.方向键控制下的移动动作属于前进动作,将进行碰撞检测; 2.任何情况下,物体将不会被移出动画框边界外.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 一次移动距离 <类型 = 整数 注释 = "本参数指定当方向键被按下一次后物体移动的距离,单位为像素点." @默认值 = 10>
    参数 每次移动间隔时间 <类型 = 整数 注释 = "本参数指定每将物体移动一次等待的间隔时间,单位为毫秒." @默认值 = 10>
    参数 避免碰撞 <类型 = 逻辑型 注释 = "本参数指定是否避免被控制物体与其它允许碰撞状态为真的同层不同类型值物体之间产生碰撞事件" @默认值 = 假>
    参数 移动时外形变换 <类型 = 整数 注释 = "本参数可以为以下值之一:" 注释 = "  0. 不作任何变换;" 注释 = "  1. 如果物体的当前图片为动画图片,则每移动一下将其播放1次;"
            注释 = "  2. 如果物体的当前图片为动画图片,则每移动一下播放其下1帧,如果已经在动画最后一帧上,将自动回到首帧." @默认值 = 0>
    参数 上移键 <类型 = 整数 注释 = "本参数提供上移键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持上移." @默认值 = 按键码.空>
    参数 下移键 <类型 = 整数 注释 = "本参数提供下移键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持下移." @默认值 = 按键码.空>
    参数 左移键 <类型 = 整数 注释 = "本参数提供左移键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持左移." @默认值 = 按键码.空>
    参数 右移键 <类型 = 整数 注释 = "本参数提供右移键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持右移." @默认值 = 按键码.空>
    参数 左转键 <类型 = 整数 注释 = "本参数提供向左转向键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持向左转向." 注释 = "注意: 如果本参数设置了有效键值,那么物体的旋转跟随状态将被自动设置为真."
            @默认值 = 按键码.空>
    参数 右转键 <类型 = 整数 注释 = "本参数提供向右转向键的键代码(参见\"按键码\"类),如果为\"按键码.空\",则不支持向右转向." 注释 = "注意: 如果本参数设置了有效键值,那么物体的旋转跟随状态将被自动设置为真."
            @默认值 = 按键码.空>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetAutoKeyMove (@<物体标识值>, @<一次移动距离>, @<每次移动间隔时间>, @<避免碰撞>, @<移动时外形变换>, @<上移键>, @<下移键>, @<左移键>, @<右移键>, @<左转键>, @<右转键>);
    }

    方法 播放动画 <公开 注释 = "如果指定物体内的图片为GIF格式,则开始或停止播放其GIF动画.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 播放次数 <类型 = 整数 注释 = "本参数指定欲播放动画的次数: -1: 暂停播放; 0: 无限次播放; >0: 播放指定次数">
    参数 自动销毁 <类型 = 逻辑型 注释 = "本参数当指定次数播放完毕后,是否自动销毁." @默认值 = 假>
    参数 每帧附加间隔时间 <类型 = 整数 注释 = "本参数指定播放动画每帧时除了每帧本身设置的间隔时间外的附加间隔时间,单位为毫秒." 注释 = "如果本参数值为0,表示无附加间隔时间." @默认值 = 0>
    参数 每次播放间隔时间 <类型 = 整数 注释 = "当播放次数参数不为-1时,本参数指定动画每次播放之间的间隔时间,单位为毫秒." 注释 = "如果本参数值为0,表示无间隔时间." @默认值 = 0>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->PlayGif (@<物体标识值>, @<播放次数>, @<自动销毁>, @<每帧附加间隔时间>, @<每次播放间隔时间>);
    }

    方法 定位物体 <公开 类型 = 整数 注释 = "  返回包含指定动画框位置的最顶层物体的标识值," 注释 = "如果没有任何一个物体包含指定位置,返回-1." @禁止流程检查 = 真>
    参数 横坐标 <类型 = 整数 注释 = "本参数指定欲检测动画框位置的横坐标值">
    参数 纵坐标 <类型 = 整数 注释 = "本参数指定欲检测动画框位置的纵坐标值">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->FindSpecPosObject (@<横坐标>, @<纵坐标>));
    }

    方法 是否重叠 <公开 类型 = 逻辑型 注释 = "如果指定两个物体非透明部分之间存在重叠,返回真,否则返回假." @禁止流程检查 = 真>
    参数 物体一标识值 <类型 = 整数 注释 = "本参数提供欲检测物体一的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 物体二标识值 <类型 = 整数 注释 = "  本参数提供欲检测是否与物体一重叠的物体二的标识值,该标识值为创建或复" 注释 = "制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->IsOverlapped (@<物体一标识值>, @<物体二标识值>));
    }

    方法 寻找重叠物体 <公开 类型 = 整数 注释 = "如果有满足条件的物体与指定物体的非透明部分之间存在重叠,返回该物体的标识值,否则返回-1." @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 假想横坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的横坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前横坐标位置."
            @默认值 = 数值范围.最大整数值>
    参数 假想纵坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的纵坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前纵坐标位置."
            @默认值 = 数值范围.最大整数值>
    参数 所需附加文本 <类型 = 文本型 注释 = "  指定满足条件的物体所必须具有的附加文本,如果附加文本不等同于本参数值,即使另一物体与本物体存" 注释 = "在事实重叠,也会认为不重叠. 如果本参数值为空对象,表示不要求进行附加文本匹配."
            @默认值 = 空对象>
    参数 仅检查可能碰撞物体 <类型 = 逻辑型 注释 = "本参数指定是否仅仅检查允许碰撞状态为真且类型值不一样的同层次物体" @默认值 = 假>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->FindOverlappedObject (@<物体标识值>, @<假想横坐标位置>, @<假想纵坐标位置>, (@<所需附加文本>.IsNullObject () ? NULL : @<所需附加文本>.GetText ()), @<仅检查可能碰撞物体>));
    }

    方法 边界检查 <公开 类型 = 整数 注释 = "  如果指定物体所有非透明部分都完全位于动画框边框外,返回-1;"
            注释 = "  如果指定物体非透明部分碰撞到动画框的边框,返回碰撞到边界的类型: 1:左边界; 2:上边界; 4:右边界; 8:下边界." 注释 = "注意有可能同时碰撞到几个边界,所以应该通过检测相应位来查看具体碰撞到了哪些边界;"
            注释 = "  如果物体既没有越出也没有碰撞到边界,返回0." @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 假想横坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的横坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前横坐标位置."
            @默认值 = 数值范围.最大整数值>
    参数 假想纵坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的纵坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前纵坐标位置."
            @默认值 = 数值范围.最大整数值>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->IsCollideBorder (@<物体标识值>, @<假想横坐标位置>, @<假想纵坐标位置>));
    }

    方法 是否在区域内 <公开 类型 = 逻辑型 注释 = "如果指定物体有非透明部分在指定矩形区域内,返回真,否则返回假." @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 假想横坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的横坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前横坐标位置."
            @默认值 = 数值范围.最大整数值>
    参数 假想纵坐标位置 <类型 = 整数 注释 = "物体将被假想已经移动到本参数所指定的纵坐标位置,将依据此位置进行检查而忽略物体的当前实际位置." 注释 = "如果参数值为\"数值范围.最大整数值\",表示等同于物体的当前纵坐标位置."
            @默认值 = 数值范围.最大整数值>
    参数 矩形左边 <类型 = 整数 注释 = "本参数指定矩形区域左边的横坐标位置">
    参数 矩形顶边 <类型 = 整数 注释 = "本参数指定矩形区域顶边的纵坐标位置">
    参数 矩形宽度 <类型 = 整数 注释 = "本参数指定矩形区域的宽度" @默认值 = 1>
    参数 矩形高度 <类型 = 整数 注释 = "本参数指定矩形区域的高度" @默认值 = 1>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->IsInsideRect (@<物体标识值>, @<假想横坐标位置>, @<假想纵坐标位置>, @<矩形左边>, @<矩形顶边>, @<矩形宽度>, @<矩形高度>));
    }

    方法 取区域图片 <公开 类型 = 字节集类 注释 = "返回动画框中指定区域的图片内容,如果指定区域为空,将返回空字节集." @禁止流程检查 = 真>
    参数 左边 <类型 = 整数 注释 = "本参数指定矩形区域左边的横坐标位置">
    参数 顶边 <类型 = 整数 注释 = "本参数指定矩形区域顶边的纵坐标位置">
    参数 宽度 <类型 = 整数 注释 = "本参数指定矩形区域的宽度">
    参数 高度 <类型 = 整数 注释 = "本参数指定矩形区域的高度">
    参数 背景替代色 <类型 = 整数 注释 = "本参数指定如何将动画框背景加入到输出图像中去. 参数值可以使用\"颜色类\"中的常量值."
            注释 = "如果参数值为\"颜色类.默认色\",则背景部分被原样加入到输出图像中,否则背景部分将被指定颜色所替换." @默认值 = 颜色类.默认色>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ @an<CVolMem> memPic;
        @ if (pWnd != NULL)  pWnd->GetRegionBitmap (@<左边>, @<顶边>, @<宽度>, @<高度>, @<背景替代色>, memPic);
        @ return memPic;
    }

    方法 合并物体 <公开 注释 = "将一个物体的外形合并到另一个物体里面去,如果欲合并物体为动画外形,将仅使用其第一帧.">
    参数 被合并到物体标识值 <类型 = 整数>
    参数 合并物体标识值 <类型 = 整数 注释 = "本参数提供合并物体的标识值,此物体的当前外形(包括角度、缩放比等等)将被合并到前一参数所指定的被合并物体中去.">
    参数 横向偏移位置 <类型 = 整数 注释 = "本参数指定合并物体欲合并到被合并物体中的横向偏移位置,此位置相对于被合并物体的左边."
            注释 = "如果参数值为负值,此时被合并物体的左边将被自动扩展,如果参数值超出被合并物体的宽度,被合并物体的右边将被自动扩展.">
    参数 纵向偏移位置 <类型 = 整数 注释 = "本参数指定合并物体欲合并到被合并物体中的纵向偏移位置,此位置相对于被合并物体的顶边."
            注释 = "如果参数值为负值,此时被合并物体的顶边将被自动扩展,如果参数值超出被合并物体的高度,被合并物体的底边将被自动扩展.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->CmbObject (@<被合并到物体标识值>, @<合并物体标识值>, @<横向偏移位置>, @<纵向偏移位置>);
    }

    方法 复制物体 <公开 类型 = 整数 注释 = "创建指定物体的完全复制品,成功返回该复制物体的标识值,失败返回-1." @禁止流程检查 = 真>
    参数 被复制物体标识值 <类型 = 整数 注释 = "本参数提供欲复制物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 横坐标 <类型 = 整数 注释 = "本参数提供所复制出来物体的左边横坐标位置,如果为\"数值范围.最大整数值\",表示等同于被复制物体的当前左边横坐标位置." @默认值 = 数值范围.最大整数值>
    参数 纵坐标 <类型 = 整数 注释 = "本参数提供所复制出来物体的顶边纵坐标位置,如果为\"数值范围.最大整数值\",表示等同于被复制物体的当前顶边纵坐标位置." @默认值 = 数值范围.最大整数值>
    参数 是否显示 <类型 = 整数 注释 = "本参数指定是否立即显示所复制出来的物体,大于0显示,等于0不显示,小于0表示等同于被复制物体的当前显示状态." @默认值 = -1>
    参数 附加数据 <类型 = 文本型 注释 = "本参数提供随同复制出来物体的附加文本数据,如果为空对象,表示等同于被复制物体的当前附加数据." @默认值 = 空对象>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->CartoonCloneObject (@<被复制物体标识值>, @<横坐标>, @<纵坐标>, @<是否显示>, @<附加数据>));
    }

    方法 置生存时间 <公开 注释 = "指定物体的生存时间,时间到达后该物体将被自动销毁.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 生存时间 <类型 = 整数 注释 = "指定物体从现在开始的生存时间,单位为毫秒,0表示无限制." @默认值 = 0>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetExistTime (@<物体标识值>, @<生存时间>);
    }

    方法 寻找物体 <公开 类型 = 整数 注释 = "寻找具有指定附加文本数据的第一个物体,找到后返回该物体的标识值,未找到返回-1." @禁止流程检查 = 真>
    参数 欲寻找的附加文本数据 <类型 = 文本型>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->FindObjectWithSpecExtraText (@<欲寻找的附加文本数据>.GetText ()));
    }

    方法 置类型 <公开 注释 = "  设置动画框中指定物体的类型值,该值可以是任意整数," 注释 = "物体之间的碰撞仅在具有不同类型值的同层物体之间产生.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 类型值 <类型 = 整数 注释 = "本参数指定欲设置物体的类型值">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->SetObjectType (@<物体标识值>, @<类型值>);
    }

    方法 取类型 <公开 类型 = 整数 注释 = "返回指定物体的当前类型值" @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectType (@<物体标识值>));
    }

    方法 添加监视键 <公开 注释 = "  添加需要被监视的按键,添加后这些键如果被按下,将一直发送监视键被按下事件." 注释 = "  监视键被按下事件与普通的按下某键事件相比有以下不同: 假设你在按下A键后再同时按下B键."
            注释 = "然后放开B键但仍然保持A键的按下状态,那么普通的按下某键事件将不会再发送A键被按下事件," 注释 = "但如果此时A键已被设置为监视键,那么将继续定时重复发送A监视键被按下事件.">
    参数 检测间隔时间 <类型 = 整数 注释 = "  本参数提供检测后面参数中所列出的所有监视按键时的间隔延迟时间,单位为毫秒,时间越长," 注释 = "所对应键的监视按键事件发送周期就越长." @默认值 = 10>
    参数 欲监视的按键 <类型 = 整数 注释 = "本参数提供欲监视按键的代码值. 参见\"按键码\"类.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->AddListenKey (@<欲监视的按键>, MAX (0, @<检测间隔时间>));
    }

    方法 清除监视键 <公开 注释 = "清除当前已经设置的所有监视按键">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->ClearListenKey ();
    }

    方法 显示下一帧 <公开 注释 = "  如果物体的当前图片为动画图片,那么不管其是否已经开始播放," 注释 = "都会把该物体当前图片帧切换到其下一帧,如果已经在动画最后一" 注释 = "帧上,将自动回到首帧.">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->ShowNextPic (@<物体标识值>);
    }

    方法 图像翻转 <公开 注释 = "翻转动画框中指定物体的图像">
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    参数 翻转类型 <类型 = 整数 注释 = "可以为以下值之一: 0:撤销翻转; 1:左右翻转; 2:上下翻转; 3:上下左右翻转." @默认值 = 0>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->TurnObject (@<物体标识值>, @<翻转类型>);
    }

    方法 取翻转状态 <公开 类型 = 整数 注释 = "返回动画框中指定物体的当前图像翻转状态: 0:未翻转; 1:左右翻转; 2:上下翻转; 3:上下左右翻转." @禁止流程检查 = 真>
    参数 物体标识值 <类型 = 整数 注释 = "本参数提供欲操作物体的标识值,该标识值为创建或复制物体时所返回的数值.">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? 0 : pWnd->GetObjectTurnType (@<物体标识值>));
    }

    方法 清除背景 <公开 注释 = "清除动画框背景上指定区域的内容并将当前文本写出位置移动到被清除区左上角">
    参数 清除区左上角横坐标 <类型 = 整数 @默认值 = 0>
    参数 清除区左上角纵坐标 <类型 = 整数 @默认值 = 0>
    参数 清除区宽度 <类型 = 整数 注释 = "如果为\"数值范围.最大整数值\",表示为清除区左边到动画框右边之间的宽度." @默认值 = 数值范围.最大整数值>
    参数 清除区高度 <类型 = 整数 注释 = "如果为\"数值范围.最大整数值\",表示为清除区顶边到动画框底边之间的高度." @默认值 = 数值范围.最大整数值>
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_ClearBack (@<清除区左上角横坐标>, @<清除区左上角纵坐标>, @<清除区宽度>, @<清除区高度>);
    }

    方法 画点 <公开 注释 = "在动画框背景上画一个点">
    参数 点横坐标 <类型 = 整数>
    参数 点纵坐标 <类型 = 整数>
    参数 欲画入点的颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"中定义的常量值">
    {
        @ CVWnd_CartoonBox* pWnd = (CVWnd_CartoonBox*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)  pWnd->D_DrawPoint (@<点横坐标>, @<点纵坐标>, (COLORREF)@<欲画入点的颜色值>);
    }

    方法 画直线 <公开 注释 = "在动画框背景上画一条直线">
