    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetCellBackColor (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>, GetRealBackColor (@<所欲设置的颜色>))
    }

