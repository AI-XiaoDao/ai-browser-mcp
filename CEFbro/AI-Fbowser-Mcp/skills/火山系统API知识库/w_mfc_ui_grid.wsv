    方法 置数据 <公开 类型 = 逻辑型 注释 = "设置指定单元格的值,返回是否成功." 编辑时信息 = "119543, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 行号 <类型 = 整数 注释 = "行号从0开始" 编辑时信息 = "119543, 0, 0, 0">
    参数 列号 <类型 = 整数 注释 = "列号从0开始" 编辑时信息 = "119543, 0, 0, 0">
    参数 欲置入类型 <类型 = 整数 注释 = "指定要置入数据的列类型,为以下常量值之一: 1:表格常量.文本值型; 5:表格常量.选择型; 6:表格常量.图片型." 编辑时信息 = "119543, 0, 0, 0">
    参数 欲置入数据 <注释 = "提供准备置入单元格的数据." 注释 = "如\"欲置入类型\"为文本值型,则必须为任意基本数据类型,类库将自动将其转换为文本内容;"
            注释 = "如\"欲置入类型\"为图片型,则必须为字节集类/图片文件名文本/位图资源;" 注释 = "如\"欲置入类型\"为选择型,则必须为逻辑型,为真表示选中,假表示不选中." 编辑时信息 = "119543, 0, 0, 0"
            @匹配类型 = 通用型>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetCellData (@<行号>, @<列号>, @<欲置入类型>, @pdt_ch<欲置入数据>, @<欲置入数据>)
    }

