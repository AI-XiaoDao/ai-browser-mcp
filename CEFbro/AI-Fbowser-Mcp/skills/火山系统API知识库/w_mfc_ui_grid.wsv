    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->CleanAllCellContent ()
    }

    方法 合并 <公开 注释 = "组合表格中指定范围内的单元格,使之以一个单元格的形式表现." @嵌入式方法 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供所指定区域起始行的行号,行号从0开始.">
    参数 起始列号 <类型 = 整数 注释 = "提供所指定区域起始列的列号,列号从0开始.">
    参数 结束行号 <类型 = 整数 注释 = "提供所指定区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供所指定区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->MergeGridCells (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>)
    }

    方法 分解 <公开 类型 = 逻辑型 注释 = "分解表格中指定的已经组合的单元格,行列参数指向被组合单元格内的任何一个单元格即可." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->BreakSelectionCell (@<行号>, @<列号>))
        @ {
        @     pWnd->Refresh ();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

