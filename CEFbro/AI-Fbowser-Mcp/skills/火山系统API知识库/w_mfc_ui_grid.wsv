    # 方法 --

    方法 置光标 <公开 注释 = "将光标移动到指定的单元格上,如果参数指定的行号或列号无效,则隐藏光标并把当前光标行号和列号置为-1." @嵌入式方法 = "">
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetCaretCellPos (@<行号>, @<列号>)
    }

    方法 选择区域 <公开 注释 = "选择指定区域的单元格" @嵌入式方法 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供选择区域起始行的行号,行号从0开始.">
    参数 起始列号 <类型 = 整数 注释 = "提供选择区域起始列的列号,列号从0开始.">
    参数 结束行号 <类型 = 整数 注释 = "提供选择区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供选择区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SelectCells (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>)
    }

    方法 全部选择 <公开 注释 = "选择所有单元格" @嵌入式方法 = "">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SelectAllCells ()
    }

