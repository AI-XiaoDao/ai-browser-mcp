    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->InsertComboList (@<列号>, @<列表项>.GetText ()));
    }

    方法 置打印表头 <公开 类型 = 逻辑型 注释 = "指定表格打印时的表头名称及字体" 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 表头名称 <类型 = 文本型 注释 = "提供表格打印时的表头名称">
    参数 字体名称 <类型 = 文本型 注释 = "提供表格打印时的表头字体名称">
    参数 字体尺寸 <类型 = 整数 注释 = "提供表格打印时的表头字体尺寸,字体尺寸为0-100之间的整数." @默认值 = 20>
    参数 是否为粗体 <类型 = 逻辑型 注释 = "提供表格打印时的表头是否使用粗体" @默认值 = 真>
    参数 对齐方式 <类型 = 整数 注释 = "表格打印时表头的对齐方式,可以为以下常量值之一:" 注释 = "  1:表格常量.左对齐; 2:表格常量.居中对齐; 3:表格常量.右对齐." @默认值 = 2>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? FALSE : pWnd->SetPrintHeadInfo (@<表头名称>.GetText (), @<字体名称>.GetText (), @<字体尺寸>, @<是否为粗体>, @<对齐方式>));
    }

    方法 加线条 <公开 注释 = "为指定的单元格添加线条">
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    参数 斜线种类 <类型 = 整数 注释 = "提供需要添加的斜线类型,可以为以下常量值之一:" 注释 = "  0:表格常量.无线条; 1:表格常量.单斜线; 2:表格常量.双斜线; 3:表格常量.交叉线." @默认值 = 1>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->IsValid (@<行号>, @<列号>))
        @ {
        @     pWnd->SetItemLineType (@<行号>, @<列号>, @<斜线种类>);
        @     pWnd->RedrawCell (@<行号>, @<列号>);
        @ }
    }

    方法 删线条 <公开 注释 = "去除指定单元格中的线条">
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
        加线条 (行号, 列号, 表格常量.无线条)
    }

    方法 置边距 <公开 类型 = 逻辑型 注释 = "设置指定单元格在显示其中数据时到其单元格边框之间的空白距离,单位为0.1毫米." 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
