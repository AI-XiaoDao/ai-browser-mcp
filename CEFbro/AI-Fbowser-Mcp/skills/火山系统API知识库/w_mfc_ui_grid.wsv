            注释 = "  5:表格常量.选择型; 6:表格常量.图片型; 7:表格常量.货币型; 8:表格常量.不可编辑列表型." @嵌入式方法 = "">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->GetGridColType (@<列号>)
    }

