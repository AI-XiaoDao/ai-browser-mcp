    }

    方法 置只读方式 <公开 类型 = 逻辑型 注释 = "设置指定单元格是否只读" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供所指定区域起始行的行号,行号从0开始.">
    参数 起始列号 <类型 = 整数 注释 = "提供所指定区域起始列的列号,列号从0开始.">
    参数 结束行号 <类型 = 整数 注释 = "提供所指定区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供所指定区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    参数 是否只读 <类型 = 逻辑型 @默认值 = 真>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridCellReadonly (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>, @<是否只读>)
    }

    方法 取只读方式 <公开 类型 = 逻辑型 注释 = "返回指定单元格是否只读" @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
