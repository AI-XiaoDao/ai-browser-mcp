    方法 打印 <公开 注释 = "打印当前表格内容">
    参数 左边距 <类型 = 整数 @默认值 = 0>
    参数 顶边距 <类型 = 整数 @默认值 = 0>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->SetPrintSpace (@<左边距>, @<顶边距>);
        @     pWnd->UpdateWindow ();
        @     pWnd->Print ();
        @     pWnd->UpdateWindow ();
        @ }
    }

    方法 打印预览 <公开 注释 = "打印预览当前表格内容">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->PrintPreview ();
    }

    方法 清空下拉列表 <公开 注释 = "删除所有的下拉列表项">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->RemoveAllList ();
    }

    方法 添加下拉列表内容 <公开 注释 = "应该在设置列类型为列表型之前首先调用本方法添加所有下拉列表项">
    参数 列表项内容 <类型 = 文本型 注释 = "提供表格中下拉列表框的单个列表项目内容">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->AddList ((TCHAR*)@<列表项内容>.GetText ());
    }

    方法 置列类型 <公开 类型 = 逻辑型 注释 = "设置单元列所包含数据的输入方式,返回是否成功." @嵌入式方法 = "">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    参数 所欲设置的列类型 <类型 = 整数 注释 = "单元格的数据输入类型,为以下常量值之一:" 注释 = "  1:表格常量.文本型; 2:表格常量.数值型; 3:表格常量.日期型; 4:表格常量.列表型;"
            注释 = "  5:表格常量.选择型; 6:表格常量.图片型; 7:表格常量.货币型; 8:表格常量.不可编辑列表型.">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridColType (@<列号>, @<所欲设置的列类型>)
    }

    方法 置行高 <公开 类型 = 逻辑型 注释 = "设置指定行的高度,返回是否成功." @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 所欲设置的高度 <类型 = 整数 注释 = "提供所欲设置的表格行高度">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->SetRowHeight (@<行号>, @<所欲设置的高度>, TRUE))
        @ {
        @     pWnd->Refresh ();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 置列宽 <公开 类型 = 逻辑型 注释 = "设置指定列的宽度,返回是否成功." @禁止流程检查 = 真>
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    参数 所欲设置的宽度 <类型 = 整数 注释 = "提供所欲设置的表格列宽度">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->SetColumnWidth (@<列号>, @<所欲设置的宽度>, TRUE))
        @ {
        @     pWnd->Refresh ();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 置日期格式 <公开 类型 = 逻辑型 注释 = "设置日期显示格式,返回是否成功." @嵌入式方法 = "">
    参数 列号 <类型 = 整数 注释 = "提供需要置日期格式的列号,从0开始.">
    参数 所欲设置的日期格式 <类型 = 整数 注释 = "提供所欲设置的日期格式类型,为以下常量值之一:" 注释 = "  1:表格常量.长日期格式; 2:表格常量.短日期格式1; 3:表格常量.短日期格式2; 4:表格常量.短日期格式3;"
            注释 = "  5:表格常量.美式格式1; 6:表格常量.美式格式2; 7:表格常量.美式格式3;  8:表格常量.美式格式4.">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridDateFormat (@<列号>, @<所欲设置的日期格式>)
    }

    方法 置货币前缀 <公开 类型 = 逻辑型 注释 = "设置货币型单元格的显示前缀,返回是否成功." @嵌入式方法 = "">
    参数 列号 <类型 = 整数 注释 = "提供需要置货币前缀的列的列号,从0开始.">
    参数 货币类型 <类型 = 整数 注释 = "货币型单元格的货币类型,为以下常量值之一:" 注释 = "  1:表格常量.人民币; 2:表格常量.美元; 3:表格常量.欧元; 4:表格常量.英镑; 5:表格常量.自定义货币.">
    参数 自定义前缀 <类型 = 文本型 注释 = "提供货币型单元格的自定义显示前缀,仅当\"货币类型\"参数值为\"表格常量.自定义货币\"时有效." @默认值 = "">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridMoneyLeader (@<列号>, @<货币类型>, @<自定义前缀>.GetText ())
    }

    方法 置图片显示方式 <公开 类型 = 逻辑型 注释 = "设置图片型单元格的显示方式,返回是否成功." @嵌入式方法 = "">
