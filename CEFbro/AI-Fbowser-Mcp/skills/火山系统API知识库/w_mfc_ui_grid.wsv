    参数 结束行号 <类型 = 整数 注释 = "提供所指定区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供所指定区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    参数 所欲设置的对齐方式 <类型 = 整数 注释 = "提供所欲设置的文本对齐方式,可以为以下常量值之一:" 注释 = "  1:表格常量.左对齐; 2:表格常量.居中对齐; 3:表格常量.右对齐.">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetCellTextAlignMode (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>, @<所欲设置的对齐方式>)
    }

    方法 取对齐方式 <公开 类型 = 整数 注释 = "返回表格中指定区域在显示文字时所使用的文本对齐方式,为以下值之一:" 注释 = "  1:表格常量.左对齐; 2:表格常量.居中对齐; 3:表格常量.右对齐;  -1:失败"
            @嵌入式方法 = "">
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
