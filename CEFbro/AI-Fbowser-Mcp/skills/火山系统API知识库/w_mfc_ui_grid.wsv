    参数 结束行号 <类型 = 整数 注释 = "提供所指定区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供所指定区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    参数 所欲设置的边距 <类型 = 整数 注释 = "提供所欲设置的边距尺寸,单位为0.1毫米." @默认值 = 9>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridCellMargin (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>, @<所欲设置的边距>)
    }

    方法 取边距 <公开 类型 = 整数 注释 = "返回指定单元格在显示其中数据时到其单元格边框之间的空白距离,单位为0.1毫米." @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
