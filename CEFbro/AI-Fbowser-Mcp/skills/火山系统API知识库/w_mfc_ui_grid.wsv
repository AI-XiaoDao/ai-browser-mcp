    }

    方法 置计算公式 <公开 类型 = 逻辑型 注释 = "  指定在表格中任意两个数字列之间进行简单的数学计算后自动将结" 注释 = "果赋予表格中的另一列." 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 列号1 <类型 = 整数 注释 = "指定参与自动计算的第1列的列号,从0开始,该列必须为数值或货币型.">
    参数 列号2 <类型 = 整数 注释 = "指定参与自动计算的第2列的列号,从0开始,该列必须为数值或货币型.">
    参数 计算操作符 <类型 = 整数 注释 = "指定自动计算的操作符,值为以下常量值之一:" 注释 = "  1:表格常量.加; 2:表格常量.减; 3:表格常量.乘; 4:表格常量.除.">
    参数 结果列号 <类型 = 整数 注释 = "指定自动计算结果存放到的列,从0开始,该列必须为数值或货币型.">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridColAutoCalc (@<列号1>, @<列号2>, @<计算操作符>, @<结果列号>)
    }

    方法 置单元格小数位数 <公开 类型 = 逻辑型 注释 = "指定单元格数字的小数位数,只对数值和货币型单元格有效." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 列号 <类型 = 整数 注释 = "指定需要置小数位数的列号,从0开始.">
    参数 小数位数 <类型 = 整数 注释 = "指定数值或货币类型数据的小数位数,为从0到9之间的整数.">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->SetBitCount (@<列号>, @<小数位数>))
        @ {
        @     pWnd->Refresh ();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 置自动换行 <公开 类型 = 逻辑型 注释 = "指定单元格内容是否自动换行" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供所指定区域起始行的行号,行号从0开始.">
    参数 起始列号 <类型 = 整数 注释 = "提供所指定区域起始列的列号,列号从0开始.">
    参数 结束行号 <类型 = 整数 注释 = "提供所指定区域结束行的行号,行号从0开始.如果为-1,表示等于起始行号." @默认值 = -1>
    参数 结束列号 <类型 = 整数 注释 = "提供所指定区域结束列的列号,列号从0开始.如果为-1,表示等于起始列号." @默认值 = -1>
    参数 是否自动换行 <类型 = 逻辑型 注释 = "指定单元格内容是否自动换行,为真则自动换行,为假则单行显示." @默认值 = 真>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridLineAutoWrap (@<起始行号>, @<起始列号>, @<结束行号>, @<结束列号>, @<是否自动换行>)
    }

    方法 取行高 <公开 类型 = 整数 注释 = "返回所指定行的高度,成功返回行高,失败返回-1." @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "行号从0开始">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->GetRowHeight (@<行号>));
    }

    方法 取列宽 <公开 类型 = 整数 注释 = "返回所指定列的宽度,成功返回列宽,失败返回-1." @禁止流程检查 = 真>
    参数 列号 <类型 = 整数 注释 = "列号从0开始">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd == NULL ? -1 : pWnd->GetColumnWidth (@<列号>));
    }

    方法 插入下拉列表项 <公开 类型 = 逻辑型 注释 = "插入指定列的下拉列表项,该列必须为列表型." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 列号 <类型 = 整数 注释 = "提供需要插入下拉列表项的列号,从0开始.">
