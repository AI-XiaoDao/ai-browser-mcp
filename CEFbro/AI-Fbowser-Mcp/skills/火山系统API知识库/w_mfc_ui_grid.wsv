    参数 行号 <类型 = 整数 注释 = "指定空行的插入行号位置,从0开始,如果为-1,表示插入到表格尾部." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->InsertGridRow (@<行号>, @<行标题>.GetText ())
    }

    方法 插入列 <公开 类型 = 逻辑型 注释 = "在指定的位置插入空列,返回是否成功." @嵌入式方法 = "">
