    }

    方法 取单元格行高 <公开 类型 = 整数 注释 = "取得指定单元格的高度.成功返回该单元格高度,失败返回-1." 注释 = "注意: 如果所指定单元格位置位于被合并的单元格中,将返回被合并单元格的高度." @嵌入式方法 = "">
    参数 行号 <类型 = 整数 注释 = "行号从0开始,如为-1,则为当前焦点所在单元格行号." @默认值 = -1>
    参数 列号 <类型 = 整数 注释 = "列号从0开始,如为-1,则为当前焦点所在单元格列号." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->GetGridCellHeight (@<行号>, @<列号>)
    }

    方法 取单元格列宽 <公开 类型 = 整数 注释 = "取得指定单元格的宽度.成功返回该单元格宽度,失败返回-1." 注释 = "注意: 如果所指定单元格位置位于被合并的单元格中,将返回被合并单元格的宽度." @嵌入式方法 = "">
    参数 行号 <类型 = 整数 注释 = "行号从0开始,如为-1,则为当前焦点所在单元格行号." @默认值 = -1>
    参数 列号 <类型 = 整数 注释 = "列号从0开始,如为-1,则为当前焦点所在单元格列号." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->GetGridCellWidth (@<行号>, @<列号>)
    }

    方法 置打印页边距 <公开 注释 = "设置打印页中的各种边距" @嵌入式方法 = "">
    参数 所欲设置的页边距 <类型 = 整数 注释 = "提供所欲设置页边距的类型,可以为以下常量值之一:" 注释 = "  1:表格常量.左边距; 2:表格常量.右边距; 3:表格常量.上边距; 4:表格常量.下边距;"
            注释 = "  5:表格常量.页眉; 6:表格常量.页脚; 7:表格常量.表头与表格间隔.">
    参数 页边距值 <类型 = 整数 注释 = "提供所欲设置的页边距值,单位为0.1毫米.">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridPrintMargin (@<所欲设置的页边距>, @<页边距值>)
    }

    方法 置累加公式 <公开 类型 = 逻辑型 注释 = "设置纵向单元格累加公式" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 列号 <类型 = 整数 注释 = "提供要设置累加公式的列号,从0开始.">
    参数 起始行号 <类型 = 整数 注释 = "提供进行累加的起始行号,从0开始.">
    参数 结束行号 <类型 = 整数 注释 = "提供进行累加的结束行号,从0开始.">
    参数 结果存放行号 <类型 = 整数 注释 = "提供累加结果存放到行的行号,从0开始,如果为-1,表示为\"结束行号\"的下一行." 注释 = "本行号不能位于\"起始行号\"和\"结束行号\"之间." @默认值 = -1>
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->SetGridAddRows (@<列号>, @<起始行号>, @<结束行号>, @<结果存放行号>)
    }

    方法 删除累加公式 <公开 类型 = 逻辑型 注释 = "删除指定列的单元格累加公式" 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 列号 <类型 = 整数 注释 = "提供要删除累加公式的列号,从0开始.">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->DeleteAddCol (@<列号>) : FALSE);
    }

    方法 刷新单元格 <公开 注释 = "重新绘制表格所有单元格,主要用于计算公式结果单元格的刷新.">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->RefreshResCell ();
    }

    方法 置编辑状态字体和颜色 <公开 类型 = 逻辑型 注释 = "  设置单元格编辑状态下使用的文本字体和颜色." 注释 = "  默认情况下,编辑状态下的文本字体和颜色与当前正在编辑的单元格的文本"
            注释 = "字体和颜色一致,用户可以在处理\"将被编辑\"事件时调用本方法进行修改." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所欲设置的字体 <类型 = 字体对象类 注释 = "提供编辑时所使用的字体,为空对象表示不进行修改." @默认值 = 空对象>
    参数 文本颜色 <类型 = 整数 注释 = "提供编辑时所使用的文本颜色,为\"颜色类.透明色\"表示不进行修改." @默认值 = 颜色类.透明色>
    参数 背景颜色 <类型 = 整数 注释 = "提供编辑时所使用的背景颜色,为\"颜色类.透明色\"表示不进行修改." @默认值 = 颜色类.透明色>
    {
        @ return ((CVWnd_Grid*)GetMfcWndPtr ())->SetGridEditFontAndColor ((HFONT)(@<所欲设置的字体>.IsNullObject () ? NULL : @<所欲设置的字体>.GetGDIHandle ()), @<文本颜色>, @<背景颜色>);
    }

    # --
    # @begin
    # <> <include>
    # virtual void OnCurrentCellPosChanged () override  { @<光标位置改变> (); }
    # virtual BOOL IsCellEditable () override  { return (@<可否被编辑> () == 0); }
    # virtual void OnBeforeEditCell () override  {  @<将被编辑> (); }
    # virtual void OnEndEditCell () override  {  @<结束编辑> (); }
    # virtual void OnColWidthChanged (INT col) override  { @<列宽被改变> (col); }
    # virtual void OnRowHeightChanged (INT row) override  { @<行高被改变> (row); }
    # virtual void OnCellClick (INT x, INT y) override  { @<被单击> (x, y); }
    # virtual void OnFixedCellClick (INT row, INT col) override  { @<表头被单击> (row, col); }
    # virtual void OnFixedCellDblClick (INT row, INT col) override  { @<表头被双击> (row, col); }
    # virtual void OnListItemChoose (INT row, INT col, const TCHAR* szListItem)  { @<列表项被选择> (row, col, CVolString (szListItem)); }
    # <> </include>
    # @end
}
