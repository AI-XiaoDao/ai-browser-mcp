类 表格 <公开 基础类 = 窗口组件 编辑时信息 = "255530, 0, 0, 0" @视窗.外部头文件 = "src\\mfc_ui_grid.h"
        @视窗.外部源文件 = "src\\grid\\ComboGridCtrl.cpp\r\nsrc\\grid\\GridCell.cpp\r\nsrc\\grid\\GridCellBase.cpp\r\nsrc\\grid\\GridCtrl.cpp\r\nsrc\\grid\\GridDropTarget.cpp\r\nsrc\\grid\\InPlaceButton.cpp\r\nsrc\\grid\\inplacedatepick.cpp\r\nsrc\\grid\\InPlaceEdit.cpp\r\nsrc\\grid\\inplacelist.cpp\r\nsrc\\grid\\TitleTip.cpp\r\nsrc\\mfc_ui_grid.cpp\r\nsrc\\mfc_ui_grid_preview.cpp"
        @视窗.后缀文本 = "public IGridEventListener" @视窗.外部资源文件 = "src\\res\\mfc_ui_grid.rc"
        @视窗.窗口组件 = "icon=\"@66\"\r\ndefault_size = \"160, 160\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_Grid, IGridEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 光标位置改变 <公开 定义事件 类型 = 整数 注释 = "当用户更改了当前被选择单元时会产生本事件">

    方法 将被编辑 <公开 定义事件 类型 = 整数 注释 = "当单元格将被编辑前产生本事件,调用\"取光标行号\"和\"取光标列号\"方法可获取将被编辑的单元格位置.">

    方法 结束编辑 <公开 定义事件 类型 = 整数 注释 = "当单元格编辑结束之后产生此事件">

    方法 行高被改变 <公开 定义事件 类型 = 整数 注释 = "当用户调整了表格行行高时即产生此事件">
    参数 行号 <类型 = 整数 注释 = "提供行高被改变的表格行号,行号从0开始.">

    方法 列宽被改变 <公开 定义事件 类型 = 整数 注释 = "当用户调整了表格列列宽时即产生此事件">
    参数 列号 <类型 = 整数 注释 = "提供列宽被改变的表格列号,列号从0开始.">

    方法 被单击 <公开 定义事件 类型 = 整数 注释 = "当用户单击表格时即产生此事件,关于表格的鼠标点击事件都应在此事件中处理.">
    参数 横向位置 <类型 = 整数 注释 = "提供单击位置在当前所处窗口组件中的横向位置">
    参数 纵向位置 <类型 = 整数 注释 = "提供单击位置在当前所处窗口组件中的纵向位置">

    方法 列表项被选择 <公开 定义事件 类型 = 整数 注释 = "当用户选择列表型单元格中的列表项时产生此事件">
    参数 行号 <类型 = 整数 注释 = "提供当前单元格所处表格行的行号,行号从0开始.">
    参数 列号 <类型 = 整数 注释 = "提供当前单元格所处表格列的列号,列号从0开始.">
    参数 被选择项目文本 <类型 = 文本型 注释 = "提供被选择项目的文本内容">

    方法 可否被编辑 <公开 定义事件 类型 = 整数 注释 = "  在某单元格\"将被编辑\"事件之前产生本事件,如果本事件返回1,表示不允许" 注释 = "该单元格进入编辑状态,这种情况下不会有后续的\"将被编辑\"事件.本事件并"
            注释 = "不能阻止\"不进入编辑状态而修改单元格内容\"的行为,如按下DEL或Ctrl+V键.">

    方法 表头被单击 <公开 定义事件 类型 = 整数 注释 = "当表头被单击后发送本事件">
    参数 行号 <类型 = 整数 注释 = "提供当前单元格所处表格行的行号,行号从0开始.">
    参数 列号 <类型 = 整数 注释 = "提供当前单元格所处表格列的列号,列号从0开始.">

    方法 表头被双击 <公开 定义事件 类型 = 整数 注释 = "当表头被双击后发送本事件">
    参数 行号 <类型 = 整数 注释 = "提供当前单元格所处表格行的行号,行号从0开始.">
    参数 列号 <类型 = 整数 注释 = "提供当前单元格所处表格列的列号,列号从0开始.">

    # 属性 --

    方法 表格线颜色 <公开 属性读 类型 = 整数 注释 = "返回当前表格线颜色" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetGridColor () : pWnd->m_clrLine);
    }

    方法 表格线颜色 <公开 属性写 注释 = "设置当前表格线颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetGridColor (pWnd->m_clrLine = @<所欲设置颜色值>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前文本背景颜色" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetTextBkColor () : pWnd->m_clrBk);
    }

    方法 背景颜色 <公开 属性写 注释 = "设置当前文本背景颜色" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "  可以使用\"颜色类\"所提供的颜色值,可以使用\"颜色类.默认色\"" 注释 = "来指定使用默认组件背景颜色.">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetTextBkColor (pWnd->m_clrBk = GetRealBackColor (@<所欲设置颜色值>));
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 文字颜色 <公开 属性读 类型 = 整数 注释 = "返回当前文本颜色" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetTextColor () : pWnd->m_clrText);
    }

    方法 文字颜色 <公开 属性写 注释 = "设置当前文本颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetTextColor (pWnd->m_clrText = @<所欲设置颜色值>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 点燃色 <公开 属性读 类型 = 整数 注释 = "返回当前焦点所在单元格文本颜色" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetLightColor () : pWnd->m_clrLight);
    }

    方法 点燃色 <公开 属性写 注释 = "设置当前焦点所在单元格文本颜色" @值细节类型 = 颜色 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetLightColor (pWnd->m_clrLight = @<所欲设置颜色值>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 显示表格线 <公开 属性读 类型 = 表格线显示类型 注释 = "返回当前表格线显示类型" @嵌入式方法 = "">
    {
        @ ((CVWnd_Grid*)@sn<this>.GetMfcWndPtr ())->m_nLineType
    }

    方法 显示表格线 <公开 属性写 注释 = "设置当前表格线显示类型" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的显示类型 <类型 = 表格线显示类型>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nLineType = CLIP (@<所欲设置的显示类型>, 0, 3);
        @ pWnd->SetGridLines (pWnd->m_nLineType);
    }

    方法 允许调整行高 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许用户调整表格行高" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetRowResize () : pWnd->m_blResizeHeight);
    }

    方法 允许调整行高 <公开 属性写 注释 = "设置是否允许用户调整表格行高" @视窗.设置时机 = 组件创建前后>
    参数 是否允许调整行高 <类型 = 逻辑型>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetRowResize (pWnd->m_blResizeHeight = @<是否允许调整行高>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 允许调整列宽 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许用户调整表格列宽" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (INT)(pWnd->m_hWnd != NULL ? pWnd->GetColumnResize () : pWnd->m_blResizeWidth);
    }

    方法 允许调整列宽 <公开 属性写 注释 = "设置是否允许用户调整表格列宽" @视窗.设置时机 = 组件创建前后>
    参数 是否允许调整列宽 <类型 = 逻辑型>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->SetColumnResize (pWnd->m_blResizeWidth = @<是否允许调整列宽>);
        @ SafeInvalidateWnd (pWnd, FALSE);
    }

    方法 行高 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的表格默认行高" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetDefCellHeight () : pWnd->m_nRowHeight);
    }

    方法 行高 <公开 属性写 注释 = "设置表格默认行高,并且同时设置当前所有表格行的高度." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的行高 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nRowHeight = MAX (0, @<所欲设置的行高>);
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetDefCellHeight (pWnd->m_nRowHeight);
        @     const INT nNumRows = pWnd->GetRowCount ();
        @     for (INT nRowIndex = 0; nRowIndex < nNumRows; nRowIndex++)
        @         pWnd->SetRowHeight (nRowIndex, pWnd->m_nRowHeight);
        @     pWnd->Refresh ();
        @ }
    }

    方法 列宽 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的表格默认列宽" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetDefCellWidth () : pWnd->m_nColWidth);
    }

    方法 列宽 <公开 属性写 注释 = "设置表格默认列宽,并且同时设置当前所有表格列的宽度." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的列宽 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nColWidth = MAX (0, @<所欲设置的列宽>);
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetDefCellWidth (pWnd->m_nColWidth);
        @     const INT nNumCols = pWnd->GetColumnCount ();
        @     for (INT nColIndex = 0; nColIndex < nNumCols; nColIndex++)
        @         pWnd->SetColumnWidth (nColIndex, pWnd->m_nColWidth);
        @     pWnd->Refresh ();
        @ }
    }

    方法 行数 <公开 属性读 类型 = 整数 注释 = "返回当前表格行数" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetRowCount () : pWnd->m_nRowCount);
    }

    方法 行数 <公开 属性写 注释 = "设置当前表格行数" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的行数 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nRowCount = MAX (1, @<所欲设置的行数>);
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetRowCount (pWnd->m_nRowCount);
        @     if (pWnd->m_bShowBM)
        @         pWnd->ShowZebraLine (pWnd->m_iLineType, pWnd->m_clr1, pWnd->m_clr2);
        @ }
    }

    方法 列数 <公开 属性读 类型 = 整数 注释 = "返回当前表格列数" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetColumnCount () : pWnd->m_nColCount);
    }

    方法 列数 <公开 属性写 注释 = "设置当前表格列数" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的列数 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nColCount = MAX (1, @<所欲设置的列数>);
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     pWnd->SetColumnCount (pWnd->m_nColCount);
        @     if (pWnd->m_bShowBM)
        @         pWnd->ShowZebraLine (pWnd->m_iLineType, pWnd->m_clr1, pWnd->m_clr2);
        @ }
    }

    方法 表头行数 <公开 属性读 类型 = 整数 注释 = "返回当前表格表头行数" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetFixedRowCount () : pWnd->m_nHeadRowCount);
    }

    方法 表头行数 <公开 属性写 注释 = "设置当前表格表头行数" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的行数 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nHeadRowCount = MAX (0, @<所欲设置的行数>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetFixedRowCount (pWnd->m_nHeadRowCount);
    }

    方法 表头列数 <公开 属性读 类型 = 整数 注释 = "返回当前表格表头列数" @禁止流程检查 = 真>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ return (pWnd->m_hWnd != NULL ? pWnd->GetFixedColumnCount () : pWnd->m_nHeadColCount);
    }

    方法 表头列数 <公开 属性写 注释 = "设置当前表格表头列数" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的列数 <类型 = 整数>
    {
        @ CVWnd_Grid* pWnd = (CVWnd_Grid*)GetMfcWndPtr ();
        @ pWnd->m_nHeadColCount = MAX (0, @<所欲设置的列数>);
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SetFixedColumnCount (pWnd->m_nHeadColCount);
    }

