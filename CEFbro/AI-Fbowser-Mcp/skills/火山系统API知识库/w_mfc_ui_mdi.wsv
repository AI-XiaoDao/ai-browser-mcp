    # virtual void OnShow (BOOL_P blpShown) override  { if (blpShown)  @<被显示> ();  else  @<被隐藏> (); }
    # virtual void OnMove () override  { @<位置被改变> (); }
    # virtual BOOL OnProcessCommand (const INT nCommandID) override  { return (@<接收到命令> (nCommandID) != 0); }
    # virtual BOOL OnUpdateCommandState (const INT nCommandID, CVolCmdState& objCmdState) override  { return (@<更新命令状态> (nCommandID, objCmdState) != 0); }
    # virtual BOOL OnBeforeClose () override  { return (@<可否被关闭> () == 0); }
    # virtual BOOL OnBeforeWindowClose () override  { return (@<窗口可否被关闭> () == 0); }
    # virtual void OnFirstActive () override  { @<首次激活> (); }
    # virtual void OnActive () override  { @<被激活> (); }
    # virtual void OnInactive () override  { @<被取消激活> (); }
    # virtual void OnIconOper (INT nType) override  { @<托盘事件> (nType); }
    # virtual void OnGetMinMaxInfo (MINMAXINFO* lpMMI) override;
    # virtual BOOL OnPreTranslateMessage (MSG* pMsg) override  { return (@<消息过滤> ((INT_P)pMsg->hwnd, (INT)pMsg->message, (INT_P)pMsg->wParam, (INT_P)pMsg->lParam, (INT_P)pMsg) == FALSE); }
    # virtual void OnRClickDocTab () override  { @<右键单击活动文档夹> (); }
    # virtual BOOL OnGetTitle (CVolString& strTitle) override  { return (@<获取窗口标题> (strTitle) != 0); }
    # virtual void OnIdleUpdateCmdUI () override  { @<空闲处理> (); }
    # virtual void OnActivateDocumentChanged () override  { @<活动文档被改变> (); }
    # virtual BOOL OnUpdateStatusBarCol (INT_P npColIndex, CVolString& strContent) override  { return (@<取状态栏文本> ((INT)npColIndex, strContent) != 0); }
