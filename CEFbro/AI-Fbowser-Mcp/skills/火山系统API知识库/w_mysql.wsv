    方法 取字符集信息 <公开 类型 = Mysql字符集信息类 注释 = "获取当前默认字符集的详细信息.">
    {
        变量 信息 <类型 = Mysql字符集信息类>
        @ if (GetMysql())
        @ {
        @     MY_CHARSET_INFO info;
        @     mysql_get_character_set_info(GetMysql(), &info);
        @     @<信息>.@n<Mysql字符集信息类.序号> = (INT)info.number;
        @     @<信息>.@n<Mysql字符集信息类.状态> = (INT)info.state;
        @     if (info.csname != NULL) @<信息>.@n<Mysql字符集信息类.排序名>.SetText(info.csname);
        @     if (info.name != NULL) @<信息>.@n<Mysql字符集信息类.字符集>.SetText(info.name);
        @     if (info.comment != NULL) @<信息>.@n<Mysql字符集信息类.注释>.SetText(info.comment);
        @     if (info.dir != NULL) @<信息>.@n<Mysql字符集信息类.字符集目录>.SetText(info.comment);
        @     @<信息>.@n<Mysql字符集信息类.多字节最小长度> = (INT)info.mbminlen;
        @     @<信息>.@n<Mysql字符集信息类.多字节最大长度> = (INT)info.mbmaxlen;
        @ }
        返回 (信息)
    }

