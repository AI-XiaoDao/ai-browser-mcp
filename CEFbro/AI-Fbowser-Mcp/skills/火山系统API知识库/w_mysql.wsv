类 Mysql连接池类 <公开 注释 = "提供一个线程安全的Mysql连接池.">
{

    # @begin
    # <> <include>
    # protected:
    #     CMMutex m_mutex;
    #     CMSemaphore m_semap;
    #     INT m_maxSize;    //最大连接数
    #     BOOL isInit;
    #     CVolObjectArray m_mysqlList;
    #     CVolMem memBuf[6];
    #     char* m_host;
    #     char* m_user;
    #     char* m_password;
    #     char* m_dbname;
    #     char* m_unix_socket;
    #     char* m_character;
    #     INT m_port;
    #     unsigned long m_clientflag;
    #
    #     inline_ void @an<_OnInitExtra> ()  { isInit = FALSE; m_character = NULL; }
    # public:
    #     INT GetActCount();
    #     INT InitConnectPool(CVolString& host, CVolString& user, CVolString& password, CVolString& dbname, INT port, CVolString& unix_socket, unsigned long clientflag, INT maxSize, INT initSize);
    #     BOOL CreateMysql(INT* pIndex);
    #     BOOL GetListActivityMysql(@dt<Mysql数据库类>& objResult, INT timeout);
    #     void DestroyMysql(@dt<Mysql数据库类>& obj);
    #     void ReleaseMysql(@dt<Mysql数据库类>& obj);
    #     void ReleaseAll();
    #     void SetCharacter(CVolString& str);
