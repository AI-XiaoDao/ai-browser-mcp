    方法 初始化 <公开 类型 = 整数 注释 = "初始化Mysql连接池并连接至指定Mysql服务器" 返回值注释 = "返回该连接池中所创建成功的连接数" @嵌入式方法 = "">
    参数 地址 <类型 = 文本型 注释 = "提供所欲连接数据库的地址.">
    参数 用户名 <类型 = 文本型 注释 = "提供所欲连接数据库的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供所欲连接数据库的连接密码.">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲连接数据库的名称.">
    参数 端口 <类型 = 整数 注释 = "提供所欲连接数据库的端口." @默认值 = 3306>
    参数 套接字 <类型 = 文本型 注释 = "该字符串描述了应使用的套接字或命名管道." @默认值 = 空对象>
    参数 配置位 <类型 = 整数 注释 = "请参考\"Mysql连接配置\"所提供的常量,该参数接受其中单个或多个组合的值." @默认值 = 0>
    参数 最大连接数 <类型 = 整数 注释 = "连接池中所能创建的最大连接数量." @默认值 = 50>
    参数 初始连接数 <类型 = 整数 注释 = "初始化时所欲创建的可用连接数." @默认值 = 10>
    {
        @ @sn<this>.InitConnectPool(@<地址>, @<用户名>, @<密码>, @<数据库名>, @<端口>, @<套接字>, @<配置位>, @<最大连接数>, @<初始连接数>)
    }

    方法 取连接 <公开 类型 = 逻辑型 注释 = "  从Mysql连接池中取出一个可用的连接. 成功返回真,失败返回假." 注释 = "  如果当前连接池中暂无可用连接,将会新建一个连接,如果已达到最大连接数限制时将会等待指定时长,"
            注释 = "超时后将会返回假." 注释 = "  注意:取出的连接使用完毕后务必调用\"释放连接\"方法,否则所取出的连接将一直处于占用状态." 返回值注释 = "返回本次获取的连接是否有效." @嵌入式方法 = "">
    参数 结果连接 <类型 = Mysql数据库类 注释 = "如果本方法成功,则所获得连接将填入此结果变量中.">
    参数 繁忙等待时间 <类型 = 整数 注释 = "指定在所有连接都已用尽时所欲等待的时长,提供-1表示无限等待,0表示不等待.单位:毫秒." @默认值 = 10000>
    {
        @ @sn<this>.GetListActivityMysql(@<结果连接>, @<繁忙等待时间>)
    }

    方法 释放连接 <公开 注释 = "释放从连接池中所取出的连接对象,使其在连接池中恢复空闲状态等待被获取." 注释 = "注意:取出的连接使用完毕后务必调用本方法释放,否则所取出的连接将一直处于占用状态." @嵌入式方法 = "">
    参数 连接对象 <类型 = Mysql数据库类 注释 = "提供所欲释放的连接对象,必须确认此连接目前不再使用.">
    {
        @ @sn<this>.ReleaseMysql(@<连接对象>)
    }

    方法 释放所有连接 <公开 注释 = "释放连接池中所有的连接对象,使其在连接池中恢复空闲状态等待被获取." 注释 = "调用本方法时必须确认所有连接目前不再使用." @嵌入式方法 = "">
    {
        @ @sn<this>.ReleaseAll()
    }

    方法 销毁连接 <公开 注释 = "销毁连接池中的指定连接,该连接将会从连接池中被移除并断开释放." @嵌入式方法 = "">
    参数 连接对象 <类型 = Mysql数据库类 注释 = "提供所欲销毁的连接对象,必须确认此连接不再使用.">
    {
        @ @sn<this>.DestroyMysql(@<连接对象>)
    }

    方法 创建连接 <公开 类型 = 逻辑型 注释 = "在该连接池中新建一个连接,返回创建的结果." 返回值注释 = "如果当前连接池中连接已达最大连接数将会返回失败." @嵌入式方法 = "">
    {
        @ @sn<this>.CreateMysql(NULL)
    }

    方法 取空闲连接数 <公开 类型 = 整数 注释 = "获取当前连接池中空闲的可用连接数." @嵌入式方法 = "">
    {
        @ @sn<this>.GetActCount()
    }

    方法 置字符集 <公开 注释 = "设置该连接池中所有连接所欲使用的默认字符集,支持在\"初始化\"方法之前调用." @嵌入式方法 = "">
    参数 字符集 <类型 = 文本型 注释 = "提供所欲使用的字符集.">
    {
        @ @sn<this>.SetCharacter(@<字符集>)
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 注释 = "使用连接池当前空闲的连接执行一条SQL语句" 返回值注释 = "执行成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 语句内容 <类型 = 文本型 注释 = "提供所欲查询当前数据库的SQL语句.">
    参数 繁忙等待时间 <类型 = 整数 注释 = "指定在所有连接都已用尽时所欲等待的时长,提供-1表示无限等待,0表示不等待.单位:毫秒." @默认值 = 10000>
    {
        变量 临时连接 <类型 = Mysql数据库类>
        变量 返回结果 <类型 = 逻辑型>
        如果 (取连接 (临时连接, 繁忙等待时间))  // 判定所取出连接是否有效
        {
            返回结果 = 临时连接.执行SQL语句 (语句内容)
            释放连接 (临时连接)
        }
        返回 (返回结果)
    }
}
