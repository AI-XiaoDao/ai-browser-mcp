<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.MYSQL数据库

类 Mysql_SSL模式 <公开 注释 = "定义Mysql协议类型." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 禁用加密模式 <公开 值 = 1 注释 = "客户端禁用加密连接。">
    常量 默认连接模式 <公开 值 = 2 注释 = "默认值首选">
    常量 启用加密模式 <公开 值 = 3 注释 = "客户端需要加密连接，如果无法建立连接则失败。">
    常量 证书加密模式 <公开 值 = 4 注释 = "客户端需要加密连接，并且还针对服务器 CA 证书">
    常量 服务器证书模式 <公开 值 = 5
            注释 = "针对其证书中的服务器主机名执行验证。 不适用于由服务器自动创建或使用mysql_ssl_rsa_setup手动创建的自签名证书。此类自签名证书不包含服务器名称作为 Common Name 值。">
}

类 Mysql数据库类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装."
        注释 = "如果用户程序中调用了本类中的\"使用新版本\"方法,将使用 mysql 最新 8.0.40 版进行编译,支持火山模块的静态链接方式,否则将使用 6.1.11 版进行编译." 编辑时信息 = "2E1527, 0, 0, 0"
        @视窗.外部头文件 = "vol_mysql.h" "" "@视窗.头文件搜寻目录.d:!_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\1\\include"
        "@视窗.附属文件.d:!_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\1\\$(p)\\libmysql.dll"
        "@视窗.外部库.d:!_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\1\\$(p)\\libmysql.lib" ""
        "@视窗.头文件搜寻目录.d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\include"
        "@视窗.附属文件.non_static-x64 - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libcrypto-3-x64.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libssl-3-x64.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zstd.dll"
        "@视窗.附属文件.non_static-win32 - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libcrypto-3.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libssl-3.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zstd.dll"
        "@视窗.外部库.non_static - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.lib" ""
        "@视窗.附属文件.static-debug-x64 - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libcrypto-3-x64.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libssl-3-x64.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zstd.dll"
        "@视窗.附属文件.static-debug-win32 - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libcrypto-3.dll\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libssl-3.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zstd.dll"
        "@视窗.外部库.static-debug - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\dll\\libmysql.lib" ""
        "@视窗.外部库.static-release - d:_VOL_MYSQL_VER2" = "..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\lib\\mysqlclient.lib\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\lib\\libcrypto.lib\r\n..\\..\\shared\\extern_lib\\common\\mysql\\2\\$(p)\\lib\\libssl.lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zstd.lib\r\ncrypt32.lib"
        "@视窗.需求VS版本.static - d:_VOL_MYSQL_VER2" = "16-" "@视窗.使用静态运行时库.static - d:_VOL_MYSQL_VER2" = 真>
{
    方法 使用新版本 <公开 静态 注释 = "调用本方法指示编译器使用 mysql 最新 8.0.40 版进行编译,同时支持火山模块的静态链接方式,如果不调用本方法,将使用 6.1.11 版进行编译."
            注释 = "注意: 本方法为编译时处理方法,系统在编译时只要检测到用户程序实际执行流程中任意位置调用了此方法,就启用对应的编译特性,和方法本身是否被执行到没有任何关系." @视窗.预定义宏 = "_VOL_MYSQL_VER2"
            @视窗.编译信息 = "基于 MYSQL 8.0.40 版本编译">
    {

    }

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CMysqlWraper)
    #
    # @ <include>
    # @ inline_ MYSQL* GetMysql ()  { return data().GetData(); }
    # @ </include>
    #
    # 静态方法 ---

    方法 取客户端版本名 <公开 静态 类型 = 文本型 注释 = "获取当前客户端的版本名称." @禁止流程检查 = 真>
    {
        @ const char* infoStr = mysql_get_client_info();
        @ if (infoStr != NULL) return @an<CVolString> (infoStr);
        @ return _T ("");
    }

    方法 取客户端版本号 <公开 静态 类型 = 整数 注释 = "获取当前客户端的版本号." @嵌入式方法 = "">
    {
        @ (INT)mysql_get_client_version()
    }

    # options属性 ---

    方法 SSL模式 <公开 属性写 注释 = "指定需要连接使用的ssl模式类型." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 类型 <类型 = Mysql_SSL模式>
    {
        @ if (GetMysql())
        @ {
        @     mysql_ssl_mode mode = SSL_MODE_PREFERRED;
        @     if (@<类型> == 1)
        @         mode = SSL_MODE_DISABLED;
        @     else if (@<类型> == 3)
        @         mode = SSL_MODE_REQUIRED;
        @     else if (@<类型> == 4)
        @         mode = SSL_MODE_VERIFY_CA;
        @     else if (@<类型> == 5)
        @         mode = SSL_MODE_VERIFY_IDENTITY;
        @     mysql_options(GetMysql(), MYSQL_OPT_SSL_MODE, &mode);
        @ }
    }

    方法 线程安全 <公开 属性读 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return (INT)mysql_thread_safe();
    }

    方法 连接超时 <公开 属性写 注释 = "设置连接超时时长." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 超时 <类型 = 整数 注释 = "单位:秒.">
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_OPT_CONNECT_TIMEOUT, &@<超时>);
    }

    方法 连接超时 <公开 属性读 类型 = 整数 注释 = "获取当前配置的连接超时时长." 返回值注释 = "单位:秒">
    {
        变量 超时 <类型 = 整数 值 = 0>
        @ if (GetMysql()) mysql_get_option(GetMysql(), MYSQL_OPT_CONNECT_TIMEOUT, &@<超时>);
        返回 (超时)
    }

    方法 读取超时 <公开 属性写 注释 = "设置读取信息的超时时长." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 超时 <类型 = 整数 注释 = "单位:秒.">
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_OPT_READ_TIMEOUT, &@<超时>);
    }

    方法 读取超时 <公开 属性读 类型 = 整数 注释 = "获取当前配置的读取超时时长." 返回值注释 = "单位:秒">
    {
        变量 超时 <类型 = 整数 值 = 0>
        @ if (GetMysql()) mysql_get_option(GetMysql(), MYSQL_OPT_READ_TIMEOUT, &@<超时>);
        返回 (超时)
    }

    方法 写入超时 <公开 属性写 注释 = "设置写入数据的超时时长." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 超时 <类型 = 整数 注释 = "单位:秒.">
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_OPT_WRITE_TIMEOUT, &@<超时>);
    }

    方法 写入超时 <公开 属性读 类型 = 整数 注释 = "获取当前配置的写入超时时长." 返回值注释 = "单位:秒">
    {
        变量 超时 <类型 = 整数 值 = 0>
        @ if (GetMysql()) mysql_get_option(GetMysql(), MYSQL_OPT_WRITE_TIMEOUT, &@<超时>);
        返回 (超时)
    }

    方法 通报数据截断错误 <公开 属性写 注释 = "指定对于预处理语句是否允许通报数据截断错误." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 启用 <类型 = 逻辑型>
    {
        @ if (GetMysql())
        @ {
        @     my_bool value = (my_bool)@<启用>;
        @     mysql_options(GetMysql(), MYSQL_REPORT_DATA_TRUNCATION, &value);
        @ }
    }

    方法 通报数据截断错误 <公开 属性读 类型 = 逻辑型 注释 = "获取对于预处理语句是否允许通报数据截断错误." @禁止流程检查 = 真>
    {
        @ my_bool value = 0;
        @ if (GetMysql()) mysql_get_option(GetMysql(), MYSQL_REPORT_DATA_TRUNCATION, &value);
        @ return (BOOL)value;
    }

    方法 自动提交事务 <公开 属性写 注释 = "指定是否将当前事务提交模式设为自动.">
    参数 启用 <类型 = 逻辑型>
    {
        @ if (GetMysql()) mysql_autocommit(GetMysql(), (CHAR)@<启用>);
    }

    方法 自动重连 <公开 属性写 注释 = "如果与服务器连接被断开,是否进行自动重连." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 启用 <类型 = 逻辑型>
    {
        @ if (GetMysql()) 
        @ {
        @     my_bool value = (my_bool)@<启用>;
        @     mysql_options(GetMysql(), MYSQL_OPT_RECONNECT, &value);
        @ }
    }

    方法 自动重连 <公开 属性读 类型 = 逻辑型 注释 = "获取是否已启用自动重连属性." @禁止流程检查 = 真>
    {
        @ my_bool value = 0;
        @ if (GetMysql()) mysql_get_option(GetMysql(), MYSQL_OPT_RECONNECT, &value);
        @ return (BOOL)value;
    }

    方法 连接后命令 <公开 属性写 注释 = "设置一个在连接成功后立即执行的命令,如再次连接将会再次执行该命令." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 命令内容 <类型 = 文本型>
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_INIT_COMMAND, GetMbsText (@<命令内容>, CVolMem (), NULL));
    }

    方法 命名选项文件 <公开 属性写 注释 = "指定从命名选项文件而不是从my.cnf读取选项配置." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 文件 <类型 = 文本型>
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_READ_DEFAULT_FILE, GetMbsText (@<文件>, CVolMem (), NULL));
    }

    方法 命名选项组 <公开 属性写 注释 = "指定从my.cnf或用\"命名选项文件\"属性指定的文件中的命名组读取选项配置." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 命名组 <类型 = 文本型>
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_READ_DEFAULT_GROUP, GetMbsText (@<命名组>, CVolMem (), NULL));
    }

    方法 字符集定义文件 <公开 属性写 注释 = "指定包含字符集定义文件的目录的路径名." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 文件 <类型 = 文本型>
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_SET_CHARSET_DIR, GetMbsText (@<文件>, CVolMem (), NULL));
    }

    方法 协议类型 <公开 属性写 注释 = "指定需要连接使用的协议类型." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 类型 <类型 = Mysql协议类型>
    {
        @ if (GetMysql()) 
        @ {
        @     mysql_protocol_type type = MYSQL_PROTOCOL_DEFAULT;
        @     if (@<类型> == 1)
        @         type = MYSQL_PROTOCOL_TCP;
        @     else if (@<类型> == 2)
        @         type = MYSQL_PROTOCOL_SOCKET;
        @     else if (@<类型> == 3)
        @         type = MYSQL_PROTOCOL_PIPE;
        @     else if (@<类型> == 4) 
        @         type = MYSQL_PROTOCOL_MEMORY;
        @     mysql_options(GetMysql(), MYSQL_OPT_PROTOCOL, &type);
        @ }
    }

    方法 共享内存对象名称 <公开 属性写 注释 = "命名为与服务器进行通信的共享内存对象." 注释 = "注意:必须在\"连接()\"方法之前调用生效.">
    参数 名称 <类型 = 文本型>
    {
        @ if (GetMysql()) mysql_options(GetMysql(), MYSQL_SHARED_MEMORY_BASE_NAME, GetMbsText (@<名称>, CVolMem (), NULL));
    }

    方法 多个查询结果 <公开 属性读 类型 = 逻辑型 注释 = "检查当前所执行的查询是否存在多个结果集." 返回值注释 = "如果返回真,获取查询的记录集之前必须调用\"到下一个记录集()\"来获取多个记录集." @禁止流程检查 = 真>
    {
        @ if (GetMysql()) return (BOOL)mysql_more_results(GetMysql());
        @ return FALSE;
    }

    # ---

    方法 启用SSL <公开 类型 = 整数 注释 = "启用SSL以建立数据库的安全连接." 注释 = "注意:必须在\"连接()\"方法之前调用生效." 返回值注释 = "返回0表示初始化SSL环境成功." @禁止流程检查 = 真>
    参数 私钥文件 <类型 = 文本型 注释 = "提供所欲使用的私钥文件(key文件)路径.">
    参数 证书文件 <类型 = 文本型 注释 = "提供所欲使用的证书文件(cert)路径.">
    参数 授权文件 <类型 = 文本型 注释 = "提供所欲使用的证书授权文件(ca)路径.">
    参数 目录名称 <类型 = 文本型 注释 = "提供pem格式的SSL CA证书目录路径.">
    参数 允许密码列表 <类型 = 文本型 注释 = "允许密码的列表,用于SSL加密.">
    {
        @ if (GetMysql()) return mysql_ssl_set(GetMysql(), GetMbsText (@<私钥文件>, CVolMem (), NULL), GetMbsText (@<证书文件>, CVolMem (), NULL), GetMbsText (@<授权文件>, CVolMem (), NULL), GetMbsText (@<目录名称>, CVolMem (), NULL), GetMbsText (@<允许密码列表>, CVolMem (), NULL));
        @ return -1;
    }

    方法 取SSL允许密码列表 <公开 类型 = 文本型 注释 = "获取SSL允许密码列表." @禁止流程检查 = 真>
    {
        @ if (GetMysql()) {
        @     const char* str = mysql_get_ssl_cipher(GetMysql());  //可能会返回NULL.
        @      if (str != NULL) return @an<CVolString> (str);
        @ }
        @ return _T ("");
    }

    方法 连接 <公开 类型 = 逻辑型 注释 = "连接至指定Mysql服务器." 返回值注释 = "返回是否连接成功." @禁止流程检查 = 真>
    参数 地址 <类型 = 文本型 注释 = "提供所欲连接数据库的地址.">
    参数 用户名 <类型 = 文本型 注释 = "提供所欲连接数据库的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供所欲连接数据库的连接密码.">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲连接数据库的名称.">
    参数 端口 <类型 = 整数 注释 = "提供所欲连接数据库的端口." @默认值 = 3306>
    参数 套接字 <类型 = 文本型 注释 = "该字符串描述了应使用的套接字或命名管道." @默认值 = 空对象>
    参数 配置位 <类型 = 整数 注释 = "请参考\"Mysql连接配置\"所提供的常量,该参数接受其中单个或多个组合的值." @默认值 = 0>
    {
        @ if (GetMysql()) return mysql_real_connect(GetMysql(), GetMbsText (@<地址>, CVolMem (), NULL), GetMbsText (@<用户名>, CVolMem (), NULL), GetMbsText (@<密码>, CVolMem (), NULL), GetMbsText (@<数据库名>, CVolMem (), NULL), @<端口>, (BOOL)@<套接字>.IsNullObject () ? NULL : GetMbsText (@<套接字>, CVolMem (), NULL), @<配置位>) != 0;
        @ return FALSE;
    }

    方法 修改用户 <公开 类型 = 逻辑型 注释 = "更改用户以及当前的默认数据库(即当前所操作的库)." 返回值注释 = "返回是否更换用户成功." @禁止流程检查 = 真>
    参数 数据库名 <类型 = 文本型 注释 = "提供新的数据库名称.">
    参数 用户名 <类型 = 文本型 注释 = "提供新的数据库用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供新的数据库密码.">
    {
        @ if (GetMysql()) return !(BOOL)mysql_change_user(GetMysql(), GetMbsText (@<用户名>, CVolMem (), NULL), GetMbsText (@<密码>, CVolMem (), NULL), GetMbsText (@<数据库名>, CVolMem (), NULL));
        @ return FALSE;
    }

    方法 选择库 <公开 类型 = 逻辑型 注释 = "更改当前的默认数据库(即当前所操作的库)." @禁止流程检查 = 真>
    参数 数据库名 <类型 = 文本型 注释 = "提供新的数据库名称.">
    {
        @ if (GetMysql()) return !(BOOL)mysql_select_db(GetMysql(), GetMbsText (@<数据库名>, CVolMem (), NULL));
        @ return FALSE;
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 注释 = "执行一条SQL语句,执行成功后可通过\"取记录集\"命令获取记录集."
            注释 = "注意:如果所欲执行的SQL语句中包含二进制数据,请使用命令\"执行SQL语句_二进制\",否则有可能执行出错." 返回值注释 = "执行成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 语句内容 <类型 = 文本型 注释 = "提供所欲查询当前数据库的SQL语句.">
    {
        @ if (GetMysql()) return !(BOOL)mysql_query(GetMysql(), GetMbsText (@<语句内容>, CVolMem (), NULL));
        @ return FALSE;
    }

    方法 执行SQL语句_二进制 <公开 类型 = 逻辑型 注释 = "执行一条SQL语句,执行成功后可通过\"取记录集\"命令获取记录集." 返回值注释 = "执行成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 语句内容 <类型 = 字节集类 注释 = "提供所欲查询当前数据库的SQL语句.">
    {
        @ if (GetMysql()) return !(BOOL)mysql_real_query(GetMysql(), (CHAR*)@<语句内容>.GetPtr(), (unsigned long)(INT)@<语句内容>.GetSize());
        @ return FALSE;
    }

    # ---

    方法 到下一个记录集 <公开 类型 = 整数 注释 = "如果当前所执行的查询存在多个记录集,需调用本方法后去获取结果集." 返回值注释 = "如果返回0,表示后续还有结果未取完,返回-1表示已取完所有结果." @禁止流程检查 = 真>
    {
        @ if (GetMysql()) return mysql_next_result(GetMysql());
        @ return -1;
    }

    方法 取记录集 <公开 类型 = Mysql记录集类 注释 = "在使用\"执行SQL语句()\"获取一些需要返回数据的查询后,如果查询成功本方法将返回一个有效记录集." @禁止流程检查 = 真>
    {
