    方法 转义SQL语句 <公开 类型 = 文本型 注释 = "如果所欲执行的SQL语句中包含特殊字符,可使用本方法对该语句进行转义后确保语句安全执行." 返回值注释 = "成功返回转义后的内容,否则返回空文本." @禁止流程检查 = 真>
    参数 原内容 <类型 = 文本型 注释 = "提供所欲转义的文本内容.">
    {
        @ if (GetMysql())
        @ {
        @     INT_P fromLen;
        @     CVolMem memBuf[2];
        @     const char* from = GetMbsText(@<原内容>.GetText(), memBuf[0], &fromLen);
        @     if (mysql_real_escape_string(GetMysql(), (char*)memBuf[1].Alloc(fromLen * 2 + 1, TRUE), from, fromLen) > 0)
        @     {
        @         CVolMem wideBuf;
        @         INT_P toLen;
        @         const WCHAR* pws = GetWideText ((const CHAR*)memBuf[1].GetPtr(), wideBuf, &toLen);    //to必定以Null结尾.
        @         return @an<CVolString> (pws, toLen);
        @     }
        @ }
        @ return _T("");
    }
}

类 Mysql记录集类 <公开 注释 = "本类实例表示一次SQL查询所得到的结果集." 注释 = "记录集实际为一个链表结构,移动其行(即\"到下一行\"/\"到指定行\"方法)的索引取出当前值." @强制依赖 = "Mysql数据库类">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CMysqlResWraper)
    #
    # @ <include>
    # @ inline_ @dt<Mysql记录集类> (INT_P ptr) : @dt<Mysql记录集类>()  { data().SetData(ptr); }
    # @ inline_ MYSQL_RES* GetMyRes ()  { return data ().GetData (); }
    # @ </include>

    方法 是否有效 <公开 属性读 类型 = 逻辑型 注释 = "判断该结果集是否为有效结果集." 返回值注释 = "返回假则该结果集将无法取出任何内容." @禁止流程检查 = 真>
    {
        @ return GetMyRes() != NULL;
    }

    方法 行数 <公开 属性读 类型 = 长整数 注释 = "返回该记录集所包含的行数." @禁止流程检查 = 真>
    {
        @ if (GetMyRes()) return (INT64)mysql_num_rows(GetMyRes());
        @ return 0;
    }

    方法 列数 <公开 属性读 类型 = 整数 注释 = "返回该记录集所包含的列(字段)总数." @禁止流程检查 = 真>
    {
        @ if (GetMyRes()) return mysql_num_fields(GetMyRes());
        @ return 0;
    }

    方法 列长度 <公开 属性读 类型 = 整数 注释 = "获取当前所处位置列(字段)的长度,为NULL时返回0." @禁止流程检查 = 真>
    {
        @ if (GetMyRes())
        @ {
        @     unsigned long * len = mysql_fetch_lengths(GetMyRes());
        @     if (len) return (INT)*len;
        @ }
        @ return 0;
    }

    方法 取字段列表 <公开 类型 = Mysql字段信息数组类 注释 = "获取该记录集中所有列信息(即所有字段)." 返回值注释 = "一个成员对应一个列(字段),其成员数与列数(字段数)对应.">
    {
        变量 结果 <类型 = Mysql字段信息数组类>
        @ if (!GetMyRes()) return @<结果>;
        @ MYSQL_FIELD* fields = mysql_fetch_fields(GetMyRes());
        @ if (fields)
        @ {
        @     for (INT i = 0; i < (INT)mysql_num_fields(GetMyRes()); i++)
        @         @<结果>.Add (@dt<Mysql字段信息类>(&fields[i]), NULL);
        @ }
        返回 (结果)
    }

    方法 取当前行数据 <公开 类型 = 字节集数组类 注释 = "读出当前行的原始数据,包括所有列." 注释 = "注意:如果数据为文本,需使用\"多字节到文本()\"转换数据."
            返回值注释 = "一个成员对应一个列(字段),其成员数与列数(字段数)对应.">
    {
        变量 结果 <类型 = 字节集数组类>
        @ if (!GetMyRes()) return @<结果>;
        @ char** current_row = GetMyRes()->current_row;
        @ unsigned long *lengths = mysql_fetch_lengths(GetMyRes());    //unsigned long *lengths = GetMyRes()->lengths;
        @ if (current_row && lengths)    //修复空表引发异常.
        @ {
        @     for (INT i = 0; i < mysql_num_fields(GetMyRes()); i++)
        @     {
        @         if (current_row[i] == NULL)
        @             @<结果>.Add (CVolMem (), NULL);
        @         else
        @             @<结果>.Add (CVolMem (current_row[i], lengths[i]), NULL);    //@<结果>.Add (CVolMem (current_row[i], strlen(current_row[i])), NULL);
        @     }
        @ }
        返回 (结果)
    }

    方法 取当前行文本数据 <公开 类型 = 文本数组类 注释 = "以文本内容形式读出当前行的数据,包括所有列." 返回值注释 = "一个成员对应一个列(字段),其成员数与列数对应.">
    {
        变量 结果 <类型 = 文本数组类>
        @ if (!GetMyRes()) return @<结果>;
        @ char** current_row = GetMyRes()->current_row;
        @ if (current_row)    //修复空表引发异常.
        @ {
        @     for (INT i = 0; i < (INT)mysql_num_fields(GetMyRes()); i++)
        @     {
        @         if (current_row[i] == NULL)  //字段内容为NULL?
        @             @<结果>.data ().Add ("");
        @         else 
        @             @<结果>.data ().Add (GetWideText (current_row[i], CVolMem (), NULL));
        @     }
        @ }
        返回 (结果)
    }

    方法 取当前行整数数据 <公开 类型 = 整数数组类 注释 = "按十进制整数形式读出当前行的数据,包括所有列." 返回值注释 = "一个成员对应一个列(字段),其成员数与列数对应.">
    {
        变量 结果 <类型 = 整数数组类>
        @ if (!GetMyRes()) return @<结果>;
        @ char** current_row = GetMyRes()->current_row;
        @ if (current_row)    //修复空表引发异常.
        @ {
        @     for (INT i = 0; i < mysql_num_fields(GetMyRes()); i++)
        @     {
        @         if (current_row[i] == NULL)  //字段内容为NULL?
        @             @<结果>.data ().Add (0);
        @         else 
        @             @<结果>.data ().Add (atoi(current_row[i]));
        @     }
        @ }
        返回 (结果)
    }

    方法 到下一行 <公开 类型 = 逻辑型 注释 = "移动到下一行去读数据." 返回值注释 = "如果移动成功返回真,否则返回假(通常为无数据)." @禁止流程检查 = 真>
    {
        @ if (GetMyRes()) return mysql_fetch_row(GetMyRes()) != NULL;
        @ return FALSE;
    }

    方法 到指定行 <公开 类型 = 逻辑型 注释 = "将当前记录指针移动到指定行,移动后调用\"取当前行XX()\"获取数据." 注释 = "注意:使用\"取临时结果集\"所返回的记录集不支持使用."
            返回值注释 = "移动成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 行 <类型 = 长整数 注释 = "提供所欲跳转到的行索引.">
    {
        如果 (行 >= 行数)
        {
            返回 (假)
        }
        @ if (GetMyRes())
        @ {
        @     mysql_data_seek(GetMyRes(), @<行>);
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 关闭 <公开 注释 = "关闭记录集,释放所占用资源.">
    {
        @ if (GetMyRes()) pdata()->Close();
    }

    方法 读字节集数据 <公开 类型 = 字节集类 注释 = "提供指定字段(列)名称,读出记录集当前行该字段对应的数据内容." 返回值注释 = "返回所读到的数据." @禁止流程检查 = 真>
    参数 字段名 <类型 = 文本型 注释 = "提供所欲读出数据对应的字段名称.">
    {
        @ if (GetMyRes())
        @ {
        @     char** current_row = GetMyRes()->current_row;
        @     MYSQL_FIELD* fields = GetMyRes()->fields;
        @     unsigned long *lengths = mysql_fetch_lengths(GetMyRes());    //unsigned long *lengths = GetMyRes()->lengths;
        @     if (current_row && fields && lengths)
        @     {
        @         CVolMem memBuf;
        @         char* fieldName = (char*)GetMbsText(@<字段名>, memBuf, NULL);
        @         for (INT i = 0; i < (INT)mysql_num_fields(GetMyRes()); i++)
        @             if (!strcmp(fieldName, fields[i].name)) return CVolMem(current_row[i], lengths[i]);
        @     }
        @ }
        @ return CVolMem();
    }

    方法 读索引字节集数据 <公开 类型 = 字节集类 注释 = "提供指定字段(列)的索引,读出记录集当前行该字段对应的数据内容." 返回值注释 = "返回所读到的数据." @禁止流程检查 = 真>
    参数 字段索引 <类型 = 整数 注释 = "提供所欲读出数据对应的字段索引位置.">
    {
        @ if (GetMyRes() && @<字段索引> < mysql_num_fields(GetMyRes()))
        @ {
        @     char** current_row = GetMyRes()->current_row;
        @     unsigned long *lengths = mysql_fetch_lengths(GetMyRes());    //unsigned long *lengths = GetMyRes()->lengths;
        @     if (current_row && lengths)
        @         return CVolMem(current_row[@<字段索引>], lengths[@<字段索引>]);
        @ }
        @ return CVolMem();
    }

    方法 读文本数据 <公开 类型 = 文本型 注释 = "提供指定字段(列)名称,读出记录集当前行该字段对应的数据内容." 返回值注释 = "返回所读到的数据.">
    参数 字段名 <类型 = 文本型 注释 = "提供所欲读出数据对应的字段名称.">
    {
        返回 (多字节到文本 (读字节集数据 (字段名)))
    }

    方法 读索引文本数据 <公开 类型 = 文本型 注释 = "提供指定字段(列)的索引,读出记录集当前行该字段对应的数据内容." 返回值注释 = "返回所读到的数据.">
