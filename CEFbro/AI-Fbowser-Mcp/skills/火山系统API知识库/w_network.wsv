类 客户 <公开 @视窗.后缀文本 = "public IVolSocketInterface">
{

    # 事件 --

    方法 数据到达 <公开 定义事件 类型 = 整数 注释 = "当服务器端将数据发送过来后,会产生本事件.">
    参数 所接收到的数据 <类型 = 字节集类 注释 = "提供所接收到的数据,必定不为空字节集.">

    方法 连接断开 <公开 定义事件 类型 = 整数 注释 = "当连接被服务器端断开后,会产生本事件.">

    # 方法 --

    方法 连接 <公开 类型 = 逻辑型 注释 = "连接到指定主机上的指定端口,该主机上的该端口必须已经被某一服务器监听." 注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 服务器地址 <类型 = 文本型 注释 = "可以为主机名/IP地址等">
    参数 服务器端口号 <类型 = 整数 注释 = "该端口必须已经被服务器组件监听">
    {
        @ return (m_objClient.Create (this) && m_objClient.ConnectServer (@<服务器地址>.GetText (), @<服务器端口号>));
    }

    方法 断开连接 <公开 注释 = "断开与服务器的已有连接" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objClient.CloseConnection ()
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "在成功建立与服务器的连接后,发送数据到服务器端组件." 注释 = "成功返回真,失败返回假."
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 所欲发送的所有数据 <注释 = "提供所欲发送的所有数据,可以为基本数据类型或字节集类数据." 编辑时信息 = "EAA9C, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.SendData (-1, CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>), @<所欲发送的所有数据>))
    }

    方法 发送数据2 <公开 类型 = 逻辑型 注释 = "在成功建立与服务器的连接后,发送数据到服务器端组件." 注释 = "成功返回真,失败返回假."
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 最长等待时间 <类型 = 整数 注释 = "指定等待发送成功的最长时间,单位为秒.如果为-1,表示为无限等待.">
    参数 所欲发送的所有数据 <注释 = "提供所欲发送的所有数据,可以为基本数据类型或字节集类数据." 编辑时信息 = "EAA9C, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.SendData (@<最长等待时间>, CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>) + 1, @<所欲发送的所有数据>))
    }

    方法 是否已连接 <公开 类型 = 逻辑型 注释 = "返回当前是否已经连接到了服务器" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objClient.IsConnected ()
    }

    # --
    # @begin
    # <> <include>
    # CClientSockObject m_objClient;
    # virtual void OnRecvPeerData (CVolMem& memData) override  { @<数据到达> (memData); }
    # virtual void OnServerCloseConnect () override  { @<连接断开> (); }
    # inline_ BOOL SendData (INT nWaitSeconds, const CVolMem& memData)  { return m_objClient.SendData (memData.GetPtr (), (INT)memData.GetSize (), nWaitSeconds); }
    # <> </include>
    # @end
}

# ===

类 服务器 <公开 @视窗.后缀文本 = "public IVolSocketInterface">
{

    # 事件 --

    方法 数据到达 <公开 定义事件 类型 = 整数 注释 = "当有客户端数据到达后,会产生本事件.">
    参数 客户地址 <类型 = 文本型 注释 = "提供所对应客户的地址文本: IP地址 + 端口">
    参数 所接收到的数据 <类型 = 字节集类 注释 = "提供所接收到的数据,必定不为空字节集.">

    方法 客户进入 <公开 定义事件 类型 = 整数 注释 = "当有新客户连接入本服务器后,会产生本事件.">
    参数 所进入客户地址 <类型 = 文本型 注释 = "提供所进入客户的地址文本: IP地址 + 端口">

    方法 客户离开 <公开 定义事件 类型 = 整数 注释 = "当有已连接客户断开与本服务器的连接后,会产生本事件.">
    参数 所离开客户地址 <类型 = 文本型 注释 = "提供所离开客户的地址文本: IP地址 + 端口">

    # 属性 --

    方法 端口 <公开 属性写 注释 = "指定监听客户连接的端口号,如果不进行设置,默认为19730.">
    参数 所欲监听的端口号 <类型 = 整数 注释 = "可以是大于 0 小于 32767 的任何自定整数值">
    {
        @ m_objServer.ChangePort (@<所欲监听的端口号>);
    }

    方法 端口 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的监听数据到达的端口号" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.GetPort ()
    }

    方法 仅监听本机 <公开 属性写 注释 = "为真指定仅监听本机地址(127.0.0.1),一般用作进程之间通讯时使用,为假则监听所有地址." 注释 = "注意: 本属性仅在调用\"开始监听\"方法前设置有效.">
    参数 是否仅监听本机 <类型 = 逻辑型>
    {
        @ m_objServer.m_blOnlyBindLocalHost = @<是否仅监听本机>;
    }

    方法 仅监听本机 <公开 属性读 类型 = 逻辑型 注释 = "返回是否仅监听本机地址(127.0.0.1)" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.m_blOnlyBindLocalHost
    }

    # 方法 --

    方法 开始监听 <公开 类型 = 逻辑型 注释 = "开始在\"端口\"属性所指定的端口上监听客户端连接及数据到达,返回是否成功." @禁止流程检查 = 真>
    {
        @ return m_objServer.Create (this);
    }

    方法 停止监听 <公开 注释 = "断开所有已连接客户端(注意不会发送\"客户离开\"事件),停止监听端口." @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.Close ()
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "向指定已经连接进来的客户发送数据. 成功返回真,失败返回假."
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 接收客户地址 <类型 = 文本型 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户地址文本,为空文本表示向所有现有客户发送数据.">
    参数 最长等待时间 <类型 = 整数 注释 = "指定等待发送到每个客户成功的最长时间,单位为秒.如果为-1,表示为无限等待." @默认值 = -1>
    参数 所欲发送的所有数据 <注释 = "提供所欲发送的所有数据,可以为基本数据类型或字节集类数据." 编辑时信息 = "EAA9C, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.SendData (@<接收客户地址>.GetText (), @<最长等待时间>, CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>) + 2, @<所欲发送的所有数据>))
    }

    方法 断开客户 <公开 注释 = "断开与指定客户之间的连接,发送\"客户离开\"事件." @嵌入式方法 = "">
    参数 欲断开客户 <类型 = 文本型 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户地址文本,为空文本表示断开所有现有客户.">
    {
        @ @sn<this>.m_objServer.CloseSpecClientConnect (@<欲断开客户>.GetText ())
    }

    方法 取客户数目 <公开 类型 = 整数 注释 = "返回当前所有已经连接客户的数目" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.GetNumClients ()
    }

    方法 取客户 <公开 类型 = 文本型 注释 = "返回所指定索引位置处已连接客户的地址文本" @嵌入式方法 = "">
    参数 客户索引位置 <类型 = 整数 注释 = "提供所欲获取已连接客户的索引位置,必须大于等于0且小于\"取客户数目\"方法的返回值,如索引值无效将返回空文本.">
    {
        @ CVolString (@sn<this>.m_objServer.GetClient (@<客户索引位置>))
    }

    方法 取客户句柄 <公开 类型 = 变整数 注释 = "返回所指定索引位置处已连接客户的 HSOCKET 句柄值" @嵌入式方法 = "">
    参数 客户索引位置 <类型 = 整数 注释 = "提供所欲获取已连接客户的索引位置,必须大于等于0且小于\"取客户数目\"方法的返回值,如索引值无效将返回-1.">
    {
        @ @sn<this>.m_objServer.GetClientSocket (@<客户索引位置>)
    }

    方法 查找客户句柄 <公开 类型 = 变整数 注释 = "返回所指定地址文本客户所对应的 HSOCKET 句柄值,不存在返回0." @嵌入式方法 = "">
    参数 客户地址文本 <类型 = 文本型 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户地址文本">
    {
        @ @sn<this>.m_objServer.FindClientSocket (@<客户地址文本>.GetText ())
    }

    # --
    # @begin
    # <> <include>
    # CServerSockObject m_objServer;
    # virtual void OnRecvClientData (CVolMem& memData, const TCHAR* szClient) override  { @<数据到达> (CVolString (szClient), memData); }
    # virtual void OnClientEntry (const TCHAR* szClient) override  { @<客户进入> (CVolString (szClient)); }
    # virtual void OnClientLeave  (const TCHAR* szClient) override  { @<客户离开> (CVolString (szClient)); }
    # inline_ BOOL SendData (const TCHAR* szClient, INT nWaitSeconds, const CVolMem& memData)  { return m_objServer.SendData (szClient, memData.GetPtr (), (INT)memData.GetSize (), nWaitSeconds); }
    # <> </include>
    # @end
}

# ===

类 服务器2 <公开 注释 = "提供直接基于SOCKET句柄进行高效网络操作的服务器类." 注释 = "注意: 相比\"服务器\"类,本类未在内部维护已连接客户列表,用户需要自行管理."
        @视窗.后缀文本 = "public IVolSocketInterface">
{

    # 事件 --

    方法 数据到达 <公开 定义事件 类型 = 整数 注释 = "当有客户端数据到达后,会产生本事件.">
    参数 客户句柄 <类型 = 变整数 注释 = "提供所对应客户的SOCKET句柄值">
    参数 所接收到的数据 <类型 = 字节集类 注释 = "提供所接收到的数据,必定不为空字节集.">

    方法 客户进入 <公开 定义事件 类型 = 整数 注释 = "当有新客户连接入本服务器后,会产生本事件.">
    参数 客户句柄 <类型 = 变整数 注释 = "提供所对应客户的SOCKET句柄值">

    方法 客户离开 <公开 定义事件 类型 = 整数 注释 = "当有已连接客户断开与本服务器的连接后,会产生本事件.">
    参数 客户句柄 <类型 = 变整数 注释 = "提供所对应客户的SOCKET句柄值">

    # 属性 --

    方法 端口 <公开 属性写 注释 = "指定监听客户连接的端口号,如果不进行设置,默认为19730.">
    参数 所欲监听的端口号 <类型 = 整数 注释 = "可以是大于 0 小于 32767 的任何自定整数值">
    {
        @ m_objServer.ChangePort (@<所欲监听的端口号>);
    }

    方法 端口 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的监听数据到达的端口号" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.GetPort ()
    }

    方法 仅监听本机 <公开 属性写 注释 = "为真指定仅监听本机地址(127.0.0.1),一般用作进程之间通讯时使用,为假则监听所有地址." 注释 = "注意: 本属性仅在调用\"开始监听\"方法前设置有效.">
    参数 是否仅监听本机 <类型 = 逻辑型>
    {
        @ m_objServer.m_blOnlyBindLocalHost = @<是否仅监听本机>;
    }

    方法 仅监听本机 <公开 属性读 类型 = 逻辑型 注释 = "返回是否仅监听本机地址(127.0.0.1)" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.m_blOnlyBindLocalHost
    }

    # 方法 --

    方法 启动 <公开 类型 = 逻辑型 注释 = "开始在\"端口\"属性所指定的端口上监听客户端连接及数据到达,返回是否成功." @禁止流程检查 = 真>
    {
        @ return m_objServer.Create (this);
    }

    方法 停止 <公开 注释 = "停止监听端口,断开与所有客户的连接,如需再使用本对象,需要重新启动." @嵌入式方法 = "">
    {
        @ @sn<this>.m_objServer.Close ()
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "向指定已经连接进来的客户发送数据. 成功返回真,失败返回假." 注释 = "本方法支持在多线程环境下运行."
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 客户句柄 <类型 = 变整数 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户SOCKET句柄值">
    参数 最长等待时间 <类型 = 整数 注释 = "指定等待发送到每个客户成功的最长时间,单位为秒.如果为-1,表示为无限等待." @默认值 = -1>
    参数 所欲发送的所有数据 <注释 = "提供所欲发送的所有数据,可以为基本数据类型或字节集类数据." 编辑时信息 = "EAA9C, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.SendData (@<客户句柄>, @<最长等待时间>, CollectVariantVolDatas (CVolMem (), _T (@sn<pm_types>) + 2, @<所欲发送的所有数据>))
    }

    方法 断开客户 <公开 注释 = "断开与指定客户之间的连接(注意不会发送\"客户离开\"事件)." 注释 = "本方法支持在多线程环境下运行." @嵌入式方法 = "">
    参数 客户句柄 <类型 = 变整数 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户SOCKET句柄值">
    {
        @ @sn<this>.m_objServer.CloseSpecClientConnect (@<客户句柄>)
    }

    方法 取客户地址 <公开 静态 类型 = 文本型 注释 = "成功返回所指定客户的地址文本(格式为\"IP地址:端口\"),失败返回空文本." @嵌入式方法 = "">
    参数 客户句柄 <类型 = 变整数 注释 = "为\"数据到达\"/\"客户进入\"事件或\"取客户\"方法中所提供的客户SOCKET句柄值">
    {
        @ CServerSockObject2::sGetPeerAddress (@<客户句柄>, CVolString ())
    }

    # --
    # @begin
    # <> <include>
    # CServerSockObject2 m_objServer;
    # virtual void OnRecvClientData2 (CVolMem& memData, const INT_P npSocketHandle) override  { @<数据到达> (npSocketHandle, memData); }
    # virtual void OnClientEntry2 (const INT_P npSocketHandle) override  { @<客户进入> (npSocketHandle); }
    # virtual void OnClientLeave2  (const INT_P npSocketHandle) override  { @<客户离开> (npSocketHandle); }
    # inline_ BOOL SendData (const INT_P npSocketHandle, INT nWaitSeconds, const CVolMem& memData)  { return CBaseSocketObjct::sSendData ((SOCKET)npSocketHandle, memData.GetPtr (), (INT)memData.GetSize (), nWaitSeconds); }
    # <> </include>
    # @end
    #
}
