    参数 红 <类型 = 小数 注释 = "提供欲设置填充颜色的\"洋红\"分量值,有效值为0到1.">
    参数 黄 <类型 = 小数 注释 = "提供欲设置填充颜色的\"黄色\"分量值,有效值为0到1.">
    参数 黑 <类型 = 小数 注释 = "提供欲设置填充颜色的\"黑色\"分量值,有效值为0到1.">
