类 PDF文本编码类型 <公开 注释 = "文本编码类型用作指定字体和文本内容所对应的编码类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 标准 <公开 值 = @VHPET_STANDARD_ENCODING 注释 = "\"StandardEncoding\": PDF使用的标准编码" "">
    常量 MacOS编码 <公开 值 = @VHPET_MAC_ROMAN_ENCODING 注释 = "\"MacRomanEncoding\": Mac OS 操作系统的标准编码">
    常量 WINANSI <公开 值 = @VHPET_WIN_ANSI_ENCODING 注释 = "\"WinAnsiEncoding\": Windows操作系统的标准编码">
    常量 内置 <公开 值 = @VHPET_FONT_SPECIFIC 注释 = "\"FontSpecific\": 字体内置编码">
    常量 拉丁字母2 <公开 值 = @VHPET_ISO8859_2 注释 = "\"ISO8859-2\": 拉丁字母2">
    常量 拉丁字母3 <公开 值 = @VHPET_ISO8859_3 注释 = "\"ISO8859-3\": 拉丁字母3">
    常量 拉丁字母4 <公开 值 = @VHPET_ISO8859_4 注释 = "\"ISO8859-4\": 拉丁字母4">
    常量 西里尔字母 <公开 值 = @VHPET_ISO8859_5 注释 = "\"ISO8859-5\": 拉丁文西里尔字母">
    常量 阿拉伯字母 <公开 值 = @VHPET_ISO8859_6 注释 = "\"ISO8859-6\": 拉丁阿拉伯文字母">
    常量 希腊字母 <公开 值 = @VHPET_ISO8859_7 注释 = "\"ISO8859-7\": 拉丁希腊字母">
    常量 希伯来字母 <公开 值 = @VHPET_ISO8859_8 注释 = "\"ISO8859-8\": 拉丁希伯来字母">
    常量 拉丁字母5 <公开 值 = @VHPET_ISO8859_9 注释 = "\"ISO8859-9\": 拉丁字母5">
    常量 拉丁字母6 <公开 值 = @VHPET_ISO8859_10 注释 = "\"ISO8859-10\": 拉丁字母6">
    常量 泰文 <公开 值 = @VHPET_ISO8859_11 注释 = "\"ISO8859-11\": 泰文, TIS 620-2569字符集">
    常量 拉丁字母7 <公开 值 = @VHPET_ISO8859_13 注释 = "\"ISO8859-13\": 拉丁字母7">
    常量 拉丁字母8 <公开 值 = @VHPET_ISO8859_14 注释 = "\"ISO8859-14\": 拉丁字母8">
    常量 拉丁字母9 <公开 值 = @VHPET_ISO8859_15 注释 = "\"ISO8859-15\": 拉丁字母9">
    常量 拉丁字母10 <公开 值 = @VHPET_ISO8859_16 注释 = "\"ISO8859-16\": 拉丁字母10">
    常量 中欧语 <公开 值 = @VHPET_CP1250 注释 = "\"CP1250\": 微软 Windows 代码页 1250 (EE). 主要代表位于中欧使用拉丁字母的语言.">
    常量 西里尔文 <公开 值 = @VHPET_CP1251 注释 = "\"CP1251\": 微软 Windows 代码页 1251 (Cyrl). 主要代表使用西里尔字母的语言.">
    常量 ANSI <公开 值 = @VHPET_CP1252 注释 = "\"CP1252\": 微软 Windows 代码页 1252 (ANSI)">
    常量 希腊语 <公开 值 = @VHPET_CP1253 注释 = "\"CP1253\": 微软 Windows 代码页 1253 (希腊文)">
    常量 土耳其语 <公开 值 = @VHPET_CP1254 注释 = "\"CP1254\": 微软 Windows 代码页 1254 (土耳其语)">
    常量 希伯来语 <公开 值 = @VHPET_CP1255 注释 = "\"CP1255\": 微软 Windows 代码页 1255 (希伯来语)">
    常量 阿拉伯语 <公开 值 = @VHPET_CP1256 注释 = "\"CP1256\": 微软 Windows 代码页 1256 (阿拉伯文)">
    常量 波罗的海语 <公开 值 = @VHPET_CP1257 注释 = "\"CP1257\": 微软 Windows 代码页 1257 (BaltRim). 主要代表波罗的海国家的语言.">
    常量 越南语 <公开 值 = @VHPET_CP1258 注释 = "\"CP1258\": 微软 Windows 代码页 1258 (越南)">
    常量 俄语 <公开 值 = @VHPET_KOI8_R 注释 = "\"KOI8-R\": 俄语网络字符集">
    常量 ""
    常量 简体中文 <公开 值 = @VHPET_CNS_GBK_EUC_H 注释 = "简体中文编码类型. \"GBK-EUC-H\": 微软代码页936(lfCharSet 0x86)GBK编码">
    常量 简体中文竖写 <公开 值 = @VHPET_CNS_GBK_EUC_V 注释 = "简体中文编码类型. \"GBK-EUC-V\": GBK-EUC-H的竖写版">
    常量 简体中文GB <公开 值 = @VHPET_CNS_GB_EUC_H 注释 = "简体中文编码类型. \"GB-EUC-H\": EUC-CN编码">
    常量 简体中文GB竖写 <公开 值 = @VHPET_CNS_GB_EUC_V 注释 = "简体中文编码类型. \"GB-EUC-V\": GB-EUC-H的竖写版">
    常量 ""
    常量 繁体中文 <公开 值 = @VHPET_CNT_ETEN_B5_H 注释 = "繁体中文编码类型. \"ETen-B5-H\": 微软代码页950（lfCharSet 0x88）带有ETen扩展的big5字符集">
    常量 繁体中文竖写 <公开 值 = @VHPET_CNT_ETEN_B5_V 注释 = "繁体中文编码类型. \"ETen-B5-V\": ETen-B5-H的竖写版">
    常量 ""
    常量 日文 <公开 值 = @VHPET_JP_90MS_RKSJ_H 注释 = "日文编码类型. \"90ms-RKSJ-H\": 微软代码页932, JIS X 0208字符">
    常量 日文竖写 <公开 值 = @VHPET_JP_90MS_RKSJ_V 注释 = "日文编码类型. \"90ms-RKSJ-V\": 90ms-RKSJ-H的竖写版">
    常量 日文变宽 <公开 值 = @VHPET_JP_90MSP_RKSJ_H 注释 = "日文编码类型. \"90msp-RKSJ-H\": 微软代码页932, JIS X 0208字符(比例)">
    常量 日文EUC <公开 值 = @VHPET_JP_EUC_H 注释 = "日文编码类型. \"EUC-H\": JIS X 0208字符集, EUC-JP编码">
    常量 日文EUC竖写 <公开 值 = @VHPET_JP_EUC_V 注释 = "日文编码类型. \"EUC-V\": EUC-H的竖写版">
    常量 ""
    常量 韩文 <公开 值 = @VHPET_KR_KSCMS_UHC_H
            注释 = "韩文编码类型. \"KSCms-UHC-H\": 微软代码页949(lfCharSet 0x81), KS X 1001:1992 字符集加上8822附加韩文,统一韩文代码(UHC)编码(比例)">
    常量 韩文定宽 <公开 值 = @VHPET_KR_KSCMS_UHC_HW_H
            注释 = "韩文编码类型. \"KSCms-UHC-HW-H\": 微软代码页949(lfCharSet 0x81), KS X 1001:1992 字符集加上8822附加韩文,统一韩文代码(UHC)编码(固定宽度)">
    常量 韩文定宽竖写 <公开 值 = @VHPET_KR_KSCMS_UHC_HW_V 注释 = "韩文编码类型. \"KSCms-UHC-HW-V\": KSCms-UHC-HW-H的竖写版">
    常量 韩文EUC <公开 值 = @VHPET_KR_KSC_EUC_H 注释 = "韩文编码类型. \"KSC-EUC-H\": KS X 1001:1992 字符集, EUC-KR编码">
    常量 韩文EUC竖写 <公开 值 = @VHPET_KR_KSC_EUC_V 注释 = "韩文编码类型. \"KSC-EUC-V\": KSC-EUC-H的竖写版">
    常量 ""
    常量 UTF8 <公开 值 = @VHPET_UTF8
            注释 = "UTF-8编码类型. 必须与支持Unicode字符集的TrueType字体协同使用,见\"PDF文档.取字体\"方法\"字体名称\"参数中关于\"TrueType字体\"的描述.">
}

类 PDF页面布局模式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 单页 <公开 值 = @HPDF_PAGE_LAYOUT_SINGLE 注释 = "仅显示一个页面">
    常量 单列 <公开 值 = @HPDF_PAGE_LAYOUT_ONE_COLUMN 注释 = "在一列中显示页面">
    常量 双列左侧 <公开 值 = @HPDF_PAGE_LAYOUT_TWO_COLUMN_LEFT 注释 = "以两列显示,奇数页码显示在左侧.">
    常量 双列右侧 <公开 值 = @HPDF_PAGE_LAYOUT_TWO_COLUMN_RIGHT 注释 = "以两列显示,奇数页码显示在右侧.">
    常量 双页左侧 <公开 值 = @HPDF_PAGE_LAYOUT_TWO_PAGE_LEFT 注释 = "以双页显示,奇数页码显示在左侧.">
    常量 双页右侧 <公开 值 = @HPDF_PAGE_LAYOUT_TWO_PAGE_RIGHT 注释 = "以双页显示,奇数页码显示在右侧.">
    常量 无 <公开 值 = @HPDF_PAGE_LAYOUT_EOF 注释 = "仅用作返回当前页面布局模式,设置时不能使用本常量.">
}

类 PDF页面模式 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 通常 <公开 值 = @HPDF_PAGE_MODE_USE_NONE 注释 = "显示不带书签或缩略图的文档">
    常量 书签 <公开 值 = @HPDF_PAGE_MODE_USE_OUTLINE 注释 = "显示带有书签的文档">
    常量 缩略图 <公开 值 = @HPDF_PAGE_MODE_USE_THUMBS 注释 = "显示带有缩略图窗格的文档">
    常量 全屏 <公开 值 = @HPDF_PAGE_MODE_FULL_SCREEN 注释 = "以全屏模式显示文档">
    常量 无 <公开 值 = @HPDF_PAGE_MODE_EOF 注释 = "仅用作返回当前页面显示模式,设置时不能使用本常量.">
}

类 PDF页号风格 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 阿拉伯数字 <公开 值 = @HPDF_PAGE_NUM_STYLE_DECIMAL 注释 = "阿拉伯数字（1 2 3 4）">
    常量 大写罗马数字 <公开 值 = @HPDF_PAGE_NUM_STYLE_UPPER_ROMAN 注释 = "大写罗马数字（I II III IV）">
    常量 小写罗马数字 <公开 值 = @HPDF_PAGE_NUM_STYLE_LOWER_ROMAN 注释 = "小写罗马数字（i ii iii iv）">
    常量 大写字母 <公开 值 = @HPDF_PAGE_NUM_STYLE_UPPER_LETTERS 注释 = "大写字母（A B C D）">
    常量 小写字母 <公开 值 = @HPDF_PAGE_NUM_STYLE_LOWER_LETTERS 注释 = "小写字母（a B c d）">
    常量 无 <公开 值 = @HPDF_PAGE_NUM_STYLE_EOF 注释 = "仅用作返回当前页号风格,设置时不能使用本常量.">
}

类 PDF字典项类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 创建时间 <公开 值 = @HPDF_INFO_CREATION_DATE 注释 = "属性值是\"PDF时间\"数据">
    常量 修改时间 <公开 值 = @HPDF_INFO_MOD_DATE 注释 = "属性值是\"PDF时间\"数据">
    常量 作者 <公开 值 = @HPDF_INFO_AUTHOR>
    常量 创建者 <公开 值 = @HPDF_INFO_CREATOR>
    常量 出品方 <公开 值 = @HPDF_INFO_PRODUCER>
    常量 标题 <公开 值 = @HPDF_INFO_TITLE>
    常量 主题 <公开 值 = @HPDF_INFO_SUBJECT>
    常量 关键词 <公开 值 = @HPDF_INFO_KEYWORDS>
    常量 陷印 <公开 值 = @HPDF_INFO_TRAPPED 注释 = "用于标记文档的色彩是否已经被正确处理(即\"陷印\"处理)."
            注释 = "这个信息对于下游的印前处理流程非常重要. 如果文档被标记为\"False\",则 RIP(光栅图像处理器)或印前软件可能会自动应用陷印算法."
            注释 = "如果文档已经被正确陷印(标记为\"True\"),则应避免再次应用陷印,否则可能会导致颜色重叠过多或视觉效果变差." 注释 = "属性值是一个字符串,根据 PDF 规范,可以是以下值之一:"
            注释 = "\"True\": 表示文档中的所有元素都已正确陷印;" 注释 = "\"False\": 表示文档尚未陷印，或者陷印信息未知;" 注释 = "\"Unknown\": 表示陷印状态不确定.">
    常量 版本规范 <公开 值 = @HPDF_INFO_GTS_PDFX
            注释 = "用于指定 PDF 文件符合哪一个具体的 PDF/X 标准版本规范. 例如: \"PDF/X-1a:2001\", \"PDF/X-3:2002\", \"PDF/X-4\", \"PDF/X-4p\"."
            注释 = "它的主要目的是确保 PDF 文件在不同系统、不同印刷服务商之间进行交换时,能够可靠地、可预测地被打印和印刷,避免因字体缺失、颜" 注释 = "色空间错误、图像分辨率不足等问题导致印刷失败或效果偏差."
            注释 = "遵循 PDF/X 标准的文件通常需要通过专门的预检(Preflight)验证.">
    常量 无 <公开 值 = @HPDF_INFO_EOF>
}

类 PDF权限 <公开 注释 = "用作提供各种PDF文档权限,可以使用\"相加\"或\"位或\"操作符组合起来使用" @文档 = "category = \"辅助类\"">
{
    常量 读 <公开 类型 = 整数 值 = @HPDF_ENABLE_READ 注释 = "用户可以读取文档">
    常量 打印 <公开 类型 = 整数 值 = @HPDF_ENABLE_PRINT 注释 = "用户可以打印文档">
    常量 编辑内容 <公开 类型 = 整数 值 = @HPDF_ENABLE_EDIT_ALL 注释 = "用户可以编辑除注解、表单字段以外的文档内容.">
    常量 复制 <公开 类型 = 整数 值 = @HPDF_ENABLE_COPY 注释 = "用户可以复制文档的文本和图形">
    常量 编辑注解或表单 <公开 类型 = 整数 值 = @HPDF_ENABLE_EDIT 注释 = "用户可以添加或修改文档的注解和表单字段">
}

类 PDF加密算法 <公开 注释 = "用作提供各种PDF文档加密算法" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 修订版2 <公开 值 = @HPDF_ENCRYPT_R2 注释 = "\"修订版2\"算法. 加密密钥的字节长度自动设置为5(40位).">
    常量 修订版3 <公开 值 = @HPDF_ENCRYPT_R3 注释 = "\"修订版3\"算法. 加密密钥的字节长度可以从 5(40位) 到 16(128位).">
}

类 PDF压缩模式 <公开 注释 = "用作提供各种PDF压缩模式,可以使用\"相加\"或\"位或\"操作符组合起来使用" @文档 = "category = \"辅助类\"">
{
