<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.PDF操作 <注释 = "本类库封装了LibHaru PDF开源库,用作支持创建并写出指定内容的PDF文件." 编辑时信息 = "173FE8, 0, 0, 0">

类 PDF错误码 <公开 注释 = "提供对PDF进行操作时的错误码值" @文档 = "category = \"辅助类\"">
{
    常量 成功 <公开 类型 = 整数 值 = @HPDF_OK 注释 = "当操作成功时返回此值">
    常量 数组数目错 <公开 类型 = 整数 值 = @HPDF_ARRAY_COUNT_ERR>
    常量 未找到数组项 <公开 类型 = 整数 值 = @HPDF_ARRAY_ITEM_NOT_FOUND>
