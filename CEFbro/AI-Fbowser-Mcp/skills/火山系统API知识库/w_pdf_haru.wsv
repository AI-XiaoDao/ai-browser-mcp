    }

    方法 取灰度填充色 <公开 静态 类型 = 小数 注释 = "返回页面填充颜色的当前值(以灰度值表示)." 注释 = "仅在页面的填充颜色空间为\"PDF颜色空间.设备灰度\"时有效."
            返回值注释 = "成功返回当前所设置的页面填充色(以灰度值0到1表示),否则返回默认值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetGrayFill (@<本页面句柄>)
    }

    方法 置灰度填充色 <公开 静态 类型 = 整数 注释 = "设置页面填充颜色的当前值(以灰度值表示)." 注释 = "调用本方法后页面的填充颜色空间将改变为\"PDF颜色空间.设备灰度\"."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的灰度值 <类型 = 小数 注释 = "为介于0和1之间的灰度值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetGrayFill (@<本页面句柄>, (HPDF_REAL)@<欲设置的灰度值>)
    }

    方法 取灰度描边色 <公开 静态 类型 = 小数 注释 = "返回页面描边颜色的当前值(以灰度值表示)." 注释 = "仅在页面的描边颜色空间为\"PDF颜色空间.设备灰度\"时有效."
            返回值注释 = "成功返回当前所设置的描边色(以灰度值0到1表示),否则返回默认值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetGrayStroke (@<本页面句柄>)
    }

    方法 置灰度描边色 <公开 静态 类型 = 整数 注释 = "设置页面描边颜色的当前值(以灰度值表示)." 注释 = "调用本方法后页面的描边颜色空间将改变为\"PDF颜色空间.设备灰度\"."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的灰度值 <类型 = 小数 注释 = "为介于0和1之间的灰度值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetGrayStroke (@<本页面句柄>, (HPDF_REAL)@<欲设置的灰度值>)
    }

    方法 取描边颜色空间 <公开 静态 类型 = PDF颜色空间 注释 = "成功返回页面描边颜色空间的当前值,失败返回\"PDF颜色空间.无\"." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetStrokingColorSpace (@<本页面句柄>)
    }

    方法 取填充颜色空间 <公开 静态 类型 = PDF颜色空间 注释 = "成功返回页面填充颜色空间的当前值,失败返回\"PDF颜色空间.无\"." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetFillingColorSpace (@<本页面句柄>)
    }

    方法 压入图形状态 <公开 静态 类型 = 整数 注释 = "  将页面的当前图形状态保存到图形状态堆栈顶部,图形状态栈深度加一,以后可以通过调用\"弹出图形状态\"方法恢复保存的图形状态."
            注释 = "  所保存的图形状态包括: 扩展图形状态, 字符间距, 剪切路径, 虚线模式, 填充颜色, 曲线平坦度, 字体, 字体尺寸, 文本水平缩放比,"
            注释 = "线宽, 线条末端样式, 线条连接样式, 线条斜接限制值, 文本渲染模式, 描边颜色, 文本行距, 文本上升值, 转换矩阵, 单词间距."
            注释 = "  在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式不改变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_GSave (@<本页面句柄>)
    }

    方法 弹出图形状态 <公开 静态 类型 = 整数 注释 = "恢复先前通过调用\"压入图形状态\"方法保存到图形状态堆栈顶部的图形状态,然后图形状态栈深度减一." 注释 = "所恢复的图形状态参见\"压入图形状态\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式不改变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_GRestore (@<本页面句柄>)
    }

    方法 取已压入图形状态数 <公开 静态 类型 = 整数 注释 = "  获取PDF页面上已压入图形状态且尚未弹出的数目,即图形状态栈的当前深度."
            注释 = "  \"图形状态\": 在PDF中,图形状态是一组当前生效的绘图属性,包括: 当前颜色(填充色、描边色); 线宽、线型(虚线模式); 裁剪路径;"
            注释 = " 变换矩阵(用于平移、旋转、缩放); 字体和字号; 透明度(如果启用)."
            注释 = "  \"图形状态栈\": PDF支持通过压入(保存)和弹出(恢复)操作来管理图形状态: 每调用一次\"压入图形状态\"方法将当前图形状态压入栈中(保存状态),"
            注释 = "栈深度加1. 每调用一次\"弹出图形状态\"方法将最近保存的图形状态从栈中弹出并恢复(恢复状态),栈深度减1. 这个栈结构允许你在进行临时性绘图操作"
            注释 = "(如变换、裁剪)后,能够准确地恢复到之前的状态,避免影响后续绘图." 返回值注释 = "成功返回图形状态栈的深度,否则返回值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetGStateDepth (@<本页面句柄>)
    }

    方法 置幻灯播放选项 <公开 静态 类型 = 整数 注释 = "为PDF页面设置以全屏幻灯片方式播放的过渡效果和持续时间."
            注释 = "当你希望生成的PDF文件在以全屏幻灯片模式播放时,页面之间能够平滑过渡(如淡入、推进、覆盖等),可以调用本方法." 注释 = "注意: 并非所有PDF查看器均支持本特性."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 过渡类型 <类型 = PDF幻灯过渡类型>
    参数 持续时间 <类型 = 小数 注释 = "页面的显示持续时间,单位秒.">
    参数 过渡时间 <类型 = 小数 注释 = "页面过渡效果的持续时间,单位秒.">
    {
        @ HPDF_Page_SetSlideShow (@<本页面句柄>, (HPDF_TransitionStyle)@<过渡类型>, (HPDF_REAL)@<持续时间>, (HPDF_REAL)@<过渡时间>)
    }

    方法 新建并切换内容流 <公开 静态 类型 = PDF字典 注释 = "本方法用于在现有PDF页面的末尾追加一个新的内容流,并将后续所有指令操作都切换输出到该内容流."
            注释 = "这在需要分阶段绘制内容、动态修改页面内容、重复添加页面内容时非常有用."
            注释 = "\"PDF 内容流\": 在PDF中,页面的可视内容(如文本、图形、图像)是通过一系列操作指令流(称为\"内容流\")来描述的. 这些指令为PDF特有的操作符,"
            注释 = "如: m (移动到); l (画线到); re (画矩形); Tj (显示文本) 等."
            注释 = "通常,一个页面有一个主内容流,但通过使用本方法,你可以在该页面上创建多个独立的内容流,它们同时存在并按顺序执行,共同构成页面的最终显示效果." 注释 = "作用与用途:"
            注释 = "1. 分阶段绘制: 你可以先绘制背景、边框等内容,然后调用本方法切换到一个新的内容流,再绘制前景文本或图形,这有助于组织绘图逻辑;"
            注释 = "2. 避免状态污染: 每个内容流有相对独立的图形状态,在新内容流中进行变换(如旋转、缩放)不会影响之前流的状态(除非显式保存/恢复);"
            注释 = "3. 动态内容追加: 在生成PDF的后期阶段,可以向已有内容的页面继续添加新元素;" 注释 = "4. 提高可维护性: 将不同部分的内容(如页眉、正文、页脚)放在不同的内容流中,便于管理和调试;"
            注释 = "5. 插入重复内容: 用作支持在多个页面上快速放置大量相同的内容. 在第一次出现重复内容时,调用本方法并保存所返回的字典句柄值,从而将后"
            注释 = "续内容输出到此单独的流中,重复内容输出完毕后再次调用本方法切换到另一个内容流以完成本流的构建. 最后,在后续其它页面上,直接使用前面所"
            注释 = "返回的字典句柄值调用\"插入内容流\"方法就可以将先前流中的所有内容直接输出到该页面上." 返回值注释 = "成功返回对应新建内容流的字典句柄(该句柄仅用作在\"插入内容流\"方法中使用,在输出内容时不需要),失败返回0."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ CHaruPdfDocument::sPage_New_Content_Stream (@<本页面句柄>)
    }

    方法 插入内容流 <公开 静态 类型 = 整数 注释 = "用于在当前PDF页面上插入一份先前由\"新建并切换内容流\"方法建立的内容,具体请参见该方法处的说明."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 内容流句柄 <类型 = PDF字典 注释 = "为先前调用\"新建并切换内容流\"方法时所返回的句柄值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Insert_Shared_Content_Stream (@<本页面句柄>, @<内容流句柄>)
    }

    方法 开始输出文本 <公开 静态 类型 = 整数 注释 = "开始输出文本并将文本输出位置设置到(0,0)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式将切换到\"PDF图形模式.文本\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_BeginText (@<本页面句柄>)
    }

    方法 置文本位置 <公开 静态 类型 = 整数 注释 = "将文本的当前输出位置设置到一个新的位置." 注释 = "本方法与\"移动文本位置\"方法不同之处在于,本方法使用的是绝对位置."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 横坐标 <类型 = 小数 注释 = "提供文本输出横坐标位置">
    参数 纵坐标 <类型 = 小数 注释 = "提供文本输出纵坐标位置">
    {
        @ CHaruPdfDocument::sPage_SetTextPos (@<本页面句柄>, @<横坐标>, @<纵坐标>)
    }

    方法 移动文本位置 <公开 静态 类型 = 整数 注释 = "将文本的当前输出位置移动到一个新的相对位置,新位置为当前位置加上本方法中所提供的偏移量." 注释 = "本方法与\"置文本位置\"方法不同之处在于,本方法使用的是相对偏移量."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 横向偏移量 <类型 = 小数 注释 = "相对当前文本输出横坐标位置的偏移量">
    参数 纵向偏移量 <类型 = 小数 注释 = "相对当前文本输出纵坐标位置的偏移量">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_MoveTextPos (@<本页面句柄>, (HPDF_REAL)@<横向偏移量>, (HPDF_REAL)@<纵向偏移量>)
    }

    方法 移动文本位置2 <公开 静态 类型 = 整数 注释 = "将文本的当前输出位置移动到一个新的相对位置,新位置为当前位置加上本方法中所提供的偏移量."
            注释 = "与\"移动文本位置\"方法不同的是,本方法会同时将\"文本行距\"图形状态设置为\"-纵向偏移量\"." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 横向偏移量 <类型 = 小数 注释 = "相对当前文本输出横坐标位置的偏移量">
    参数 纵向偏移量 <类型 = 小数 注释 = "相对当前文本输出纵坐标位置的偏移量,本参数的负值将被设置为新的\"文本行距\".">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_MoveTextPos2 (@<本页面句柄>, (HPDF_REAL)@<横向偏移量>, (HPDF_REAL)@<纵向偏移量>)
    }

    方法 到下文本行位置 <公开 静态 类型 = 整数 注释 = "  本方法将当前文本输出位置移动到同一段落中的下一行开头,它会根据当前设置的字体和字号自动计算行间距,并相应地调整垂直位置.这个操作通常与文本"
            注释 = "流相关联,当你需要从一行文本结束的地方跳转到下一行开始继续输出文本时非常有用."
            注释 = "  当你想要模拟类似文字处理器中的\"换行\"功能时,可以使用本方法,这对于创建包含多行文本的PDF文档特别有用,例如生成报告、信件或任何形式的书面通信."
            注释 = "  在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_MoveToNextLine (@<本页面句柄>)
    }

    方法 取文本位置 <公开 静态 类型 = PDF位置 注释 = "获取文本输出的当前位置. 注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸)."
            注释 = "注意: 仅当现行图形操作模式包含\"PDF图形模式.文本\"(使用\"位与\"操作符检测)时,应用程序才能调用本方法." 返回值注释 = "成功返回页面的当前文本输出位置,否则返回(0,0)位置." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetCurrentTextPos (@<本页面句柄>)
    }

    方法 取文本宽度 <公开 静态 类型 = 小数 注释 = "根据本页面中当前设置的字体尺寸及字符和单词间距,计算并返回指定文本的宽度." 注释 = "文本的高度请通过页面当前字体高度获取."
            返回值注释 = "成功返回所指定文本的宽度,单位为\"点\"(1/72英寸),失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 欲检测的文本 <类型 = 文本型 注释 = "  提供欲检测其宽度的文本内容,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作,因此必须确保所属文档"
            注释 = "当前\"文本编码类型\"属性值与页面中所设置字体创建时使用的\"文本编码类型\"属性值一致.">
    {
        @ @<所属文档>.data ().Page_TextWidth (@<本页面句柄>, @<欲检测的文本>.GetText ())
    }

    方法 取原始文本宽度 <公开 静态 类型 = 小数 注释 = "根据本页面中当前设置的字体尺寸及字符和单词间距,计算并返回指定原始文本(不会进行转码)的宽度." 注释 = "文本的高度请通过页面当前字体高度获取."
            注释 = "本方法应该在极特殊的情况下使用,正常情况不要使用." 返回值注释 = "成功返回所指定文本的宽度,单位为\"点\"(1/72英寸),失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲检测的原始文本 <类型 = "字节 []" 注释 = "提供欲检测其宽度文本的原始字节数据数组,其不会基于当前\"所属文档.文本编码类型\"属性值进行转码操作." 注释 = "注意: 用户必须确保该文本字节数据有效且以字节值 0 结束.">
    {
        @ CHaruPdfDocument::sPage_RawTextWidth (@<本页面句柄>, @<欲检测的原始文本>)
    }

    方法 取原始文本宽度2 <公开 静态 类型 = 小数 注释 = "根据本页面中当前设置的字体尺寸及字符和单词间距,计算并返回指定原始文本(不会进行转码)的宽度." 注释 = "文本的高度请通过页面当前字体高度获取."
            注释 = "本方法应该在极特殊的情况下使用,正常情况不要使用." 返回值注释 = "成功返回所指定文本的宽度,单位为\"点\"(1/72英寸),失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲检测的原始文本 <类型 = 字节集类 注释 = "提供欲检测其宽度文本的原始字节数据,其不会基于当前\"所属文档.文本编码类型\"属性值进行转码操作." 注释 = "注意: 用户必须确保该文本字节数据有效且以字节值 0 结束.">
    {
        @ CHaruPdfDocument::sPage_RawTextWidth (@<本页面句柄>, @<欲检测的原始文本>.GetPtr ())
    }

    方法 测量文本 <公开 静态 类型 = 整数 注释 = "根据当前字体尺寸、字符间距、单词间距进行计算,获取文本能够容纳在指定宽度里面的部分." 返回值注释 = "成功返回在\"可显示文本\"参数所返回文本后面的剩余文本的长度,否则返回0."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 欲检测的文本 <类型 = 文本型 注释 = "  提供欲检测其宽度的文本内容,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作,因此必须确保所属文档"
            注释 = "当前\"文本编码类型\"属性值与页面中所设置字体创建时使用的\"文本编码类型\"属性值一致.">
    参数 欲检测宽度 <类型 = 小数 注释 = "提供所使用的检测宽度值,单位为\"点\"(1/72英寸),被检测文本只有能够在此宽度中显示的部分才会被返回.">
    参数 在单词处切割 <类型 = 逻辑型 注释 = "  假设有如下文本需要检测\"ABCDE FGH IJKL\",并且在所指定宽度内可以容纳\"ABCDE FGH IJ\"部分,如果本参数值为真,"
            注释 = "将返回\"ABCDE FGH \"(在\"IJKL\"单词前切割),否则返回\"ABCDE FGH IJ\"(在任意字符处切割)." 注释 = "  对于中文文本,由于其并不会以空白字符对文本进行分词,因此请将本参数值设置为假."
            @默认值 = 假>
    参数 可显示文本 <类型 = 文本型 注释 = "用作返回\"欲检测的文本\"在\"欲检测宽度\"所指定的宽度内能够被显示的部分文本,必定位于\"欲检测的文本\"的首部."
            注释 = "如果\"欲检测的文本\"为空,或者\"欲检测宽度\"过小,或者方法处理失败,将返回空文本." @需求类型 = 可写入变量>
    {
        @ @<所属文档>.data ().Page_MeasureText (@<本页面句柄>, @<欲检测的文本>.GetText (), @<欲检测宽度>, @<在单词处切割>, @<可显示文本>)
    }

    方法 输出文本 <公开 静态 类型 = 整数 注释 = "在页面中当前文本位置(纵坐标指定文本行的基线位置)输出指定文本,然后将当前文本位置移动到所输出文本尾部."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    {
        @ @<所属文档>.data ().Page_ShowText (@<本页面句柄>, @<欲输出文本>.GetText ())
    }

    方法 输出原始文本 <公开 静态 类型 = 整数 注释 = "在页面中当前文本位置(纵坐标指定文本行的基线位置)输出指定原始文本(不会进行转码),然后将当前文本位置移动到所输出文本尾部."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 注释 = "本方法应该在极特殊的情况下使用,正常情况不要使用."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲输出原始文本 <类型 = "字节[]" 注释 = "提供欲输出文本的原始字节数据数组,其不会基于当前\"所属文档.文本编码类型\"属性值进行转码操作." 注释 = "注意: 用户必须确保该文本字节数据有效且以字节值 0 结束.">
    {
        @ CHaruPdfDocument::sPage_ShowRawText (@<本页面句柄>, @<欲输出原始文本>)
    }

    方法 输出原始文本2 <公开 静态 类型 = 整数 注释 = "在页面中当前文本位置(纵坐标指定文本行的基线位置)输出指定原始文本(不会进行转码),然后将当前文本位置移动到所输出文本尾部."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 注释 = "本方法应该在极特殊的情况下使用,正常情况不要使用."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲输出原始文本 <类型 = 字节集类 注释 = "提供欲输出文本的原始字节数据,其不会基于当前\"所属文档.文本编码类型\"属性值进行转码操作." 注释 = "注意: 用户必须确保该文本字节数据有效且以字节值 0 结束.">
    {
        @ CHaruPdfDocument::sPage_ShowRawText (@<本页面句柄>, @<欲输出原始文本>.GetPtr ())
    }

    方法 定位输出文本 <公开 静态 类型 = 整数 注释 = "在页面中指定位置处输出文本,然后将当前文本位置移动到所输出文本尾部." 注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 横坐标 <类型 = 小数 注释 = "提供文本输出的横坐标位置,单位为\"点\"(1/72英寸).">
    参数 纵坐标 <类型 = 小数 注释 = "提供文本输出时其基线所处的纵坐标位置,单位为\"点\"(1/72英寸),注意Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下.">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    {
        @ @<所属文档>.data ().Page_TextOut (@<本页面句柄>, @<横坐标>, @<纵坐标>, @<欲输出文本>.GetText ())
    }

    方法 输出区域文本 <公开 静态 类型 = 文本型 注释 = "在页面中的指定矩形区域内输出文本,并控制文本的对齐方式和自动换行." 注释 = "本方法能自动处理文本的换行和在矩形区域内的对齐,是处理多行文本布局的利器."
            注释 = "它通过指定一个矩形区域,自动完成以下工作:" 注释 = "1. 自动换行: 当文本到达右边界时自动换到下一行;" 注释 = "2. 对齐控制: 支持左对齐、右对齐、居中、两端对齐;"
            注释 = "3. 溢出处理: 通过返回值告诉你文本是否溢出所指定的矩形区域,便于实现切换区域继续输出后续文本." 注释 = "它是创建报告、文档、表单等需要格式化文本内容的 PDF 时不可或缺的函数,记住使用前必须设置好字体和字号."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 返回值注释 = "返回在所指定矩形区域内由于空间限制未能成功输出的后续文本内容,如果所有文本均被输出或中途出错,将返回空文本."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 左边 <类型 = 小数 注释 = "提供文本输出矩形区域的左边横坐标位置,单位为\"点\"(1/72英寸).">
    参数 顶边 <类型 = 小数 注释 = "提供文本输出矩形区域的顶边纵坐标位置,单位为\"点\"(1/72英寸). 注意Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下.">
    参数 右边 <类型 = 小数 注释 = "提供文本输出矩形区域的右边横坐标位置,单位为\"点\"(1/72英寸).">
    参数 底边 <类型 = 小数 注释 = "提供文本输出矩形区域的底边纵坐标位置,单位为\"点\"(1/72英寸). 注意Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下.">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    参数 对齐方式 <类型 = PDF文本对齐方式 注释 = "提供文本的水平对齐方式. 注意如果将\"在单词处切割\"参数设置为假,\"两端对齐\"方式将不会被支持(自动转换为\"左对齐\")." @默认值 = PDF文本对齐方式.左对齐>
    参数 在单词处切割 <类型 = 逻辑型 注释 = "  指定是否自动在单词处切割." 注释 = "  注意: 如果设置本参数值为真,所输出文本必须基于空白字符分词,不然处理时如果发现指定矩形区域宽度无法容纳整段文本,又无法根据空白字符分"
            注释 = "词以切换为多行的话,文本将不会被显示. 因此对于中文文本,请将本参数值设置为假." @默认值 = 假>
    {
        @ @<所属文档>.data ().Page_TextRect (@<本页面句柄>, @<左边>, @<顶边>, @<右边>, @<底边>, @<欲输出文本>.GetText (), @<对齐方式>, @<在单词处切割>)
    }

    方法 输出区域文本2 <公开 静态 类型 = 文本型 注释 = "在页面中的指定矩形区域内输出文本,并控制文本的对齐方式和自动换行. 具体信息及注意事项请参见\"输出区域文本\"方法."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 返回值注释 = "返回在所指定矩形区域内由于空间限制未能成功输出的后续文本内容,如果所有文本均被输出或中途出错,将返回空文本."
            @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 矩形区域 <类型 = PDF矩形 注释 = "提供文本输出矩形区域">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    参数 对齐方式 <类型 = PDF文本对齐方式 注释 = "提供文本的水平对齐方式. 注意如果将\"在单词处切割\"参数设置为假,\"两端对齐\"方式将不会被支持(自动转换为\"左对齐\")." @默认值 = PDF文本对齐方式.左对齐>
    参数 在单词处切割 <类型 = 逻辑型 注释 = "  指定是否自动在单词处切割." 注释 = "  注意: 如果设置本参数值为真,所输出文本必须基于空白字符分词,不然处理时如果发现指定矩形区域宽度无法容纳整段文本,又无法根据空白字符分"
            注释 = "词以切换为多行的话,文本将不会被显示. 因此对于中文文本,请将本参数值设置为假." @默认值 = 假>
    {
        @ return @<所属文档>.data ().Page_TextRect (@<本页面句柄>, @<矩形区域.左边>, @<矩形区域.顶边>, @<矩形区域.右边>, @<矩形区域.底边>, @<欲输出文本>.GetText (), @<对齐方式>, @<在单词处切割>);
    }

    方法 换行输出文本 <公开 静态 类型 = 整数 注释 = "将页面的当前文本位置移动到下一行的开头,然后在其当前文本位置(纵坐标指定文本行的基线位置)输出指定文本."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    {
        @ @<所属文档>.data ().Page_ShowTextNextLine (@<本页面句柄>, @<欲输出文本>.GetText ())
    }

    方法 换行输出文本2 <公开 静态 类型 = 整数 注释 = "将页面的当前文本位置移动到下一行的开头,然后设置指定的单词间距和字符间距,最后在其当前文本位置(纵坐标指定文本行的基线位置)输出指定文本."
            注释 = "在调用本方法前,页面的图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 单词间距 <类型 = 小数 注释 = "提供在输出文本前欲设置的单词间距,单位为\"点\"(1/72英寸).">
    参数 字符间距 <类型 = 小数 注释 = "提供在输出文本前欲设置的字符间距,单位为\"点\"(1/72英寸).">
    参数 欲输出文本 <类型 = 文本型 注释 = "提供欲输出文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作.">
    {
        @ @<所属文档>.data ().Page_ShowTextNextLineEx (@<本页面句柄>, @<单词间距>, @<字符间距>, @<欲输出文本>.GetText ())
    }

    方法 结束输出文本 <公开 静态 类型 = 整数 注释 = "结束输出文本. 本方法用作与\"开始输出文本\"方法配合使用."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_EndText (@<本页面句柄>)
    }

    方法 加圆弧 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个圆弧,角度以度为单位,0度表示从所指定的\"圆弧中心\"位置向上垂直."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 圆弧中心横坐标 <类型 = 小数>
    参数 圆弧中心纵坐标 <类型 = 小数>
    参数 圆弧半径 <类型 = 小数 注释 = "指定圆弧的半径值">
    参数 弧线起始角度 <类型 = 小数 注释 = "圆弧开始的角度">
    参数 弧线结束角度 <类型 = 小数 注释 = "圆弧末端的角度,必须大于\"弧线起始角度\"且与其差值小于360度.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Arc (@<本页面句柄>, (HPDF_REAL)@<圆弧中心横坐标>, (HPDF_REAL)@<圆弧中心纵坐标>, (HPDF_REAL)@<圆弧半径>, (HPDF_REAL)@<弧线起始角度>, (HPDF_REAL)@<弧线结束角度>)
    }

    方法 加圆 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个圆."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 圆中心横坐标 <类型 = 小数>
    参数 圆中心纵坐标 <类型 = 小数>
    参数 圆半径 <类型 = 小数 注释 = "指定圆的半径值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Circle (@<本页面句柄>, (HPDF_REAL)@<圆中心横坐标>, (HPDF_REAL)@<圆中心纵坐标>, (HPDF_REAL)@<圆半径>)
    }

    方法 加曲线 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个贝塞尔曲线,然后将当前点设置为 (x3, y3)." 注释 = "参数 (x1, y1), (x2, y2), (x3, y3) 为贝塞尔曲线的 3 个控制点坐标."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 x1 <类型 = 小数>
    参数 y1 <类型 = 小数>
    参数 x2 <类型 = 小数>
    参数 y2 <类型 = 小数>
    参数 x3 <类型 = 小数>
    参数 y3 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_CurveTo (@<本页面句柄>, (HPDF_REAL)@<x1>, (HPDF_REAL)@<y1>, (HPDF_REAL)@<x2>, (HPDF_REAL)@<y2>, (HPDF_REAL)@<x3>, (HPDF_REAL)@<y3>)
    }

    方法 加曲线2 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个贝塞尔曲线,然后将当前点设置为 (x3, y3)."
            注释 = "路径当前点为贝塞尔曲线的第一个控制点,参数 (x2, y2), (x3, y3) 为贝塞尔曲线的后 2 个控制点坐标."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 x2 <类型 = 小数>
    参数 y2 <类型 = 小数>
    参数 x3 <类型 = 小数>
    参数 y3 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_CurveTo2 (@<本页面句柄>, (HPDF_REAL)@<x2>, (HPDF_REAL)@<y2>, (HPDF_REAL)@<x3>, (HPDF_REAL)@<y3>)
    }

    方法 加曲线3 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个贝塞尔曲线,然后将当前点设置为 (x3, y3)." 注释 = "本方法所加入贝塞尔曲线仅使用两个控制点,由参数 (x1, y1), (x3, y3) 提供."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 x1 <类型 = 小数>
    参数 y1 <类型 = 小数>
    参数 x3 <类型 = 小数>
    参数 y3 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_CurveTo3 (@<本页面句柄>, (HPDF_REAL)@<x1>, (HPDF_REAL)@<y1>, (HPDF_REAL)@<x3>, (HPDF_REAL)@<y3>)
    }

    方法 加椭圆 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个椭圆."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 中心点横坐标 <类型 = 小数 注释 = "提供椭圆中心点的横坐标位置">
    参数 中心点纵坐标 <类型 = 小数 注释 = "提供椭圆中心点的纵坐标位置">
    参数 横向半径 <类型 = 小数 注释 = "提供椭圆的横向半径值">
    参数 纵向半径 <类型 = 小数 注释 = "提供椭圆的纵向半径值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Ellipse (@<本页面句柄>, (HPDF_REAL)@<中心点横坐标>, (HPDF_REAL)@<中心点纵坐标>, (HPDF_REAL)@<横向半径>, (HPDF_REAL)@<纵向半径>)
    }

    方法 加矩形 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个矩形."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 左下角横坐标 <类型 = 小数 注释 = "提供矩形左下角的横坐标位置">
    参数 左下角纵坐标 <类型 = 小数 注释 = "提供矩形左下角的纵坐标位置">
    参数 矩形宽度 <类型 = 小数 注释 = "提供矩形的宽度">
    参数 矩形高度 <类型 = 小数 注释 = "提供矩形的高度">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Rectangle (@<本页面句柄>, (HPDF_REAL)@<左下角横坐标>, (HPDF_REAL)@<左下角纵坐标>, (HPDF_REAL)@<矩形宽度>, (HPDF_REAL)@<矩形高度>)
    }

    方法 加矩形2 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个矩形."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值.">
    参数 本页面句柄 <类型 = PDF页面>
    参数 矩形1 <类型 = PDF矩形>
    {
        返回 (本页面句柄.加矩形 (矩形1.左边, 矩形1.底边, 矩形1.宽度, 矩形1.高度))
    }

    方法 加直线 <公开 静态 类型 = 整数 注释 = "在当前路径上添加一个线条,线条从路径当前点到所指定目标位置,然后将当前点移动到该目标位置."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 目标位置横坐标 <类型 = 小数>
    参数 目标位置纵坐标 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_LineTo (@<本页面句柄>, (HPDF_REAL)@<目标位置横坐标>, (HPDF_REAL)@<目标位置纵坐标>)
    }

    方法 加路径闭合线 <公开 静态 类型 = 整数 注释 = "闭合当前路径(从当前点到路径的起点添加一条直线,当前点移动到路径的起点)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式不改变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_ClosePath (@<本页面句柄>)
    }

    方法 置路径位置 <公开 静态 类型 = 整数 注释 = "开始一个新的子路径,将指定坐标位置设置为该新建路径的当前点位置."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.路径\"状态."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 横坐标 <类型 = 小数 注释 = "提供新建路径的当前点的横坐标位置">
    参数 纵坐标 <类型 = 小数 注释 = "提供新建路径的当前点的纵坐标位置">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_MoveTo (@<本页面句柄>, (HPDF_REAL)@<横坐标>, (HPDF_REAL)@<纵坐标>)
    }

    方法 取路径位置 <公开 静态 类型 = PDF位置 注释 = "获取路径绘制时的当前点位置." 注释 = "注意: 仅当现行图形操作模式包含\"PDF图形模式.路径\"(使用\"位与\"操作符检测)时,应用程序才能调用本方法."
            返回值注释 = "成功返回页面路径绘制的当前位置,否则返回(0,0)位置." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetCurrentPos (@<本页面句柄>)
    }

    方法 闭合路径并描边 <公开 静态 类型 = 整数 注释 = "闭合当前路径(从当前点到路径的起点添加一条直线,当前点移动到路径的起点),然后立即描边绘制该路径."
            注释 = "相比\"闭合路径\"方法,本方法增加了一个路径闭合后立即描边绘制的操作,并且方法执行后图形模式不同."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_ClosePathStroke (@<本页面句柄>)
    }

    方法 闭合路径并奇偶填充描边 <公开 静态 类型 = 整数 注释 = "  闭合当前路径(从当前点到路径的起点添加一条直线,当前点移动到路径的起点),然后使用\"奇偶规则\"填充当前路径,然后描边绘制路径."
            注释 = "  相比\"闭合路径\"方法,本方法增加了一个路径闭合后立即描边绘制的操作,并且方法执行后图形模式不同."
            注释 = "  偶数-奇数规则是一种决定哪些区域应该被填充的方法. 在这种规则下,从任意一点向无穷远处画一条射线,并计算这条射线与路径相交的次数,"
            注释 = "如果交点的数量是奇数,则该点在路径内部,因此会被填充;如果是偶数,则该点在路径外部,不会被填充.这种填充方法对于自相交路径特别有用," 注释 = "因为它可以更准确地判断哪些区域属于\"内部\"."
            注释 = "  本方法适用于需要同时填充和描边的情况,特别是当路径自身相交且你希望使用偶数-奇数规则来确定哪些区域应被填充时. 例如,在创建复杂" 注释 = "的图形、图标或者具有特殊形状的图案时,这个方法非常有用."
            注释 = "  在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_ClosePathEofillStroke (@<本页面句柄>)
    }

    方法 闭合路径并填充描边 <公开 静态 类型 = 整数 注释 = "  闭合当前路径(从当前点到路径的起点添加一条直线,当前点移动到路径的起点),然后使用\"非零缠绕数规则\"填充当前路径,然后描边绘制路径."
            注释 = "  相比\"闭合路径\"方法,本方法增加了一个路径闭合后立即描边绘制的操作,并且方法执行后图形模式不同."
            注释 = "  非零缠绕数规则是默认的填充规则,它通过计算路径方向和环绕次数来确定哪些区域应该被填充. 如果一个点被路径环绕的总次数不为零," 注释 = "则认为该点在路径内,并会被填充颜色."
            注释 = "  本方法适用于需要同时填充和描边的情况,特别适合那些你希望既能看到图形的轮廓又能区分出其覆盖区域的情形. 例如,在创建图表、图形" 注释 = "设计或者制作带有特定形状和样式的报告时非常有用."
            注释 = "  在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_ClosePathFillStroke (@<本页面句柄>)
    }

    方法 结束路径 <公开 静态 类型 = 整数 注释 = "结束路径对象而不进行填充或绘制."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_EndPath (@<本页面句柄>)
    }

    方法 画图像 <公开 静态 类型 = 整数 注释 = "在页面中绘制所指定的图像." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式不改变."
            注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲绘制图像 <类型 = PDF图像 注释 = "提供欲绘制图像的对象句柄">
    参数 左下角横坐标 <类型 = 小数 注释 = "提供图像左边的绘制横坐标位置">
    参数 左下角纵坐标 <类型 = 小数 注释 = "提供图像底边的绘制纵坐标位置">
    参数 绘制宽度 <类型 = 小数 注释 = "提供欲将图像绘制到区域的宽度,如果为0则使用图像本身的宽度." @默认值 = 0>
    参数 绘制高度 <类型 = 小数 注释 = "提供欲将图像绘制到区域的高度,如果为0则使用图像本身的高度." @默认值 = 0>
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_DrawImage (@<本页面句柄>, @<欲绘制图像>, (HPDF_REAL)@<左下角横坐标>, (HPDF_REAL)@<左下角纵坐标>, (IsDoubleEqualZero (@<绘制宽度>) ? (HPDF_REAL)HPDF_Image_GetWidth (@<欲绘制图像>) : (HPDF_REAL)@<绘制宽度>), (IsDoubleEqualZero (@<绘制高度>) ? (HPDF_REAL)HPDF_Image_GetHeight (@<欲绘制图像>) : (HPDF_REAL)@<绘制高度>));
    }

    方法 置裁剪路径 <公开 静态 类型 = 整数 注释 = "根据当前路径(由前面的所有路径操作来构造)设置为当前页面的裁剪路径,并使用\"非零环绕规则\"来确定路径内部的区域."
            注释 = "所设置裁剪区域是图形状态的一部分,可以通过\"压入图形状态\"和\"弹出图形状态\"方法来保存和恢复."
            注释 = "一旦设置了裁剪路径,后续所有的绘图操作(如填充、描边、绘制图像等)都只能在该区域内显示,区域外的内容将被\"裁剪\"掉不可见."
            注释 = "关于\"裁剪路径\"的进一步说明、\"非零环绕规则\"与\"奇偶规则\"的对比,请参见\"置奇偶裁剪路径\"方法." 注释 = "使用步骤:"
            注释 = "1. 构造路径: 使用绘图方法(如\"画圆弧\"、\"画圆\"、\"画矩形\"等)定义一个形状;" 注释 = "2. 设置裁剪: 调用本方法将当前路径转换为裁剪路径;"
            注释 = "3. 执行绘图: 在此之后的所有绘图操作都将被限制在裁剪区域内." 注释 = "4. (可选)恢复状态: 调用\"弹出图形状态\"方法恢复之前的图形状态(包括裁剪路径)." 注释 = "关键注意事项:"
            注释 = "1. 必须先构造路径: 在调用本方法之前,必须已经使用绘图方法创建了一个有效的路径,否则会出错;"
            注释 = "2. 路径方向影响裁剪区域: 对于简单形状(如矩形、圆形),方向通常不重要. 对于复杂或自交路径,路径的缠绕方向会影响裁剪区域的判定,默认使用\"非零缠绕规则\";"
            注释 = "3. 裁剪路径是累积的: 你可以在一个已有的裁剪路径基础上再次设置裁剪,新的裁剪区域将是新旧裁剪区域的交集;"
            注释 = "4. 裁剪状态会持续存在,直到被新的裁剪区域覆盖或通过\"弹出图形状态\"方法恢复. 强烈建议在使用裁剪前调用\"压入图形状态\",使用完后调用\"弹出图形状态\"方法,以避免影响后续绘图."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.裁剪路径\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Clip (@<本页面句柄>)
    }

    方法 置奇偶裁剪路径 <公开 静态 类型 = 整数 注释 = "根据当前路径(由前面的所有路径操作来构造)设置为当前页面的裁剪路径,并使用\"奇偶规则\"来确定路径内部的区域,"
            注释 = "相对\"非零环绕规则\"规则,\"奇偶规则\"在处理复杂、嵌套或自相交的路径时,能提供更直观的裁剪结果." 注释 = "1. \"裁剪路径\":"
            注释 = "  在PDF中,裁剪路径定义了一个区域,在这个区域之外的内容将被隐藏、不可见."
            注释 = "  你可以把它想象成一张纸,你在这张纸上剪出了一个特殊的形状(比如一颗星星). 之后,你只能透过这个星星的形状看到下一层的内容,纸张的其他部分会遮住一切."
            注释 = "  在代码中，你通常先使用像\"加矩形\"或\"加椭圆\"这样的函数来定义一条路径,然后使用\"置裁剪路径\"或\"置奇偶裁剪路径\"来将这条路径设置为裁剪路径." 注释 = "2. \"非零环绕规则\"对比\"奇偶规则\":"
            注释 = "  这是确定一个点是否在复杂路径\"内部\"的两种算法. \"置裁剪路径\"使用默认的非零环绕规则,而\"置奇偶裁剪路径\"方法使用奇偶规则."
            注释 = "  它们的区别可以通过一个经典的例子来说明: 同心圆环(像一个字母\"O\")."
            注释 = "  使用\"置裁剪路径\"方法(非零环绕规则)时: 这个规则会考虑路径绘制的方向(顺时针或逆时针). 对于同心圆环,如果你用相同的方向绘制内外两个圆,整个环状区域会被认为是\"内部\".但"
            注释 = "如果你用相反的方向绘制,则只有两个圆之间的环状区域是\"内部\",内圆内部区域反而会被认为是\"外部\". 结果取决于路径的方向,有时不够直观."
            注释 = "  使用\"置奇偶裁剪路径\"方法(奇偶规则): 这个规则非常简单: 从该点向任意方向发出一条射线,计算射线与路径相交的次数. 如果相交次数是奇数,则该点在内部. 如果相交次数是偶数,"
            注释 = "则该点在外部. 对于同心圆环,无论你怎么画这两个圆,从环内一点发出一条射线,它会穿过路径两次(一次外圆,一次内圆),是偶数,所以是外部. 而从内圆内部一点发出的射线,只会穿过内"
            注释 = "圆一次,是奇数,所以是内部. 结果非常直观且不依赖于路径方向." 注释 = "简单总结: 如果你需要处理复杂、自相交或嵌套的路径,并且希望所有嵌套区域交替地被视为内部和外部,就应该使用\"置奇偶裁剪路径\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.裁剪路径\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Eoclip (@<本页面句柄>)
    }

    方法 奇偶填充路径 <公开 静态 类型 = 整数 注释 = "使用\"奇偶规则\"填充当前路径." 注释 = "关于\"非零环绕规则\"和\"奇偶规则\"的对比描述,请参见\"置奇偶裁剪路径\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Eofill (@<本页面句柄>)
    }

    方法 奇偶填充描边路径 <公开 静态 类型 = 整数 注释 = "使用\"奇偶规则\"填充当前路径,然后描边绘制路径." 注释 = "关于\"非零环绕规则\"和\"奇偶规则\"的对比描述,请参见\"置奇偶裁剪路径\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_EofillStroke (@<本页面句柄>)
    }

    方法 填充路径 <公开 静态 类型 = 整数 注释 = "使用\"非零环绕规则\"填充当前路径." 注释 = "关于\"非零环绕规则\"和\"奇偶规则\"的对比描述,请参见\"置奇偶裁剪路径\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Fill (@<本页面句柄>)
    }

    方法 填充描边路径 <公开 静态 类型 = 整数 注释 = "使用\"非零环绕规则\"填充当前路径,然后描边绘制路径." 注释 = "关于\"非零环绕规则\"和\"奇偶规则\"的对比描述,请参见\"置奇偶裁剪路径\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_FillStroke (@<本页面句柄>)
    }

    方法 描边路径 <公开 静态 类型 = 整数 注释 = "描边绘制当前路径,本方法不会填充路径."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.路径\"或\"PDF图形模式.裁剪路径\"状态,调用本方法后图形模式将切换到\"PDF图形模式.页面\"状态."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Stroke (@<本页面句柄>)
    }

    方法 置扩展图形状态 <公开 静态 类型 = 整数 注释 = "本方法用于将一个扩展图形状态应用到当前的 PDF 页面上,是实现高级视觉效果(如透明度和混合模式)的关键步骤." 注释 = "要使用本方法实现透明或混合效果,需要遵循以下标准流程:"
            注释 = "1. 创建扩展图形状态对象: 调用\"PDF文档.创建扩展图形状态\"方法创建;" 注释 = "2. 配置扩展图形状态: 调用\"PDF扩展图形状态\"类中的方法进行配置;"
            注释 = "3. 应用扩展图形状态到页面: 调用本方法应用到页面,一旦应用,后续所有绘图命令都将使用此扩展图形状态中定义的属性;"
            注释 = "4. 可以在应用扩展图形状态前后调用\"压入图形状态\"和\"弹出图形状态\"方法进行图形状态的保存和恢复." 注释 = "注意:"
            注释 = "1. 透明度和混合模式是 PDF 1.4 及更高版本的功能,如欲使用本方法,请确保你的 PDF 阅读器支持这些特性才能正确显示效果."
            注释 = "2. 在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式不变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置状态 <类型 = PDF扩展图形状态 注释 = "  提供一个已配置好的扩展图形状态对象的句柄,这个对象必须先通过\"PDF文档.创建扩展图形状态\"方法创建,并调用"
            注释 = "\"PDF扩展图形状态\"类中的方法进行了配置. 具体请参见\"PDF扩展图形状态\"类." 注释 = "  注意: 一旦调用本方法进行了设置,本参数提供的扩展图形状态对象将被切换到只读状态,不能再修改.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetExtGState (@<本页面句柄>, @<欲设置状态>)
    }

    方法 执行外部对象 <公开 静态 类型 = 整数 注释 = "本方法将一个预先创建好的外部对象(通常是图像或表单)根据当前的图形状态(如坐标系、缩放、旋转等)绘制到页面的当前位置." 注释 = "通常使用步骤:"
            注释 = "1. 创建或加载外部对象:"
            注释 = "  对于图像: 使用\"PDF文档.载入PNG图像\", \"PDF文档.载入JPEG图像\"等加载图像,返回图像句柄,然后调用其\"到外部对象\"方法或强转数据类型获得对应外部对象句柄;"
            注释 = "  对于表单: 使用\"创建表单外部对象\"方法创建一个表单外部对象,然后在其内部绘制内容."
            注释 = "2. (可选)设置坐标系: 使用\"压入图形状态\"方法保存当前状态,然后调用\"连接矩阵\"、\"置偏移\"、\"置缩放\"等方法调整坐标系,以控制外部对象的绘制位置、缩放、旋转等."
            注释 = "3. 执行外部对象: 调用本方法并提供你创建或加载的外部对象;" 注释 = "4. (可选)恢复坐标系: 调用\"弹出图形状态\"方法,恢复到步骤 2 之前的图形状态."
            注释 = "关于\"PDF外部对象\"的描述,请参见\"PDF外部对象\"类." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 外部对象 <类型 = PDF外部对象 注释 = "提供欲执行的外部对象句柄值">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_ExecuteXObject (@<本页面句柄>, @<外部对象>)
    }

    #
}
