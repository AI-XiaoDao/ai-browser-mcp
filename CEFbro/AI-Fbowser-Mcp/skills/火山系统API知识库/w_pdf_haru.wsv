    常量 右对齐 <公开 值 = @HPDF_TALIGN_RIGHT>
    常量 居中 <公开 值 = @HPDF_TALIGN_CENTER>
    常量 两端对齐 <公开 值 = @HPDF_TALIGN_JUSTIFY 注释 = "两端对齐(最后一行除外,通常为左对齐)">
}

类 PDF幻灯过渡类型 <公开 注释 = "用作提供PDF以全屏幻灯片方式播放时的各种过渡类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 向右擦除 <公开 值 = @HPDF_TS_WIPE_RIGHT 注释 = "从左向右擦除显示">
    常量 向上擦除 <公开 值 = @HPDF_TS_WIPE_UP 注释 = "从下向上擦除显示">
    常量 向左擦除 <公开 值 = @HPDF_TS_WIPE_LEFT 注释 = "从右向左擦除显示">
    常量 向下擦除 <公开 值 = @HPDF_TS_WIPE_DOWN 注释 = "从上向下擦除显示">
    常量 谷仓门水平外切 <公开 值 = @HPDF_TS_BARN_DOORS_HORIZONTAL_OUT 注释 = "以谷仓门样式从中间向左右两边展开">
    常量 谷仓门水平内切 <公开 值 = @HPDF_TS_BARN_DOORS_HORIZONTAL_IN 注释 = "以谷仓门样式从左右两边向中间分开显示">
    常量 谷仓门垂直外切 <公开 值 = @HPDF_TS_BARN_DOORS_VERTICAL_OUT 注释 = "以谷仓门样式从中间向上下两边展开">
    常量 谷仓门垂直内切 <公开 值 = @HPDF_TS_BARN_DOORS_VERTICAL_IN 注释 = "以谷仓门样式从上下两边向中间合拢">
    常量 方盒向外 <公开 值 = @HPDF_TS_BOX_OUT 注释 = "从页面中心向边缘展开">
    常量 方盒向内 <公开 值 = @HPDF_TS_BOX_IN 注释 = "从页面边缘向中心收缩显示">
    常量 水平百叶窗 <公开 值 = @HPDF_TS_BLINDS_HORIZONTAL 注释 = "像百叶窗一样水平条纹依次出现">
    常量 垂直百叶窗 <公开 值 = @HPDF_TS_BLINDS_VERTICAL 注释 = "像百叶窗一样垂直条纹依次出现">
    常量 溶解 <公开 值 = @HPDF_TS_DISSOLVE 注释 = "像素随机出现,类似\"雪花\"溶解效果.">
    常量 向右闪烁 <公开 值 = @HPDF_TS_GLITTER_RIGHT 注释 = "类似\"闪光\"从左向右扫过">
    常量 向下闪烁 <公开 值 = @HPDF_TS_GLITTER_DOWN 注释 = "类似\"闪光\"从上向下扫过">
    常量 向右下闪烁 <公开 值 = @HPDF_TS_GLITTER_TOP_LEFT_TO_BOTTOM_RIGHT 注释 = "类似\"闪光\"从左上方向右下方扫过">
    常量 直接切换 <公开 值 = @HPDF_TS_REPLACE 注释 = "无动画,直接切换页面(默认).">
    常量 无 <公开 值 = @HPDF_TS_EOF>
}

类 PDF颜色空间 <公开 注释 = "用作提供各种PDF图形颜色空间模式" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 设备灰度 <公开 值 = @HPDF_CS_DEVICE_GRAY 注释 = "设备灰度颜色空间。使用一个值（0.0到1.0）表示从黑到白的灰度。">
    常量 设备RGB <公开 值 = @HPDF_CS_DEVICE_RGB 注释 = "设备RGB颜色空间。使用三个值（红、绿、蓝），每个在0.0到1.0之间，组合成各种颜色。">
    常量 设备CMYK <公开 值 = @HPDF_CS_DEVICE_CMYK 注释 = "设备CMYK颜色空间。使用四个值（青、品红、黄、黑），每个在0.0到1.0之间，主要用于打印。">
    常量 校准灰度 <公开 值 = @HPDF_CS_CAL_GRAY 注释 = "校准灰度颜色空间。允许更精确地定义灰度，考虑设备特性。">
    常量 校准RGB <公开 值 = @HPDF_CS_CAL_RGB 注释 = "校准RGB颜色空间。提供比设备RGB更精确的颜色控制。">
    常量 LAB <公开 值 = @HPDF_CS_LAB 注释 = "CIE Lab颜色空间。一种与设备无关的颜色空间，旨在匹配人眼感知。">
    常量 ICC <公开 值 = @HPDF_CS_ICC_BASED 注释 = "基于ICC配置文件的颜色空间。允许嵌入ICC配置文件以实现跨设备一致的颜色再现。">
    常量 索引 <公开 值 = @HPDF_CS_SEPARATION 注释 = "索引颜色空间。使用一个索引值来查找调色板中的实际颜色，常用于减少颜色数量以压缩图像。">
    常量 图案 <公开 值 = @HPDF_CS_DEVICE_N 注释 = "图案颜色空间。允许使用重复的图案（如线条、网格）作为填充或描边颜色。">
    常量 分色 <公开 值 = @HPDF_CS_INDEXED 注释 = "分色颜色空间。用于专色（Spot Color），如Pantone色。">
    常量 多通道 <公开 值 = @HPDF_CS_PATTERN 注释 = "多通道设备颜色空间。用于具有多于四个颜色通道的设备。">
    常量 无 <公开 值 = @HPDF_CS_EOF>
}

类 PDF颜色混合模式 <公开 注释 = "  用于定义 PDF 文档中图形对象绘制时所使用的颜色混合模式." 注释 = "  混合模式决定了新绘制的图形(源)如何与它下面已经存在的内容(目标,通常是背景或其他图形)进行颜色混合,"
        注释 = "通过选择不同的混合模式,可以创建出从简单的透明效果到复杂的光影、着色等丰富的视觉效果." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 通常 <公开 值 = @HPDF_BM_NORMAL 注释 = "这是默认和最常用的模式。新绘制的内容完全覆盖其下的内容（除非设置了透明度）。">
    常量 正片叠底 <公开 值 = @HPDF_BM_MULTIPLY 注释 = "将源颜色和目标颜色相乘。通常会产生变暗的效果。任何颜色与黑色相乘得到黑色，与白色相乘则保持不变。常用于阴影效果。">
    常量 滤色 <公开 值 = @HPDF_BM_SCREEN 注释 = "将源颜色和目标颜色的补色相乘，然后取结果的补色。通常会产生变亮的效果。任何颜色与白色相乘得到白色，与黑色相乘则保持不变。常用于高光效果。">
    常量 叠加 <公开 值 = @HPDF_BM_OVERLAY
            注释 = "结合了\"正片叠底\"和\"滤色\"模式的特性。如果目标颜色较亮，则类似\"滤色\"模式使其更亮；如果目标颜色较暗，则类似\"正片叠底\"模式使其更暗。它保留了目标颜色的高光和阴影。">
    常量 变暗 <公开 值 = @HPDF_BM_DARKEN 注释 = "比较源和目标的颜色值，对于每个颜色分量，选择较暗的一个。">
    常量 变亮 <公开 值 = @HPDF_BM_LIGHTEN 注释 = "比较源和目标的颜色值，对于每个颜色分量，选择较亮的一个。">
    常量 颜色减淡 <公开 值 = @HPDF_BM_COLOR_DODGE 注释 = "通过降低对比度来照亮目标颜色，以反映源颜色。效果通常很亮。">
    常量 颜色加深 <公开 值 = @HPDF_BM_COLOR_BUM 注释 = "通过增加对比度来加深目标颜色，以反映源颜色。效果通常很暗。">
    常量 强光 <公开 值 = @HPDF_BM_HARD_LIGHT 注释 = "类似\"叠加\"模式，但源和目标的角色互换。根据源颜色的亮度来决定是使用\"正片叠底\"还是\"滤色\"模式的效果。">
    常量 柔光 <公开 值 = @HPDF_BM_SOFT_LIGHT 注释 = "与\"叠加\"模式类似，但效果更柔和。产生一种漫射光源照射在图像上的感觉。">
    常量 差值 <公开 值 = @HPDF_BM_DIFFERENCE 注释 = "从较亮的颜色中减去较暗的颜色。当颜色相同时结果为黑色，颜色越不同结果越亮。常用于对齐图像或创建特殊效果。">
    常量 排除 <公开 值 = @HPDF_BM_EXCLUSHON 注释 = "类似于\"差值\"模式，但对比度较低，产生的白色区域较少。也是一种创建特殊效果的模式。">
}

类 PDF扩展图形状态 <公开 注释 = "本类对象代表一个PDF文档中的图形扩展对象句柄值." 注释 = "注意: 有效本类对象只能由\"PDF文档.创建扩展图形状态\"方法创建返回." @文档 = "category = \"辅助类\""
        @别名 = "HPDF_ExtGState" @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 置描边透明度 <公开 静态 类型 = 整数 注释 = "设置PDF文档中描边操作的透明度." 注释 = "透明度是图像合成中的一个重要概念,它决定了图形对象在绘制时相对于其下方内容的透明程度."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本扩展状态 <类型 = PDF扩展图形状态>
    参数 欲设置的透明度 <类型 = 小数 注释 = "提供描边透明度的值,有效值范围为从0到1之间的小数值,0表示完全透明,1表示完全不透明.">
    {
        @ (VOL_HPDF_STATUS)HPDF_ExtGState_SetAlphaStroke (@<本扩展状态>, (HPDF_REAL)@<欲设置的透明度>)
    }

    方法 置填充透明度 <公开 静态 类型 = 整数 注释 = "设置PDF文档中填充操作的透明度." 注释 = "透明度是图像合成中的一个重要概念,它决定了图形对象在绘制时相对于其下方内容的透明程度."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本扩展状态 <类型 = PDF扩展图形状态>
    参数 欲设置的透明度 <类型 = 小数 注释 = "提供填充透明度的值,有效值范围为从0到1之间的小数值,0表示完全透明,1表示完全不透明.">
    {
        @ (VOL_HPDF_STATUS)HPDF_ExtGState_SetAlphaFill (@<本扩展状态>, (HPDF_REAL)@<欲设置的透明度>)
    }

    方法 置颜色混合模式 <公开 静态 类型 = 整数 注释 = "用于设置扩展图形状态对象的混合模式,从而允许你控制新绘制的图形如何与 PDF 页面上已有的内容进行混合,以实现丰富的视觉效果(如叠加、变暗、变亮等)."
            注释 = "具体请参见\"PDF颜色混合模式\"类处的说明" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本扩展状态 <类型 = PDF扩展图形状态>
    参数 欲设置的混合模式 <类型 = PDF颜色混合模式>
    {
        @ (VOL_HPDF_STATUS)HPDF_ExtGState_SetBlendMode (@<本扩展状态>, @<欲设置的混合模式>)
    }
}

类 PDF字典 <公开 注释 = "本类对象代表一个PDF文档中的字典对象句柄值." 注释 = "注意: 有效本类对象只能由\"PDF文档.新建并切换内容流\"方法创建返回." @文档 = "category = \"辅助类\""
        @别名 = "HPDF_Dict" @别名类型 = 本地整数基本类型 @有效值范围 = "0">

类 PDF注解高亮模式 <公开 注释 = "提供鼠标单击PDF文档中链接型注解时的外观" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = @HPDF_ANNOT_NO_HIGHTLIGHT 注释 = "鼠标悬停或点击时，不进行任何视觉变化。">
    常量 反转框 <公开 值 = @HPDF_ANNOT_INVERT_BOX 注释 = "鼠标悬停时，链接的边界框颜色会被反转（黑变白，白变黑等）。这是默认和最常见的模式。">
    常量 反转边框 <公开 值 = @HPDF_ANNOT_INVERT_BORDER 注释 = "鼠标悬停时，只反转链接的边框颜色，填充区域不变。">
    常量 凹陷 <公开 值 = @HPDF_ANNOT_DOWN_APPEARANCE 注释 = "当用户点击（按下）链接时，显示一个预定义的“按下状态”的外观（通常是一个下凹效果）。这需要提前设置好不同的外观流，实现更复杂的视觉效果。">
}

类 PDF注解图标样式 <公开 注释 = "提供PDF文本型注解中的各种图标样式" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 评论 <公开 值 = @HPDF_ANNOT_ICON_COMMENT 注释 = "最通用的图标,通常是一个对话气泡.">
    常量 关键字 <公开 值 = @HPDF_ANNOT_ICON_KEY 注释 = "表示强调关键词,通常是一个钥匙图标.">
    常量 笔记 <公开 值 = @HPDF_ANNOT_ICON_NOTE 注释 = "表示一个普通的笔记,通常是一个便签图标.">
    常量 帮助 <公开 值 = @HPDF_ANNOT_ICON_HELP 注释 = "表示提示或帮助信息,通常是一个问号 (?).">
    常量 新段落 <公开 值 = @HPDF_ANNOT_ICON_NEW_PARAGRAPH 注释 = "表示建议添加新段落,通常是一个带箭头的段落符号.">
    常量 段落 <公开 值 = @HPDF_ANNOT_ICON_PARAGRAPH 注释 = "表示与段落相关的注解,通常是一个段落符号 (¶).">
    常量 插入 <公开 值 = @HPDF_ANNOT_ICON_INSERT 注释 = "表示建议插入内容,通常是一个带加号的竖线 (†) 或类似符号.">
}

类 PDF注解边框样式 <公开 注释 = "提供PDF注解的各种边框样式" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 实线 <公开 值 = @HPDF_BS_SOLID>
    常量 虚线 <公开 值 = @HPDF_BS_DASHED>
    常量 斜面 <公开 值 = @HPDF_BS_BEVELED>
    常量 内嵌 <公开 值 = @HPDF_BS_INSET>
    常量 下划线 <公开 值 = @HPDF_BS_UNDERLINED>
}

类 PDF注解 <公开 注释 = "本类对象代表一个PDF文档中的注解对象句柄值." 注释 = "注意: 有效本类对象只能由\"PDF页面.创建文本注解\",\"PDF页面.创建链接注解\",\"PDF页面.创建网址链接注解\"方法创建返回."
        @文档 = "category = \"辅助类\"" @别名 = "HPDF_Annotation" @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 置边框样式 <公开 静态 类型 = 整数 注释 = "定义注解边框的样式."
            注释 = "本方法与\"置链接注解边框样式\"方法类似,但作用范围更广,可以应用于多种支持边框的注解类型(如链接、文本、图章等),提供了一种统一的方式来控制注解边框的外观."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本注解对象 <类型 = PDF注解>
    参数 欲设置边框样式 <类型 = PDF注解边框样式>
    参数 线宽 <类型 = 小数 注释 = "提供边框线的宽度,单位为\"点\"(1/72英寸),设置为0可使边框不可见.">
    参数 实线长度 <类型 = 整数 注释 = "当\"欲设置边框样式\"参数为\"PDF注解边框样式.虚线\"时,指定虚线中实线段的长度,单位为\"点\"(1/72英寸)." @默认值 = 0>
    参数 虚线长度 <类型 = 整数 注释 = "当\"欲设置边框样式\"参数为\"PDF注解边框样式.虚线\"时,指定虚线中空白段的长度,单位为\"点\"(1/72英寸)." @默认值 = 0>
    参数 虚线起始偏移 <类型 = 整数 注释 = "当\"欲设置边框样式\"参数为\"PDF注解边框样式.虚线\"时,指定虚线的起始偏移量,单位为\"点\"(1/72英寸),通常设为0,表示从\"实线段\"首部开始." @默认值 = 0>
    {
        @ (VOL_HPDF_STATUS)HPDF_Annotation_SetBorderStyle (@<本注解对象>, (HPDF_BSSubtype)@<欲设置边框样式>, (HPDF_REAL)@<线宽>, (HPDF_UINT16)@<实线长度>, (HPDF_UINT16)@<虚线长度>, (HPDF_UINT16)@<虚线起始偏移>)
    }

    方法 置链接注解高亮模式 <公开 静态 类型 = 整数 注释 = "  当你在 PDF 中创建一个可点击的链接(例如: 链接到网页、文档内的某个位置或其他文件)时,"
            注释 = "你可能希望控制当用户将鼠标悬停在该链接上或点击它时,其周围的矩形区域如何被\"高亮\"或" 注释 = "\"突出显示\",本方法就是用来定义这种视觉反馈行为的." 注释 = "使用场景:"
            注释 = "1. 自定义链接交互体验: 你可以选择是否启用高亮,以及使用哪种高亮方式来匹配你的 PDF 文档的整体设计风格;"
            注释 = "2. 可访问性与用户体验: 启用高亮(尤其是\"反转框\")可以帮助用户更容易地识别哪些文本是可点击的链接;" 注释 = "3. 专业文档设计: 在制作电子书、报告或交互式表单时,精细控制链接的视觉反馈可以提升专业感."
            注释 = "注意: 请确保本注解对象确实是链接型注解(由\"PDF页面.创建链接注解\"或\"PDF页面.创建网址链接注解\"方法创建),否则调用会失败."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本注解对象 <类型 = PDF注解>
    参数 欲设置模式 <类型 = PDF注解高亮模式>
    {
        @ (VOL_HPDF_STATUS)HPDF_LinkAnnot_SetHighlightMode (@<本注解对象>, (HPDF_AnnotHighlightMode)@<欲设置模式>)
    }

    方法 置链接注解边框样式 <公开 静态 类型 = 整数 注释 = "定义链接型注注解边框的样式."
            注释 = "注意: 请确保本注解对象确实是链接型注解(由\"PDF页面.创建链接注解\"或\"PDF页面.创建网址链接注解\"方法创建),否则调用会失败."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本注解对象 <类型 = PDF注解>
    参数 线宽 <类型 = 小数 注释 = "提供边框线的宽度,单位为\"点\"(1/72英寸),设置为0可使边框不可见.">
    参数 实线长度 <类型 = 整数 注释 = "虚线模式中实线段的长度,单位为\"点\"(1/72英寸). 只有当本参数和\"虚线长度\"参数值均不为0时,这两个参数才有意义,用作指定边框线采用虚线(破折线)." @默认值 = 0>
    参数 虚线长度 <类型 = 整数 注释 = "虚线模式中空白段的长度,单位为\"点\"(1/72英寸)." @默认值 = 0>
    {
        @ (VOL_HPDF_STATUS)HPDF_LinkAnnot_SetBorderStyle (@<本注解对象>, (HPDF_REAL)@<线宽>, (HPDF_UINT16)@<实线长度>, (HPDF_UINT16)@<虚线长度>)
    }

    方法 置文本注解图标 <公开 静态 类型 = 整数 注释 = "定义文本注解的图标样式." 注释 = "当你在 PDF 中创建一个\"便签\"或\"注解气泡\"(即文本注解)时,这个注解在页面上通常会以一个带有图标的标签形式显示."
            注释 = "当用户点击该图标时,才会弹出完整的注解文本内容." 注释 = "本方法允许你指定这个标签上显示的图标样式,不同的图标可以传达注解的类型或语气(如注解、帮助、警告等)." 注释 = "使用场景:"
            注释 = "1. 语义化注解: 使用\"帮助\"图标表示使用说明,使用\"评论\"图标表示重要提醒,使用\"关键字\"图标突出显示关键词;" 注释 = "2. 提升可读性: 通过不同图标快速区分文档中各种类型的注解;"
            注释 = "3. 自动化文档生成: 在生成报告或技术文档时,根据内容自动选择合适的图标." 注释 = "注意: 本注解对象必须是文本类型(由\"PDF页面.创建文本注解\"方法创建,如果传入非文本注解,方法会返回错误."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本注解对象 <类型 = PDF注解>
    参数 欲设置图标样式 <类型 = PDF注解图标样式 注释 = "提供所欲设置的图标样式">
    {
        @ (VOL_HPDF_STATUS)HPDF_TextAnnot_SetIcon (@<本注解对象>, (HPDF_AnnotIcon)@<欲设置图标样式>)
    }

    方法 置文本注解打开状态 <公开 静态 类型 = 整数 注释 = "  当你在 PDF 中创建一个文本注解(通常显示为一个小图标,如便签 💬),点击该图标才会弹出完整的注解内容窗口,"
            注释 = "本方法允许你控制这个内容窗口是默认打开(可见)还是关闭(隐藏),从而赋予了你对文本注解用户体验的精细控制能"
            注释 = "力. 通过将重要的注解设置为默认打开,你可以确保关键信息不被忽略; 而对于辅助性内容,则保持默认关闭以维持页" 注释 = "面整洁. 它是创建专业、易用 PDF 文档的重要方法之一." 注释 = "使用场景:"
            注释 = "1. 强调重要信息: 对于非常关键的说明、警告或使用指南,可以将其设为默认打开,确保用户第一眼就能看到." 注释 = "2. 教程或引导文档: 在交互式教程中,可以按步骤将注解设为\"打开\",引导用户逐步阅读;"
            注释 = "3. 避免页面杂乱: 对于大量辅助性注解,设置为假可以让页面更整洁,用户按需点击查看;" 注释 = "4. 动态内容展示: 结合其他逻辑,决定哪些注解需要立即引起注意."
            注释 = "注意: 本注解对象必须是文本类型(由\"PDF页面.创建文本注解\"方法创建,如果传入非文本注解,方法会返回错误." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本注解对象 <类型 = PDF注解>
    参数 是否打开 <类型 = 逻辑型 注释 = "如果设置为真,当用户打开 PDF 或翻到该页面时,注解的文本内容窗口会自动弹出显示." 注释 = "如果设置为假,注解仅显示为一个图标,用户需要手动点击才能查看内容(这是大多数情况下的默认行为).">
    {
        @ (VOL_HPDF_STATUS)HPDF_TextAnnot_SetOpened (@<本注解对象>, (@<是否打开> ? HPDF_TRUE : HPDF_FALSE))
    }
}

类 PDF页面适配模式 <公开 注释 = "  提供\"PDF目标\"跳转到目的页面后该页面的外观适配模式,也就是当用户点击\"PDF目标\"关联的书签或链接时," 注释 = "PDF阅读器对页面进行的缩放和位置调整操作."
        @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 整体适配 <公开 值 = @VHPDFM_FIT 注释 = "缩放页面,使得整个页面(包括所有边距)恰好适应当前视口(窗口或阅读区域)的大小." 注释 = "不指定精确的对齐点,整个页面内容会居中或适配显示."
            注释 = "这相当于点击阅读器中的\"适合页面\"或\"100% 视图\"按钮,确保用户能看到页面的完整布局,而无需水平或垂直滚动.">
    常量 整体适配2 <公开 值 = @VHPDFM_FIT_B 注释 = "缩放页面,使得页面的整个边界框恰好适应当前视口(窗口或阅读区域)的大小." 注释 = "不指定精确的对齐点,整个页面内容会居中或适配显示."
            注释 = "这与\"适配整体\"模式非常相似,但关键区别在于它使用页面的边界框而不是媒体框(页面物理尺寸)进行适配.">
    常量 宽度适配 <公开 值 = @VHPDFM_FIT_H 注释 = "水平缩放: 将页面水平缩放,使得页面的整个宽度恰好适应当前视口(窗口或阅读区域)的宽度." 注释 = "垂直定位: 将页面上指定的\"顶边\"坐标对齐到视口的顶部边缘."
            注释 = "这使得用户在跳转后,可以完整地看到页面从左到右的全部内容,并且页面的特定部分(如章节标题)正好位于视野最上方.">
    常量 宽度适配2 <公开 值 = @VHPDFM_FIT_BH 注释 = "水平缩放: 将页面水平缩放,使得页面的整个宽度恰好适应当前视口(窗口或阅读区域)的宽度." 注释 = "垂直定位: 将页面上指定的\"顶边\"坐标对齐到视口的顶部边缘."
            注释 = "这与\"适配宽度\"模式非常相似,但关键区别在于它使用页面的边界框而不是媒体框(页面物理尺寸)进行适配."
            注释 = "这个目标类型特别适用于长文档,让用户在跳转到某个章节时,既能看清该章节的全貌(适合宽度),又能确保标题或关键内容位于页面顶部.">
    常量 高度适配 <公开 值 = @VHPDFM_FIT_V 注释 = "垂直缩放: 将页面垂直缩放,使得页面的整个高度恰好适应当前视口(窗口或阅读区域)的高度." 注释 = "水平定位: 将页面上指定的\"左边\"坐标对齐到视口的左边缘."
            注释 = "这使得用户在跳转后,可以完整地看到页面从上到下的全部内容,并且页面的特定列或起始位置正好位于视野最左边.">
    常量 高度适配2 <公开 值 = @VHPDFM_FIT_BV 注释 = "垂直缩放: 将页面垂直缩放,使得页面的整个高度恰好适应当前视口(窗口或阅读区域)的高度." 注释 = "水平定位: 将页面上指定的\"左边\"坐标对齐到视口的左边缘."
            注释 = "这与\"适配高度\"模式非常相似,但关键区别在于它使用页面的边界框而不是媒体框(页面物理尺寸)进行适配." 注释 = "这个目标类型适用于需要完整查看页面高度并精确定位水平起始位置的场景,例如查看宽表格、时间轴或长幅图像.">
    常量 区域适配 <公开 值 = @VHPDFM_FIT_R 注释 = "PDF阅读器会自动计算缩放比例和滚动位置,使得你指定的矩形区域 (\"左边\", \"顶边\", \"右边\", \"底边\") 恰好填满整个视口(屏幕或阅读区域)."
            注释 = "这相当于说: \"请放大并移动页面,直到这个特定的区域(如一个图表、表格或段落)刚好占据整个屏幕.\"">
}

类 PDF目标 <公开 注释 = "本类对象代表一个PDF文档中的目标位置对象句柄值." 注释 = "注意: 有效本类对象只能由\"PDF页面.创建目标\"方法创建返回." @文档 = "category = \"辅助类\""
        @别名 = "HPDF_Destination" @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 置位置 <公开 静态 类型 = 整数 注释 = "  本方法用于精确设置 PDF 目标的跳转位置和缩放级别. 它定义了一个跳转目标,当用户点击关联的书签或链接时,将滚动到指定"
            注释 = "页面(创建本类对象时基于的页面)中的 X 和 Y 坐标位置(以该页面左下角为原点),然后将页面缩放至指定的比例." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本目标对象 <类型 = PDF目标>
    参数 横坐标 <类型 = 小数 注释 = "指定跳转后视图左边缘距离页面左边缘的X坐标,单位为\"点\"(1/72英寸).">
    参数 纵坐标 <类型 = 小数 注释 = "指定跳转后视图上边缘距离页面下边缘的Y坐标,单位为\"点\"(1/72英寸).">
    参数 欲设置的缩放比例 <类型 = 小数 注释 = "提供跳转后的页面缩放比例,必须大于等于0.08小于等于32,为1表示不缩放." @默认值 = 1>
    {
        @ (VOL_HPDF_STATUS)HPDF_Destination_SetXYZ (@<本目标对象>, (HPDF_REAL)@<横坐标>, (HPDF_REAL)@<纵坐标>, (HPDF_REAL)@<欲设置的缩放比例>)
    }

    方法 置页面适配模式 <公开 静态 类型 = 整数 注释 = "  设置本目标对象跳转到目的页面(创建本类对象时基于的页面)后该页面的外观适配模式,也就是当用户点击与本目标对象关联的"
            注释 = "书签或链接时,PDF阅读器对页面进行的缩放和位置调整操作." 注释 = "  注意: 本方法所有位置参数的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
            注释 = "  相关信息请参见\"PDF页面适配模式\"类." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本目标对象 <类型 = PDF目标>
    参数 页面适配模式 <类型 = PDF页面适配模式 注释 = "指定跳转到目标页面后具体的页面适配模式">
    参数 左边 <类型 = 小数 注释 = "仅当\"页面适配模式\"参数为\"高度适配\"、\"区域适配\"、\"高度适配2\"时有效,用作提供对齐用的左方边缘位置." @默认值 = 0>
    参数 顶边 <类型 = 小数 注释 = "仅当\"页面适配模式\"参数为\"宽度适配\"、\"区域适配\"、\"宽度适配2\"时有效,用作提供对齐用的顶部边缘位置." @默认值 = 0>
    参数 右边 <类型 = 小数 注释 = "仅当\"页面适配模式\"参数为\"区域适配\"时有效,用作提供指定矩形区域的右侧边缘位置." @默认值 = 0>
    参数 底边 <类型 = 小数 注释 = "仅当\"页面适配模式\"参数为\"区域适配\"时有效,用作提供指定矩形区域的底部边缘位置." @默认值 = 0>
    {
        @ CHaruPdfDocument::sSetDestinationFitMode (@<本目标对象>, (VOL_HPDF_DEST_FIT_MODE)@<页面适配模式>, @<左边>, @<顶边>, @<右边>, @<底边>)
    }
}

类 PDF字体 <公开 注释 = "本类对象代表一个PDF字体句柄值." 注释 = "注意:" 注释 = "1. 有效本类对象只能由\"PDF文档.取字体\"或\"PDF页面.取字体\"方法创建或返回;"
        注释 = "2. 本类方法中所使用的尺寸和坐标单位均为\"字体空间单位\",在标准的 PDF 规范中,字体空间通常是 1000 个单位等于 1 个\"em\"(即字体大小的基准单位),"
        注释 = "转换为实际显示的\"点\"(1/72英寸)的公式为: (尺寸或坐标值 / 1000.0) * 本字体的尺寸." @文档 = "category = \"辅助类\"" @别名 = "HPDF_Font"
        @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 取名称 <公开 静态 类型 = 文本型 注释 = "获取字体名称" @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ CHaruPdfDocument::sGetPdfFontName (@<本字体句柄>)
    }

    方法 取编码 <公开 静态 类型 = 文本型 注释 = "获取字体的编码名称" @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ CHaruPdfDocument::sGetPdfFontEncodingName (@<本字体句柄>)
    }

    方法 取字符宽度 <公开 静态 类型 = 整数 注释 = "获取本字体中指定字符的宽度." 注释 = "本方法常用于:" 注释 = "1. 文本布局计算: 在绘制多行文本、居中对齐、右对齐或精确排版时,需要知道每个字符或字符串的总宽度;"
            注释 = "2. 自动换行: 根据当前行可用宽度和字符宽度,决定在哪里换行;" 注释 = "3. 绘制下划线/删除线: 需要知道文本的实际渲染宽度, 以便精确绘制线条;" 注释 = "4. 文本测量工具: 构建自定义的文本测量或渲染引擎."
            注释 = "注意事项:" 注释 = "1. 字体支持: 确保所使用的字体文件包含你查询的字符,否则可能返回无效宽度;"
            注释 = "2. 性能: 频繁调用此函数可能影响性能,对于长文本,建议使用\"PDF文档.取文本宽度\"方法直接获取整个字符串的宽度." 返回值注释 = "返回所指定字符的宽度,单位为\"字体空间单位\"(转换到\"点\"见本类说明)."
            @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    参数 欲检测宽度的字符 <类型 = 字符>
    {
        @ HPDF_Font_GetUnicodeWidth (@<本字体句柄>, (HPDF_UNICODE)@<欲检测宽度的字符>)
    }

    方法 取边界框 <公开 静态 类型 = PDF矩形 注释 = "获取字体的全局边界框." 注释 = "返回字体中所有字形所占据的最大范围矩形区域,这个矩形定义了该字体在设计上可能延伸到的最左、最右、最上和最下的位置."
            注释 = "这个\"边界框\"是一个字体级别的属性,不是针对单个字符的. 它描述了整个字体的理论尺寸范围,常用于排版引擎计算行高、垂直对齐、文本包围框等." 注释 = "使用场景:"
            注释 = "1. 计算行高: 字体的推荐行高通常基于所返回矩形的高度值,并结合字体的\"上升(Ascender)\"和\"下降(Descender)\"高度,字体边界框提供了字体理论上可能达到的最大高度;"
            注释 = "2. 文本对齐与布局: 在进行垂直居中、基线对齐等操作时,了解字体的整体尺寸范围有助于精确控制;"
            注释 = "3. 绘制文本背景或边框: 如果你想为一段文本绘制一个背景色块或边框,字体边界框可以帮助你估算文本在垂直方向上的最大可能范围;" 注释 = "4. 字体度量分析: 用于调试或分析字体的度量信息."
            返回值注释 = "成功返回本字体的边界框,单位为\"字体空间单位\"(转换到\"点\"见本类说明),否则返回空矩形(成员全为零值)." @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ HPDF_Font_GetBBox (@<本字体句柄>)
    }

    方法 取上升高度 <公开 静态 类型 = 整数 注释 = "本方法返回字体中字符从基线 (Baseline) 到其最高点的理论最大距离。这个值描述了大写字母（如 \"H\"、\"T\"）或上伸部分（如 \"d\"、\"h\"）通常能达到的高度。"
            注释 = "使用场景:"
            注释 = "1. 计算行高: 行高通常由字体的\"上升高度(Ascender)\"和\"下降深度(Descender)\"和\"行间距(Leading)\"共同决定, 公式: 行高 = Ascent - Descent + Leading . \"下降深度\"通常是负值,所以用减法."
            注释 = "2. 垂直文本对齐: 当需要将文本与图标、其他文本行或页面元素进行顶部对齐时,\"上升高度\"值可以帮助你确定文本的顶部位置;"
            注释 = "3. 绘制文本装饰: 如绘制上划线(overline),其位置通常在\"上升高度\"附近;" 注释 = "4. 文本包围框计算: 结合\"上升高度\"、\"下降深度\"和文本宽度,可以计算出一段文本的完整包围矩形."
            返回值注释 = "返回值单位为\"字体空间单位\"(转换到\"点\"见本类说明),失败返回0." @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ HPDF_Font_GetAscent (@<本字体句柄>)
    }

    方法 取下降深度 <公开 静态 类型 = 整数 注释 = "本方法返回字体中字符从基线 (Baseline) 到其最低点的理论最大距离. 这个值通常是负数,因为它表示基线以下的部分."
            注释 = "它描述了具有\"下伸部\"(descenders)的字符(如 \"g\"、\"j\"、\"p\"、\"q\"、\"y\")向下延伸的程度." 注释 = "使用场景:"
            注释 = "1. 行高和文本包围框计算: 见\"取上升高度\"方法说明;"
            注释 = "2. 避免文本重叠: 在绘制多行文本时,了解\"下降深度\"可以确保下行文本的上伸部分(如 \'h\' 的顶部)不会与上行文本的下伸部分(如 \'p\' 的底部)发生碰撞;"
            注释 = "3. 垂直对齐: 当需要将文本与图形或其他元素底部对齐时,\"下降深度\"值可以帮助你确定文本的实际底部位置." 返回值注释 = "返回值单位为\"字体空间单位\"(转换到\"点\"见本类说明),失败返回0."
            @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ HPDF_Font_GetDescent (@<本字体句柄>)
    }

    方法 取x高度 <公开 静态 类型 = 整数 注释 = "返回字体中小写字母 \"x\" 的高度(从基线到其顶部的距离). 这个度量值被称为\"x-height\",是字体设计中的一个关键参数."
            注释 = "\"x高度\"决定了字体中小写字母(如 a, e, m, n, o, x 等)的主体高度,它对字体的可读性和视觉大小有重要影响."
            注释 = "\"x高度\"大的字体,在相同字号下看起来更大、更清晰,通常在小字号时更易读(如用于正文);" 注释 = "\"x高度\"小的字体,看起来更优雅或正式,但小字号时可能较难阅读." 注释 = "使用场景:"
            注释 = "1. 文本垂直对齐: 当需要将文本与图标、数学符号或其他文本进行光学对齐时,使用\"x高度\"比使用\"上升高度(Ascender)\"更自然,因为它代表了小写字母的主体高度. 例如: 将图标与文本的\"视觉中心\"对齐;"
            注释 = "2. 绘制中线 (Midline) 或基线 (Baseline) 装饰: 如绘制删除线,其位置通常设置在\"x高度\"的 60% 到 70% 高度处;" 注释 = "3. 字体分析与比较: 比较不同字体的可读性和视觉大小;"
            注释 = "4. 自定义文本渲染引擎: 在需要精确控制文本绘制位置的高级排版中, \"x高度\"是重要的参考值." 返回值注释 = "返回值单位为\"字体空间单位\"(转换到\"点\"见本类说明),失败返回0." @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ (INT)HPDF_Font_GetXHeight (@<本字体句柄>)
    }

    方法 取大写高度 <公开 静态 类型 = 整数 注释 = "返回字体中大写字母 \"H\" 或 \"I\" 的高度(从基线到其顶部的距离),这个度量值被称为 \"CapHeight\",是字体设计中的一个重要参数."
            注释 = "与\"上升高度\"不同,\"大写高度\"特指标准大写字母(如 H, I, E, L 等平顶大写字母)的高度,不包括像 \"A\" 这样可能略微超出的字母,它描述了大写字母主体的实际视觉高度." 注释 = "使用场景:"
            注释 = "1. 精确垂直对齐: 当需要将大写文本与其他元素(如图标、线条、其他字体的大写字母)进行光学对齐时,使用\"大写高度\"比\"上升高度\"更准确,因为\"上升高度\"可能包含一些超过大写字母顶部的额外空间或装饰;"
            注释 = "2. 绘制大写文本的装饰线: 如绘制上划线,其位置可以基于\"大写高度\"来设置,使其与大写字母顶部保持一致的视觉距离;"
            注释 = "3. 字体比较与分析: 比较不同字体的\"视觉大小\"和比例. 例如,两个相同字号的字体,\"大写高度\"更大的看起来会更\"粗壮\"或\"显大\";"
            注释 = "4. 自定义排版引擎: 在需要精细控制文本布局的高级应用中,\"大写高度\"提供了比\"上升高度\"更精确的大写字母高度参考." 返回值注释 = "返回值单位为\"字体空间单位\"(转换到\"点\"见本类说明),失败返回0."
            @嵌入式方法 = "">
    参数 本字体句柄 <类型 = PDF字体>
    {
        @ (INT)HPDF_Font_GetCapHeight (@<本字体句柄>)
    }
}

类 PDF颜色 <公开 注释 = "本类对象代表一个PDF中使用的颜色值." 注释 = "每个颜色分量的有效值为0到1, 0表示该颜色分量为最小值(无该颜色), 1表示该颜色分量为最大值(全强度)."
        @文档 = "category = \"辅助类\"" @别名 = "HPDF_RGBColor" @别名类型 = 本地结构>
{
    变量 红 <公开 类型 = 单精度小数 @输出名 = "r">
    变量 绿 <公开 类型 = 单精度小数 @输出名 = "g">
    变量 蓝 <公开 类型 = 单精度小数 @输出名 = "b">

    方法 取 <公开 静态 类型 = PDF颜色 注释 = "创建并返回指定RGB整数颜色值对应的PDF颜色值" @嵌入式方法 = "">
    参数 颜色值 <类型 = 整数 注释 = "为将RGB颜色组合到一起后的颜色值">
    {
        @ CHaruPdfDocument::sGetPdfRgbColor (@<颜色值>)
    }

    方法 取2 <公开 静态 类型 = PDF颜色 注释 = "创建并返回使用指定RGB各分量颜色值填充后的PDF颜色值" @嵌入式方法 = "">
    参数 红色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的红色分量值.">
    参数 绿色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的绿色分量值.">
    参数 蓝色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的蓝色分量值.">
    {
        @ CHaruPdfDocument::sGetPdfRgbColor (@<红色分量值>, @<绿色分量值>, @<蓝色分量值>)
    }

    方法 取整数颜色 <公开 静态 类型 = 整数 注释 = "返回本对象所对应的RGB整数颜色值" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = PDF颜色>
    {
        @ CHaruPdfDocument::sMakeRgbColor (&@<欲操作本对象>)
    }
}

类 PDF印刷色 <公开 注释 = "本类对象代表一个PDF中使用的CMYK颜色值." 注释 = "每个颜色分量为青色、洋红、黄色、黑色,有效值为0到1, 0表示该颜色分量为最小值(无该油墨颜色), 1表示该颜色分量为最大值(全强度)."
        注释 = "在生成用于打印或印刷的 PDF 文件时,使用 CMYK 颜色可以更准确地预测最终印刷品的颜色效果,特别适用于需要高质量打印输出的场景." @文档 = "category = \"辅助类\""
        @别名 = "HPDF_CMYKColor" @别名类型 = 本地结构>
{
    变量 青 <公开 类型 = 单精度小数 @输出名 = "c">
    变量 红 <公开 类型 = 单精度小数 注释 = "洋红" @输出名 = "m">
    变量 黄 <公开 类型 = 单精度小数 @输出名 = "y">
    变量 黑 <公开 类型 = 单精度小数 @输出名 = "k">
}

类 PDF书签 <公开 注释 = "本类对象代表一个PDF书签句柄值." 注释 = "书签(也称大纲)通常以树状结构显示在阅读器的侧边栏中,每个书签节点可以是展开(显示其子书签)或折叠(隐藏其子书签)状态."
        注释 = "注意: 有效本类对象只能由\"PDF文档.创建书签\"方法创建返回." @文档 = "category = \"辅助类\"" @别名 = "HPDF_Outline" @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 置打开状态 <公开 静态 类型 = 整数 注释 = "  本方法用于控制某个书签节点(特别是包含子书签的父节点)在文档首次打开时是默认展开还是折叠."
            注释 = "  本方法能够让你精细控制 PDF 书签的初始显示状态,通过合理设置初始打开状态,你可以引导用户的阅读路径,优化文档的导航体验,"
            注释 = "使重要内容更容易被发现,在生成结构复杂的 PDF 文档(如报告、手册、电子书)时,是提升专业性和可用性的关键方法之一." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本书签对象 <类型 = PDF书签>
    参数 是否打开 <类型 = 逻辑型 注释 = "如果设置为真,书签及其子书签在打开 PDF 时自动展开显示." 注释 = "如果设置为假,书签默认折叠,用户需要点击旁边的箭头才能查看其子书签.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Outline_SetOpened (@<本书签对象>, (@<是否打开> ? HPDF_TRUE : HPDF_FALSE))
    }

    方法 置目标 <公开 静态 类型 = 整数 注释 = "设置书签被单击后跳转到的目标位置" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本书签对象 <类型 = PDF书签>
    参数 目标位置 <类型 = PDF目标>
    {
        @ (VOL_HPDF_STATUS)HPDF_Outline_SetDestination (@<本书签对象>, @<目标位置>)
    }
}

类 PDF图像 <公开 注释 = "本类对象代表一个PDF图像句柄值." 注释 = "PDF图像对象为PDF外部对象的一种,可以强行转换到\"PDF外部对象\"数据类型."
        注释 = "注意: 有效本类对象只能由\"PDF文档.载入PNG图像\",\"PDF文档.载入内存PNG图像\",\"PDF文档.载入JPEG图像\",\"PDF文档.载入内存JPEG图像\",\"PDF文档.载入原始图像\",\"PDF文档.载入内存原始图像\"方法之一创建返回."
        @文档 = "category = \"辅助类\"" @别名 = "HPDF_Image" @别名类型 = 本地整数基本类型 @有效值范围 = "0">
{
    方法 到外部对象 <公开 静态 类型 = PDF外部对象 注释 = "PDF图像对象为PDF外部对象的一种,调用本方法可以将本对象句柄值转换为外部对象句柄值." 注释 = "也可以直接强行转换数据类型,如: (PDF外部对象)PDF图像对象"
            @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ (HPDF_XObject)@<本PDF图像>
    }

    方法 取尺寸 <公开 静态 类型 = PDF位置 注释 = "返回本对象中图像的尺寸" 返回值注释 = "成功返回图像尺寸值,单位为\"点\"(1/72英寸),否则返回(0,0)." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ HPDF_Image_GetSize (@<本PDF图像>)
    }

    方法 取宽度 <公开 静态 类型 = 整数 注释 = "返回本对象中图像的宽度" 返回值注释 = "成功返回图像宽度值,单位为\"点\"(1/72英寸),否则返回0." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ (INT)HPDF_Image_GetWidth (@<本PDF图像>)
    }

    方法 取高度 <公开 静态 类型 = 整数 注释 = "返回本对象中图像的高度" 返回值注释 = "成功返回图像高度值,单位为\"点\"(1/72英寸),否则返回0." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ (INT)HPDF_Image_GetHeight (@<本PDF图像>)
    }

    方法 取颜色位数 <公开 静态 类型 = 整数 注释 = "返回图像中用于描述每个颜色像素的位数" 返回值注释 = "成功返回所取得的位数,否则返回0." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ (INT)HPDF_Image_GetBitsPerComponent (@<本PDF图像>)
    }

    方法 取颜色空间名 <公开 静态 类型 = 文本型 注释 = "返回图像所基于颜色空间的名称"
            返回值注释 = "成功返回以下文本之一: \"DeviceGray\"(设备灰色), \"DeviceRGB\"(设备RGB), \"DeviceCMYK\"(设备CMYK), \"Indexed\"(分色)."
            返回值注释 = "否则返回空文本." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    {
        @ CVolString (HPDF_Image_GetColorSpace (@<本PDF图像>))
    }

    方法 置透明色 <公开 静态 类型 = 整数 注释 = "通过指定的 RGB 颜色范围值设置图像的透明颜色,范围内的颜色显示为透明色." 注释 = "图像必须基于RGB颜色空间(\"取颜色空间名\"方法返回\"DeviceRGB\")."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    参数 红色最小值 <类型 = 整数 注释 = "提供红色分量的最小值,有效值从0到255.">
    参数 红色最大值 <类型 = 整数 注释 = "提供红色分量的最大值,有效值从0到255.">
    参数 绿色最小值 <类型 = 整数 注释 = "提供绿色分量的最小值,有效值从0到255.">
    参数 绿色最大值 <类型 = 整数 注释 = "提供绿色分量的最大值,有效值从0到255.">
    参数 蓝色最小值 <类型 = 整数 注释 = "提供蓝色分量的最小值,有效值从0到255.">
    参数 蓝色最大值 <类型 = 整数 注释 = "提供蓝色分量的最大值,有效值从0到255.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Image_SetColorMask (@<本PDF图像>, (HPDF_UINT)@<红色最小值>, (HPDF_UINT)@<红色最大值>, (HPDF_UINT)@<绿色最小值>, (HPDF_UINT)@<绿色最大值>, (HPDF_UINT)@<蓝色最小值>, (HPDF_UINT)@<蓝色最大值>)
    }

    方法 置遮罩图像 <公开 静态 类型 = 整数 注释 = "设置用作本图像掩码的遮罩图像" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本PDF图像 <类型 = PDF图像>
    参数 欲设置遮罩图像 <类型 = PDF图像 注释 = "提供欲设置遮罩图像的对象句柄,此图像必须是 1 位灰度(即黑白色)图像.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Image_SetMaskImage (@<本PDF图像>, @<欲设置遮罩图像>)
    }
}

类 PDF外部对象 <公开 注释 = "本类对象代表一个PDF外部对象句柄值." 注释 = "  在 PDF 规范中,\"外部对象\"是一种重要的图形对象,其内容定义在 PDF 文档的内容流之外,可以作为共享资源被多个页面重复引用."
        注释 = "这在需要重复绘制相同内容(如公司Logo、水印、复杂图表)时非常高效,能显著减小最终生成文件的体积." 注释 = "\"外部对象\"主要分为以下类型:"
        注释 = "1. 图像: 代表一个位图或 JPEG/PNG 等格式的图像,图像对象句柄值可以强行转换到本数据类型;" 注释 = "2. 内联图像: 直接嵌入在内容流中的小图像;"
        注释 = "3. 表单: 一段可重用的图形内容(如矢量图形、文本、甚至其他外部对象),可以像一个\"子页面\"或\"宏\"一样被多次调用. 如果你有一段"
        注释 = "复杂的图形(比如公司的 Logo、水印、边框等),可以将其创建为一个表单外部对象,之后你可以在文档的多个页面或同一页面的多个位"
        注释 = "置通过调用\"执行外部对象\"方法来\"执行\"这个表单,实现内容的高效重用,而无需重复绘制所有指令." 注释 = "注意: 有效本类对象只能由有效的\"PDF图像\"对象强行转换得到."
        @文档 = "category = \"辅助类\"" @别名 = "HPDF_XObject" @别名类型 = 本地整数基本类型 @有效值范围 = "0">

类 PDF矩形 <公开 注释 = "本类对象用作记录PDF页面中的矩形位置." 注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
        @文档 = "category = \"辅助类\"" @别名 = "HPDF_Rect" @别名类型 = 本地结构>
{
    变量 左边 <公开 类型 = 单精度小数 @输出名 = "left">
    变量 底边 <公开 类型 = 单精度小数 注释 = "注意由于Y坐标轴的方向为从下到上,底边的值要比顶边的小." @输出名 = "bottom">
    变量 右边 <公开 类型 = 单精度小数 @输出名 = "right">
    变量 顶边 <公开 类型 = 单精度小数 注释 = "注意由于Y坐标轴的方向为从下到上,顶边的值要比底边的大." @输出名 = "top">

    方法 取 <公开 静态 类型 = PDF矩形 注释 = "创建并返回指定小数矩形值对应的PDF矩形对象">
    参数 小数矩形 <类型 = 小数矩形类>
    {
        变量 矩形变量 <类型 = PDF矩形>
        矩形变量.左边 = (单精度小数)小数矩形.左边
        矩形变量.底边 = (单精度小数)小数矩形.底边
        矩形变量.右边 = (单精度小数)小数矩形.右边
        矩形变量.顶边 = (单精度小数)小数矩形.顶边
        返回 (矩形变量)
    }

    方法 设置 <公开 静态>
    参数 本矩形对象 <类型 = PDF矩形>
    参数 所欲设置左边位置 <类型 = 小数>
    参数 所欲设置顶边位置 <类型 = 小数>
    参数 所欲设置右边位置 <类型 = 小数>
    参数 所欲设置底边位置 <类型 = 小数>
    {
        本矩形对象.左边 = (单精度小数)所欲设置左边位置
        本矩形对象.顶边 = (单精度小数)所欲设置顶边位置
        本矩形对象.右边 = (单精度小数)所欲设置右边位置
        本矩形对象.底边 = (单精度小数)所欲设置底边位置
    }

    方法 宽度 <公开 静态 属性读 类型 = 小数 注释 = "返回本矩形的宽度">
    参数 本矩形对象 <类型 = PDF矩形>
    {
        返回 ((小数)本矩形对象.右边 - (小数)本矩形对象.左边)
    }

    方法 宽度 <公开 静态 属性写 注释 = "设置本矩形的宽度">
    参数 本矩形对象 <类型 = PDF矩形>
    参数 所欲设置宽度 <类型 = 小数>
    {
        本矩形对象.右边 = 本矩形对象.左边 + (单精度小数)所欲设置宽度
    }

    方法 高度 <公开 静态 属性读 类型 = 小数 注释 = "返回本矩形的高度">
    参数 本矩形对象 <类型 = PDF矩形>
    {
        返回 ((小数)本矩形对象.顶边 - (小数)本矩形对象.底边)
    }

    方法 高度 <公开 静态 属性写 注释 = "设置本矩形的高度">
    参数 本矩形对象 <类型 = PDF矩形>
    参数 所欲设置高度 <类型 = 小数>
    {
        本矩形对象.底边 = 本矩形对象.顶边 - (单精度小数)所欲设置高度
    }

    方法 放大 <公开 静态>
    参数 本矩形对象 <类型 = PDF矩形>
    参数 横向放大尺寸 <类型 = 小数>
    参数 纵向放大尺寸 <类型 = 小数>
    {
        本矩形对象.左边 = 本矩形对象.左边 - (单精度小数)横向放大尺寸
        本矩形对象.右边 = 本矩形对象.右边 + (单精度小数)横向放大尺寸
        本矩形对象.顶边 = 本矩形对象.顶边 + (单精度小数)纵向放大尺寸
        本矩形对象.底边 = 本矩形对象.底边 - (单精度小数)纵向放大尺寸
    }

    方法 缩小 <公开 静态>
    参数 本矩形对象 <类型 = PDF矩形>
    参数 横向缩小尺寸 <类型 = 小数>
    参数 纵向缩小尺寸 <类型 = 小数>
    {
        本矩形对象.左边 = 本矩形对象.左边 + (单精度小数)横向缩小尺寸
        本矩形对象.右边 = 本矩形对象.右边 - (单精度小数)横向缩小尺寸
        本矩形对象.顶边 = 本矩形对象.顶边 - (单精度小数)纵向缩小尺寸
        本矩形对象.底边 = 本矩形对象.底边 + (单精度小数)纵向缩小尺寸
    }
}

类 PDF位置 <公开 注释 = "本类对象用作记录PDF页面中的2D坐标位置." 注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸)" @文档 = "category = \"辅助类\""
        @别名 = "HPDF_Point" @别名类型 = 本地结构>
{
    变量 横坐标 <公开 类型 = 单精度小数 @输出名 = "x">
    变量 纵坐标 <公开 类型 = 单精度小数 注释 = "注意纵向坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下." @输出名 = "y">

    方法 取 <公开 静态 类型 = PDF位置 注释 = "创建并返回指定小数位置值对应的PDF位置对象">
    参数 小数位置 <类型 = 小数位置类>
    {
        变量 位置变量 <类型 = PDF位置>
        位置变量.横坐标 = (单精度小数)小数位置.横向位置
        位置变量.纵坐标 = (单精度小数)小数位置.纵向位置
        返回 (位置变量)
    }

    方法 设置 <公开 静态>
    参数 本位置对象 <类型 = PDF位置>
    参数 所欲设置的横向位置 <类型 = 小数>
    参数 所欲设置的纵向位置 <类型 = 小数>
    {
        本位置对象.横坐标 = (单精度小数)所欲设置的横向位置
        本位置对象.纵坐标 = (单精度小数)所欲设置的纵向位置
    }
}

类 PDF矩阵 <公开 注释 = "本类对象用作记录PDF页面中使用的2D转换矩阵."
        注释 = "在计算机图形学中,一个 3x3 的仿射变换矩阵可以表示平移、旋转、缩放和倾斜.在实际操作中,通常用 6 个值 [ A, B, C, D, X, Y ] (2x3 的仿射变换矩阵,对应本类中的各个成员)来表示这个矩阵:"
        注释 = "  [ A  B  0 ] ;" 注释 = "  [ C  D  0 ] ;" 注释 = "  [ X  Y  1 ] ." 注释 = "其中:"
        注释 = "  A, B, C, D 控制缩放、旋转、倾斜(剪切). A 控制水平旋转,通常值为\"余弦(欲旋转角度)\", B 控制垂直旋转,通常值为\"正弦(欲旋转角度)\". X 和 Y 控制平移."
        注释 = "  如果 A 或 D 为零,则 B 或 C 不能为零." 注释 = "一个位置 (x, y) 可以乘于一个矩阵,相乘后将得到变换后的新位置 (x\', y\'), 计算公式为:"
        注释 = "  x\' = x * A + y * C + X ;" 注释 = "  y\' = x * B + y * D + Y ." 注释 = "你可以通过设置 [ A, B, C, D, X, Y ] 的特定值来实现不同的变换:"
        注释 = "1. 平移: 将所有内容在 X 轴方向移动 tx, Y 轴方向移动 ty. 矩阵: [ 1, 0, 0, 1, tx, ty ]."
        注释 = "2. 缩放: 在 X 轴方向缩放 sx 倍, 在 Y 轴方向缩放 sy 倍. 矩阵: [ sx, 0, 0, sy, 0, 0 ] . 如, 将页面的坐标系从默认的72dpi更改为300dpi: [ 72.0f / 300.0f, 0, 0, 72.0f / 300.0f, 0, 0 ]."
        注释 = "3. 旋转: 围绕原点逆时针旋转 θ 弧度. 矩阵: [ cos(θ), sin(θ), -sin(θ), cos(θ), 0, 0 ]."
        注释 = "4. 倾斜: 在 X 轴方向倾斜 θ 弧度: [ 1, 0, tan(θ), 1, 0, 0 ]; 在 Y 轴方向倾斜 θ 弧度: [ 1, tan(θ), 0, 1, 0, 0 ];  在 X,Y 轴方向分别倾斜 θx 和 θy 弧度: [ 1, tan(θy), tan(θx), 1, 0, 0 ]."
        注释 = "矩阵之间可以相乘,相乘后所得到新矩阵的效果是两个矩阵的效果顺序叠加. 譬如先旋转后平移,可以这样运算:"
        注释 = "  \"位置 (x, y) * 旋转矩阵 * 平移矩阵\" 或 \"位置 (x, y) * (旋转矩阵 * 平移矩阵)\",两个表达式结果一致."
        注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下." @文档 = "category = \"辅助类\""
        @别名 = "HPDF_TransMatrix" @别名类型 = 本地结构>
{
    变量 A <公开 类型 = 单精度小数 @输出名 = "a">
    变量 B <公开 类型 = 单精度小数 @输出名 = "b">
    变量 C <公开 类型 = 单精度小数 @输出名 = "c">
    变量 D <公开 类型 = 单精度小数 @输出名 = "d">
    变量 X <公开 类型 = 单精度小数 注释 = "横向偏移量" @输出名 = "x">
    变量 Y <公开 类型 = 单精度小数 注释 = "纵向偏移量" @输出名 = "y">
}

类 PDF时间 <公开 注释 = "本类对象代表一个PDF时间值" @文档 = "category = \"辅助类\"" @别名 = "HPDF_Date" @别名类型 = 本地结构>
{
    变量 年 <公开 类型 = 整数 @输出名 = "year">
    变量 月 <公开 类型 = 整数 @输出名 = "month">
    变量 日 <公开 类型 = 整数 @输出名 = "day">
    变量 时 <公开 类型 = 整数 @输出名 = "hour">
    变量 分 <公开 类型 = 整数 @输出名 = "minutes">
    变量 秒 <公开 类型 = 整数 @输出名 = "seconds">
    变量 时区 <公开 类型 = 字符 注释 = "本字段用于记录所提供时间与世界时间(UTC)之间的时区关系,属性值为以下字符之一."
            注释 = "1. \' \'(空格)或0值: 代表所提供时间为 UTC 时间,也称为 \"Zulu time\". 此时\"时区小时偏移\"和\"时区分钟偏移\"字段应被忽略(或设为 0),表示时间值是基于 UTC 的;"
            注释 = "2. \'+\'(加号) / \'-\'(减号): 代表所提供时间为本地时间,其时区偏移量是相对于 UTC 的. \"时区小时偏移\"和\"时区分钟偏移\"字段提供本地时间与 UTC 时间之间的差值,"
            注释 = "\'+\'字符(表示在 UTC 以东,如北京时间为 UTC+8)或\'-\'字符(表示在 UTC 以西,如美国东部时间为 UTC-5)用作提供时间偏移值的符号." @输出名 = "ind">
    变量 时区小时偏移 <公开 类型 = 整数 注释 = "有效值从 0 到 23. 表示所提供时间相对于 UTC 时间的小时偏移量." 注释 = "注意: 本字段仅在\"时区\"字段值不为\' \'(空格)或0值时有效."
            @输出名 = "off_hour">
    变量 时区分钟偏移 <公开 类型 = 整数
            注释 = "有效值从  0 到 59. 表示所提供时间相对于 UTC 的额外分钟偏移量. 与\"时区小时偏移\"字段结合使用,可以用作表示像 UTC+5:30 (印度标准时间) 或 UTC-3:30 (纽芬兰时间) 这样的非整小时偏移."
            注释 = "注意: 本字段仅在\"时区\"字段值不为\' \'(空格)或0值时有效." @输出名 = "off_minutes">

    方法 设置 <公开 静态 类型 = 逻辑型 注释 = "将所指定的时间值置入本对象" 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = PDF时间>
    参数 欲置入的时间 <类型 = 小数 注释 = "提供所欲置入的本地时间值">
    {
        @ CHaruPdfDocument::sFillPdfDate (&@<欲操作本对象>, @<欲置入的时间>)
    }
}

类 PDF图形模式 <公开 注释 = "用作提供各种PDF图形操作模式,可以使用\"相加\"或\"位或\"操作符组合起来使用" @文档 = "category = \"辅助类\"">
{
    常量 页面 <公开 类型 = 整数 值 = @HPDF_GMODE_PAGE_DESCRIPTION 注释 = "  这是页面对象被创建后的初始状态."
            注释 = "  在此模式下你可以执行所有页面操作,包括: 绘制图形(线条、矩形、路径等),输出文本," 注释 = "设置图形状态(颜色、线宽、字体等),设置页面大小、方向等.这是最常用和最自由的模式.">
    常量 路径 <公开 类型 = 整数 值 = @HPDF_GMODE_PATH_OBJECT 注释 = "当你开始定义一个复杂的路径（Path）时进入此模式,要用于继续构建路径(添加线段、曲线等)."
            注释 = "在此模式下,通常不能直接输出文本或执行其他非路径构建的操作,直到路径被\"结束\".">
    常量 文本 <公开 类型 = 整数 值 = @HPDF_GMODE_TEXT_OBJECT 注释 = "  当你开始输出文本时进入此模式,在此模式下你可以设置文本位置、输出文本、设置文本状态(对齐、缩放等),"
            注释 = "不能在此模式下直接绘制图形路径,除非文本输出被结束.">
    常量 裁剪路径 <公开 类型 = 整数 值 = @HPDF_GMODE_CLIPPING_PATH 注释 = "当你正在定义一个裁剪路径时进入此模式">
    常量 渐变着色 <公开 类型 = 整数 值 = @HPDF_GMODE_SHADING 注释 = "渐变/着色模式. 与定义和使用渐变填充相关.">
    常量 内嵌图像 <公开 类型 = 整数 值 = @HPDF_GMODE_INLINE_IMAGE>
    常量 外部对象 <公开 类型 = 整数 值 = @HPDF_GMODE_EXTERNAL_OBJECT>
}

类 PDF线条末端样式 <公开 注释 = "提供PDF文档中线条的末端样式,用于定义 PDF 页面上绘制线条时,线条末端(端点)的样式." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 平头 <公开 值 = @HPDF_BUTT_END 注释 = "这是默认样式. 线条在精确的起点和终点处被垂直截断,线的末端与路径方向垂直,形成一个平直的边. 线条的长度就是其几何路径的长度,不会超出端点.">
    常量 圆头 <公开 值 = @HPDF_ROUND_END 注释 = "线条的末端以一个半圆形结束. 这个半圆的圆心位于线条的端点上,半径等于线条宽度的一半. 这种样式会让线条的末端看起来是圆润的.">
    常量 方头 <公开 值 = @HPDF_PROJECTING_SQUARE_END
            注释 = "线条的末端延伸出一个方形区域. 这个方形的长度等于线条宽度的一半,并且从端点向外延伸. 因此,线条的实际视觉长度会比其几何路径长出一倍的线宽(两端各多出半倍线宽).">
}

类 PDF线条连接样式 <公开 注释 = "提供PDF文档中线条的连接样式,用于定义 PDF 页面上绘制路径时,两条线段相交处(连接点)的连接样式. 它决定了当路径转弯时,拐角处的外观." @文档 = "category = \"辅助类\""
        @常量类 = 整数>
{
    常量 斜接 <公开 值 = @HPDF_MITER_JOIN
            注释 = "这是默认的连接样式. 两条线段的外侧边被延伸,直到它们相交于一点,形成一个尖锐的角. 如果两条线的夹角非常小(即非常尖锐的拐角),斜接长度(从连接点到斜接顶点的距离)可能会变得非常长."
            注释 = "视觉效果: 锐利的、有棱角的拐角.">
    常量 圆角 <公开 值 = @HPDF_ROUND_JOIN 注释 = "在两条线段的连接处,绘制一个以连接点为圆心、半径等于线条宽度一半的圆弧,来平滑地连接两条线段,这使得拐角看起来是圆润的." 注释 = "视觉效果: 平滑的、圆形的拐角.">
    常量 平切 <公开 值 = @HPDF_BEVEL_JOIN 注释 = "在两条线段的内角相交处连接,然后用一条与两条线段都垂直的直线(平分外角)来截断外角,形成一个平坦的切口."
            注释 = "视觉效果: 钝的、被切平的拐角,看起来像是一个斜面.">
}

类 PDF虚线设置 <公开 注释 = "提供PDF页面上绘制线条时所使用的虚线设置信息" @文档 = "category = \"辅助类\"" @别名 = "HPDF_DashMode" @别名类型 = 本地结构>
{
    变量 模式 <公开 类型 = "单精度小数 [8]"
            注释 = "这是一个数值序列,定义了虚线的\"实线段\"和\"空白段\"的长度,单位为\"点\"(1/72英寸). 例如: [5, 3] 表示画长度为5的实线,然后跳过长度为3的空白,循环往复."
            注释 = "数组中的奇数索引(第1、3、5...个成员)代表实线长度,数组中的偶数索引(第2、4、6...个成员)代表空白长度." 注释 = "如果数组为空或所有成员为0,则表示绘制实线." @输出名 = "ptn">
    变量 模式数量 <公开 类型 = 整数 注释 = "表示\"模式\"数组中有效成员的个数,例如: 如果本成员值是2,那么只使用\"模式[0]\"和\"模式[1]\"." @输出名 = "num_ptn">
    变量 偏移 <公开 类型 = 单精度小数
            注释 = "定义了虚线模式从路径的起点开始绘制时的偏移量. 例如,如果模式是 [3, 1] 而本成员值是 1,那么绘制会从该模式长度为 1 的位置处开始(可能表现为从空白段的中间开始),这会影响虚线在路径上的起始位置."
            @输出名 = "phase">
}

类 PDF文本渲染模式 <公开 注释 = "提供PDF页面的文本渲染模式. 该模式决定了后续文本输出时是实心、空心、带边框,还是被用作裁剪区域."
        注释 = "这个设置是 PDF 文本状态的关键部分,对于创建复杂的文本视觉效果(如描边文字、文本遮罩)至关重要." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 填充 <公开 值 = @HPDF_FILL 注释 = "(默认) 文本的内部被当前填充色填充. 这是最常见的文本显示方式,即实心文字.">
    常量 描边 <公开 值 = @HPDF_STROKE 注释 = "文本的轮廓(边框)被当前描边色绘制. 文字看起来是空心的,只有边框.">
    常量 填充描边 <公开 值 = @HPDF_FILL_THEN_STROKE 注释 = "文本先被填充色填充,然后用描边色绘制轮廓. 这是创建\"描边文字\"效果的常用模式.">
    常量 隐藏 <公开 值 = @HPDF_INVISIBLE 注释 = "文本不可视被隐藏">
    常量 填充裁剪 <公开 值 = @HPDF_FILL_CLIPPING 注释 = "文本被用作一个裁剪路径,并且其内部被填充,后续的绘制操作(如图像、形状)将只显示在文本轮廓的内部.">
    常量 描边裁剪 <公开 值 = @HPDF_STROKE_CLIPPING 注释 = "文本的轮廓被用作一个裁剪路径,后续的绘制操作将只显示在文本轮廓线所定义的区域内.">
    常量 填充描边裁剪 <公开 值 = @HPDF_FILL_STROKE_CLIPPING 注释 = "文本先被填充并描边,然后其整个形状(填充区域+描边)被用作一个裁剪路径.">
    常量 裁剪 <公开 值 = @HPDF_CLIPPING 注释 = "文本被用作一个裁剪路径,但文本本身不被绘制(既不填充也不描边),后续的绘制操作将只显示在文本轮廓的内部.">
}

类 PDF边界框类型 <公开 注释 = "  提供PDF页面的各种边界框类型." 注释 = "  页面边界框是PDF标准中用于定义页面内容范围和不同用途区域的重要概念,用作定义页面的显示区域(媒体框)、"
        注释 = "打印区域(裁剪框)、出血区域(出血框)等,以满足专业出版和打印的需求." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 媒体框 <公开 值 = @HPDF_PAGE_MEDIABOX 注释 = "这是最重要的边界框,它定义了页面的总体物理尺寸(如A4、信纸),所有其它边界框通常都在媒体框的范围内定义."
            注释 = "如果未显式设置,PDF查看器和打印机将使用媒体框作为默认的页面大小.">
    常量 裁剪框 <公开 值 = @HPDF_PAGE_CROPBOX 注释 = "用作定义页面内容在屏幕上显示或打印时应被裁切到的区域,对于大多数普通PDF,裁剪框通常与媒体框相同."
            注释 = "查看器软件默认会显示裁剪框内的内容,你可以利用它来\"隐藏\"页面边缘的注解或辅助信息.">
    常量 出血框 <公开 值 = @HPDF_PAGE_BLEEDBOX 注释 = "用作定义页面内容在最终裁剪后预计会扩展到裁剪框之外的区域(\"出血\"区域)." 注释 = "这是专业印刷中的核心概念,旨在避免因裁切误差而在成品边缘留下白边."
            注释 = "出血框应大于裁切框(通常每边大3-5mm).">
    常量 艺术框 <公开 值 = @HPDF_PAGE_ARTBOX 注释 = "用作定义页面上的\"有意义的艺术内容\"占据的区域,这个概念在实际应用中较少使用.">
}

类 PDF文档 <公开 注释 = "用作记录一个PDF文档对象." 注释 = "注意: 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下."
        @视窗.外部头文件 = "lib\\vol_pdf_haru.h" @视窗.外部源文件 = "lib\\vol_pdf_haru.cpp" @视窗.外部库.non_static = "lib\\$(p)\\hpdf.lib"
        @视窗.附属文件.non_static = "lib\\$(p)\\hpdf.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll\r\n..\\..\\shared\\extern_lib\\common\\libpng\\$(p)\\libpng16.dll"
        @视窗.预定义宏.non_static = "HPDF_DLL"
        @视窗.外部库.static = "lib\\$(p)\\hpdf-static.lib\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib\r\n..\\..\\shared\\extern_lib\\common\\libpng\\$(p)\\libpng16-static.lib"
        @视窗.需求VS版本.static = "16-" @视窗.使用静态运行时库.static = 真>
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CHaruPdfDocument)
    #
    # 属性 ---

    方法 文本编码类型 <公开 属性读 类型 = PDF文本编码类型 注释 = "获取文档的当前文本编码类型. 如果未设置过,默认为\"PDF文本编码类型.简体中文\"." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetCurrentEncoderType ()
    }

    方法 文本编码类型 <公开 属性写 注释 = "设置文档的当前文本编码类型,默认为\"PDF文本编码类型.简体中文\".">
    参数 欲设置的类型 <类型 = PDF文本编码类型 注释 = "指定所欲设置的文本编码类型">
    {
        @ data ().SetCurrentEncoderType ((VOL_HPDF_ENCODER_TYPE)@<欲设置的类型>);
    }

    # 方法 ---

    方法 取文本编码名称 <公开 静态 类型 = 文本型 注释 = "返回所指定文本编码类型的名称" @嵌入式方法 = "">
    参数 文本编码类型 <类型 = PDF文本编码类型>
    {
        @ CHaruPdfDocument::sGetEncoderName ((VOL_HPDF_ENCODER_TYPE)@<文本编码类型>)
    }

    方法 取文本书写方向 <公开 类型 = 逻辑型 注释 = "返回文档当前文本编码类型对应的文字书写方向" 返回值注释 = "返回真表示水平方向书写,返回假表示垂直方向书写." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Encoder_GetWritingMode ()
    }

    方法 清空 <公开 注释 = "清除文档中的现有内容." 注释 = "当准备再次基于本对象构建另一个新文档前,需要调用本方法清除已经存在的文档数据." 注释 = "本方法调用不是必需的,本类对象被销毁时会自动清除所有文档内容."
            @嵌入式方法 = "">
    {
        @ @sn<this>.data ().CleanContent ()
    }

    方法 取错误码 <公开 类型 = 整数 注释 = "返回在本文档对象上最近一次操作失败后的错误码." 注释 = "注意: 一旦某些操作出错导致设置了错误代码,某些IO处理功能将被阻止,此时必须调用\"重置错误\"方法来重置恢复;"
            返回值注释 = "返回\"PDF错误码\"类中的常量值,为\"PDF错误码.成功\"表示无." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetError ()
    }

    方法 重置错误 <公开 注释 = "清理掉本文档对象上最近一次操作失败后记录的错误码值. 注意:" 注释 = "1. 一旦某些操作出错导致设置了错误代码,某些IO处理功能将被一直阻止,此时必须调用本方法来重置恢复;"
            注释 = "2. 本方法调用后\"取错误码\"方法将返回\"PDF错误码.成功\"." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().ResetError ()
    }

    方法 保存到文件 <公开 类型 = 整数 注释 = "将当前文档内容保存到指定名称的文件" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲保存到文件名 <类型 = 文本型>
    {
        @ @sn<this>.data ().SaveToFile (@<欲保存到文件名>.GetText ())
    }

    方法 保存到字节集 <公开 类型 = 整数 注释 = "将当前文档内容保存到字节集中" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲保存到字节集 <类型 = 字节集类 注释 = "所保存的数据将写入到此字节集变量中" @需求类型 = 可写入变量>
    {
        @ @sn<this>.data ().SaveToBin (@<欲保存到字节集>)
    }

    方法 取页面布局模式 <公开 类型 = PDF页面布局模式 注释 = "返回当前页面布局模式,返回\"PDF页面布局模式.无\"表示未设置,此时将使用PDF查看器应用程序自身的相关设置值." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetPageLayout ()
    }

    方法 置页面布局模式 <公开 类型 = 整数 注释 = "设置当前页面布局模式" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的模式 <类型 = PDF页面布局模式 注释 = "提供所欲设置的页面布局模式,注意不能为\"PDF页面布局模式.无\".">
    {
        @ @sn<this>.data ().SetPageLayout (@<欲设置的模式>)
    }

    方法 取页面模式 <公开 类型 = PDF页面模式 注释 = "返回当前页面显示模式,返回\"PDF页面模式.无\"表示未设置." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetPageMode ()
    }

    方法 置页面模式 <公开 类型 = 整数 注释 = "设置当前页面显示模式" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的模式 <类型 = PDF页面模式 注释 = "提供所欲设置的页面显示模式,注意不能为\"PDF页面模式.无\".">
    {
        @ @sn<this>.data ().SetPageMode (@<欲设置的模式>)
    }

    方法 置首页位置 <公开 类型 = 整数 注释 = "设置打开文档时显示的首页目标位置" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的目标位置 <类型 = PDF目标>
    {
        @ @sn<this>.data ().SetOpenAction (@<欲设置的目标位置>)
    }

    方法 取当前页 <公开 类型 = PDF页面 注释 = "返回当前页面对象" 返回值注释 = "成功返回对应的页面句柄值,失败返回0." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetCurrentPage ()
    }

    方法 加入页 <公开 类型 = PDF页面 注释 = "创建一个新页面并将其添加到文档的尾页之后." 注释 = "所创建页面尺寸为默认的 A4 纸尺寸,即: 210 x 297 毫米; 595.276 x 841.89 点(1/72英寸)."
            返回值注释 = "成功返回对应的页面句柄值,失败返回0." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().AddPage ()
    }

    方法 插入页 <公开 类型 = PDF页面 注释 = "创建一个新页面并将其插入到指定页面的前面" 注释 = "所创建页面尺寸为默认的 A4 纸尺寸,即: 210 x 297 毫米; 595.276 x 841.89 点(1/72英寸)."
            返回值注释 = "成功返回对应的页面句柄值,失败返回0." @嵌入式方法 = "">
    参数 插入位置页面 <类型 = PDF页面 注释 = "提供欲将新页面插入到其前方的页面句柄">
    {
        @ @sn<this>.data ().InsertPage (@<插入位置页面>)
    }

    方法 添加页面标签 <公开 类型 = 整数 注释 = "为文档中指定范围内的页面添加标签,页面标签显示在缩略图视图中." 注释 = "例如以下语句(行尾分号多余):"
            注释 = "  本类对象.添加页面标签 (0, PDF页号风格.小写罗马数字, 1, \"\");" 注释 = "  本类对象.添加页面标签 (4, PDF页号风格.阿拉伯数字, 1, \"\");"
            注释 = "  本类对象.添加页面标签 (7, PDF页号风格.阿拉伯数字, 8, \"A-\");" 注释 = "执行后将生成带有以下标签页面的文档:"
            注释 = "  i, ii, iii, iv, 1, 2, 3, A-8, A-9, ..." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 首页索引位置 <类型 = 整数 注释 = "指定应用标签的文档中首页索引位置,从0开始.">
    参数 欲设置的页号风格 <类型 = PDF页号风格 注释 = "指定欲设置的页号风格,注意不能为\"PDF页号风格.无\".">
    参数 起始页码 <类型 = 整数 注释 = "指定要使用的第一个页码值">
    参数 标签前缀 <类型 = 文本型 注释 = "指定欲添加到页面标签首部的前缀文本" @默认值 = "">
    {
        @ @sn<this>.data ().AddPageLabel (@<首页索引位置>, @<欲设置的页号风格>, @<起始页码>, @<标签前缀>.GetText ())
    }

    方法 载入Type1字体 <公开 类型 = 文本型 注释 = "从外部文件加载 Type1 字体并将其注册到文档对象中" 返回值注释 = "成功返回所载入字体的名称(用作\"取字体\"方法的\"字体名称\"参数值),失败返回空文本."
            @嵌入式方法 = "">
    参数 AFM文件名 <类型 = 文本型 注释 = "提供Type1字体\".afm\"文件的路径">
    参数 数据文件名 <类型 = 文本型 注释 = "提供字体PFA/PFB文件的路径,如果为空文本,则字体文件的XML数据不会被嵌入到所生成的PDF文件中.">
    {
        @ @sn<this>.data ().LoadType1FontFromFile (@<AFM文件名>.GetText (), @<数据文件名>.GetText ())
    }

    方法 载入TrueType字体 <公开 类型 = 文本型 注释 = "从外部文件加载 TrueType 字体并将其注册到文档对象中" 返回值注释 = "成功返回所载入字体的名称(用作\"取字体\"方法的\"字体名称\"参数值),失败返回空文本."
            @嵌入式方法 = "">
    参数 字体文件名 <类型 = 文本型 注释 = "提供TrueType字体的\".ttf\"(其中仅包含单个TrueType字体)或\".ttc\"(其中可以包含多个TrueType字体)文件路径.">
    参数 字体索引 <类型 = 整数 注释 = "如果\"字体文件名\"参数提供的是\".ttc\"字体集文件,请提供欲使用字体在该字体集中的索引位置(-1被自动规整到位置0),如果是\".ttf\"单字体文件,请提供-1." @默认值 = -1>
    参数 是否嵌入 <类型 = 逻辑型 注释 = "指定是否将所使用到的相关字体数据直接嵌入到生成的pdf文件中,嵌入后打开该pdf文件时不再需要系统中存在该 TrueType 字体文件." @默认值 = 真>
    {
        @ @sn<this>.data ().LoadTTFontFromFile (@<字体文件名>.GetText (), @<字体索引>, @<是否嵌入>)
    }

    方法 取字体 <公开 类型 = PDF字体 注释 = "获取并返回所请求类型的字体对象句柄."
            注释 = "注意: 调用本方法前,必须正确设置\"文本编码类型\"属性值,所有基于本方法返回字体进行的文本操作均以调用本方法时的\"文本编码类型\"属性值进行转换." 返回值注释 = "成功时返回非0字体对象句柄值,失败返回0."
            @嵌入式方法 = "">
    参数 字体名称 <类型 = 文本型
            注释 = "指定所欲使用的字体名称,如果为空文本,则根据当前\"文本编码类型\"属性值进行设置,具体为: 简体中文:\"SimSun\"; 繁体中文:\"MingLiU\"; 日文:\"MS-Gothic\"; 韩文:\"DotumChe\"; 其它: \"Helvetica\"."
            注释 = "本参数可以使用以下几类字体的名称:" 注释 = "一. 内置字体. 有以下几种:" 注释 = "1. Base14字体(使用前不能将\"文本编码类型\"属性设置为下面2到5所需求的\"PDF文本编码类型\"类常量值):"
            注释 = "   Base14字体内置于PDF中,所有PDF查看器都可以显示这些字体.使用Base14字体的PDF文件比使用其他类型字体的文件小,PDF处理速度更快(因为不需要加载外部字体),"
            注释 = "但是Base14字体只能显示latin1(拉丁字母1)字符集,要使用其它字符集,应用程序必须使用其它类型的字体."
            注释 = "   可用Base14字体的名称(名称包含\"Bold\"表示为粗体,包含\"Italic\"或\"Oblique\"表示为斜体,包含\"BoldItalic\"或\"BoldOblique\"表示为粗斜体,下同):"
            注释 = "   \"Courier\", \"Courier-Bold\", \"Courier-Oblique\", \"Courier-BoldOblique\";"
            注释 = "   \"Helvetica\", \"Helvetica-Bold\", \"Helvetica-Oblique\", \"Helvetica-BoldOblique\";"
            注释 = "   \"Times-Roman\", \"Times-Bold\", \"Times-Italic\", \"Times-BoldItalic\";"
            注释 = "   \"Symbol\", \"ZapfDingbats\"." 注释 = "2. 简体中文字体(使用前必须将\"文本编码类型\"属性设置为注释中标注有\"简体中文编码类型\"的\"PDF文本编码类型\"类常量值):"
            注释 = "   \"SimSun\", \"SimSun,Bold\", \"SimSun,Italic\", \"SimSun,BoldItalic\";"
            注释 = "   \"SimHei\", \"SimHei,Bold\", \"SimHei,Italic\", \"SimHei,BoldItalic\"."
            注释 = "3. 繁体中文字体(使用前必须将\"文本编码类型\"属性设置为注释中标注有\"繁体中文编码类型\"的\"PDF文本编码类型\"类常量值):"
            注释 = "   \"MingLiU\", \"MingLiU,Bold\", \"MingLiU,Italic\", \"MingLiU,BoldItalic\"."
            注释 = "4. 日文字体(使用前必须将\"文本编码类型\"属性设置为注释中标注有\"日文编码类型\"的\"PDF文本编码类型\"类常量值):"
            注释 = "   \"MS-Gothic\", \"MS-Gothic,Bold\", \"MS-Gothic,Italic\", \"MS-Gothic,BoldItalic\";"
            注释 = "   \"MS-PGothic\", \"MS-PGothic,Bold\", \"MS-PGothic,Italic\", \"MS-PGothic,BoldItalic\";"
            注释 = "   \"MS-Mincho\", \"MS-Mincho,Bold\", \"MS-Mincho,Italic\", \"MS-Mincho,BoldItalic\";"
            注释 = "   \"MS-PMincho\", \"MS-PMincho,Bold\", \"MS-PMincho,Italic\", \"MS-PMincho,BoldItalic\"."
            注释 = "5. 韩文字体(使用前必须将\"文本编码类型\"属性设置为注释中标注有\"韩文编码类型\"的\"PDF文本编码类型\"类常量值):"
            注释 = "   \"DotumChe\", \"DotumChe,Bold\", \"DotumChe,Italic\", \"DotumChe,BoldItalic\";"
            注释 = "   \"Dotum\", \"Dotum,Bold\", \"Dotum,Italic\", \"Dotum,BoldItalic\";"
            注释 = "   \"BatangChe\", \"BatangChe,Bold\", \"BatangChe,Italic\", \"BatangChe,BoldItalic\";"
            注释 = "   \"Batang\", \"Batang,Bold\", \"Batang,Italic\", \"Batang,BoldItalic\"." 注释 = "二. TrueType字体:"
            注释 = "   有两种类型的TrueType字体: 第一种格式扩展名为\".ttf\",在文件中只包含一个字体数据.第二种格式扩展名为\".ttc\",文件中可以包含多个"
            注释 = "字体数据.当应用程序使用外部TrueType字体时,必须调用\"载入TrueType字体\"方法载入并获取对应的字体名称以提供给本参数使用.调用\"载入TrueType字体\"方法时如果将"
            注释 = "参数\"是否嵌入\"设置为真,则字体子集将嵌入到PDF文件中,设置为假则仅将字体矩阵数据存储到PDF文件中,在这种情况下,如果PDF查看器找不到该字体,将自动寻找替代字" 注释 = "体(将无法保证显示效果)."
            注释 = "   当将\"文本编码类型\"设置为\"PDF文本编码类型.UTF8\"时,只有支持Unicode编码字符集的TrueType字体才能与之配合使用,譬如以下代码(行尾分号多余)获取了一个雅黑字体:"
            注释 = "   本类对象.文本编码类型 = PDF文本编码类型.UTF8 ;" 注释 = "   本类对象.取字体 (载入TrueType字体 (\"C:\\\\Windows\\\\Fonts\\\\msyh.ttc\", 0)) ."
            注释 = "三. Type1字体:" 注释 = "   Type1是Adobe开发的一种轮廓字体格式,在PDF中使用外部Type1字体需要一个AFM文件,当应用程序使用外部Type1字体时,必须调用\"载入Type1字体\"方法载入并获取对"
            注释 = "应的字体名称以提供给本参数使用. 如果在调用\"载入Type1字体\"方法时通过\"数据文件名\"参数指定了PFA/PFB文件,则字体的glyf数据将嵌入到PDF文件中,否则仅嵌入AFM" 注释 = "文件中的度量数据."
            @默认值 = "">
    {
        @ @sn<this>.data ().GetPdfFont (@<字体名称>.GetText ())
    }

    方法 创建书签 <公开 类型 = PDF书签 注释 = "创建一个新书签对象" 返回值注释 = "成功返回所创建的书签对象句柄值,失败返回0." @嵌入式方法 = "">
    参数 父书签 <类型 = PDF书签 注释 = "提供所创建书签对象的父书签对象句柄,如无则为0,此时表示所创建的书签对象为顶层书签." @默认值 = 0>
    参数 标题 <类型 = 文本型 注释 = "提供所创建书签对象的标题文本,其将根据当前\"文本编码类型\"属性值进行转码操作." @默认值 = "">
    {
        @ @sn<this>.data ().CreateOutline ((HPDF_Outline)@<父书签>, @<标题>.GetText ())
    }

    方法 载入PNG图像 <公开 类型 = PDF图像 注释 = "载入一个外部PNG图像文件" 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0." @嵌入式方法 = "">
    参数 PNG图像文件名 <类型 = 文本型 注释 = "提供所欲载入的PNG图像文件名">
    参数 节省内存占用 <类型 = 逻辑型 注释 = "  当本参数为真时,本方法不会立即加载PNG图像的所有数据(仅获取尺寸和颜色属性),在图像被写入" 注释 = "PDF之前才会加载图像主数据,并在写入后立即删除所加载的数据,以节省内存占用."
            @默认值 = 真>
    {
        @ @sn<this>.data ().LoadPngImageFromFile (@<PNG图像文件名>.GetText (), @<节省内存占用>)
    }

    方法 载入内存PNG图像 <公开 类型 = PDF图像 注释 = "从指定字节集中加载PNG图像格式的图像" 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0." @嵌入式方法 = "">
    参数 PNG图像数据 <类型 = 字节集类 注释 = "提供所欲载入的PNG图像数据">
    {
        @ @sn<this>.data ().LoadPngImageFromMem (@<PNG图像数据>)
    }

    方法 载入JPEG图像 <公开 类型 = PDF图像 注释 = "载入一个外部JPEG图像文件" 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0." @嵌入式方法 = "">
    参数 JPEG图像文件名 <类型 = 文本型 注释 = "提供所欲载入的JPEG图像文件名">
    {
        @ @sn<this>.data ().LoadJpegImageFromFile (@<JPEG图像文件名>.GetText ())
    }

    方法 载入内存JPEG图像 <公开 类型 = PDF图像 注释 = "从指定字节集中加载JPEG图像格式的图像" 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0." @嵌入式方法 = "">
    参数 JPEG图像数据 <类型 = 字节集类 注释 = "提供所欲载入的JPEG图像数据">
    {
        @ @sn<this>.data ().LoadJpegImageFromMem (@<JPEG图像数据>)
    }

    方法 载入原始图像 <公开 类型 = PDF图像 注释 = "加载具有\"原始\"图像格式的图像. 此方法加载图像数据而不进行任何转换,通常比其他功能更快." 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0."
            @嵌入式方法 = "">
    参数 原始图像文件名 <类型 = 文本型 注释 = "提供所欲载入的原始图像文件名">
    参数 图像宽度 <类型 = 整数 注释 = "提供图像的宽度,单位像素.">
    参数 图像高度 <类型 = 整数 注释 = "提供图像的高度,单位像素.">
    参数 颜色空间 <类型 = PDF颜色空间 注释 = "提供图像的颜色空间类型,可以为以下值:"
            注释 = "\"PDF颜色空间.设备灰度\": 8位灰度图像. 图像数据格式为: 每个字节描述一个灰度像素. 对于每个字节, 0表示最暗,255表示最亮. 图像数据的大小为(宽 * 高)字节."
            注释 = "\"PDF颜色空间.设备RGB\": 24位RGB彩色图像. 图像数据格式为: 每3个字节描述一个像素,分别顺序记录其红、绿、蓝分量值(0到255). 图像数据的大小为(宽 * 高 * 3)字节."
            注释 = "\"PDF颜色空间.设备CMYK\". 32位CMYK彩色图像. 图像数据格式为: 每4个字节描述一个像素,分别顺序记录其青色、洋红、黄色、黑色分量值(0到255). 图像数据的大小为(宽 * 高 * 4)字节."
            @默认值 = PDF颜色空间.设备RGB>
    {
        @ @sn<this>.data ().LoadRawImageFromFile (@<原始图像文件名>.GetText (), @<图像宽度>, @<图像高度>, @<颜色空间>)
    }

    方法 载入内存原始图像 <公开 类型 = PDF图像 注释 = "从指定字节集中加载具有\"原始\"图像格式的图像. 此方法加载图像数据而不进行任何转换,通常比其他功能更快." 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0."
            @嵌入式方法 = "">
    参数 原始图像数据 <类型 = 字节集类 注释 = "提供所欲载入的原始图像数据">
    参数 图像宽度 <类型 = 整数 注释 = "提供图像的宽度,单位像素.">
    参数 图像高度 <类型 = 整数 注释 = "提供图像的高度,单位像素.">
    参数 颜色空间 <类型 = PDF颜色空间 注释 = "提供图像的颜色空间类型,具体参见\"载入原始图像\"方法.">
    参数 每颜色分量位数 <类型 = 整数 注释 = "一般情况下,每个像素中的每个颜色分量值都用一个字节记录(此时有效值从0到255),但是为了减少数据尺寸,也可以减少为使用数个bit位来记录."
            注释 = "本参数的有效值为 1 / 2 / 4 / 8 之一." 注释 = "当本参数值为8时,图像数据的尺寸与\"载入原始图像\"方法中的要求一致." @默认值 = 8>
    {
        @ @sn<this>.data ().LoadRawImageFromBin (@<原始图像数据>, @<图像宽度>, @<图像高度>, @<颜色空间>, @<每颜色分量位数>)
    }

    方法 载入内存原始图像2 <公开 类型 = PDF图像 注释 = "从指定字节集中加载具有\"原始\"图像格式的图像. 此方法加载图像数据而不进行任何转换,通常比其他功能更快." 返回值注释 = "成功返回所创建的图像对象句柄值,失败返回0."
            @嵌入式方法 = "">
    参数 原始图像数据 <类型 = "字节 []" 注释 = "提供所欲载入的原始图像数据数组">
    参数 原始图像数据尺寸 <类型 = 整数 注释 = "提供原始图像数据的尺寸,单位字节.">
    参数 图像宽度 <类型 = 整数 注释 = "提供图像的宽度,单位像素.">
    参数 图像高度 <类型 = 整数 注释 = "提供图像的高度,单位像素.">
    参数 颜色空间 <类型 = PDF颜色空间 注释 = "提供图像的颜色空间类型,具体参见\"载入原始图像\"方法.">
    参数 每颜色分量位数 <类型 = 整数 注释 = "一般情况下,每个像素中的每个颜色分量值都用一个字节记录(此时有效值从0到255),但是为了减少数据尺寸,也可以减少为使用数个bit位来记录."
            注释 = "本参数的有效值为 1 / 2 / 4 / 8 之一." 注释 = "当本参数值为8时,图像数据的尺寸与\"载入原始图像\"方法中的要求一致." @默认值 = 8>
    {
        @ @sn<this>.data ().LoadRawImageFromMem (@<原始图像数据>, @<原始图像数据尺寸>, @<图像宽度>, @<图像高度>, @<颜色空间>, @<每颜色分量位数>)
    }

    方法 置文本字典项 <公开 类型 = 整数 注释 = "设置指定PDF文本型字典项的值" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 字典项类型 <类型 = PDF字典项类型 注释 = "提供欲设置其值的文本型字典项目类型,注意不能为\"PDF字典项类型.创建时间\"/\"PDF字典项类型.修改时间\"/\"PDF字典项类型.无\".">
    参数 文本值 <类型 = 文本型 注释 = "提供欲设置的文本值,其将根据当前\"文本编码类型\"属性值进行转码操作.">
    {
        @ @sn<this>.data ().SetInfoAttr ((HPDF_InfoType)@<字典项类型>, @<文本值>.GetText ())
    }

    方法 置时间字典项 <公开 类型 = 整数 注释 = "设置指定PDF时间型字典项的值" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 字典项类型 <类型 = PDF字典项类型 注释 = "提供欲设置其值的时间型字典项目类型,只能为\"PDF字典项类型.创建时间\"/\"PDF字典项类型.修改时间\".">
    参数 时间值 <类型 = PDF时间 注释 = "提供欲设置的时间值">
    {
        @ @sn<this>.data ().SetInfoDateAttr ((HPDF_InfoType)@<字典项类型>, @<时间值>)
    }

    方法 取字典项 <公开 类型 = 文本型 注释 = "取指定PDF字典项的值" 返回值注释 = "返回获取的属性文本值,其将根据当前\"文本编码类型\"属性值进行转码操作." @嵌入式方法 = "">
    参数 字典项类型 <类型 = PDF字典项类型 注释 = "提供欲获取其值的字典项目类型,注意不能为\"PDF字典项类型.无\".">
    {
        @ @sn<this>.data ().GetInfoAttr ((HPDF_InfoType)@<字典项类型>)
    }

    方法 置密码 <公开 类型 = 整数 注释 = "设置所生成PDF的密码" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 所有者密码 <类型 = 文本型 注释 = "提供文档所有者的密码. 文档所有者可以更改PDF文档的权限,不允许为空文本或与用户密码相同.">
    参数 用户密码 <类型 = 文本型 注释 = "提供文档用户的密码,如无则提供空文本." @默认值 = "">
    {
        @ @sn<this>.data ().SetPassword (@<所有者密码>.GetText (), @<用户密码>.GetText ())
    }

    方法 置权限 <公开 类型 = 整数 注释 = "设置文档的权限标志" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的权限 <类型 = 整数 注释 = "为\"PDF权限\"类中各个常量值使用\"相加\"或\"位或\"操作符组合后的值">
    {
        @ @sn<this>.data ().SetPermission (@<欲设置的权限>)
    }

    方法 置加密算法 <公开 类型 = 整数 注释 = "设置PDF加密算法. 作为副作用,当算法设置为\"PDF加密算法.修订版3\"时,会自动将PDF的版本提升到1.4."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的加密算法 <类型 = PDF加密算法 注释 = "提供具体的加密算法">
    参数 关键字长度 <类型 = 整数 注释 = "指定加密密钥的字节长度. 仅对\"PDF加密算法.修订版3\"算法有效,可以指定 5(40位) 到 16(128位) 之间的值." @默认值 = 5>
    {
        @ @sn<this>.data ().SetEncryptionMode ((HPDF_EncryptMode)@<欲设置的加密算法>, @<关键字长度>)
    }

    方法 置压缩模式 <公开 类型 = 整数 注释 = "设置PDF文档的压缩模式" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 欲设置的压缩模式 <类型 = 整数 注释 = "为\"PDF压缩模式\"类中各个常量值使用\"相加\"或\"位或\"操作符组合后的值" @默认值 = PDF压缩模式.所有>
    {
        @ @sn<this>.data ().SetCompressionMode (@<欲设置的压缩模式>)
    }

    方法 创建扩展图形状态 <公开 类型 = PDF扩展图形状态 注释 = "创建并返回一个扩展图形状态对象句柄" 返回值注释 = "成功返回所创建扩展图形状态对象的句柄,失败返回0." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().CreateExtGState ()
    }
}

类 PDF页面 <公开 注释 = "本类对象代表一个PDF页面句柄值." 注释 = "新建页面的尺寸为默认 A4 纸尺寸,即: 210 x 297 毫米; 595.276 x 841.89 点(1/72英寸)." 注释 = "注意:"
        注释 = "1. 有效本类对象只能由\"PDF文档.取当前页\",\"PDF文档.加入页\",\"PDF文档.插入页\"方法之一返回;"
        注释 = "2. 在PDF文档中,所有位置和尺寸的单位均为\"点\"(1/72英寸),Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下." @别名 = "HPDF_Pages" @别名类型 = 本地整数基本类型
        @有效值范围 = "0">
{
    方法 置宽度 <公开 静态 类型 = 整数 注释 = "设置页面的宽度" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的宽度 <类型 = 小数 注释 = "欲设置的宽度值,单位为点(1/72英寸).">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetWidth (@<本页面句柄>, (HPDF_REAL)@<欲设置的宽度>)
    }

    方法 取宽度 <公开 静态 类型 = 小数 注释 = "返回页面的宽度值" 返回值注释 = "成功返回宽度值,单位为点(1/72英寸),失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetWidth (@<本页面句柄>)
    }

    方法 置高度 <公开 静态 类型 = 整数 注释 = "设置页面的高度" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的高度 <类型 = 小数 注释 = "欲设置的高度值,单位为点(1/72英寸).">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetHeight (@<本页面句柄>, (HPDF_REAL)@<欲设置的高度>)
    }

    方法 取高度 <公开 静态 类型 = 小数 注释 = "返回页面的高度值" 返回值注释 = "成功返回高度值,单位为点(1/72英寸),失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetHeight (@<本页面句柄>)
    }

    方法 置尺寸 <公开 静态 类型 = 整数 注释 = "将页面的大小和方向设置为预定义值" 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的预定义尺寸 <类型 = PDF页面尺寸>
    参数 是否纵向 <类型 = 逻辑型 注释 = "为真指定页面方向为纵向,为假则为横向." @默认值 = 真>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetSize (@<本页面句柄>, (HPDF_PageSizes)@<欲设置的预定义尺寸>, (@<是否纵向> ? HPDF_PAGE_PORTRAIT : HPDF_PAGE_LANDSCAPE))
    }

    方法 置边界框 <公开 静态 类型 = 整数 注释 = "用于设置页面的边界框,页面边界框是PDF标准中用于定义页面内容范围和不同用途区域的重要概念."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的边界框 <类型 = PDF边界框类型 注释 = "具体请参见\"PDF边界框类型\"类的说明">
    参数 左边 <类型 = 小数 注释 = "提供边界框的左边横坐标位置,单位为\"点\"(1/72英寸).">
    参数 顶边 <类型 = 小数 注释 = "提供边界框的顶边纵坐标位置,单位为\"点\"(1/72英寸). 注意Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下.">
    参数 右边 <类型 = 小数 注释 = "提供边界框的右边横坐标位置,单位为\"点\"(1/72英寸).">
    参数 底边 <类型 = 小数 注释 = "提供边界框的底边纵坐标位置,单位为\"点\"(1/72英寸). 注意Y坐标轴的方向为从下到上(即Y坐标位置0在页面底部),而非通常的从上到下.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetBoundary (@<本页面句柄>, @<欲设置的边界框>, (HPDF_REAL)@<左边>, (HPDF_REAL)@<底边>, (HPDF_REAL)@<右边>, (HPDF_REAL)@<顶边>)
    }

    方法 置旋转角度 <公开 静态 类型 = 整数 注释 = "设置查看本页面时使用的旋转角度,本方法设置名为\"Rotate\"的字典项值,用作在PDF查看器中使用."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的角度 <类型 = 整数 注释 = "提供欲设置的页面旋转角度(单位:度),必须是90的倍数.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetRotate (@<本页面句柄>, (HPDF_UINT16)@<欲设置的角度>)
    }

    方法 置缩放比例 <公开 静态 类型 = 整数 注释 = "设置查看本页面时使用的缩放比例,本方法设置名为\"PZ\"的字典项值,用作在PDF查看器中使用."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的缩放比例 <类型 = 小数 注释 = "提供欲设置的页面缩放比例,必须大于等于0.08小于等于32,为1表示不缩放.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetZoom (@<本页面句柄>, (HPDF_REAL)@<欲设置的缩放比例>)
    }

    方法 创建目标 <公开 静态 类型 = PDF目标 注释 = "为页面创建一个新的目标位置对象" 返回值注释 = "成功返回所创建目标位置对象的句柄,失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_CreateDestination (@<本页面句柄>)
    }

    方法 创建文本注解 <公开 静态 类型 = PDF注解 注释 = "在页面上创建一个新的文本注解对象" 返回值注释 = "成功返回所创建注解对象的句柄,失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 所属文档 <类型 = PDF文档 注释 = "提供本页面所处文档对象,必须有效.">
    参数 位置 <类型 = PDF矩形 注释 = "提供欲显示注解在页面上的矩形位置">
    参数 注解文本 <类型 = 文本型 注释 = "提供要显示的注解文本,其将根据当前\"所属文档.文本编码类型\"属性值进行转码操作."
            注释 = "注意: 由于PDF中无法设置注解所使用的字体,因此如果使用中文将可能导致在某些PDF查看器无法显示.">
    {
        @ @<所属文档>.data ().Page_CreateTextAnnot (@<本页面句柄>, @<位置>, @<注解文本>.GetText ())
    }

    方法 创建链接注解 <公开 静态 类型 = PDF注解 注释 = "在页面上创建一个新的链接注解对象" 返回值注释 = "成功返回所创建注解对象的句柄,失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 位置 <类型 = PDF矩形 注释 = "提供页面上可点击区域的矩形位置">
    参数 跳转目标 <类型 = PDF目标 注释 = "提供要跳转到的目标位置对象的句柄">
    {
        @ HPDF_Page_CreateLinkAnnot (@<本页面句柄>, @<位置>, @<跳转目标>)
    }

    方法 创建网址链接注解 <公开 静态 类型 = PDF注解 注释 = "在页面上创建一个新的网址链接注解对象" 返回值注释 = "成功返回所创建注解对象的句柄,失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 位置 <类型 = PDF矩形 注释 = "提供页面上可点击区域的矩形位置">
    参数 网络地址 <类型 = 文本型 注释 = "提供要跳转到的URL网络地址">
    {
        @ HPDF_Page_CreateURILinkAnnot (@<本页面句柄>, @<位置>, CU8String (@<网络地址>.GetText ()).GetText ())
    }

    方法 取图形模式 <公开 静态 类型 = 整数 注释 = "获取页面当前所处于的图形操作模式. 具体参见\"PDF图形模式\"类说明."
            注释 = "图形操作模式为\"PDF图形模式\"类中各个常量使用\"相加\"或\"位或\"操作符组合起来的值,表明当前具体允许进行哪些图形操作." 返回值注释 = "成功返回页面当前处于的图形操作模式,否则返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetGMode (@<本页面句柄>)
    }

    方法 取字体 <公开 静态 类型 = PDF字体 注释 = "获取页面当前字体的句柄" 返回值注释 = "成功返回页面当前字体对象的句柄,失败返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetCurrentFont (@<本页面句柄>)
    }

    方法 取字体尺寸 <公开 静态 类型 = 小数 注释 = "获取页面当前字体的尺寸" 返回值注释 = "成功返回页面当前字体的尺寸,单位为\"点\"(1/72英寸),否则返回0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetCurrentFontSize (@<本页面句柄>)
    }

    方法 置字体 <公开 静态 类型 = 整数 注释 = "设置页面所使用的当前字体及其尺寸." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 字体对象 <类型 = PDF字体 注释 = "提供欲设置字体对象的句柄,如果为0表示使用当前字体." @默认值 = 0>
    参数 字体尺寸 <类型 = 小数 注释 = "提供欲设置字体的尺寸,单位为\"点\"(1/72英寸).">
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_SetFontAndSize (@<本页面句柄>, (@<字体对象> == 0 ? HPDF_Page_GetCurrentFont (@<本页面句柄>) : @<字体对象>), (HPDF_REAL)@<字体尺寸>);
    }

    方法 取转换矩阵 <公开 静态 类型 = PDF矩阵 注释 = "获取页面的当前全局转换矩阵. 具体参见\"PDF矩阵\"类说明."
            注释 = "注意: 相对\"取文本转换矩阵\"方法(该方法返回当前\"文本转换矩阵\"),本方法返回的是影响整个页面坐标系的当前全局变换矩阵,这个矩阵决定了所有后续绘制操作(包括图形和文本)的坐标如何映射到页面上."
            返回值注释 = "成功返回页面的当前转换矩阵,否则返回标准无变换矩阵 { 1, 0, 0, 1, 0, 0 }." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetTransMatrix (@<本页面句柄>)
    }

    方法 连接矩阵 <公开 静态 类型 = 整数
            注释 = "将指定的矩阵连接到页面的当前全局转换矩阵上,该矩阵决定了所有后续绘制操作(包括图形和文本)的坐标如何映射到页面上.可以通过\"压入图形状态\"和\"弹出图形状态\"方法来保存和恢复当前转换矩阵."
            注释 = "关于矩阵相关信息,请参见\"PDF矩阵\"类处的说明.关于\"文本转换矩阵\"和\"全局转换矩阵\"之间的关系,请参见\"取文本转换矩阵\"方法."
            注释 = "参数 A, B, C, D, X, Y 分别对应所提供矩阵的对应名称成员, 页面当前全局转换矩阵 = 页面当前全局转换矩阵 * 所提供矩阵 ."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 A <类型 = 小数>
    参数 B <类型 = 小数>
    参数 C <类型 = 小数>
    参数 D <类型 = 小数>
    参数 X <类型 = 小数 注释 = "横向偏移量">
    参数 Y <类型 = 小数 注释 = "纵向偏移量">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_Concat (@<本页面句柄>, (HPDF_REAL)@<A>, (HPDF_REAL)@<B>, (HPDF_REAL)@<C>, (HPDF_REAL)@<D>, (HPDF_REAL)@<X>, (HPDF_REAL)@<Y>)
    }

    方法 连接矩阵2 <公开 静态 类型 = 整数
            注释 = "将指定的矩阵连接到页面的当前全局转换矩阵上,该矩阵决定了所有后续绘制操作(包括图形和文本)的坐标如何映射到页面上.可以通过\"压入图形状态\"和\"弹出图形状态\"方法来保存和恢复当前转换矩阵."
            注释 = "关于矩阵相关信息,请参见\"PDF矩阵\"类处的说明.关于\"文本转换矩阵\"和\"全局转换矩阵\"之间的关系,请参见\"取文本转换矩阵\"方法." 注释 = "页面当前全局转换矩阵 = 页面当前全局转换矩阵 * 所提供矩阵 ."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲连接的矩阵 <类型 = PDF矩阵 注释 = "页面当前转换矩阵 = 页面当前转换矩阵 * 本参数所提供矩阵">
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_Concat (@<本页面句柄>, @<欲连接的矩阵.A>, @<欲连接的矩阵.B>, @<欲连接的矩阵.C>, @<欲连接的矩阵.D>, @<欲连接的矩阵.X>, @<欲连接的矩阵.Y>);
    }

    方法 取文本转换矩阵 <公开 静态 类型 = PDF矩阵 注释 = "返回页面的当前文本转换矩阵. 具体请参见\"PDF矩阵\"类中的说明."
            注释 = "注意: 相对\"取转换矩阵\"方法(该方法返回当前\"全局转换矩阵\"),本方法返回的是特定于文本操作的当前变换矩阵."
            注释 = "如果文本转换矩阵和全局转换矩阵同时存在,则两者的效果会叠加,文本输出位置将先使用\"文本转换矩阵\"进行转换,然后使用\"全局转换矩阵\"进行二次转换."
            返回值注释 = "成功返回当前文本转换矩阵,否则返回标准无变换矩阵 { 1, 0, 0, 1, 0, 0 }." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetTextMatrix (@<本页面句柄>)
    }

    方法 置文本转换矩阵 <公开 静态 类型 = 整数 注释 = "设置页面的当前文本转换矩阵,该矩阵决定了所有后续文本操作的坐标如何映射到页面上.可以通过\"压入图形状态\"和\"弹出图形状态\"方法来保存和恢复当前文本转换矩阵."
            注释 = "关于矩阵相关信息,请参见\"PDF矩阵\"类处的说明.关于\"文本转换矩阵\"和\"全局转换矩阵\"之间的关系,请参见\"取文本转换矩阵\"方法."
            注释 = "参数 A, B, C, D, X, Y 分别对应所提供矩阵的对应名称成员." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 A <类型 = 小数>
    参数 B <类型 = 小数>
    参数 C <类型 = 小数>
    参数 D <类型 = 小数>
    参数 X <类型 = 小数 注释 = "横向偏移量">
    参数 Y <类型 = 小数 注释 = "纵向偏移量">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetTextMatrix (@<本页面句柄>, (HPDF_REAL)@<A>, (HPDF_REAL)@<B>, (HPDF_REAL)@<C>, (HPDF_REAL)@<D>, (HPDF_REAL)@<X>, (HPDF_REAL)@<Y>)
    }

    方法 置文本转换矩阵2 <公开 静态 类型 = 整数 注释 = "设置页面的当前文本转换矩阵,该矩阵决定了所有后续文本操作的坐标如何映射到页面上.可以通过\"压入图形状态\"和\"弹出图形状态\"方法来保存和恢复当前文本转换矩阵."
            注释 = "关于矩阵相关信息,请参见\"PDF矩阵\"类处的说明.关于\"文本转换矩阵\"和\"全局转换矩阵\"之间的关系,请参见\"取文本转换矩阵\"方法."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置矩阵 <类型 = PDF矩阵>
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_SetTextMatrix (@<本页面句柄>, @<欲设置矩阵.A>, @<欲设置矩阵.B>, @<欲设置矩阵.C>, @<欲设置矩阵.D>, @<欲设置矩阵.X>, @<欲设置矩阵.Y>);
    }

    方法 取线宽 <公开 静态 类型 = 小数 注释 = "获取页面的当前线宽,单位为\"点\"(1/72英寸)." 注释 = "如果所返回线宽为0,请参见\"置线宽\"方法中的说明."
            返回值注释 = "成功返回页面路径绘制的当前线宽,否则返回默认值1." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetLineWidth (@<本页面句柄>)
    }

    方法 置线宽 <公开 静态 类型 = 整数 注释 = "设置页面的当前线宽(默认值为1),单位为\"点\"(1/72英寸)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置宽度 <类型 = 小数 注释 = "  为0表示使用输出设备的最小可分辨线宽. 具体来说是\"逻辑上为0\": 你告诉PDF渲染引擎\"我想画一条无限细的线\". 实际显示为最小可见线.由于物理设备"
            注释 = "(屏幕、打印机)和PDF规范都有分辨率限制,真正的\"0宽度\"无法显示.因此,PDF阅读器会将其渲染为当前缩放比例下可见的最细的一条线,通常为1像素.在大多数"
            注释 = "PDF查看器中,尤其是在标准缩放比例(如100%)下查看时,线宽为0的线条通常会被渲染为1个设备像素宽.但这并非绝对,会随缩放级别变化." @默认值 = 0>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetLineWidth (@<本页面句柄>, (HPDF_REAL)@<欲设置宽度>)
    }

    方法 取线条末端样式 <公开 静态 类型 = PDF线条末端样式 注释 = "获取页面的当前线条末端样式. 具体参见\"PDF线条末端样式\"类说明."
            返回值注释 = "成功返回页面路径绘制时使用的线条末端样式,否则返回默认值\"PDF线条末端样式.平头\"." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetLineCap (@<本页面句柄>)
    }

    方法 置线条末端样式 <公开 静态 类型 = 整数 注释 = "设置页面的当前线条末端样式. 具体参见\"PDF线条末端样式\"类说明."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置样式 <类型 = PDF线条末端样式>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetLineCap (@<本页面句柄>, @<欲设置样式>)
    }

    方法 取线条连接样式 <公开 静态 类型 = PDF线条连接样式 注释 = "获取页面的当前线条连接样式. 具体参见\"PDF线条连接样式\"类说明."
            返回值注释 = "成功返回页面路径绘制时使用的线条连接样式,否则返回默认值\"PDF线条连接样式.斜接\"." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetLineJoin (@<本页面句柄>)
    }

    方法 置线条连接样式 <公开 静态 类型 = 整数 注释 = "设置页面的当前线条连接样式. 具体参见\"PDF线条连接样式\"类说明."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置样式 <类型 = PDF线条连接样式>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetLineJoin (@<本页面句柄>, @<欲设置样式>)
    }

    方法 取线条斜接限制 <公开 静态 类型 = 小数 注释 = "  获取页面的当前线条斜接限制长度,单位为\"点\"(1/72英寸)."
            注释 = "  当页面的线条连接样式为\"PDF线条连接样式.斜接\"时,为了避免斜接尺寸过长导致渲染问题, PDF 引入了\"斜接限制\"值."
            注释 = "如果计算出的斜接长度超过了此限制值,渲染器会自动回退到\"PDF线条连接样式.平切\"样式." 返回值注释 = "成功返回当前所设置的线条斜接限制值,否则返回默认值10." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetMiterLimit (@<本页面句柄>)
    }

    方法 置线条斜接限制 <公开 静态 类型 = 整数 注释 = "设置页面的当前线条斜接限制长度,单位为\"点\"(1/72英寸)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置长度 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetMiterLimit (@<本页面句柄>, (HPDF_REAL)@<欲设置长度>)
    }

    方法 取虚线设置 <公开 静态 类型 = PDF虚线设置 注释 = "获取页面上绘制线条时所使用的虚线模式信息. 具体参见\"PDF虚线设置\"类说明."
            返回值注释 = "成功返回当前所设置的虚线模式信息,否则返回默认值全零结构(表示为实线)." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetDash (@<本页面句柄>)
    }

    方法 置虚线 <公开 静态 类型 = 整数 注释 = "设置页面上绘制线条时所使用的虚线模式." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 模式 <类型 = "单精度小数 []"
            注释 = "这是一个数值序列(最多8个成员),定义了虚线的\"实线段\"和\"空白段\"的长度,单位为\"点\"(1/72英寸). 例如: [5, 3] 表示画长度为5的实线,然后跳过长度为3的空白,循环往复."
            注释 = "数组中的奇数索引(第1、3、5...个成员)代表实线长度,数组中的偶数索引(第2、4、6...个成员)代表空白长度." 注释 = "如果数组所有成员为0,则表示绘制实线.">
    参数 模式数量 <类型 = 整数 注释 = "表示\"模式\"数组参数中有效成员的个数,例如: 如果本成员值是2,那么只使用\"模式[0]\"和\"模式[1]\".">
    参数 偏移 <类型 = 小数
            注释 = "定义了虚线模式从路径的起点开始绘制时的偏移量. 例如,如果模式是 [3, 1] 而本成员值是 1,那么绘制会从该模式长度为 1 的位置处开始(可能表现为从空白段的中间开始),这会影响虚线在路径上的起始位置." @默认值 = 0>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetDash (@<本页面句柄>, @<模式>, (HPDF_UINT)@<模式数量>, (HPDF_REAL)@<偏移>)
    }

    方法 置虚线2 <公开 静态 类型 = 整数 注释 = "设置页面上绘制线条时所使用的虚线模式." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置的虚线模式 <类型 = PDF虚线设置 注释 = "具体参见\"PDF虚线设置\"类说明">
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_SetDash (@<本页面句柄>, @<欲设置的虚线模式.模式>, (HPDF_UINT)@<欲设置的虚线模式.模式数量>, @<欲设置的虚线模式.偏移>);
    }

    方法 取消虚线 <公开 静态 类型 = 整数 注释 = "清除并取消页面上绘制线条时所使用的虚线模式(由\"置虚线\"方法设置)." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetDash (@<本页面句柄>, NULL, 0, 0)
    }

    方法 取曲线平坦度 <公开 静态 类型 = 小数 注释 = "返回页面用于控制曲线渲染精度的\"平坦度\"值,为一个 1 到 100 之间的小数值." 注释 = "具体信息请参见\"置曲线平坦度\"方法."
            返回值注释 = "成功返回当前所设置的曲线平坦度(1到100),否则返回默认值1." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetFlat (@<本页面句柄>)
    }

    方法 置曲线平坦度 <公开 静态 类型 = 整数 注释 = "设置页面用于控制曲线渲染精度的\"平坦度\"值." 注释 = "这个设置主要影响贝塞尔曲线、圆弧等非直线路径的视觉质量,默认值为1(需求较高的曲线质量)."
            注释 = "PDF阅读器在绘制曲线时,实际上是将曲线近似为一系列非常短的直线段(称为\"线性化\"或\"细分\").平坦度参数决定了这种近似过程的精度."
            注释 = "平坦度值越小(接近1)表示精度要求越高,曲线会被分割成更多、更短的直线段来逼近,使得最终绘制出的曲线看起来非常平滑,但会增加文件大小和渲染时间."
            注释 = "平坦度值越大(接近100)表示精度要求越低,曲线会被分割成更少、更长的直线段,这可能导致曲线看起来有轻微的\"锯齿\"或不够平滑,但能提高渲染速度并减小文件体积."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置平坦度 <类型 = 小数 注释 = "为一个 1 到 100 之间的小数值,数值越小表示曲线越平滑(但计算量越大),数值越大表示曲线越粗糙(但渲染越快).">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetFlat (@<本页面句柄>, (HPDF_REAL)@<欲设置平坦度>)
    }

    方法 取字符间距 <公开 静态 类型 = 小数 注释 = "返回页面字符之间的当前间距长度,单位为\"点\"(1/72英寸)." 返回值注释 = "成功返回当前所设置的字符间距长度,否则返回默认值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetCharSpace (@<本页面句柄>)
    }

    方法 置字符间距 <公开 静态 类型 = 整数 注释 = "设置页面字符之间的当前间距长度(初始值为0)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置间距 <类型 = 小数 注释 = "提供欲设置的间距长度,单位为\"点\"(1/72英寸).">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetCharSpace (@<本页面句柄>, @<欲设置间距>)
    }

    方法 取单词间距 <公开 静态 类型 = 小数 注释 = "返回页面单词之间的当前间距长度,单位为\"点\"(1/72英寸)." 返回值注释 = "成功返回当前所设置的单词间距长度,否则返回默认值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetWordSpace (@<本页面句柄>)
    }

    方法 置单词间距 <公开 静态 类型 = 整数 注释 = "设置页面单词之间的当前间距长度,单位为\"点\"(1/72英寸)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置间距 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetWordSpace (@<本页面句柄>, (HPDF_REAL)@<欲设置间距>)
    }

    方法 取文本水平缩放比 <公开 静态 类型 = 小数 注释 = "取当前页面文本的水平缩放比例,为一个表示百分比的浮点数(如 100.0 表示正常宽度)."
            注释 = "这个设置允许你控制文本输出时的宽度,实现拉伸或压缩的视觉效果,是 PDF 文本状态的一部分." 返回值注释 = "成功返回当前所设置的文本水平缩放比,否则返回默认值100." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetHorizontalScalling (@<本页面句柄>)
    }

    方法 置文本水平缩放比 <公开 静态 类型 = 整数 注释 = "设置当前页面文本的水平缩放比例." 注释 = "这个设置允许你控制文本输出时的宽度,实现拉伸或压缩的视觉效果,是 PDF 文本状态的一部分."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 水平缩放比例 <类型 = 小数 注释 = "为一个表示百分比的浮点数(如 100.0 表示正常宽度).">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetHorizontalScalling (@<本页面句柄>, (HPDF_REAL)@<水平缩放比例>)
    }

    方法 取文本行距 <公开 静态 类型 = 小数 注释 = "获取当前页面的文本行距(两行文本基线之间的距离),单位为\"点\"(1/72英寸)."
            注释 = "如何设置合适的行距: 仅仅设置文本行距为字体大小通常是不够的,因为这会导致行与行之间紧贴,没有足够的空间."
            注释 = "一个常见的做法是将行距设置为字体大小的 1.2 到 1.5 倍. 例如: 如果字体大小是 12,可以将行距设置为 14.4 (12 * 1.2) 或 18 (12 * 1.5),以获得舒适的阅读间距."
            返回值注释 = "成功返回当前所设置的文本行距,否则返回默认值0." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetTextLeading (@<本页面句柄>)
    }

    方法 置文本行距 <公开 静态 类型 = 整数 注释 = "设置当前页面的文本行距(两行文本基线之间的距离,初始值为0),单位为\"点\"(1/72英寸)."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置文本行距 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetTextLeading (@<本页面句柄>, (HPDF_REAL)@<欲设置文本行距>)
    }

    方法 取文本渲染模式 <公开 静态 类型 = PDF文本渲染模式 注释 = "获取当前页面的文本渲染模式. 具体参见\"PDF文本渲染模式\"类说明."
            返回值注释 = "成功返回当前所设置的文本渲染模式,否则返回默认值\"PDF文本渲染模式.填充\"." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (INT)HPDF_Page_GetTextRenderingMode (@<本页面句柄>)
    }

    方法 置文本渲染模式 <公开 静态 类型 = 整数 注释 = "设置当前页面的文本渲染模式. 具体参见\"PDF文本渲染模式\"类说明."
            注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置渲染模式 <类型 = PDF文本渲染模式>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetTextRenderingMode (@<本页面句柄>, @<欲设置渲染模式>)
    }

    方法 取文本上升值 <公开 静态 类型 = 小数 注释 = "获取当前页面的文本上升值,单位为\"点\"(1/72英寸). 具体参见\"置文本上升值\"方法处的说明." 返回值注释 = "成功返回当前所设置的文本上升值,否则返回默认值0."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ (DOUBLE)HPDF_Page_GetTextRise (@<本页面句柄>)
    }

    方法 置文本上升值 <公开 静态 类型 = 整数 注释 = "设置当前页面的文本上升值,单位为\"点\"(1/72英寸)."
            注释 = "文本上升值是一个垂直偏移量,它控制文本基线相对于当前文本位置的上下移动,正值将文本向上移动,负值将文本向下移动."
            注释 = "当你输出文本时,文本是基于一个\"基线\"来定位的,\"文本上升值\"允许你将这个基线向上或向下移动一个指定的距离,这个偏移是叠加在当前文本位置之上的." 注释 = "用途:"
            注释 = "1. 上标: 设置一个正的上升值(例如 5.0),可以使文本看起来像数学公式中的上标(如 x²);" 注释 = "2. 下标: 设置一个负的上升值(例如 -3.0),可以使文本看起来像化学式中的下标(如 H₂O)."
            注释 = "3. 特殊排版效果: 可以用于创建文本的阴影、偏移等视觉效果." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置值 <类型 = 小数>
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetTextRise (@<本页面句柄>, (HPDF_REAL)@<欲设置值>)
    }

    方法 取填充色 <公开 静态 类型 = PDF颜色 注释 = "返回页面填充颜色的当前值." 注释 = "仅在页面的填充颜色空间为\"PDF颜色空间.设备RGB\"时有效."
            返回值注释 = "成功返回当前所设置的页面填充色,否则返回默认值黑色." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetRGBFill (@<本页面句柄>)
    }

    方法 置填充色 <公开 静态 类型 = 整数 注释 = "设置页面填充颜色的当前值." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "调用本方法后页面的填充颜色空间将被改变为\"PDF颜色空间.设备RGB\"." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 红 <类型 = 小数 注释 = "提供欲设置填充颜色的\"红色\"分量值,有效值为0到1.">
    参数 绿 <类型 = 小数 注释 = "提供欲设置填充颜色的\"绿色\"分量值,有效值为0到1.">
    参数 蓝 <类型 = 小数 注释 = "提供欲设置填充颜色的\"蓝色\"分量值,有效值为0到1.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetRGBFill (@<本页面句柄>, (HPDF_REAL)@<红>, (HPDF_REAL)@<绿>, (HPDF_REAL)@<蓝>)
    }

    方法 置填充色2 <公开 静态 类型 = 整数 注释 = "设置页面填充颜色的当前值." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "调用本方法后页面的填充颜色空间将被改变为\"PDF颜色空间.设备RGB\"." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
    参数 本页面句柄 <类型 = PDF页面>
    参数 欲设置颜色 <类型 = PDF颜色 注释 = "提供欲设置的填充颜色">
    {
        @ return (VOL_HPDF_STATUS)HPDF_Page_SetRGBFill (@<本页面句柄>, @<欲设置颜色.红>, @<欲设置颜色.绿>, @<欲设置颜色.蓝>);
    }

    方法 取描边色 <公开 静态 类型 = PDF颜色 注释 = "返回页面描边颜色的当前值." 注释 = "仅在页面的描边颜色空间为\"PDF颜色空间.设备RGB\"时有效." 返回值注释 = "成功返回当前所设置的描边色,否则返回默认值黑色."
            @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    {
        @ HPDF_Page_GetRGBStroke (@<本页面句柄>)
    }

    方法 置描边色 <公开 静态 类型 = 整数 注释 = "设置页面描边颜色的当前值." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "调用本方法后页面的描边颜色空间将被改变为\"PDF颜色空间.设备RGB\"." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @嵌入式方法 = "">
    参数 本页面句柄 <类型 = PDF页面>
    参数 红 <类型 = 小数 注释 = "提供欲设置描边颜色的\"红色\"分量值,有效值为0到1.">
    参数 绿 <类型 = 小数 注释 = "提供欲设置描边颜色的\"绿色\"分量值,有效值为0到1.">
    参数 蓝 <类型 = 小数 注释 = "提供欲设置描边颜色的\"蓝色\"分量值,有效值为0到1.">
    {
        @ (VOL_HPDF_STATUS)HPDF_Page_SetRGBStroke (@<本页面句柄>, (HPDF_REAL)@<红>, (HPDF_REAL)@<绿>, (HPDF_REAL)@<蓝>)
    }

    方法 置描边色2 <公开 静态 类型 = 整数 注释 = "设置页面描边颜色的当前值." 注释 = "在调用本方法前,页面图形模式必须包含\"PDF图形模式.页面\"或\"PDF图形模式.文本\"状态,调用本方法后图形模式不改变."
            注释 = "调用本方法后页面的描边颜色空间将被改变为\"PDF颜色空间.设备RGB\"." 返回值注释 = "成功返回\"PDF错误码.成功\",失败返回\"PDF错误码\"类中的其它常量值." @禁止流程检查 = 真>
