    常量 行政文书 <公开 值 = @HPDF_PAGE_SIZE_EXECUTIVE 注释 = "尺寸: 7.25 x 10.5 (英寸); 522 x 756 (点)">
    常量 US4x6 <公开 值 = @HPDF_PAGE_SIZE_US4x6 注释 = "尺寸: 4 x 6 (英寸); 288 x 432 (点)">
    常量 US4x8 <公开 值 = @HPDF_PAGE_SIZE_US4x8 注释 = "尺寸: 4 x 8 (英寸); 288 x 576 (点)">
    常量 US5x7 <公开 值 = @HPDF_PAGE_SIZE_US5x7 注释 = "尺寸: 5 x 7 (英寸); 360 x 504 (点)">
