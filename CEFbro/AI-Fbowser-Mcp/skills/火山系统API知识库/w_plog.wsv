类 日志记录器 <公开 基础类 = 对象类 注释 = "用于记录全局当前日志实例的一些信息" @文档 = "category = \"功能类\"" @视窗.前缀文本 = "template<int instanceId> \n"
        @禁止继承 = 真 @禁止创建对象 = 真>
{
    方法 取默认记录器 <公开 静态 类型 = 日志记录器 注释 = "获取默认标识实例的记录器" @嵌入式方法 = "">
    {
        @ @dt<日志记录器><PLOG_DEFAULT_INSTANCE_ID>(plog::get())
    }

    方法 取指定记录器 <公开 静态 类型 = 日志记录器 注释 = "获取指定标识实例的记录器" @嵌入式方法 = "">
    参数 日志标识 <类型 = 整数 注释 = "指示当前获取的日志记录器来自哪个实例ID." 注释 = "注意:需自行确保ID已初始化,不同的ID得到的记录器也不同." @默认值 = 多日志类.默认标识 @需求类型 = 立即数或常量>
    {
        @ PLOG_GET_LOGGER(@dt<日志记录器>, @<日志标识>)
    }

    方法 是否为空 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ (@dt<逻辑型>)!@sn<this>.m_data
    }

    方法 取最大级别 <公开 类型 = 日志级别 注释 = "取当前日志实例级别" @嵌入式方法 = "">
    {
        @ (@dt<日志级别>)@sn<this>.data().getMaxSeverity()
    }

    方法 置最大级别 <公开 注释 = "重新定义当前日志实例级别" @嵌入式方法 = "">
    参数 输出级别 <类型 = 日志级别 注释 = "日志文件接收的级别,级别越高能接收的输出级别就越多." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释.">
    {
        @ @sn<this>.data().setMaxSeverity((plog::Severity)@<输出级别>)
    }

    方法 是否已存在 <公开 类型 = 逻辑型 注释 = "检查当前日志级别是否大于或等于指定级别" 返回值注释 = "如果当前实例中最大级别大于或等于指定的级别则返回真,反之返回假." @嵌入式方法 = "">
    参数 级别 <类型 = 日志级别 注释 = "欲检查的日志级别">
    {
        @ (@dt<逻辑型>)@sn<this>.data().checkSeverity((plog::Severity)@<级别>)
    }

    # @begin
    # <> <include>
    #     #define PLOG_GET_LOGGER(logger, id) logger<id>(plog::get<id>())
    #     @sn<current_class>(plog::Logger<instanceId>* data){m_data = data; }
    #     @sn<current_class>(plog::Logger<instanceId>& data){ m_data = &data; }
    #     plog::Logger<instanceId>& data(){ assert(m_data); return *m_data; }
    #     plog::Logger<instanceId>* m_data = nullptr;
    # <> </include>
    # @end
}

类 日志功能类 <公开 基础类 = 对象类 注释 = "一些日志功能操作类" @文档 = "category = \"功能类\"" @禁止创建对象 = 真>
{
    方法 级别到文本 <公开 静态 类型 = 文本型 注释 = "将指定日志级别常量转换成日志级别对应的字符" @嵌入式方法 = "">
    参数 级别 <类型 = 日志级别 注释 = "欲转换的日志级别">
    {
        @ @dt<文本型>(plog::severityToString((plog::Severity)@<级别>))
    }

    方法 文本到级别 <公开 静态 类型 = 日志级别 注释 = "将指定日志级别对应的字符转换为日志级别常量" @嵌入式方法 = "req_str_param_text_pointer_u8 = true">
    参数 级别 <类型 = 文本型 注释 = "输入[\"FATAL\",\"ERROR\",\"WARN\",\"INFO\",\"DEBUG\",\"VERB\",\"NONE\"]以上任意一组成员或成员首字母即可转换为对应级别常量."
            注释 = "注意:输入的字符不区分大小写,且只需首字母对应即可.">
    {
        @ (@dt<日志级别>)plog::severityFromString((const char*)@<级别>)
    }

    方法 取当前对象 <公开 静态 注释 = "获取当前语句调用时所在位置的对象实例" @嵌入式方法 = "" @视窗.返回参考 = 真 @视窗.预定义宏 = "PLOG_ENABLE_GET_THIS">
    参数 返回值类型 <类型 = 对象类 注释 = "欲返回的对象类型,必须为当前语句调用时所在位置的对象" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ *(@<返回值类型>*)PLOG_GET_THIS()
    }

    方法 取当前行号 <公开 静态 类型 = 整数 注释 = "获取当前语句调用时所在位置的行号" @嵌入式方法 = "">
    {
        @ (@dt<整数>)__LINE__
    }

    方法 取当前方法名 <公开 静态 类型 = 文本型 注释 = "获取当前语句调用时所在位置的方法名" @嵌入式方法 = "">
    {
        @ @dt<文本型>(plog::util::processFuncName(PLOG_GET_FUNC()).c_str())
    }

    方法 取当前文件名 <公开 静态 类型 = 文本型 注释 = "获取当前语句调用时所在位置的文件名" @嵌入式方法 = "" @视窗.预定义宏 = "PLOG_CAPTURE_FILE">
    {
        @ @dt<文本型>(PLOG_GET_FILE())
    }

    方法 取当前线程标识 <公开 静态 类型 = 整数 注释 = "获取当前语句调用时所在位置的线程ID" @嵌入式方法 = "">
    {
        @ (@dt<整数>)plog::util::gettid()
    }
}

类 日志格式 <公开 基础类 = 对象类 注释 = "日志格式预设基础类,仅用于规范参数数据类型,无实际作用" @文档 = "category = \"日志格式类\"" @禁止创建对象 = 真>

