<火山程序 类型 = "通常" 版本 = 1 />

包 火山.日志 <注释 = "开源地址:https://github.com/SergiusTheBest/plog"
        注释 = "开源许可:https://github.com/SergiusTheBest/plog/blob/master/LICENSE" @视窗.头文件搜寻目录 = "include" @视窗.外部头文件 = "<plog/Log.h>"
        "">

类 日志级别 <公开 注释 = "日志输出级别" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 通常 <公开 值 = @"@ plog::Severity::none" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常]\"以上任意一个成员时则进行输出处理">
    常量 致命 <公开 值 = @"@ plog::Severity::fatal" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命]\"以上任意一个成员时则进行输出处理">
    常量 错误 <公开 值 = @"@ plog::Severity::error" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命,错误]\"以上任意一个成员时则进行输出处理">
    常量 警告 <公开 值 = @"@ plog::Severity::warning" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命,错误,警告]\"以上任意一个成员时则进行输出处理">
    常量 信息 <公开 值 = @"@ plog::Severity::info" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命,错误,警告,信息]\"以上任意一个成员时则进行输出处理">
    常量 调试 <公开 值 = @"@ plog::Severity::debug" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命,错误,警告,信息,调试]\"以上任意一个成员时则进行输出处理">
    常量 详细 <公开 值 = @"@ plog::Severity::verbose" 注释 = "如\"初始化\"时填入的级别为当前值,且\"输出\"时级别为\"[通常,致命,错误,警告,信息,调试,详细]\"以上任意一个成员时则进行输出处理">
}

类 日志输出模式 <公开 注释 = "控制台日志输出流类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 标准输出 <公开 值 = @"@ plog::OutputStream::streamStdOut" 注释 = "在默认情况下当前模式为\"行缓冲\",通常只有遇到换行符或缓冲区满时内容才会输出到屏幕">
    常量 标准错误 <公开 值 = @"@ plog::OutputStream::streamStdErr" 注释 = "在默认情况下当前模式为\"无缓冲\",内容将直接输出到屏幕">
}

类 日志类 <公开 基础类 = 对象类 注释 = "当前类为日志对象基本类,输出日志前必须使用当前类进行初始化" @文档 = "category = \"单日志类\"" @禁止创建对象 = 真>
{
    方法 初始化文件 <公开 静态 类型 = 日志记录器 注释 = "初始化滚动轮替文件的日志实例" @嵌入式方法 = "" @视窗.外部头文件 = "<plog/Initializers/RollingFileInitializer.h>">
    参数 接收级别 <类型 = 日志级别 注释 = "日志文件接收的级别,级别越高能接收的输出级别就越多." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释." @默认值 = 日志级别.通常>
    参数 格式对象 <类型 = 日志格式 注释 = "日志输出的数据格式,可使用\"日志格式预设_XXX\"也可使用以\"日志格式模板\"为基础类的模板实现类." @需求类型 = 数据类型>
    参数 文件名称 <类型 = 文本型 注释 = "表示初始文件名,如果已开启了文件滚动功能则需新建文件时将在文件名后(扩展名前)自动加入文件序号." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0."
            @默认值 = "default.log">
    参数 最大长度 <类型 = 变整数 注释 = "表示单文件最大长度(单位为字节),如果文件大于或等于设定的大小将创建新文件,后续内容将输出到新文件." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0."
            @默认值 = 0>
    参数 最大数量 <类型 = 整数 注释 = "表示允许最大存在的文件数,如果超过这个数量文件将进行循环轮替(替换之前的旧文件)." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0." @默认值 = 0>
    {
        @ @dt<日志记录器><PLOG_DEFAULT_INSTANCE_ID>(plog::init<@<格式对象>>((plog::Severity)@<接收级别>, (const plog::util::nchar*)@<文件名称>, (size_t)@<最大长度>, (int)@<最大数量>))
    }

    方法 初始化控制台 <公开 静态 类型 = 日志记录器 注释 = "初始化带颜色的控制台实例" @嵌入式方法 = "" @视窗.外部头文件 = "<plog/Initializers/ConsoleInitializer.h>">
    参数 接收级别 <类型 = 日志级别 注释 = "日志文件接收的级别,级别越高能接收的输出级别就越多." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释." @默认值 = 日志级别.通常>
    参数 格式对象 <类型 = 日志格式 注释 = "日志输出的数据格式,可使用\"日志格式预设_XXX\"也可使用以\"日志格式模板\"为基础类的模板实现类." @需求类型 = 数据类型>
    参数 输出模式 <类型 = 日志输出模式 注释 = "控制台日志输出流类型,详情介绍可见\"日志输出模式\"类." @默认值 = 日志输出模式.标准输出>
    {
        @ @dt<日志记录器><PLOG_DEFAULT_INSTANCE_ID>(&plog::init<@<格式对象>>((plog::Severity)@<接收级别>, (plog::OutputStream)@<输出模式>))
    }
}

类 日志输出 <公开 基础类 = 对象类 注释 = "当前类主要用于输出日志,输出日志前必须使用\"日志类.初始化XXX()\"进行初始化" @文档 = "category = \"单日志类\"" @禁止创建对象 = 真>
{
    方法 指定级别 <公开 静态 注释 = "输出指定级别的日志" @嵌入式方法 = "">
    参数 输出级别 <类型 = 日志级别 注释 = "日志输出的级别,必须大于或等于初始化时的级别,否则将不进行输出." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG(@<输出级别>) << @<输出内容>
    }

    方法 通常 <公开 静态 注释 = "输出日志级别为\"通常\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_NONE << @<输出内容>
    }

    方法 致命 <公开 静态 注释 = "输出日志级别为\"致命\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_FATAL << @<输出内容>
    }

    方法 错误 <公开 静态 注释 = "输出日志级别为\"错误\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_ERROR << @<输出内容>
    }

    方法 警告 <公开 静态 注释 = "输出日志级别为\"警告\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_WARNING << @<输出内容>
    }

    方法 信息 <公开 静态 注释 = "输出日志级别为\"信息\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_INFO << @<输出内容>
    }

    方法 调试 <公开 静态 注释 = "输出日志级别为\"调试\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_DEBUG << @<输出内容>
    }

    方法 详细 <公开 静态 注释 = "输出日志级别为\"详细\"的日志" @嵌入式方法 = "">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_VERBOSE << @<输出内容>
    }
}

类 日志条件输出 <公开 基础类 = 对象类 注释 = "与\"日志输出\"不同的是当前类支持了条件判断,当条件成立时才会输出日志" @文档 = "category = \"单日志类\"" @禁止创建对象 = 真>
{
    方法 指定级别 <公开 静态 注释 = "输出指定级别的日志" @嵌入式方法 = "">
    参数 输出级别 <类型 = 日志级别 注释 = "日志输出的级别,必须大于或等于初始化时的级别,否则将不进行输出." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释.">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_IF(@<输出级别>, @<输出条件>) << @<输出内容>
    }

    方法 通常 <公开 静态 注释 = "输出日志级别为\"通常\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_NONE_IF(@<输出条件>) << @<输出内容>
    }

    方法 致命 <公开 静态 注释 = "输出日志级别为\"致命\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_FATAL_IF(@<输出条件>) << @<输出内容>
    }

    方法 错误 <公开 静态 注释 = "输出日志级别为\"错误\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_ERROR_IF(@<输出条件>) << @<输出内容>
    }

    方法 警告 <公开 静态 注释 = "输出日志级别为\"警告\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_WARNING_IF(@<输出条件>) << @<输出内容>
    }

    方法 信息 <公开 静态 注释 = "输出日志级别为\"信息\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_INFO_IF(@<输出条件>) << @<输出内容>
    }

    方法 调试 <公开 静态 注释 = "输出日志级别为\"调试\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_DEBUG_IF(@<输出条件>) << @<输出内容>
    }

    方法 详细 <公开 静态 注释 = "输出日志级别为\"详细\"的日志" @嵌入式方法 = "">
    参数 输出条件 <类型 = 逻辑型 注释 = "输出条件,仅当条件成立(逻辑型值为\"真\")时才会输出日志.">
    参数 输出内容 <注释 = "欲输出的日志内容,可传入多个不同类型的数据内容." @匹配类型 = 通用基本型 @可扩展 = "d_text = \" << \"">
    {
        @ PLOG_VERBOSE_IF(@<输出条件>) << @<输出内容>
    }
}

类 多日志类 <公开 基础类 = 对象类 注释 = "与\"日志类\"不同的是当前类支持多个日志实例,且可指定操作某个日志实例" @文档 = "category = \"多日志类\"" @禁止创建对象 = 真>
{
    常量 默认标识 <公开 类型 = 整数 值 = @"@ PLOG_DEFAULT_INSTANCE_ID" 注释 = "当前版本默认ID值等于0">

    # @ <include>
    # @ #define PLOG_INIT_MULTTIINSTANCE(logger, id, formatter) logger<id>(plog::init<formatter, id>
    # @ </include>

    方法 初始化文件 <公开 静态 类型 = 日志记录器 注释 = "初始化滚动轮替文件的日志实例" @嵌入式方法 = "" @视窗.外部头文件 = "<plog/Initializers/RollingFileInitializer.h>">
    参数 日志标识 <类型 = 整数 注释 = "指示当前初始化的日志唯一性实例ID." 注释 = "注意:需自行确保ID的唯一性,不同的ID操作的日志实例也不同." @默认值 = 多日志类.默认标识 @需求类型 = 立即数或常量>
    参数 接收级别 <类型 = 日志级别 注释 = "日志文件接收的级别,级别越高能接收的输出级别就越多." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释." @默认值 = 日志级别.通常>
    参数 格式对象 <类型 = 日志格式 注释 = "日志输出的数据格式,可使用\"日志格式预设_XXX\"也可使用以\"日志格式模板\"为基础类的模板实现类." @需求类型 = 数据类型>
    参数 文件名称 <类型 = 文本型 注释 = "表示初始文件名,如果已开启了文件滚动功能则需新建文件时将在文件名后(扩展名前)自动加入文件序号." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0."
            @默认值 = "default.log">
    参数 最大长度 <类型 = 变整数 注释 = "表示单文件最大长度(单位为字节),如果文件大于或等于设定的大小将创建新文件,后续内容将输出到新文件." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0."
            @默认值 = 0>
    参数 最大数量 <类型 = 整数 注释 = "表示允许最大存在的文件数,如果超过这个数量文件将进行循环轮替(替换之前的旧文件)." 注释 = "注意:启用文件滚动功能需参数\"最大长度\"和\"最大数量\"均大于0." @默认值 = 0>
    {
        @ PLOG_INIT_MULTTIINSTANCE(@dt<日志记录器>, @<日志标识>, @<格式对象>)((plog::Severity)@<接收级别>, (const plog::util::nchar*)@<文件名称>, (size_t)@<最大长度>, (int)@<最大数量>))
    }

    方法 初始化控制台 <公开 静态 类型 = 日志记录器 注释 = "初始化带颜色的控制台实例" @嵌入式方法 = "" @视窗.外部头文件 = "<plog/Initializers/ConsoleInitializer.h>">
    参数 日志标识 <类型 = 整数 注释 = "指示当前初始化的日志唯一性实例ID." 注释 = "注意:需自行确保ID的唯一性,不同的ID操作的日志实例也不同." @默认值 = 多日志类.默认标识 @需求类型 = 立即数或常量>
    参数 接收级别 <类型 = 日志级别 注释 = "日志文件接收的级别,级别越高能接收的输出级别就越多." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释." @默认值 = 日志级别.通常>
    参数 格式对象 <类型 = 日志格式 注释 = "日志输出的数据格式,可使用\"日志格式预设_XXX\"也可使用以\"日志格式模板\"为基础类的模板实现类." @需求类型 = 数据类型>
    参数 输出模式 <类型 = 日志输出模式 注释 = "控制台日志输出流类型,详情介绍可见\"日志输出模式\"类." @默认值 = 日志输出模式.标准输出>
    {
        @ PLOG_INIT_MULTTIINSTANCE(@dt<日志记录器>, @<日志标识>, @<格式对象>)((plog::Severity)@<接收级别>, (plog::OutputStream)@<输出模式>))
    }
}

类 多日志输出 <公开 基础类 = 对象类 注释 = "与\"日志输出\"不同的是当前类支持多个日志实例,且可指定操作某个日志实例" @文档 = "category = \"多日志类\"" @禁止创建对象 = 真>
{
    方法 指定级别 <公开 静态 注释 = "输出指定级别的日志" @嵌入式方法 = "">
    参数 日志标识 <类型 = 整数 注释 = "指示当前输出的日志流向哪个实例ID." 注释 = "注意:需自行确保ID已初始化,不同的ID输出到的日志实例也不同." @默认值 = 多日志类.默认标识 @需求类型 = 立即数或常量>
    参数 输出级别 <类型 = 日志级别 注释 = "日志输出的级别,必须大于或等于初始化时的级别,否则将不进行输出." 注释 = "注意:级别高低可查看\"日志级别\"类中相关常量注释.">
