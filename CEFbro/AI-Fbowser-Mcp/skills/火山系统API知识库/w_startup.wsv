<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "本包中的内容用作提供火山程序启动代码" @文档 = "category = \"启动\"">

类 程序基础类 <公开 @别名 = "@an<CVolUserApp>" @禁止创建对象 = 真>

类 程序类 <公开 基础类 = 程序基础类 注释 = "用户定义的启动类必须直接或间接以此类作为基础类" @全局类 = 真 @禁止创建对象 = 真>
{
    方法 取程序 <公开 静态 类型 = 启动类 注释 = "返回系统自动建立的全局唯一的用户启动类实例对象" @嵌入式方法 = "" @视窗.返回参考 = 真>
    {
        @ (@dt<启动类>&)g_objVolApp.GetVolApp ()
    }

    方法 取全局对象 <公开 静态 类型 = 对象类 注释 = "  获取指定类型对象类的唯一性全局实例." 注释 = "  如果该类型的全局对象尚不存在,则自动创建一个新对象并记录到系统数组中返回,否则直接"
            注释 = "返回在系统数组中的已有全局类对象." 注释 = "  本方法支持在多线程环境中运行. 当用户程序退出时,系统将自动释放所有已有的全局对象." @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲获取对象类型 <类型 = 对象类 注释 = "提供所欲获取全局对象的类型" @需求类型 = 数据类型>
    {
        @ g_objVolApp.GetRefGlobalObject (VOL_RUNTIME_CLASS (@<所欲获取对象类型>))
    }

    方法 投递退出消息 <公开 静态 注释 = "  向Windows消息队列发送一个退出消息,通知其退出消息队列处理." 注释 = "  如果使用系统所提供的各种界面库,不需要调用本方法,否则在程序主窗口关闭的时候,"
            注释 = "需要调用本方法退出消息队列处理,否则程序将不会结束." @嵌入式方法 = "">
    参数 退出码 <类型 = 整数>
    {
        @ ::PostQuitMessage (@<退出码>)
    }

    方法 取用户程序名称 <公开 静态 类型 = 文本型 注释 = "返回在项目设置里面所设置的程序名称" @嵌入式方法 = "">
    {
        @ CVolConstString (_T_VOL_USER_APP_NAME)
    }

    方法 取用户程序版本号 <公开 静态 类型 = 小数 注释 = "返回在项目设置里面所设置的程序版本号" @嵌入式方法 = "">
    {
        @ _VOL_USER_APP_VERSION_NUMBER
    }

    方法 取用户程序次版本号 <公开 静态 类型 = 小数 注释 = "返回在项目设置里面所设置的程序次版本号" @嵌入式方法 = "">
    {
        @ _VOL_USER_APP_MINOR_VERSION_NUMBER
    }

    方法 取用户程序版本名 <公开 静态 类型 = 文本型 注释 = "返回在项目设置里面所设置的程序版本名称文本" @嵌入式方法 = "">
    {
        @ CVolConstString (_T_USER_APP_VERSION_NAME)
    }

    方法 取火山平台版本号 <公开 静态 类型 = 整数 注释 = "返回编译此程序时所使用的火山平台版本号" @嵌入式方法 = "">
    {
        @ _VOL_DEV_VERSION_NUMBER
    }

    # --
