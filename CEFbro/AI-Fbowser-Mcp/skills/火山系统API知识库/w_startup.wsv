    #             _NUM_SPEC_USER_CLASS_TYPES == NUM_ELEMENTS_OF (cs_aRuntimeClasses));
    #     return cs_aRuntimeClasses;
    # }
    # @end
}

# ===

类 窗口程序类 <公开 基础类 = 程序类 注释 = "基于窗口的用户程序的启动类可以选择以此类作为基础类" @禁止创建对象 = 真>
{
    方法 消息过滤 <公开 类型 = 逻辑型 注释 = "用户的启动类可以覆盖此方法以过滤处理程序中所有窗口的消息" 返回值注释 = "返回真表示允许消息继续向后传递并处理,返回假表示取消掉该消息的后续处理." @虚拟方法 = 可覆盖>
    参数 窗口句柄 <类型 = 变整数 注释 = "提供消息所对应的窗口句柄(HWND)">
    参数 消息值 <类型 = 整数 注释 = "提供消息的具体值">
    参数 消息参数1 <类型 = 变整数 注释 = "提供消息所附带的参数1的值">
    参数 消息参数2 <类型 = 变整数 注释 = "提供消息所附带的参数2的值">
    参数 消息地址 <类型 = 变整数 注释 = "提供消息的具体 MSG* 地址指针,用作备用.">
    {
        返回 (真)
    }

    方法 空闲 <公开 类型 = 逻辑型 注释 = "当系统正处于空闲状态时调用此方法,用户的启动类可以覆盖此方法以做一些后台处理工作."
            返回值注释 = "返回假,在此次空闲期间系统将不再调用本方法(可以降低 CPU 占用率),返回真则将继续调用." @虚拟方法 = 可覆盖>
    参数 已空闲时间 <类型 = 整数 注释 = "  提供自系统本次进入空闲状态后到现在所经过的空闲时间,单位为毫秒.用户程序在空闲状态" 注释 = "下所进行的大工作量操作最好等到此值较大时进行.">
    {
        返回 (假)
    }

    方法 即将退出 <公开 注释 = "用户的启动类可以覆盖此方法以在窗口程序退出前做一些清理工作" @虚拟方法 = 可覆盖>
}

# ---

类 动态库程序类 <公开 基础类 = 程序类 注释 = "动态链接库用户程序的启动类可以选择以此类作为基础类" @禁止创建对象 = 真>
{
    方法 入口通知 <公开 类型 = 逻辑型 注释 = "动态库的 DllMain 入口函数通知" @虚拟方法 = 可覆盖>
    参数 模块句柄 <类型 = 变整数 注释 = "动态库自身的模块句柄">
    参数 调用原因 <类型 = 整数>
    参数 保留指针 <类型 = 变整数>
    {
        返回 (真)
    }

    方法 将被卸载 <公开 注释 = "用户的启动类可以覆盖此方法以在动态链接库被卸载前做一些清理工作" @虚拟方法 = 可覆盖>

    方法 _调试入口 <公开 静态 注释 = "当使用火山DLL默认调试启动程序直接调试DLL时,本方法将在DLL加载后被自动调用." @编译条件 = "_VOL_DEBUG" @视窗.输出 = 真
            @输出名 = "_VolDllDebugEntry">
    {
        @ #if @n<启动类._调试入口方法, b>  // 用户程序中定义了"启动类._调试入口方法"?
        @     ((@sn<startup_class>&)g_objVolApp.GetVolApp ()).@n<启动类._调试入口方法, e> ();  // 调用该方法以进行功能测试
        @ #else
        调试输出 ("提示: 未找到欲调用的\"启动类._调试入口方法\". 可以使用\"编辑->插入->插入特定内容\"菜单功能,插入其中的\"方法->_调试入口方法\"到动态链接库程序的\"启动类\"中,然后将调试用代码放置进去. 调试启动后,此方法将被自动调用以进行相关功能测试,在编译项目发布版本时,此方法会被自动忽略.")
        @ #endif
    }
}

