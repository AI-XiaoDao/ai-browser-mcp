类 视窗通知持续类型 <公开 注释 = "指定了通知的持续时间类型." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 系统 <公开 值 = @"@WinToastLib::WinToastTemplate::Duration::System" 编辑时信息 = "0, 6FFF9, 0, 0">
    常量 短时间 <公开 值 = @"@WinToastLib::WinToastTemplate::Duration::Short">
    常量 长时间 <公开 值 = @"@WinToastLib::WinToastTemplate::Duration::Long">
}

类 视窗通知关闭原因 <公开 注释 = "指定了通知取消展示的原因类型." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 用户取消 <公开 值 = @"@WinToastLib::IWinToastHandler::WinToastDismissalReason::UserCanceled" 注释 = "表示被用户取消展示"
            编辑时信息 = "0, 6FFF9, 0, 0">
    常量 主动隐藏 <公开 值 = @"@WinToastLib::IWinToastHandler::WinToastDismissalReason::ApplicationHidden" 注释 = "表示应用程序自己主动隐藏">
    常量 超时关闭 <公开 值 = @"@WinToastLib::IWinToastHandler::WinToastDismissalReason::TimedOut" 注释 = "表示该通知已达到最大显示时间">
}
