类 代码编辑框折叠线显示类型 <公开 注释 = "提供折叠线的显示选项" @文档 = "category = \"辅助类\"">
{
    常量 "//不显示" <公开 类型 = 整数 值 = @SC_FOLDFLAG_NONE 注释 = "不显示任何折叠线,默认." 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 展开向上 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LINEBEFORE_EXPANDED 注释 = "如果是展开,则在上方绘制线." 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 未展开向上 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LINEBEFORE_CONTRACTED 注释 = "如果是未展开,则在上方绘制线." 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 展开向下 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LINEAFTER_EXPANDED 注释 = "如果是展开,则在下方绘制线." 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 未展开向下 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LINEAFTER_CONTRACTED 注释 = "如果是未展开,则在下方绘制线." 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 显示折叠级别 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LEVELNUMBERS 注释 = "显示出折叠级别的十六进制内容" 编辑时信息 = "0, 12CCBA, 0, 0">
    常量 显示行状态 <公开 类型 = 整数 值 = @SC_FOLDFLAG_LINESTATE 注释 = "显示出行的状态信息,不能与\'显示折叠级别\'共用." 编辑时信息 = "0, 12CCBA, 0, 0">
}

