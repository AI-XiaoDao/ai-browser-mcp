    }

    方法 切换指定行折叠状态及文本 <公开 注释 = "切换指定折叠点的折叠状态并显示一段标签文本在折叠内容的右侧">
    参数 行号 <类型 = 整数 注释 = "请提供折叠点所处的行号">
    参数 内容 <类型 = 文本型 注释 = "提供所欲显示的标签文本内容">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<内容>.GetText());
        @     pWnd->SendEditor(SCI_TOGGLEFOLDSHOWTEXT, (uptr_t)@<行号>, (sptr_t)str.GetText());
        @ }
    }

    方法 折叠行标签文本样式 <公开 属性写 注释 = "设置在折叠内容右侧显示的标签文本内容的显示样式">
    参数 样式 <类型 = 整数 注释 = "提供0表示使用默认,即不显示该标签文本,提供1即正常显示该标签文本,提供2即绘制一个矩形框包围该文本并显示.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_FOLDDISPLAYTEXTSETSTYLE, (uptr_t)@<样式>);
    }

    方法 "//折叠行标签文本样式" <公开 属性读 类型 = 整数 注释 = "获取在折叠内容右侧显示的标签文本内容的显示样式" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (INT)pWnd->SendEditor(SCI_FOLDDISPLAYTEXTGETSTYLE);
        @ return SC_FOLDDISPLAYTEXT_HIDDEN;
    }

    方法 "//折叠行标签文本内容" <公开 属性写 注释 = "设置在折叠内容右侧显示的标签文本内容">
    参数 内容 <类型 = 文本型>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<内容>.GetText());
        @     pWnd->SendEditor(SCI_SETDEFAULTFOLDDISPLAYTEXT, 0, (sptr_t)str.GetText());
        @ }
    }

    方法 "//折叠行标签文本内容" <公开 属性读 类型 = 文本型 注释 = "获取在折叠内容右侧显示的标签文本内容" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETDEFAULTFOLDDISPLAYTEXT) + 1;
        @     if (pWnd->SendEditor(SCI_GETDEFAULTFOLDDISPLAYTEXT, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 置指定行展开状态 <公开 注释 = "将指定行置为折叠或展开状态">
    参数 行号 <类型 = 整数 注释 = "提供所欲设置的行号">
    参数 展开 <类型 = 逻辑型 注释 = "提供真则展开该行,否则折叠该行.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_FOLDDISPLAYTEXTSETSTYLE, (uptr_t)@<行号>, (sptr_t)@<展开>);
    }

