        @     pWnd->SendEditor(SCI_STOPRECORD);
    }

    # 打印相关 ---

    方法 打印内容到指定设备 <公开 类型 = 整数 注释 = "将当前编辑框中指定范围的内容呈现到指定的目标设备上" 返回值注释 = "返回下一个要输出字符的位置" @禁止流程检查 = 真>
    参数 分页 <类型 = 逻辑型 注释 = "指定本次输出是否为分页,如果为真表示已完成了所有内容输出.">
    参数 设备句柄 <类型 = 变整数 注释 = "提供所欲接收输出内容的设备(打印机)句柄">
    参数 打印范围 <类型 = 矩形类 注释 = "提供所欲约定的打印输出范围">
    参数 物理范围 <类型 = 矩形类 注释 = "提供物理可打印输出(纸张)的范围">
    参数 内容起始位置 <类型 = 整数 注释 = "提供所欲打印输出当前编辑框中内容起始位置">
    参数 内容结束位置 <类型 = 整数 注释 = "提供所欲打印输出当前编辑框中内容结束位置">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     Sci_RangeToFormat stRangeToFormat;
        @     ZERO_MEM (&stRangeToFormat, sizeof (Sci_RangeToFormat));
        @     stRangeToFormat.hdc = (Sci_SurfaceID)@<设备句柄>;
        @     stRangeToFormat.hdcTarget = (Sci_SurfaceID)@<设备句柄>;    //Windows下打印必定一致
        @     Sci_Rectangle stRectangle, stRectanglePage;
        @     CopyFromVolRect(stRectangle, &@<打印范围>);
        @     CopyFromVolRect(stRectanglePage, &@<物理范围>);
        @     stRangeToFormat.rc = stRectangle;
        @     stRangeToFormat.rcPage = stRectanglePage;
        @     Sci_CharacterRange stCharacterRange = {0};
        @     stCharacterRange.cpMin = (INT)@<内容起始位置>;
        @     stCharacterRange.cpMax = (INT)@<内容结束位置>;
        @     stRangeToFormat.chrg = stCharacterRange;
        @     return (INT)pWnd->SendEditor(SCI_FORMATRANGE, (uptr_t)@<分页>, (sptr_t)&stRangeToFormat);
        @ }
        @ return -1;
    }

    方法 打印内容字体缩放 <公开 属性写 注释 = "指定打印输出内容时字体所欲使用当前系统字体的缩放比例">
    参数 缩放 <类型 = 整数 注释 = "提供大于0表示放大,小于0表示缩小,譬如:-3表示将当前系统字体尺寸缩小3倍后打印.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETPRINTMAGNIFICATION, (uptr_t)@<缩放>);
    }

    方法 打印内容字体缩放 <公开 属性读 类型 = 整数 注释 = "指定打印输出内容时字体所欲使用当前系统字体的缩放比例" @禁止流程检查 = 真>
    {
