        @     return (INT)pWnd->SendEditor(SCI_GETPRINTMAGNIFICATION);
        @ return 0;
    }

    方法 打印内容换行模式 <公开 属性写 注释 = "指定打印输出内容时所使用的内容换行模式">
    参数 模式 <类型 = 逻辑型 注释 = "提供真表示确保每行的结尾都将完整考虑单词完整性,提供假则不考虑单词直接换行.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETPRINTWRAPMODE, (uptr_t)(@<模式> ? SC_WRAP_WORD : SC_WRAP_NONE));
    }

    方法 打印内容换行模式 <公开 属性读 类型 = 逻辑型 注释 = "获取打印输出内容时所使用的内容换行模式" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (BOOL)pWnd->SendEditor(SCI_GETPRINTWRAPMODE);
        @ return SC_WRAP_NONE;
    }

