    方法 自动补全列表现行选中内容 <公开 属性读 类型 = 文本型 注释 = "获取自动补全列表中当前所选中候选词的内容" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_AUTOCGETCURRENTTEXT) + 1;
        @     if (pWnd->SendEditor(SCI_AUTOCGETCURRENTTEXT, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

