    方法 单词字符内容 <公开 属性读 类型 = 文本型 注释 = "获取所设置的单词字符内容" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETWORDCHARS) + 1;
        @     if (pWnd->SendEditor(SCI_GETWORDCHARS, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

