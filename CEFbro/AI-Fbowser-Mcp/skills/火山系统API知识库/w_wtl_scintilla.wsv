类 查找选项类型 <公开 注释 = "提供使用查找功能时的选项." @文档 = "category = \"辅助类\"">
{
    常量 "//无" <公开 类型 = 整数 值 = @SCFIND_NONE>
    常量 区分大小写 <公开 类型 = 整数 值 = @SCFIND_MATCHCASE 注释 = "与搜索词大小写完全一致时匹配.">
    常量 匹配全词 <公开 类型 = 整数 值 = @SCFIND_WHOLEWORD 注释 = "搜索词前后字符不是定义的文字字符时匹配.">
    常量 匹配开始 <公开 类型 = 整数 值 = @SCFIND_WORDSTART 注释 = "搜索词之前的字符不是定义的文字字符时匹配.">
    常量 正则表达式 <公开 类型 = 整数 值 = @SCFIND_REGEXP 注释 = "指示搜索词是一个正则表达式,以正则匹配的方式搜索.">
    常量 兼容正则模式 <公开 类型 = 整数 值 = @SCFIND_POSIX 注释 = "POSIX兼容模式的正则表达式匹配,例如使用(*)而不需要使用/(*/).">
    常量 CPP正则表达式 <公开 类型 = 整数 值 = @SCFIND_CXX11REGEX 注释 = "使用C++11中的<regex>代替本库的基本正则表达式.">
}

