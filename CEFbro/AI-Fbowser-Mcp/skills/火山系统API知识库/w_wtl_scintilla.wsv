类 "//词法分析器" <公开 注释 = "提供内置的词法分析器相关支持" @视窗.附属文件.non_static = "..\\scintilla\\lib\\$(p)\\lexilla.dll"
        @视窗.外部库.non_static = "..\\scintilla\\lib\\$(p)\\lexilla.lib"
        @视窗.外部库.static = "..\\scintilla\\lib\\$(p)\\liblexilla-$(d).lib" @强制依赖 = "火花代码编辑框" @文档 = "category = \"辅助类\"">
{
    方法 取内置词法分析器数量 <公开 静态 类型 = 整数 注释 = "获取当前词法分析器库所支持的分析器数量" @嵌入式方法 = "">
    {
        @ GetLexerCount()
    }

    方法 取指定索引处名称 <公开 静态 类型 = 文本型 注释 = "提供指定索引,返回该索引处对应的词法分析器的名称." @禁止流程检查 = 真>
    参数 索引 <类型 = 整数 注释 = "所提供索引值必须大于等于0且小于\"取内置词法分析器数量\"所返回的数量.">
    {
        @ CVolMem memBuf;
        @ GetLexerName(@<索引>, (char*)memBuf.Alloc(128, TRUE), 127);
        @ return @an<CVolString> ((const CHAR*)memBuf.GetPtr ());
    }

    方法 创建自名称 <公开 静态 类型 = 变整数 注释 = "根据指定词法分析器名称创建该词法分析器" 返回值注释 = "创建失败返回0" @嵌入式方法 = "">
    参数 名称 <类型 = 文本型 注释 = "提供所欲创建分析器的名称,例如\"cpp\".">
    {
        @ (INT_P)CreateLexer((const char*)CU8String(@<名称>.GetText()).GetText())
    }

    方法 创建自索引 <公开 静态 类型 = 变整数 注释 = "根据指定词法分析器的索引创建对应的词法分析器" 返回值注释 = "创建失败返回0">
    参数 索引 <类型 = 整数 注释 = "所提供索引值必须大于等于0且小于\"取内置词法分析器数量\"所返回的数量.">
    {
        返回 (创建自名称 (取指定索引处名称 (索引)))
    }
}
