        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (INT)pWnd->SendEditor(SCI_PROPERTYTYPE, (uptr_t)CU8String(@<属性名称>.GetText()).GetText());
        @ return 0;
    }

    方法 取词法分析器属性描述 <公开 类型 = 文本型 注释 = "获取当前所使用词法分析器指定属性的内容描述" @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲获取其描述内容的属性名">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     CU8String name(@<属性名称>.GetText());
        @     sptr_t len = pWnd->SendEditor(SCI_DESCRIBEPROPERTY, (uptr_t)name.GetText()) + 1;
        @     if (pWnd->SendEditor(SCI_DESCRIBEPROPERTY, (uptr_t)name.GetText(), (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 置词法分析器属性值 <公开 注释 = "设置当前词法分析器指定属性的值">
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲设置其值的属性名">
    参数 属性值 <类型 = 文本型 注释 = "提供所欲设置的值内容,可参考文档\"https://www.scintilla.org/ScintillaDoc.html#SCI_SETPROPERTY\".">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETPROPERTY, (uptr_t)CU8String(@<属性名称>.GetText()).GetText(), (sptr_t)CU8String(@<属性值>.GetText()).GetText());
    }

    方法 取词法分析器属性值 <公开 类型 = 文本型 注释 = "获取当前词法分析器指定属性的值" @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲设置其值的属性名">
    参数 关键词替换 <类型 = 逻辑型 注释 = "指定是否执行\"关键词替换\",详细说明请参考\"https://www.scintilla.org/ScintillaDoc.html#SCI_SETPROPERTY\"." @默认值 = 假>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     CU8String name(@<属性名称>.GetText());
        @     UINT cmd = @<关键词替换> ? SCI_GETPROPERTYEXPANDED : SCI_GETPROPERTY;
        @     sptr_t len = pWnd->SendEditor(cmd, (uptr_t)name.GetText()) + 1;
        @     if (pWnd->SendEditor(cmd, (uptr_t)name.GetText(), (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 置词法分析器关键字列表 <公开 注释 = "设置指定的关键词列表供当前的词法分析器使用">
