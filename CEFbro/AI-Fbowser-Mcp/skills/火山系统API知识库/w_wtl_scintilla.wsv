    方法 查找指定内容2 <公开 类型 = 整数 注释 = "  提供指定搜索选项,以及查找的范围查找指定子文本,找" 注释 = "到后返回该子文本首次出现的首索引位置." 返回值注释 = "  如果搜到指定内容则返回该内容在当前文档中的起始位置,"
            返回值注释 = "未找到则返回-1." @禁止流程检查 = 真>
    参数 查找选项 <类型 = 整数 注释 = "  提供所欲使用的查找选项,请参考\"查找选项类型\"所提供的常" 注释 = "量值.">
    参数 起始位置 <类型 = 整数 注释 = "提供查找的起始位置.">
    参数 结束位置 <类型 = 整数 注释 = "提供查找的结束位置.">
    参数 欲查找内容 <类型 = 文本型 注释 = "提供所欲搜索的内容(表达式).">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<欲查找内容>.GetText ());
        @     Sci_TextToFind find;
        @     find.chrg.cpMin = (Sci_PositionCR)@<起始位置>;
        @     find.chrg.cpMax = (Sci_PositionCR)@<结束位置>;
        @     find.lpstrText = (const char *)u8str.GetText();
        @     return (INT)pWnd->SendEditor(SCI_FINDTEXT, (uptr_t)@<查找选项>, (sptr_t)&find);
        @ }
        @ return -1;
    }

