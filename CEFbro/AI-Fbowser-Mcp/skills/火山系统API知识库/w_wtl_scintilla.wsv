    # 代指字符 ---

    方法 置指定内容替换符 <公开 注释 = "  为了使编辑框中正确区分所有不同的内容(例如一些控制字符,无效字节,没有" 注释 = "固定的字形或难以区分的字形),通过本方法以设置其代替显示的内容.">
    参数 源内容 <类型 = 文本型 注释 = "提供编码后的源文本内容,例如欧米伽符号:\"\\xe2\\x84\\xa6\".">
    参数 显示内容 <类型 = 文本型 注释 = "提供替换后所欲显示出来的文本内容,例如:\"\\xe2\\x84\\xa6\",最大不能超过200字节.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<源内容>.GetText());
        @     CU8String rep(@<显示内容>.GetText());
        @     pWnd->SendEditor(SCI_SETREPRESENTATION, (uptr_t)str.GetText(), (sptr_t)rep.GetText());
        @ }
    }

    方法 取指定内容替换符 <公开 类型 = 文本型 注释 = "获取指定内容的代替显示内容" @禁止流程检查 = 真>
    参数 源内容 <类型 = 文本型 注释 = "提供编码后的源文本内容,例如欧米伽符号:\"\\xe2\\x84\\xa6\".">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     CU8String str(@<源内容>.GetText());
        @     sptr_t len = pWnd->SendEditor(SCI_GETREPRESENTATION, (uptr_t)str.GetText()) + 1;
        @     if (pWnd->SendEditor(SCI_GETREPRESENTATION, (uptr_t)str.GetText(), (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 清除指定内容替换符 <公开 注释 = "清除指定内容的代替显示内容">
    参数 源内容 <类型 = 文本型 注释 = "提供编码后的源文本内容,例如欧米伽符号:\"\\xe2\\x84\\xa6\".">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<源内容>.GetText());
        @     pWnd->SendEditor(SCI_CLEARREPRESENTATION, (uptr_t)str.GetText());
        @ }
    }

