    方法 置自动补全像素图像数据 <公开 注释 = "  设置在自动补全列表中使用的图像数据,支持设置多种图像,以不同的\"类型\"参数加以区分."
            注释 = "  譬如:正常候选词内容为\"候选词A 候选词B 候选词C\",欲将类型为1的图像数据设置给" 注释 = "候选词A,带图像数据的候选词即需改为\"候选词A?1 候选词B 候选词C\",即在需要显示图像的"
            注释 = "候选词尾部加上\'?类型\'即可完成图像与候选词的关联.">
    参数 类型 <类型 = 整数 注释 = "提供该图像所欲注册的类型,在候选词内容中使用该类型文本来关联不同的图像数据.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供所欲设置的像素图像数据,该图像格式数据请参考\"https://www.scintilla.org/ScintillaDoc.html#XPM\".">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_REGISTERIMAGE, (uptr_t)@<类型>, (sptr_t)@<图像数据>.GetPtr());
    }

