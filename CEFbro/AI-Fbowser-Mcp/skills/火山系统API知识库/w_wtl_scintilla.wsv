    方法 "//取新建文档选项" <公开 类型 = 整数 注释 = "返回用于创建文档的选项" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (INT)pWnd->SendEditor(SCI_GETDOCUMENTOPTIONS);
        @ return SC_DOCUMENTOPTION_DEFAULT;
