    方法 "//字体语言环境" <公开 属性写 注释 = "使用依赖于语言的字形设置用于字体选择的语言环境">
    参数 语言环境 <类型 = 文本型 注释 = "提供所欲设置的语言环境,例如\"en-us\"表示英语,\"zh-Hans\"表示简体中文等.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<语言环境>.GetText ());
        @     pWnd->SendEditor(SCI_SETFONTLOCALE, 0, (sptr_t)u8str.GetText());
        @ }
    }

    方法 "//字体语言环境" <公开 属性读 类型 = 文本型 注释 = "获取所设置的字体语言环境" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETFONTLOCALE) + 1;
        @     if (pWnd->SendEditor(SCI_GETFONTLOCALE, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

