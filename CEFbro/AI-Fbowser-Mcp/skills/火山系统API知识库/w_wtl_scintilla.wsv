    方法 词法分析器名称 <公开 属性读 类型 = 文本型 注释 = "获取当前所使用的内置词法分析器名称" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETLEXERLANGUAGE) + 1;
        @     if (pWnd->SendEditor(SCI_GETLEXERLANGUAGE, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

