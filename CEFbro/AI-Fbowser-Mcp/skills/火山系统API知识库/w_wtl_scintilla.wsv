    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     uptr_t len = pWnd->SendEditor(SCI_GETSELTEXT) + 1;
        @     if (pWnd->SendEditor(SCI_GETSELTEXT, 0, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

