<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.窗口组件

类 火花代码编辑框 <公开 基础类 = 窗口组件 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "Scintilla火花编辑框,代码/文本编辑框." 注释 = "默认使用UTF8代码页(Unicode)."
        @视窗.窗口组件 = "icon=\"@56\"\r\ndefault_size = \"500, 300\"" @视窗.后缀文本 = "public IScintillaEventListener"
        @视窗.附属文件.non_static = "..\\scintilla\\lib\\$(p)\\SciLexer.dll"
        @视窗.外部库.static = "..\\scintilla\\lib\\$(p)\\libscintilla-$(d).lib" @视窗.预定义宏.static = "_VOL_SCINTILLA_STATIC"
        @视窗.头文件搜寻目录 = "..\\scintilla\\lib\\include" @视窗.外部头文件 = "src\\wtl_ui_scintilla.h" @视窗.外部源文件 = "src\\wtl_ui_scintilla.cpp"
        @视窗.需求VS版本.static = "16-">
{

    # @begin
    # @m<DECLARE_WTL_CONTROL_DEFAULT> (CVWnd_Scintilla, IScintillaEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # <> <include>
    # virtual void OnSavePointChange ()  { @<保存点已改变> (); }
    # virtual void OnSavePointLeft ()  { @<已离开保存点> (); }
    # virtual void OnModifyAttemptRo ()  { @<只读模式尝试内容更改> (); }
    # virtual void OnMarginLeftClick (int modifiers, Sci_Position position, int margin)  { @<旁注被左键单击> ((INT)position, margin, modifiers); }
    # virtual void OnMarginRightClick (int modifiers, Sci_Position position, int margin)  { @<旁注被右键单击> ((INT)position, margin, modifiers); }
    # virtual void OnAutocSelection (Sci_Position position, const char *text, int ch, int listCompletionMethod)
    # {
    #     if (@<自动补全列表被选择> ((INT)position, CVolString ((const CHAR*)text), ch, listCompletionMethod) != 0)    //取消补全?
    #         @<关闭自动补全列表>();
    # }
    # virtual void OnUserListSelection (int listType, Sci_Position position, const char *text, int ch, int listCompletionMethod)  { @<用户列表被选择>(listType, (INT)position, CVolString(text), ch, listCompletionMethod); }
    # virtual void OnMacroRecord (int message, uptr_t wParam, sptr_t lParam) { @<宏录制记录动作>(message, (INT_P)wParam, (INT_P)lParam); }
    # //virtual void OnCharAdded (int characterSource, int ch) { @<已键入普通文本字符>(characterSource, ch); }
    # virtual void OnCharAdded (int ch) { @<已键入普通文本字符>(ch); }
    # virtual void OnDoubleClick (Sci_Position position, Sci_Position line, int modifiers) { @<内容被双击>((INT)position, (INT)line, modifiers); }
    # virtual void OnUpdateUI (int updated) { @<文档界面已更新>(updated); }
    # virtual void OnPainted () { @<已绘制完毕>(); }
    # virtual void OnDwellStart (Sci_Position position, int x, int y)  { @<鼠标开始悬停>((INT)position, x, y); }
    # virtual void OnDwellEnd (Sci_Position position, int x, int y)  { @<鼠标结束悬停>((INT)position, x, y); }
    # virtual void OnZoom ()  { @<缩放系数已改变>(); }
    # virtual void OnHotspotClick (Sci_Position position, int modifiers)  { @<点燃内容被单击>((INT)position, modifiers); }
    # virtual void OnHotspotDoubleClick (Sci_Position position, int modifiers)  { @<点燃内容被双击>((INT)position, modifiers); }
    # virtual void OnHotspotReleaseClick (Sci_Position position, int modifiers)  { @<点燃内容已释放点击>((INT)position, modifiers); }
    # virtual void OnIndicatorClick (Sci_Position position, int modifiers)  { @<指示器被单击>((INT)position, modifiers); }
    # virtual void OnIndicatorRelease (Sci_Position position, int modifiers)  { @<指示器已释放点击>((INT)position, modifiers); }
    # virtual void OnCallTipClick (Sci_Position position)  { @<悬浮提示被单击>((INT)position); }
    # virtual void OnAutoCCancelled ()  { @<自动补全列表被关闭>(); }
    # virtual void OnAutoCCharDeleted ()  { @<自动补全状态内容被删除>(); }
    # virtual void OnAutoCCompleted (Sci_Position position, const char *text, int ch, int listCompletionMethod)  { @<自动补全已完成>((INT)position, CVolString ((const CHAR*)text), ch, listCompletionMethod); }
    # virtual void OnAutoCSelectionChange (int listType, const char* text, Sci_Position position)  { @<自动补全列表选中项改变>(listType, CVolString ((const CHAR*)text), (INT)position); }
    # //MOD事件
    # virtual void OnChangeLineState (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<行状态值已改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnInsertText (Sci_Position position, Sci_Position length, const char* text, Sci_Position linesAdded, int eventSoure, bool multiStep, bool lastStep, bool startAction) { @<内容已插入>((INT)position, (INT)length, CVolString(text), (INT)linesAdded, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnDeleteText (Sci_Position position, Sci_Position length, const char* text, Sci_Position linesAdded, int eventSoure, bool multiStep, bool lastStep, bool startAction) { @<内容已删除>((INT)position, (INT)length, CVolString(text), (INT)linesAdded, eventSoure, multiStep, lastStep, startAction);  }
    # virtual void OnChangeStyle (Sci_Position position, Sci_Position length, int eventSoure, bool multiStep, bool lastStep, bool startAction) { @<样式被改变>((INT)position, (INT)length, eventSoure, multiStep, lastStep, startAction);  }
    # virtual void OnChangeFold (Sci_Position line, int foldLevelNow, int foldLevelPrev, int eventSoure, bool multiStep, bool lastStep, bool startAction) { @<折叠级别被改变>((INT)line, foldLevelNow, foldLevelPrev, eventSoure, multiStep, lastStep, startAction);  }
    # virtual void OnChangeMarker (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<标记被改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnInsertCheck (Sci_Position position, Sci_Position length, const char* text, int eventSoure, bool multiStep, bool lastStep, bool startAction) { @<内容插入前检查> ((INT)position, (INT)length, CVolString(text), eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnChangeMargin (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<文本旁注内容已改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnChangeAnnotation (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<注释内容已改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnChangeEolAnnotation (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<行尾注释内容已改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnChangeTabStops (Sci_Position line, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<显式制表符已改变> ((INT)line, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnBeforeInsert (Sci_Position position, Sci_Position length, const char* text, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<即将插入内容> ((INT)position, (INT)length, CVolString(text), eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnBeforeDelete (Sci_Position position, Sci_Position length, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<即将删除内容> ((INT)position, (INT)length, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnChangeIndicator (Sci_Position position, Sci_Position length, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<指示器被改变> ((INT)position, (INT)length, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnLexerState (Sci_Position position, Sci_Position length, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<词法分析器状态被改变> ((INT)position, (INT)length, eventSoure, multiStep, lastStep, startAction); }
    # virtual void OnContainer (int token, int eventSoure, bool multiStep, bool lastStep, bool startAction)  { @<撤销堆栈已改变> (token, eventSoure, multiStep, lastStep, startAction); }
    #
    # //其他 ---
    # static void @an<_sOnBeforeAppInit> () { CVWnd_Scintilla::RegisterScintilla(); }
    # static void @an<_sOnAfterAppExit> () { CVWnd_Scintilla::ReleaseScintilla(); }
    #
    # static void CopyFromVolRect(Sci_Rectangle& sci_rect, const @dt<矩形类>* prtCopy);
    # <> </include>
    #
    # void @sn<current_class>::CopyFromVolRect(Sci_Rectangle& sci_rect, const @dt<矩形类>* prtCopy)
    # {
    #     sci_rect.left = prtCopy->@n<矩形类.左边>;
    #     sci_rect.top = prtCopy->@n<矩形类.顶边>;
    #     sci_rect.right = prtCopy->@n<矩形类.右边>;
    #     sci_rect.bottom = prtCopy->@n<矩形类.底边>;
    # }
    #
    # @end
    # 内容控制 ---

    方法 内容 <公开 属性写 注释 = "设置当前编辑框中的文本内容.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲写入的文本内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_SETTEXT, 0, (sptr_t)u8str.GetText ());
        @ }
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "获取当前编辑框中的文本内容." @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETTEXTLENGTH) + 1;
        @     if (pWnd->SendEditor(SCI_GETTEXT, len, (sptr_t)memBuf.Alloc(len + 1, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 置为保存点 <公开 注释 = "  将当前编辑框中文档标记为保存点,当执行撤销或重做时," 注释 = "将会触发\"保存点已触发\"及\"已离开保存点\"事件.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETSAVEPOINT);
    }

    方法 取指定行内容 <公开 类型 = 文本型 注释 = "获取当前编辑框中指定行的文本内容." @禁止流程检查 = 真>
    参数 行号 <类型 = 变整数 注释 = "提供所欲获取其内容的行号.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_GETLINE, @<行号>, NULL) + 1;
        @     if (pWnd->SendEditor(SCI_GETLINE, @<行号>, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 替换选择内容 <公开 注释 = "  将当前被选中的文本内容替换为指定的内容,如果未选中任何" 注释 = "内容,将会置入该内容到锚点所处位置." 注释 = "  注意:如果替换后内容超出当前编辑框的可视范围,将会自动"
            注释 = "进行滚动显示.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲替换选中内容的新文本.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_REPLACESEL, 0, (sptr_t)u8str.GetText ());
        @ }
    }

    方法 只读 <公开 属性写 注释 = "指定当前编辑框中文档内容是否只读(不可被用户所编辑).">
    参数 启用 <类型 = 逻辑型>
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本?
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETREADONLY, (uptr_t)@<启用>);    //避免影响设计效果,设计器中始终可读写
        @ #endif
    }

    方法 只读 <公开 属性读 类型 = 逻辑型 注释 = "获取当前编辑框中文档内容是否为只读(不可被用户所编辑)." 返回值注释 = "返回真表示只读,反之可读写." @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (BOOL)pWnd->SendEditor(SCI_GETREADONLY);
        @ return FALSE;
    }

    方法 取指定长度内容 <公开 类型 = 文本型 注释 = "获取当前编辑框中指定长度的文本内容." @禁止流程检查 = 真>
    参数 长度 <类型 = 整数 注释 = "指定所欲获取文本内容的长度,单位:字节.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)    //m_fnDirect && m_ptrDirect 必定不为NULL
        @ {
        @     CVolMem memBuf;
        @     if (pWnd->SendEditor(SCI_GETTEXT, (uptr_t)@<长度> + 1, (sptr_t)memBuf.Alloc(@<长度> + 1, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 取指定范围内容 <公开 类型 = 文本型 注释 = "获取当前编辑框中指定区域内的文本内容." 返回值注释 = "返回所指定区域内的文本内容." @禁止流程检查 = 真>
    参数 起始位置 <类型 = 整数 注释 = "提供所欲获取文本区域的起始位置,单位:字节.">
    参数 结束位置 <类型 = 整数 注释 = "提供所欲获取文本区域的结束位置,单位:字节.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL && (@<结束位置> - @<起始位置> > 0))
        @ {
        @     Sci_TextRange mTextRange;
        @     CVolMem memBuf;
        @     mTextRange.lpstrText = (char*)memBuf.Alloc(@<结束位置> - @<起始位置> + 1, TRUE);
        @     mTextRange.chrg.cpMin = (Sci_PositionCR)@<起始位置>;
        @     mTextRange.chrg.cpMax = (Sci_PositionCR)@<结束位置>;
        @     if (pWnd->SendEditor(SCI_GETTEXTRANGE, 0, (sptr_t)&mTextRange) > 0)
        @         return @an<CVolString>((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

    方法 取指定区域样式数据 <公开 类型 = 字节集类 注释 = "获取当前编辑框中指定区域内的样式内容." 返回值注释 = "返回所指定区域内的样式文本内容." @禁止流程检查 = 真>
    参数 起始位置 <类型 = 整数 注释 = "提供所欲获取文本区域的起始位置,单位:字节.">
    参数 结束位置 <类型 = 整数 注释 = "提供所欲获取文本区域的结束位置,单位:字节.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ CVolMem memBuf;
        @ if (pWnd->m_hWnd != NULL && (@<结束位置> - @<起始位置> > 0))
        @ {
        @     Sci_TextRange mTextRange;
        @     mTextRange.lpstrText = (char*)memBuf.Alloc(2 * (@<结束位置> - @<起始位置>) + 2, TRUE);
        @     mTextRange.chrg.cpMin = (Sci_PositionCR)@<起始位置>;
        @     mTextRange.chrg.cpMax = (Sci_PositionCR)@<结束位置>;
        @     sptr_t len = pWnd->SendEditor(SCI_GETSTYLEDTEXT, 0, (sptr_t)&mTextRange);
        @     if (len > 0)
        @         memBuf.Realloc(len);
        @ }
        @ return memBuf;
    }

    方法 分配缓冲区 <公开 注释 = "分配足够大的缓冲区,以容纳指定大小的字节.">
    参数 尺寸 <类型 = 整数 注释 = "单位:字节">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_ALLOCATE, (uptr_t)@<尺寸>);
    }

    方法 添加内容 <公开 注释 = "  在当前编辑框中当前光标位置处插入文本内容." 注释 = "注意:如果所添加内容超出当前编辑框的可视范围,将不会自动滚动显示.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲插入的文本内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_ADDTEXT, (uptr_t)u8str.GetLength(), (sptr_t)u8str.GetText());
        @ }
    }

    方法 添加样式内容 <公开 注释 = "  在当前编辑框中当前光标位置处插入样式内容." 注释 = "注意:如果所添加内容超出当前编辑框的可视范围,将不会自动滚动显示.">
    参数 内容 <类型 = 字节集类 注释 = "提供所欲插入的样式内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_ADDSTYLEDTEXT, (uptr_t)@<内容>.GetSize(), (sptr_t)@<内容>.GetPtr());
    }

    方法 追加内容 <公开 注释 = "  在当前编辑框中的尾部追加文本内容,该操作不会改变当前选中的内容." 注释 = "注意:如果所追加内容超出当前编辑框的可视范围,将不会自动滚动显示.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲追加的文本内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_APPENDTEXT, (uptr_t)u8str.GetLength(), (sptr_t)u8str.GetText());
        @ }
    }

    方法 插入内容 <公开 注释 = "  在当前编辑框中的指定位置处插入文本内容." 注释 = "注意:如果所追加内容超出当前编辑框的可视范围,将不会自动滚动显示.">
    参数 位置 <类型 = 整数 注释 = "提供所欲插入文本的位置.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲插入的文本内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_INSERTTEXT, (uptr_t)@<位置>, (sptr_t)u8str.GetText());
        @ }
    }

    方法 修改即将插入内容 <公开 注释 = "  修改即将被插入至编辑框中的内容,本方法仅" 注释 = "支持在\"内容插入前检查\"事件响应时使用.">
    参数 内容 <类型 = 文本型 注释 = "提供修改后所欲插入的文本内容.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String u8str (@<内容>.GetText ());
        @     pWnd->SendEditor(SCI_CHANGEINSERTION, (uptr_t)u8str.GetLength(), (sptr_t)u8str.GetText());
        @ }
    }

    方法 清空 <公开 注释 = "删除编辑框中所有内容,在只读模式下无效.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_CLEARALL);
    }

    方法 删指定区域内容 <公开 注释 = "删除当前编辑框中指定区域内的文本内容.">
    参数 起始位置 <类型 = 整数 注释 = "提供所欲获取删除文本区域的起始位置,单位:字节.">
    参数 删除长度 <类型 = 整数 注释 = "提供所欲删除文本的长度,单位:字节.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_DELETERANGE, (uptr_t)@<起始位置>, (sptr_t)@<删除长度>);
    }

    方法 清除文档样式 <公开 注释 = "清除所有文档样式并恢复折叠状态.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_CLEARDOCUMENTSTYLE);
    }

