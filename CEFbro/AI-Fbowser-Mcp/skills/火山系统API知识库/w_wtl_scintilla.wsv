    # 撤销,重做 ---

    方法 撤销 <公开 注释 = "回退到上一步.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_UNDO);
    }

    方法 重做 <公开 注释 = "重回到下一步,即取消上次执行\"撤销\"的结果.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_REDO);
    }

    方法 取可撤销状态 <公开 类型 = 逻辑型 注释 = "获取当前状态下是否可以使用\"撤销\"方法回退到上一步." 返回值注释 = "可被撤销则返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (BOOL)pWnd->SendEditor(SCI_CANUNDO);
        @ return FALSE;
    }

    方法 取可重做状态 <公开 类型 = 逻辑型 注释 = "获取当前状态下是否可以使用\"重做\"方法以重回到下一步." 返回值注释 = "可被重做则返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (BOOL)pWnd->SendEditor(SCI_CANREDO);
        @ return FALSE;
    }

    方法 清空撤销及重做缓冲区 <公开 注释 = "  如果当前文档状态可执行撤销操作或重做操作,调用本方法可重置" 注释 = "其状态并且清空所占内存,以使文档处于未被修改的状态.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_EMPTYUNDOBUFFER);
    }

    方法 撤销信息收集状态 <公开 属性写 注释 = "  设置编辑框是否收集撤销信息,如果启用则会一直收" 注释 = "集可撤销信息,以供\"撤销\"/\"重做\"方法使用.">
    参数 启用 <类型 = 逻辑型 注释 = "  如果为真则开始收集,否则停止收集,停止收集之前应调" 注释 = "用\"清空撤销及重做缓冲区\"以避免缓冲区内存不同步的问题.">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_SETUNDOCOLLECTION, (uptr_t)@<启用>);
    }

    方法 撤销信息收集状态 <公开 属性读 类型 = 逻辑型 注释 = "获取编辑框是否收集撤销信息以支持撤销以及重做功能的使用." @禁止流程检查 = 真>
    {
