    # 后台加载,保存 ---

    方法 新建加载器对象 <公开 类型 = 变整数 注释 = "创建一个支持ILoader接口的对象,通常用于在后台加载数据,然后将其转为文档对象指针用于设置并显示." 返回值注释 = "返回所创建加载器对象的指针,创建失败将返回0."
            @禁止流程检查 = 真>
    参数 初始容量 <类型 = 整数 注释 = "提供该加载器所欲使用的初始容量,单位:字节.">
    参数 选项 <类型 = 整数 注释 = "指定新建文档内存和性能的选项,更多细节请参考文档\"https://www.scintilla.org/ScintillaDoc.html#SCI_CREATEDOCUMENT\"." @默认值 = 0>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (INT_P)pWnd->SendEditor(SCI_CREATELOADER, (uptr_t)@<初始容量>, (sptr_t)@<选项>);
        @ return 0;
    }

    方法 释放加载器数据 <公开 类型 = 整数 注释 = "将加载器中所有已添加的数据释放" 返回值注释 = "返回操作结果,请参考\"代码编辑框错误状态码\"所提供的常量." @禁止流程检查 = 真>
    参数 加载器指针 <类型 = 变整数 注释 = "提供该加载器对象的指针,必须是通过\"新建加载器对象\"创建并返回的指针.">
    {
        @ if (@<加载器指针> != NULL)
        @     return ((ILoader*)@<加载器指针>)->Release();
        @ return SC_STATUS_FAILURE;
    }

    方法 添加数据到加载器 <公开 类型 = 整数 注释 = "将指定的数据复制添加到指定的加载器中存放" 返回值注释 = "返回操作结果,请参考\"代码编辑框错误状态码\"所提供的常量." @禁止流程检查 = 真>
    参数 加载器指针 <类型 = 变整数 注释 = "提供该加载器对象的指针,必须是通过\"新建加载器对象\"创建并返回的指针.">
    参数 数据 <类型 = 字节集类 注释 = "提供所欲加入的数据">
    {
        @ if (@<加载器指针> != NULL)
        @     return ((ILoader*)@<加载器指针>)->AddData((const char*)@<数据>.GetPtr(), (Sci_Position)@<数据>.GetSize());
        @ return SC_STATUS_FAILURE;
    }

    方法 加载器指针到文档指针 <公开 类型 = 变整数 注释 = "提供指定加载器对象的指针,将其转为文档对象并返回该对象的指针." 返回值注释 = "返回转换后的文档指针,转换失败返回0." @禁止流程检查 = 真>
    参数 加载器指针 <类型 = 变整数 注释 = "提供该加载器对象的指针,必须是通过\"新建加载器对象\"创建并返回的指针.">
    {
        @ if (@<加载器指针> != NULL)
        @     return (INT_P)((ILoader*)@<加载器指针>)->ConvertToDocument();
        @ return 0;
    }

