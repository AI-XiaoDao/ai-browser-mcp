    方法 自动补全完全忽略大小写 <公开 属性写 注释 = "  当\"自动补全区分大小写\"属性为假时,默认情况下仍会选择第一个以区分大小写" 注释 = "方式匹配到的候选词,本属性可禁用该默认情况以实现完全忽略大小写.">
    参数 完全忽略 <类型 = 逻辑型 注释 = "指定是否启用完全忽略大小写">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     pWnd->SendEditor(SCI_AUTOCSETCASEINSENSITIVEBEHAVIOUR, (uptr_t)(@<完全忽略> ? SC_CASEINSENSITIVEBEHAVIOUR_IGNORECASE : SC_CASEINSENSITIVEBEHAVIOUR_RESPECTCASE));
    }

    方法 自动补全完全忽略大小写 <公开 属性读 类型 = 逻辑型 注释 = "获取自动补全功能当前是否已启用完全忽略大小写" @禁止流程检查 = 真>
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @     return (pWnd->SendEditor(SCI_AUTOCGETCASEINSENSITIVEBEHAVIOUR) == SC_CASEINSENSITIVEBEHAVIOUR_RESPECTCASE ? FALSE : TRUE);
        @ return FALSE;
    }

