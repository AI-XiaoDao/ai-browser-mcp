    方法 置指定行旁注内容 <公开 注释 = "设置指定行对应的旁注文本内容,设置成功后将触发\"文本旁注内容已改变\"事件.">
    参数 行号 <类型 = 整数 注释 = "提供所欲设置其旁注内容对应的行">
    参数 内容 <类型 = 文本型 注释 = "提供所欲设置的旁注内容">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<内容>.GetText());
        @     pWnd->SendEditor(SCI_MARGINSETTEXT, (uptr_t)@<行号>, (sptr_t)str.GetText());
        @ }
    }

    方法 取指定行旁注内容 <公开 类型 = 文本型 注释 = "获取指定行对应的旁注文本内容" @禁止流程检查 = 真>
    参数 行号 <类型 = 整数 注释 = "提供所欲获取其旁注内容对应的行">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_MARGINGETTEXT, (uptr_t)@<行号>) + 1;
        @     if (pWnd->SendEditor(SCI_MARGINGETTEXT, (uptr_t)@<行号>, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

