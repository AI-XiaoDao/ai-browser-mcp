    方法 "//置指定行行尾注释内容" <公开 注释 = "设置指定内容行所欲显示的行尾注释内容,设置成功后将触发\"行尾注释内容已改变\"事件.">
    参数 行号 <类型 = 变整数 注释 = "提供所欲设置其行尾注释内容的行号">
    参数 内容 <类型 = 文本型 注释 = "提供所欲设置的行尾注释内容">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CU8String str(@<内容>.GetText());
        @     pWnd->SendEditor(SCI_EOLANNOTATIONSETTEXT, (uptr_t)@<行号>, (sptr_t)str.GetText());
        @ }
    }

    方法 "//取指定行行尾注释内容" <公开 类型 = 文本型 注释 = "获取指定行对应的行尾注释文本内容" @禁止流程检查 = 真>
    参数 行号 <类型 = 变整数 注释 = "提供所欲获取其行尾注释内容对应的行">
    {
        @ CVWnd_Scintilla* pWnd = (CVWnd_Scintilla*)GetWtlControlPtr ();
        @ if (pWnd->m_hWnd != NULL)
        @ {
        @     CVolMem memBuf;
        @     sptr_t len = pWnd->SendEditor(SCI_EOLANNOTATIONGETTEXT, (uptr_t)@<行号>) + 1;
        @     if (pWnd->SendEditor(SCI_EOLANNOTATIONGETTEXT, (uptr_t)@<行号>, (sptr_t)memBuf.Alloc(len, TRUE)) > 0)
        @         return @an<CVolString> ((const CHAR*)memBuf.GetPtr());
        @ }
        @ return _T("");
    }

