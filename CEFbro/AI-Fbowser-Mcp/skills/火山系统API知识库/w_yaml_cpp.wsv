    #         out << (const char*)CU8String(str).GetText();
    #         return out;
    #     }
    # }
    # <> </global>
    # @end
}

类 YAML节点类 <公开 基础类 = 对象类>
{
    方法 取标记 <公开 类型 = YAML标记类 注释 = "获取当前对象所处位置信息" @嵌入式方法 = "">
    {
        @ @dt<YAML标记类>(@sn<this>.data().Mark())
    }

    方法 取类型 <公开 类型 = YAML节点类型 注释 = "获取当前对象的值类型" @嵌入式方法 = "">
    {
        @ (@dt<YAML节点类型>)@sn<this>.data().Type()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "获取当前对象的值类型是否为空" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsNull()
    }

    方法 是否为标量 <公开 类型 = 逻辑型 注释 = "获取当前对象的值类型是否为标量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsScalar()
    }

    方法 是否为数组 <公开 类型 = 逻辑型 注释 = "获取当前对象的值类型是否为数组" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsSequence()
    }

    方法 是否为对象 <公开 类型 = 逻辑型 注释 = "获取当前对象的值类型是否为对象" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsMap()
    }

    方法 是否为未定义 <公开 类型 = 逻辑型 注释 = "获取当前对象的值类型是否为未定义" @嵌入式方法 = "">
    {
        @ @sn<this>.data().IsDefined()
    }

    方法 取值 <公开 注释 = "获取当前对象的值" @嵌入式方法 = "">
    参数 返回值类型 <注释 = "欲返回的值类型,必须对应数据中的值类型." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    {
        @ @sn<this>.data().as<@pdt<返回值类型>>()
    }

    方法 置值 <公开 注释 = "设置当前对象的值" @嵌入式方法 = "req_cpp_bool = true">
    参数 内容 <注释 = "@匹配类型:通用基本型、YAML节点类、YAML节点类型" @匹配类型 = 通用型>
    {
        @ @sn<this>.data() = @<内容>
    }

    方法 置空值 <公开 注释 = "设置当前对象为空值" @嵌入式方法 = "">
    {
        @ @sn<this>.data() = YAML::Null
    }

    方法 取标量值 <公开 类型 = 文本型 注释 = "获取当前节点的标量值" @嵌入式方法 = "">
    {
        @ @dt<文本型>(@sn<this>.data().Scalar().c_str())
    }

    方法 取标签 <公开 类型 = 文本型 注释 = "取当前节点标签" @嵌入式方法 = "">
    {
        @ @dt<文本型>(@sn<this>.data().Tag().c_str())
    }

    方法 置标签 <公开 注释 = "设置当前节点标签" @嵌入式方法 = "">
    参数 欲设置的标签 <类型 = 文本型>
    {
        @ @sn<this>.data().SetTag(std::string(@<欲设置的标签>))
    }

    方法 取节点样式 <公开 类型 = YAML输出样式 注释 = "获取当前节点样式" @嵌入式方法 = "">
    {
        @ (@dt<YAML输出样式>)@sn<this>.data().Style()
    }

    方法 置节点样式 <公开 注释 = "设置当前节点样式" @嵌入式方法 = "">
    参数 欲设置的风格 <类型 = YAML输出样式>
    {
        @ @sn<this>.data().SetStyle((YAML::EmitterStyle::value)@<欲设置的风格>)
    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "比较两个节点是否等" @嵌入式方法 = "">
    参数 欲比较的对象 <类型 = YAML输出样式>
    {
        @ (@dt<逻辑型>)@sn<this>.data().is(@<欲比较的对象>.data())
    }

    方法 重置 <公开 注释 = "重置当前对象" @嵌入式方法 = "">
    参数 节点对象 <类型 = YAML节点类 注释 = "重置后欲克隆的节点对象" @默认值 = 空对象>
    {
        @ @sn<this>.data().reset(@<节点对象>.data())
    }

    方法 取数量 <公开 类型 = 变整数 注释 = "取当前成员数,如果当前节点为对象则返回对象数量,如果为数组则返回数组成员数" @嵌入式方法 = "">
    {
        @ (@dt<变整数>)@sn<this>.data().size()
    }

    方法 枚举循环 <公开 注释 = "枚举循环当前对象或数组" @嵌入式方法 = "name = iterator\r\nhas_loop_body = true">
    {
        @ YAML_ENUM(@sn<this>.data())
    }

    方法 取枚举对象名 <公开 类型 = YAML节点类 注释 = "如果枚举的节点是对象则用此方法获取枚举键名" @嵌入式方法 = "parent = \"iterator\"">
    {
        @ @sn<current_class_def>(it->first)
    }

    方法 取枚举对象值 <公开 类型 = YAML节点类 注释 = "如果枚举的节点是对象则用此方法获取枚举键值" @嵌入式方法 = "parent = \"iterator\"">
    {
        @ @sn<current_class_def>(it->second)
    }

    方法 取枚举数组值 <公开 类型 = YAML节点类 注释 = "如果枚举的节点是数组则用此方法获取枚举成员值" @嵌入式方法 = "parent = \"iterator\"">
    {
        @ @sn<current_class_def>(*it)
    }

    方法 添加成员 <公开 注释 = "添加数组成员" @嵌入式方法 = "req_cpp_bool = true">
    参数 成员 <注释 = "欲添加的成员.@匹配类型:通用基本型、YAML节点类、YAML节点类型" @匹配类型 = 通用型>
    {
        @ @sn<this>.data().push_back(@<成员>)
    }

    方法 添加多成员 <公开 注释 = "连续添加数组成员" @嵌入式方法 = "req_cpp_bool = true">
    参数 成员 <注释 = "" 注释 = "欲添加的成员.@匹配类型:通用基本型、YAML节点类、YAML节点类型" @可扩展 = "" @匹配类型 = 通用型>
    {
        @ @sn<current_class_def>::push_back(@sn<this>.data(), _T(@sn<pm_types>), @<成员>)
    }

    方法 选择 <公开 类型 = YAML节点类 注释 = "选择当前节点" @嵌入式方法 = "req_cpp_bool = true">
    参数 节点名称 <注释 = "选择当前节点." 注释 = "如果为对象则输出对象名称,如果为数组则输入成员序号" @可扩展 = "d_text = \"][\"" @匹配类型 = 通用型>
    {
        @ @sn<current_class_def>(@sn<this>.data()[@<节点名称>])
    }

    方法 移除 <公开 类型 = 逻辑型 注释 = "移除当前节点" @嵌入式方法 = "req_cpp_bool = true">
    参数 节点名称 <注释 = "如果为对象则输出对象名称,如果为数组则输入成员序号" @匹配类型 = 通用型>
    {
        @ (@dt<逻辑型>)@sn<this>.data().remove(@<节点名称>)
    }

    方法 添加对象 <公开 注释 = "添加对象内容" @嵌入式方法 = "req_cpp_bool = true">
    参数 对象名 <注释 = "对象名称" @匹配类型 = 通用型>
    参数 对象值 <注释 = "对象值" @匹配类型 = 通用型>
    {
        @ @sn<this>.data().force_insert(@<对象名>,@<对象值>)
    }

    方法 添加多对象 <公开 注释 = "连续添加对象内容" @嵌入式方法 = "req_cpp_bool = true">
    参数 键值对 <注释 = "欲添加的对象名称及值." 注释 = "注意:键值对必须成对出现(键名,键值...)" @可扩展 = "" @匹配类型 = 通用型>
    {
        @ @sn<current_class_def>::force_insert(@sn<this>.data(), _T(@sn<pm_types>), @<键值对>)
    }

    方法 取文本值 <公开 类型 = 文本型 注释 = "取当前节点文本值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<文本型>>()
    }

    方法 取逻辑值 <公开 类型 = 逻辑型 注释 = "取当前节点逻辑值" @嵌入式方法 = "">
    {
        @ (@dt<逻辑型>)@sn<this>.data().as<bool>()
    }

    方法 取小数值 <公开 类型 = 小数 注释 = "取当前节点小数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<小数>>()
    }

    方法 取整数值 <公开 类型 = 整数 注释 = "取当前节点整数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<整数>>()
    }

    方法 取短整数值 <公开 类型 = 短整数 注释 = "取当前节点短整数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<短整数>>()
    }

    方法 取长整数值 <公开 类型 = 长整数 注释 = "取当前节点长整数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<长整数>>()
    }

    方法 取变整数值 <公开 类型 = 变整数 注释 = "取当前节点变整数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data().as<@dt<变整数>>()
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将当前对象输出到文本" @嵌入式方法 = "">
    {
        @ @dt<文本型>(YAML::Dump(@sn<this>.data()).c_str())
    }

    方法 保存到文件 <公开 注释 = "将当前对象保存到文件" @嵌入式方法 = "req_str_param_text_pointer_u8 = true" @视窗.外部头文件 = "<fstream>">
    参数 文件名称 <类型 = 文本型 注释 = "欲保存的文件名称">
    {
        @ std::ofstream fout(@<文件名称>);
        @ fout << @sn<this>.data()
    }

