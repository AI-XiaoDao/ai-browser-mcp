    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    {
        返回 (方法 ("getProxyPort", 整数, 协议名称))
    }

    方法 置代理端口 <公开 注释 = "设置所指定协议的代理端口." 注释 = "注意: 本方法仅当所设置的代理选项值为2(使用手动指定的代理选项)时才有效.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    参数 代理端口号 <类型 = 整数>
    {
        无返回值方法 ("setProxyPort", 协议名称, 代理端口号)
    }

    方法 取代理例外列表 <公开 类型 = 文本型 注释 = "返回所指定协议的代理例外主机列表,这些主机将不会通过所指定的代理服务器访问." 返回值注释 = "所返回的多个主机地址列表项之间使用分号分隔.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    {
        返回 (方法 ("getProxyExceptionList", 文本型, 协议名称))
    }

    方法 置代理例外列表 <公开 注释 = "设置所指定协议的代理例外主机列表,这些主机将不会通过所指定的代理服务器访问.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    参数 例外主机列表 <类型 = 文本型 注释 = "提供不通过代理服务器访问的主机地址列表,多个主机地址项之间使用分号分隔.">
