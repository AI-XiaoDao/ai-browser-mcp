    方法 取代理选项 <公开 类型 = 整数 注释 = "返回所指定协议的代理选项值" 返回值注释 = "返回值有以下几种:" 返回值注释 = "  0: 未使用代理服务器;" 返回值注释 = "  1: 使用当前浏览器的HTTP代理选项;"
            返回值注释 = "  2: 使用手动指定的代理选项;" 返回值注释 = "  3. 自动探测使用代理选项.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    {
        返回 (方法 ("getProxySettings", 整数, 协议名称))
    }

    方法 置代理选项 <公开 注释 = "设置所指定协议的代理选项值">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    参数 代理选项值 <类型 = 整数 注释 = "代理选项值有以下几种:" 注释 = "  0: 未使用代理服务器;" 注释 = "  1: 使用当前浏览器的HTTP代理选项;" 注释 = "  2: 使用手动指定的代理选项;"
            注释 = "  3. 自动探测使用代理选项.">
    {
        无返回值方法 ("setProxySettings", 协议名称, 代理选项值)
    }

    方法 取代理服务器 <公开 类型 = 文本型 注释 = "返回所指定协议使用的代理服务器名称." 注释 = "注意: 本方法的返回值仅当所设置的代理选项值为2(使用手动指定的代理选项)时才有效.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    {
        返回 (方法 ("getProxyName", 文本型, 协议名称))
    }

    方法 置代理服务器 <公开 注释 = "设置所指定协议使用的代理服务器名称." 注释 = "注意: 本方法仅当所设置的代理选项值为2(使用手动指定的代理选项)时才有效.">
    参数 协议名称 <类型 = 文本型 注释 = "提供协议名称,目前所支持的协议名称有:"
            注释 = "  \"HTTP\", \"RTSP\", \"RTSPU\", \"RTSPT\", \"MMS\", \"MMSU\", \"MMST\", \"WMPCD\", \"WMPDVD\"">
    参数 代理服务器名称 <类型 = 文本型 注释 = "指定所使用的代理服务器名称">
    {
        无返回值方法 ("setProxyName", 协议名称, 代理服务器名称)
