    方法 立体声平衡 <公开 属性读 类型 = 整数 注释 = "返回当前声道均衡值,有效值从-100到100,-100表示完全使用左声道,100表示完全使用右声道.">
    {
        返回 (读无参数属性 ("balance", 整数))
    }

    方法 立体声平衡 <公开 属性写 注释 = "设置当前声道均衡值">
    参数 欲写入属性值 <类型 = 整数 注释 = "有效值从-100到100,-100表示完全使用左声道,100表示完全使用右声道.">
    {
        写属性 ("balance", 欲写入属性值)
    }

    方法 音量 <公开 属性读 类型 = 整数 注释 = "返回当前播放音量,有效值从0到100, 0表示完全无声,100表示为最大音量.">
    {
        返回 (读无参数属性 ("volume", 整数))
    }

    方法 音量 <公开 属性写 注释 = "设置当前播放音量,有效值从0到100, 0表示完全无声,100表示为最大音量.">
    参数 欲写入属性值 <类型 = 整数>
    {
        写属性 ("volume", 欲写入属性值)
    }

    方法 显示错误 <公开 属性读 类型 = 逻辑型 注释 = "返回是否允许显示错误对话框">
    {
        返回 (读无参数属性 ("enableErrorDialogs", 逻辑型))
    }

    方法 显示错误 <公开 属性写 注释 = "设置是否允许显示错误对话框">
    参数 欲写入属性值 <类型 = 逻辑型>
    {
        写属性 ("enableErrorDialogs", 欲写入属性值)
    }

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "返回所指定的媒体功能是否有效">
    参数 项目名 <类型 = 文本型 注释 = "项目名称为以下文本值之一:" 注释 = "  \"AutoStart\": 自动开始播放;" 注释 = "  \"Balance\": 设置立体声平衡;"
            注释 = "  \"BaseURL\": 设置基准地址;" 注释 = "  \"DefaultFrame\": 设置默认帧;" 注释 = "  \"EnableErrorDialogs\": 显示错误对话框;"
            注释 = "  \"GetMode\": 获取当前模式;" 注释 = "  \"InvokeURLs\": 设置请求地址;" 注释 = "  \"Mute\": 设置是否静音;"
            注释 = "  \"PlayCount\": 设置媒体播放次数;" 注释 = "  \"Rate\": 设置媒体播放速率;" 注释 = "  \"SetMode\": 设置模式;" 注释 = "  \"Volume\": 设置音量.">
    {
        返回 (方法 ("isAvailable", 逻辑型, 项目名))
    }

    方法 取模式 <公开 类型 = 逻辑型 注释 = "返回播放列表指定模式的值">
    参数 模式名称 <类型 = 文本型 注释 = "指定所欲检查模式的名称,可以为以下文本值之一:" 注释 = "  \"autoRewind\": 当播放到媒体尾部后自动回卷到首部重新播放;" 注释 = "  \"loop\": 重复循环播放;"
            注释 = "  \"showFrame\": 当未播放时,自动显示最近的关键帧. 本模式仅对视频播放有效;" 注释 = "  \"shuffle\": 随机播放.">
    {
        返回 (方法 ("getMode", 逻辑型, 模式名称))
    }

    方法 置模式 <公开 注释 = "设置播放列表指定模式的值">
    参数 模式名称 <类型 = 文本型 注释 = "指定所欲设置模式的名称,可以为以下文本值之一:" 注释 = "  \"autoRewind\": 当播放到媒体尾部后自动回卷到首部重新播放;" 注释 = "  \"loop\": 重复循环播放;"
            注释 = "  \"showFrame\": 当未播放时,自动显示最近的关键帧. 本模式仅对视频播放有效;" 注释 = "  \"shuffle\": 随机播放.">
    参数 所欲设置的模式值 <类型 = 逻辑型 注释 = "为真启用,为假则禁用.">
    {
        无返回值方法 ("setMode", 模式名称, 所欲设置的模式值)
    }
}

