            注释 = "例如,以下文本定义了一个名为\"#Emphasis1\"的风格:" 注释 = "  #Emphasis1 {Name: Big Bold Italic; font-size: 14pt; text-align: center;"
            注释 = "            color: blue; font-family: sans-serif; font-weight: bold;" 注释 = "            font-style: italic;}">
