    # 方法 --

    方法 初始化 <公开 静态 注释 = "  默认情况下,类库会自动以默认参数初始化CEF运行时环境,如果需要以特定的方式初始化,可以" 注释 = "调用本方法进行手动初始化." 注释 = "  请注意:"
            注释 = "  1. 本方法只能调用一次,后续再次调用将不起作用;" 注释 = "  2. 本方法并不必须一定要调用,如果没有调用,将自动以默认参数初始化CEF运行时环境." @嵌入式方法 = "">
    参数 配置参数表 <类型 = 文本型 注释 = "  提供所需要指定的所有CEF配置参数,具体格式为: 每个参数之间使用换行符\'\\n\'分隔,参数如果存在值,"
            注释 = "则名称和值之间使用等号\'=\'分隔. 如: \"disable-web-security\\nenable-system-flash=1\"" @默认值 = "">
    参数 用户代理 <类型 = 文本型 注释 = "提供HTTP头中的\"User-Agent\"值,为空文本表示使用默认值." @默认值 = "">
    参数 缓存目录 <类型 = 文本型 注释 = "提供缓存数据的存放目录,为空文本表示使用内存空间缓存(此时将不会持续化保存任何缓存数据,包括Cookie)." @默认值 = "">
    参数 是否缓存会话Cookie <类型 = 逻辑型 注释 = "  指定是否在缓存目录中持续保存会话中所使用的临时Cookie,设置本参数为真则必须同时设置非" 注释 = "空文本的有效缓存目录." @默认值 = 假>
    参数 背景颜色 <类型 = 整数 注释 = "提供浏览器的背景颜色" @默认值 = 0x383838>
    参数 远程调试端口 <类型 = 整数 注释 = "提供远程调试端口号,为0表示禁用." @默认值 = 0>
    参数 日志记录级别 <类型 = CEF日志记录级别 注释 = "提供具体日志记录级别" @默认值 = CEF日志记录级别.禁止>
    参数 日志记录文件名 <类型 = 文本型 注释 = "提供日志记录文件名,为空文本表示使用默认文件名." @默认值 = "">
    参数 代理服务器 <类型 = 文本型 注释 = "提供所使用的代理服务器地址,为空文本表示无." @默认值 = "">
    {
        @ CCefBrowserManager::sInitCef (@<配置参数表>.GetText (), @<用户代理>.GetText (), @<缓存目录>.GetText (), @<是否缓存会话Cookie>,
        @         @<背景颜色>, @<远程调试端口>, @<日志记录级别>, @<日志记录文件名>.GetText (), @<代理服务器>.GetText ())
    }

    方法 使用线程消息循环 <公开 静态 注释 = "调用本方法指示编译CEF3时使用其线程方式的消息循环,如果不调用本方法,将会将CEF3的消息循环整合进当前程序自身的消息循环中(默认方式)."
            注释 = "注意: 本方法为编译时处理方法,系统在编译时只要检测到用户程序实际执行流程中任意位置调用了此方法,就启用对应的编译特性,和方法本身是否被执行到没有任何关系."
            @视窗.预定义宏 = "_VOL_CEF_MULTI_THREADED_MESSAGE_LOOP" @视窗.编译信息 = "基于线程消息循环版本编译CEF3浏览器">
    {

    }

    方法 函数 <公开 属性读 类型 = 文本型 注释 = "返回所有欲在本浏览器中登记的JS函数名列表,多个函数名之间使用逗号分隔." @嵌入式方法 = "">
    {
        @ CVolString (((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->GetFunctionNames ())
    }

    方法 函数 <公开 属性写 注释 = "设置所有欲在本浏览器中登记的JS函数名列表,多个函数名之间使用逗号分隔." @视窗.设置时机 = 组件创建前>
    参数 函数名列表 <类型 = 文本型 注释 = "提供所有欲在本浏览器中登记的JS函数名列表,多个函数名之间使用逗号分隔.">
    {
        @ ((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->InitFunctionNames (@<函数名列表>.GetText ());
    }

    方法 是否初始化成功 <公开 静态 类型 = 逻辑型 注释 = "返回CEF运行时环境是否已经初始化成功" @嵌入式方法 = "">
    {
        @ CCefBrowserManager::sIsCefInitialized ()
    }

    方法 载入文本 <公开 注释 = "载入所指定的HTML文本内容" @嵌入式方法 = "">
    参数 框架标识符 <类型 = 文本型 注释 = "提供欲置入内容的页面框架的标识符,为空文本表示为主框架." @默认值 = "">
    参数 欲载入文本 <类型 = 文本型 注释 = "提供欲载入的HTML格式的文本内容">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->LoadString (@<框架标识符>.GetText (), @<欲载入文本>.GetText ())
    }

    方法 能否后退 <公开 类型 = 逻辑型 注释 = "返回当前页面能否进行后退操作" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->CanGoBack ());
    }

    方法 后退 <公开 注释 = "后退当前页面">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser))
        @     browser->GoBack ();
    }

    方法 能否前进 <公开 类型 = 逻辑型 注释 = "返回当前页面能否进行前进操作" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->CanGoForward ());
    }

    方法 前进 <公开 注释 = "前进当前页面">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser))
        @     browser->GoForward ();
    }

    方法 是否正在载入 <公开 类型 = 逻辑型 注释 = "返回当前是否正在载入文档" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->IsLoading ());
    }

    方法 重载 <公开 注释 = "重新载入当前文档">
    参数 是否忽略缓存 <类型 = 逻辑型 注释 = "指定是否不从当前缓存中载入文档" @默认值 = 假>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser))
        @     if (@<是否忽略缓存>) browser->ReloadIgnoreCache (); else browser->Reload ();
    }

    方法 停止载入 <公开 注释 = "指定是否停止载入当前文档">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser))
        @     browser->StopLoad ();
    }

    方法 是否已载入 <公开 类型 = 逻辑型 注释 = "返回当前是否已经载入了一个文档" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->HasDocument ());
    }

    方法 取ID <公开 类型 = 整数 注释 = "返回本浏览器的全局唯一ID值" 返回值注释 = "如果本浏览器组件尚未创建,将返回0." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) ? browser->GetIdentifier () : 0);
    }

    方法 为弹出窗口 <公开 类型 = 逻辑型 注释 = "返回本浏览器是否为弹出窗口" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->IsPopup ());
    }

    方法 取主框架 <公开 类型 = CEF页面框架 注释 = "返回当前页面中的主框架" 返回值注释 = "如果失败,所返回框架将为空(\"CEF页面框架.是否为空\"方法返回真)." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) ? @dt<CEF页面框架> (browser->GetMainFrame ()) : @dt<CEF页面框架> ());
    }

    方法 取焦点框架 <公开 类型 = CEF页面框架 注释 = "返回当前页面中的焦点框架" 返回值注释 = "如果失败,所返回框架将为空(\"CEF页面框架.是否为空\"方法返回真)." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) ? @dt<CEF页面框架> (browser->GetFocusedFrame ()) : @dt<CEF页面框架> ());
    }

    方法 取框架 <公开 类型 = CEF页面框架 注释 = "返回当前页面中具有指定ID的框架" 返回值注释 = "如果失败,所返回框架将为空(\"CEF页面框架.是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 框架标识符 <类型 = 文本型 注释 = "提供所欲获取页面框架的标识符,为空文本表示为主框架.">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser))
        @     return (@<框架标识符>.IsEmpty () ? @dt<CEF页面框架> (browser->GetMainFrame ()) : @dt<CEF页面框架> (browser->GetFrameByIdentifier (CefString ((const char16_t*)@<框架标识符>.GetText ()))));
        @ return @dt<CEF页面框架> ();
    }

    方法 取指定名称框架 <公开 类型 = CEF页面框架 注释 = "返回当前页面中具有指定名称的框架" 返回值注释 = "如果失败,所返回框架将为空(\"CEF页面框架.是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 框架名称 <类型 = 文本型 注释 = "提供所欲获取页面框架的名称">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) ? @dt<CEF页面框架> (browser->GetFrameByName (CefString ((const char16_t*)@<框架名称>.GetText ()))) : @dt<CEF页面框架> ());
    }

    方法 取框架数目 <公开 类型 = 整数 注释 = "返回当前页面中所有框架的数目" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) ? (INT)browser->GetFrameCount () : 0);
    }

    方法 取所有框架标识符 <公开 类型 = 整数 注释 = "获取当前页面中所有框架的标识符" 返回值注释 = "返回所获取框架的数目" @嵌入式方法 = "">
    参数 结果存放参数 <类型 = 文本数组类 注释 = "获取的所有框架标识符将存放入此数组参数中">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->GetAllFrameIdentifiers (@<结果存放参数>.data ())
    }

    方法 取所有框架名称 <公开 类型 = 整数 注释 = "获取当前页面中所有框架的名称" 返回值注释 = "返回所获取框架的数目" @嵌入式方法 = "">
    参数 结果存放参数 <类型 = 文本数组类 注释 = "获取的所有框架名称将存放入此数组参数中">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->GetAllFrameNames (@<结果存放参数>.data ())
    }

    方法 启动开发工具 <公开 注释 = "启动并显示开发工具窗口" @嵌入式方法 = "">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->ShowDevTool ()
    }

    方法 结束开发工具 <公开 注释 = "如果当前已经启动显示了开发工具窗口,则将其退出.">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->CloseDevTools ();
    }

    方法 开发工具是否启动 <公开 类型 = 逻辑型 注释 = "返回当前是否已经启动显示了开发工具窗口" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (BOOL)browser->GetHost ()->HasDevTools ();
        @ return FALSE;
    }

    方法 开始下载 <公开 注释 = "开始下载所指定链接地址中的文件,本下载操作会触发本类中的所有下载相关事件.">
    参数 下载链接地址 <类型 = 文本型>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->StartDownload (@<下载链接地址>.GetText ());
    }

    方法 下载图像 <公开 注释 = "下载一个图像(通常是网页中的图片或网站图标)并获取其数据." 注释 = "下载完毕会发送\"图像下载完毕\"事件(无论下载成功还是失败,都会被发送一次且仅一次)." @嵌入式方法 = "">
    参数 图像链接地址 <类型 = 文本型 注释 = "提供要下载的图像的完整链接地址,必须是一个有效的、可访问的图像 URL.">
    参数 图像最大尺寸 <类型 = 整数 注释 = "指定下载图像的最大尺寸(以像素为单位),这里指的是图像的宽度和高度,而不是文件大小." 注释 = "作用: CEF 会自动缩放下载的图像,确保其宽度和高度都不超过此值."
            注释 = "例如: 如果一张图片是 2000x1500 像素，而本参数值等于512,那么 CEF 返回的图像数据将是缩放到 512x384 或更小的版本."
            注释 = "目的: 防止加载过大的图片导致内存占用过高; 优化性能,特别是当最终显示尺寸很小时(如缩略图、图标)."
            注释 = "建议值: 对于网站图标,通常设为 64 或 128; 对于普通图片预览,可根据 UI 设计设定(如 512, 1024).">
    参数 是否为网站图标 <类型 = 逻辑型 注释 = "  当设置为真时,CEF 会应用一些针对网站图标的特殊处理逻辑: 可能会尝试从常见的路径(如 /favicon.ico)加载,"
            注释 = "可能会对响应头进行更严格的检查,内部可能会使用不同的缓存策略." 注释 = "  如果你只是下载普通图片,应设置为假." @默认值 = 假>
    参数 是否不使用缓存 <类型 = 逻辑型 注释 = "设置为真强制从网络重新下载,不使用任何缓存的副本." 注释 = "设置为假允许使用缓存,如果图像已缓存且未过期,将直接使用缓存版本,速度更快." @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->DownloadImage (@<图像链接地址>.GetText (), @<图像最大尺寸>, @<是否为网站图标>, @<是否不使用缓存>)
    }

    方法 打印 <公开 注释 = "打印当前页面内容">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->Print ();
    }

    方法 打印到PDF <公开 类型 = 逻辑型 注释 = "开始打印当前页面内容到指定的PDF文件" 返回值注释 = "返回是否开始打印成功" @嵌入式方法 = "">
    参数 PDF文件名 <类型 = 文本型 注释 = "提供所欲打印到的PDF文件名">
    参数 等待打印完毕 <类型 = 逻辑型 注释 = "  指定是否一直等待打印到PDF完毕后才返回,如果为假,则打印完毕后会发送\"PDF打印完毕\"事件."
            注释 = "  注意: 如果本参数值为假,则本方法返回真只能说明开始打印成功,并不意味着打印本身已经成功," 注释 = "打印本身是否成功在接收到\"PDF打印完毕\"事件后由其\"是否打印成功\"参数值提供." @默认值 = 假>
    参数 页眉模板 <类型 = 文本型 注释 = "提供显示在页面顶部的文本模板,支持特定的变量和简单的 HTML 标签.如果为空,则不显示页眉." 注释 = "支持的变量和类:" 注释 = "1. 页码相关:"
            注释 = "当前页码: <span class=\'pageNumber\'></span> ;" 注释 = "总页数: <span class=\'totalPages\'></span> ." 注释 = "2. 日期时间相关:"
            注释 = "打印日期: <span class=\'date\'></span> ;" 注释 = "打印时间: <span class=\'time\'></span> ;"
            注释 = "页面标题: <span class=\'title\'></span> ." 注释 = "示例,设置包含多种信息的页眉:"
            注释 = "  \"<div style=\'width: 100%; font-size: 8px; font-family: Arial; padding: 5px; border-bottom: 1px solid #ccc;\'>"
            注释 = "<span style=\'float: left;\'><span class=\'title\'></span></span><span style=\'float: center;\'>第 <span class=\'pageNumber\'>"
            注释 = "</span> 页 / 共 <span class=\'totalPages\'></span> 页</span><span style=\'float: right;\'>打印日期: <span class=\'date\'></span>"
            注释 = "</span><div style=\'clear: both;\'></div></div>\" ." 注释 = "以下是几个常用的页眉和页脚模板示例:" 注释 = "1. 简洁商务风格:"
            注释 = "  页眉: \"<div style=\'width: 100%; font-size: 9px; font-family: Arial; padding: 8px 0; border-bottom: 1px solid #ddd;\'>"
            注释 = "<span style=\'float: left;\'><span class=\'title\'></span></span><span style=\'float: right;\'>机密文档</span>"
            注释 = "<div style=\'clear: both;\'></div></div>\";"
            注释 = "  页脚: \"<div style=\'width: 100%; font-size: 8px; font-family: Arial; padding: 8px 0; border-top: 1px solid #ddd; color: #666;\'>"
            注释 = "<span style=\'float: left;\'>打印于: <span class=\'date\'></span></span><span style=\'float: center;\'>第 <span class=\'pageNumber\'>"
            注释 = "</span> 页 / 共 <span class=\'totalPages\'></span> 页</span><span style=\'float: right;\'>© 2024 公司名称</span>"
            注释 = "<div style=\'clear: both;\'></div></div>\"." 注释 = "2. 居中页码风格:"
            注释 = "  页眉: \"<div style=\'text-align: center; font-size: 10px; color: #333; padding: 5px 0;\'><span class=\'title\'></span></div>\";"
            注释 = "  页脚: \"<div style=\'text-align: center; font-size: 9px; color: #666; padding: 10px 0;\'>第 <span class=\'pageNumber\'></span> 页</div>\"."
            注释 = "3. 报告文档风格:"
            注释 = "  页眉: \"<div style=\'width: 100%; font-size: 8px; font-family: Arial; padding: 6px 0; background-color: #f5f5f5;\'>"
            注释 = "<span style=\'float: left;\'>项目报告书</span><span style=\'float: center;\'>版本: 1.0</span><span style=\'float: right;\'>"
            注释 = "<span class=\'date\'></span></span><div style=\'clear: both;\'></div></div>\";"
            注释 = "  页脚: \"<div style=\'width: 100%; font-size: 8px; font-family: Arial; padding: 6px 0; color: #888;\'>"
            注释 = "<span style=\'float: left;\'>部门: 技术部</span><span style=\'float: center;\'>第 <span class=\'pageNumber\'></span> 页 / 共 <span class=\'totalPages\'>"
            注释 = "</span> 页</span><span style=\'float: right;\'>审批人: 张三</span><div style=\'clear: both;\'></div></div>\"."
            注释 = "4. 极简风格:" 注释 = "  页眉 - 只有一条细线:  \"<div style=\'border-bottom: 0.5px solid #eee; height: 1px;\'></div>\";"
            注释 = "  页脚: \"<div style=\'text-align: center; font-size: 8px; color: #999; padding: 5px;\'><span class=\'pageNumber\'>"
            注释 = "</span> / <span class=\'totalPages\'></span></div>\"." 注释 = "5. 法律文档风格:"
            注释 = "  页眉: \"<div style=\'width: 100%; font-size: 7px; font-family: Arial; padding: 4px 0; border-bottom: 1px solid #000;\'>"
            注释 = "<span style=\'float: left;\'>合同编号: HT-2024-001</span><span style=\'float: right;\'>机密级别: 内部</span>"
            注释 = "<div style=\'clear: both;\'></div></div>\";"
            注释 = "  页脚: \"<div style=\'width: 100%; font-size: 7px; font-family: Arial; padding: 4px 0; border-top: 1px solid #000;\'>"
            注释 = "<span style=\'float: left;\'>© 2024 律师事务所 版权所有</span><span style=\'float: center;\'>第 <span class=\'pageNumber\'></span> 页</span>"
            注释 = "<span style=\'float: right;\'>打印时间: <span class=\'date\'></span> <span class=\'time\'></span></span><div style=\'clear: both;\'></div></div>\"."
            注释 = "使用提示:" 注释 = "字体大小: 通常使用 7-10px;" 注释 = "颜色: 使用灰色系 (#666, #888, #999) 避免太醒目;"
            注释 = "布局: 使用 float 进行左中右布局,最后用 clear: both 清除浮动." 注释 = "间距: 适当使用 padding 增加可读性;" 注释 = "边框: 使用细边框分隔内容区域." @默认值 = "">
    参数 页脚模板 <类型 = 文本型 注释 = "提供显示在页面底部的文本模板,模板格式见\"页眉模板\"参数." @默认值 = "">
    参数 页宽 <类型 = 整数 注释 = "提供输出页面宽度,单位为微米(0.001毫米).如果页宽或页高任一项小于等于0,则使用默认A4纸张尺寸." @默认值 = 0>
    参数 页高 <类型 = 整数 注释 = "提供输出页面高度,单位为微米(0.001毫米).如果页宽或页高任一项小于等于0,则使用默认A4纸张尺寸." @默认值 = 0>
    参数 边距类型 <类型 = PDF打印边距类型 注释 = "提供边距的打印类型" @默认值 = PDF打印边距类型.默认>
    参数 自定义边距 <类型 = 矩形类 注释 = "当\"边距类型\"为\"PDF打印边距类型.自定义\"时提供对应的各边边距,单位为微米(0.001毫米)." @默认值 = 空对象>
    参数 横向打印 <类型 = 逻辑型 注释 = "指定是否横向打印" @默认值 = 假>
    参数 打印背景图 <类型 = 逻辑型 注释 = "指定是否打印页面的背景图" @默认值 = 假>
    参数 缩放比例 <类型 = 小数 注释 = "指定打印时所使用的缩放比例,1表示100%,如果小于等于0则使用默认值1." @默认值 = 0>
    参数 使用CSS定义尺寸 <类型 = 逻辑型 注释 = "控制打印时是否优先使用 CSS 中通过 @page 规则定义的页面尺寸,而不是用户设置的打印机页面尺寸." @默认值 = 假>
    参数 打印范围 <类型 = 文本型 注释 = "控制在打印文档时只打印指定的页面范围,如果为空字符串,则打印所有页面. 格式示例:" 注释 = "\"1-5,8,10-12\": 打印第1-5页、第8页、第10-12页."
            注释 = "\"1,3,5\": 打印第1、3、5页." 注释 = "\"2-\": 打印从第2页到最后一页." 注释 = "\"-5\": 打印从第1页到第5页." 注释 = "\"\": 打印所有页面(默认)." @默认值 = "">
    参数 是否生成结构信息 <类型 = 逻辑型 注释 = "控制生成的 PDF 文件是否包含结构辅助标签(标题、段落、列表、表格等),以提升可访问性." @默认值 = 假>
    参数 是否生成文档大纲 <类型 = 逻辑型 注释 = "控制生成的 PDF 文件是否包含基于文档标题结构的可导航大纲(书签)" @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->PrintPDF (@<PDF文件名>.GetText (), @<页眉模板>.GetText (), @<页脚模板>.GetText (), @<页宽>, @<页高>, @<边距类型>, @<自定义边距>.ToRect (), @<横向打印>, @<打印背景图>, @<等待打印完毕>, @<缩放比例>, @<使用CSS定义尺寸>, @<打印范围>.GetText (), @<是否生成结构信息>, @<是否生成文档大纲>)
    }

    方法 枚举Cookie <公开 类型 = 逻辑型 注释 = "枚举所有现有Cookie,每枚举到一个Cookie,就发送一个对应的\"获得Cookie\"事件."
            注释 = "Cookie枚举以其最长路径排序,如果路径相同,则以创建时间从早到晚排序." 返回值注释 = "返回真表示枚举操作启动成功,返回假表示无法访问Cookie." @嵌入式方法 = "">
    参数 匹配链接地址 <类型 = 文本型 注释 = "如果不为空文本,则仅当匹配此链接地址的Cookie才会被枚举." @默认值 = "">
    参数 仅普通链接 <类型 = 逻辑型 注释 = "如果为真,则仅枚举\"CEFCookie信息.仅普通链接使用\"成员值为真的Cookie." @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->EnumAllCookies (@<匹配链接地址>.GetText (), @<仅普通链接>)
    }

    方法 置Cookie <公开 静态 类型 = 逻辑型 注释 = "设置所指定的Cookie" 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 链接地址 <类型 = 文本型 注释 = "提供所对应的链接地址">
    参数 Cookie <类型 = CEFCookie信息 注释 = "提供对应的Cookie信息">
    {
        @ CefCookie cookie;
        @ @<Cookie>.ToCefCookie (cookie);
        @ CefRefPtr<CefCookieManager> manager = CefCookieManager::GetGlobalManager (nullptr);
        @ return (manager->SetCookie (@<链接地址>.GetText (), cookie, nullptr) ? TRUE : FALSE);
    }

    方法 删除Cookie <公开 静态 类型 = 逻辑型 注释 = "删除所有匹配的Cookie" 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 匹配链接地址 <类型 = 文本型 注释 = "提供用作匹配的链接地址">
    参数 Cookie名称 <类型 = 文本型 注释 = "提供用作匹配的Cookie名称">
    {
        @ CefRefPtr<CefCookieManager> manager = CefCookieManager::GetGlobalManager (nullptr);
        @ return (manager->DeleteCookies (@<匹配链接地址>.GetText (), @<Cookie名称>.GetText (), nullptr) ? TRUE : FALSE);
    }

    方法 刷新Cookie存储 <公开 静态 类型 = 逻辑型 注释 = "将所有后备Cookie数据刷新存储到磁盘" 返回值注释 = "成功返回真,无法访问Cookie返回假." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefCookieManager> manager = CefCookieManager::GetGlobalManager (nullptr);
        @ return (manager->FlushStore (nullptr) ? TRUE : FALSE);
    }

    方法 获取输入焦点 <公开 注释 = "将输入焦点设置到浏览器">
    参数 是否获得焦点 <类型 = 逻辑型 注释 = "指定是否为获得焦点">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->SetFocus (@<是否获得焦点>);
    }

    方法 取浏览器窗口句柄 <公开 类型 = 变整数 注释 = "获取浏览器窗口(注意不是本组件)的窗口句柄,不存在返回0" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (INT_P)browser->GetHost ()->GetWindowHandle ();
        @ return 0;
    }

    方法 取父浏览器窗口句柄 <公开 类型 = 变整数 注释 = "获取打开本浏览器窗口的父浏览器的窗口句柄." 注释 = "如果本浏览器窗口不为弹出式窗口,将返回0." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (INT_P)browser->GetHost ()->GetOpenerWindowHandle ();
        @ return 0;
    }

    方法 能否缩放 <公开 类型 = 逻辑型 注释 = "返回本浏览器是否支持使用指定的缩放操作命令" @禁止流程检查 = 真>
    参数 欲检测的缩放命令 <类型 = CEF缩放命令>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (BOOL)browser->GetHost ()->CanZoom ((cef_zoom_command_t)@<欲检测的缩放命令>);
        @ return FALSE;
    }

    方法 缩放 <公开 注释 = "执行指定的缩放操作命令">
    参数 欲执行的缩放命令 <类型 = CEF缩放命令>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->Zoom ((cef_zoom_command_t)@<欲执行的缩放命令>);
    }

    方法 取默认缩放级别 <公开 类型 = 小数 注释 = "返回浏览器中内容的默认缩放级别." 注释 = "缩放级别:" 注释 = "推荐范围为 -10.0 到 10.0, 典型缩放级别如:"
            注释 = "  -10.0: 最小缩放 (约 10%);" 注释 = "  -5.0: 较小缩放;" 注释 = "  0.0: 原始大小 (100%);" 注释 = "  1.0: 约 110%;" 注释 = "  2.0: 约 125%;"
            注释 = "  3.0: 约 150%;" 注释 = "  5.0: 约 200%;" 注释 = "  10.0: 最大缩放 (约 500%)." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return browser->GetHost ()->GetDefaultZoomLevel ();
        @ return 0.0;
    }

    方法 取当前缩放级别 <公开 类型 = 小数 注释 = "返回浏览器中内容的当前缩放级别. 有关\"缩放级别\"的说明见\"取默认缩放级别\"方法." @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return browser->GetHost ()->GetZoomLevel ();
        @ return 0.0;
    }

    方法 置当前缩放级别 <公开 注释 = "设置浏览器中内容的当前缩放级别. 有关\"缩放级别\"的说明见\"取默认缩放级别\"方法.">
    参数 欲设置缩放级别 <类型 = 小数>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->SetZoomLevel (@<欲设置缩放级别>);
    }

    方法 发送按键事件 <公开 注释 = "发送所指定的按键事件到浏览器" @嵌入式方法 = "">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 为按键放开事件 <类型 = 逻辑型 注释 = "  为真表示发送按键放开事件(WM_SYSKEYUP/WM_KEYUP),否则将发送" 注释 = "按键按下事件(WM_SYSKEYDOWN/WM_KEYDOWN)." @默认值 = 假>
    参数 为系统按键事件 <类型 = 逻辑型 注释 = "  为真表示发送系统按键事件(WM_SYSKEYDOWN/WM_SYSKEYUP),否则将" 注释 = "发送非系统按键事件(WM_KEYDOWN/WM_KEYUP)" @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendKeyEvent ((@<键代码> | @<辅助键状态>), @<为按键放开事件>, @<为系统按键事件>)
    }

    方法 发送字符事件 <公开 注释 = "发送所指定的字符输入事件到浏览器" @嵌入式方法 = "">
    参数 字符编码 <类型 = 字符 注释 = "提供所欲发送的字符">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendCharEvent (@<字符编码>)
    }

    方法 发送字符串事件 <公开 注释 = "发送所指定的字符串文本输入事件到浏览器" @嵌入式方法 = "">
    参数 字符串文本 <类型 = 文本型 注释 = "提供所欲发送的字符串文本">
    参数 字符间隔时间 <类型 = 整数 注释 = "提供发送每个字符时的中间间隔时间,单位毫秒." @默认值 = 30>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendCharsEvent (@<字符串文本>.GetText (), (DWORD)MAX (0, @<字符间隔时间>))
    }

    方法 发送鼠标单击事件 <公开 注释 = "发送所指定的鼠标键单击事件到浏览器" @嵌入式方法 = "">
    参数 所单击按键类型 <类型 = 整数 注释 = "为\"CEF鼠标键类型\"类中的常量值之一">
    参数 横向位置 <类型 = 整数 注释 = "提供所单击位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供所单击位置在浏览器窗口中的纵向坐标">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"CEF鼠标键类型\"类中各常量值的组合." @默认值 = 0>
    参数 单击次数 <类型 = 整数 注释 = "提供所单击的次数" @默认值 = 1>
    参数 是否为鼠标键放开 <类型 = 逻辑型 注释 = "为真表示为鼠标键放开,否则为鼠标键被按下." @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendMouseClickEvent (@<所单击按键类型>, @<横向位置>, @<纵向位置>, @<辅助键状态>, @<鼠标键状态>, @<单击次数>, @<是否为鼠标键放开>)
    }

    方法 发送鼠标移动事件 <公开 注释 = "发送所指定的鼠标移动事件到浏览器" @嵌入式方法 = "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"CEF鼠标键类型\"类中各常量值的组合." @默认值 = 0>
    参数 是否为鼠标离开 <类型 = 逻辑型 注释 = "提供是否为鼠标离开该位置" @默认值 = 假>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendMouseMoveEvent (@<横向位置>, @<纵向位置>, @<辅助键状态>, @<鼠标键状态>, @<是否为鼠标离开>)
    }

    方法 发送鼠标滚轮事件 <公开 注释 = "发送所指定的鼠标滚轮事件到浏览器" @嵌入式方法 = "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"CEF鼠标键类型\"类中各常量值的组合." @默认值 = 0>
    参数 横向滚动距离 <类型 = 整数 注释 = "提供滚轮横向滚动距离,小于0页面向左滚动,大于0页面向右滚动." @默认值 = 0>
    参数 纵向滚动距离 <类型 = 整数 注释 = "提供滚轮纵向滚动距离,小于0页面向上滚动,大于0页面向下滚动." @默认值 = 0>
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->SendMouseWheelEvent (@<横向位置>, @<纵向位置>, @<辅助键状态>, @<鼠标键状态>, @<横向滚动距离>, @<纵向滚动距离>)
    }

    方法 暂停下载 <公开 类型 = 逻辑型 注释 = "暂停指定项目的下载" 返回值注释 = "找到所指定的下载项返回真,否则返回假." @嵌入式方法 = "">
    参数 下载项ID <类型 = 整数 注释 = "指定欲处理下载项目的ID,该ID在\"下载更新\"事件中提供.">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->ExecuteDownloadCommand (@<下载项ID>, CEF_DIDC_PAUSE)
    }

    方法 继续下载 <公开 类型 = 逻辑型 注释 = "继续下载先前被暂停的项目" 返回值注释 = "找到所指定的下载项返回真,否则返回假." @嵌入式方法 = "">
    参数 下载项ID <类型 = 整数 注释 = "指定欲处理下载项目的ID,该ID在\"下载更新\"事件中提供.">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->ExecuteDownloadCommand (@<下载项ID>, CEF_DIDC_RESUME)
    }

    方法 中止下载 <公开 类型 = 逻辑型 注释 = "中止指定项目的下载" 返回值注释 = "找到所指定的下载项返回真,否则返回假." @嵌入式方法 = "">
    参数 下载项ID <类型 = 整数 注释 = "指定欲处理下载项目的ID,该ID在\"下载更新\"事件中提供.">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->ExecuteDownloadCommand (@<下载项ID>, CEF_DIDC_CANCEL)
    }

    方法 下载是否已结束 <公开 类型 = 逻辑型 注释 = "返回指定的项目是否已经下载结束(该项目不存在/下载完成/被中止/被中断/已超时)" @嵌入式方法 = "">
    参数 下载项ID <类型 = 整数 注释 = "指定欲处理下载项目的ID,该ID在\"下载更新\"事件中提供.">
    {
        @ ((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->IsDownloadEndOrTimeout (@<下载项ID>)
    }

    方法 查找 <公开 注释 = "在当前网页内容中执行文本搜索,并通过发送\"获得查找结果\"事件来获取匹配结果.">
    参数 欲搜索文本 <类型 = 文本型 注释 = "提供要搜索的文本">
    参数 区分大小写 <类型 = 逻辑型 注释 = "指定是否区分大小写" @默认值 = 真>
    参数 正向搜寻 <类型 = 逻辑型 注释 = "指定搜索方向.为真表示向前(从当前位置到页面末尾)搜索,为假表示向后(从当前位置到页面开头)搜索." @默认值 = 真>
    参数 查找下一项 <类型 = 逻辑型 注释 = "  本参数值为假或\"欲搜索文本\"和\"区分大小写\"参数值相对上一次调用发生改变: 清除之前的高亮开始"
            注释 = "一次全新的搜索,否则继续搜索下一个(或上一个,取决于\"正向搜寻\"参数值)匹配项." @默认值 = 假>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (@<欲搜索文本>.IsEmpty () == FALSE && ((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->Find (@<欲搜索文本>.GetText (), (bool)@<正向搜寻>, (bool)@<区分大小写>, (bool)@<查找下一项>);
    }

    方法 停止查找 <公开 注释 = "停止当前正在进行的文本搜索并控制搜索高亮显示.它通常在用户关闭\"查找\"面板或按下\"Esc\"键时调用.">
    参数 是否清除高亮 <类型 = 逻辑型 注释 = "控制停止搜索后,页面上的搜索高亮是否被清除." 注释 = "为真: 停止搜索并清除所有高亮. 页面恢复到搜索前的状态,所有匹配项的黄色/橙色背景消失."
            注释 = "为假: 停止搜索但保留当前高亮. 当前激活的匹配项仍然保持高亮状态,方便用户继续查看." @默认值 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->StopFinding ((bool)@<是否清除高亮>);
    }

    方法 启用可访问状态 <公开 注释 = "本方法用于启用或禁用浏览器的可访问性支持." 注释 = "作用场景:" 注释 = "1. 屏幕阅读器支持 - 为视障用户提供内容朗读;" 注释 = "2. 辅助技术 - 支持其他可访问性工具和软件;"
            注释 = "3. 自动化测试 - 某些自动化框架需要可访问性支持." 注释 = "注意事项:" 注释 = "1. 通常在浏览器创建后调用;" 注释 = "2. 改变状态可能会影响性能;"
            注释 = "3. 只在确实需要时可启用,否则建议使用默认状态." 注释 = "这个方法让开发者能够根据应用程序的需求灵活控制可访问性功能的开关.">
    参数 欲启用状态 <类型 = CEF许可状态>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->SetAccessibilityState ((cef_state_t)@<欲启用状态>);
    }

    方法 置静音静态 <公开 注释 = "设置浏览器的音频静音状态">
    参数 是否静音 <类型 = 逻辑型>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->SetAudioMuted ((bool)@<是否静音>);
    }

    方法 是否静音 <公开 类型 = 逻辑型 注释 = "返回浏览器当前是否处于静音状态" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (BOOL)browser->GetHost ()->IsAudioMuted ();
        @ return FALSE;
    }

    方法 是否全屏 <公开 类型 = 逻辑型 注释 = "返回浏览器当前是否处于全屏状态" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     return (BOOL)browser->GetHost ()->IsFullscreen ();
        @ return FALSE;
    }

    方法 退出全屏 <公开 注释 = "强制浏览器退出全屏显示模式">
    参数 是否导致尺寸变化 <类型 = 逻辑型 注释 = "指示退出全屏是否会导致尺寸变化:" 注释 = "为真: 退出全屏会导致浏览器窗口/视图调整大小;" 注释 = "为假: 退出全屏不会导致尺寸变化.">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->ExitFullscreen ((bool)@<是否导致尺寸变化>);
    }

    方法 执行JS脚本 <公开 注释 = "在浏览器的主页面框架内执行所指定的JS脚本代码">
    参数 JS代码 <类型 = 文本型 注释 = "提供所欲执行的JavaScript脚本内容">
    参数 链接地址 <类型 = 文本型 注释 = "  提供脚本所对应的链接地址,当脚本执行遇到问题时,浏览器" 注释 = "将访问此地址为脚本开发者提供错误来源." @默认值 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供出错报告的基准行号" @默认值 = 1>
    {
        取主框架 ().执行JS脚本 (JS代码, 链接地址, 起始行号)
    }

