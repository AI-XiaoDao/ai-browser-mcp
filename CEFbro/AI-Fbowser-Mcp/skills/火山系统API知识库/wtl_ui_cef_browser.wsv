}

类 CEF下载中断原因 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NONE" 注释 = "未中断">
    常量 文件操作失败 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_FAILED">
    常量 文件无访问权限 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_ACCESS_DENIED">
    常量 磁盘空间不足 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_NO_SPACE">
    常量 文件名太长 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_NAME_TOO_LONG" 注释 = "目录或文件名太长">
    常量 文件太大 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_TOO_LARGE" 注释 = "文件太大超出了文件系统管理能力">
    常量 文件包含病毒 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_VIRUS_INFECTED">
    常量 打开太多的文件 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_TRANSIENT_ERROR">
    常量 文件被阻塞 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_BLOCKED" 注释 = "文件操作被系统本地策略阻塞">
    常量 安全检查失败 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_SECURITY_CHECK_FAILED">
    常量 文件太短 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_TOO_SHORT"
            注释 = "试图在打开文件时越过了文件的末尾（作为恢复先前中断的下载的一部分）">
    常量 不匹配散列值 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_HASH_MISMATCH"
            注释 = "部分文件内容与期望的散列值不匹配">
    常量 源和目标相同 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_FILE_SAME_AS_SOURCE"
            注释 = "所下载文件的源和目标地址相同">
    常量 网络出错 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NETWORK_FAILED">
    常量 网络超时 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NETWORK_TIMEOUT">
    常量 网络连接断开 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NETWORK_DISCONNECTED">
    常量 服务器下线 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NETWORK_SERVER_DOWN">
    常量 无效的网络请求 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NETWORK_INVALID_REQUEST"
            注释 = "如: 不被支持的协议,无效的连接地址,被策略所禁止.">
    常量 服务器操作失败 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_FAILED" 注释 = "服务器通知操作已经失败">
    常量 不支持范围请求 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_NO_RANGE" 注释 = "服务器不支持范围请求">
    常量 数据不存在 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_BAD_CONTENT" 注释 = "服务器上不存在所请求的数据">
    常量 无授权访问 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_UNAUTHORIZED"
            注释 = "所访问的资源在服务器上没有授权">
    常量 证书问题 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_CERT_PROBLEM" 注释 = "服务器证书问题">
    常量 禁止访问服务器 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_FORBIDDEN">
    常量 服务器不可达 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_UNREACHABLE">
    常量 内容长度无效 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_CONTENT_LENGTH_MISMATCH"
            注释 = "  服务器发送过来的数据尺寸小于\"content-length\"头字段中指定的尺寸,这将导致连接过早关闭,"
            注释 = "或者\"content-length\"头字段值无效. 下载仅当存在强力验证器时被中断,否则将视作下载完成.">
    常量 重定向出错 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_SERVER_CROSS_ORIGIN_REDIRECT"
            注释 = "发生了意外的跨域重定向">
    常量 被用户中止 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_USER_CANCELED" 注释 = "下载操作被用户中止">
    常量 浏览器被用户关闭 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_USER_SHUTDOWN">
    常量 浏览器崩溃 <公开 值 = @"@cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_CRASH">
}

类 CEF下载项信息 <公开 注释 = "提供一个正在下载项目的相关信息." 注释 = "注意: 不能新建本类对象或对本类对象进行赋值,只能在处理\"下载更新\"事件时使用所提供的\"下载项\"参数." @禁止创建对象 = 真>
{

    # @begin
    # <> <include>
    # CefRefPtr<CefDownloadItem> m_item;
    # inline_ @sn<current_class> (CefRefPtr<CefDownloadItem> item) : @sn<current_class> ()  { m_item = item; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_item = nullptr; }  // 禁止赋值
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return FALSE; }
    # inline_ BOOL_P IsEmpty () const  { return (m_item.get () == nullptr); }
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象是否为空,为空则不能取出任何信息." 注释 = "处理\"下载更新\"事件接收到的\"下载项\"参数必定不为空." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.IsEmpty ()
    }

    方法 是否正在下载 <公开 类型 = 逻辑型 注释 = "返回本项目是否正在下载中" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_item->IsInProgress ());
    }

    方法 是否已下载完毕 <公开 类型 = 逻辑型 注释 = "返回本项目是否已经下载完毕" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_item->IsComplete ());
    }

    方法 是否被中止 <公开 类型 = 逻辑型 注释 = "返回本项目的下载是否已经被中止" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_item->IsCanceled ());
    }

    方法 是否被中断 <公开 类型 = 逻辑型 注释 = "返回本项目的下载是否已经因为某种原因被中断" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_item->IsInterrupted ());
    }

    方法 取中断原因 <公开 类型 = CEF下载中断原因 注释 = "如果\"是否被中断\"方法返回真,则返回具体的中断原因." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? (INT)cef_download_interrupt_reason_t::CEF_DOWNLOAD_INTERRUPT_REASON_NONE : (INT)m_item->GetInterruptReason ());
    }

    方法 取下载速度 <公开 类型 = 长整数 注释 = "返回当前下载速度,单位: 字节/秒." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? 0 : (INT64)m_item->GetCurrentSpeed ());
    }

    方法 取下载进度 <公开 类型 = 整数 注释 = "返回当前已经下载的百分比,有效值在 0 到 100 之间,返回 -1 表示数据总尺寸未知,无法计算百分比." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? -1 : m_item->GetPercentComplete ());
    }

    方法 取需下载总尺寸 <公开 类型 = 长整数 注释 = "返回欲下载数据的总尺寸,单位字节." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? 0 : (INT64)m_item->GetTotalBytes ());
    }

    方法 取已下载尺寸 <公开 类型 = 长整数 注释 = "返回已经下载数据的尺寸,单位字节." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? 0 : (INT64)m_item->GetReceivedBytes ());
    }

    方法 取起始时间 <公开 类型 = CEF时间 注释 = "返回下载操作的起始时间">
    {
        变量 时间值 <类型 = CEF时间>
        @ if (IsEmpty () == FALSE)  @<时间值>.FromCefTime (m_item->GetStartTime ());
        返回 (时间值)
    }

    方法 取结束时间 <公开 类型 = CEF时间 注释 = "返回下载操作的结束时间">
    {
        变量 时间值 <类型 = CEF时间>
        @ if (IsEmpty () == FALSE)  @<时间值>.FromCefTime (m_item->GetEndTime ());
        返回 (时间值)
    }

    方法 取文件保存路径 <公开 类型 = 文本型 注释 = "取文件已保存或正在保存的完整路径,为空文本表示下载尚未开始、被取消或路径不可用.">
    {
        变量 路径 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetFullPath (), @<路径>);
        返回 (路径)
    }

    方法 "// 取ID" <公开 类型 = 整数 注释 = "返回本下载项对应的\"下载项ID\"值" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? 0 : (INT)m_item->GetId ());
    }

    方法 取当前地址 <公开 类型 = 文本型 注释 = "返回当前下载链接地址">
    {
        变量 地址 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetURL (), @<地址>);
        返回 (地址)
    }

    方法 取最初地址 <公开 类型 = 文本型 注释 = "返回在进行任何重定位操作前的最初下载链接地址">
    {
        变量 地址 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetOriginalUrl (), @<地址>);
        返回 (地址)
    }

    方法 取推荐文件名 <公开 类型 = 文本型 注释 = "返回本下载项推荐保存到的文件名">
    {
        变量 文件名 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetSuggestedFileName (), @<文件名>);
        返回 (文件名)
    }

    方法 取内容展示方式 <公开 类型 = 文本型 注释 = "返回 HTTP 响应头中的\"Content-Disposition\"字段值."
            注释 = "\"Content-Disposition\"响应头指示回复的内容该以何种形式展示,主要有两种类型:" 注释 = "1. inline: 在页面内显示;"
            注释 = "2. attachment: 作为附件下载,通常指定文件名. 其中\"filename\"字段提供所建议的文件名.">
    {
        变量 内容展示方式 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetContentDisposition (), @<内容展示方式>);
        返回 (内容展示方式)
    }

    方法 取媒体类型 <公开 类型 = 文本型 注释 = "返回下载项对应的媒体类型">
    {
        变量 媒体类型值 <类型 = 文本型>
        @ if (IsEmpty () == FALSE)  GetCefStringText (m_item->GetMimeType (), @<媒体类型值>);
        返回 (媒体类型值)
    }
}

类 CEF窗口打开位置 <公开 注释 = "定义了用户点击链接或调用 window.open() 时,目标页面应如何被打开." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 未知 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_UNKNOWN" 注释 = "未识别的位置，不应出现。">
    常量 当前标签页 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_CURRENT_TAB" 注释 = "在当前页面加载目标 URL。这是大多数链接点击的默认行为。">
    常量 单例标签页 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_SINGLETON_TAB"
            注释 = "确保同一个窗口内只有一个该 URL 的标签页。如果已存在，则激活它；否则创建新标签页。">
    常量 前台新标签页 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_NEW_FOREGROUND_TAB"
            注释 = "在前台（立即聚焦）打开一个新标签页。触发：Ctrl/Cmd + 点击链接 或 中键点击（部分配置）。">
    常量 后台新标签页 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_NEW_BACKGROUND_TAB"
            注释 = "在后台（不聚焦）打开一个新标签页。触发：通常由程序逻辑指定，或某些扩展行为。">
    常量 新弹出窗口 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_NEW_POPUP" 注释 = "打开一个独立的弹出式窗口（通常无地址栏、工具栏等，由 window.open() 控制）。">
    常量 新窗口 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_NEW_WINDOW" 注释 = "打开一个全新的浏览器窗口。触发：Shift + 点击链接。">
    常量 保存到磁盘 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_SAVE_TO_DISK" 注释 = "不打开页面，而是下载链接指向的文件。触发：Alt + 点击链接。">
    常量 无痕模式 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_OFF_THE_RECORD" 注释 = "在新的隐私（Incognito）窗口中打开链接。">
    常量 忽略操作 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_IGNORE_ACTION" 注释 = "特殊错误状态，来自渲染进程，表示该操作应被忽略（如脚本阻止了默认行为）。">
    常量 切换到标签页 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_SWITCH_TO_TAB"
            注释 = "搜索所有同配置文件（Profile）的窗口，如果找到相同 URL 的标签页，则激活它；否则退化为\"当前标签页\"或\"前台新标签页\"。比\"单例标签页\"范围更广。">
    常量 新画中画窗口 <公开 值 = @"@cef_window_open_disposition_t::CEF_WOD_NEW_PICTURE_IN_PICTURE"
            注释 = "创建一个新的画中画（PiP）窗口，用于显示视频或特定内容（现代特性）。">
}

类 CEF文本类 <公开 注释 = "用作代表一段在CEF中保存的文本数据" @文档 = "category = \"辅助类\"" @别名类型 = 本地类 @别名 = "CefString">
{
    方法 取文本 <公开 静态 类型 = 文本型 注释 = "获取其中保存的文本数据" @嵌入式方法 = "">
    参数 CEF文本 <类型 = CEF文本类>
    {
        @ GetCefVolString (@<CEF文本>)
    }
}

类 CEF头字段表 <公开 基础类 = 多值哈希表模板类 注释 = "用作提供CEF中的HTML头部信息中的字段列表" @文档 = "category = \"辅助类\"" @模板实现类 = "CEF文本类, CEF文本类">

# ---

类 CEF3浏览器 <公开 基础类 = 窗口组件 注释 = "基于CEF3最新版本(141.0.11)的 HTML 浏览器." 注释 = "注意:" 注释 = "1. 旧版本的\"CEF浏览器\"组件已经被放弃并从系统类库中删除,如果您需要,"
        注释 = "请到 https://www.voldp.com/downloads/old_cef_browser_ctrl.rar 处下载后解压到火山系统安装目录下即可;"
        注释 = "2. 本组件所使用的 CEF3 浏览器基于的是多进程机制,因此使用了本组件的应用程序会被启动多个进程实例,这是正" 注释 = "常的不会影响到用户程序的执行;" 注释 = "3. 不能在控制台程序和动态链接库程序中使用本组件."
        编辑时信息 = "15BFEA, 0, 0, 0" @视窗.后缀文本 = "public ICefWebBrowserEventListener"
        @视窗.窗口组件 = "icon=\"@64\"\r\ndefault_size = \"200, 200\"\r\npreview_unsupported"
        @视窗.头文件搜寻目录 = "..\\mfc_ui_cef_browser\\src\\cef" @视窗.外部头文件.全局 = "src\\wtl_ui_cef_web_browser.h"
        @视窗.外部源文件 = "src\\wtl_ui_cef_web_browser.cpp"
        @视窗.外部库 = "..\\mfc_ui_cef_browser\\src\\cef\\lib\\$(p)_$(d)\\libcef.lib\r\n..\\mfc_ui_cef_browser\\src\\cef\\lib\\$(p)_$(d)\\libcef_dll_wrapper.lib"
        @视窗.附属文件 = "..\\mfc_ui_cef_browser\\src\\cef\\client\\$(p)\\release" @视窗.需求VS版本 = "16-"
        @视窗.编译信息.console = "err:由于cef浏览器需消息循环支持,不能在控制台程序项目中使用本组件." @视窗.编译信息.dll = "err:由于cef浏览器需要子进程支持,不能在动态链接库程序项目中使用本组件.">
{

    # @ @m<DECLARE_WTL_CONTROL_DEFAULT> (CVWnd_CefWebBrowser, ICefWebBrowserEventListener, 0, 0, WS_TABSTOP, WS_EX_CLIENTEDGE)
    #
    # 事件 --

    方法 函数被执行 <公开 定义事件 类型 = 整数 注释 = "当使用\"函数\"属性登记的JS函数在网页中被执行时,本事件被触发.">
    参数 函数名 <类型 = 文本型 注释 = "提供所执行函数的名称">
    参数 参数表 <类型 = 文本数组类 注释 = "提供所有的调用参数">

    方法 链接地址被改变 <公开 定义事件 类型 = 整数 注释 = "在当前所浏览页面链接地址被改变后,本事件被触发.">
    参数 链接地址 <类型 = 文本型 注释 = "提供所改变到的链接地址">
    参数 框架标识符 <类型 = 文本型 注释 = "提供其中链接地址被改变的框架标识符,为空文本表示为主框架.">

    方法 标题被改变 <公开 定义事件 类型 = 整数 注释 = "在当前所浏览页面的窗口标题被改变后,本事件被触发.">
    参数 标题 <类型 = 文本型 注释 = "提供所改变到的标题文本">

    方法 收藏夹图标改变 <公开 定义事件 类型 = 整数 注释 = "  当网页加载过程中,浏览器解析到 <link rel=\"icon\"> 或 <link rel=\"shortcut icon\"> 标签,"
            注释 = "从而发现网站的收藏夹图标的链接地址发生变化时,本事件被发送.">
    参数 图标链接地址 <类型 = 文本数组类 注释 = "提供所有收藏夹图标的链接地址,至少有一个成员.">

    方法 载入进度改变 <公开 定义事件 类型 = 整数 注释 = "当页面资源（如 HTML、CSS、JS、图片等）加载状态发生变化时,都会发送本事件,并传入一个表示整体加载进度的百分比数值.">
    参数 载入进度 <类型 = 整数 注释 = "提供具体的载入进度百分比,值从0到100之间.">

    方法 媒体访问权限改变 <公开 定义事件 类型 = 整数 注释 = "当网页对摄像头和/或麦克风的访问状态发生了改变后发送本事件">
    参数 是否能捕获视频 <类型 = 逻辑型 注释 = "表示浏览器当前是否具有视频捕获权限(例如摄像头)">
    参数 是否能捕获音频 <类型 = 逻辑型 注释 = "表示浏览器当前是否具有音频捕获权限(例如麦克风)">

    方法 全屏模式被改变 <公开 定义事件 类型 = 整数 注释 = "在当前所浏览页面的全屏模式被改变后,本事件被触发.">
    参数 是否全屏 <类型 = 逻辑型 注释 = "提供所切换到的全屏模式">

    方法 显示提示文本 <公开 定义事件 类型 = 整数 注释 = "在需要显示提示文本时,本事件被触发." 返回值注释 = "返回0继续显示提示文本,返回1自行管理提示文本的显示禁止后续的自动显示.">
    参数 提示文本 <类型 = 文本型 注释 = "提供所欲显示的提示文本,可以修改本参数值以改变所显示的提示文本.">

    方法 显示状态信息 <公开 定义事件 类型 = 整数 注释 = "在需要显示状态信息时,本事件被触发.">
    参数 状态信息 <类型 = 文本型>

    方法 显示控制台信息 <公开 定义事件 类型 = 整数 注释 = "在需要显示控制台信息时,本事件被触发." 返回值注释 = "返回0允许显示,返回1禁止显示.">
    参数 控制台信息 <类型 = 文本型>
    参数 源文本 <类型 = 文本型>
    参数 行号 <类型 = 整数>

    方法 即将弹出窗口 <公开 定义事件 类型 = 整数 注释 = "在浏览器即将打开一个窗口前发送本事件."
            注释 = "CEF将所有通过 window.open() 脚本或\"点击链接\"触发的目标页面加载行为,都抽象为一个统一的\"窗口打开请求\"." 注释 = "这个抽象不仅包括真正的新窗口/新标签页,也包括:"
            注释 = "1. 在当前窗口打开 (\"CEF窗口打开位置.当前标签页\");" 注释 = "2. 在新窗口打开 (\"CEF窗口打开位置.新窗口\");" 注释 = "3. 在新标签页打开 (\"CEF窗口打开位置.前台新标签页\");"
            注释 = "4. 在后台标签页打开 (\"CEF窗口打开位置.后台新标签页\")" 注释 = "5. 弹出窗口 (\"CEF窗口打开位置.新弹出窗口\")."
            注释 = "因此,本事件的名字虽然叫\"即将弹出窗口\",但其实际职责是: 在任何\"窗口打开\"请求执行前,进行拦截和控制." 返回值注释 = "返回0允许打开,返回1改为在当前框架内部打开,返回-1禁止打开.">
    参数 链接地址 <类型 = 文本型 注释 = "提供即将打开的弹出窗口所浏览的链接地址,注意可能为空文本(如调用 window.open 不传参).">
    参数 源框架标识符 <类型 = 文本型 注释 = "提供发起弹出请求的源页面框架(即打开新窗口的那个\"父页面\"),为空文本表示为主框架.">
    参数 弹窗ID <类型 = 整数 注释 = "为一个唯一标识值,用于在 CEF 内部唯一地标记本次弹窗请求.">
    参数 目标框架名 <类型 = 文本型 注释 = "提供所弹出新窗口的目标框架名称(如 \"_blank\", \"myWindow\"等),也可能为空文本.">
    参数 窗口打开位置 <类型 = CEF窗口打开位置 注释 = "提供新窗口的打开位置">
    参数 是否为用户手动 <类型 = 逻辑型 注释 = "为真表示本操作为由于用户手动操作导致(譬如鼠标左键单击链接),为假表示为通过程序打开.">
    参数 是否禁止JS访问 <类型 = 逻辑型类 注释 = "用作接收一个逻辑值,处理本事件时置入真则新窗口无法通过 window.opener 访问原窗口(更安全).">

    方法 载入状态被改变 <公开 定义事件 类型 = 整数 注释 = "在当前页面的载入状态被改变时发送本事件." 注释 = "本事件在\"开始载入\"事件之前发送一次,在\"载入出错\"或\"载入完毕\"事件之后被发送一次.">
    参数 是否正在载入 <类型 = 逻辑型 注释 = "提供是否还正在载入当前页面">
    参数 能否后退 <类型 = 逻辑型 注释 = "提供当前页面是否能够后退">
    参数 能否前进 <类型 = 逻辑型 注释 = "提供当前页面是否能够前进">

    方法 开始载入 <公开 定义事件 类型 = 整数 注释 = "在当前页面内某个框架开始载入内容时发送本事件,所有子框架的本事件将在主框架的本事件之后发送.">
    参数 框架标识符 <类型 = 文本型 注释 = "提供所开始载入的页面框架标识符,为空文本表示为主框架.">

    方法 载入完毕 <公开 定义事件 类型 = 整数 注释 = "  在当前页面内某个框架成功载入完毕后发送本事件," 注释 = "所有子框架的本事件将在主框架的本事件之前发送.">
    参数 HTTP状态码 <类型 = 整数 注释 = "提供对应的HTTP状态码">
    参数 框架标识符 <类型 = 文本型 注释 = "提供所载入完毕的页面框架标识符,为空文本表示为主框架.">

    方法 载入出错 <公开 定义事件 类型 = 整数 注释 = "在当前页面内某个框架载入失败后发送本事件" 返回值注释 = "返回0进行默认处理(显示出错信息),返回1禁止默认处理.">
    参数 错误码 <类型 = 整数 注释 = "提供载入出错时的错误码">
    参数 错误文本 <类型 = 文本型 注释 = "提供载入出错时的具体错误文本">
    参数 出错链接地址 <类型 = 文本型 注释 = "提供载入出错时的链接地址">
    参数 框架标识符 <类型 = 文本型 注释 = "提供载入出错的页面框架标识符,为空文本表示为主框架.">

    方法 浏览器被创建 <公开 定义事件 类型 = 整数 注释 = "当CEF浏览器对象被创建后发送本事件">

    方法 浏览器被关闭 <公开 定义事件 类型 = 整数 注释 = "当CEF浏览器对象被关闭后发送本事件">

    方法 即将跳转 <公开 定义事件 类型 = 整数 注释 = "在某框架的当前浏览内容即将跳转前发送本事件" 返回值注释 = "返回0允许跳转,返回1禁止跳转.">
    参数 链接地址 <类型 = 文本型 注释 = "提供即将跳转到的链接地址">
    参数 跳转方法 <类型 = 文本型 注释 = "提供跳转时所使用的方法(POST/GET/...)">
    参数 头字段表 <类型 = CEF头字段表 注释 = "提供跳转时所提供的HTML头字段列表">
    参数 是否为用户手动 <类型 = 逻辑型 注释 = "为真表示本操作为由于用户手动操作导致(譬如鼠标左键单击链接),为假表示为通过程序打开.">
    参数 是否重定位 <类型 = 逻辑型 注释 = "是否进行了重定位">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">

    方法 即将跳转到新浏览器 <公开 定义事件 类型 = 整数 注释 = "当即将在某框架中打开并跳转一个新浏览器前本事件被发送,主要用作拦截和自定义网页中\"在新窗口/标签页中打开链接\"的行为."
            返回值注释 = "返回0允许跳转,返回1禁止跳转.">
    参数 链接地址 <类型 = 文本型 注释 = "提供即将跳转到的链接地址">
    参数 是否为用户手动 <类型 = 逻辑型 注释 = "为真表示本操作为由于用户手动操作导致(譬如鼠标左键单击链接),为假表示为通过程序打开.">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">
    参数 窗口打开位置 <类型 = CEF窗口打开位置 注释 = "提供窗口的打开位置">

    方法 JS对话框 <公开 定义事件 类型 = 整数 注释 = "当需要显示JS对话框时,本事件被发送." 返回值注释 = "  返回0显示默认对话框,返回1表示显示了自己的替代对话框,返回2表示"
            返回值注释 = "显示了自己的替代对话框且用户是通过单击\"确认\"按钮关闭该对话框的." 返回值注释 = "  注意: 如果欲显示自己的对话框,该对话框必须是模态的.">
    参数 对话框类型 <类型 = 整数 注释 = "提供所欲显示JS对话框的类型: 0:警告对话框; 1:确认对话框; 2:提示对话框">
    参数 来源链接地址 <类型 = 文本型 注释 = "提供对应的来源链接地址">
    参数 来源链接地址显示文本 <类型 = 文本型 注释 = "提供来源链接地址的对应显示用文本">
    参数 信息文本 <类型 = 文本型 注释 = "提供对应信息文本">
    参数 默认提示文本 <类型 = 文本型 注释 = "本参数仅当对话框类型为提示对话框时有效,用作提供对应的默认提示文本.">
    参数 用户输入结果 <类型 = 文本型 注释 = "  本参数仅当事件处理程序返回非0值(即显示自己的对话框)时有效,用作返回" 注释 = "用户在所显示自定义对话框中的输入内容到CEF浏览器.">

    方法 离开对话框 <公开 定义事件 类型 = 整数 注释 = "当需要显示离开当前页面的确认对话框时,本事件被发送." 返回值注释 = "  返回0显示默认对话框,返回1表示显示了自己的替代对话框,返回2表示"
            返回值注释 = "显示了自己的替代对话框且用户是通过单击\"确认\"按钮关闭该对话框的." 返回值注释 = "  注意: 如果欲显示自己的对话框,该对话框必须是模态的.">
    参数 信息文本 <类型 = 文本型 注释 = "提供对应信息文本">
    参数 是否为重载 <类型 = 逻辑型 注释 = "提供当前操作是否为重载现行页面">

    方法 默认对话框被关闭 <公开 定义事件 类型 = 整数 注释 = "当CEF实现的默认对话框被关闭后,本事件被发送.">

    方法 重置对话框状态 <公开 定义事件 类型 = 整数 注释 = "当需要取消任何正在等待的对话框并重置所有已保存的对话框状态时,会发送本事件."
            注释 = "如果当前有文件选择对话框(或其他由 CEF 触发的对话框)正处于\"等待用户响应\"的状态(即已弹出但用户还未点击\"打开\"或\"取消\"),CEF 会尝试取消它."
            注释 = "CEF 内部可能会为对话框保存一些临时状态(例如上次打开的目录、过滤器设置、窗口位置等),本事件通知这些内部状态将被重置或清除."
            注释 = "无论当前是否有对话框正在等待,只要发生诸如页面导航之类的事件,就会发送本事件. 例如:"
            注释 = "用户点击链接跳转到新页面; 执行了 window.location.href = \"...\"; 页面通过 history.pushState 或单页应用（SPA）路由发生了变化等."
            注释 = "接收到本事件后,应该进行类似以下清理工作:" 注释 = "1. 清理你为该浏览器实例保存的任何与对话框相关的临时变量;" 注释 = "2. 重置 UI 标志(如\"等待文件选择\"指示器);"
            注释 = "3. 取消与该页面关联的、依赖于对话框结果的异步任务.">

    方法 PDF打印完毕 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始打印到PDF\"方法返回真且\"等待打印完毕\"参数值为假时,打印完毕后将会发送本事件.">
    参数 PDF文件名 <类型 = 文本型 注释 = "提供所打印到的PDF文件名">
    参数 是否打印成功 <类型 = 逻辑型 注释 = "提供是否打印成功">

    方法 获得Cookie <公开 定义事件 类型 = 整数 注释 = "当调用\"枚举Cookie\"方法后,每枚举到一个Cookie时,发送一次本事件." 返回值注释 = "返回1停止继续枚举;" 返回值注释 = "返回0继续枚举;"
            返回值注释 = "返回-1删除当前cookie并继续枚举;" 返回值注释 = "返回-2删除当前cookie并停止继续枚举.">
    参数 cookie <类型 = CEFCookie信息 注释 = "提供所枚举到的Cookie信息">
    参数 为最后一个 <类型 = 逻辑型 注释 = "提供当前所所枚举到的Cookie是否为最后一个能枚举到的Cookie.">

    方法 取验证信息 <公开 定义事件 类型 = 整数 注释 = "当浏览器需要用户提供验证信息时,本事件被发送." 返回值注释 = "返回1表示已经提供了有效的用户名和密码,返回0表示未提供且中止对应的网络请求.">
    参数 来源链接地址 <类型 = 文本型 注释 = "提供对应的来源链接地址">
    参数 主机 <类型 = 文本型 注释 = "提供欲访问主机的名称">
    参数 端口号 <类型 = 整数 注释 = "提供欲访问端口号">
    参数 是否为代理服务器 <类型 = 逻辑型 注释 = "为真表示欲访问的主机为代理服务器">
    参数 域名 <类型 = 文本型 注释 = "本参数有可能为空文本">
    参数 验证协议 <类型 = 文本型 注释 = "提供所使用的验证协议,譬如\"basic\"/\"digest\",有可能为空文本(如果所访问主机为FTP服务器).">
    参数 用户名 <类型 = 文本型 注释 = "事件处理方法需要在本参数中填入所提供的访问授权用户名">
    参数 密码 <类型 = 文本型 注释 = "事件处理方法需要在本参数中填入所提供的访问授权密码">

    方法 证书验证错误 <公开 定义事件 类型 = 整数 注释 = "  当 CEF 尝试加载一个 HTTPS 资源（如网页、API 调用）时，如果服务器的 SSL 证书无法通过浏览器的"
            注释 = "安全验证（例如，证书过期、自签名、域名不匹配、被吊销等），CEF 会发送此事件，让你有机会决定如何" 注释 = "处理这个安全风险，而不是直接中断连接并显示错误页面。"
            返回值注释 = "返回0将使用默认行为(通常是显示一个\"您的连接不是私密连接\"的错误页面,并中断连接),返回1忽略此错误.">
    参数 错误码 <类型 = 整数 注释 = "提供具体的CEF错误码值,有关证书验证失败的常见值有:" 注释 = "-200: 证书的通用名称 (CN) 或主题备用名称 (SAN) 与请求的域名不匹配;"
            注释 = "-201: 证书已过期或尚未生效;" 注释 = "-202: 证书颁发机构 (CA) 不受信任(例如: 自签名证书);" 注释 = "-203: 证书本身包含错误;" 注释 = "-206: 证书已被吊销."
            注释 = "还有很多其它错误值,具体请查阅相关CEF API文档.">
    参数 所请求链接地址 <类型 = 文本型 注释 = "提供发生错误的 HTTPS 请求的完整链接地址">

    方法 渲染视图已就绪 <公开 定义事件 类型 = 整数 注释 = "本事件将在以下情况下被发送:" 注释 = "1. 浏览器创建完成: 当你创建一个新浏览器后, CEF 会启动渲染进程,当这个进程初始化完毕,主渲染视图建立后,就会发送本事件;"
            注释 = "2. 渲染进程重启: 如果渲染进程由于崩溃等原因被 CEF 重新启动,在新的渲染进程和视图准备就绪后,也会再次发送本事件."
            注释 = "在 CEF 的架构中,浏览器进程和渲染进程是分离的,你在主进程中(浏览器进程)调用的许多方法(尤其是与 JavaScript 和 DOM 相关的),需要通过 IPC (进程间通信) 发送到渲染进程去执行."
            注释 = "在接收到本事件之前,渲染进程可能尚未完全启动,或者主渲染视图还未创建. 此时调用\"执行JS脚本\"方法可能会失败或被静默丢弃,尝试注入 JavaScript 或访问 DOM 可能不会生效."
            注释 = "一旦接收到本事件,你就有了一个可靠的保证: 渲染视图已经存在,可以安全地执行 JavaScript 和与页面内容交互,此时是执行初始化 JavaScript 代码和设置页面环境的最佳时机.">

    方法 主框架文档已就绪 <公开 定义事件 类型 = 整数
            注释 = "接收到本事件标志着一个关键的、比\"渲染视图已就绪\"事件更精确的页面加载阶段: 主页面框架的 HTML 文档对象 (Document Object) 已经在渲染进程中创建并可用."
            注释 = "本事件在页面加载生命周期中的非常早期被发送,具体时机是:" 注释 = "1. 渲染进程已经启动(\"渲染视图已就绪\"事件已经或即将被调用);" 注释 = "2. 主框架的文档对象(即 window.document)已经创建."
            注释 = "但是此时HTML文档可能尚未完全解析,\"<script>\"和\"<link>\"标签引用的外部资源(如 CSS、JavaScript 文件)可能还在下载中,DOM 树可能只构建了一部分."
            注释 = "在 CEF 的架构中,本事件解决了一个长期存在的痛点:" 注释 = "1. \"渲染视图已就绪\"事件的局限性:"
            注释 = "  该事件只保证渲染视图存在,可以接收 IPC 消息,但它不保证\"window.document\"对象已经创建,在此事件触发后立即执行: 执行JS脚本(\"document.getElementById(\'...\')\"),"
            注释 = "可能会失败,因为 document 可能还不存在或为空." 注释 = "2. 本事件的优势:"
            注释 = "  接收到本事件可以明确确定: document 对象现在存在了,这是最早可以安全地执行依赖于 document 对象的 JavaScript 的时机,它比\"载入状态被改变\"事件(\"是否正在载入\"参数为假)早得多,"
            注释 = "允许你更早地介入页面加载过程。" 注释 = "主要用途: 本事件是执行最早期 JavaScript 注入(如: 注入\"启动器\"脚本,为后续的 JS 执行做准备)和修改页面初始环境的理想时机."
            注释 = "各种相关事件特性对比(发送时机 / 是否保证 document 存在 / 用途):" 注释 = "\"浏览器被创建\": 在浏览器进程创建了浏览器对象后发送 / document不存在 / 用作初始化浏览器对象、窗口等;"
            注释 = "\"渲染视图已就绪\": 在渲染进程已创建渲染视图后发送 / document不确定存在 / 可以发送 IPC,但 JS 执行可能失败;"
            注释 = "\"主框架文档已就绪\": 主框架的 document 对象创建后发送 / document已存在 / 最早安全执行 JS 的时机;"
            注释 = "\"载入状态被改变\"事件(\"是否正在载入\"参数为假): 页面(主框架)完全加载后发送 / document已存在 / 可以执行依赖完整资源和 DOM 的操作.">

    方法 是否允许下载 <公开 定义事件 类型 = 整数 注释 = "当浏览器在下载指定URL前,本事件被发送." 返回值注释 = "返回0表示允许下载,返回1表示不允许下载.">
    参数 下载链接地址 <类型 = 文本型 注释 = "提供对应的下载链接URL地址">
    参数 请求方法 <类型 = 文本型 注释 = "提供对应的请求方法名称,如: \"GET\", \"POST\" 等.">

    方法 即将下载 <公开 定义事件 类型 = 整数 注释 = "当浏览器即将下载指定URL时,本事件被发送." 返回值注释 = "返回0表示正常下载,返回1时进行如下默认处理: 浏览器为Alloy风格就取消下载,为Chrome风格就显示下载框架.">
    参数 下载链接地址 <类型 = 文本型 注释 = "提供对应的下载链接URL地址">
    参数 推荐文件名 <类型 = 文本型 注释 = "提供所推荐使用的下载数据保存到的本地文件名">
    参数 保存到文件名 <类型 = 文本型 注释 = "用作接收保存到文件名." 注释 = "用户在处理本事件时,可以在其中填写一个全路径的本地文件名,下载数据将被保存到该文件中."
            注释 = "如果未填写,则将把推荐文件名和系统临时目录组合起来建立默认文件名.">
    参数 是否显示文件对话框 <类型 = 逻辑型类 注释 = "用作接收是否显示文件另存为对话框." 注释 = "用户在处理本事件时,将本参数设置为真将显示文件另存为对话框以获取保存到文件名,为假则不显示.">

    方法 下载更新 <公开 定义事件 类型 = 整数 注释 = "当浏览器正在下载的项目进度或其它信息更新后,本事件被发送." 返回值注释 = "返回0表示继续下载,返回1表示暂停该项目下载,返回-1表示中止该项目下载.">
    参数 下载项ID <类型 = 整数 注释 = "提供当前下载项的ID值,必定不为0. 可以将其保存起来在\"暂停下载\"/\"继续下载\"/\"中止下载\"/\"是否已下载结束\"等方法中使用.">
    参数 下载项 <类型 = CEF下载项信息 注释 = "提供下载项的当前信息,必定不为空. 注意: 只能在处理本事件时使用,不能将其保存起来在以后使用.">
    参数 刚开始下载 <类型 = 逻辑型 注释 = "提供本次更新是否为开始下载后的首次更新,用户可以在接收到此类型事件后进行一些初始化工作.">

    方法 下载结束 <公开 定义事件 类型 = 整数 注释 = "当浏览器结束下载指定项目(下载完成/被中止/被中断/已超时)后,本事件被发送." 注释 = "发送本事件之前,必定已经发送了\"刚开始下载\"参数为真的\"下载更新\"事件.">
    参数 下载项ID <类型 = 整数 注释 = "提供已结束下载项的ID值,必定不为0.">
    参数 结束原因 <类型 = CEF下载结束原因 注释 = "提供下载结束的具体原因">
    参数 中断原因 <类型 = CEF下载中断原因 注释 = "如果\"结束原因\"参数值为\"CEF下载结束原因.被中断\",提供具体中断原因.">

    方法 图像下载完毕 <公开 定义事件 类型 = 整数 注释 = "当调用\"下载图像\"方法后,无论下载成功还是失败,都会被发送本事件,用作提供下载结果.">
    参数 图像链接地址 <类型 = 文本型 注释 = "提供所下载的图像链接地址,与调用\"下载图像\"方法时所传入的对应参数一致.">
    参数 响应状态码 <类型 = 整数 注释 = "HTTP响应状态码: 200: 成功; 404: 文件未找到; 403: 禁止访问; 其他非 200 值均表示失败.">
    参数 所下载图像 <类型 = CEF图像 注释 = "提供下载并解码后的图像对象." 注释 = "如果下载成功且图像有效,这是一个有效不为空(\"是否为空\"方法返回假)的CEF图像实例."
            注释 = "如果下载失败(网络错误、HTTP 错误、不是有效图像等),将返回为空的CEF图像实例.">

    方法 获得查找结果 <公开 定义事件 类型 = 整数 注释 = "当调用\"查找\"方法后,将发送本事件以报告查找结果.">
    参数 匹配项总数 <类型 = 整数 注释 = "提供页面中匹配项的总数." 注释 = "如果为 0，表示未找到任何匹配。" 注释 = "这个值可能在搜索过程中动态变化（例如，页面动态加载内容时）。">
    参数 矩形位置 <类型 = 矩形类 注释 = "当前激活的匹配项(即被高亮显示的那个)在窗口坐标系下的矩形区域." 注释 = "注意: 是相对于整个浏览器窗口的位置，不是网页内的相对位置。">
    参数 匹配项序号 <类型 = 整数 注释 = "当前激活的匹配项的序号,为从 1 到\"匹配项总数\"." 注释 = "如: 如果有 5 个匹配,当前高亮的是第 3 个,则本参数值为 3 .">
    参数 是否为最终更新 <类型 = 逻辑型 注释 = "提供是否是本次搜索的最终结果更新." 注释 = "为假: 搜索仍在进行中,\"匹配项总数\"和\"匹配项序号\"参数值可能不完整,CEF 可能会在新内容加载后再次发送本事件."
            注释 = "为真: 搜索已完成.\"匹配项总数\"和\"匹配项序号\"参数是最终的、完整的值."
            注释 = "注意: 应该只在本参数值为真时更新 UI 的最终状态(如\"未找到\"或\"X/Y\"),在本参数值为假时,可以显示\"搜索中...\"或暂时性的计数.">

    方法 框架被创建 <公开 定义事件 类型 = 整数 注释 = "当浏览器中的任意一个页面框架被成功创建后发送本事件">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">

    方法 框架被销毁 <公开 定义事件 类型 = 整数 注释 = "当一个页面框架即将被销毁前(如页面关闭、<iframe> 被移除)发送本事件">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">

    方法 框架被附加 <公开 定义事件 类型 = 整数 注释 = "当一个页面框架附加到浏览器的 DOM 树中时(例如动态添加 <iframe> 到页面)发送本事件">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">
    参数 是否为重新挂接 <类型 = 逻辑型 注释 = "  参数值为假: 表示该框架是首次被附加到文档. 通常发生在: 页面初始加载时主框架的附加; 动态创建一个新的 <iframe> 并插入 DOM,这是一个\"从无到有\"的挂载过程;"
            注释 = "  参数值为真: 表示该框架之前已被附加过,后来被移除,现在又被重新插入 DOM. 通常发生在: JavaScript 操作 DOM，如 appendChild() 一个之前被移除的 <iframe> 元素,"
            注释 = "框架在 display:none 或从 DOM 移除后又被恢复,此时框架的内部状态（如 JavaScript 上下文）可能仍然存在.">

    方法 框架被移除 <公开 定义事件 类型 = 整数 注释 = "当一个页面框架从浏览器的 DOM 树中被移除时(但尚未销毁)发送本事件">
    参数 框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为主框架.">

    方法 主框架改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器的主页面框架发生变更时(例如页面跳转、历史记录导航导致主框架更换)发送本事件">
    参数 原主框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为当前主框架.">
    参数 新主框架标识符 <类型 = 文本型 注释 = "提供对应的页面框架标识符,为空文本表示为当前主框架.">

    方法 浏览器按下某键1 <公开 定义事件 类型 = 整数 注释 = "当用户在浏览器上按下某个按键时,本事件将在页面中 JaveScript 脚本处理该按键事件之前发送,可以用作拦截JS中对该按键的处理."
            返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续发送给页面中 JaveScript 脚本或进行系统默认处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 浏览器放开某键1 <公开 定义事件 类型 = 整数 注释 = "当用户在浏览器上放下某个按键时,本事件将在页面中 JaveScript 脚本处理该按键事件之前发送,可以用作拦截JS中对该按键的处理."
            返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续发送给页面中 JaveScript 脚本或进行系统默认处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 浏览器按下某键2 <公开 定义事件 类型 = 整数 注释 = "当用户在浏览器上按下某个按键时,本事件将在页面中 JaveScript 脚本处理该按键事件之后发送."
            返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续系统默认处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 浏览器放开某键2 <公开 定义事件 类型 = 整数 注释 = "当用户在浏览器上放下某个按键时,本事件将在页面中 JaveScript 脚本处理该按键事件之后发送."
            返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续系统默认处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    # 属性 --

    方法 背景颜色 <公开 属性读 类型 = 整数 注释 = "返回当前所设置的本组件本身的背景颜色值" @嵌入式方法 = "">
    {
        @ (INT)((CVWnd_CefWebBrowser*)@sn<this>.GetWtlControlPtr ())->m_clrBack
    }

    方法 背景颜色 <公开 属性写 注释 = "设置本组件本身的背景颜色值" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前>
    参数 所欲设置颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ ((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->m_clrBack = @<所欲设置颜色值>;
    }

    方法 链接地址 <公开 属性读 类型 = 文本型 注释 = "返回主框架所浏览页面的链接地址" @嵌入式方法 = "">
