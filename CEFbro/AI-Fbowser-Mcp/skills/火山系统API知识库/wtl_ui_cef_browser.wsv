    方法 缩放级别 <公开 属性读 类型 = 小数 注释 = "返回本浏览器的缩放级别" @禁止流程检查 = 真>
    {
        @ CefRefPtr<CefBrowser> browser;
        @ return ((((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL) ? browser->GetHost ()->GetZoomLevel () : 0);
    }

    方法 缩放级别 <公开 属性写 注释 = "设置本浏览器的缩放级别">
    参数 所欲设置的缩放级别 <类型 = 小数 注释 = "必须大于等于0">
    {
        @ CefRefPtr<CefBrowser> browser;
        @ if (((CVWnd_CefWebBrowser*)GetWtlControlPtr ())->GetBrowser (browser) && browser->GetHost ().get () != NULL)
        @     browser->GetHost ()->SetZoomLevel (MAX (0, @<所欲设置的缩放级别>));
    }

    方法 默认编码 <公开 属性读 类型 = 文本型 注释 = "返回所使用的网页内容默认编码,如果为空,则将使用\"ISO-8859-1\"." @嵌入式方法 = "">
