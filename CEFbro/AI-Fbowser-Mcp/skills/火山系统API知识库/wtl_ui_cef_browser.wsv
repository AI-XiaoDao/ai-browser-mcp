类 CEFCookie信息 <公开 注释 = "提供CEF的Cookie信息" @文档 = "category = \"辅助类\"">
{
    变量 名称 <公开 类型 = 文本型 注释 = "提供Cookie的名称">
    变量 值 <公开 类型 = 文本型 注释 = "提供Cookie的值">
    变量 域名 <公开 类型 = 文本型 注释 = "  如果域名为空文本,则将创建一个主机Cookie来替换此域名Cookie." 注释 = "  域名Cookie存储时将以句点\'.\'字符为开头并对所有下属子域名可见,"
            注释 = "而主机Cookie不会如此.">
    变量 路径 <公开 类型 = 文本型 注释 = "如果路径非空,则只有在此路径下的链接地址网页才能获取此Cookie值.">
    变量 仅安全链接使用 <公开 类型 = 逻辑型 注释 = "如果为真则本Cookie只在 Https 安全链接请求下才会发送">
    变量 仅普通链接使用 <公开 类型 = 逻辑型 注释 = "如果为真则本Cookie只在 Http 请求下才会发送">
    变量 是否会过期 <公开 类型 = 逻辑型 注释 = "指定本Cookie是否会过期">
    变量 过期时间 <公开 类型 = CEF时间 注释 = "如果\"是否会过期\"为真,则提供具体的过期时间.">
    变量 创建时间 <公开 类型 = CEF时间 注释 = "本成员由CEF自动维护(用户无需填写),用作提供本Cookie的创建时间.">
    变量 最后访问时间 <公开 类型 = CEF时间 注释 = "本成员由CEF自动维护(用户无需填写),用作提供本Cookie的最后访问时间.">

    # @begin
    # <> <include>
    # void FromCefCookie (const CefCookie& cookie);
    # void ToCefCookie (CefCookie& cookie);
    # <> </include>
    # void @sn<current_class>::FromCefCookie (const CefCookie& cookie)
    # {
    #     GetCefStringText (CefString (&cookie.name), @<名称>);  GetCefStringText (CefString (&cookie.value), @<值>);  GetCefStringText (CefString (&cookie.domain), @<域名>);
    #     GetCefStringText (CefString (&cookie.path), @<路径>); @<仅安全链接使用> = (cookie.secure != FALSE);  @<仅普通链接使用> = (cookie.httponly != FALSE);
    #     @<是否会过期> = (cookie.has_expires != FALSE); @<过期时间>.FromCefTime (cookie.expires);  @<创建时间>.FromCefTime (cookie.creation); @<最后访问时间>.FromCefTime (cookie.last_access);
    # }
    # void @sn<current_class>::ToCefCookie (CefCookie& cookie)
    # {
    #     CefString (&cookie.name) = (const char16_t*)@<名称>.GetText ();  CefString (&cookie.value) = (const char16_t*)@<值>.GetText ();  CefString (&cookie.domain) = (const char16_t*)@<域名>.GetText ();
    #     CefString (&cookie.path) = (const char16_t*)@<路径>.GetText (); cookie.secure = @<仅安全链接使用>;  cookie.httponly = @<仅普通链接使用>;  cookie.has_expires = @<是否会过期>;
    #     cookie.expires = @<过期时间>.ToCefTime ();  cookie.creation = @<创建时间>.ToCefTime ();  cookie.last_access = @<最后访问时间>.ToCefTime ();
    # }
    # @end
}

