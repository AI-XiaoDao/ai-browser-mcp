包 火山.WTL界面.浏览器 <编辑时信息 = "192A91, 0, 0, 0">

# @begin
# @def_macro DECLARE_CEF_OBJECT_CLASS(cef_data_type)  \
# <>     <include>  \
#     CefRefPtr<cef_data_type> m_objCef;  \
#     inline_ @sn<current_class> (CefRefPtr<cef_data_type> objCef) : @sn<current_class> ()  { m_objCef = objCef; }  \
#     inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_objCef = objCopyFrom.m_objCef; }  \
#     inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return (m_objCef.get () == objCompare.m_objCef.get ()); }  \
#     inline_ BOOL_P IsEmpty () const  { return (m_objCef.get () == NULL); }  \
#     inline_ void Set (CefRefPtr<cef_data_type> objCef)  { m_objCef = objCef; }  \
# <>     </include>
# @end

类 CEF字节集类 <公开 注释 = "用作在CEF中保存一段字节集数据">
{

    # @ @m<DECLARE_CEF_OBJECT_CLASS> (CefBinaryValue)

    方法 创建 <公开 静态 类型 = CEF字节集类 注释 = "创建并返回一个本类对象实例" @禁止流程检查 = 真>
    参数 欲复制数据 <类型 = 字节集类 注释 = "提供欲复制到本对象中的字节集数据">
    {
        @ return @sn<current_class> (CefBinaryValue::Create (@<欲复制数据>.GetPtr (), (size_t)@<欲复制数据>.GetSize ()));
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象是否为空" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () || m_objCef->IsValid () == false);
    }

    方法 复制 <公开 类型 = CEF字节集类 注释 = "建立并返回一个本对象的复制对象,该对象将复制本对象中的所有数据内容.">
    {
        变量 字节集1 <类型 = CEF字节集类>
        @ if (IsEmpty () == FALSE && m_objCef->IsValid ())
        @     @<字节集1>.Set (m_objCef->Copy ());
        返回 (字节集1)
    }

    方法 取数据指针 <公开 类型 = 变整数 注释 = "返回本对象中数据的指针值,如不存在将返回0." @禁止流程检查 = 真>
    {
        @ return ((IsEmpty () || m_objCef->IsValid () == false) ? 0 : (INT_P)m_objCef->GetRawData ());
    }

    方法 取数据尺寸 <公开 类型 = 整数 注释 = "返回本对象中数据的尺寸" @禁止流程检查 = 真>
    {
        @ return ((IsEmpty () || m_objCef->IsValid () == false) ? 0 : (INT)m_objCef->GetSize ());
    }

    方法 取数据 <公开 注释 = "获取本对象中指定尺寸的数据">
    参数 起始偏移 <类型 = 整数 注释 = "指定欲获取数据在本对象中的起始偏移位置,必须大于等于0." @默认值 = 0>
    参数 欲获取数据尺寸 <类型 = 整数 注释 = "提供欲获取数据的尺寸,为-1表示获取起始偏移之后的所有数据." @默认值 = -1>
    参数 保存到字节集 <类型 = 字节集类 注释 = "用作存储所获得的数据,必须大于等于0." @需求类型 = 可写入变量>
    {
        保存到字节集.清空字节集 ()
        @ if (@<起始偏移> >= 0 && IsEmpty () == FALSE && m_objCef->IsValid ())
        @ {
        @     if (@<欲获取数据尺寸> < 0)
        @         @<欲获取数据尺寸> = (INT)m_objCef->GetSize () - @<起始偏移>;
        @     if (@<欲获取数据尺寸> > 0)
        @     {
        @         size_t stSize = m_objCef->GetData (@<保存到字节集>.Alloc (@<欲获取数据尺寸>), (size_t)@<欲获取数据尺寸>, (size_t)@<起始偏移>);
        @         @<保存到字节集>.Realloc ((INT_P)stSize);
        @     }
        @ }
    }
}

类 CEF颜色类型 <公开 注释 = "提供CEF颜色的具体类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 RGBA8888 <公开 值 = @"@cef_color_type_t::CEF_COLOR_TYPE_RGBA_8888" 注释 = "32位像素格式,每个像素值使用4个字节保存,顺序为\"红/绿/蓝/透明度\"字节值."
            注释 = "这是许多跨平台图形库和现代系统(如 macOS、iOS)中常见的格式.">
    常量 BGRA8888 <公开 值 = @"@cef_color_type_t::CEF_COLOR_TYPE_BGRA_8888" 注释 = "32位像素格式,每个像素值使用4个字节保存,顺序为\"蓝/绿/红/透明度\"字节值.">
}

类 CEF透明度类型 <公开 注释 = "提供CEF透明度的具体类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 不透明 <公开 值 = @"@cef_alpha_type_t::CEF_ALPHA_TYPE_OPAQUE" 注释 = "图像完全不透明，没有透明度。Alpha 通道（如果存在）将被忽略。整个图像被视为 100% 不透明。">
    常量 预乘透明度 <公开 值 = @"@cef_alpha_type_t::CEF_ALPHA_TYPE_PREMULTIPLIED" 注释 = "像素的颜色分量（R, G, B）的值已经乘以了 Alpha (A) 值。"
            注释 = "在存储时：R\' = R * A, G\' = G * A, B\' = B * A。" 注释 = "像素数据中存储的是 (R\', G\', B\', A)。">
    常量 后乘透明度 <公开 值 = @"@cef_alpha_type_t::CEF_ALPHA_TYPE_POSTMULTIPLIED"
            注释 = "颜色分量（R, G, B）和 Alpha 分量是独立存储的。颜色值是原始的，未经过 Alpha 缩放。" 注释 = "像素数据中直接存储原始颜色和透明度：(R, G, B, A)。"
            注释 = "在渲染时，引擎需要先计算 R * A, G * A, B * A，然后再进行混合。" 注释 = "PNG 文件解码后的原始输出通常是这种格式。">
}

类 CEF图像 <公开 注释 = "对应CEF浏览器中处理的图像" "">
{

    # @ @m<DECLARE_CEF_OBJECT_CLASS> (CefImage)

    方法 创建 <公开 静态 类型 = CEF图像 注释 = "创建并返回一个本类对象实例" @禁止流程检查 = 真>
    {
        @ return @sn<current_class> (CefImage::CreateImage ());
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象是否为空" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () || m_objCef->IsEmpty ());
    }

    方法 加入位图 <公开 类型 = 逻辑型 注释 = "将指定位图数据加入本对象中,返回是否成功." @禁止流程检查 = 真>
    参数 图像宽度 <类型 = 整数 注释 = "指定\"图像数据\"参数中图像的实际宽度(单位像素)."
            注释 = "注意: 这个尺寸是相对于\"设备缩放因子\"的。例如，设备缩放因子=2.0 且 图像宽度=32 意味着这个图像是为 2x 缩放设计的，其逻辑尺寸是 32 / 2.0 = 16。">
    参数 图像高度 <类型 = 整数 注释 = "指定\"图像数据\"参数中图像的实际高度(单位像素).">
    参数 图像数据 <类型 = 字节集类 注释 = "提供具体的图像数据,其格式及尺寸必须与本方法中的其它参数保持一致.">
    参数 设备缩放因子 <类型 = 小数 注释 = "指定了这组像素数据所对应的设备缩放因子 (Device Scale Factor)。" 注释 = "作用: 允许一个本类对象存储同一图像的多个分辨率版本，以适应不同 DPI 的屏幕。"
            注释 = "设备缩放因子 = 1.0: 对应 1x 分辨率 (标准 DPI)。" 注释 = "设备缩放因子 = 2.0: 对应 2x 分辨率 (如 Retina 屏幕)，图像尺寸是 1x 版本的两倍。"
            注释 = "示例: 如果你想为一个逻辑尺寸为 16x16 的图标提供 1x 和 2x 支持：" 注释 = "调用 加入位图 (1.0, 16, 16, ...) 添加一个 16x16 的图像。"
            注释 = "调用 加入位图 (2.0, 32, 32, ...) 添加一个 32x32 的高清版本。" 注释 = "CEF 会根据当前显示器的 DPI 自动选择最合适的版本。" @默认值 = 1.0>
    参数 颜色类型 <类型 = CEF颜色类型 注释 = "指定\"图像数据\"参数中图像的颜色格式" @默认值 = CEF颜色类型.RGBA8888>
    参数 透明度类型 <类型 = CEF透明度类型 注释 = "指定\"图像数据\"参数中图像的透明度格式" @默认值 = CEF透明度类型.不透明>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_objCef->AddBitmap ((float)@<设备缩放因子>, @<图像宽度>, @<图像高度>, (cef_color_type_t)@<颜色类型>, (cef_alpha_type_t)@<透明度类型>, @<图像数据>.GetPtr (), (size_t)@<图像数据>.GetSize ()));
    }

    方法 加入PNG图像 <公开 类型 = 逻辑型 注释 = "将指定PNG格式图像数据加入本对象中,返回是否成功." @禁止流程检查 = 真>
    参数 图像数据 <类型 = 字节集类 注释 = "提供具体的PNG格式图像数据">
    参数 设备缩放因子 <类型 = 小数 注释 = "指定了这组像素数据所对应的设备缩放因子 (Device Scale Factor)." 注释 = "有关\"设备缩放因子\",参见\"加入位图\"方法的\"设备缩放因子\"参数解释."
            @默认值 = 1.0>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_objCef->AddPNG ((float)@<设备缩放因子>, @<图像数据>.GetPtr (), (size_t)@<图像数据>.GetSize ()));
    }

    方法 加入JPEG图像 <公开 类型 = 逻辑型 注释 = "将指定JPEG格式图像数据加入本对象中,返回是否成功." @禁止流程检查 = 真>
    参数 图像数据 <类型 = 字节集类 注释 = "提供具体的JPEG格式图像数据">
    参数 设备缩放因子 <类型 = 小数 注释 = "指定了这组像素数据所对应的设备缩放因子 (Device Scale Factor)." 注释 = "有关\"设备缩放因子\",参见\"加入位图\"方法的\"设备缩放因子\"参数解释."
            @默认值 = 1.0>
    {
        @ return (IsEmpty () ? FALSE : (BOOL)m_objCef->AddJPEG ((float)@<设备缩放因子>, @<图像数据>.GetPtr (), (size_t)@<图像数据>.GetSize ()));
    }

    方法 宽度 <公开 属性读 类型 = 整数 注释 = "返回图像宽度" @禁止流程检查 = 真>
    {
        @ return (@<是否为空> () ? 0 : (INT)m_objCef->GetWidth ());
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "返回图像高度" @禁止流程检查 = 真>
    {
        @ return (@<是否为空> () ? 0 : (INT)m_objCef->GetHeight ());
    }

    方法 是否有指定分辨率图像 <公开 类型 = 逻辑型 注释 = "返回本对象中是否已经为指定的设备缩放因子添加了图像数据."
            注释 = "这是在处理高 DPI (HiDPI) 显示时非常重要的一个方法，因为它允许你在添加或使用图像数据之前，先查询其状态，避免重复添加或确保所需分辨率的数据已存在。" @禁止流程检查 = 真>
    参数 设备缩放因子 <类型 = 小数 注释 = "提供所欲检查的设备缩放因子 (Device Scale Factor)." 注释 = "有关\"设备缩放因子\",参见\"加入位图\"方法的\"设备缩放因子\"参数解释.">
    {
        @ return (@<是否为空> () ? FALSE : (BOOL)m_objCef->HasRepresentation ((float)@<设备缩放因子>));
    }

    方法 删除指定分辨率图像 <公开 类型 = 逻辑型 注释 = "删除本对象中为指定的设备缩放因子所添加的图像数据,返回是否成功." @禁止流程检查 = 真>
    参数 设备缩放因子 <类型 = 小数 注释 = "提供所欲处理的设备缩放因子 (Device Scale Factor)." 注释 = "有关\"设备缩放因子\",参见\"加入位图\"方法的\"设备缩放因子\"参数解释.">
    {
        @ return (@<是否为空> () ? FALSE : (BOOL)m_objCef->RemoveRepresentation ((float)@<设备缩放因子>));
    }

    方法 取指定分辨率信息 <公开 类型 = 逻辑型 注释 = "获取已添加到本对象中的匹配特定缩放因子表示的详细信息,返回是否成功." @禁止流程检查 = 真>
    参数 期望缩放因子 <类型 = 小数 注释 = "指定希望匹配的设备缩放因子。" 注释 = "如: 1.0 (1x), 2.0 (2x HiDPI)。" 注释 = "作为查询的“提示”或“目标”。CEF 会尝试找到最接近这个值的已添加图像。">
    参数 匹配缩放因子 <类型 = 小数类 注释 = "用作返回所实际匹配到的缩放因子."
            注释 = "例如: 如果你请求 1.25 ，而图像只有 1.0 和 2.0 的表示，CEF 可以选择一个“最佳匹配”（例如 1.0），然后通过本参数告诉你：“你要 1.25，但我给了你 1.0 的版本”。" @需求类型 = 可写入变量>
    参数 匹配图像宽度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的宽度(单位像素)." @需求类型 = 可写入变量>
    参数 匹配图像高度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的高度(单位像素)." @需求类型 = 可写入变量>
    {
        @ if (@<是否为空> ())  return FALSE;
        @ float actual_scale_factor = 1.0f;
        @ if (m_objCef->GetRepresentationInfo ((float)@<期望缩放因子>, actual_scale_factor, @<匹配图像宽度.值>, @<匹配图像高度.值>) == false)  return FALSE;
        @ @<匹配缩放因子.值> = (DOUBLE)actual_scale_factor;
        @ return TRUE;
    }

    方法 取位图数据 <公开 类型 = CEF字节集类 注释 = "返回本对象中最匹配所要求分辨率的图像数据" 返回值注释 = "成功返回所获得的图像字节集,失败所返回对象的内容为空.">
    参数 期望缩放因子 <类型 = 小数 注释 = "指定希望匹配的设备缩放因子。" 注释 = "如: 1.0 (1x), 2.0 (2x HiDPI)。" 注释 = "作为查询的“提示”或“目标”。CEF 会尝试找到最接近这个值的已添加图像。">
    参数 期望颜色类型 <类型 = CEF颜色类型 注释 = "指定所期望输出的图像颜色格式" @默认值 = CEF颜色类型.RGBA8888>
    参数 期望透明度类型 <类型 = CEF透明度类型 注释 = "指定所期望输出的图像透明度格式" @默认值 = CEF透明度类型.不透明>
    参数 匹配图像宽度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的宽度(单位像素)." @需求类型 = 可写入变量>
    参数 匹配图像高度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的高度(单位像素)." @需求类型 = 可写入变量>
    {
        变量 字节集1 <类型 = CEF字节集类>
        如果 (是否为空 () == 假)
        {
            @ @<字节集1>.Set (m_objCef->GetAsBitmap ((float)@<期望缩放因子>, (cef_color_type_t)@<期望颜色类型>, (cef_alpha_type_t)@<期望透明度类型>, @<匹配图像宽度.值>, @<匹配图像高度.值>));
        }
        返回 (字节集1)
    }

    方法 取PNG位图数据 <公开 类型 = CEF字节集类 注释 = "返回本对象中最匹配所要求分辨率的PNG格式图像数据" 返回值注释 = "成功返回所获得的图像字节集,失败所返回对象的内容为空.">
    参数 期望缩放因子 <类型 = 小数 注释 = "指定希望匹配的设备缩放因子。" 注释 = "如: 1.0 (1x), 2.0 (2x HiDPI)。" 注释 = "作为查询的“提示”或“目标”。CEF 会尝试找到最接近这个值的已添加图像。">
    参数 是否包含透明度 <类型 = 逻辑型 注释 = "指定所输出的图像数据是否包含透明度通道值" @默认值 = 真>
    参数 匹配图像宽度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的宽度(单位像素)." @需求类型 = 可写入变量>
    参数 匹配图像高度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的高度(单位像素)." @需求类型 = 可写入变量>
    {
        变量 字节集1 <类型 = CEF字节集类>
        如果 (是否为空 () == 假)
        {
            @ @<字节集1>.Set (m_objCef->GetAsPNG ((float)@<期望缩放因子>, (bool)@<是否包含透明度>, @<匹配图像宽度.值>, @<匹配图像高度.值>));
        }
        返回 (字节集1)
    }

    方法 取JPEG位图数据 <公开 类型 = CEF字节集类 注释 = "返回本对象中最匹配所要求分辨率的JPEG格式图像数据." 注释 = "注意: 由于JPEG格式不支持透明度,源位图中的透明度通道值将被抛弃."
            返回值注释 = "成功返回所获得的图像字节集,失败所返回对象的内容为空.">
    参数 期望缩放因子 <类型 = 小数 注释 = "指定希望匹配的设备缩放因子。" 注释 = "如: 1.0 (1x), 2.0 (2x HiDPI)。" 注释 = "作为查询的“提示”或“目标”。CEF 会尝试找到最接近这个值的已添加图像。">
    参数 期望压缩级别 <类型 = 整数 注释 = "指定所输出JPEG图像数据的期望压缩级别,有效值从0(最低)到100(最高).">
    参数 匹配图像宽度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的宽度(单位像素)." @需求类型 = 可写入变量>
    参数 匹配图像高度 <类型 = 整数类 注释 = "用作返回所实际匹配到图像的高度(单位像素)." @需求类型 = 可写入变量>
    {
        变量 字节集1 <类型 = CEF字节集类>
        如果 (是否为空 () == 假)
        {
            @ @<字节集1>.Set (m_objCef->GetAsJPEG ((float)@<期望缩放因子>, @<期望压缩级别>, @<匹配图像宽度.值>, @<匹配图像高度.值>));
        }
        返回 (字节集1)
    }
}

类 CEF页面框架 <公开 注释 = "提供CEF页面中的一个框架">
{

    # @ @m<DECLARE_CEF_OBJECT_CLASS> (CefFrame)

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本框架对象是否为空,为空则不能进行任何操作." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.IsEmpty ()
    }

    方法 是否为主框架 <公开 类型 = 逻辑型 注释 = "返回本框架是否为页面的主框架" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () == FALSE && m_objCef->IsMain ());
    }

    方法 是否为焦点框架 <公开 类型 = 逻辑型 注释 = "返回本框架是否为页面的焦点框架" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () == FALSE && m_objCef->IsFocused ());
    }

    方法 取框架名 <公开 类型 = 文本型 注释 = "返回本框架的名称" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? CVolString () : GetCefVolString (m_objCef->GetName ()));
    }

    方法 取框架标识符 <公开 类型 = 文本型 注释 = "返回本框架的标识符文本" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? CVolString () : GetCefVolString (m_objCef->GetIdentifier ()));
    }

    方法 取父框架 <公开 类型 = CEF页面框架 注释 = "返回本框架的父框架" 返回值注释 = "如果不存在父框架,所返回框架将为空(\"CEF页面框架.是否为空\"方法返回真)." @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ? @dt<CEF页面框架> () : @dt<CEF页面框架> (m_objCef->GetParent ()));
    }

    方法 取链接地址 <公开 类型 = 文本型 注释 = "返回本框架中当前浏览内容的链接地址" @禁止流程检查 = 真>
    {
        @ return (IsEmpty () ?  CVolString () : GetCefVolString (m_objCef->GetURL ()));
    }

    方法 跳转 <公开 注释 = "设置本框架中当前浏览的链接地址">
    参数 链接地址 <类型 = 文本型 注释 = "提供所欲跳转到的链接地址">
    {
        @ if (IsEmpty () == FALSE)
        @     m_objCef->LoadURL (@<链接地址>.GetText ());
    }

    方法 载入内容 <公开 注释 = "设置本框架中当前浏览的页面内容">
    参数 页面内容 <类型 = 文本型 注释 = "提供所欲浏览的HTML页面内容文本">
    {
        @ if (IsEmpty () == FALSE)
        @     CVWnd_CefWebBrowser::sLoadHtmlString (m_objCef, @<页面内容>.GetText ());
    }

    方法 取源代码 <公开 类型 = 文本型 注释 = "返回本框架中当前所浏览页面内容的HTML源代码" @嵌入式方法 = "">
    {
        @ CVWnd_CefWebBrowser::sGetSource (@sn<this>.m_objCef)
    }

    方法 取显示文本 <公开 类型 = 文本型 注释 = "返回本框架中当前所浏览页面内容的可显示文本" @嵌入式方法 = "">
    {
        @ CVWnd_CefWebBrowser::sGetText (@sn<this>.m_objCef)
    }

    方法 查看源代码 <公开 注释 = "启动文本外部编辑器查看本框架中当前所浏览页面内容的HTML源代码">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->ViewSource ();
    }

    方法 Post访问 <公开 注释 = "以Post方式访问所指定的URL" @嵌入式方法 = "req_obj_param_pointer = true">
    参数 链接地址 <类型 = 文本型 注释 = "提供所欲访问的链接地址">
    参数 访问头 <类型 = 文本型 注释 = "  每个项目为\"属性名=属性值\"格式,多个项目之间使用换行符\'\\n\'" 注释 = "分隔. 如: \"MyHead1=value\\nMyHead2=value\"."
            注释 = "  无则为空文本.">
    参数 所欲传递数据 <类型 = 字节集类 注释 = "提供所有欲传递过去的数据" @可扩展 = "">
    {
        @ CVWnd_CefWebBrowser::sPost (@sn<this>.m_objCef, @<链接地址>.GetText (), @<访问头>.GetText (), NUM_CHARS_OF_TEXT (@sn<pm_types>) - 2, @<所欲传递数据>)
    }

    方法 执行JS脚本 <公开 注释 = "执行所指定的JS脚本代码">
    参数 JS代码 <类型 = 文本型 注释 = "提供所欲执行的JavaScript脚本内容">
    参数 链接地址 <类型 = 文本型 注释 = "  提供脚本所对应的链接地址,当脚本执行遇到问题时,浏览器" 注释 = "将访问此地址为脚本开发者提供错误来源." @默认值 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供出错报告的基准行号" @默认值 = 1>
    {
        @ if (IsEmpty () == FALSE)
        @     m_objCef->ExecuteJavaScript (@<JS代码>.GetText (), @<链接地址>.GetText (), @<起始行号>);
    }

    方法 全部选择 <公开 注释 = "选择本框架中的所有内容">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->SelectAll ();
    }

    方法 复制 <公开 注释 = "将本框架中的被选择内容复制到剪贴板">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->Copy ();
    }

    方法 撤销 <公开 注释 = "在本框架中执行\"撤销\"命令">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->Undo ();
    }

    方法 重做 <公开 注释 = "在本框架中执行\"重做\"命令">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->Redo ();
    }

    方法 剪切 <公开 注释 = "在本框架中执行\"剪切\"命令">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->Cut ();
    }

    方法 粘贴 <公开 注释 = "在本框架中执行\"粘贴\"命令">
    参数 是否匹配文本样式 <类型 = 逻辑型 注释 = "如果为真,则粘贴剪贴板内容时匹配目标位置的文本样式,而不是保留原始格式." @默认值 = 假>
    {
        @ if (IsEmpty () == FALSE)
        @     if (@<是否匹配文本样式>)  m_objCef->PasteAndMatchStyle ();  else m_objCef->Paste ();
    }

    方法 删除 <公开 注释 = "在本框架中执行\"删除\"命令">
    {
        @ if (IsEmpty () == FALSE)  m_objCef->Delete ();
    }
}

