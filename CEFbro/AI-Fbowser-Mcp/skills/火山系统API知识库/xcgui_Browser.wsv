    方法 发送鼠标事件 <公开 注释 = "发送所指定的鼠标事件到浏览器" 折叠 @嵌入式方法 = "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"MB鼠标键类型\"类中各常量值." "">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    {
        @ wkeFireMouseEvent(@sn<this>.GetwebView(), @<鼠标键状态>, @<横向位置>, @<纵向位置>, @<辅助键状态>)
    }

    方法 发送鼠标单击事件 <公开 注释 = "触发一个鼠标点击事件,横坐标和纵坐标为相对窗口左上角的像素坐标." 折叠>
    参数 横坐标 <类型 = 整数 注释 = "横坐标">
    参数 纵坐标 <类型 = 整数 注释 = "纵坐标">
    {
        @ wkeFireMouseEvent(GetwebView(),WKE_MSG_LBUTTONDOWN,@<横坐标>, @<纵坐标>,WKE_LBUTTON);
        @ wkeFireMouseEvent(GetwebView(),WKE_MSG_LBUTTONUP,@<横坐标>, @<纵坐标>,WKE_LBUTTON);
    }

    方法 发送鼠标移动事件 <公开 注释 = "发送所指定的鼠标移动事件到浏览器" 折叠 "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"MB鼠标键类型\"类中各常量值." @默认值 = 0>
    {
        @ wkeFireMouseEvent(GetwebView(), WKE_MSG_MOUSEMOVE, @<横向位置>, @<纵向位置>, @<辅助键状态>);
        如果 (鼠标键状态 != 0)
        {
            @ wkeFireMouseEvent(GetwebView(), @<鼠标键状态>, @<横向位置>, @<纵向位置>, @<辅助键状态>);
        }
    }

    方法 发送按键事件 <公开 注释 = "发送所指定的按键事件到MB浏览器" 折叠>
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 为按键放开事件 <类型 = 逻辑型 注释 = "  为真表示发送按键放开事件(WM_SYSKEYUP/WM_KEYUP),否则将发送" 注释 = "按键按下事件(WM_SYSKEYDOWN/WM_KEYDOWN)." @默认值 = 假>
    参数 为系统按键事件 <类型 = 逻辑型 注释 = "  为真表示发送系统按键事件(WM_SYSKEYDOWN/WM_SYSKEYUP),否则将" 注释 = "发送非系统按键事件(WM_KEYDOWN/WM_KEYUP)" @默认值 = 假>
    {
        如果 (为按键放开事件)
        {
            @ wkeFireKeyUpEvent( GetwebView(), @<键代码>,@<辅助键状态>,@<为系统按键事件>);
        }
        否则
        {
            @ wkeFireKeyDownEvent( GetwebView(),@<键代码>, @<辅助键状态>,@<为系统按键事件>);
        }
    }

    方法 发送字符事件 <公开 注释 = "向MB浏览器发送一个字符消息" 折叠 @嵌入式方法 = "">
