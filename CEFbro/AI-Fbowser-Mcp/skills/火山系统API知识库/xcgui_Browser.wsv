    参数 文件目录 <类型 = 文本型 注释 = "文件目录路径,不包括文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 置Cookie文件全路径 <公开 注释 = "设置Cookie文件的全路径包括文件名,默认是程序运行的当前目录,默认文件名为cookie.dat。" 折叠 @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "全路径,包括cookie文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarFullPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 置LocalStorage路径 <公开 注释 = "设置LocalStorage本地存储文件的路径" 折叠 @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\LocalStorage,必须且只能是目录,默认是当前目录.">
    {
        @ wkeSetLocalStorageFullPath(@sn<this>.GetwebView(),@<文件目录>)
    }

    方法 添加插件目录 <公开 注释 = "设置插件目录,默认情况下为plugins目录" 折叠 @嵌入式方法 = "">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\plugins,必须且只能是目录,默认是当前目录">
    {
        @ wkeAddPluginDirectory(@sn<this>.GetwebView(), @<文件目录>)
    }

    方法 媒体音量 <公开 属性写 注释 = "设置浏览器的媒体音量">
    参数 音量 <类型 = 单精度小数 注释 = "媒体音量值默认为1">
    {
        @ wkeSetMediaVolume(GetwebView(),@<音量>);
    }

    方法 媒体音量 <公开 属性读 类型 = 单精度小数 注释 = "取浏览器的媒体音量" 返回值注释 = "媒体音量值" @嵌入式方法 = "">
    {
        @ wkeGetMediaVolume(@sn<this>.GetwebView())
    }

    方法 启用Cookie <公开 属性写 注释 = "设置Cookie是否可用" 折叠>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用" @默认值 = 真>
    {
        @ wkeSetCookieEnabled(GetwebView(),@<是否启用>);
    }

    方法 启用Cookie <公开 属性读 类型 = 逻辑型 注释 = "判断是否启用Cookie" 返回值注释 = "真为启用" 折叠 @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsCookieEnabled(@sn<this>.GetwebView())
    }

    方法 启用高分辨率支持 <公开 静态 注释 = "本质是通过设置ZOOM并且关闭系统默认缩放来实现的,所以再使用\"缩放系数\"会发现值可能不为1。" 折叠 @嵌入式方法 = "">
    {
        @ wkeEnableHighDPISupport()
    }

    方法 启用鼠标 <公开 注释 = "开启或关闭鼠标消息,可以在开启触屏后,关闭鼠标消息" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
