    }

    方法 发送消息 <公开 类型 = 长整数 注释 = "向浏览器窗口发送一个window消息" 折叠 @禁止流程检查 = 真>
    参数 message <类型 = 整数 注释 = "消息值" "">
    参数 wParam <类型 = 整数 注释 = "消息附加参数wParam">
    参数 IParam <类型 = 整数 注释 = "消息附加参数IParam">
    {
        @ HWND hWnd = wkeGetHostHWND(GetwebView());
        @ LRESULT result;
        @ wkeFireWindowsMessage(GetwebView(), hWnd, @<message>, @<wParam>, @<IParam>, &result); 
        @ return result;
    }

    方法 网页_点击 <公开 注释 = "执行JS查找并执行元素点击事件" 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    {
        执行JS脚本 ("document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].click()")
    }

    方法 网页_取元素文本 <公开 类型 = 文本型 注释 = "执行JS查找并返回元素的textContent" 返回值注释 = "返回元素的textContent文本" 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" @默认值 = 0>
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
