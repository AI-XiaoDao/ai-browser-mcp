        @ wkeSetMouseEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用触摸 <公开 注释 = "开启或关闭触屏" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetTouchEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用系统触摸 <公开 注释 = "开启或关闭系统触屏" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetSystemTouchEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用拖入文件 <公开 注释 = "可启用或关闭拖拽文件加载网页" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetDragEnable(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用拖拽元素 <公开 注释 = "可启用或关闭元素拖拽或拖拽到其他进程" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetDragDropEnable(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用内存缓存 <公开 注释 = "可启用或关闭内存缓存" 折叠 @嵌入式方法 = "">
