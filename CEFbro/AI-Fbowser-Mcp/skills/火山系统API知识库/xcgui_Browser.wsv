    {
        @ wkeSetMemoryCacheEnable(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 保存内存缓存 <公开 注释 = "保存当前浏览器内存缓存" 折叠 @嵌入式方法 = "">
    {
        @ wkeSaveMemoryCache(@sn<this>.GetwebView())
    }

    方法 启用Npapi插件 <公开 注释 = "可启用或关闭Npapi插件" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetNpapiPluginsEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用无头模式 <公开 注释 = "开启或关闭无头模式,开启后页面不会被渲染上屏,直接内存运行,大幅提升性能." 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetHeadlessEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用默认菜单 <公开 注释 = "设置是否允许右键弹出MB浏览器默认菜单,默认状态下为开启." 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetContextMenuEnabled(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 置默认菜单项显示 <公开 注释 = "设置MB浏览器某菜单项是否显示" 折叠 @嵌入式方法 = "">
    参数 菜单项 <类型 = 炫彩MB默认菜单项 注释 = "MB默认菜单项常量">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示,假为隐藏">
    {
        @ wkeSetContextMenuItemShow(@sn<this>.GetwebView(),(wkeMenuItemId)@<菜单项>,@<是否显示>)
    }

    方法 启用导航到新窗口 <公开 注释 = "当有新页面需要打开时,是否在新窗口打开,默认是当前窗口,如开启,则会触发\"即将创建新窗口\"事件." 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用,假为关闭." @默认值 = 真>
    {
        @ wkeSetNavigationToNewWindowEnable(@sn<this>.GetwebView(),@<是否启用>)
    }

    方法 启用跨域检查 <公开 注释 = "设置是否开启csp跨域检查,默认状态下为开启,如需进行跨域操作,如跨域ajax,跨域设置iframe等,则需要先关闭此开关." 折叠 @嵌入式方法 = "">
    参数 是否检查 <类型 = 逻辑型>
    {
        @ wkeSetCspCheckEnable(@sn<this>.GetwebView(),@<是否检查>)
    }

    方法 置设备参数 <公开 注释 = "设置webView模拟硬件设备环境" @嵌入式方法 = "">
    参数 设备参数名 <类型 = 文本型 注释 = "为\"navigator.maxTouchPoints\"时，需设置\"整数参数\"，表示touch的点数。"
            注释 = "为\"navigator.platform\"时，需设置\"文本参数\"，表示js里获取的navigator.platform字符串。"
            注释 = "为\"navigator.hardwareConcurrency\"时，需设置\"整数参数\"，表示js里获取的navigator.hardwareConcurrency整数值。"
            注释 = "为\"screen.width\"时，需设置\"整数参数\"，表示js里获取的screen.width整数值。"
            注释 = "为\"screen.height\"时，需设置\"整数参数\"，表示js里获取的screen.height整数值。"
            注释 = "为\"screen.availWidth\"时，需设置\"整数参数\"，表示js里获取的screen.availWidth整数值。"
            注释 = "为\"screen.availHeight\"时，需设置\"整数参数\"，表示js里获取的screen.availHeight整数值。"
            注释 = "为\"screen.pixelDepth\"时，需设置\"整数参数\"，表示js里获取的screen.pixelDepth整数值。" 折叠2>
    参数 文本参数 <类型 = 文本型 @默认值 = "">
    参数 整数参数 <类型 = 整数 @默认值 = 0>
    参数 浮点参数 <类型 = 单精度小数 @默认值 = 0>
    {
        @ wkeSetDeviceParameter (@sn<this>.GetwebView(), CU8String  (@<设备参数名>).GetText (), CU8String (@<文本参数>).GetText (), @<整数参数>, @<浮点参数>)
    }

    方法 置代理 <公开 注释 = "置当前浏览器代理设置" 折叠>
    参数 代理类型 <类型 = 炫彩MB代理类型 注释 = "提供MB代理类型" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = 炫彩MB代理类型.HTTP>
    参数 服务器 <类型 = 文本型 注释 = "代理服务器地址" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 端口 <类型 = 短整数 注释 = "代理服务器端口" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 用户名 <类型 = 文本型 注释 = "代理服务器用户" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "代理服务器密码" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    {
        @ wkeProxy  Proxy;
        @ Proxy.type=(wkeProxyType)@<代理类型>;
        @ strncpy_z(Proxy.hostname, CU8String (@<服务器>).GetText(), NUM_ELEMENTS_OF (Proxy.hostname) - 1);
        @ strncpy_z(Proxy.username, CU8String (@<用户名>).GetText(), NUM_ELEMENTS_OF (Proxy.username) - 1);
        @ strncpy_z(Proxy.password, CU8String (@<密码>).GetText(), NUM_ELEMENTS_OF (Proxy.password) - 1);
        @ Proxy.port=@<端口>;
        @ wkeSetViewProxy (GetwebView(), &Proxy);
    }

    方法 置全局代理 <公开 静态 注释 = "设置MB浏览器代理全局生效" 折叠>
    参数 代理类型 <类型 = 炫彩MB代理类型 注释 = "提供MB代理类型" @默认值 = 炫彩MB代理类型.HTTP>
    参数 服务器 <类型 = 文本型 注释 = "代理服务器地址">
    参数 端口 <类型 = 短整数 注释 = "代理服务器端口">
    参数 用户名 <类型 = 文本型 注释 = "代理服务器用户" @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "代理服务器密码" @默认值 = "">
    {
        @ wkeProxy  Proxy;
        @ Proxy.type=(wkeProxyType)@<代理类型>;
        @ strncpy_z(Proxy.hostname, CU8String (@<服务器>).GetText(), NUM_ELEMENTS_OF (Proxy.hostname) - 1);
        @ strncpy_z(Proxy.username, CU8String (@<用户名>).GetText(), NUM_ELEMENTS_OF (Proxy.username) - 1);
        @ strncpy_z(Proxy.password, CU8String (@<密码>).GetText(), NUM_ELEMENTS_OF (Proxy.password) - 1);
        @ Proxy.port=@<端口>;
        @ wkeSetProxy (&Proxy);
    }

    方法 置调试配置 <公开 注释 = "设置一些实验性选项,配置项目前支持:"
            注释 = "showDevTools:开启开发者工具,此时参数值要填写开发者工具的资源路径,如file:///c:/miniblink-release/front_end/inspector.html 必须是全路径,并且不能有中文."
            注释 = "wakeMinInterval:设置帧率,默认值是10值越大帧率越低;" 注释 = "drawMinInterval:设置帧率,默认值是3,值越大帧率越低;"
            注释 = "antiAlias:设置抗锯齿渲染,参数值必须设置为\"1\";" 注释 = "minimumFontSize:最小字体;" 注释 = "minimumLogicalFontSize:最小逻辑字体;"
            注释 = "defaultFontSize:默认字号;" 注释 = "defaultFixedFontSize:默认Fixed字号;" 注释 = "imageEnable:是否打开无图模式,参数值为\"0\"表示开启无图模式;"
            注释 = "jsEnable:是否禁用js,参数值为\"0\"表示禁用;" 注释 = "enableNodejs:是否开启nodejs 支持,参数值为\"1\"表示开启.(目前仅支持32位)" 折叠 折叠2 @嵌入式方法 = "">
    参数 配置项 <类型 = 文本型 注释 = "配置项名">
    参数 参数值 <类型 = 文本型 注释 = "配置项参数值">
    {
        @ wkeSetDebugConfig(@sn<this>.GetwebView(),CU8String (@<配置项>).GetText(),CU8String (@<参数值>).GetText())
    }

    方法 执行JS脚本 <公开 类型 = 炫彩MBjs值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()">
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = 炫彩MBjs值>
        @ @<jv>=(INT_P)wkeRunJSW(GetwebView(), @<JS文本>.GetText ());
        @ @<es>=(INT_P)wkeGlobalExec(GetwebView());
        返回 (js.绑定 (es, jv))
    }

    方法 执行JS脚本UTF8 <公开 类型 = 炫彩MBjs值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()" 折叠>
    参数 JS文本UTF8 <类型 = 字节集类 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 jsValue <类型 = 炫彩MBjs值>
        @ @<jv>=(INT_P)wkeRunJS(GetwebView(), (const utf8*)@<JS文本UTF8>.GetPtr());
        @ @<es>=(INT_P)wkeGlobalExec(GetwebView());
        返回 (jsValue.绑定 (es, jv))
    }

    方法 执行JS脚本自框架 <公开 类型 = 炫彩MBjs值
            注释 = "在指定框架中执行一段js代码,返回js执行返回值类实例 使用方法 如: 变量.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()"
            返回值注释 = "返回js值对象,用于js执行结果取值操作." 折叠>
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID" 折叠>
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真,则MB会将这段js代码放到一个function(){ script }中执行,以避免变量名和页面中的js变量重名导致的错误.">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = 炫彩MBjs值>
        @ @<jv>=(INT_P)wkeRunJsByFrame(GetwebView(),(wkeWebFrameHandle)@<框架ID>,CU8String (@<JS文本>).GetText(),@<是否闭包>);
        @ @<es>=(INT_P)wkeGetGlobalExecByFrame(GetwebView(),(wkeWebFrameHandle)@<框架ID>);
        返回 (js.绑定 (es, jv))
    }

    方法 取主框架 <公开 类型 = 变整数 注释 = "取页面主框架ID" 返回值注释 = "返回页面主框架ID" 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)wkeWebFrameGetMainFrame (@sn<this>.GetwebView())
    }

    方法 是否为主框架 <公开 类型 = 逻辑型 注释 = "判断页面中的某个框架是否为远程框架" 返回值注释 = "如果为主框架则返回真" 折叠 @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    {
        @ wkeIsMainFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 是否为远程框架 <公开 类型 = 逻辑型 注释 = "判断页面中的某个框架是否为远程框架" 返回值注释 = "如果为远程框架则返回真" 折叠 @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    {
        @ wkeIsWebRemoteFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 取JS执行状态 <公开 类型 = 变整数 注释 = "获取页面主框架的js执行状态,js执行状态可以理解为一个句柄,js相关接口会频繁使用该句柄,使用完立刻就失效,再次使用需重新获取.。" 返回值注释 = "主框架js执行状态" 折叠
            @嵌入式方法 = "">
    {
        @ (INT_P)wkeGlobalExec(@sn<this>.GetwebView())
    }

    方法 取JS执行状态_框架 <公开 类型 = 变整数 注释 = "获取页面的js执行状态,js执行状态可以理解为一个句柄,js相关接口会频繁使用该句柄,使用完立刻就失效,再次使用需重新获取." 返回值注释 = "js执行状态" 折叠
            @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供页面框架ID">
    {
        @ (INT_P)wkeGetGlobalExecByFrame(@sn<this>.GetwebView(),(wkeWebFrameHandle)@<框架ID>)
    }

    方法 JS绑定函数 <公开 静态 注释 = "绑定全局JS函数,须在窗口创建前调用." 折叠 "">
    参数 函数名称 <类型 = 文本型 注释 = "提供该js方法的函数名称,全局生效,请注意方法名的唯一性.">
    参数 参数个数 <类型 = 整数 注释 = "提供该js方法的参数个数">
    参数 回调方法指针 <类型 = 变整数 注释 = "指定一个静态方法指针值" 注释 = "属性:@视窗.前缀文本 值为:@CDECL;" 注释 = "返回值类型:整数 即调用jsValue类成员方法生成的js值;"
            注释 = "参数1 类型:js执行状态;" 注释 = "如不指定此方法默认会在本类各实例对象的\"JS绑定方法被执行\"事件中触发" @默认值 = 0>
    {
        @ wkeJsBindFunction(CU8String (@<函数名称>).GetText (), (@<回调方法指针> == 0 ? (wkeJsNativeFunction)handlewkeJsNativeFunction : (wkeJsNativeFunction)@<回调方法指针>), (void *)@<函数名称>.GetText (), (unsigned int)@<参数个数>);
    }

    方法 插入CSS到框架 <公开 注释 = "插入一段CSS到页面框架中" 折叠 @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供页面框架ID">
    参数 CSS文本 <类型 = 文本型 注释 = "提供CSS文本">
    {
        @ wkeInsertCSSByFrame (@sn<this>.GetwebView(), (wkeWebFrameHandle)@<框架ID>,CU8String (@<CSS文本>).GetText ())
    }

    方法 显示窗口 <公开 注释 = "显示或隐藏浏览器窗口" 折叠 @嵌入式方法 = "">
    参数 是否显示 <类型 = 逻辑型 注释 = "是否显示浏览器窗口">
    {
        @ wkeShowWindow(@sn<this>.GetwebView() ,  @<是否显示>)
    }

    方法 获取焦点 <公开 注释 = "如果浏览器绑定了窗口,窗口也会获得焦点." 折叠 @嵌入式方法 = "">
    {
        @ wkeSetFocus(@sn<this>.GetwebView())
    }

    方法 失去焦点 <公开 注释 = "让浏览器失去焦点" 折叠 @嵌入式方法 = "">
    {
        @ wkeKillFocus(@sn<this>.GetwebView())
    }

    方法 启动开发工具 <公开 注释 = "打开浏览器开发者工具Devtools,须配合对应的页面文档使用" 折叠 @视窗.附属文件 = "data\\front_end > front_end">
    参数 开发工具文件目录 <类型 = 文本型 注释 = "开发者工具目录,例如:\"file:///\"＋取运行目录 ()＋\"\\front_end\\inspector.html\"" @默认值 = "">
    {
        如果真 (开发工具文件目录 == "")
        {
            开发工具文件目录 = "file:///" + 取运行目录 () + "/front_end/inspector.html"
        }
        @ wkeShowDevtools(GetwebView() , @<开发工具文件目录>,0,0);
    }

