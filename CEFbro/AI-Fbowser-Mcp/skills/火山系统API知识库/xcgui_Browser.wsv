    方法 创建 <公开 注释 = "MiniBlink 创建窗口">
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    参数 cx <类型 = 整数>
    参数 cy <类型 = 整数>
    参数 hParent <类型 = 变整数>
    参数 DllPath <类型 = 文本型 注释 = "MiniBlink动态库名称默认为\"node.dll\"用户可通过此参数修改调用动态库dll名称,请将改名后的dll库放置在编译目录." @默认值 = "node.dll">
    {
        @  wkeSetWkeDllPath(@<DllPath>);
        @  wkeInitialize();
        @  set((INT_P) XEle_Create(@<x>,@<y>,@<cx>,@<cy>,(HXCGUI)@<hParent>));
        @  SetwebView ( wkeCreateWebView());
        @ wkeOnPaintUpdated(GetwebView(), OnWkePaintUpdatedCallback,this);
        @  wkeResize(GetwebView(), @<cx>, @<cy>);
        @  XEle_RegEventCPP1((HELE)get(),XE_SETCURSOR,&@dt<炫彩MB浏览器>::OnSetCursor);
        // @  XEle_RegEventCPP1((HELE)get(),XE_XC_TIMER,&@dt<炫彩MB浏览器>::OnEleXCTimer);
        // @  XEle_SetXCTimer((HELE)get(),5195,100);
        @  XEle_RegEventCPP1((HELE)get(),XE_SIZE,&@dt<炫彩MB浏览器>::OnEleSize);
        @  XEle_RegEventCPP1((HELE)get(),XE_PAINT,&@dt<炫彩MB浏览器>::OnDraw);
        @  XEle_EnableEvent_XE_MOUSEWHEEL((HELE)get(),TRUE);   
        @  XEle_RegEventCPP1((HELE)get(),XE_MOUSEWHEEL,&@dt<炫彩MB浏览器>::OnMouseWheel);
        @  XEle_RegEventCPP1((HELE)get(),XE_LBUTTONDOWN,&@dt<炫彩MB浏览器>::OnLButtonDown);
        @  XEle_RegEventCPP1((HELE)get(),XE_LBUTTONUP,&@dt<炫彩MB浏览器>::OnLButtonUp);
        @  XEle_RegEventCPP1((HELE)get(),XE_RBUTTONDOWN,&@dt<炫彩MB浏览器>::OnRButtonDown);
        @  XEle_RegEventCPP1((HELE)get(),XE_RBUTTONUP,&@dt<炫彩MB浏览器>::OnRButtonUp);
        @  XEle_RegEventCPP1((HELE)get(),XE_MOUSEMOVE,&@dt<炫彩MB浏览器>::OnMouseMove);
        @  XEle_RegEventCPP1((HELE)get(),XE_SETFOCUS,&@dt<炫彩MB浏览器>::OnSetFocus);
        @  XEle_RegEventCPP1((HELE)get(),XE_KILLFOCUS,&@dt<炫彩MB浏览器>::OnKillFocus);
        @  XEle_RegEventCPP1((HELE)get(),XE_KEYDOWN,&@dt<炫彩MB浏览器>::OnKeyDown);
        @  XEle_RegEventCPP1((HELE)get(),XE_KEYUP,&@dt<炫彩MB浏览器>::OnKeyUp);
        @  XEle_RegEventCPP1((HELE)get(),XE_CHAR,&@dt<炫彩MB浏览器>::OnChar);
        @  XEle_RegEventCPP1((HELE)get(),XE_DESTROY,&@dt<炫彩MB浏览器>::OnDestroy);
        // @ _XC_SetType((HELE)get(),XC_WEB); //设置类型
        // @  _XC_AddType((HELE)get(),XC_WEB); //增加类型
        // @  @dt<炫彩MB浏览器>* pWeb = new @dt<炫彩MB浏览器>;
        // @  _XC_BindData((HELE)get(), (int)pWeb); //绑定关联

    }

