    方法 网页_填表 <公开 类型 = 文本型 注释 = "执行JS查找元素并赋值" 返回值注释 = "成功返回执行结果文本,失败返回js错误文本." 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 填入内容 <类型 = 文本型 注释 = "填表内容" @默认值 = "">
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    {
        返回 (执行JS脚本 ("return document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].value='" + 填入内容 + "'").取文本值 ())
    }

    方法 网页_点击_框架 <公开 注释 = "执行JS查找并执行元素点击事件" 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等" 编辑时信息 = "2A5A3, 0, 0, 0">
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" 编辑时信息 = "2A5A3, 0, 0, 0" @默认值 = 0>
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" 编辑时信息 = "2A5A3, 0, 0, 0" @默认值 = 0>
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真.则MB会将这段js代码放到一个function(){ script }中执行.以避免变量名和页面中的js变量重名导致的错误." 编辑时信息 = "2A5A3, 0, 0, 0"
            @默认值 = 真>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        执行JS脚本自框架 (框架ID, "document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].click()", 是否闭包)
    }

    方法 网页_触发输入事件 <公开 注释 = "执行JS查找并执行元素输入事件,在填表时有些页面监听文本框的输入行为,此时需要先触发该元素的输入事件,再执行填表操作." 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  input 等">
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" @默认值 = 0>
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真.则MB会将这段js代码放到一个function(){ script }中执行.以避免变量名和页面中的js变量重名导致的错误." @默认值 = 真>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        执行JS脚本自框架 (框架ID, "document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].dispatchEvent(new Event('input'))", 是否闭包)
    }

    方法 网页_复选框选中 <公开 注释 = "执行JS查找元素,设置复选框的选中状态." 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  input 等">
    参数 是否选中 <类型 = 逻辑型 注释 = "真为选中,假为取消选中状态." @默认值 = 真>
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" @默认值 = 0>
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真.则MB会将这段js代码放到一个function(){ script }中执行.以避免变量名和页面中的js变量重名导致的错误." @默认值 = 真>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        执行JS脚本自框架 (框架ID, "document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].checked=" + 选择 (是否选中, "true", "false"), 是否闭包)
    }

    方法 网页_填表_框架 <公开 类型 = 文本型 注释 = "执行JS查找元素并赋值" 返回值注释 = "成功返回执行结果文本 ,失败返回js错误文本." 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 填入内容 <类型 = 文本型 注释 = "填表内容" @默认值 = "">
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" @默认值 = 0>
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真,则MB会将这段js代码放到一个function(){ script }中执行,以避免变量名和页面中的js变量重名导致的错误." @默认值 = 假>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        返回 (执行JS脚本自框架 (框架ID, "return document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].value='" + 填入内容 + "'", 是否闭包).取文本值 ())
    }

    方法 网页_查找元素 <公开 类型 = 整数 注释 = "执行JS查找元素,成功返回查找到元素数量." 返回值注释 = "找到的元素数量" 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 框架ID <类型 = 变整数 注释 = "默认为主框架" @默认值 = 0>
    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        返回 (执行JS脚本自框架 (框架ID, "return document.querySelectorAll('" + css选择器 + "').length", 真).取整数值 ())
    }

    #
}

类 炫彩MB网络工作 <公开 注释 = "MB网络工作类,用于获得或处理MB网络请求相关操作" 折叠 "">
{
    变量 _job <类型 = 变整数>

    方法 绑定 <公开 类型 = 炫彩MB网络工作 注释 = "初始化绑网络工作指针封装层内部使用" 返回值注释 = "返回MB网络工作对象" "">
    参数 网络工作指针 <类型 = 变整数>
    {
        _job = 网络工作指针
        返回 (本对象)
    }

    方法 置MIMEType <公开 注释 = "设置网络响应的的MIMEType" 折叠>
    参数 MIME类型 <类型 = 文本型 注释 = "MIME类型 如:\"image/jpeg\"">
    {
        变量 mime <类型 = 字节集类>
        mime = 文本到字节集 (MIME类型)
        @ wkeNetSetMIMEType((wkeNetJob)@<_job>,(const utf8 *)@<mime>.GetPtr());
    }

    方法 取MIMEType <公开 类型 = 文本型 注释 = "获取网络响应的的MIMEType" @禁止流程检查 = 真>
    参数 MIME类型 <类型 = 文本型 注释 = "MIME类型 如:\"image/jpeg\"" @默认值 = "">
    {
        变量 mime <类型 = 字节集类>
        mime = 文本到字节集 (MIME类型)
        @ wkeString str =wkeCreateString((const utf8 *)@<mime>.GetPtr(),@<mime>.GetSize ());
        @ return wkeNetGetMIMEType((wkeNetJob)@<_job>,str);
    }

    方法 取HTTP头某字段 <公开 类型 = 文本型 注释 = "根据参数名获取http请求头" 返回值注释 = "http头字段的值" @禁止流程检查 = 真>
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    {
        @ return wkeNetGetHTTPHeaderField((wkeNetJob)@<_job>,CU8String (@<http头字段名>).GetText());
    }

    方法 置HTTP头某字段 <公开 注释 = "设置http请求（或者file:///协议）的http请求头" "">
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    参数 http头字段值 <类型 = 文本型 注释 = "http头字段值">
    {
        @ wkeNetSetHTTPHeaderField((wkeNetJob)@<_job>, @<http头字段名>, @<http头字段值>, 0);
    }

    方法 取HTTP响应头某字段 <公开 类型 = 文本型 注释 = "获取http响应头" 返回值注释 = "http头字段的值" @禁止流程检查 = 真>
    参数 http头字段名 <类型 = 文本型 注释 = "http头字段名如:\"method\",\"user-agent\"等等.">
    {
        @ return wkeNetGetHTTPHeaderFieldFromResponse((wkeNetJob)@<_job>,CU8String (@<http头字段名>).GetText());
    }

    方法 置数据 <公开 注释 = "  调用此方法后,网络层收到数据会存储在一个内存缓冲区内,接收数据完成后触发\"结束加载Url\"事件.并允许次方法修改网络数据,"
            注释 = "此接口一般在\"开始加载Url\"事件中使用,在网络访问执行前,设置指定的数据到网络层,数据内容可以为js代码,图片,字符串,数据块等任意类型.">
    参数 数据 <类型 = 字节集类 注释 = "欲修改的网络数据">
    {
        @ wkeNetSetData((wkeNetJob)@<_job>,(void*)@<数据>.GetPtr(),(int)@<数据>.GetSize ());
    }

    方法 Hook请求 <公开 注释 = "此方法一般在\"开始加载Url\"事件中使用,调用此方法会在接收数据完成后响应\"结束加载Url\"事件中获得拦截到的数据.">
    {
        @ wkeNetHookRequest((wkeNetJob)@<_job>);
    }

    方法 取请求方法 <公开 类型 = 整数 注释 = "取当前http请求类型" 返回值注释 = "请求类型 0:无效; 1:Get; 2:Post; 3:Put." @禁止流程检查 = 真>
    {
        @ return (int)wkeNetGetRequestMethod((wkeNetJob)@<_job>);
    }

    方法 取Url <公开 类型 = 文本型 注释 = "获取当前请求的链接地址" 返回值注释 = "前请求的链接地址" @禁止流程检查 = 真>
    {
        @ return wkeNetGetUrlByJob((wkeNetJob)@<_job>);
    }

    方法 取消请求 <公开 注释 = "取消本次网络请求,此方法需要在\"开始载入Ulr\"事件中使用.">
    {
        @ wkeNetCancelRequest((wkeNetJob)@<_job>);
    }

    方法 修改请求URL <公开 注释 = "修改当前请求的url,使请求指向另外一个url,此方法需要在\"开始载入Ulr\"事件中使用.">
    参数 链接地址 <类型 = 文本型 注释 = "欲修改的url">
    {
        @ wkeNetChangeRequestUrl((wkeNetJob)@<_job>,CU8String (@<链接地址>).GetText ());
    }

    方法 取HTTP请求头 <公开 注释 = "用于获得当前载入链接的请求头信息">
    参数 请求头数据 <类型 = 文本数组类 注释 = "提供文本数组变量,用于存放获得的请求头信息,每个成员代表一个字段.">
    {
        @ const wkeSlist* psHeadList = wkeNetGetRawHttpHead((wkeNetJob)@<_job>);
        @ while (psHeadList != nullptr)
        @ {
        @     @<请求头数据>.data ().Add2 (psHeadList->data);
        @     psHeadList = psHeadList->next;
        @ }
    }

    方法 取HTTP响应头 <公开 注释 = "用于获得当前载入链接的响应头信息">
    参数 响应头数据 <类型 = 文本数组类 注释 = "提供文本数组变量,用于存放获得的响应头信息,每个成员代表一个字段.">
    {
        @ const wkeSlist* psHeadList = wkeNetGetRawResponseHead((wkeNetJob)@<_job>);
        @ while (psHeadList != nullptr)
        @ {
        @     @<响应头数据>.data ().Add2 (psHeadList->data);
        @     psHeadList = psHeadList->next;
        @ }
    }

    方法 取POST数据 <公开 类型 = 整数 注释 = "取当前POST请求数据,当前请求类型为POST时有效." 返回值注释 = "成功返回提交数据(文件)个数,否则返回0." @禁止流程检查 = 真>
    参数 POST数据 <类型 = 字节集数组类 注释 = "提供一个字节集数组,用来接收POST数据集.">
    {
        @ wkePostBodyElements* pPostDatas = wkeNetGetPostBody((wkeNetJob)@<_job>);
        @ if(pPostDatas == nullptr) return 0;
        @ wkePostBodyElement* pElement;
        @ for (int i = 0; i< pPostDatas->elementSize; i++)
        @ {
        @     if (pPostDatas->element != nullptr)
        @     {
        @         pElement =(pPostDatas->element)[i];
        @         if (pElement->type == wkeHttBodyElementTypeData)
        @         {
        @             if(pElement->data != NULL ) 
        @                @<POST数据>.Add (CVolMem((BYTE*)pElement->data->data, pElement->data->length) , NULL);
        @         } else {
        @            @<POST数据>.Add (CVolMem(wkeGetString( pElement->filePath)) , NULL); //@<POST数据>.Add (CVolMem((BYTE*)pElement->fileStart, pElement->fileLength) , NULL); //
        @         }
        @     } 
        @ }
        @ return (int)pPostDatas->elementSize; 
    }
}

类 炫彩MB代理类型 <公开 注释 = "MB代理类型常量" 折叠 折叠2 @文档 = "category = \"炫彩WEB组件.辅助类\"" @常量类 = 整数>
