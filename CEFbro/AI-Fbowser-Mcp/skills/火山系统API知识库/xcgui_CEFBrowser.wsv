    方法 对象事件_获取 <公开 定义事件 类型 = 整数 折叠>
    参数 函数名称 <类型 = 文本型>
    参数 调用对象 <类型 = 炫彩CEFV8值>
    参数 置返回值 <类型 = 炫彩CEFV8值>
    参数 异常信息 <类型 = 文本型>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "默认:假">

    方法 对象事件_设置 <公开 定义事件 类型 = 整数 折叠>
    参数 函数名称 <类型 = 文本型>
    参数 调用对象 <类型 = 炫彩CEFV8值>
    参数 置V8值 <类型 = 炫彩CEFV8值>
    参数 异常信息 <类型 = 文本型>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "默认:假">

    方法 取指针 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.m_class
    }

    方法 是否为空 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.IsEmpty()
    }

    方法 是否为函数 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8_IsFunction(@sn<this>.m_class)
    }

    方法 是否为文本 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8_IsString(@sn<this>.m_class)
    }

    方法 是否为整数 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8_IsInt(@sn<this>.m_class)
    }

    方法 是否为对象 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8_IsObject(@sn<this>.m_class)
    }

    方法 是否为空值 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8_IsNull(@sn<this>.m_class)
    }

    方法 置值 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 关键值 <类型 = 文本型>
    参数 V8值 <类型 = 炫彩CEFV8值>
    参数 性能属性 <类型 = 整数 注释 = "CEFV8性能属性.**" @默认值 = 0>
    {
        @ FTV8_SetValue(@sn<this>.m_class,@<关键值>.GetText(),@<V8值>.m_class,@<性能属性>)
    }

    方法 置值Ex <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 关键值 <类型 = 文本型>
    参数 访问控制 <类型 = 整数 注释 = "CEFV8访问控制.**">
    参数 性能属性 <类型 = 整数 注释 = "CEFV8性能属性.**" @默认值 = 0>
    {
        @ FTV8_SetValueEx(@sn<this>.m_class,@<关键值>.GetText(),@<访问控制>,@<性能属性>)
    }

    方法 置值自索引 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    参数 V8值 <类型 = 炫彩CEFV8值>
    {
        @ FTV8_SetValueindex(@sn<this>.m_class,@<索引>,@<V8值>.m_class)
    }

    方法 执行函数_整数 <公开 类型 = 炫彩CEFV8值 注释 = "注意:不支持调试模式" 折叠 @禁止流程检查 = 真>
    参数 整数数值 <类型 = 整数数组类>
    {
        @ int i = (int)@<整数数值>.data ().GetCount ();
        // @ std::vector<int> args  ;
        // @ for (INT npIndex = 0; npIndex < i; npIndex++) {
        // @ args.push_back(@<整数数值>.data ().GetAt (npIndex));
        // @ }
        @ return @dt<炫彩CEFV8值>(FTV8_ExecuteFunctionInt(m_class,@<整数数值>.data().GetData (),i));
    }

    方法 执行函数_文本 <公开 类型 = 炫彩CEFV8值 注释 = "注意:不支持调试模式" 折叠 @禁止流程检查 = 真>
    参数 文本数值 <类型 = 文本数组类>
    {
        @ int i = (int)@<文本数值>.data ().GetCount ();
        // @ std::vector<LPCWSTR> args  ;
        // @ CWString str;
        // @ for (INT npIndex = 0; npIndex < i; npIndex++) {
        // @ str = @<文本数值>.data ().GetAt (npIndex);
        // @ args.push_back(str.GetText());
        // // @ ::MessageBox(NULL, str, TEXT("pretval"), MB_OK);
        // @ }
        // @ args.push_back(L"火山");
        // @ args.push_back(L"456sdasd易团雪");
        @ return @dt<炫彩CEFV8值>(FTV8_ExecuteFunctionString(m_class,@<文本数值>.data().GetData (),i));
    }

    方法 取文本值 <公开 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTV8_GetStringValue(@sn<this>.m_class))
    }

    方法 取整数值 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ FTV8_GetIntValue(@sn<this>.m_class)
    }

    方法 创建文本值 <公开 静态 类型 = 炫彩CEFV8值 折叠 @嵌入式方法 = "">
    参数 函数名称 <类型 = 文本型>
    {
        @ @dt<炫彩CEFV8值>(FTV8_CreateString(@<函数名称>.GetText()))
    }

    方法 创建整数值 <公开 静态 类型 = 炫彩CEFV8值 折叠 @嵌入式方法 = "">
    参数 列表 <类型 = 整数>
    {
        @ @dt<炫彩CEFV8值>(FTV8_CreateInt(@<列表>))
    }

    方法 创建函数 <公开 类型 = 炫彩CEFV8值 注释 = "函数被执行-事件将被触发,注意:不支持调试模式" 折叠 @禁止流程检查 = 真>
    参数 函数名称 <类型 = 文本型>
    {
        @ return @dt<炫彩CEFV8值>(FTV8_CreateFunction(@<函数名称>.GetText(),OnFunction,this));
    }

    方法 创建对象 <公开 类型 = 炫彩CEFV8值 注释 = "对象事件_获取/设置-事件将被触发" 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<炫彩CEFV8值>(FTV8_CreateObject(OnFunAccessor,this));
    }
}

类 炫彩CEFV8值数组 <公开 基础类 = 对象数组模板类 @模板实现类 = "炫彩CEFV8值">

类 炫彩CEFV8环境 <公开 折叠>
{

    # @begin
    # <> <include>
    # HV8CONTEXE m_class;
    # inline_ @sn<current_class> (HV8CONTEXE object) : @sn<current_class> () { m_class = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class == objCompare.m_class); }
    # inline_ BOOL_P IsEmpty () const { return m_class == NULL; }
    # inline_ void Set (HV8CONTEXE object) { m_class = object; }
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "英文名：IsValid" 折叠 @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FTV8Context_IsValid(m_class);
    }

    方法 是否当前环境 <公开 类型 = 逻辑型 注释 = "英文名：InContext" 折叠 @禁止流程检查 = 真>
    {
        @ return IsEmpty()? false : FTV8Context_InContext(m_class);
    }

    方法 "//取任务处理器" <公开 类型 = 炫彩CEF任务运行器 注释 = "英文名：GetTaskRunner" 折叠 @禁止流程检查 = 真>
    {
        @ return IsEmpty()? @dt<炫彩CEF任务运行器>() : @dt<炫彩CEF任务运行器>(FTV8Context_GetTaskRunner(m_class));
    }

    方法 取全局V8值 <公开 类型 = 炫彩CEFV8值 折叠 @嵌入式方法 = "">
    {
        @ @dt<炫彩CEFV8值>(FTV8Context_GetGlobal(@sn<this>.m_class))
    }

    方法 是否相同 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 对比值 <类型 = 炫彩CEFV8环境>
    {
        @ FTV8Context_IsSame(@sn<this>.m_class,@<对比值>.m_class)
    }

    方法 进入 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8Context_Enter(@sn<this>.m_class)
    }

    方法 退出 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTV8Context_Exit(@sn<this>.m_class)
    }

    方法 执行JS代码 <公开 折叠 @嵌入式方法 = "">
    参数 JS代码 <类型 = 文本型>
    参数 链接地址 <类型 = 文本型>
    参数 错误行位置 <类型 = 整数 @默认值 = 0>
    参数 设置返回值 <类型 = 炫彩CEFV8值 @默认值 = 空对象>
    {
        @ FTV8Context_Eval(@sn<this>.m_class,@<JS代码>.GetText(),@<链接地址>.GetText(),@<错误行位置>,(uintptr_t*)@<设置返回值>.m_class);
    }
}

