    方法 关闭 <公开 折叠 @嵌入式方法 = "">
    {
        @ FTBrowser_Close(@sn<this>.hWebView)
    }

    方法 取指针 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.hWebView1
    }

    方法 取浏览器句柄 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    {
        @ return (INT_P)hWebView;
    }

    方法 置浏览器句柄 <公开 折叠>
    参数 句柄 <类型 = 变整数>
    {
        @ hWebView = (HWEBVIEW)@<句柄>;
    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 URL <类型 = 文本型>
    参数 请求环境 <类型 = 炫彩CEF请求环境 @默认值 = 空对象>
    参数 句柄 <类型 = 变整数>
    参数 窗口信息 <类型 = CEF窗口信息>
    {
        @ HELE hele = XEle_Create(@<窗口信息.左边>,@<窗口信息.顶边>,@<窗口信息.宽度>,@<窗口信息.高度>,(HXCGUI)@<句柄>);
        @ FTWindowInfo Info;
        @ @<窗口信息>.ToFTWindowInfo(Info);
        @ hWebView1 = FTBrowser_Create(Info, (LONG_PTR)hele,  RGB(255,0,0), @<URL>,@<请求环境>.IsNullObject()?nullptr:@<请求环境>.m_class, OnBeforeCreate,this);
        @ if(XC_IsHXCGUI(hele,XC_ELE)){
        @ set((vint)hele);
        @  XEle_RegEventCPP1(hele,XE_PAINT,&@sn<current_class>::OnDraw);
        @  XEle_EnableEvent_XE_MOUSEWHEEL(hele,TRUE);
        @  XEle_RegEventCPP1(hele,XE_ELEPROCE,&@sn<current_class>::OnEventProc);
        @  return (INT_P)hele;
        @ }
        @ return 0;

    }

