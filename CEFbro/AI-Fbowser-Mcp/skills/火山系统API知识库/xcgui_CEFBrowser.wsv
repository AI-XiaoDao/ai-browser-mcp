类 炫彩CEF框架 <公开 折叠>
{

    # @begin
    # <> <include>
    # HFRAME m_class;
    # inline_ @sn<current_class> (HFRAME object) : @sn<current_class> () { m_class = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class == objCompare.m_class); }
    # inline_ BOOL_P IsEmpty () const { return m_class == NULL; }
    # inline_ void Set (HFRAME object) { m_class = object; }
    # <> </include>
    # @end

    方法 链接地址 <公开 属性读 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTFrame_GetUrl(@sn<this>.m_class))
    }

    方法 链接地址 <公开 属性写 折叠>
    参数 URL <类型 = 文本型>
    {
        @ FTFrame_LoadUrl(m_class,@<URL>.GetText ());
    }

    方法 是否可前进 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTFrame_IsFocused(@sn<this>.m_class)
    }

    方法 是否主框架 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTFrame_IsMain(@sn<this>.m_class)
    }

    方法 查看网页源码 <公开 注释 = "启动文本外部编辑器查看本框架中当前所浏览页面内容的HTML源代码" 折叠 @嵌入式方法 = "">
    {
        @ FTFrame_ViewSource(@sn<this>.m_class)
    }

    方法 取父框架 <公开 类型 = 炫彩CEF框架 折叠 @嵌入式方法 = "">
    {
        @ @dt<炫彩CEF框架> (FTFrame_GetParent(@sn<this>.m_class))
    }

    方法 取网页源码 <公开 类型 = 文本型 注释 = "返回本框架中当前所浏览页面内容的HTML源代码" 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTFrame_GetWebcode(@sn<this>.m_class))
    }

    方法 取网页文本 <公开 类型 = 文本型 注释 = "返回本框架中当前所浏览页面内容的可显示文本" @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTFrame_GetWebText(@sn<this>.m_class))
    }

    方法 取框架名称 <公开 类型 = 文本型 注释 = "返回本框架的名称" @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTFrame_GetName(@sn<this>.m_class))
    }

    方法 执行JS脚本 <公开 注释 = "执行所指定的JS脚本代码" @嵌入式方法 = "">
    参数 JS代码 <类型 = 文本型 注释 = "提供所欲执行的JavaScript脚本内容" 折叠>
    参数 链接地址 <类型 = 文本型 注释 = "  提供脚本所对应的链接地址,当脚本执行遇到问题时,浏览器" 注释 = "将访问此地址为脚本开发者提供错误来源." @默认值 = "">
    参数 起始行号 <类型 = 整数 注释 = "提供出错报告的基准行号" @默认值 = 1>
    {
        @ FTFrame_ExecJs(@sn<this>.m_class,@<JS代码>.GetText(),@<链接地址>.GetText (), @<起始行号>)
    }

    方法 网页_点击 <公开 注释 = "执行JS查找并执行元素点击事件" 折叠>
    参数 css选择器 <类型 = 文本型 注释 = "提供一个 css选择器 如: #id  .css  div p 等">
    参数 元素索引 <类型 = 整数 注释 = "元素索引从0开始默认为第一个" @默认值 = 0>
    {
        执行JS脚本 ("document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].click()")
    }

    #
}

类 炫彩CEF菜单模式 <公开 折叠>
{

    # @begin
    # <> <include>
    # HMENUMODEL m_class;
    # inline_ @sn<current_class> (HMENUMODEL object) : @sn<current_class> () { m_class = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class == objCompare.m_class); }
