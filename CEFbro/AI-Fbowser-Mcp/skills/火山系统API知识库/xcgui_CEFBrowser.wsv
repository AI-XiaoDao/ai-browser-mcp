类 CEFCookie信息 <公开 注释 = "提供CEF的Cookie信息" 折叠 @文档 = "category = \"炫彩WEB组件.辅助类\"">
{
    变量 名称 <公开 类型 = 文本型 注释 = "提供Cookie的名称" 折叠>
    变量 值 <公开 类型 = 文本型 注释 = "提供Cookie的值">
    变量 域名 <公开 类型 = 文本型 注释 = "  如果域名为空文本,则将创建一个主机Cookie来替换此域名Cookie." 注释 = "  域名Cookie存储时将以句点\'.\'字符为开头并对所有下属子域名可见,"
            注释 = "而主机Cookie不会如此." 折叠2>
    变量 路径 <公开 类型 = 文本型 注释 = "如果路径非空,则只有在此路径下的链接地址网页才能获取此Cookie值.">
    变量 仅安全链接使用 <公开 类型 = 逻辑型 注释 = "如果为真则本Cookie只在 Https 安全链接请求下才会发送">
    变量 仅普通链接使用 <公开 类型 = 逻辑型 注释 = "如果为真则本Cookie只在 Http 请求下才会发送">
    变量 是否会过期 <公开 类型 = 逻辑型 注释 = "指定本Cookie是否会过期">
    变量 过期时间 <公开 类型 = CEF时间类型 注释 = "如果\"是否会过期\"为真,则提供具体的过期时间.">
    变量 创建时间 <公开 类型 = CEF时间类型 注释 = "本成员由CEF自动维护(用户无需填写),用作提供本Cookie的创建时间.">
    变量 最后访问时间 <公开 类型 = CEF时间类型 注释 = "本成员由CEF自动维护(用户无需填写),用作提供本Cookie的最后访问时间.">

    # @begin
    # <> <include>
    # void FromFTCookie (const FTCookie& cookie);
    # void ToFTCookie (FTCookie& cookie);
    # <> </include>
    # void @sn<current_class>::FromFTCookie (const FTCookie& cookie) {
    #     @<名称>.SetText (cookie.name);  @<值>.SetText (cookie.value);  @<域名>.SetText (cookie.domain);
    #     @<路径>.SetText (cookie.path); @<仅安全链接使用> = (cookie.secure != FALSE);  @<仅普通链接使用> = (cookie.httponly != FALSE);
    #     @<是否会过期> = (cookie.has_expires != FALSE); @<过期时间>.FromFTTime(cookie.expires); 
    #     @<创建时间>.FromFTTime(cookie.creation); @<最后访问时间>.FromFTTime(cookie.last_access); 
    # }
    # void @sn<current_class>::ToFTCookie (FTCookie& cookie) {
    #     cookie.name = @<名称>.GetText ();  cookie.value = @<值>.GetText ();  cookie.domain = @<域名>.GetText ();
    #     cookie.path = @<路径>.GetText (); cookie.secure = @<仅安全链接使用>;  cookie.httponly = @<仅普通链接使用>;  cookie.has_expires = @<是否会过期>;  @<过期时间>.ToFTTime(cookie.expires); @<创建时间>.ToFTTime(cookie.creation);
    #    @<最后访问时间>.ToFTTime(cookie.last_access);
    # }
    # @end
}

类 CEF命令行标识 <公开 折叠 @文档 = "category = \"炫彩WEB组件.辅助类\"">
{
    常量 单进程 <公开 类型 = 文本型 值 = "single-process">
    常量 开启摄像头 <公开 类型 = 文本型 值 = "enable-media-stream" 注释 = "1">
    常量 flash <公开 类型 = 文本型 值 = "enable-system-flash" 注释 = "1">
    常量 语音输入 <公开 类型 = 文本型 值 = "enable-speech-input" 注释 = "1">
    常量 禁用GPU <公开 类型 = 文本型 值 = "disable-gpu">
    常量 禁用GPU组合 <公开 类型 = 文本型 值 = "disable-gpu-compositing">
    常量 开启WEBGL <公开 类型 = 文本型 值 = "enable-webgl" 注释 = "1">
    常量 忽略显卡黑名单 <公开 类型 = 文本型 值 = "ignore-gpu-blacklist" 注释 = "1">
    常量 本地调试WEBGL <公开 类型 = 文本型 值 = "allow-file-access-from-files" 注释 = "1">
}

