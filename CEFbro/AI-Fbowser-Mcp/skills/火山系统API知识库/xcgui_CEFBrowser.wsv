    参数 CEF框架 <类型 = 炫彩CEF框架>
    参数 CEFV8环境 <类型 = 炫彩CEFV8环境>

    方法 即将释放V8环境 <公开 定义事件 类型 = 整数 注释 = "注:属于渲染进程所以无法调试,如设置子进程(CefSubprocess.exe)此事件无效," 折叠>
    参数 浏览器句柄 <类型 = 变整数>
    参数 CEF框架 <类型 = 炫彩CEF框架>
    参数 CEFV8环境 <类型 = 炫彩CEFV8环境>

    方法 即将初始化WebKit <公开 定义事件 类型 = 整数 注释 = "注:属于渲染进程所以无法调试,如设置子进程(CefSubprocess.exe)此事件无效,">

    方法 "//初始化" <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 缓存目录 <类型 = 文本型 注释 = "此目录将保存浏览器缓存和用户数据缓存,默认无缓存" @默认值 = 空对象>
    参数 子进程文件 <类型 = 文本型 注释 = "注:如设置了子进程(CefSubprocess.exe)渲染进程相关事件无效" @默认值 = 空对象>
    参数 浏览器标识 <类型 = 文本型 注释 = "值，该值将作为用户代理HTTP头返回。" @默认值 = 空对象>
    参数 远程端口 <类型 = 整数 注释 = "设置为介于1024和65535之间的值，以便在指定端口上启用远程调试。" @默认值 = 0>
    {
        // @ CVolString strPath;
        // @ GetInstancePath (strPath);
        @ return FT_Browser_Init(GetModuleHandle(NULL),@<子进程文件>,  @<缓存目录>.GetText (), @<浏览器标识>.GetText (), @<远程端口>,OnBeforeInit,this);
    }

    方法 初始化 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 初始化配置 <类型 = CEF初始化配置>
    {
        @ FTSettings  Settings;
        @ @<初始化配置>.ToFTSettings(Settings);
        @ return FT_CefInit(GetModuleHandle(NULL), Settings, OnBeforeInit,this);
    }

    方法 运行 <公开 折叠 @嵌入式方法 = "">
    {
        @ FT_RunMessageLoop();
    }

    方法 退出 <公开 折叠 折叠2 @嵌入式方法 = "" "//@视窗.前缀文本" = "@__cdecl">
    {
        @ FT_Shutdown();
    }

    #
}

类 炫彩CEF命令行 <公开 折叠>
{

    # @begin
    # <> <include>
    # HCOMMAND m_class;
    # inline_ @sn<current_class> (HCOMMAND object) : @sn<current_class> () { m_class = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class == objCompare.m_class); }
    # inline_ BOOL_P IsEmpty () const { return m_class == NULL; }
    # inline_ void Set (HCOMMAND object) { m_class = object; }
    # <> </include>
    # @end

    方法 置值 <公开 折叠 @嵌入式方法 = "">
    参数 值 <类型 = 文本型 注释 = "炫彩CEF标识.命令行_**">
    {
        @ FTCommandLine_AppendSwitch(@sn<this>.m_class,@<值>.GetText());
    }

    方法 置项值 <公开 折叠 @嵌入式方法 = "">
    参数 项目名 <类型 = 文本型 注释 = "炫彩CEF标识.命令行_**">
    参数 项目值 <类型 = 文本型>
    {
        @ FTCommandLine_AppendSwitchWithValue(@sn<this>.m_class,@<项目名>.GetText(),@<项目值>.GetText());
    }

    方法 取项值 <公开 类型 = 文本型 折叠 @嵌入式方法 = "">
    参数 值 <类型 = 文本型 注释 = "炫彩CEF标识.命令行_**">
    {
        @ @an<CVolString> (FTCommandLine_GetSwitchValue(@sn<this>.m_class,@<值>.GetText()))
    }

    方法 取程序 <公开 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString> (FTCommandLine_GetProgram(@sn<this>.m_class))
    }

    方法 是否存在项 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ FTCommandLine_HasSwitches(@sn<this>.m_class)
    }

    方法 是否存在某项 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 值 <类型 = 文本型 注释 = "炫彩CEF标识.命令行_**">
    {
        @ FTCommandLine_HasSwitch(@sn<this>.m_class,@<值>.GetText())
    }

    #
}

类 炫彩CEFCookie <公开 折叠>
{

    # @begin
    # <> <include>
    # HCOOKIE hCookie ;
    # inline_ @sn<current_class> (HCOOKIE object) : @sn<current_class> () { hCookie = object;}
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { hCookie = objCopyFrom.hCookie; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (hCookie == objCompare.hCookie); }
    # inline_ BOOL_P IsEmpty () const { return hCookie == NULL; }
    # inline_ void Set (HCOOKIE object) { hCookie = object; }
    # <> </include>
    # void CALLBACK OnEnumAllCookies(FTCookie& cook,bool blpIsLastCookie,int &upResult,void* hCallParam){
    # @sn<current_class>* p = (@sn<current_class>*)hCallParam;
    # @dt<CEFCookie信息> inf;
    #  inf.FromFTCookie (cook);
    # //DebugTrace (FALSE, 0, 0, _T ("Sn"),  _T("FTCookie"),cook.expires.year);
    #   @dt<整数类> bHandle;
    #   bHandle.@n<整数类.值> = upResult;
    #  p->@<获得Cookie>(inf,blpIsLastCookie,bHandle);
    # upResult =  bHandle.@n<整数类.值> ;
    #  }
    #
    # @end

    方法 获得Cookie <公开 定义事件 类型 = 整数 注释 = "当调用\"枚举Cookie\"方法后,每枚举到一个Cookie时,发送一次本事件." 折叠>
    参数 cookie <类型 = CEFCookie信息 注释 = "提供所枚举到的Cookie信息">
    参数 为最后一个 <类型 = 逻辑型 注释 = "提供当前所所枚举到的Cookie是否为最后一个能枚举到的Cookie.">
    参数 是否拦截 <类型 = 整数类 注释 = "返回1停止继续枚举;" 注释 = "返回0继续枚举;" 注释 = "返回-1删除当前cookie并继续枚举;" 注释 = "返回-2删除当前cookie并停止继续枚举.">

    方法 枚举Cookie <公开 类型 = 逻辑型 注释 = "枚举所有现有Cookie,每枚举到一个Cookie,就发送一个对应的\"获得Cookie\"事件."
            注释 = "Cookie枚举以其最长路径排序,如果路径相同,则以创建时间从早到晚排序." 返回值注释 = "返回真表示枚举操作启动成功,返回假表示无法访问Cookie." 折叠 折叠2 @禁止流程检查 = 真>
    参数 匹配链接地址 <类型 = 文本型 注释 = "如果不为空文本,则仅当匹配此链接地址的Cookie才会被枚举." @默认值 = "">
    参数 仅普通链接 <类型 = 逻辑型 注释 = "如果为真,则仅枚举\"CEFCookie信息.仅普通链接使用\"成员值为真的Cookie." @默认值 = 假>
    {
        @ Set(FTCookies_GetGlobalManager());
        @ return FTCookies_EnumAll (hCookie,@<匹配链接地址>.GetText (), @<仅普通链接>,OnEnumAllCookies,this);
    }

    方法 置Cookie <公开 类型 = 逻辑型 注释 = "设置所指定的Cookie" 返回值注释 = "成功返回真,失败返回假." 折叠 @禁止流程检查 = 真>
    参数 链接地址 <类型 = 文本型 注释 = "提供所对应的链接地址">
    参数 Cookie <类型 = CEFCookie信息 注释 = "提供对应的Cookie信息">
    {
        @ if(IsEmpty()) return false;
        @ FTCookie cookie;
        @ @<Cookie>.ToFTCookie (cookie);
        @ return FTCookies_Set (hCookie,@<链接地址>.GetText (), cookie) ;
    }

    方法 删除Cookie <公开 类型 = 逻辑型 注释 = "删除所有匹配的Cookie" 返回值注释 = "成功返回真,失败返回假." 折叠 @禁止流程检查 = 真>
    参数 匹配链接地址 <类型 = 文本型 注释 = "提供用作匹配的链接地址">
    参数 Cookie名称 <类型 = 文本型 注释 = "提供用作匹配的Cookie名称">
    {
        @ if(IsEmpty()) return false;
        @ return FTCookies_Delete (hCookie,@<匹配链接地址>.GetText (), @<Cookie名称>.GetText ()) ;
    }

    方法 刷新Cookie <公开 类型 = 逻辑型 注释 = "将所有后备Cookie数据刷新存储到磁盘" 返回值注释 = "成功返回真,无法访问Cookie返回假." 折叠 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FTCookies_FlushStore (hCookie) ;
    }

    #
}

