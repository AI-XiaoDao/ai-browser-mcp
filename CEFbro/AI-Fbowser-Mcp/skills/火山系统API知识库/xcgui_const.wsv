    常量 不抗锯齿 <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_ALIASED 注释 = "指定不执行抗锯齿。每个像素要么设置为文本的前景色，要么保留背景的颜色"
            编辑时信息 = "0, 70CC5, 0, 0">
    常量 GDI_CLASSIC <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_CLEARTYPE_GDI_CLASSIC
            注释 = "使用与别名文本相同的度量指定 ClearType 呈现,字形只能定位在整个像素的边界上" 编辑时信息 = "0, 70CC5, 0, 0">
    常量 GDI_NATURAL <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_CLEARTYPE_GDI_NATURAL
            注释 = "使用使用 CLEARTYPE_NATURAL_QUALITY 创建的字体，使用与使用 GDI 的文本呈现相同的指标指定 ClearType 呈现。 与使用别名文本相比，字形度量更接近其理想值，但字形仍然位于整个像素的边界上"
            编辑时信息 = "0, 70CC5, 0, 0">
    常量 NATURAL <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_CLEARTYPE_NATURAL
            注释 = "仅在水平维度中指定具有抗锯齿功能的 ClearType 渲染。 这通常用于中小字体大小（最多 16 ppem）" 编辑时信息 = "0, 70CC5, 0, 0">
    常量 NATURAL_SYMMETRIC <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_CLEARTYPE_NATURAL_SYMMETRIC
            注释 = "指定在水平和垂直维度上具有抗锯齿的 ClearType 渲染。这通常用于较大的尺寸，以使曲线和对角线看起来更平滑，但会牺牲一些柔和度" 编辑时信息 = "0, 70CC5, 0, 0">
    常量 OUTLINE <公开 类型 = 整数 值 = @XC_DWRITE_RENDERING_MODE_OUTLINE 注释 = "指定渲染应绕过光栅化器并直接使用轮廓。 这通常用于非常大的尺寸"
            编辑时信息 = "0, 70CC5, 0, 0">
}

