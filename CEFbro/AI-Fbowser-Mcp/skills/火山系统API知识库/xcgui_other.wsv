    参数 文件名 <类型 = 文本型 注释 = "文件名,如:样式文件\\\\style.css">
    参数 密码 <类型 = 文本型 注释 = "密码" @默认值 = 空对象>
    {
        @ @an<CVolMem> memBuf;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
        @ return 0; }
        @ return  XC_LoadStyleZipMem((void*)memBuf.GetPtr (),(INT)memBuf.GetSize (),@<文件名>.GetText (),@<密码>.GetText ());
    }

