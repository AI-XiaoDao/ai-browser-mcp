    方法 曲线 <公开 折叠 @嵌入式方法 = "">
    参数 坐标数组 <类型 = 变整数 注释 = "坐标点数组">
    参数 数组大小 <类型 = 整数>
    参数 张力 <类型 = 单精度小数 注释 = "大于或等于0.0F的值，指定曲线的张力">
    {
        @ XDraw_DrawCurve(@sn<this>.GetP(), (POINT*)@<坐标数组>, @<数组大小>, @<张力>)
    }

    方法 曲线F <公开 @禁止流程检查 = 真>
    参数 坐标数组 <类型 = 单精度小数坐标数组类 注释 = "坐标点数组">
    参数 张力 <类型 = 单精度小数 注释 = "大于或等于0.0F的值，指定曲线的张力">
    {
        变量 局部_位置 <类型 = 单精度小数坐标_xc>
        @ INT Count = @<坐标数组>.GetCount();
        @ POINTF *points = new POINTF[Count];
        @ for (INT i=0; i<Count; i++  ) {
        @ @<局部_位置>=(@dt<单精度小数坐标_xc>&)@<坐标数组>.GetAt(i);
        @ points[i].x = @<局部_位置>.pdata ()->x; 
        @ points[i].y =@<局部_位置>.pdata ()->y; 
        @ }
        @ XDraw_DrawCurveF(GetP(), points, Count, @<张力>);
        @ delete []points;
    }

