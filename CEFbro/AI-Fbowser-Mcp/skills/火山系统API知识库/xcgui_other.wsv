    方法 路径_取图标 <公开 静态 类型 = 变整数 折叠 折叠2 @视窗.外部头文件 = "<commoncontrols.h>" @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    参数 图标大小 <类型 = 整数 注释 = "0:32,1:16,2:48,4:256" @默认值 = 0>
    {
        @ SHFILEINFOW sfi = {0};
        @ IImageList* imageList;
        @ CoInitialize(0);
        @ SHGetFileInfo(@<路径>.GetText (), FILE_ATTRIBUTE_DIRECTORY, &sfi, sizeof(sfi), SHGFI_ICON | SHGFI_LARGEICON | SHGFI_SHELLICONSIZE | SHGFI_SYSICONINDEX | SHGFI_TYPENAME | SHGFI_DISPLAYNAME);//获取指定路径的文件类型信息
        // SHIL_SMALL, SHIL_LARGE, SHIL_EXTRALARGE, SHIL_JUMBO
        @ CoUninitialize();
        @ SHGetImageList(@<图标大小>, IID_IImageList, (void**)&imageList);
        @ HICON hico;
        @ ((IImageList *)imageList)->GetIcon(sfi.iIcon, ILD_TRANSPARENT, &hico);
        @ ((IImageList *)imageList)->Release();
        @ return (INT_P)hico;
    }

