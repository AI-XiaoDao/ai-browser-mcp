    方法 托盘图标_置弹出气泡 <公开 静态 注释 = "" 折叠 @嵌入式方法 = "">
    参数 标题 <类型 = 文本型>
    参数 内容 <类型 = 文本型>
    参数 气泡图标 <类型 = 变整数>
    参数 标识 <类型 = 整数 注释 = "可设置默认图标类型, 托盘标识_**">
    {
        @ XTrayIcon_SetPopupBalloon(@<标题>.GetText (),@<内容>.GetText (),@<气泡图标>,@<标识>)
    }

    方法 托盘图标_置回调消息 <公开 静态 注释 = " 设置用户自定义的回调消息类型, 触发事件后, 系统会发送到此消息" 折叠 @嵌入式方法 = "">
    参数 回调消息 <类型 = 变整数 注释 = "用户自定义消息, 界面库默认定义消息为 XWM_TRAYICON">
    {
        @ XTrayIcon_SetCallbackMessage(@<回调消息>)
    }

    方法 炫彩_调用界面线程 <公开 静态 类型 = 整数 注释 = "炫彩_调用界面线程" 返回值注释 = "XC_CallUiThread" 折叠 @嵌入式方法 = "">
    参数 pCall <类型 = 变整数 注释 = "回调函数 @ref funCallUiThread ; int  (CALLBACK *funCallUiThread)(int data)">
    参数 data <类型 = 变整数 注释 = "用户自定义数据">
    {
        @ XC_CallUiThread ((funCallUiThread)@<pCall>,(vint)@<data>)
    }

    方法 炫彩_信息框 <公开 静态 类型 = 整数 返回值注释 = "返回:消息框标识.***" 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 内容 <类型 = 文本型 注释 = "内容文本">
    参数 标题 <类型 = 文本型 注释 = "标题" @默认值 = "提示:">
    参数 标识 <类型 = 整数 注释 = "如:消息框标识.***" @默认值 = 消息框标识.确定按钮>
    参数 库样式 <类型 = 整数 注释 = "如:窗口样式.***" @默认值 = 窗口样式.弹出窗口>
    {
        @ XC_MessageBox(@<标题>.GetText (), @<内容>.GetText (), @<标识>,(HWND)@<窗口句柄>,@<库样式>)
    }

    方法 炫彩_信息框创建 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 内容 <类型 = 文本型 注释 = "内容文本">
    参数 标题 <类型 = 文本型 注释 = "标题" @默认值 = "提示:">
    参数 标识 <类型 = 整数 注释 = "如:消息框标识.***" @默认值 = 消息框标识.确定按钮>
    参数 库样式 <类型 = 整数 注释 = "如:窗口样式.***" @默认值 = 窗口样式.弹出窗口>
    {
        @ (INT_P)XMsg_Create( @<标题>.GetText (), @<内容>.GetText (), @<标识>,(HWND)@<窗口句柄>,@<库样式>)
    }

    方法 炫彩_信息框创建Ex <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 内容 <类型 = 文本型 注释 = "内容文本">
    参数 标题 <类型 = 文本型 注释 = "标题" @默认值 = "提示:">
    参数 标识 <类型 = 整数 注释 = "如:消息框标识.***" @默认值 = 消息框标识.确定按钮>
    参数 库样式 <类型 = 整数 注释 = "如:窗口样式.***" @默认值 = 窗口样式.弹出窗口>
