类 炫彩全局 <公开 折叠2 @全局类 = 真 @文档 = "category = \"全局函数\"" @禁止创建对象 = 真 @输出名 = "xcklei">
{
    方法 炫彩_取句柄总数 <公开 静态 类型 = 整数 注释 = "获取当前所使用的句柄总数量" 返回值注释 = "返回当前所使用的句柄总数量" 折叠 @嵌入式方法 = "">
    {
        @ XC_GetHandleCount()
    }

    方法 炫彩_启用自动重画 <公开 静态 注释 = "当修改UI后将自动调用重绘函数更新UI, 例如按钮: XBtn_SetText(), 将自动调用" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "启用自动重绘UI, 默认关闭" @默认值 = 假>
    {
        @ XC_EnableAutoRedrawUI(@<是否启用>)
    }

    方法 炫彩_启用DPI <公开 静态 类型 = 逻辑型 注释 = "启用DPI几种方式: 1.在项目属性中启用DPI, 2.使用清单文件, 3.调用此函数, 4.自己调用DPI函数"
            注释 = "参考MSDN: https://learn.microsoft.com/zh-cn/windows/win32/hidpi/setting-the-default-dpi-awareness-for-a-process"
            返回值注释 = "如果成功返回TRUE,否则返回FALSE" 折叠 折叠2 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "当启用后, 创建窗口时自动检测DPI调整UI缩放, 处理DPI改变消息; 禁用后,当DPI改变,需要手动设置窗口DPI" @默认值 = 真>
    {
        @ XC_EnableDPI(@<是否启用>)
    }

    方法 炫彩_启用自动DPI <公开 静态 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 注释 = "默认禁用; 当启用后, 创建窗口时自动检测DPI调整UI缩放, 处理DPI改变消息; 禁用后,当DPI改变,需要手动设置窗口DPI" @默认值 = 假>
    {
        @ XC_EnableAutoDPI(@<是否启用>)
    }

    方法 炫彩_置窗口图标 <公开 静态 折叠 @嵌入式方法 = "">
    参数 图片对象 <类型 = 炫彩图片>
    {
        @ XC_SetWindowIcon(@<图片对象>.GetP())
    }

    方法 炫彩_是否初始化 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ XC_IsInit()
    }

    方法 炫彩_初始化 <公开 静态 类型 = 逻辑型 注释 = "初始化炫彩界面库" 返回值注释 = "成功返回TRUE否则返回FALSE" @禁止流程检查 = 真>
    参数 启用D2D <类型 = 逻辑型 注释 = "默认:假,为GDI+绘制,真:为D2D绘制" 折叠2 @默认值 = 假 @输出名 = "bD2D">
    {
        变量 输出 <类型 = 文本型
                值 = "-----------------------------------------------------------\r\n封装 : 易团雪-->炫彩问答服务群-->一口价99永久服务\r\n版本 : DLL:3.3.9.1-25.3.31->模块 : 2025.3.31\r\n炫彩论坛 :bbs.xcgui.com-->炫彩QQ群3:2283812      \r\n资源商场 :mall.xcgui.com-->私人企鹅:283279437\r\n-----------------------------------------------------------"
                编辑时信息 = "0, 4B6D6, 0, 0">
        如果真 (是否为调试版 () == 真)
        {
            调试输出 (输出)
        }
        @ return XInitXCGUI (bD2D);
    }

    方法 炫彩_运行 <公开 静态 注释 = "如配合MFC使用,无需加此命令.消息交给mfc处理,否则mfc的消息会被炫彩拦截.导致mfc部分消息事件失效" 折叠 @嵌入式方法 = "">
    {
        @ XRunXCGUI ()
    }

    方法 炫彩_退出 <公开 静态 注释 = "如配合MFC使用,无需加此命令." 折叠 @嵌入式方法 = "">
