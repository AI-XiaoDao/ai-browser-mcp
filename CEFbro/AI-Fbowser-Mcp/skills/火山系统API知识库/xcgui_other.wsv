    参数 zip密码 <类型 = 文本型 注释 = "zip密码" @默认值 = 空对象>
    参数 模板句柄1 <类型 = 变整数 注释 = "返回模板句柄1, 项模板">
    参数 模板句柄2 <类型 = 变整数 注释 = "返回模板句柄2, 列表头模板或列表视组模板">
    {
        // @ HTEMP pOutTemp1, pOutTemp2;
        @ XTemp_LoadZipMemEx((listItemTemp_type_)@<类型>,(void*)@<数据资源>.GetPtr (),@<数据长度>,@<文件名>.GetText (),@<zip密码>.GetText (),(HTEMP*)&@<模板句柄1>,(HTEMP*)&@<模板句柄2>)
        // @ WRITE_POINTER_NUMBER (@<模板句柄1>, vint, pOutTemp1);
        // @ WRITE_POINTER_NUMBER (@<模板句柄2>, vint, pOutTemp2);
        // @ return  i;
    }

    方法 项模板_加载从内存 <公开 静态 类型 = 变整数 返回值注释 = "返回模板句柄" 折叠 @禁止流程检查 = 真>
    参数 类型 <类型 = 整数 注释 = "项模板类型.***(项模板类型.组合_**不可用)">
    参数 数据资源 <类型 = 视窗文件资源>
    {
        @ @an<CVolMem> memBuf;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
        @ return 0; }//文件资源到字节集
        @ return (INT_P)XTemp_LoadFromMem((listItemTemp_type_)@<类型>,(void*)memBuf.GetPtr (),(INT)memBuf.GetSize ());
    }

