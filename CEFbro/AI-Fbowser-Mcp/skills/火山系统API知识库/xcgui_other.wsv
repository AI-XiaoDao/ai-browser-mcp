类 炫彩字体 <公开 基础类 = guibase 注释 = "因为edit不支持下划线字体, 下划线,删除线,需要单独设置,见本模块接口" 折叠>
{

    # @ @m<guibase.DECLARE_YTXXCGUI_CLASS>(CXHFONTX, HFONTX)
    # @begin
    # <> <include>
    # public:
    # //构造函数  可以用于 强转 @dt<炫彩字体>
    #     inline_ @sn<current_class>(HFONTX hBkInfoM):@sn<current_class>()    {
    #         data().SetPtr(hBkInfoM);  
    #     }
    # <>  </include>
    # @end

    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        // @ if (GetP () != NULL){
        // @ XImage_Release(GetP()); }//释放
        @ SetP((HFONTX)@<指针>);
    }

    方法 增加引用计数 <公开 @嵌入式方法 = "">
    {
        @ XFont_AddRef(@sn<this>.GetP())
    }

    方法 创建 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 大小 <类型 = 整数>
    {
        @ @sn<this>.SetP(XFont_Create(@<大小>))
    }

    方法 创建扩展 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 字体名称 <类型 = 文本型>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ @sn<this>.SetP(XFont_CreateEx(@<字体名称>.GetText (), @<字体大小>, @<字体风格>))
    }

    方法 创建从ZPI内存 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 字体指针 <类型 = 变整数>
    参数 指针长度 <类型 = 整数>
    参数 文件名 <类型 = 文本型>
    参数 密码 <类型 = 文本型>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ @sn<this>.SetP(XFont_CreateFromZipMem((void*)@<字体指针>, @<指针长度>,@<文件名>.GetText (),@<密码>.GetText (),@<字体大小>, @<字体风格>))
    }

    方法 创建从ZPI <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 pZipFileName <类型 = 文本型>
    参数 文件名 <类型 = 文本型>
    参数 密码 <类型 = 文本型>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ @sn<this>.SetP(XFont_CreateFromZip(@<pZipFileName>.GetText (),@<文件名>.GetText (),@<密码>.GetText (),@<字体大小>, @<字体风格>))
    }

    方法 创建从内存 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 字体指针 <类型 = 变整数>
    参数 指针长度 <类型 = 整数>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ @sn<this>.SetP(XFont_CreateFromMem((void*)@<字体指针>, @<指针长度>,@<字体大小>, @<字体风格>))
    }

    方法 创建从字节集 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 字体数据 <类型 = 字节集类>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ return SetP(XFont_CreateFromMem((void *)@<字体数据>.GetPtr (),(INT)@<字体数据>.GetSize (),@<字体大小>, @<字体风格>));
    }

    方法 创建从资源 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 资源ID <类型 = 整数>
    参数 资源类型 <类型 = 文本型>
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    参数 模块句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ @sn<this>.SetP(XFont_CreateFromRes(@<资源ID>,@<资源类型>.GetText (),@<字体大小>,@<字体风格>, @<模块句柄>))
    }

    方法 创建逻辑字体 <公开 折叠 @禁止流程检查 = 真>
    参数 字体结构 <类型 = 逻辑字体_结构>
    {
        @ LOGFONTW pCopy;
        @ pCopy.lfHeight = @<字体结构.字符高度> ;
        @ pCopy.lfWidth = @<字体结构.字符宽度>;    
        @ pCopy.lfEscapement = @<字体结构.打印角度> ;
        @ pCopy.lfOrientation = @<字体结构.字体打印角度> ;
        @ pCopy.lfWeight = @<字体结构.字体重量> ;
        @ pCopy.lfItalic = (BYTE)@<字体结构.斜体> ;
        @ pCopy.lfUnderline = (BYTE)@<字体结构.下划线> ;
        @ pCopy.lfStrikeOut = (BYTE)@<字体结构.删除线> ;
        @ pCopy.lfCharSet = (BYTE)@<字体结构.字符集> ;
        @ pCopy.lfOutPrecision = (BYTE)@<字体结构.输出精度> ;
        @ pCopy.lfPitchAndFamily = (BYTE)@<字体结构.间距>  ;
        @ pCopy.lfFaceName = @<字体结构.字体名称>;
        @ SetP(XFont_CreateFromLOGFONTW(&pCopy));
    }

    方法 创建从文件 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 字体文件 <类型 = 文本型>
    参数 字体大小 <类型 = 整数 @默认值 = 10>
    参数 字体风格 <类型 = 整数 注释 = "字体风格.***" @默认值 = 字体风格.正常>
    {
        @ @sn<this>.SetP(XFont_CreateFromFile(@<字体文件>.GetText (), @<字体大小>, @<字体风格>))
    }

    方法 创建从Font <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 字体句柄 <类型 = 变整数 注释 = "GDI+字体指针">
    {
        @ @sn<this>.SetP(XFont_CreateFromFont((void *)@<字体句柄>))
    }

    方法 创建从HFONT <公开 类型 = 逻辑型 注释 = "创建炫彩字体从现有HFONT字体" 折叠 @嵌入式方法 = "">
    参数 字体句柄 <类型 = 变整数>
    {
        @ @sn<this>.SetP(XFont_CreateFromHFONT((HFONT )@<字体句柄>))
    }

    方法 销毁 <公开 折叠 @嵌入式方法 = "">
    {
        @ XFont_Destroy(@sn<this>.GetP())
    }

    方法 启用自动销毁 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XFont_EnableAutoDestroy(@sn<this>.GetP(), @<是否启用>)
    }

    方法 取Font <公开 类型 = 变整数 注释 = "返回GDI+ Font指针." 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)XFont_GetFont(@sn<this>.GetP())
    }

    方法 取信息 <公开 折叠 @嵌入式方法 = "">
    参数 信息 <类型 = 字体信息_结构>
    {
        // @ font_info_ font;
        @ XFont_GetFontInfo(@sn<this>.GetP(), @<信息>.pdata ());
        // @ @<信息.字体名称>(font.name);
        // @ @<信息.字体大小>(font.nSize);
        // @ @<信息.字体样式>(font.nStyle);
        // @ return @<信息>;
    }

    方法 取逻辑字体W <公开 类型 = 逻辑型 返回值注释 = "成功返回TRUE,否则返回FALSE" 折叠 @禁止流程检查 = 真>
    参数 设备句柄 <类型 = 变整数>
    参数 字体结构 <类型 = 逻辑字体_结构 注释 = "返回接收的字体结构">
    {
        @ LOGFONTW pOut;
        @ BOOL hr = XFont_GetLOGFONTW(GetP(), (HDC)@<设备句柄>, &pOut);
        @ @<字体结构>.Copy(&pOut);
        @ return hr;
    }

    方法 取引用计数 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XFont_GetRefCount(@sn<this>.GetP())
    }

    方法 置下划线 <公开 注释 = "仅供edit字体使用, 因为edit不支持下划线字体, 所以需要单独设置" 折叠 @嵌入式方法 = "">
    参数 启用下划线 <类型 = 逻辑型>
    参数 启用删除线 <类型 = 逻辑型>
    {
        @ XFont_SetUnderlineEdit(@sn<this>.GetP(),@<启用下划线>,@<启用删除线>)
    }

    方法 取下划线 <公开 注释 = "仅供edit字体使用, 因为edit不支持下划线字体, 所以需要单独设置" 折叠 @嵌入式方法 = "">
    参数 启用下划线 <类型 = 逻辑型 注释 = "接收返回值">
    参数 启用删除线 <类型 = 逻辑型 注释 = "接收返回值">
    {
        @ XFont_GetUnderlineEdit(@sn<this>.GetP(),(BOOL*)&@<启用下划线>,(BOOL*)&@<启用删除线>)
    }

    方法 释放引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XFont_Release(@sn<this>.GetP())
    }
}

类 炫彩SVG <公开 基础类 = guibase 注释 = "SVG矢量图形" 折叠>
{

    # @ @m<guibase.DECLARE_YTXXCGUI_CLASS>(CXHSVG, HSVG)
    # @begin
    # <> <include>
    # public:
    #     inline_ @sn<current_class>(HSVG hHSVG):@sn<current_class>()    {
    #         data().SetPtr(hHSVG);  
    #     }
    # <>  </include>
    # @end

    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        // @ if (GetP () != NULL){
        // @ XImage_Release(GetP()); }//释放
        @ SetP((HSVG)@<指针>);
    }

    方法 加载从ZIP资源 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 ID <类型 = 整数>
    参数 zip文件名 <类型 = 文本型 注释 = "zip文件名.">
    参数 zip密码 <类型 = 文本型 注释 = "zip密码.">
    参数 模块句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ @sn<this>.SetP(XSvg_LoadZipRes(@<ID>,@<zip文件名>.GetText (),@<zip密码>.GetText (),(HMODULE)@<模块句柄>))
    }

    方法 加载从ZIP内存 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 data <类型 = 变整数 注释 = "指针">
    参数 length <类型 = 整数 注释 = "长度">
    参数 pFileName <类型 = 文本型 注释 = "文件名">
    参数 pPassword <类型 = 文本型 注释 = "密码">
    {
        @ @sn<this>.SetP (XSvg_LoadZipMem ((void*)@<data>,@<length>,@<pFileName>.GetText (),@<pPassword>.GetText ()))
    }

    方法 加载从文件 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 pFileName <类型 = 文本型 注释 = "文件名">
    {
        @ @sn<this>.SetP (XSvg_LoadFile (@<pFileName>.GetText ()))
    }

    方法 加载从字符串 <公开 类型 = 逻辑型 注释 = "A码" 折叠 @嵌入式方法 = "">
    参数 pString <类型 = 字节集类 注释 = "字符串指针">
    {
        @ @sn<this>.SetP (XSvg_LoadString ((const char *)@<pString>.GetPtr()))
    }

    方法 加载从字符串UTF8 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 pString <类型 = 字节集类 注释 = "字符串指针">
    {
        @ @sn<this>.SetP (XSvg_LoadStringUtf8 ((const char *)@<pString>.GetPtr()))
    }

    方法 加载从字符串W <公开 类型 = 逻辑型 注释 = "UNICODE字符串" 折叠 @嵌入式方法 = "">
    参数 pString <类型 = 字节集类 注释 = "字符串指针">
    {
        @ @sn<this>.SetP (XSvg_LoadStringW ((const wchar_t *)@<pString>.GetPtr()))
    }

    方法 加载从ZIP <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 pZipFileName <类型 = 文本型 注释 = "zip文件名">
    参数 pFileName <类型 = 文本型 注释 = "svg文件名">
    参数 pPassword <类型 = 文本型 注释 = "zip密码">
    {
        @ @sn<this>.SetP (XSvg_LoadZip (@<pZipFileName>.GetText (), @<pFileName>.GetText (), @<pPassword>.GetText ()))
    }

    方法 加载从资源 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 id <类型 = 整数 注释 = "资源ID">
    参数 pType <类型 = 文本型 注释 = "资源类型. 在rc资源文件中,资源的类型, 例如:xcgui.rc, 用记事本打开可以看见资源类型; 例如:BITMAP, PNG; 参见MSDN">
    参数 hModule <类型 = 变整数 注释 = "从指定模块加载, 例如:DLL, EXE; 如果为空, 从当前EXE加载" @默认值 = 0>
    {
        @ @sn<this>.SetP (XSvg_LoadRes (@<id>, @<pType>.GetText (), @<hModule>)
    }

    方法 置大小 <公开 折叠 @嵌入式方法 = "">
    参数 nWidth <类型 = 整数 注释 = "宽度">
    参数 nHeight <类型 = 整数 注释 = "高度">
    {
        @ XSvg_SetSize (@sn<this>.GetP (), @<nWidth>, @<nHeight>)
    }

    方法 取大小 <公开 折叠 @嵌入式方法 = "">
    参数 pWidth <类型 = 整数 注释 = "接收返回宽度">
    参数 pHeight <类型 = 整数 注释 = "接收返回高度">
    {
        @ XSvg_GetSize (@sn<this>.GetP (), (int *)&@<pWidth>, (int *)&@<pHeight>)
    }

    方法 取宽度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XSvg_GetWidth (@sn<this>.GetP ())
    }

    方法 取高度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XSvg_GetHeight (@sn<this>.GetP ())
    }

    方法 置位置 <公开 注释 = "偏移" 折叠 @嵌入式方法 = "">
    参数 x <类型 = 整数 注释 = "x轴偏移">
    参数 y <类型 = 整数 注释 = "y轴偏移">
    {
        @ XSvg_SetPosition (@sn<this>.GetP (), @<x>, @<y>)
    }

    方法 取位置 <公开 注释 = "偏移" 折叠 @嵌入式方法 = "">
    参数 pX <类型 = 整数 注释 = "返回x轴偏移">
    参数 pY <类型 = 整数 注释 = "返回y轴偏移">
    {
        @ XSvg_GetPosition (@sn<this>.GetP (), (int *)&@<pX>, (int *)&@<pY>)
    }

    方法 取视图框 <公开 折叠 @嵌入式方法 = "">
    参数 pViewBox <类型 = 矩形_xc 注释 = "接收返回视图框">
    {
        @ XSvg_GetViewBox (@sn<this>.GetP (), @<pViewBox>.pdata())
    }

    方法 启用自动销毁 <公开 折叠 @嵌入式方法 = "">
    参数 bEnable <类型 = 逻辑型 注释 = "是否自动销毁">
    {
        @ XSvg_EnableAutoDestroy (@sn<this>.GetP (), @<bEnable>)
    }

    方法 增加引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XSvg_AddRef (@sn<this>.GetP ())
    }

    方法 释放引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XSvg_Release (@sn<this>.GetP ())
    }

    方法 取引用计数 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XSvg_GetRefCount (@sn<this>.GetP ())
    }

    方法 透明度 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 透明度 <类型 = 整数>
    {
        @ XSvg_SetAlpha (GetP (),(BYTE)@<透明度>);
    }

    方法 透明度 <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ (INT)XSvg_GetAlpha (@sn<this>.GetP ())
    }

    方法 旋转角度 <公开 属性写 注释 = "默认以自身中心点旋转" @禁止流程检查 = 真>
    参数 角度 <类型 = 单精度小数>
    {
        @ XSvg_SetRotateAngle (GetP (),@<角度>);
    }

    方法 旋转角度 <公开 属性读 类型 = 单精度小数 @嵌入式方法 = "">
    {
        @ XSvg_GetRotateAngle (@sn<this>.GetP ())
    }

    方法 置旋转 <公开 @嵌入式方法 = "">
    参数 角度 <类型 = 单精度小数>
    参数 x <类型 = 单精度小数 注释 = "旋转中心点X">
    参数 y <类型 = 单精度小数 注释 = "旋转中心点Y">
    参数 是否偏移 <类型 = 逻辑型 注释 = "TRUE:旋转中心点相对于自身中心偏移, FALSE:使用绝对坐标">
    {
        @ XSvg_SetRotate (@sn<this>.GetP (),@<角度>,@<x>,@<y>,@<是否偏移>)
    }

    方法 取旋转 <公开 @嵌入式方法 = "">
    参数 角度 <类型 = 单精度小数 注释 = "返回角度">
    参数 x <类型 = 单精度小数 注释 = "返回旋转中心点X">
    参数 y <类型 = 单精度小数 注释 = "返回旋转中心点Y">
    参数 是否偏移 <类型 = 逻辑型 注释 = "返回TRUE:旋转中心点相对于自身中心偏移, FALSE:使用绝对坐标">
    {
        // @ float  pAngle,  pX,  pY;//@ BOOL  pbOffset  ;
        @ XSvg_GetRotate (@sn<this>.GetP (),&@<角度>,&@<x>,&@<y>,&@<是否偏移>)
        // @ @<角度>=(@dt<小数>)pAngle;
        // @ @<x>=(@dt<小数>)pX;
        // @ @<y>=(@dt<小数>)pY;
        // @ @<是否偏移>=pbOffset;
    }

    方法 置填充颜色 <公开 注释 = "用户颜色将覆盖默认样式" 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 整数 @默认值 = 255>
    参数 是否有效 <类型 = 逻辑型>
    {
        @ XSvg_SetUserFillColor (@sn<this>.GetP (),COLORREF_MAKE2(@<颜色>,(BYTE)@<透明度>),@<是否有效>)
    }

    方法 取填充颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数类 注释 = "返回的颜色">
    {
        @ COLORREF pColor ;
        @ XSvg_SetUserFillColor (@sn<this>.GetP (),&pColor);
        @ @<颜色>=(INT)pColor;
    }

    方法 置笔触颜色 <公开 注释 = "用户颜色将覆盖默认样式" @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 整数 @默认值 = 255>
    参数 笔触宽度 <类型 = 单精度小数>
    参数 是否有效 <类型 = 逻辑型>
    {
        @ XSvg_SetUserStrokeColor (@sn<this>.GetP (),COLORREF_MAKE2(@<颜色>,(BYTE)@<透明度>),@<笔触宽度>,@<是否有效>)
    }

    方法 取笔触颜色 <公开 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数 注释 = "返回的颜色">
    参数 笔触宽度 <类型 = 单精度小数 注释 = "返回的宽度">
    {
        @ COLORREF pColor ;//float pStrokeWidth ;
        @ XSvg_GetUserStrokeColor (@sn<this>.GetP (),&pColor,&@<笔触宽度>);
        @ @<颜色>=(INT)pColor;
        // @ @<笔触宽度>=(@dt<小数>)pStrokeWidth;
    }

    方法 显示 <公开 折叠 @嵌入式方法 = "">
    参数 bShow <类型 = 逻辑型>
    {
        @ XSvg_Show (@sn<this>.GetP (),@<bShow>)
    }

    方法 销毁 <公开 折叠 @嵌入式方法 = "">
    {
        @ XSvg_Destroy (@sn<this>.GetP ())
    }
}

类 动画基类 <基础类 = guibase 折叠>
{

    # @ @m<guibase.DECLARE_YTXXCGUI_CLASS>(CXHXCGUI, HXCGUI)
    # //@begin
    # <> <include>
    # public:
    #     inline_ @sn<current_class>(HXCGUI hObjectUI):@sn<current_class>()    {
    #         data().SetPtr(hObjectUI);  
    #     }
    # <>  </include>
    # //@end

    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        // @ if (GetP () != NULL){
        // @ XImage_Release(GetP()); }//释放
        @ SetP((HXCGUI)@<指针>);
    }

    方法 缩放 <公开 类型 = 变整数 注释 = "默认以自身为中心缩放" 返回值注释 = "返回动画项句柄" @嵌入式方法 = "">
    参数 持续时间 <类型 = 整数>
    参数 X轴缩放比例 <类型 = 单精度小数>
    参数 Y轴缩放比例 <类型 = 单精度小数>
    参数 次数 <类型 = 整数 注释 = "动画循环次数, 0:无限循环">
    参数 缓动标识 <类型 = 整数 注释 = "缓动标识.****">
    参数 是否往返 <类型 = 逻辑型 注释 = "当启用后:往返到起点, 起点->终点->起点" @默认值 = 假>
    {
        @ (INT_P)XAnima_Scale(@sn<this>.GetP (), (UINT)@<持续时间>, @<X轴缩放比例>, @<Y轴缩放比例>, @<次数>, @<缓动标识>, @<是否往返>)
    }

    方法 缩放大小 <公开 类型 = 变整数 注释 = "修改UI对象大小,默认向右延伸" 返回值注释 = "返回动画项句柄" @嵌入式方法 = "">
    参数 持续时间 <类型 = 整数>
    参数 宽度 <类型 = 单精度小数>
    参数 高度 <类型 = 单精度小数>
    参数 次数 <类型 = 整数 注释 = "动画循环次数, 0:无限循环">
    参数 缓动标识 <类型 = 整数 注释 = "缓动标识.****">
    参数 是否往返 <类型 = 逻辑型 注释 = "当启用后:往返到起点, 起点->终点->起点" @默认值 = 假>
    {
        @ (INT_P)XAnima_ScaleSize(@sn<this>.GetP (), (UINT)@<持续时间>, @<宽度>, @<高度>, @<次数>, @<缓动标识>, @<是否往返>)
    }

    方法 运行 <公开 注释 = "并且增加引用计数" 折叠 @嵌入式方法 = "">
