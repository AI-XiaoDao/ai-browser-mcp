    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        // @ if (GetP () != NULL){
        // @ XImage_Release(GetP()); }//释放
        @ SetP((HDRAW)@<指针>);
    }

    方法 GDI_复制带透明 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 目标左边 <类型 = 整数>
    参数 目标顶边 <类型 = 整数>
    参数 目标宽度 <类型 = 整数>
    参数 目标高度 <类型 = 整数>
    参数 源设备句柄 <类型 = 变整数>
    参数 源左边 <类型 = 整数>
    参数 源顶边 <类型 = 整数>
    参数 源宽度 <类型 = 整数>
    参数 源高度 <类型 = 整数>
    参数 透明度 <类型 = 整数 @默认值 = 255>
    {
        @ XDraw_GDI_AlphaBlend(@sn<this>.GetP(), @<目标左边>, @<目标顶边>, @<目标宽度>, @<目标高度>, (HDC)@<源设备句柄>, @<源左边>, @<源顶边>, @<源宽度>, @<源高度>, @<透明度>)
    }

    方法 GDI_复制 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 目标左边 <类型 = 整数 注释 = "指定目标矩形区域左上角的X轴逻辑坐标">
    参数 目标顶边 <类型 = 整数 注释 = "指定目标矩形区域左上角的Y轴逻辑坐标">
    参数 宽度 <类型 = 整数 注释 = "指定源在目标矩形区域的逻辑宽度">
    参数 高度 <类型 = 整数 注释 = "指定源在目标矩形区域的逻辑高度">
    参数 源设备句柄 <类型 = 变整数>
    参数 源左边 <类型 = 整数 注释 = "指定源矩形区域左上角的X轴逻辑坐标">
    参数 源顶边 <类型 = 整数 注释 = "指定源矩形区域左上角的Y轴逻辑坐标">
    参数 方式 <类型 = 整数 注释 = "操作方式.***">
    {
        @ XDraw_GDI_BitBlt(@sn<this>.GetP(), @<目标左边>, @<目标顶边>, @<宽度>, @<高度>, (HDC)@<源设备句柄>, @<源左边>, @<源顶边>, @<方式>)
    }

    方法 GDI_复制2 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
