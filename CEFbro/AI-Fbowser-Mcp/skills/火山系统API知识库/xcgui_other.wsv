    方法 项模板_加载从内存ZIP扩展 <公开 静态 类型 = 逻辑型 返回值注释 = "如果成功返回TRUE,否则返回FALSE." 折叠 @禁止流程检查 = 真>
    参数 类型 <类型 = 整数 注释 = "项模板类型.组合_**">
    参数 数据资源 <类型 = 视窗文件资源 注释 = "内存块指针">
    参数 文件名 <类型 = 文本型 注释 = "文件名">
    参数 zip密码 <类型 = 文本型 注释 = "zip密码" @默认值 = 空对象>
    参数 模板句柄1 <类型 = 变整数 注释 = "返回模板句柄1, 项模板" @视窗.后缀文本 = "&">
    参数 模板句柄2 <类型 = 变整数 注释 = "返回模板句柄2, 列表头模板或列表视组模板" @视窗.后缀文本 = "&">
    {
        @ @an<CVolMem> memBuf;
        // @ HTEMP pOutTemp1, pOutTemp2;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) return false;
        @ return XTemp_LoadZipMemEx((listItemTemp_type_)@<类型>,(void*)memBuf.GetPtr (),(INT)memBuf.GetSize (),@<文件名>.GetText (),@<zip密码>.GetText (),(HTEMP*)&@<模板句柄1>,(HTEMP*)&@<模板句柄2>);
        // @ WRITE_POINTER_NUMBER (@<模板句柄1>, INT_P, pOutTemp1);
