类 炫彩可设计类 <公开 基础类 = 可设计类 折叠 隐藏值属性 = "0"
        @设计器 = "name = \"炫彩界面设计器\"\r\ndll_file_name.win32 = \"lib\\win32\\designer_win32.dll\"\r\ndll_file_name.x64 = \"lib\\x64\\designer_win64.dll\"\r\nauto_generate_mark = \"炫彩界面库\"">
{
    变量 句柄 <公开 类型 = 变整数 注释 = "用炫彩_加载**相关命令加载的句柄实现动态效果">

    方法 "//创建" <公开 类型 = 逻辑型 注释 = "从文件创建" 折叠 "">
    参数 父句柄 <类型 = 变整数 注释 = "父对象句柄,窗口句柄或UI元素句柄." 折叠 @默认值 = 0>
    参数 附加窗口 <类型 = 变整数 注释 = "附加到指定窗口,取窗口句柄()" @默认值 = 0>
    {
        变量 设计内容 <类型 = 文本型 折叠>
        变量 属性名数组 <类型 = 文本数组类>
        变量 属性值数组 <类型 = 文本数组类>
        设计内容 = 取设计内容 ()
        变量 窗口布局文件 <类型 = 文本型 注释 = "取出窗口xml文件" 折叠>
        变量 文本数组 <类型 = 文本数组类 注释 = "取出 组件列表 <组件类型,组件name>">
        变量 index <类型 = 整数>
        变量 count <类型 = 整数>
        // pos = 寻找字符 (设计内容, ',')
        // 删除字符 (设计内容, 0, pos + 1)  // 删除 xcgui 字段
        分割子文本 (设计内容, ",", 文本数组)
        计次循环 (文本数组.取成员数 ())
        {
            变量 文本数组_临时 <类型 = 文本数组类>
            分割子文本 (文本数组.取成员 (取循环索引 ()), ":", 文本数组_临时)

            如果 (2 != 文本数组_临时.取成员数 ())
            {
                返回 (假)
            }
            // 调试输出 (文本数组_临时.取成员 (0), "|", 文本数组_临时.取成员 (1))
            属性名数组.加入成员 (文本数组_临时.取成员 (0))
            属性值数组.加入成员 (文本数组_临时.取成员 (1))

        }
        // 调试输出 ("------------------")
        index = 属性名数组.查找首成员 ("xml")
        如果 (-1 == index)
        {
            调试输出 ("未找到布局文件标签")
            返回 (假)
        }

        窗口布局文件 = 属性值数组.取成员 (index)
        删除部分文本 (窗口布局文件, 0, 1)
        删除字符 (窗口布局文件, 取文本长度 (窗口布局文件) - 1, 1)
        // 调试输出 ("布局文件 = ", 窗口布局文件)
        @ HXCGUI hWindow = XC_LoadLayout(@<窗口布局文件>.GetText (),(HXCGUI)@<父句柄>,(HWND)@<附加窗口>);
        @ if (!hWindow){
        @   DebugTrace (FALSE, 0, 0, _T ("SSSpS"), L"加载布局文件失败=", @<窗口布局文件>.GetText() ,  L"窗口的句柄 = ",hWindow,L"请检查资源路径是否正确!");
        @  return 0; }
        index = index + 1

        @  vint addr = (vint)this + sizeof( @dt<炫彩可设计类>) ;
        @ ((@dt<炫彩基类>*)addr)->set( (vint)hWindow );
        @ XC_OBJECT_TYPE  xc_type = XObj_GetType(hWindow);
        @ if(XC_WINDOW==xc_type) {
        @      ((@dt<普通窗口>*) addr)->@n<普通窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<普通窗口> );
        @      @< index>++; 
        @ }
        @ if(XC_FRAMEWND==xc_type) {
        @      ((@dt<框架窗口>*) addr)->@n<框架窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<框架窗口> );
        @      @< index>++; 
        @ }
        @ if(XC_MODALWINDOW==xc_type) {
        @      ((@dt<模态窗口>*) addr)->@n<模态窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<模态窗口> );
        @      @< index>++; 
        @ }

        // 调试输出 ("---绑定变量---------------")
        count = 属性名数组.取成员数 ()
        // 调试输出 ("索引", index, "数量", count)
        循环 (index, count, index, 1)
        {
            变量 value <类型 = 文本型>
            value = 属性值数组.取成员 (index)  // 变量名称
            @ HXCGUI hObj = XC_GetObjectByName(@<value>.GetText());
            @ if(!hObj){
            @   DebugTrace (FALSE, 0, 0, _T ("SSSp"), L"绑定变量失败 变量名=",  @<value>.GetText(), L"句柄=", hObj);
            @   return 0; }

            @  xc_type = XObj_GetType (hObj);
            @ if(XC_ERROR==xc_type) return false;
            @ ((@dt<炫彩基类>*) addr)->set( (vint)hObj );
            @  ((@dt<可视对象>*) addr)->@n<可视对象.自动注册事件>();

            @ switch(xc_type){
            @ case  XC_ELE:  addr = addr + sizeof( @dt<基础元素> ); break;
            @ case  XC_ELE_LAYOUT:   addr = addr + sizeof( @dt<炫彩布局> ); break;
            @ case  XC_BUTTON:    addr = addr + sizeof( @dt<炫彩按钮> ); break;
            @ case XC_LISTBOX:  addr = addr + sizeof( @dt<炫彩列表框> ); break;
            @ case XC_LIST:  addr = addr + sizeof( @dt<炫彩列表> ); break;
            @ case XC_SHAPE:  addr = addr + sizeof( @dt<形状基类> ); break;
            @ case XC_SHAPE_TEXT:  addr = addr + sizeof( @dt<形状文本> ); break;
            @ case XC_SHAPE_PICTURE:  addr = addr + sizeof( @dt<形状图片> ); break;
            @ case XC_SHAPE_RECT:  addr = addr + sizeof( @dt<形状矩形> ); break;
            @ case XC_SHAPE_GROUPBOX:  addr = addr + sizeof( @dt<形状组框> ); break;
            @ case XC_SHAPE_GIF:  addr = addr + sizeof( @dt<形状GIF> ); break;
            @ case XC_SHAPE_TABLE:  addr = addr + sizeof( @dt<形状表格> ); break;
            @ case XC_EDIT:  addr = addr + sizeof( @dt<炫彩编辑框> ); break;
            @ case XC_TREE:  addr = addr + sizeof( @dt<炫彩列表树> ); break;
            @ case XC_EDITOR:  addr = addr + sizeof( @dt<炫彩代码框> ); break;
            @ case XC_PROGRESSBAR:   addr = addr + sizeof( @dt<炫彩进度条> ); break;
            @ case XC_SLIDERBAR:  addr = addr + sizeof( @dt<炫彩滑动条> ); break;
            @ case XC_SCROLLBAR:  addr = addr + sizeof( @dt<炫彩滚动条> ); break;
            @ case XC_TABBAR:  addr = addr + sizeof( @dt<炫彩Tab条> ); break;
            @ case XC_TOOLBAR:  addr = addr + sizeof( @dt<炫彩工具条> ); break;
            @ case XC_SCROLLVIEW:  addr = addr + sizeof( @dt<炫彩滚动视图> ); break;
            @ case XC_DATETIME:  addr = addr + sizeof( @dt<炫彩日期框> ); break;
            @ case XC_MONTHCAL:  addr = addr + sizeof( @dt<炫彩月历框> ); break;
            @ case XC_PANE:  addr = addr + sizeof( @dt<炫彩窗格> ); break;
            @ case XC_PROPERTYGRID:  addr = addr + sizeof( @dt<炫彩属性框> ); break;
            @ case XC_MENU:  addr = addr + sizeof( @dt<炫彩菜单> ); break;
            @ case XC_MENUBAR:  addr = addr + sizeof( @dt<炫彩菜单条> ); break;
            @ case XC_COMBOBOX:  addr = addr + sizeof( @dt<炫彩组合框> ); break;
            @ case XC_LISTVIEW:  addr = addr + sizeof( @dt<炫彩列表视图> ); break;
            @ case  XC_LAYOUT_FRAME:   addr = addr + sizeof( @dt<炫彩布局框架> ); break;
            @ case  XC_TEXTLINK:   addr = addr + sizeof( @dt<炫彩文本链接> ); break;
            @ default:   DebugTrace (FALSE, 0, 0, _T ("S"), "错误:未知类型");    return false;
            @ }
        }
        创建完成 ()
        返回 (真)
    }

    方法 "//创建从内存ZIP" <公开 类型 = 逻辑型 返回值注释 = "返回窗口句柄或布局句柄或元素句柄" 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 视窗文件资源 注释 = "请确认zip文件正确,否则报错">
    参数 布局文件名 <类型 = 文本型 注释 = "布局文件名.如:\"布局文件\\\\layout.xml\"">
    参数 zip密码 <类型 = 文本型 注释 = "zip密码." @默认值 = 空对象>
    参数 父句柄 <类型 = 变整数 注释 = "父对象句柄,窗口句柄或UI元素句柄." @默认值 = 0>
    参数 布局窗口 <类型 = 变整数 注释 = "附加到指定窗口,取窗口句柄()" @默认值 = 0>
    {
        变量 设计内容 <类型 = 文本型 折叠>
        变量 属性名数组 <类型 = 文本数组类>
        变量 属性值数组 <类型 = 文本数组类>
        设计内容 = 取设计内容 ()
        变量 窗口布局文件 <类型 = 文本型 注释 = "取出窗口xml文件" 折叠>
        变量 文本数组 <类型 = 文本数组类 注释 = "取出 组件列表 <组件类型,组件name>">
        变量 index <类型 = 整数>
        变量 count <类型 = 整数>
        // pos = 寻找字符 (设计内容, ',')
        // 删除字符 (设计内容, 0, pos + 1)  // 删除 xcgui 字段
        分割子文本 (设计内容, ",", 文本数组)
        <折叠> 计次循环 (文本数组.取成员数 ())
        {
            变量 文本数组_临时 <类型 = 文本数组类>
            分割子文本 (文本数组.取成员 (取循环索引 ()), ":", 文本数组_临时)

            如果 (2 != 文本数组_临时.取成员数 ())
            {
                返回 (假)
            }
            // 调试输出 (文本数组_临时.取成员 (0), "|", 文本数组_临时.取成员 (1))
            属性名数组.加入成员 (文本数组_临时.取成员 (0))
            属性值数组.加入成员 (文本数组_临时.取成员 (1))

        }
        // 调试输出 ("------------------")
        index = 属性名数组.查找首成员 ("xml")
        <折叠> 如果 (-1 == index)
        {
            调试输出 ("未找到布局文件标签")
            返回 (假)
        }

        窗口布局文件 = 属性值数组.取成员 (index)
        删除部分文本 (窗口布局文件, 0, 1)
        删除字符 (窗口布局文件, 取文本长度 (窗口布局文件) - 1, 1)

        @ @an<CVolMem> memBuf;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
        @ return 0; }
        @ HXCGUI hWindow = XC_LoadLayoutZipMem((void*)memBuf.GetPtr (),(INT)memBuf.GetSize (),@<布局文件名>.GetText (),@<zip密码>.GetText (),(HXCGUI)@<父句柄>,(HWND)@<布局窗口>);
        @ if (!hWindow){
        @   DebugTrace (FALSE, 0, 0, _T ("SSSpS"), L"加载布局文件失败=", @<窗口布局文件>.GetText() ,  L"窗口的句柄 = ",hWindow,L"请检查资源路径是否正确!");
        @  return 0; }

        index = index + 1

        @  vint addr = (vint)this + sizeof( @dt<炫彩可设计类>) ;
        @ ((@dt<炫彩基类>*)addr)->set( (vint)hWindow );
        @ XC_OBJECT_TYPE  xc_type = XObj_GetType(hWindow);
        @ if(XC_WINDOW==xc_type) {
        @      ((@dt<普通窗口>*) addr)->@n<普通窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<普通窗口> );
        @      @< index>++; 
        @ }
        @ if(XC_FRAMEWND==xc_type) {
        @      ((@dt<框架窗口>*) addr)->@n<框架窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<框架窗口> );
        @      @< index>++; 
        @ }
        @ if(XC_MODALWINDOW==xc_type) {
        @      ((@dt<模态窗口>*) addr)->@n<模态窗口.自动注册事件>();
        @      addr = addr + sizeof( @dt<模态窗口> );
        @      @< index>++; 
        @ }

        // 调试输出 ("---绑定变量---------------")
        count = 属性名数组.取成员数 ()
        // 调试输出 ("索引", index, "数量", count)
        循环 (index, count, index, 1)
        {
            变量 value <类型 = 文本型>
            value = 属性值数组.取成员 (index)  // 变量名称
            @ HXCGUI hObj = XC_GetObjectByName(@<value>.GetText());
            // 调试输出 (name, value, "句柄 = ", hObj)
            @ if(!hObj){
            @   DebugTrace (FALSE, 0, 0, _T ("SSSp"), L"绑定变量失败 变量名=",  @<value>.GetText(), L"句柄=", hObj);
            @   return 0; }
            @  xc_type = XObj_GetType (hObj);
            @ if(XC_ERROR==xc_type) return false;
            @ ((@dt<炫彩基类>*) addr)->set( (vint)hObj );
            @  ((@dt<可视对象>*) addr)->@n<可视对象.自动注册事件>();

            @ switch(xc_type){
            @ case  XC_ELE:  addr = addr + sizeof( @dt<基础元素> ); break;
            @ case  XC_ELE_LAYOUT:   addr = addr + sizeof( @dt<炫彩布局> ); break;
            @ case  XC_BUTTON:    addr = addr + sizeof( @dt<炫彩按钮> ); break;
            @ case XC_LISTBOX:  addr = addr + sizeof( @dt<炫彩列表框> ); break;
            @ case XC_LIST:  addr = addr + sizeof( @dt<炫彩列表> ); break;
            @ case XC_SHAPE:  addr = addr + sizeof( @dt<形状基类> ); break;
            @ case XC_SHAPE_TEXT:  addr = addr + sizeof( @dt<形状文本> ); break;
            @ case XC_SHAPE_PICTURE:  addr = addr + sizeof( @dt<形状图片> ); break;
            @ case XC_SHAPE_RECT:  addr = addr + sizeof( @dt<形状矩形> ); break;
            @ case XC_SHAPE_GROUPBOX:  addr = addr + sizeof( @dt<形状组框> ); break;
            @ case XC_SHAPE_GIF:  addr = addr + sizeof( @dt<形状GIF> ); break;
            @ case XC_SHAPE_TABLE:  addr = addr + sizeof( @dt<形状表格> ); break;
            @ case XC_EDIT:  addr = addr + sizeof( @dt<炫彩编辑框> ); break;
            @ case XC_TREE:  addr = addr + sizeof( @dt<炫彩列表树> ); break;
            @ case XC_EDITOR:  addr = addr + sizeof( @dt<炫彩代码框> ); break;
            @ case XC_PROGRESSBAR:   addr = addr + sizeof( @dt<炫彩进度条> ); break;
            @ case XC_SLIDERBAR:  addr = addr + sizeof( @dt<炫彩滑动条> ); break;
            @ case XC_SCROLLBAR:  addr = addr + sizeof( @dt<炫彩滚动条> ); break;
            @ case XC_TABBAR:  addr = addr + sizeof( @dt<炫彩Tab条> ); break;
            @ case XC_TOOLBAR:  addr = addr + sizeof( @dt<炫彩工具条> ); break;
            @ case XC_SCROLLVIEW:  addr = addr + sizeof( @dt<炫彩滚动视图> ); break;
            @ case XC_DATETIME:  addr = addr + sizeof( @dt<炫彩日期框> ); break;
            @ case XC_MONTHCAL:  addr = addr + sizeof( @dt<炫彩月历框> ); break;
            @ case XC_PANE:  addr = addr + sizeof( @dt<炫彩窗格> ); break;
            @ case XC_PROPERTYGRID:  addr = addr + sizeof( @dt<炫彩属性框> ); break;
            @ case XC_MENU:  addr = addr + sizeof( @dt<炫彩菜单> ); break;
            @ case XC_MENUBAR:  addr = addr + sizeof( @dt<炫彩菜单条> ); break;
            @ case XC_COMBOBOX:  addr = addr + sizeof( @dt<炫彩组合框> ); break;
            @ case XC_LISTVIEW:  addr = addr + sizeof( @dt<炫彩列表视图> ); break;
            @ case  XC_LAYOUT_FRAME:   addr = addr + sizeof( @dt<炫彩布局框架> ); break;
            @ case  XC_TEXTLINK:   addr = addr + sizeof( @dt<炫彩文本链接> ); break;
            @ default:   DebugTrace (FALSE, 0, 0, _T ("S"), "错误:未知类型");    return false;
            @ }
        }
        创建完成 ()
        返回 (真)
    }

    方法 创建 <公开 类型 = 逻辑型 注释 = "从文件创建" 折叠 "">
    参数 父句柄 <类型 = 变整数 注释 = "父对象句柄,窗口句柄或UI元素句柄." @默认值 = 0>
    参数 附加窗口 <类型 = 变整数 注释 = "附加到指定窗口,取窗口句柄()" @默认值 = 0>
    {
        变量 设计内容 <类型 = 文本型 折叠>
        变量 文本数组 <类型 = 文本数组类 注释 = "取出 组件列表 <组件类型,组件name>">
        变量 窗口布局文件 <类型 = 文本型>
        变量 index <类型 = 整数 值 = 0>
        变量 count <类型 = 整数 值 = 0>
        设计内容 = 取设计内容 ()
        // 调试输出 (设计内容)
        分割子文本 (设计内容, ",", 文本数组)

        count = 文本数组.取成员数 ()
        如果 (0 == count)
        {
            调试输出 ("设计内容错误")
            返回 (假)
        }

        窗口布局文件 = 文本数组.取成员 (0)
        文本数组.删除成员 (0, 1)
        count = count - 1

        删除部分文本 (窗口布局文件, 0, 1)
        删除字符 (窗口布局文件, 取文本长度 (窗口布局文件) - 1, 1)

        @ HXCGUI hObj = XC_LoadLayout(@<窗口布局文件>.GetText (),(HXCGUI)@<父句柄>,(HWND)@<附加窗口>);
        @ if (!hObj){
        @   DebugTrace (FALSE, 0, 0, _T ("SSSpS"), L"加载布局文件失败=", @<窗口布局文件>.GetText() ,  L"句柄 = ",hObj,L"请检查资源路径是否正确!");
        @  return 0; }
        @  vint addr = (vint)this + sizeof( @dt<炫彩可设计类>) ;

        // 调试输出 ("索引", index, "数量", count)
        循环 (0, count, index, 1)
        {
            变量 value <类型 = 文本型>
            @ if (0 != @<index>){
            value = 文本数组.取成员 (index)  // 绑定名称(name)
            @    hObj = XC_GetObjectByName(@<value>.GetText());
            @    if(!hObj){
            @     DebugTrace (FALSE, 0, 0, _T ("SSSp"), L"绑定变量失败 变量名=",  @<value>.GetText(), L"句柄=", hObj);
            @     return 0; }
            @ }

            @ XC_OBJECT_TYPE xc_type = XObj_GetType (hObj);
            @ if(XC_ERROR==xc_type) return false;
            @ ((@dt<炫彩基类>*) addr)->set( (vint)hObj );
            @  ((@dt<可视对象>*) addr)->@n<可视对象.自动注册事件>();

            @ switch(xc_type){
            @ case  XC_ELE:  addr = addr + sizeof( @dt<基础元素> ); break;
            @ case  XC_ELE_LAYOUT:   addr = addr + sizeof( @dt<炫彩布局> ); break;
            @ case  XC_BUTTON:    addr = addr + sizeof( @dt<炫彩按钮> ); break;
            @ case XC_LISTBOX:  addr = addr + sizeof( @dt<炫彩列表框> ); break;
            @ case XC_LIST:  addr = addr + sizeof( @dt<炫彩列表> ); break;
            @ case XC_SHAPE:  addr = addr + sizeof( @dt<形状基类> ); break;
            @ case XC_SHAPE_TEXT:  addr = addr + sizeof( @dt<形状文本> ); break;
            @ case XC_SHAPE_PICTURE:  addr = addr + sizeof( @dt<形状图片> ); break;
            @ case XC_SHAPE_RECT:  addr = addr + sizeof( @dt<形状矩形> ); break;
            @ case XC_SHAPE_GROUPBOX:  addr = addr + sizeof( @dt<形状组框> ); break;
            @ case XC_SHAPE_GIF:  addr = addr + sizeof( @dt<形状GIF> ); break;
            @ case XC_SHAPE_TABLE:  addr = addr + sizeof( @dt<形状表格> ); break;
            @ case XC_EDIT:  addr = addr + sizeof( @dt<炫彩编辑框> ); break;
            @ case XC_TREE:  addr = addr + sizeof( @dt<炫彩列表树> ); break;
            @ case XC_EDITOR:  addr = addr + sizeof( @dt<炫彩代码框> ); break;
            @ case XC_PROGRESSBAR:   addr = addr + sizeof( @dt<炫彩进度条> ); break;
            @ case XC_SLIDERBAR:  addr = addr + sizeof( @dt<炫彩滑动条> ); break;
            @ case XC_SCROLLBAR:  addr = addr + sizeof( @dt<炫彩滚动条> ); break;
            @ case XC_TABBAR:  addr = addr + sizeof( @dt<炫彩Tab条> ); break;
            @ case XC_TOOLBAR:  addr = addr + sizeof( @dt<炫彩工具条> ); break;
            @ case XC_SCROLLVIEW:  addr = addr + sizeof( @dt<炫彩滚动视图> ); break;
            @ case XC_DATETIME:  addr = addr + sizeof( @dt<炫彩日期框> ); break;
            @ case XC_MONTHCAL:  addr = addr + sizeof( @dt<炫彩月历框> ); break;
            @ case XC_PANE:  addr = addr + sizeof( @dt<炫彩窗格> ); break;
            @ case XC_PROPERTYGRID:  addr = addr + sizeof( @dt<炫彩属性框> ); break;
            @ case XC_MENU:  addr = addr + sizeof( @dt<炫彩菜单> ); break;
            @ case XC_MENUBAR:  addr = addr + sizeof( @dt<炫彩菜单条> ); break;
            @ case XC_COMBOBOX:  addr = addr + sizeof( @dt<炫彩组合框> ); break;
            @ case XC_LISTVIEW:  addr = addr + sizeof( @dt<炫彩列表视图> ); break;
            @ case  XC_LAYOUT_FRAME:   addr = addr + sizeof( @dt<炫彩布局框架> ); break;
            @ case  XC_TEXTLINK:   addr = addr + sizeof( @dt<炫彩文本链接> ); break;
            @ case XC_WINDOW:  addr = addr + sizeof( @dt<普通窗口> ); break;
            @ case XC_FRAMEWND:   addr = addr + sizeof( @dt<框架窗口> ); break;
            @ case XC_MODALWINDOW:  addr = addr + sizeof( @dt<模态窗口> ); break;
            @ default:   DebugTrace (FALSE, 0, 0, _T ("S"), "错误:未知类型");    return false;
            @ }
        }
        创建完成 ()
        返回 (真)
    }

    方法 创建从内存ZIP <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 视窗文件资源 注释 = "当成员变量\"句柄\"不为0时此参数可空,请确认zip文件正确,否则报错" @默认值 = 空资源.空文件>
    参数 布局文件名 <类型 = 文本型 注释 = "当成员变量\"句柄\"不为0时此参数可空,布局文件名.如:\"布局文件\\\\layout.xml\"" @默认值 = 空对象>
    参数 zip密码 <类型 = 文本型 注释 = "zip密码." @默认值 = 空对象>
    参数 父句柄 <类型 = 变整数 注释 = "父对象句柄,窗口句柄或UI元素句柄." @默认值 = 0>
    参数 布局窗口 <类型 = 变整数 注释 = "附加到指定窗口,取窗口句柄()" @默认值 = 0>
    {
        变量 设计内容 <类型 = 文本型 折叠>
        变量 文本数组 <类型 = 文本数组类 注释 = "取出 组件列表 <组件类型,组件name>">
        变量 窗口布局文件 <类型 = 文本型>
        变量 index <类型 = 整数 值 = 0>
        变量 count <类型 = 整数 值 = 0>
        设计内容 = 取设计内容 ()
        // 调试输出 (设计内容)
        分割子文本 (设计内容, ",", 文本数组)

        count = 文本数组.取成员数 ()
        如果 (0 == count)
        {
            调试输出 ("设计内容错误")
            返回 (假)
        }

        窗口布局文件 = 文本数组.取成员 (0)
        文本数组.删除成员 (0, 1)
        count = count - 1

        删除部分文本 (窗口布局文件, 0, 1)
        删除字符 (窗口布局文件, 取文本长度 (窗口布局文件) - 1, 1)
        @ HXCGUI hObj ;
        如果 (句柄 != 0)
        {
            @ hObj = (HXCGUI)@<句柄>;
        }
        否则
        {
            @ @an<CVolMem> memBuf;
            @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
            @ return 0; }
            @ hObj = XC_LoadLayoutZipMem((void*)memBuf.GetPtr (),(INT)memBuf.GetSize (),@<布局文件名>.GetText (),@<zip密码>.GetText (),(HXCGUI)@<父句柄>,(HWND)@<布局窗口>);

        }
        @ if (!hObj){
        @   DebugTrace (FALSE, 0, 0, _T ("SSSpS"), L"加载布局文件失败=", @<窗口布局文件>.GetText() ,  L"句柄 = ",hObj,L"请检查资源路径是否正确!");
        @  return 0; }
        @  vint addr = (vint)this + sizeof( @dt<炫彩可设计类>) ;

        // 调试输出 ("索引", index, "数量", count)
        循环 (0, count, index, 1)
        {
            变量 value <类型 = 文本型>
            @ if (0 != @<index>){
            value = 文本数组.取成员 (index)  // 绑定名称(name)
            @    hObj = XC_GetObjectByName(@<value>.GetText());
            @    if(!hObj){
            @     DebugTrace (FALSE, 0, 0, _T ("SSSp"), L"绑定变量失败 变量名=",  @<value>.GetText(), L"句柄=", hObj);
            @     return 0; }
            @ }

            @ XC_OBJECT_TYPE xc_type = XObj_GetType (hObj);
            @ if(XC_ERROR==xc_type) return false;
            @ ((@dt<炫彩基类>*) addr)->set( (vint)hObj );
            @  ((@dt<可视对象>*) addr)->@n<可视对象.自动注册事件>();

            @ switch(xc_type){
            @ case  XC_ELE:  addr = addr + sizeof( @dt<基础元素> ); break;
            @ case  XC_ELE_LAYOUT:   addr = addr + sizeof( @dt<炫彩布局> ); break;
            @ case  XC_BUTTON:    addr = addr + sizeof( @dt<炫彩按钮> ); break;
            @ case XC_LISTBOX:  addr = addr + sizeof( @dt<炫彩列表框> ); break;
            @ case XC_LIST:  addr = addr + sizeof( @dt<炫彩列表> ); break;
            @ case XC_SHAPE:  addr = addr + sizeof( @dt<形状基类> ); break;
            @ case XC_SHAPE_TEXT:  addr = addr + sizeof( @dt<形状文本> ); break;
            @ case XC_SHAPE_PICTURE:  addr = addr + sizeof( @dt<形状图片> ); break;
            @ case XC_SHAPE_RECT:  addr = addr + sizeof( @dt<形状矩形> ); break;
            @ case XC_SHAPE_GROUPBOX:  addr = addr + sizeof( @dt<形状组框> ); break;
            @ case XC_SHAPE_GIF:  addr = addr + sizeof( @dt<形状GIF> ); break;
            @ case XC_SHAPE_TABLE:  addr = addr + sizeof( @dt<形状表格> ); break;
            @ case XC_EDIT:  addr = addr + sizeof( @dt<炫彩编辑框> ); break;
            @ case XC_TREE:  addr = addr + sizeof( @dt<炫彩列表树> ); break;
            @ case XC_EDITOR:  addr = addr + sizeof( @dt<炫彩代码框> ); break;
            @ case XC_PROGRESSBAR:   addr = addr + sizeof( @dt<炫彩进度条> ); break;
            @ case XC_SLIDERBAR:  addr = addr + sizeof( @dt<炫彩滑动条> ); break;
            @ case XC_SCROLLBAR:  addr = addr + sizeof( @dt<炫彩滚动条> ); break;
            @ case XC_TABBAR:  addr = addr + sizeof( @dt<炫彩Tab条> ); break;
            @ case XC_TOOLBAR:  addr = addr + sizeof( @dt<炫彩工具条> ); break;
            @ case XC_SCROLLVIEW:  addr = addr + sizeof( @dt<炫彩滚动视图> ); break;
            @ case XC_DATETIME:  addr = addr + sizeof( @dt<炫彩日期框> ); break;
            @ case XC_MONTHCAL:  addr = addr + sizeof( @dt<炫彩月历框> ); break;
            @ case XC_PANE:  addr = addr + sizeof( @dt<炫彩窗格> ); break;
            @ case XC_PROPERTYGRID:  addr = addr + sizeof( @dt<炫彩属性框> ); break;
            @ case XC_MENU:  addr = addr + sizeof( @dt<炫彩菜单> ); break;
            @ case XC_MENUBAR:  addr = addr + sizeof( @dt<炫彩菜单条> ); break;
            @ case XC_COMBOBOX:  addr = addr + sizeof( @dt<炫彩组合框> ); break;
            @ case XC_LISTVIEW:  addr = addr + sizeof( @dt<炫彩列表视图> ); break;
            @ case  XC_LAYOUT_FRAME:   addr = addr + sizeof( @dt<炫彩布局框架> ); break;
            @ case  XC_TEXTLINK:   addr = addr + sizeof( @dt<炫彩文本链接> ); break;
            @ case XC_WINDOW:  addr = addr + sizeof( @dt<普通窗口> ); break;
            @ case XC_FRAMEWND:   addr = addr + sizeof( @dt<框架窗口> ); break;
            @ case XC_MODALWINDOW:  addr = addr + sizeof( @dt<模态窗口> ); break;
            @ default:   DebugTrace (FALSE, 0, 0, _T ("S"), "错误:未知类型");    return false;
            @ }
        }
        创建完成 ()
        返回 (真)
    }

    方法 创建从内存ZIP扩展 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 视窗文件资源 注释 = "当成员变量\"句柄\"不为0时此参数可空,请确认zip文件正确,否则报错" @默认值 = 空资源.空文件>
    参数 布局文件名 <类型 = 文本型 注释 = "当成员变量\"句柄\"不为0时此参数可空,布局文件名.如:\"布局文件\\\\layout.xml\"" @默认值 = 空对象>
    参数 名称前缀 <类型 = 文本型 注释 = "给当前布局文件中所有name属性增加前缀，那么name属性值为：前缀+name" @默认值 = 空对象>
    参数 zip密码 <类型 = 文本型 注释 = "zip密码." @默认值 = 空对象>
    参数 父句柄 <类型 = 变整数 注释 = "父对象句柄,窗口句柄或UI元素句柄." @默认值 = 0>
    参数 父窗口句柄 <类型 = 变整数 注释 = "HWND，提供给第三方窗口使用" @默认值 = 0>
    参数 附加窗口 <类型 = 变整数 注释 = "附加到指定窗口,取窗口句柄()" @默认值 = 0>
    {
        变量 设计内容 <类型 = 文本型 折叠>
        变量 文本数组 <类型 = 文本数组类 注释 = "取出 组件列表 <组件类型,组件name>">
        变量 窗口布局文件 <类型 = 文本型>
        变量 index <类型 = 整数 值 = 0>
        变量 count <类型 = 整数 值 = 0>
        设计内容 = 取设计内容 ()
        // 调试输出 (设计内容)
        分割子文本 (设计内容, ",", 文本数组)

        count = 文本数组.取成员数 ()
        如果 (0 == count)
        {
            调试输出 ("设计内容错误")
            返回 (假)
        }

        窗口布局文件 = 文本数组.取成员 (0)
        文本数组.删除成员 (0, 1)
        count = count - 1

        删除部分文本 (窗口布局文件, 0, 1)
        删除字符 (窗口布局文件, 取文本长度 (窗口布局文件) - 1, 1)
        @ HXCGUI hObj ;
        如果 (句柄 != 0)
        {
            @ hObj = (HXCGUI)@<句柄>;
        }
        否则
        {
            @ @an<CVolMem> memBuf;
            @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
            @ return 0; }
            @ hObj = XC_LoadLayoutZipMemEx((void*)memBuf.GetPtr (),(INT)memBuf.GetSize (),@<布局文件名>.GetText (),@<zip密码>.GetText (),@<名称前缀>.GetText (),(HXCGUI)@<父句柄>,(HWND)@<父窗口句柄>,(HWND)@<附加窗口>);
        }
        @ if (!hObj){
        @   DebugTrace (FALSE, 0, 0, _T ("SSSpS"), L"加载布局文件失败=", @<窗口布局文件>.GetText() ,  L"句柄 = ",hObj,L"请检查资源路径是否正确!");
        @  return 0; }
        @  vint addr = (vint)this + sizeof( @dt<炫彩可设计类>) ;

        // 调试输出 ("索引", index, "数量", count)
        循环 (0, count, index, 1)
        {
            变量 value <类型 = 文本型>
            @ if (0 != @<index>){
            value = 文本数组.取成员 (index)  // 绑定名称(name)
            value = 名称前缀 + value
            @    hObj = XC_GetObjectByName(@<value>.GetText());
            @    if(!hObj){
            @     DebugTrace (FALSE, 0, 0, _T ("SSSp"), L"绑定变量失败 变量名=",  @<value>.GetText(), L"句柄=", hObj);
            @     return 0; }
            @ }

            @ XC_OBJECT_TYPE xc_type = XObj_GetType (hObj);
            @ if(XC_ERROR==xc_type) return false;
            @ ((@dt<炫彩基类>*) addr)->set( (vint)hObj );
            @  ((@dt<可视对象>*) addr)->@n<可视对象.自动注册事件>();

            @ switch(xc_type){
            @ case  XC_ELE:  addr = addr + sizeof( @dt<基础元素> ); break;
            @ case  XC_ELE_LAYOUT:   addr = addr + sizeof( @dt<炫彩布局> ); break;
            @ case  XC_BUTTON:    addr = addr + sizeof( @dt<炫彩按钮> ); break;
            @ case XC_LISTBOX:  addr = addr + sizeof( @dt<炫彩列表框> ); break;
            @ case XC_LIST:  addr = addr + sizeof( @dt<炫彩列表> ); break;
            @ case XC_SHAPE:  addr = addr + sizeof( @dt<形状基类> ); break;
            @ case XC_SHAPE_TEXT:  addr = addr + sizeof( @dt<形状文本> ); break;
            @ case XC_SHAPE_PICTURE:  addr = addr + sizeof( @dt<形状图片> ); break;
            @ case XC_SHAPE_RECT:  addr = addr + sizeof( @dt<形状矩形> ); break;
            @ case XC_SHAPE_GROUPBOX:  addr = addr + sizeof( @dt<形状组框> ); break;
            @ case XC_SHAPE_GIF:  addr = addr + sizeof( @dt<形状GIF> ); break;
            @ case XC_SHAPE_TABLE:  addr = addr + sizeof( @dt<形状表格> ); break;
            @ case XC_EDIT:  addr = addr + sizeof( @dt<炫彩编辑框> ); break;
            @ case XC_TREE:  addr = addr + sizeof( @dt<炫彩列表树> ); break;
            @ case XC_EDITOR:  addr = addr + sizeof( @dt<炫彩代码框> ); break;
            @ case XC_PROGRESSBAR:   addr = addr + sizeof( @dt<炫彩进度条> ); break;
            @ case XC_SLIDERBAR:  addr = addr + sizeof( @dt<炫彩滑动条> ); break;
            @ case XC_SCROLLBAR:  addr = addr + sizeof( @dt<炫彩滚动条> ); break;
            @ case XC_TABBAR:  addr = addr + sizeof( @dt<炫彩Tab条> ); break;
            @ case XC_TOOLBAR:  addr = addr + sizeof( @dt<炫彩工具条> ); break;
            @ case XC_SCROLLVIEW:  addr = addr + sizeof( @dt<炫彩滚动视图> ); break;
            @ case XC_DATETIME:  addr = addr + sizeof( @dt<炫彩日期框> ); break;
            @ case XC_MONTHCAL:  addr = addr + sizeof( @dt<炫彩月历框> ); break;
            @ case XC_PANE:  addr = addr + sizeof( @dt<炫彩窗格> ); break;
            @ case XC_PROPERTYGRID:  addr = addr + sizeof( @dt<炫彩属性框> ); break;
            @ case XC_MENU:  addr = addr + sizeof( @dt<炫彩菜单> ); break;
            @ case XC_MENUBAR:  addr = addr + sizeof( @dt<炫彩菜单条> ); break;
            @ case XC_COMBOBOX:  addr = addr + sizeof( @dt<炫彩组合框> ); break;
            @ case XC_LISTVIEW:  addr = addr + sizeof( @dt<炫彩列表视图> ); break;
            @ case  XC_LAYOUT_FRAME:   addr = addr + sizeof( @dt<炫彩布局框架> ); break;
            @ case  XC_TEXTLINK:   addr = addr + sizeof( @dt<炫彩文本链接> ); break;
            @ case XC_WINDOW:  addr = addr + sizeof( @dt<普通窗口> ); break;
            @ case XC_FRAMEWND:   addr = addr + sizeof( @dt<框架窗口> ); break;
            @ case XC_MODALWINDOW:  addr = addr + sizeof( @dt<模态窗口> ); break;
            @ default:   DebugTrace (FALSE, 0, 0, _T ("S"), "错误:未知类型");    return false;
            @ }
        }
        创建完成 ()
        返回 (真)
    }

    方法 创建完成 <公开 注释 = "窗口或布局创建完成" @虚拟方法 = 可覆盖>

    #
}

类 炫彩可设计菜单类 <公开 基础类 = 可设计类 折叠 隐藏值属性 = "0"
        @设计器 = "name = \"炫彩菜单设计器\"\r\ndll_file_name.win32 = \"lib\\win32\\designer_menu.dll\"\r\ndll_file_name.x64 = \"lib\\x64\\designer_menu.dll\"\r\nauto_generate_mark = \"菜单设计器\"">
{
    方法 创建 <公开 类型 = 炫彩菜单 折叠 @禁止流程检查 = 真>
    {
        变量 属性名数组 <类型 = 文本数组类 折叠>
        变量 设计内容 <类型 = 文本型>
        变量 名称 <类型 = 文本型>
        变量 id <类型 = 整数>
        变量 count <类型 = 整数 值 = 0>
        变量 数组个数 <类型 = 整数>
        变量 标识 <类型 = 整数 值 = 0>
        设计内容 = 取设计内容 ()
        分割文本 (设计内容, ",", 属性名数组)
        @ HMENUX XMenu = NULL;
        数组个数 = 属性名数组.取成员数 ()
        如果 (数组个数 > 0)
        {
            @ XMenu = XMenu_Create();
            @  vint addr = (vint)this + sizeof( @dt<炫彩可设计菜单类>) ;
            @ ((@dt<炫彩基类>*)addr)->set( (vint)XMenu );

            计次循环 (数组个数)
            {
                count = 取循环索引 ()
                如果 (count % 2 != 0)
                {
                    id = 文本到整数 (属性名数组.取成员 (count))
                    // 调试输出 ("奇数", count, id)
                }
                否则
                {
                    名称 = 属性名数组.取成员 (count)
                    // 调试输出 ("偶数", count, 名称)
                    如果 (名称 == "-")
                    {
                        标识 = 8  // 分割条
                    }

                }

                如果 (count % 2 != 0 && 名称 != "-")
                {
                    变量 父ID <类型 = 整数>
                    如果 (寻找文本 (名称, ".") != -1)
                    {
                        删除部分文本 (名称, 0, 1)
                        @ XMenu_AddItem(XMenu, @<id>, @<名称>.GetText (), @<父ID>, 0);
                    }
                    否则
                    {
                        @ XMenu_AddItem(XMenu, @<id>, @<名称>.GetText (), 0, 0);
                        父ID = id
                    }

                }
                否则 (名称 == "-" && count % 2 == 0)
                {
                    @ XMenu_AddItem(XMenu, NULL, NULL, 0, @<标识>);
                }

            }
        }
        否则
        {
            调试输出 ("你还没有设计菜单内容哦,请重新设计.否则会出现句柄错误")
        }
        @ return @dt<炫彩菜单>((vint)XMenu);
    }

    #
}
