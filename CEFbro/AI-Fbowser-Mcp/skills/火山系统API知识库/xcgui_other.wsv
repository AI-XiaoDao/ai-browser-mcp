类 炫彩辅助 <公开 折叠 折叠2 @全局类 = 真 @文档 = "category = \"全局函数\"" @禁止创建对象 = 真>
{
    方法 热键_取功能键状态名 <公开 静态 类型 = 文本型 折叠>
    参数 功能键状态 <类型 = 整数>
    {
        变量 功能键文本临时 <类型 = 文本型>
        如果 (功能键状态 == 0)
        {
            功能键文本临时 = ""
        }
        否则 (功能键状态 == 1)
        {
            功能键文本临时 = "Ctrl +"
        }
        否则 (功能键状态 == 2)
        {
            功能键文本临时 = "Shift +"
        }
        否则 (功能键状态 == 4)
        {
            功能键文本临时 = "Alt + "
        }
        否则 (功能键状态 == 位或 (1, 4))
        {
            功能键文本临时 = "Ctrl + Alt + "
        }
        否则 (功能键状态 == 位或 (1, 2))
        {
            功能键文本临时 = "Ctrl + Shift + "
        }
        否则 (功能键状态 == 位或 (2, 4))
        {
            功能键文本临时 = "Shift + Alt + "
        }
        否则 (功能键状态 == 连续位或 (1, 4, 2))
        {
            功能键文本临时 = "Ctrl + Shift + Alt + "

        }
        返回 (功能键文本临时)


    }

    方法 热键_取键名 <公开 静态 类型 = 文本型 折叠>
    参数 键代码 <类型 = 整数>
    {
        变量 键名 <类型 = 文本型>
        如果 (键代码 == 8)
        {
            键名 = "Backspace"
        }
        否则 (键代码 == 9)
        {
            键名 = "Tab"
        }
        否则 (键代码 == 13)
        {
            键名 = "Enter"
        }
        否则 (键代码 == 16)
        {
            键名 = "Shift"
        }
        否则 (键代码 == 17)
        {
            键名 = "Ctrl"
        }
        否则 (键代码 == 18)
        {
            键名 = "Alt"
        }
        否则 (键代码 == 19)
        {
            键名 = "Pause"
        }
        否则 (键代码 == 20)
        {
            键名 = "CapsLock"
        }
        否则 (键代码 == 27)
        {
            键名 = "Esc"
        }
        否则 (键代码 == 32)
        {
            键名 = "Space"
        }
        否则 (键代码 == 33)
        {
            键名 = "PgUp"
        }
        否则 (键代码 == 34)
        {
            键名 = "PgDn"
        }
        否则 (键代码 == 35)
        {
            键名 = "End"
        }
        否则 (键代码 == 36)
        {
            键名 = "Home"
        }
        否则 (键代码 == 37)
        {
            键名 = "←"
        }
        否则 (键代码 == 38)
        {
            键名 = "↑"
        }
        否则 (键代码 == 39)
        {
            键名 = "→"
        }
        否则 (键代码 == 40)
        {
            键名 = "↓"
        }
        否则 (键代码 == 45)
        {
            键名 = "Ins"
        }
        否则 (键代码 == 46)
        {
            键名 = "Del"
        }
        否则 (键代码 >= 48 && 键代码 <= 57)
        {
            键名 = 到文本 ((字符)键代码)
        }
        否则 (键代码 >= 65 && 键代码 <= 90)
        {
            键名 = 到文本 ((字符)键代码)
        }
        否则 (键代码 == 91)
        {
            键名 = "Win"
        }
        否则 (键代码 == 93)
        {
            键名 = "Menu"
        }
        否则 (键代码 >= 96 && 键代码 <= 105)
        {
            键名 = "Num " + 到文本 ((字符)(键代码 - 48))
        }
        否则 (键代码 == 106)
        {
            键名 = "Num *"
        }
        否则 (键代码 == 107)
        {
            键名 = "Num +"
        }
        否则 (键代码 == 109)
        {
            键名 = "Num -"
        }
        否则 (键代码 == 110)
        {
            键名 = "Num ."
        }
        否则 (键代码 == 111)
        {
            键名 = "Num /"
        }
        否则 (键代码 >= 112 && 键代码 <= 123)
        {
            键名 = "F" + 到文本 (12 - (123 - 键代码))
        }
        否则 (键代码 == 144)
        {
            键名 = "NumLock"
        }
        否则 (键代码 == 145)
        {
            键名 = "ScrollLock"
        }
        否则 (键代码 == 174)
        {
            键名 = "AudioVolumeDown"
        }
        否则 (键代码 == 175)
        {
            键名 = "AudioVolumeUp"
        }
        否则 (键代码 == 179)
        {
            键名 = "MediaPlayPause"
        }
        否则 (键代码 == 181)
        {
            键名 = "LaunchMediaPlaye"
        }
        否则 (键代码 == 186)
        {
            键名 = ";"
        }
        否则 (键代码 == 187)
        {
            键名 = "="
        }
        否则 (键代码 == 188)
        {
            键名 = ","
        }
        否则 (键代码 == 189)
        {
            键名 = "-"
        }
        否则 (键代码 == 190)
        {
            键名 = "."
        }
        否则 (键代码 == 191)
        {
            键名 = "/"
        }
        否则 (键代码 == 192)
        {
            键名 = "`"
        }
        否则 (键代码 == 219)
        {
            键名 = "["
        }
        否则 (键代码 == 220)
        {
            键名 = "\\"
        }
        否则 (键代码 == 221)
        {
            键名 = "]"
        }
        否则 (键代码 == 222)
        {
            键名 = "'"
        }
        返回 (键名)

    }

    方法 取虚拟键状态 <公开 静态 类型 = 短整数 注释 = "返回值给出了给定虚拟键的状态,状态如下:" 注释 = "若高序位为1,则键处于DOWN状态，否则为UP状态"
            注释 = "若低序位为1,则键被触发。例如CAPS LOCK键，被找开时将被触发。若低序位置为0，则键被关闭，且不被触发。触发键在键盘上的指示灯，当键被触发时即亮，键不被触发时即灭。"
            返回值注释 = "得到的状态表示按键是按下了还是弹起的,还是状态切换(大小写状态.数字键盘锁状态)" 折叠 折叠2 @嵌入式方法 = "">
    参数 键码 <类型 = 虚拟键码>
    {
        @ ::GetKeyState(@<键码>)
    }

    方法 RGB2ARGB_ <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 RGB颜色 <类型 = 整数>
    参数 透明度 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    {
        @ COLORREF_MAKE2(@<RGB颜色>,(BYTE)@<透明度>) 
    }

    方法 取变量地址_结构体_32 <公开 静态 类型 = 变整数 注释 = "适用32位程序,64位暂时不公开" 折叠 @嵌入式方法 = "">
    参数 数据类型 <@匹配类型 = 所有类型>
    {
        @ (@dt<变整数>)&@<数据类型>+12
        // @ (INT_P)(&@<数据类型>)+12
    }

    方法 指针_取文本长度 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 lpString <类型 = 变整数 注释 = "字符串指针.">
    {
        @ lstrlenW((LPCWSTR)@<lpString>)
    }

    方法 矩形_偏移 <公开 静态 类型 = 矩形_xc 折叠 @输出名 = "OffsetRect">
    参数 rc <类型 = 矩形_xc>
    参数 left <类型 = 整数 @默认值 = 0>
    参数 top <类型 = 整数 @默认值 = 0>
    参数 right <类型 = 整数 @默认值 = 0>
    参数 bottom <类型 = 整数 @默认值 = 0>
    {
        变量 rc2 <类型 = 矩形_xc>
        rc2.左边 = rc.左边 + left
        rc2.顶边 = rc.顶边 + top
        rc2.右边 = rc.右边 + right
        rc2.底边 = rc.底边 + bottom
        返回 (rc2)
    }

    方法 矩形_制矩形 <公开 静态 类型 = 矩形_xc 折叠>
    参数 left <类型 = 整数 @默认值 = 0>
    参数 top <类型 = 整数 @默认值 = 0>
    参数 right <类型 = 整数 @默认值 = 0>
    参数 bottom <类型 = 整数 @默认值 = 0>
    {
        变量 rc2 <类型 = 矩形_xc>
        rc2.左边 = left
        rc2.顶边 = top
        rc2.右边 = right
        rc2.底边 = bottom
        返回 (rc2)
    }

    方法 处理_事件 <公开 静态 类型 = 整数 注释 = "暂时转让控制权,以便让 Windows 操作系统有机会处理其它的如用户键盘或鼠标输入等事件." 注释 = "直到操作系统处理并发送完程序消息队列中的所有事件后,本方法才会返回." 折叠
            折叠2 @禁止流程检查 = 真 "">
    {
        @ MSG nMsg;
        @ while (::PeekMessage (&nMsg, NULL, 0, 0, PM_REMOVE) != 0)//PM_REMOVE   0x0001
        @ {
        // @     @<xxx>=(int)nMsg.message;
        @     ::TranslateMessage(&nMsg);
        @     ::DispatchMessage(&nMsg);
        @ }
        @ return (int)nMsg.wParam;

    }

    方法 消息_循环 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ MSG nMsg={0};
        @ while( IsWindow((HWND)@<窗口句柄>) ) {
        @ if (GetMessageW(&nMsg,NULL,NULL,NULL)==0 ) {
        @ break;
        @ }
        @ else {
        @ ::TranslateMessage(&nMsg);
        @ ::DispatchMessage(&nMsg);
        @  };
        @ };
    }

    方法 程序_延时 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 延时间隔 <类型 = 整数 注释 = "1000毫秒 = 1秒  两个参数留空为无限等待" @默认值 = 0>
    参数 延时单位 <类型 = 整数 注释 = "默认为毫秒  0=毫秒  1=秒  2=分钟  3=小时" @默认值 = 0>
    {
        如果 (延时单位 == 0 && 延时间隔 == 0)
        {
            延时间隔 = 5000 * 60 * 60
            延时单位 = 5000 * 60 * 60
        }
        否则 (延时单位 == 0)
        {
            延时单位 = 1
        }
        否则 (延时单位 == 1)
        {
            延时单位 = 1000
        }
        否则 (延时单位 == 2)
        {
            延时单位 = 1000 * 60
        }
        否则 (延时单位 == 3)
        {
            延时单位 = 1000 * 60 * 60
        }
        @ LARGE_INTEGER Timer = {0};
        @ Timer.QuadPart = -(LONGLONG)(10 * @<延时间隔> * 1000 * @<延时单位>);

        @ HANDLE hTime  = CreateWaitableTimer (0, FALSE, 0);
        @ ::SetWaitableTimer (hTime , &Timer, 0, NULL, NULL, FALSE);
        @ while (::MsgWaitForMultipleObjects (1,&hTime , FALSE,-1, 255)!=0) {
        处理_事件 ()
        @ }
        @ ::CloseHandle (hTime );
        @ hTime =0;
        返回 (真)
    }

    方法 炫彩_取高位 <公开 静态 类型 = 短整数 折叠 @嵌入式方法 = "">
