    参数 压缩包密码 <类型 = 文本型 @默认值 = 空对象>
    参数 x1 <类型 = 整数>
    参数 x2 <类型 = 整数>
    参数 y1 <类型 = 整数>
    参数 y2 <类型 = 整数>
    {
        @ @sn<this>.SetP(XImage_LoadZipAdaptive(@<压缩包文件名>.GetText (), @<文件名>.GetText (), @<压缩包密码>.GetText (), @<x1>, @<x2>, @<y1>, @<y2>))
    }

    方法 加载从内存ZIP <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 视窗文件资源>
    参数 文件名 <类型 = 文本型>
    参数 压缩包密码 <类型 = 文本型 @默认值 = 空对象>
    {
        @ @an<CVolMem> memBuf;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
        @ return false; }
        @ return SetP(XImage_LoadZipMem((void *)memBuf.GetPtr (),(INT)memBuf.GetSize (), @<文件名>.GetText (), @<压缩包密码>.GetText ()));
    }

    方法 加载从内存字节集ZIP <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 字节集类>
    参数 文件名 <类型 = 文本型>
    参数 压缩包密码 <类型 = 文本型 @默认值 = 空对象>
    {
        @ return SetP(XImage_LoadZipMem((void *)@<数据资源>.GetPtr (),(INT)@<数据资源>.GetSize (), @<文件名>.GetText (), @<压缩包密码>.GetText ()));
    }

