        @ rc.right=@<宽度>+@<左边>;
        @ rc.bottom=@<高度>+@<顶边>;
        @ XDraw_DrawTextUnderlineF(GetP(), @<文本>.GetText (), @<文本>.GetLength (), &rc, COLORREF_MAKE2(@<下划线颜色>, (BYTE)@<透明度>));
    }

