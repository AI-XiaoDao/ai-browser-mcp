    方法 项模板_加载从字符串 <公开 静态 类型 = 变整数 返回值注释 = "返回模板句柄" 折叠 @禁止流程检查 = 真>
    参数 类型 <类型 = 整数 注释 = "项模板类型.***(项模板类型.组合_**不可用)">
    参数 XML文件 <类型 = 文本型 注释 = "字符串指针.">
    {
        @ @an<CVolMem> memBuf1;
        @ INT_P npResultTextLength1;
        @ const CHAR* ps = GetMbsText (@<XML文件>.GetText (), memBuf1, &npResultTextLength1);
        @ return (INT_P)XTemp_LoadFromString((listItemTemp_type_)@<类型>, ps);
    }

    方法 项模板_加载从字符串扩展 <公开 静态 返回值注释 = "如果成功返回TRUE,否则返回FALSE." 折叠 @禁止流程检查 = 真>
    参数 类型 <类型 = 整数 注释 = "项模板类型.组合_**">
    参数 XML文件 <类型 = 文本型 注释 = "字符串内容">
    参数 模板句柄1 <类型 = 变整数 注释 = "返回模板句柄1, 项模板" @视窗.后缀文本 = "&">
    参数 模板句柄2 <类型 = 变整数 注释 = "返回模板句柄2, 列表头模板或列表视组模板" @视窗.后缀文本 = "&">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const CHAR* ps = GetMbsText (@<XML文件>.GetText (), memBuf, &npResultTextLength);
        // @ HTEMP pOutTemp1, pOutTemp2;
        @ BOOL hr = XTemp_LoadFromStringEx((listItemTemp_type_)@<类型>,ps,(HTEMP*)&@<模板句柄1>,(HTEMP*)&@<模板句柄2>);
        // @ WRITE_POINTER_NUMBER (@<模板句柄1>, INT_P, pOutTemp1);
        // @ WRITE_POINTER_NUMBER (@<模板句柄2>, INT_P, pOutTemp2);
        @ return hr;
    }

