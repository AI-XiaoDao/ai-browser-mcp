类 炫彩动画 <公开 基础类 = 动画基类 折叠>
{
    方法 创建 <公开 类型 = 逻辑型 返回值注释 = "按顺序执行的动画列表" 折叠 @嵌入式方法 = "">
    参数 对象句柄 <类型 = 变整数 注释 = "绑定的UI对象, UI对象句柄: 窗口句柄,元素句柄,形状句柄,SVG句柄">
    参数 次数 <类型 = 整数 注释 = "动画循环次数, 0:无限循环">
    {
        @ @sn<this>.SetP(XAnima_Create((HXCGUI)@<对象句柄>,@<次数>))
    }
}

类 炫彩动画组 <公开 基础类 = 动画基类 折叠>
{
    方法 创建组 <公开 类型 = 逻辑型 返回值注释 = "动画同步组, 当组中动画序列全部完成后, 重新开始; 当遇到无限循环项时,直至其他序列完成后终止循环,避免出现无法到达终点,无法返回头部进行同步" 折叠 @嵌入式方法 = "">
    参数 次数 <类型 = 整数 注释 = "动画循环次数, 0:无限循环">
    {
        @ @sn<this>.SetP(XAnimaGroup_Create(@<次数>))
    }

    方法 添加项 <公开 折叠 @嵌入式方法 = "">
    参数 动画序列句柄 <类型 = 变整数 注释 = "创建()方法创建的句柄">
    {
        @ XAnimaGroup_AddItem(@sn<this>.GetP (), (HXCGUI)@<动画序列句柄>)
    }
}

类 炫彩动画回调 <公开 折叠>
{
    变量 "//对象自身指针" <静态 类型 = 变整数>

    方法 "//类_初始化" <折叠>
    {
        对象自身指针 = 本对象.取对象自身指针 ()
    }

    方法 "//类_销毁" <折叠>
    {
        对象自身指针 = 0

