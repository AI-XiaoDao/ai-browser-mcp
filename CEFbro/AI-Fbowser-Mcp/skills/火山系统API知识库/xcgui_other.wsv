<火山程序 类型 = "通常" 版本 = 1 />

包 xc.gui <注释 = "" 注释 = "" 注释 = "" 注释 = "" 注释 = "" 注释 = "" 注释 = "静态库需要单独购买,请放到模块目录.如下"
        注释 = "XCGUI\\lib\\win32(x64)=放32位/放64位" 注释 = "其他依赖文件XCGUI\\lib\\win32(x64)\\lib下面" 折叠2 @视窗.附属文件 = "lib\\$(p)\\XCGUI.dll"
        @视窗.外部库 = "lib\\$(p)\\XCGUI.lib" @视窗.库文件搜寻目录 = "lib\\$(p)" @视窗.外部头文件 = "lib\\vol_xcgui.h"
        "@视窗.外部头文件.全局-886" = "lib\\xcgui.h" @视窗.外部头文件 = "lib\\wke.h" "//@视窗.外部库.release" = "lib\\$(p)\\XCGUI-3.3.8-vs2019-MT.lib"
        "//@视窗.外部库.release-x64" = "lib\\$(p)\\XCGUI-3.3.8-vs2019-MT.lib" @文档 = "category = \"辅助函数\"">

类 guibase <折叠>
{

    # //@begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CXImage)
    # <> <include>
    # public:
    #     inline_ HIMAGE GetP()     { 
    #         HIMAGE hImage = data().GetPtr();
    #         ASSERT(hImage != NULL); //下断言
    #         return hImage;
    #     }
    #     inline_ BOOL SetP(HIMAGE hImage)  { return data().SetPtr(hImage);  }
    # <> </include>
    # //用作定义CXImage子类.
    # @def_macro DECLARE_XCGUI_CLASS(vol_wrapper_class, cx_class_name)                  \
    #     @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (vol_wrapper_class)                      \
    # <>     <include>                                                                       \
    #     inline_ cx_class_name Get##cx_class_name() { return data().GetPtr(); }    \
    #     inline_ BOOL Set##cx_class_name(cx_class_name hName)  { return data().SetPtr(hName);  }   \
    # <>  </include>
    # //@end
    # @begin
    # @def_macro DECLARE_YTXXCGUI_CLASS(vol_wrapper_class, ytx_class_name)                  \
    #     @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (vol_wrapper_class)                      \
    # <>     <include>                                                                       \
    #     virtual ytx_class_name GetP()  { return Get##ytx_class_name(); }         \  //virtual 虚函数  inline_ 内联
    #     inline_ ytx_class_name Get##ytx_class_name() { return data().GetPtr(); }    \
    #     virtual BOOL SetP(ytx_class_name ptr)  { return Set##ytx_class_name(ptr); }         \
    #     inline_  BOOL Set##ytx_class_name(ytx_class_name ptr) { return data().SetPtr(ptr); }    \
    # <>     </include>
    # @end

    方法 句柄 <公开 属性读 类型 = 变整数 注释 = "取句柄" @嵌入式方法 = "">
    {
        @ (@dt<变整数>)@sn<this>.GetP()
    }
}

类 炫彩背景管理器 <公开 基础类 = guibase 折叠>
{

    # @ @m<guibase.DECLARE_YTXXCGUI_CLASS>(CXHBKM, HBKM)
    # @begin
    # <> <include>
    # public:
    # //构造函数  可以用于 强转 @dt<炫彩背景管理器>
    #     inline_ @sn<current_class>(HBKM hBkInfoM):@sn<current_class>()    {
    #         data().SetPtr(hBkInfoM);  
    #     }
    # <>  </include>
    # @end

    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 管理器句柄 <类型 = 变整数>
    {
        @ SetP((HBKM)@<管理器句柄>);
    }

    方法 添加边框 <公开 折叠 @嵌入式方法 = "">
    参数 状态 <类型 = 整数 注释 = "组合状态.***">
    参数 颜色 <类型 = 整数 "">
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    参数 线宽 <类型 = 整数 @默认值 = 1>
    参数 ID <类型 = 整数 注释 = " 背景对象ID, 可忽略(0)" @默认值 = 0>
    {
        @ XBkM_AddBorder(@sn<this>.GetP(), @<状态>, COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>), @<线宽>,@<ID>)
    }

    方法 添加填充 <公开 折叠 @嵌入式方法 = "">
    参数 状态 <类型 = 整数 注释 = "组合状态.***">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    参数 ID <类型 = 整数 注释 = " 背景对象ID, 可忽略(0)" @默认值 = 0>
    {
        @ XBkM_AddFill(@sn<this>.GetP(), @<状态>, COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>),@<ID>)
    }

    方法 添加图片 <公开 折叠 @嵌入式方法 = "">
    参数 状态 <类型 = 整数 注释 = "组合状态.***">
    参数 图片对象 <类型 = 炫彩图片>
    参数 ID <类型 = 整数 注释 = " 背景对象ID, 可忽略(0)" @默认值 = 0>
    {
        @ XBkM_AddImage(@sn<this>.GetP(), @<状态>, @<图片对象>.GetP(),@<ID>)
    }

    方法 添加内容 <公开 类型 = 整数 返回值注释 = "返回添加的背景对象数量." 折叠 @嵌入式方法 = "">
    参数 内容 <类型 = 文本型 注释 = "内容 是设计器编辑好的 字符串">
    {
        @ XBkM_AddInfo(@sn<this>.GetP(), @<内容>.GetText ())
    }

    方法 增加引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XBkM_AddRef(@sn<this>.GetP())
    }

    方法 清空 <公开 折叠 @嵌入式方法 = "">
    {
        @ XBkM_Clear(@sn<this>.GetP());
    }

    方法 创建 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.SetP (XBkM_Create())
    }

    方法 销毁 <公开 折叠 @嵌入式方法 = "">
    {
        @ XBkM_Destroy(@sn<this>.GetP())
    }

    方法 绘制 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 组合状态 <类型 = 整数 注释 = "组合状态.***">
    参数 绘图对象 <类型 = 炫彩绘图>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ RECT rc;
        @ rc.left=@<左边>;
        @ rc.top=@<顶边>;
        @ rc.right=@<宽度>+@<左边>;
        @ rc.bottom=@<高度>+@<顶边>;
        @ return XBkM_Draw(GetP(), @<组合状态>, @<绘图对象>.GetP(), &rc);
    }

    方法 绘制扩展 <公开 类型 = 逻辑型 注释 = "例如用来绘制列表项时, nState中包含项的状态(nStateEx)才会绘制,避免列表项与元素背景叠加." 返回值注释 = "成功返回TRUE否则返回FALSE." 折叠
            @禁止流程检查 = 真>
    参数 组合状态 <类型 = 整数 注释 = "组合状态.***">
    参数 绘制句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 组合状态扩展 <类型 = 整数 注释 = "当(组合状态)中包含(组合状态扩展)中的一个或多个状态时有效.">
    {
        @ RECT rc;
        @ rc.left=@<左边>;
        @ rc.top=@<顶边>;
        @ rc.right=@<宽度>+@<左边>;
        @ rc.bottom=@<高度>+@<顶边>;
        @ return XBkM_DrawEx(GetP(), @<组合状态>, (HDRAW)@<绘制句柄>, &rc, @<组合状态扩展>);
    }

    方法 启用自动销毁 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XBkM_EnableAutoDestroy(@sn<this>.GetP(), @<是否启用>)
    }

    方法 取数量 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XBkM_GetCount(@sn<this>.GetP())
    }

    方法 取引用计数 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XBkM_GetRefCount(@sn<this>.GetP())
    }

    方法 释放引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XBkM_Release(@sn<this>.GetP())
    }

    方法 置内容 <公开 类型 = 整数 返回值注释 = "返回设置的背景对象数量" 折叠 @嵌入式方法 = "">
    参数 内容 <类型 = 文本型 注释 = "背景内容字符串,由设计器生成">
    {
        @ XBkM_SetBkInfo(@sn<this>.GetP(), @<内容>.GetText ())
    }

    方法 取状态文本颜色 <公开 折叠 @嵌入式方法 = "">
    参数 状态 <类型 = 整数 注释 = "组合状态.***">
    参数 颜色 <类型 = 整数 注释 = "返回颜色">
    {
        @ COLORREF color;
        @ XBkM_GetStateTextColor(@sn<this>.GetP(), @<状态>, &color);
        @ @<颜色> = (INT)color;
    }

    方法 取对象 <公开 类型 = 变整数 返回值注释 = "返回对象句柄" 折叠 @嵌入式方法 = "">
    参数 背景对象ID <类型 = 整数>
    {
        @ (INT_P)XBkM_GetObject(@sn<this>.GetP(), @<背景对象ID>)
    }
}

类 炫彩背景对象 <公开 折叠 折叠2 @文档 = "category = \"全局函数\"" @禁止创建对象 = 真 @全局类 = 真>
{
    方法 背景对象_启用边框 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 是否启用 <类型 = 逻辑型 "">
    {
        @ XBkObj_EnableBorder( (vint)@<背景对象句柄>, @<是否启用>)
    }

    方法 背景对象_启用填充 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 是否启用 <类型 = 逻辑型 "">
    {
        @ XBkObj_EnableFill( (vint)@<背景对象句柄>, @<是否启用>)
    }

    方法 背景对象_取对齐 <公开 静态 类型 = 整数 返回值注释 = "返回背景对象对齐方式" 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ XBkObj_GetAlign( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取边框色 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT)XBkObj_GetBorderColor( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取边框宽度 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT)XBkObj_GetBorderWidth( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取填充色 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT)XBkObj_GetFillColor( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取字体 <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT_P)XBkObj_GetFont( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取图片 <公开 静态 类型 = 炫彩图片 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ @dt<炫彩图片>(XBkObj_GetImage( (vint)@<背景对象句柄>))
    }

    方法 背景对象_取外间距 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 边框大小 <类型 = 边框大小_xc 注释 = "返回">
    {
        @ XBkObj_GetMargin( (vint)@<背景对象句柄>,@<边框大小>.pdata())
    }

    方法 背景对象_取矩形圆角 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 矩形 <类型 = 矩形_xc 注释 = "返回">
    {
        @ XBkObj_GetRectRoundAngle( (vint)@<背景对象句柄>,@<矩形>.pdata())
    }

    方法 背景对象_取旋转角度 <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT)XBkObj_GetRotate( (vint)@<背景对象句柄>)
    }

    方法 背景对象_取文本 <公开 静态 类型 = 文本型 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ @an<CVolString>(XBkObj_GetText( (vint)@<背景对象句柄>))
    }

    方法 背景对象_取文本对齐 <公开 静态 类型 = 整数 返回值注释 = "返回文本标识.对齐_" 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ (INT)XBkObj_GetTextAlign( (vint)@<背景对象句柄>)
    }

    方法 背景对象_是否边框 <公开 静态 类型 = 逻辑型 返回值注释 = "绘制边框返回TRUE,否则返回FALSE" 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ XBkObj_IsBorder( (vint)@<背景对象句柄>)
    }

    方法 背景对象_是否填充 <公开 静态 类型 = 逻辑型 返回值注释 = "填充返回TRUE,否则返回FALSE" 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    {
        @ XBkObj_IsFill( (vint)@<背景对象句柄>)
    }

    方法 背景对象_置对齐 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 对齐方式 <类型 = 整数 注释 = "背景对象对齐方式.**">
    {
        @ XBkObj_SetAlign( (vint)@<背景对象句柄>,@<对齐方式>)
    }

    方法 背景对象_置边框颜色 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XBkObj_SetBorderColor((vint)@<背景对象句柄>,COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 背景对象_置边框宽度 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 宽度 <类型 = 整数>
    {
        @ XBkObj_SetBorderWidth( (vint)@<背景对象句柄>,@<宽度>)
    }

    方法 背景对象_置填充颜色 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XBkObj_SetFillColor((vint)@<背景对象句柄>,COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 背景对象_置字体 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 字体句柄 <类型 = 变整数>
    {
        @ XBkObj_SetFont( (vint)@<背景对象句柄>,(HFONTX)@<字体句柄>)
    }

    方法 背景对象_置图片 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 图片对象 <类型 = 炫彩图片>
    {
        @ XBkObj_SetImage( (vint)@<背景对象句柄>,@<图片对象>.GetP())
    }

    方法 背景对象_置外间距 <公开 静态 注释 = "外间距与背景对象对齐标识互相依赖" 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    {
        @ XBkObj_SetMargin( (vint)@<背景对象句柄>,@<左边>,@<顶边>,@<右边>,@<底边>)
    }

    方法 背景对象_置矩形圆角 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 左上角 <类型 = 整数>
    参数 左下角 <类型 = 整数>
    参数 右上角 <类型 = 整数>
    参数 右下角 <类型 = 整数>
    {
        @ XBkObj_SetRectRoundAngle( (vint)@<背景对象句柄>,@<左上角>,@<左下角>,@<右上角>,@<右下角>)
    }

    方法 背景对象_置旋转 <公开 静态 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 旋转角度 <类型 = 单精度小数>
    {
        @ XBkObj_SetRotate( (vint)@<背景对象句柄>,@<旋转角度>)
    }

    方法 背景对象_置文本 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 文本 <类型 = 文本型>
    {
        @ XBkObj_SetText( (vint)@<背景对象句柄>,@<文本>.GetText ())
    }

    方法 背景对象_置文本对齐 <公开 静态 折叠 @嵌入式方法 = "">
    参数 背景对象句柄 <类型 = 变整数>
    参数 文本对齐 <类型 = 整数 注释 = "文本标识.对齐_">
    {
        @ XBkObj_SetTextAlign( (vint)@<背景对象句柄>,@<文本对齐>)
    }
}

类 "//炫彩图片源" <公开 基础类 = guibase 注释 = "未开放功能" 折叠>
{

    # @ @m<guibase.DECLARE_YTXXCGUI_CLASS>(CXImage, HIMAGE)

    方法 句柄 <公开 属性写 注释 = "置句柄" 折叠 @禁止流程检查 = 真>
    参数 图片句柄 <类型 = 变整数>
    {
        // @ if (GetP () != NULL){
        // @ XImage_Release(GetP()); }//释放
        @ SetP((HIMAGE)@<图片句柄>);
    }

    方法 增加引用计数 <公开 折叠 @嵌入式方法 = "">
    {
        @ XImgSrc_AddRef(@sn<this>.GetP())
    }

    方法 销毁 <公开 折叠 @嵌入式方法 = "">
    {
        @ XImgSrc_Destroy(@sn<this>.GetP())
    }

    方法 启用自动销毁 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XImgSrc_EnableAutoDestroy(@sn<this>.GetP(), @<是否启用>)
    }

    方法 取文件名 <公开 类型 = 文本型 返回值注释 = "返回文件名" 折叠 @嵌入式方法 = "">
    {
        @ XImgSrc_GetFile(@sn<this>.GetP())
    }

    方法 取高度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
