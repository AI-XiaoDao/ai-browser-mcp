<火山程序 类型 = "通常" 版本 = 1 />

包 星火.zlib

类 zlib <公开 @视窗.预定义宏 = "ZLIB_WINAPI" @视窗.头文件搜寻目录 = "zlib\\include" @视窗.外部头文件 = "zlib.h"
