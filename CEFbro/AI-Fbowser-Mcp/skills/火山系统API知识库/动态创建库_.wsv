类 动态超级列表框类_ <公开 折叠 @文档 = "category = \"动态创建库.独立组件创建\"">
{
    变量 动态超级列表框 <类型 = 对象数组类>
    变量 超级列表框标记 <类型 = 整数类>
    变量 参考超级列表框 <类型 = 超级列表框>

    方法 创建超级列表框 <公开 类型 = 超级列表框 折叠 "">
    参数 父窗口 <类型 = 窗口容器组件 编辑时信息 = "FBBAC, 0, 0, 0">
    参数 左边位置 <类型 = 整数 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = 10>
    参数 顶边位置 <类型 = 整数 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = 10>
    参数 宽度 <类型 = 整数 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = 240>
    参数 高度 <类型 = 整数 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = 200>
    参数 类型 <类型 = 整数 注释 = "1、报表列表　2、普通列表　3、小图标列表　4、大图标列表" 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = 1>
    参数 无表头 <类型 = 逻辑型 @默认值 = 假>
    参数 表头内容 <类型 = 文本型 注释 = "如： \"列1,列2,列3\"　；多个以逗号间开，支持中文标点" 编辑时信息 = "FBBAC, 0, 0, 0" @默认值 = "">
    参数 表头列宽 <类型 = 文本型 注释 = "如： \"50,70,80\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 允许编辑 <类型 = 逻辑型 @默认值 = 真>
    参数 显示表格线 <类型 = 逻辑型 @默认值 = 真>
    参数 整行选择 <类型 = 逻辑型 @默认值 = 真>
    参数 始终显示选择项 <类型 = 逻辑型 @默认值 = 真>
    参数 是否有检查框 <类型 = 逻辑型 @默认值 = 假>
    {
        动态超级列表框.加入并返回新成员2 (超级列表框, 0, 超级列表框标记)
        参考超级列表框 = (超级列表框)动态超级列表框.取成员 (超级列表框标记.值)
        如果 (类型 == 1)
        {
            参考超级列表框.类型 = 列表框类型.报表列表框
        }
        否则 (类型 == 2)
        {
            参考超级列表框.类型 = 列表框类型.普通列表框
        }
        否则 (类型 == 3)
        {
            参考超级列表框.类型 = 列表框类型.小图标列表框
        }
        否则
        {
            参考超级列表框.类型 = 列表框类型.大图标列表框
        }
        参考超级列表框.允许编辑 = 允许编辑
        参考超级列表框.显示表格线 = 显示表格线
        参考超级列表框.整行选择 = 整行选择
        参考超级列表框.始终显示选择项 = 始终显示选择项
        参考超级列表框.是否有检查框 = 是否有检查框
        参考超级列表框.无表头 = 无表头
        如果 (表头内容 == "")
        {
            参考超级列表框.报表列 = "0\n-1\n0\n40\n列1\n0\n-1\n0\n100\n列2"
        }
        否则
        {
            变量 数据包 <类型 = 文本型>
            变量 标记1 <类型 = 文本型 值 = "0\n-1\n0\n">
            变量 标记2 <类型 = 文本型 值 = "\n">
            变量 标题组 <类型 = 文本数组类>
            变量 宽度组 <类型 = 文本数组类>
            子文本替换 (表头内容, "，", ",")
            子文本替换 (表头列宽, "，", ",")
            分割文本 (表头内容, ",", 标题组)
            分割文本 (表头列宽, ",", 宽度组)
            如果 (标题组.取成员数 () == 宽度组.取成员数 ())
            {
                计次循环 (标题组.取成员数 ())
                {
                    数据包 = 数据包 + 标记1 + 宽度组.取成员 (取循环索引 ()) + 标记2 + 标题组.取成员 (取循环索引 ()) + 标记2
                }
            }
            否则
            {
                计次循环 (标题组.取成员数 ())
                {
                    数据包 = 数据包 + 标记1 + "50" + 标记2 + 标题组.取成员 (取循环索引 ()) + 标记2
                }
            }
            参考超级列表框.报表列 = 数据包
        }
        参考超级列表框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考超级列表框)
    }

    方法 销毁对象_超级列表框 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态超级列表框.删除成员 (对象序)
    }
}

