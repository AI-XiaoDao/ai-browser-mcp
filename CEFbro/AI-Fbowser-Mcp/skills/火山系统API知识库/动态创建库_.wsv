类 动态编辑框类_ <公开 折叠 @文档 = "category = \"动态创建库.独立组件创建\"">
{
    变量 动态编辑框 <类型 = 对象数组类>
    变量 编辑框标记 <类型 = 整数类>
    变量 参考编辑框 <类型 = 编辑框>

    方法 创建编辑框 <公开 类型 = 编辑框 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 内容 <类型 = 文本型 @默认值 = "">
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 80>
    参数 高度 <类型 = 整数 @默认值 = 24>
    参数 允许多行 <类型 = 逻辑型 @默认值 = 假>
    参数 滚动条 <类型 = 整数 注释 = "0、无　1、横向　2、纵向　3、横向纵向" @默认值 = 0>
    参数 调节器方式 <类型 = 整数 注释 = "0、无　1、手动　2、自动" @默认值 = 0>
    参数 对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　3、右对齐" @默认值 = 0>
    参数 输入方式 <类型 = 编辑框输入方式 注释 = "例如：编辑框输入方式.通常方式" @默认值 = 编辑框输入方式.通常方式>
    {
        动态编辑框.加入并返回新成员2 (编辑框, 0, 编辑框标记)
        参考编辑框 = (编辑框)动态编辑框.取成员 (编辑框标记.值)
        参考编辑框.内容 = 内容
        参考编辑框.是否允许多行 = 允许多行
        如果 (调节器方式 == 1)
        {
            参考编辑框.调节器方式 = 编辑框调节器方式.手动调节器
        }
        否则 (调节器方式 == 2)
        {
            参考编辑框.调节器方式 = 编辑框调节器方式.自动调节器
        }
        如果 (滚动条 == 1)
        {
            参考编辑框.滚动条 = 滚动条类型.横向滚动条
        }
        否则 (滚动条 == 2)
        {
            参考编辑框.滚动条 = 滚动条类型.纵向滚动条
        }
        否则 (滚动条 == 3)
        {
            参考编辑框.滚动条 = 滚动条类型.横向及纵向滚动条
        }
        如果 (对齐方式 == 0)
        {
            参考编辑框.对齐方式 = 横向对齐模式.左边
        }
        否则 (对齐方式 == 1)
        {
            参考编辑框.对齐方式 = 横向对齐模式.居中
        }
        否则 (对齐方式 == 2)
        {
            参考编辑框.对齐方式 = 横向对齐模式.右边
        }
        参考编辑框.输入方式 = 输入方式
        参考编辑框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考编辑框)
    }

    方法 销毁对象_编辑框 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态编辑框.删除成员 (对象序)
    }
}

