    方法 创建工具条 <公开 类型 = 工具条 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 120>
    参数 高度 <类型 = 整数 @默认值 = 35>
    参数 按钮标题 <类型 = 文本型 注释 = "如： \"新建：,打开,保存\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 图标序 <类型 = 文本型 注释 = "如： \"0,1,2\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 提示文本 <类型 = 文本型 注释 = "如： \"提示1,提示2,提示3\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 插入分隔符 <类型 = 文本型 注释 = "如： \"1,3,4\"　；数字表示分隔符将要插入到的标题序位置；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 图片组 <类型 = 图片组资源>
    参数 位置 <类型 = 整数 注释 = "1、顶边　2、自由　3、底边" @默认值 = 2>
    {
        动态工具条.加入并返回新成员2 (工具条, 0, 工具条标记)
        参考工具条 = (工具条)动态工具条.取成员 (工具条标记.值)
        如果 (位置 == 1)
        {
            参考工具条.位置 = 工具条位置.顶边
        }
        否则 (位置 == 2)
        {
            参考工具条.位置 = 工具条位置.自由
        }
        否则
        {
            参考工具条.位置 = 工具条位置.底边
        }
        如果 (按钮标题 == "")
        {
            参考工具条.工具条按钮 = "0\n4\n0\n新建\n新建\n1\n4\n0\n打开\n打开\n-1\n4\n1\n\n\n2\n4\n0\n保存\n保存\n"
        }
        否则
        {
            变量 数据包 <类型 = 文本型>
            变量 标记1 <类型 = 文本型 值 = "\n4\n0\n">
            变量 标记2 <类型 = 文本型 值 = "\n">
            变量 标记3 <类型 = 文本型 值 = "\n-1\n4\n1\n\n\n">
            变量 标题组 <类型 = 文本数组类>
            变量 图标组 <类型 = 文本数组类>
            变量 提示组 <类型 = 文本数组类>
            子文本替换 (按钮标题, "，", ",")
            子文本替换 (图标序, "，", ",")
            子文本替换 (提示文本, "，", ",")
            分割文本 (按钮标题, ",", 标题组)
            分割文本 (图标序, ",", 图标组)
            分割文本 (提示文本, ",", 提示组)
            如果真 (标题组.取成员数 () == 提示组.取成员数 () && 标题组.取成员数 () == 图标组.取成员数 ())
            {
                计次循环 (标题组.取成员数 ())
                {
                    如果 (寻找文本 (插入分隔符, 到文本 (取循环索引 () + 1)) != -1)
                    {
                        数据包 = 数据包 + 图标组.取成员 (取循环索引 ()) + 标记1 + 标题组.取成员 (取循环索引 ()) + 标记2 + 提示组.取成员 (取循环索引 ()) + 标记3
                    }
                    否则
                    {
                        数据包 = 数据包 + 图标组.取成员 (取循环索引 ()) + 标记1 + 标题组.取成员 (取循环索引 ()) + 标记2 + 提示组.取成员 (取循环索引 ()) + 标记2
                    }
                }
                参考工具条.工具条按钮 = 数据包
            }
        }
        参考工具条.图片组 = 图片组
        参考工具条.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        参考工具条.标题 = "工具条" + 到文本 (工具条标记.值 + 1)
        返回 (参考工具条)
    }

