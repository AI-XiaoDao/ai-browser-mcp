    方法 创建主窗口 <公开 类型 = 窗口 注释 = "变量 窗口模版" 注释 = "窗口1 = 窗口模版.创建主窗口 ()" 注释 = "如需触发窗口可否被关闭，则需要 挂接事件 (窗口1)" 折叠 折叠2>
    参数 标题 <类型 = 文本型 @默认值 = "主窗口">
    参数 宽度 <类型 = 整数 @默认值 = 500>
    参数 高度 <类型 = 整数 @默认值 = 300>
    {
        窗口模版.创建主窗口 (, , 宽度, 高度)
        窗口模版.标题 = 标题
        返回 (窗口模版)
    }

    方法 创建子窗口 <公开 类型 = 窗口 注释 = "变量 窗口模版" 注释 = "窗口1 = 窗口模版.创建子窗口 ()" 注释 = "如需触发窗口可否被关闭，则需要 挂接事件 (窗口1)" 折叠 折叠2>
    参数 父窗口 <类型 = 窗口>
    参数 标题 <类型 = 文本型 @默认值 = "子窗口">
    参数 宽度 <类型 = 整数 @默认值 = 500>
    参数 高度 <类型 = 整数 @默认值 = 300>
    {
        窗口模版2.创建子窗口 (父窗口, , , 宽度, 高度)
        窗口模版2.标题 = 标题
        返回 (窗口模版2)
    }

    方法 创建对话框窗口 <公开 类型 = 窗口 注释 = "变量 窗口模版" 注释 = "窗口1 = 窗口模版.创建对话框窗口 ()" 注释 = "如需触发窗口可否被关闭，则需要 挂接事件 (窗口1)" 折叠 折叠2>
    参数 标题 <类型 = 文本型 @默认值 = "对话框窗口">
    参数 宽度 <类型 = 整数 @默认值 = 500>
    参数 高度 <类型 = 整数 @默认值 = 300>
    {
        窗口模版3.标题 = 标题
        窗口模版3.创建对话框 (, , , 宽度, 高度)
        返回 (窗口模版3)
    }

    方法 创建按钮 <公开 类型 = 按钮 注释 = "调用示例：" 注释 = "按钮1 = 动态类.创建按钮 (本对象)" 注释 = "按钮组.标题 = \"按钮1\"" 注释 = "动态类.销毁对象_按钮 (组序)" 折叠 折叠2>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 标题 <类型 = 文本型 @默认值 = "">
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 80>
    参数 高度 <类型 = 整数 @默认值 = 32>
    {
        动态按钮.加入并返回新成员2 (按钮, 0, 按钮标记)
        参考按钮 = (按钮)动态按钮.取成员 (按钮标记.值)
        如果真 (标题 == "")
        {
            标题 = "按钮" + 到文本 (按钮标记.值 + 1)
        }
        参考按钮.标题 = 标题
        参考按钮.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考按钮)
    }

    方法 销毁对象_按钮 <公开 注释 = "删除动态组件占位" 折叠 "">
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态按钮.删除成员 (对象序)
    }

    方法 创建编辑框 <公开 类型 = 编辑框 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 内容 <类型 = 文本型 @默认值 = "">
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 80>
    参数 高度 <类型 = 整数 @默认值 = 24>
    参数 允许多行 <类型 = 逻辑型 @默认值 = 假>
    参数 滚动条 <类型 = 整数 注释 = "0、无　1、横向　2、纵向　3、横向纵向" @默认值 = 0>
    参数 调节器方式 <类型 = 整数 注释 = "0、无　1、手动　2、自动" @默认值 = 0>
    参数 对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　3、右对齐" @默认值 = 0>
    参数 输入方式 <类型 = 编辑框输入方式 注释 = "例如：编辑框输入方式.通常方式" @默认值 = 编辑框输入方式.通常方式>
    参数 显示默认标题 <类型 = 逻辑型 @默认值 = 假>
    {
        动态编辑框.加入并返回新成员2 (编辑框, 0, 编辑框标记)
        参考编辑框 = (编辑框)动态编辑框.取成员 (编辑框标记.值)
        参考编辑框.内容 = 内容
        参考编辑框.是否允许多行 = 允许多行
        如果 (调节器方式 == 1)
        {
            参考编辑框.调节器方式 = 编辑框调节器方式.手动调节器
        }
        否则 (调节器方式 == 2)
        {
            参考编辑框.调节器方式 = 编辑框调节器方式.自动调节器
        }
        如果 (滚动条 == 1)
        {
            参考编辑框.滚动条 = 滚动条类型.横向滚动条
        }
        否则 (滚动条 == 2)
        {
            参考编辑框.滚动条 = 滚动条类型.纵向滚动条
        }
        否则 (滚动条 == 3)
        {
            参考编辑框.滚动条 = 滚动条类型.横向及纵向滚动条
        }
        如果真 (显示默认标题 == 真)
        {
            参考编辑框.标题 = "编辑框" + 到文本 (编辑框标记.值 + 1)
        }
        如果 (对齐方式 == 0)
        {
            参考编辑框.对齐方式 = 横向对齐模式.左边
        }
        否则 (对齐方式 == 1)
        {
            参考编辑框.对齐方式 = 横向对齐模式.居中
        }
        否则 (对齐方式 == 2)
        {
            参考编辑框.对齐方式 = 横向对齐模式.右边
        }
        参考编辑框.输入方式 = 输入方式
        参考编辑框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考编辑框)
    }

    方法 销毁对象_编辑框 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
