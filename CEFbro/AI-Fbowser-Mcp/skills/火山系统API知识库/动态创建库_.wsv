类 动态组合框类_ <公开 折叠 @文档 = "category = \"动态创建库.独立组件创建\"">
{
    变量 动态组合框 <类型 = 对象数组类>
    变量 组合框标记 <类型 = 整数类>
    变量 参考组合框 <类型 = 组合框>

    方法 创建组合框 <公开 类型 = 组合框 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 100>
    参数 高度 <类型 = 整数 @默认值 = 24>
    参数 类型 <类型 = 整数 注释 = "1、可编辑下拉　2、可编辑列表　3、不可编辑下拉" @默认值 = 1>
    参数 列表项目 <类型 = 文本型 注释 = "如： \"选项1,选项2,选项3\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    {
        动态组合框.加入并返回新成员2 (组合框, 0, 组合框标记)
        参考组合框 = (组合框)动态组合框.取成员 (组合框标记.值)
        如果 (类型 == 1)
        {
            参考组合框.类型 = 组合框类型.可编辑下拉式
        }
        否则 (类型 == 2)
        {
            参考组合框.类型 = 组合框类型.可编辑列表式
        }
        否则
        {
            参考组合框.类型 = 组合框类型.不可编辑下拉式
        }
        变量 数据包 <类型 = 文本型>
        变量 标记1 <类型 = 文本型 值 = "\n0">
        变量 标记2 <类型 = 文本型 值 = "\n">
        变量 内容组 <类型 = 文本数组类>
        子文本替换 (列表项目, "，", ",")
        分割文本 (列表项目, ",", 内容组)
        计次循环 (内容组.取成员数 ())
        {
            数据包 = 数据包 + 内容组.取成员 (取循环索引 ()) + 标记1 + 标记2
        }
        参考组合框.列表项目 = 数据包
        参考组合框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考组合框)
    }

    方法 销毁对象_组合框 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态组合框.删除成员 (对象序)
    }
}

