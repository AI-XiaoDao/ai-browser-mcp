        变量 数据包 <类型 = 文本型>
        变量 标记1 <类型 = 文本型 值 = "\n0">
        变量 标记2 <类型 = 文本型 值 = "\n">
        变量 内容组 <类型 = 文本数组类>
        子文本替换 (列表项目, "，", ",")
        分割文本 (列表项目, ",", 内容组)
        计次循环 (内容组.取成员数 ())
        {
            数据包 = 数据包 + 内容组.取成员 (取循环索引 ()) + 标记1 + 标记2
        }
        参考列表框.列表项目 = 数据包
        返回 (参考列表框)
    }

    方法 销毁对象_列表框 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态列表框.删除成员 (对象序)
    }
}

