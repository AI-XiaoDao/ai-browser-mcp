    方法 创建状态条 <公开 类型 = 状态条 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 120>
    参数 高度 <类型 = 整数 @默认值 = 30>
    参数 项目标题 <类型 = 文本型 注释 = "如： \"状态：,正常\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 项目宽度 <类型 = 文本型 注释 = "如： \"50,70\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 提示文本 <类型 = 文本型 注释 = "如： \"当前状态,正常运行\"　；多个以逗号间开，支持中文标点" @默认值 = "">
    参数 位置 <类型 = 整数 注释 = "1、底边　2、顶边　3、自由" @默认值 = 1>
    {
        动态状态条.加入并返回新成员2 (状态条, 0, 状态条标记)
        参考状态条 = (状态条)动态状态条.取成员 (状态条标记.值)
        如果 (位置 == 1)
        {
            参考状态条.位置 = 状态条位置.底边
        }
        否则 (位置 == 2)
        {
            参考状态条.位置 = 状态条位置.顶边
        }
        否则
        {
            参考状态条.位置 = 状态条位置.自由
        }
        如果 (项目标题 == "")
        {
            参考状态条.项目 = "50\n0\n-1\n状态：\n\n50\n0\n-1\n正常\n"
        }
        否则
        {
            变量 数据包 <类型 = 文本型>
            变量 标记1 <类型 = 文本型 值 = "\n0\n-1\n">
            变量 标记2 <类型 = 文本型 值 = "\n">
            变量 标题组 <类型 = 文本数组类>
            变量 宽度组 <类型 = 文本数组类>
            变量 提示组 <类型 = 文本数组类>
            子文本替换 (项目标题, "，", ",")
            子文本替换 (项目宽度, "，", ",")
            子文本替换 (提示文本, "，", ",")
            分割文本 (项目标题, ",", 标题组)
            分割文本 (项目宽度, ",", 宽度组)
            分割文本 (提示文本, ",", 提示组)
            如果 (标题组.取成员数 () == 宽度组.取成员数 () && 标题组.取成员数 () == 提示组.取成员数 ())
            {
                计次循环 (标题组.取成员数 ())
                {
                    数据包 = 数据包 + 宽度组.取成员 (取循环索引 ()) + 标记1 + 标题组.取成员 (取循环索引 ()) + 标记2 + 提示组.取成员 (取循环索引 ()) + 标记2
                }
            }
            否则 (标题组.取成员数 () == 宽度组.取成员数 ())
            {
                计次循环 (标题组.取成员数 ())
                {
                    数据包 = 数据包 + 宽度组.取成员 (取循环索引 ()) + 标记1 + 标题组.取成员 (取循环索引 ()) + 标记2 + 标记2
                }
            }
            参考状态条.项目 = 数据包
        }
        参考状态条.标题 = "状态条" + 到文本 (状态条标记.值 + 1)
        参考状态条.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考状态条)
    }

    方法 销毁对象_状态条 <公开 注释 = "删除动态组件占位" 折叠>
    参数 对象序 <类型 = 整数 @默认值 = 0>
    {
        动态状态条.删除成员 (对象序)
    }

