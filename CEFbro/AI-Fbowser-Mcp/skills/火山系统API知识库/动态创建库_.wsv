        如果真 (标题 == "")
        {
            标题 = "标签" + 到文本 (标签标记.值 + 1)
        }
        参考标签.标题 = 标题
        参考标签.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考标签)
    }

