    方法 取颜色调试板 <公开 类型 = 逻辑型 注释 = "GetPalette" 注释 = "获取此 GP图像类 对象的调试板数据。" @禁止流程检查 = 真>
    参数 参数_颜色调试板 <类型 = GP颜色调色板 注释 = "接收调色板数据">
    {
        @ INT size = 0;
        @ Gdiplus::Status status = SetStatus(Gdiplus::DllExports::GdipGetImagePaletteSize(nativeImage, &size));
        @ if(status != Gdiplus::Ok) return false;
        @ Gdiplus::ColorPalette *palette = (Gdiplus::ColorPalette *)malloc(size);
        @ if(!palette) return false;
        @ status = SetStatus(Gdiplus::DllExports::GdipGetImagePalette(nativeImage, palette, size));
        @ if(status != Gdiplus::Ok) {
        @     free(palette);
        @     return false;
        @ }
        @ @<参数_颜色调试板>.Destory();
        @ @<参数_颜色调试板>.m_ptr = palette;
        @ return true;
    }

