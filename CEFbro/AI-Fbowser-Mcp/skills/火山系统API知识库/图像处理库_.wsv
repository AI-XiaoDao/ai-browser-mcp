    方法 初始化 <公开 静态 类型 = 变整数 注释 = "GdiplusStartup"
            注释 = "函数初始化 Windows GDI+。 在进行任何其他 GDI+ 调用之前调用 Gdiplus.初始化，并在使用完 GDI+ 后调用 Gdiplus.卸载。" 返回值注释 = "返回一个令牌, 这个令牌在卸载时需要" 折叠
            @禁止流程检查 = 真>
    参数 参数_版本 <类型 = 整数 注释 = "必须是 1" @默认值 = 1>
    {
        @ Gdiplus::GdiplusStartupInput gsInput;
        @ gsInput.GdiplusVersion = @<参数_版本>;
        @ ULONG_PTR token;
        @ Gdiplus::Status state = Gdiplus::GdiplusStartup(&token, &gsInput, nullptr);
        @ return (INT_P)token;

    }

    方法 卸载 <公开 静态 注释 = "GdiplusShutdown 卸载GDI+, 注意: 在此之前必须销毁其他所有GDI+对象" @嵌入式方法 = "">
    参数 参数_令牌 <类型 = 变整数 注释 = "由 Gdiplus.初始化 返回">
    {
        @ Gdiplus::GdiplusShutdown((ULONG_PTR)@<参数_令牌>)
    }

    方法 申请内存 <公开 静态 类型 = 变整数 注释 = "为一个 Windows GDI+ 对象分配内存。" 返回值注释 = "返回内存地址" @嵌入式方法 = "">
    参数 参数_大小 <类型 = 变整数 注释 = "要申请的内存大小">
    {
        @ (INT_P)Gdiplus::DllExports::GdipAlloc(@<参数_大小>)

    }

    方法 释放内存 <公开 静态 注释 = "释放由 Gdiplus.申请内存() 申请的内存" @嵌入式方法 = "">
    参数 参数_内存地址 <类型 = 变整数>
    {
        @ (INT_P)Gdiplus::DllExports::GdipFree((void*)@<参数_内存地址>)

    }

    方法 取图像编码器列表 <公开 静态 类型 = 整数 注释 = "GetImageEncoders" 注释 = "函数获取包含有关可用图像编码器信息的对象数组。" @禁止流程检查 = 真>
    参数 参数_信息列表 <类型 = GP数组图像编解码信息 注释 = "输出参数" "">
    {
        @ UINT numDecoders, size;
        @ Gdiplus::Status result = Gdiplus::GetImageEncodersSize(&numDecoders, &size);
        @ if(result != Gdiplus::Ok) return 0;
        @ Gdiplus::ImageCodecInfo * ptrInfo = @<参数_信息列表>.Create(numDecoders, size);
        @ if(!ptrInfo) return 0;
        @ result = Gdiplus::GetImageEncoders(numDecoders, size, ptrInfo);
        @ if(result != Gdiplus::Ok) {
        @    @<参数_信息列表>.Destory();
        @    return 0;
        @ }
        @ return numDecoders;
    }

    方法 取图像解码器列表 <公开 静态 类型 = 整数 注释 = "GetImageDecoders" 注释 = "函数获取包含可用图像解码器信息的对象数组。" @禁止流程检查 = 真>
    参数 参数_信息列表 <类型 = GP数组图像编解码信息 注释 = "输出参数" "">
    {
        @ UINT numDecoders, size;
        @ Gdiplus::Status result = Gdiplus::GetImageDecodersSize(&numDecoders, &size);
        @ if(result != Gdiplus::Ok) return 0;
        @ Gdiplus::ImageCodecInfo * ptrInfo = @<参数_信息列表>.Create(numDecoders, size);
        @ if(!ptrInfo) return 0;
        @ result = Gdiplus::GetImageDecoders(numDecoders, size, ptrInfo);
        @ if(result != Gdiplus::Ok) {
        @    @<参数_信息列表>.Destory();
        @    return 0;
        @ }
        @ return numDecoders;
    }

    方法 取编码器自图像格式 <公开 静态 类型 = GP全局唯一标识符 注释 = "返回编码器CLSID" @嵌入式方法 = "">
    参数 参数_图像格式 <类型 = "字节 []" 注释 = "GP图像格式 常量">
    {
        @ @dt<GP全局唯一标识符>(@dt<Gdiplus>::GetEncoderFormFormatId(&@<参数_图像格式>[0]))

    }

    方法 取编码器自媒体类型 <公开 静态 类型 = GP全局唯一标识符 注释 = "返回编码器CLSID" @嵌入式方法 = "">
    参数 参数_媒体类型 <类型 = 文本型 注释 = "如:\"image/bmp\",\"image/jpeg\",\"image/gif\",\"image/tiff\",\"image/png\"">
    {
        @ @dt<GP全局唯一标识符>(@dt<Gdiplus>::GetEncoderFormMimeType(@<参数_媒体类型>.GetText()))

    }

    方法 取解码器自图像格式 <公开 静态 类型 = GP全局唯一标识符 注释 = "返回解码器CLSID" @嵌入式方法 = "">
    参数 参数_图像格式 <类型 = "字节 []" 注释 = "GP图像格式 常量">
    {
        @ @dt<GP全局唯一标识符>(@dt<Gdiplus>::GetDecoderFormFormatId(&@<参数_图像格式>[0]))

    }

    方法 取解码器自媒体类型 <公开 静态 类型 = GP全局唯一标识符 注释 = "返回编码器CLSID" @嵌入式方法 = "">
    参数 参数_媒体类型 <类型 = 文本型 注释 = "如:\"image/bmp\",\"image/jpeg\",\"image/gif\",\"image/tiff\",\"image/png\"">
    {
        @ @dt<GP全局唯一标识符>(@dt<Gdiplus>::GetDecoderFormMimeType(@<参数_媒体类型>.GetText()))

    }

    方法 取像素格式大小 <公开 静态 类型 = 整数 注释 = "GetPixelFormatSize" 注释 = "方法返回指定像素格式使用的每个像素的位数。" @禁止流程检查 = 真>
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量组合">
    {
        @ return (INT)Gdiplus::GetPixelFormatSize(@<参数_像素格式>);
    }

    方法 是否索引像素格式 <公开 静态 类型 = 逻辑型 注释 = "IsIndexedPixelFormat" 注释 = "方法确定指定的像素格式是否为索引格式。" @禁止流程检查 = 真>
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量组合">
    {
        @ return (INT)Gdiplus::IsIndexedPixelFormat(@<参数_像素格式>);
    }

    方法 是否透明像素格式 <公开 静态 类型 = 逻辑型 注释 = "IsAlphaPixelFormat" 注释 = "方法确定指定的像素格式是否具有 alpha 分量。" @禁止流程检查 = 真>
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量组合">
    {
        @ return (INT)Gdiplus::IsAlphaPixelFormat(@<参数_像素格式>);
    }

    方法 是否扩展像素格式 <公开 静态 类型 = 逻辑型 注释 = "IsExtendedPixelFormat" 注释 = "方法确定指定的像素格式是否使用每个颜色通道 16 位。" @禁止流程检查 = 真>
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量组合">
    {
        @ return (INT)Gdiplus::IsExtendedPixelFormat(@<参数_像素格式>);
    }

    方法 是否规范像素格式 <公开 静态 类型 = 逻辑型 注释 = "IsCanonicalPixelFormat"
            注释 = "方法确定指定的像素格式是否是规范格式之一：PixelFormat32bppARGB 或 PixelFormat64bppARGB。" @禁止流程检查 = 真>
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量组合">
    {
        @ return (INT)Gdiplus::IsExtendedPixelFormat(@<参数_像素格式>);
    }
}

