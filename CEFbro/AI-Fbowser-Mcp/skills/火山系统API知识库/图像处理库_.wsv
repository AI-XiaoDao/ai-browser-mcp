    }
}

# ======

类 外形图窗类_ <公开 注释 = "类似官方“置外形图片”命令" 折叠 @文档 = "category = \"图像处理库.外形窗\"">
{
    变量 令牌 <类型 = 变整数>

    方法 类_初始化 <折叠>
    {
        令牌 = Gdiplus.初始化 ()
    }

    方法 类_清理 <折叠>
    {
        Gdiplus.卸载 (令牌)
    }

    方法 置外形图片_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 图片数据 <类型 = 字节集类>
    参数 透明度 <类型 = 整数 注释 = "0-255之间，0完全透明，255完全不透明">
    {
        变量 GP图像 <类型 = GP图像类>
        变量 尺寸 <类型 = 尺寸F>
        变量 GP缓存 <类型 = GP缓存图形类>
        变量 图片宽度 <类型 = 整数>
        变量 图片高度 <类型 = 整数>
        @ ShowWindowAsync((HWND)@<窗口句柄>,0);
        GP图像.创建自字节集 (图片数据, )
        GP图像.取物理尺寸 (尺寸)
        图片宽度 = GP图像.取宽度 ()
        图片高度 = GP图像.取高度 ()
        GP缓存.创建 (图片宽度, 图片高度, )
        GP缓存.画图像缩放 (GP图像, 0, 0, 图片宽度, 图片高度)
        @ RECT rect;
        @ GetWindowRect((HWND)@<窗口句柄>,&rect);
        @ MoveWindow((HWND)@<窗口句柄>,rect.left,rect.top,@<图片宽度>,@<图片高度>,true);
        @ LONG_PTR exStyle = GetWindowLongPtr((HWND)@<窗口句柄>, GWL_EXSTYLE);
        @ exStyle |= WS_EX_LAYERED;
        @ SetWindowLongPtr((HWND)@<窗口句柄>, GWL_EXSTYLE, exStyle);
        GP缓存.更新到分层窗口 (窗口句柄, , , , 透明度)
        @ ShowWindowAsync((HWND)@<窗口句柄>,1);
        GP图像.销毁 ()
        GP缓存.销毁 ()
    }
}

# ======

类 图像处理类_ <公开 @文档 = "category = \"图像处理库.图片处理\"">
{
    变量 令牌 <类型 = 变整数>

    方法 类_初始化 <折叠>
    {
        令牌 = Gdiplus.初始化 ()
    }

    方法 类_清理 <折叠>
    {
        Gdiplus.卸载 (令牌)
    }

    方法 置红色 <公开 类型 = 字节集类 注释 = "调整图像红色比例" 返回值注释 = "返回转换后的图片数据，如果提供了参数一的句柄，那么不会返回处理后的图片数据" 折叠>
    参数 绑定容器 <类型 = 变整数 注释 = "显示图片的容器句柄，直接显示到绑定的容器上，本参数不为空时则不会返回处理后的图片数据" @默认值 = 0>
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 红色比例 <类型 = 小数 注释 = "-1 到 1 之间">
    参数 图像品质 <类型 = 整数 @默认值 = 100>
    参数 转换格式 <类型 = 整数 注释 = "0、JPG　1、BMP　2、PNG　3、GIF" @默认值 = 0>
    参数 保存路径 <类型 = 文本型 注释 = "留空则不会保存图片" @默认值 = "">
    {
        变量 图形 <类型 = GP图形类>
        变量 图像 <类型 = GP图像类>
        变量 图像2 <类型 = 字节集类>
        变量 编码器 <类型 = GP编码器参数集>
        变量 图像属性 <类型 = GP图像属性类>
        变量 颜色矩阵 <类型 = GP颜色矩阵类>
        如果 (图片数据.取字节集长度 () == 0)
        {
            图像.创建自文件 (图片来源)
        }
        否则
        {
            图像.创建自字节集 (图片数据)
        }
        如果 (绑定容器 == 0)
        {
            图形.创建自图像 (图像)
        }
        否则
        {
            图形.创建自窗口句柄 (绑定容器)
        }
        图像属性.创建 ()
        颜色矩阵.置红色 (红色比例)
        图像属性.置颜色矩阵 (颜色矩阵)
        图形.画图像缩放部分 (图像, 0, 0, 图像.取宽度 (), 图像.取高度 (), 0, 0, 图像.取宽度 (), 图像.取高度 (), , 图像属性)
        如果真 (绑定容器 == 0)
        {
            编码器.创建 ()
            编码器.置参数整数 (0, GP编码器.品质, 图像品质)
            如果 (转换格式 == 0)
            {
                图像.保存到字节集 (图像2, GP图像格式.JPEG, 编码器)
            }
            否则 (转换格式 == 1)
            {
                图像.保存到字节集 (图像2, GP图像格式.BMP, 编码器)
            }
            否则 (转换格式 == 2)
            {
                图像.保存到字节集 (图像2, GP图像格式.PNG, 编码器)
            }
            否则 (转换格式 == 3)
            {
                图像.保存到字节集 (图像2, GP图像格式.GIF, 编码器)
            }
            如果真 (保存路径 != "")
            {
                写到文件 (保存路径, 图像2)
            }
        }
        图像.销毁 ()
        图像属性.销毁 ()
        图形.销毁 ()
        编码器.销毁 ()
        返回 (图像2)
    }

    方法 置绿色 <公开 类型 = 字节集类 注释 = "调整图像绿色比例" 返回值注释 = "返回转换后的图片数据，如果提供了参数一的句柄，那么不会返回处理后的图片数据" 折叠>
