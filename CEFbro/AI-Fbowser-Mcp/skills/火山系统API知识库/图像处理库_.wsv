    方法 取字体族数 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ INT numFound = 0;
        @ lastResult = Gdiplus::DllExports::GdipGetFontCollectionFamilyCount(nativeFontCollection, &numFound);
        @ return numFound;

    }

    方法 取字体族列表 <公开 类型 = 整数 返回值注释 = "返回 数量" @禁止流程检查 = 真>
    参数 参数_字体族数组 <类型 = GP数组字体族类 注释 = "返回的字体族列表">
    {
        @ INT numSought = 0;
        @ INT numFound = 0;
        @ lastResult = Gdiplus::DllExports::GdipGetFontCollectionFamilyCount(nativeFontCollection, &numSought);
        @ Gdiplus::GpFontFamily **nativeFamilyList = new Gdiplus::GpFontFamily*[numSought];
        @ if (nativeFamilyList == NULL)
        @ {
        @     return SetStatus(Gdiplus::OutOfMemory);
        @ }
        @ Gdiplus::Status status = Gdiplus::DllExports::GdipGetFontCollectionFamilyList(
        @        nativeFontCollection,
        @        numSought,
        @        nativeFamilyList,
        @        &numFound
        @    );
        @ @<参数_字体族数组>.InitCount (VOL_RUNTIME_CLASS (@dt<GP字体族类>), 0, numFound);
        @ if (status == Gdiplus::Ok)
        @ {
        @     for (INT i = 0; i < numFound; i++)
        @     {
        @         Gdiplus::DllExports::GdipCloneFontFamily(nativeFamilyList[i], &((@dt<GP字体族类>&)@<参数_字体族数组>.GetAt(i)).nativeFamily);
        @     }
        @ }
        @ delete [] nativeFamilyList;
        @ return numFound;

    }

    #
}

