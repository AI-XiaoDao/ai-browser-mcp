    方法 矩阵旋转 <公开 类型 = 逻辑型 注释 = "RotateTransform" 注释 = "使用自身和旋转矩阵的乘积更新此纹理画刷的当前变换矩阵。" @禁止流程检查 = 真>
    参数 参数_角度 <类型 = 小数 注释 = "指定旋转角度（以度为单位）">
    参数 参数_矩阵顺序 <类型 = GP矩阵顺序 注释 = "可选的。 用于指定乘法的顺序。" 注释 = "GP矩阵顺序.前置 指定传递的矩阵在左侧，GP矩阵顺序.后置 指定传递的矩阵在右侧。" @默认值 = GP矩阵顺序.前置>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipRotateTextureTransform((Gdiplus::GpTexture*)nativeBrush, (Gdiplus::REAL)@<参数_角度>, (Gdiplus::MatrixOrder)@<参数_矩阵顺序>)) == Gdiplus::Ok;
    }

    方法 置环绕模式 <公开 类型 = 逻辑型 注释 = "SetWrapMode" 注释 = "设置此纹理画刷的环绕模式。" @禁止流程检查 = 真>
    参数 参数_环绕模式 <类型 = GP环绕模式>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetTextureWrapMode((Gdiplus::GpTexture*)nativeBrush, (Gdiplus::WrapMode)@<参数_环绕模式>)) == Gdiplus::Ok;

    }

    方法 取环绕模式 <公开 类型 = GP环绕模式 注释 = "GetWrapMode" 注释 = "获取当前为此纹理画刷设置的环绕模式。" @禁止流程检查 = 真>
    {
        @ Gdiplus::WrapMode wrapMode;
        @ SetStatus(Gdiplus::DllExports::GdipGetTextureWrapMode((Gdiplus::GpTexture*)nativeBrush, &wrapMode));
        @ return (@dt<GP环绕模式>)wrapMode;
    }

    方法 取图像 <公开 类型 = 逻辑型 注释 = "GetImage" 注释 = "获取指向此纹理画刷定义的 GP图像类 对象" @禁止流程检查 = 真>
    参数 参数_图像 <类型 = GP图像类 注释 = "接收纹理画刷的图像" "">
    {
        @ @<参数_图像>.Destory();
        @ Gdiplus::GpImage* image;
        @ SetStatus(Gdiplus::DllExports::GdipGetTextureImage((Gdiplus::GpTexture*)nativeBrush, &image));
        @ @<参数_图像>.nativeImage = image;
        @ return lastResult == Gdiplus::Ok;
    }

    #
}

类 GP线性渐变画刷类 <公开 基础类 = GP画刷类 注释 = "LinearGradientBrush" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{

    # @begin
    # <> <include>
    # BOOL GetLineColors(INT* colors)
    # {
    #     return SetStatus(Gdiplus::DllExports::GdipGetLineColors((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::ARGB*)colors)) == Gdiplus::Ok;
    # }
    # <> </include>
    # @end

    方法 创建 <公开 类型 = 逻辑型 注释 = "从一组边界点和边界颜色创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_起点坐标 <类型 = 坐标F 注释 = "指定渐变起点的 坐标F 对象" "">
    参数 参数_终点坐标 <类型 = 坐标F 注释 = "指定渐变终点的 坐标F 对象">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrush(@<参数_起点坐标>.ptr(), @<参数_终点坐标>.ptr(),@<参数_起点颜色>,@<参数_终点颜色>,Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建I <公开 类型 = 逻辑型 注释 = "从一组边界点和边界颜色创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_起点坐标 <类型 = 坐标L 注释 = "指定渐变起点的 坐标L 对象" "">
    参数 参数_终点坐标 <类型 = 坐标L 注释 = "指定渐变终点的 坐标L 对象">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrushI(@<参数_起点坐标>.ptr(), @<参数_终点坐标>.ptr(),@<参数_起点颜色>,@<参数_终点颜色>,Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自矩形 <公开 类型 = 逻辑型 注释 = "基于矩形和方向模式创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形F 注释 = "对指定渐变起点和终点的矩形的引用。由模式指定的梯度方向会影响这些点的定义方式。矩形的尺寸影响正向对角线模式和反向对角线模式的梯度方向。" "">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    参数 参数_模式 <类型 = GP线性渐变模式 注释 = "指定渐变方向的 GP线性渐变模式 常量" @默认值 = GP线性渐变模式.水平>
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrushFromRect(@<参数_矩形>.ptr(), @<参数_起点颜色>,@<参数_终点颜色>, (Gdiplus::LinearGradientMode)@<参数_模式> ,Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自矩形I <公开 类型 = 逻辑型 注释 = "基于矩形和方向模式创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形L 注释 = "对指定渐变起点和终点的矩形的引用。由模式指定的梯度方向会影响这些点的定义方式。矩形的尺寸影响正向对角线模式和反向对角线模式的梯度方向。" "">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    参数 参数_模式 <类型 = GP线性渐变模式 注释 = "指定渐变方向的 GP线性渐变模式 常量" @默认值 = GP线性渐变模式.水平>
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrushFromRectI(@<参数_矩形>.ptr(), @<参数_起点颜色>,@<参数_终点颜色>, (Gdiplus::LinearGradientMode)@<参数_模式> ,Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自矩形角度 <公开 类型 = 逻辑型 注释 = "从矩形和方向角度创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形F 注释 = "指定渐变起点和终点的矩形的引用。矩形的左上角是起点。右下角是终点。" "">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    参数 参数_角度 <类型 = 小数 注释 = "如果 参数_角度是否可缩放 为 真，则指定计算方向线角度的基角，或者，如果 参数_角度是否可缩放 为 假，则指定方向线的角度。"
            注释 = "该角度是从 参数_矩形 指定的矩形顶部开始测量的，必须以度为单位。 渐变遵循方向线。">
    参数 参数_角度是否可缩放 <类型 = 逻辑型 注释 = "指定角度是否可缩放的布尔值。 如果为 真，则方向线的角度是可缩放的； 否则，角度不可缩放。" @默认值 = 假>
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrushFromRectWithAngle(@<参数_矩形>.ptr(), @<参数_起点颜色>,@<参数_终点颜色>, (Gdiplus::REAL)@<参数_角度> , @<参数_角度是否可缩放> , Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自矩形角度I <公开 类型 = 逻辑型 注释 = "从矩形和方向角度创建一个 GP线性渐变画刷类 对象。" 注释 = "" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形L 注释 = "指定渐变起点和终点的矩形的引用。矩形的左上角是起点。右下角是终点。" "">
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    参数 参数_角度 <类型 = 小数 注释 = "如果 参数_角度是否可缩放 为 真，则指定计算方向线角度的基角，或者，如果 参数_角度是否可缩放 为 假，则指定方向线的角度。"
            注释 = "该角度是从 参数_矩形 指定的矩形顶部开始测量的，必须以度为单位。 渐变遵循方向线。">
    参数 参数_角度是否可缩放 <类型 = 逻辑型 注释 = "指定角度是否可缩放的布尔值。 如果为 真，则方向线的角度是可缩放的； 否则，角度不可缩放。" @默认值 = 假>
    {
        @ this->Destory();
        @ Gdiplus::GpLineGradient *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateLineBrushFromRectWithAngleI(@<参数_矩形>.ptr(), @<参数_起点颜色>,@<参数_终点颜色>, (Gdiplus::REAL)@<参数_角度> , @<参数_角度是否可缩放> , Gdiplus::WrapModeTile, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 置线性颜色 <公开 类型 = 逻辑型 注释 = "SetLinearColors" 注释 = "设置此线性渐变画笔的起始颜色和结束颜色。" @禁止流程检查 = 真>
    参数 参数_起点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的起始边界线处的颜色。">
    参数 参数_终点颜色 <类型 = 整数 注释 = "指定此线性渐变画笔的结束边界线处的颜色。">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLineColors((Gdiplus::GpLineGradient*)nativeBrush, @<参数_起点颜色>, @<参数_终点颜色>)) == Gdiplus::Ok;

    }

    方法 取线性颜色 <公开 类型 = 逻辑型 注释 = "GetLinearColors" @嵌入式方法 = "">
    参数 参数_颜色 <类型 = "整数 []" 注释 = "2个成员, 接收起点颜色和终点颜色" @需求类型 = 可写入变量>
    {
        @ @sn<this>.GetLineColors(&@<参数_颜色>[0])
    }

    方法 取矩形 <公开 类型 = 逻辑型 注释 = "GetRectangle" 注释 = "获取定义渐变边界的矩形。" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形F 注释 = "接收矩形的对象">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipGetLineRect((Gdiplus::GpLineGradient*)nativeBrush, @<参数_矩形>.ptr())) == Gdiplus::Ok;
    }

    方法 取矩形I <公开 类型 = 逻辑型 注释 = "GetRectangle" 注释 = "获取定义渐变边界的矩形。" @禁止流程检查 = 真>
    参数 参数_矩形 <类型 = 矩形L 注释 = "接收矩形的对象">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipGetLineRectI((Gdiplus::GpLineGradient*)nativeBrush, @<参数_矩形>.ptr())) == Gdiplus::Ok;
    }

    方法 置伽玛校正 <公开 类型 = 逻辑型 注释 = "SetGammaCorrection" 注释 = "指定是否为此线性渐变画刷启用伽马校正。" @禁止流程检查 = 真>
    参数 参数_是否启用校正 <类型 = 逻辑型 注释 = "布尔值，指定在渲染期间是否进行伽马校正。 真 指定启用伽马校正，假 指定不启用伽马校正。" 注释 = "默认情况下，在构建 线性渐变画刷 对象期间禁用伽马校正。">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLineGammaCorrection((Gdiplus::GpLineGradient*)nativeBrush, @<参数_是否启用校正>)) == Gdiplus::Ok;
    }

    方法 取伽玛校正 <公开 类型 = 逻辑型 注释 = "GetGammaCorrection" 注释 = "确定是否为此 线性渐变画刷 对象启用伽马校正。" 返回值注释 = "如果启用了伽马校正，则此方法返回 真；否则，它返回 假"
            @禁止流程检查 = 真>
    {
        @ BOOL useGammaCorrection;
        @ SetStatus(Gdiplus::DllExports::GdipGetLineGammaCorrection((Gdiplus::GpLineGradient*)nativeBrush, &useGammaCorrection));
        @ return useGammaCorrection;
    }

    方法 取混合数 <公开 类型 = 整数 注释 = "GetBlendCount" 注释 = "获取当前为此 线性渐变画刷 对象设置的混合因子的数量。" 返回值注释 = "返回混合数" @禁止流程检查 = 真>
    {
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetLineBlendCount((Gdiplus::GpLineGradient*)nativeBrush, &count));
        @ return count;
    }

    方法 置混合 <公开 类型 = 逻辑型 注释 = "SetBlend" 注释 = "设置此线性渐变画刷的混合因子和混合位置以创建自定义混合。" 返回值注释 = "" @禁止流程检查 = 真>
    参数 参数_混合因子 <类型 = GP数组单精度 注释 = "如：{0，0.5，1} , 指定混合因子的实数数组。 数组中的每个数字都指定了结束颜色的百分比，并且应该在 0.0 到 1.0 的范围内。">
    参数 参数_混合位置 <类型 = GP数组单精度
            注释 = "如：{0，0.2，1} , 指定混合位置的实数数组。 数组中的每个数字表示起始边界和结束边界之间距离的百分比，范围为 0.0 到 1.0，其中 0.0 表示梯度的起始边界，1.0 表示结束边界。"
            注释 = "必须至少指定两个位置：第一个位置，始终为 0.0f，最后一个位置，始终为 1.0f。 否则，行为是未定义的。 介于 0.0 和 1.0 之间的混合位置表示一条线，平行于边界线，"
            注释 = "即从起始边界到结束边界的距离的某个分数。 例如，0.7 的混合位置表示从起始边界到结束边界的距离的 70% 的线。 在平行于边界线的线上，颜色是恒定的。">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLineBlend((Gdiplus::GpLineGradient*)nativeBrush, @<参数_混合因子>.data().data(), @<参数_混合位置>.data().data(),
        @ (INT)@<参数_混合因子>.data().size())) == Gdiplus::Ok;
    }

    方法 取混合 <公开 类型 = 整数 注释 = "GetBlend" 注释 = "获取混合因子及其相应的混合位置。" 返回值注释 = "返回混合数" @禁止流程检查 = 真>
    参数 参数_混合因子 <类型 = GP数组单精度 注释 = "接收混合因子的数组。数组中的每个数字表示结束颜色的百分比，范围从 0.0 到 1.0。">
    参数 参数_混合位置 <类型 = GP数组单精度 注释 = "接收混合位置的数组。数组中的每个数字表示起始边界和结束边界之间距离的百分比，范围为 0.0 到 1.0，其中 0.0 表示梯度的起始边界，1.0 表示结束边界。"
            注释 = "介于 0.0 和 1.0 之间的混合位置表示一条线，平行于边界线，即从起始边界到结束边界的距离的某个分数。"
            注释 = "例如，0.7 的混合位置表示从起始边界到结束边界的距离的 70% 的线。 在平行于边界线的线上，颜色是恒定的。">
    {
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetLineBlendCount((Gdiplus::GpLineGradient*)nativeBrush, &count));
        @ @<参数_混合因子>.data().resize(count);
        @ @<参数_混合位置>.data().resize(count);
        @ if(count != 0)
        @     SetStatus(Gdiplus::DllExports::GdipGetLineBlend((Gdiplus::GpLineGradient*)nativeBrush, @<参数_混合因子>.data().data(),@<参数_混合位置>.data().data(), count));
        @ return count;
    }

    方法 取插值颜色数 <公开 类型 = 整数 注释 = "GetInterpolationColorCount" 注释 = "获取当前设置为该线性渐变画刷插值的颜色数。" 返回值注释 = "返回插值颜色数" @禁止流程检查 = 真>
    {
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetLinePresetBlendCount((Gdiplus::GpLineGradient*)nativeBrush, &count));
        @ return count;
    }

    方法 置插值颜色 <公开 类型 = 逻辑型 注释 = "SetInterpolationColors" 注释 = "设置此线性渐变画刷的混合因子和混合位置以创建自定义混合。" 返回值注释 = "" @禁止流程检查 = 真>
    参数 参数_预设颜色 <类型 = 整数数组类 注释 = "要为此线性渐变画刷插值的颜色。 预设颜色数组中给定索引的颜色对应于 参数_混合位置 数组中相同索引的混合位置。">
    参数 参数_混合位置 <类型 = GP数组单精度 注释 = "指向指定混合位置的实数数组。 数组中的每个数字指定起始边界和结束边界之间距离的百分比，范围为 0.0 到 1.0，其中 0.0 表示渐变的起始边界，1.0 表示结束边界。"
            注释 = "必须至少指定两个位置：第一个位置，始终为 0.0f，最后一个位置，始终为 1.0f。 否则，行为是未定义的。 介于 0.0 和 1.0 之间的混合位置表示与边界线平行的线，"
            注释 = "即从起始边界到结束边界的距离的某个分数。 例如，0.7 的混合位置表示从起始边界到结束边界的距离的 70% 的线。 在平行于边界线的线上，颜色是恒定的。">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLinePresetBlend((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::ARGB*)@<参数_预设颜色>.data().GetData(), @<参数_混合位置>.data().data(),
        @ (INT)@<参数_预设颜色>.data().GetCount())) == Gdiplus::Ok;
    }

    方法 取插值颜色 <公开 类型 = 整数 注释 = "GetInterpolationColors" 注释 = "获取当前设置为该线性渐变画刷插值的颜色及其相应的混合位置。" 返回值注释 = "返回插值颜色数" @禁止流程检查 = 真>
    参数 参数_预设颜色 <类型 = 整数数组类 注释 = "指向接收颜色的数组。数组中给定索引的颜色对应于 参数_混合位置 数组中相同索引的混合位置。">
    参数 参数_混合位置 <类型 = GP数组单精度 注释 = "接收混合位置的数组。数组中的每个数字表示起始边界和结束边界之间距离的百分比，范围为 0.0 到 1.0，其中 0.0 表示梯度的起始边界，1.0 表示结束边界。"
            注释 = "介于 0.0 和 1.0 之间的混合位置表示一条线，平行于边界线，即从起始边界到结束边界的距离的某个分数。 例如，0.7 的混合位置表示从起始边界到结束边界的距离的 70% 的线。"
            注释 = "在平行于边界线的线上，颜色是恒定的。">
    {
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetLinePresetBlendCount((Gdiplus::GpLineGradient*)nativeBrush, &count));
        @ @<参数_预设颜色>.data().InitCount(count, TRUE);
        @ @<参数_混合位置>.data().resize(count);
        @ if(count != 0)
        @     SetStatus(Gdiplus::DllExports::GdipGetLinePresetBlend((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::ARGB *)@<参数_预设颜色>.data().GetData(),@<参数_混合位置>.data().data(), count));
        @ return count;
    }

    方法 置混合钟形 <公开 类型 = 逻辑型 注释 = "SetBlendBellShape" 注释 = "设置此线性渐变画刷的混合形状，以创建基于钟形曲线的自定义混合。" @禁止流程检查 = 真>
    参数 参数_焦点 <类型 = 小数 注释 = "指定结束颜色位置。 此数字是边界线之间距离的百分比，必须在 0.0 到 1.0 的范围内。">
    参数 参数_比例 <类型 = 小数 注释 = "可选的。 指定渐变的结束颜色在焦点位置与渐变的起始颜色混合的百分比。 此数字必须在 0.0 到 1.0 的范围内。 默认值为 1.0，它指定结束颜色为全强度。" @默认值 = 1.0>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLineSigmaBlend((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::REAL)@<参数_焦点>, (Gdiplus::REAL)@<参数_比例>)) == Gdiplus::Ok;
    }

    方法 置混合三角形 <公开 类型 = 逻辑型 注释 = "SetBlendTriangularShape" 注释 = "设置此线性渐变画刷的混合形状，以创建基于三角形形状的自定义混合。" @禁止流程检查 = 真>
    参数 参数_焦点 <类型 = 小数 注释 = "指定结束颜色位置。 此数字是边界线之间距离的百分比，必须在 0.0 到 1.0 的范围内。">
    参数 参数_比例 <类型 = 小数 注释 = "可选的。 指定渐变的结束颜色在焦点位置与渐变的起始颜色混合的百分比。 此数字必须在 0.0 到 1.0 的范围内。 默认值为 1.0，它指定结束颜色为全强度。" @默认值 = 1.0>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetLineLinearBlend((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::REAL)@<参数_焦点>, (Gdiplus::REAL)@<参数_比例>)) == Gdiplus::Ok;
    }

    方法 置矩阵 <公开 类型 = 逻辑型 注释 = "SetTransform" 注释 = "设置此线性渐变画刷的变换矩阵。" @禁止流程检查 = 真>
    参数 参数_矩阵 <类型 = GP矩阵类 注释 = "要使用的变换矩阵。">
    {
