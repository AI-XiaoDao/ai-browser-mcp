类 GP缓存图形类 <公开 基础类 = GP图形类 注释 = "用做内存中的图形, 双缓冲机制可以用. 也可以看做是和GDI交互的类" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{

    # @begin
    # <> <include>
    # HDC m_hdc;
    # HBITMAP m_hBitmap;
    # INT m_Width;
    # INT m_Height;
    #
    # void @an<_OnInitExtra> ()    //初始化
    # {
    #     m_hdc = NULL;
    #     m_hBitmap = NULL;
    #     m_Width = 0;
    #     m_Height = 0;    
    # }
    #
    # void @an<_OnCleanupExtra> () //销毁
    # {
    #     this->Destory();
    # }
    #
    #
    # virtual void Destory()
    # {
    #     if (nativeGraphics){
    #         Gdiplus::DllExports::GdipDeleteGraphics(nativeGraphics);
    #     }
    #     if(m_hBitmap)
    #        ::DeleteObject (m_hBitmap);
    #     if(m_hdc)
    #         ::DeleteDC (m_hdc);
    #     m_hdc = NULL;
    #     m_hBitmap = NULL;
    #     m_Width = 0;
    #     m_Height = 0;
    #     nativeGraphics = NULL;
    #     lastResult = Gdiplus::Ok;
    # }
    #
    # <> </include>
