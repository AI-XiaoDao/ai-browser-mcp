    方法 克隆 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "创建一个新的 GP字体类 对象，该对象是本对象的副本。" @禁止流程检查 = 真>
    参数 参数_新字体 <类型 = GP字体类 "">
    {
        @ @<参数_新字体>.Destory();
        @ Gdiplus::GpFont* clone;
        @ SetStatus(Gdiplus::DllExports::GdipCloneFont(nativeFont, &clone));
        @ @<参数_新字体>.nativeFont = clone;
        @ @<参数_新字体>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建自场景句柄 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_场景句柄 <类型 = 变整数 注释 = "HDC">
    {
        @ this->Destory();
        @ Gdiplus::GpFont *font = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateFontFromDC((HDC)@<参数_场景句柄>, &font);
        @ SetNativeFont(font);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自字体句柄 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_场景句柄 <类型 = 变整数 注释 = "HDC">
    参数 参数_字体句柄 <类型 = 变整数 注释 = "HFONT">
    {
        @ this->Destory();
        @ Gdiplus::GpFont *font = NULL;
        @ HDC hdc = (HDC)@<参数_场景句柄>;
        @ if (@<参数_场景句柄>)
        @ {
        @    LOGFONTA lf;
        @    if(GetObjectA(hdc, sizeof(LOGFONTA), &lf))
        @        lastResult = Gdiplus::DllExports::GdipCreateFontFromLogfontA(hdc, &lf, &font);
        @    else
        @        lastResult = Gdiplus::DllExports::GdipCreateFontFromDC(hdc, &font);
        @ }
        @ else
        @ {
        @     lastResult = Gdiplus::DllExports::GdipCreateFontFromDC(hdc, &font);
        @ }
        @ SetNativeFont(font); 
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建逻辑字体 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 字体名称 <类型 = 文本型 @默认值 = "微软雅黑">
    参数 字体大小 <类型 = 整数 @默认值 = 11>
    参数 粗体 <类型 = 整数 注释 = "0-1000" @默认值 = 0>
    参数 斜体 <类型 = 逻辑型 @默认值 = 假>
    参数 下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 删除线 <类型 = 逻辑型 @默认值 = 假>
    {
        @ this->Destory();
        @ HDC hdc = ::GetDC(NULL);
        @ LOGFONTW logFont;
        @ logFont.lfHeight =-MulDiv(@<字体大小>, GetDeviceCaps(hdc, LOGPIXELSY), 72);
        @ logFont.lfWeight = @<粗体>;
        @ logFont.lfItalic = @<斜体>;
        @ logFont.lfUnderline = @<下划线>;
        @ logFont.lfStrikeOut = @<删除线>;
        // @ logFont.lfPitchAndFamily = FF_DECORATIVE;
        @ lstrcpy (logFont.lfFaceName, @<字体名称>) ;
        @ Gdiplus::GpFont *font = NULL;
        @ lastResult =  Gdiplus::DllExports::GdipCreateFontFromLogfontW(hdc, &logFont, &font);
        @ SetNativeFont(font);
        @ ::ReleaseDC(NULL,hdc);
        @ return lastResult == Gdiplus::Ok;
    }

