    方法 取句柄 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (INT_P)nativeImageAttr;


    }

    方法 取最后状态 <公开 类型 = 整数 注释 = "GetLastStatus" 注释 = "本对象最近方法失败的状态。" @禁止流程检查 = 真>
    {
        @ Gdiplus::Status lastStatus = lastResult;
        @ lastResult = Gdiplus::Ok;
        @ return (int)lastStatus;
    }

    #

    方法 销毁 <公开 注释 = "可以手动销毁, 但超出作用域也会自动销毁." @嵌入式方法 = "">
    {
        @ @sn<this>.Destory();

    }

    方法 克隆 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "创建一个新的 GP图像属性类 对象，该对象是本对象的副本。" @禁止流程检查 = 真>
    参数 参数_新属性 <类型 = GP图像属性类 "">
    {
        @ @<参数_新属性>.Destory();
        @ Gdiplus::GpImageAttributes* clone;
        @ SetStatus(Gdiplus::DllExports::GdipCloneImageAttributes(nativeImageAttr, &clone));
        @ @<参数_新属性>.nativeImageAttr = clone;
        @ @<参数_新属性>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ this->Destory();
        @ lastResult = Gdiplus::DllExports::GdipCreateImageAttributes(&nativeImageAttr);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 置到标准 <公开 类型 = 逻辑型 注释 = "SetToIdentity" 注释 = "将指定类别的颜色调整矩阵设置为单位矩阵。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_类型 <类型 = GP颜色调整类型 @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetImageAttributesToIdentity( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型> ) ) == Gdiplus::Ok;

    }

    方法 重置 <公开 类型 = 逻辑型 注释 = "Reset" 注释 = "清除指定类别的所有颜色和灰度调整设置。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_类型 <类型 = GP颜色调整类型 注释 = "用于指定重置颜色调整的类别。" @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipResetImageAttributes( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型> ) ) == Gdiplus::Ok;

    }

    方法 置颜色矩阵 <公开 类型 = 逻辑型 注释 = "SetColorMatrix" 注释 = "设置指定类别的颜色调整矩阵。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_颜色矩阵 <类型 = GP颜色矩阵类 注释 = "颜色矩阵是一个5x5的二维数组。">
    参数 参数_模式 <类型 = GP颜色矩阵标志 注释 = "指定将受颜色调整矩阵影响的图像和颜色的类型。" @默认值 = GP颜色矩阵标志.默认>
    参数 参数_类型 <类型 = GP颜色调整类型 注释 = "指定为其设置颜色调整矩阵的类别。" @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetImageAttributesColorMatrix( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型>, TRUE, @<参数_颜色矩阵>.ptr(), NULL, (Gdiplus::ColorMatrixFlags)@<参数_模式> )) == Gdiplus::Ok;

    }

    方法 置颜色矩阵2 <公开 类型 = 逻辑型 注释 = "SetColorMatrix" 注释 = "设置指定类别的颜色调整矩阵。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
