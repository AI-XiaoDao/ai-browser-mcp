类 GP颜色矩阵类 <公开 注释 = "ColorMatrix" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus\"" "">
{

    # @begin
    # <> <include>
    # Gdiplus::ColorMatrix m_data;
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    # void @an<_OnInitExtra> ()
    # {
    #     reset();
    # }
    # void reset(){
    #     m_data.m[0][0] = 1.0f;
    #     m_data.m[0][1] = 0.0f;
    #     m_data.m[0][2] = 0.0f;
    #     m_data.m[0][3] = 0.0f;
    #     m_data.m[0][4] = 0.0f;
    #
    #     m_data.m[1][0] = 0.0f;
    #     m_data.m[1][1] = 1.0f;
    #     m_data.m[1][2] = 0.0f;
    #     m_data.m[1][3] = 0.0f;
    #     m_data.m[1][4] = 0.0f;
    #     
    #     m_data.m[2][0] = 0.0f;
    #     m_data.m[2][1] = 0.0f;
    #     m_data.m[2][2] = 1.0f;
    #     m_data.m[2][3] = 0.0f;
    #     m_data.m[2][4] = 0.0f;
    #     
    #     m_data.m[3][0] = 0.0f;
    #     m_data.m[3][1] = 0.0f;
    #     m_data.m[3][2] = 0.0f;
    #     m_data.m[3][3] = 1.0f;
    #     m_data.m[3][4] = 0.0f;
    #     
    #     m_data.m[4][0] = 0.0f;
    #     m_data.m[4][1] = 0.0f;
    #     m_data.m[4][2] = 0.0f;
    #     m_data.m[4][3] = 0.0f;
    #     m_data.m[4][4] = 1.0f;    
    # }
    #
    # Gdiplus::ColorMatrix* ptr()
    # {
    #     return &m_data;
    # }
    #
    # Gdiplus::ColorMatrix& data()
    # {
    #     return m_data;
    # }
    #
    # <> </include>
    # @end

    方法 取指针 <公开 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.ptr()
    }

    方法 重置 <公开 @嵌入式方法 = "">
    {
        @ @sn<this>.reset()
    }

    方法 置红色 <公开 @禁止流程检查 = 真>
    参数 参数_比例因子 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        @ m_data.m[3][0] = (Gdiplus::REAL)@<参数_比例因子>;
    }

    方法 置绿色 <公开 @禁止流程检查 = 真>
    参数 参数_比例因子 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        @ m_data.m[3][1] = (Gdiplus::REAL)@<参数_比例因子>;
    }

    方法 置蓝色 <公开 @禁止流程检查 = 真>
    参数 参数_比例因子 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        @ m_data.m[3][2] = (Gdiplus::REAL)@<参数_比例因子>;
    }

    方法 置透明度 <公开 @禁止流程检查 = 真>
    参数 参数_比例因子 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        @ m_data.m[3][3] = (Gdiplus::REAL)@<参数_比例因子>;
    }

    方法 亮度 <公开 @禁止流程检查 = 真>
    参数 参数_比例因子 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        @ m_data.m[4][0] = m_data.m[4][1] = m_data.m[4][2] =(Gdiplus::REAL)@<参数_比例因子>;
    }

    方法 去色 <公开 @禁止流程检查 = 真>
    {
        @ m_data.m[0][0] = m_data.m[0][1] = m_data.m[0][2] = 0.229f;
        @ m_data.m[1][0] = m_data.m[1][1] = m_data.m[1][2] = 0.587f;
        @ m_data.m[2][0] = m_data.m[2][1] = m_data.m[2][2] = 0.114f;
    }

    方法 反相 <公开 @禁止流程检查 = 真>
    {
        @ m_data.m[0][0] = m_data.m[1][1] = m_data.m[2][2] = -1.0f;
        @ m_data.m[3][0] = m_data.m[3][1] = m_data.m[3][2] = 0.999f;
    }

    方法 对比度 <公开 @禁止流程检查 = 真>
    参数 参数_对比度 <类型 = 小数 注释 = "0-2 之间">
    {
        @ m_data.m[0][0] = m_data.m[1][1] = m_data.m[2][2] = (Gdiplus::REAL)@<参数_对比度>;
        @ m_data.m[3][0] = m_data.m[3][1] = m_data.m[3][2] = 0.001f;
    }

    方法 饱和度 <公开 @禁止流程检查 = 真>
    参数 参数_饱和度 <类型 = 小数 注释 = "0-2 之间">
    {
        @ m_data.m[0][0] = m_data.m[0][1] = m_data.m[0][2] = (1.0f - (Gdiplus::REAL)@<参数_饱和度>) * 0.229f;
        @ m_data.m[1][0] = m_data.m[1][1] = m_data.m[1][2] = (1.0f - (Gdiplus::REAL)@<参数_饱和度>) * 0.587f;
        @ m_data.m[2][0] = m_data.m[2][1] = m_data.m[2][2] = (1.0f - (Gdiplus::REAL)@<参数_饱和度>) * 0.114f;
        @ m_data.m[0][0]+=(Gdiplus::REAL)@<参数_饱和度>;
        @ m_data.m[1][1]+=(Gdiplus::REAL)@<参数_饱和度>;
        @ m_data.m[2][2]+=(Gdiplus::REAL)@<参数_饱和度>;
    }

    方法 色相 <公开 @禁止流程检查 = 真 @视窗.外部头文件 = "<cmath>">
    参数 参数_色相 <类型 = 整数 注释 = "-180 到 180 之间">
    {
        @ float f = (@<参数_色相> / 180) * 3.1415926535f;
        @ float cosval = std::cosf(f);
        @ m_data.m[0][0] = m_data.m[1][1] = m_data.m[2][2] =  cosval < 0.0f ? 0.0f : cosval;
        @ m_data.m[0][1] = m_data.m[1][2] = m_data.m[2][0] =  f < 0.0f ? (cosval < 0.0f ? -cosval : 0.0f) : (cosval < 0 ?  1.0f + cosval : 1.0f - cosval);
        @ m_data.m[0][2] = m_data.m[1][0] = m_data.m[2][1] =  f < 0.0f ? (cosval < 0.0f ?  1.0f + cosval : 1.0f - cosval) : (cosval < 0.0f ?  -cosval : 0.0f);
    }

    #
}

# ====

类 GP状态 <公开 注释 = "Status" 折叠 @文档 = "category = \"图像处理库.Gdiplus.枚举\"">
{
    常量 成功 <公开 类型 = 整数 值 = 0 注释 = "Ok">
    常量 通用错误 <公开 类型 = 整数 值 = 1 注释 = "GenericError">
    常量 无效参数 <公开 类型 = 整数 值 = 2 注释 = "InvalidParameter">
    常量 内存不足 <公开 类型 = 整数 值 = 3 注释 = "OutOfMemory">
    常量 对象繁忙 <公开 类型 = 整数 值 = 4 注释 = "ObjectBusy">
    常量 缓冲区不足 <公开 类型 = 整数 值 = 5 注释 = "InsufficientBuffer">
    常量 未实现 <公开 类型 = 整数 值 = 6 注释 = "NotImplemented">
    常量 Win32错误 <公开 类型 = 整数 值 = 7 注释 = "Win32Error">
    常量 错误状态 <公开 类型 = 整数 值 = 8 注释 = "WrongState">
    常量 中止 <公开 类型 = 整数 值 = 9 注释 = "Aborted">
    常量 文件未找到 <公开 类型 = 整数 值 = 10 注释 = "FileNotFound">
    常量 值溢出 <公开 类型 = 整数 值 = 11 注释 = "ValueOverflow">
    常量 拒绝访问 <公开 类型 = 整数 值 = 12 注释 = "AccessDenied">
    常量 未知图像格式 <公开 类型 = 整数 值 = 13 注释 = "UnknownImageFormat">
    常量 字体族未找到 <公开 类型 = 整数 值 = 14 注释 = "FontFamilyNotFound">
    常量 字体风格未找到 <公开 类型 = 整数 值 = 15 注释 = "FontStyleNotFound">
    常量 非TrueType字体 <公开 类型 = 整数 值 = 16 注释 = "NotTrueTypeFont">
    常量 不支持的Gdiplus版本 <公开 类型 = 整数 值 = 17 注释 = "UnsupportedGdiplusVersion">
    常量 未初始化Gdiplus <公开 类型 = 整数 值 = 18 注释 = "GdiplusNotInitialized">
    常量 属性未找到 <公开 类型 = 整数 值 = 19 注释 = "PropertyNotFound">
    常量 属性不支持 <公开 类型 = 整数 值 = 20 注释 = "PropertyNotSupported">

    #
}

