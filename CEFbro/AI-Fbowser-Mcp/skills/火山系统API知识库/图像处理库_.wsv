类 GP路径迭代器类 <公开 注释 = "GraphicsPathIterator" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{

    # @begin
    # <> <include>
    # Gdiplus::GpPathIterator* nativeIterator;
    # mutable Gdiplus::Status lastResult;
