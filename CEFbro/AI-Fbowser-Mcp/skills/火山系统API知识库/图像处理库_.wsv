    方法 取值成员数 <公开 类型 = 整数 注释 = "NumberOfValues" @嵌入式方法 = "">
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ @sn<this>.ptr()->Parameter[@<参数_索引>].NumberOfValues


    }

    方法 取值 <公开 类型 = 字节集类 注释 = "Value 获取任意类型值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ void* ptr = ptr()->Parameter[@<参数_索引>].Value;
        @ if(!ptr)    return CVolMem();
        @ ULONG len = get_value_bytes_len(ptr()->Parameter[@<参数_索引>]);
        @ return CVolMem((BYTE*)ptr, len);


    }

    方法 取值文本 <公开 类型 = 文本型 注释 = "Value 获取 ASCII 值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ const char* ptr = (const char*)ptr()->Parameter[@<参数_索引>].Value;
        @ if(!ptr)    return @an<CVolString>();
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const WCHAR* pws = GetWideText (ptr, memBuf, &npResultTextLength);
        @ return @an<CVolString> (pws, npResultTextLength);

    }

    方法 取值字节 <公开 类型 = 字节 注释 = "Value 获取字节值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ return *((S_BYTE*)ptr()->Parameter[@<参数_索引>].Value);


    }

    方法 取值短整数 <公开 类型 = 短整数 注释 = "Value 获取短整数值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ return *((short*)ptr()->Parameter[@<参数_索引>].Value);


    }

    方法 取值整数 <公开 类型 = 整数 注释 = "Value 获取整数值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ return *((INT*)ptr()->Parameter[@<参数_索引>].Value);


    }

    方法 取值整数数组 <公开 类型 = 整数数组类 注释 = "Value 获取 分数,整数范围 和 分数范围 类型的值" @禁止流程检查 = 真>
    参数 参数_索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ ULONG type = ptr()->Parameter[@<参数_索引>].Type;
        @ ULONG numberOfVal = ptr()->Parameter[@<参数_索引>].NumberOfValues;
        @ ULONG count = 0;
        @ switch(type)
        @ {
        @        case Gdiplus::EncoderParameterValueTypeRational: count = 2 * numberOfVal; break;
        @        case Gdiplus::EncoderParameterValueTypeLongRange: count = 2 * numberOfVal; break;
        @        case Gdiplus::EncoderParameterValueTypeRationalRange: count = 4 * numberOfVal; break;
        @        default: break;
        @ }
        @ @dt<整数数组类> arr;
        @ if(count == 0) return arr;
        @ arr.data().Append((INT*)ptr()->Parameter[@<参数_索引>].Value, count);
        @ return arr;


    }
}

