类 GP阴影画刷类 <公开 基础类 = GP画刷类 注释 = "HatchBrush" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{
    方法 创建 <公开 类型 = 逻辑型 注释 = "基于填充样式、前景色和背景色创建 阴影画刷 对象。" @禁止流程检查 = 真>
    参数 参数_阴影风格 <类型 = GP阴影风格 注释 = "GP阴影风格 枚举常量，用于指定将使用的填充线图案。">
    参数 参数_前景色 <类型 = 整数 注释 = "用于阴影线的颜色" "">
    参数 参数_背景色 <类型 = 整数 注释 = "用于背景的颜色" @默认值 = 0>
    {
        @ this->Destory();
        @ Gdiplus::GpHatch *brush = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateHatchBrush((Gdiplus::HatchStyle)@<参数_阴影风格>, @<参数_前景色>, @<参数_背景色>, &brush);
        @ SetNativeBrush(brush);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 取阴影风格 <公开 类型 = GP阴影风格 注释 = "GetHatchStyle" @禁止流程检查 = 真>
    {
        @ Gdiplus::HatchStyle hatchStyle;
        @ SetStatus(Gdiplus::DllExports::GdipGetHatchStyle((Gdiplus::GpHatch*)nativeBrush, &hatchStyle));
        @ return (@dt<GP阴影风格>)hatchStyle;

    }

    方法 取前景色 <公开 类型 = 整数 注释 = "GetForegroundColor" @禁止流程检查 = 真>
    {
        @ Gdiplus::ARGB argb;
        @ SetStatus(Gdiplus::DllExports::GdipGetHatchForegroundColor((Gdiplus::GpHatch*)nativeBrush, &argb));
        @ return argb;

    }

    方法 取背景色 <公开 类型 = 整数 注释 = "GetBackgroundColor" @禁止流程检查 = 真>
    {
        @ Gdiplus::ARGB argb;
        @ SetStatus(Gdiplus::DllExports::GdipGetHatchBackgroundColor((Gdiplus::GpHatch*)nativeBrush, &argb));
        @ return argb;

    }

    #
}

