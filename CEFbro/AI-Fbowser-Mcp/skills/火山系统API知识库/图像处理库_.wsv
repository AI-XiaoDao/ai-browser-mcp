类 GP编码器参数值类型 <公开 注释 = "EncoderParameterValueType" 注释 = "图像编码器参数相关类型" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\""
        @常量类 = 整数>
{
    常量 字节型 <公开 值 = 1 注释 = "EncoderParameterValueTypeByte" 注释 = "指定参数是一个 8 位无符号整数。">
    常量 ASCII <公开 值 = 2 注释 = "EncoderParameterValueTypeASCII" 注释 = "指定参数是一个以空字符结尾的ASCII字符串。">
    常量 短整数型 <公开 值 = 3 注释 = "EncoderParameterValueTypeShort" 注释 = "指定参数是一个 16 位无符号整数">
    常量 整数型 <公开 值 = 4 注释 = "EncoderParameterValueTypeLong" 注释 = "指定参数是一个 32 位无符号整数">
    常量 分数 <公开 值 = 5 注释 = "EncoderParameterValueTypeRational" 注释 = "指定参数是两个 32 位无符号整数的数组。"
            注释 = "这对整数代表一个分数。 该对中的第一个整数是分子，该对中的第二个整数是分母。">
    常量 整数范围 <公开 值 = 6 注释 = "EncoderParameterValueTypeLongRange" 注释 = "指定参数是两个 32 位无符号整数的数组。"
            注释 = "这对整数表示一个数字范围。 第一个整数是范围内的最小数，第二个整数是范围内的最大数。">
    常量 未定义 <公开 值 = 7 注释 = "EncoderParameterValueTypeUndefined" 注释 = "指定参数是一个字节数组，可以保存任何类型的值。">
    常量 分数范围 <公开 值 = 8 注释 = "EncoderParameterValueTypeRationalRange" 注释 = "指定参数是一个由四个 32 位无符号整数组成的数组。"
            注释 = "前两个整数代表一个分数，后两个整数代表第二个分数。" 注释 = "这两个分数代表一系列分数。 第一个分数是范围内最小的分数，第二个分数是范围内最大的分数。">

    #
}

类 GP图像编解码标志 <公开 注释 = "ImageCodecFlags" 注释 = "关于图像编解码器的信息标志" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"">
{
    常量 编码 <公开 类型 = 整数 值 = 0x00000001 注释 = "ImageCodecFlagsEncoder" 注释 = "表示编解码器支持编码（保存）。">
    常量 解码 <公开 类型 = 整数 值 = 0x00000002 注释 = "ImageCodecFlagsDecoder" 注释 = "表示编解码器支持解码（读取）。">
    常量 支持位图 <公开 类型 = 整数 值 = 0x00000004 注释 = "ImageCodecFlagsSupportBitmap" 注释 = "表示编解码器支持光栅图像（位图）。">
    常量 支持向量 <公开 类型 = 整数 值 = 0x00000008 注释 = "ImageCodecFlagsSupportVector" 注释 = "表示编解码器支持矢量图像（元文件）。">
    常量 可搜索编码 <公开 类型 = 整数 值 = 0x00000010 注释 = "ImageCodecFlagsSeekableEncode" 注释 = "表示编码器需要可查找的输出流。">
    常量 阻塞解码 <公开 类型 = 整数 值 = 0x00000020 注释 = "ImageCodecFlagsBlockingDecode" 注释 = "表示解码器在解码过程中有阻塞行为。">
    常量 内置 <公开 类型 = 整数 值 = 0x00010000 注释 = "ImageCodecFlagsBuiltin" 注释 = "表示编解码器内置于 GDI+。">
    常量 系统 <公开 类型 = 整数 值 = 0x00020000 注释 = "ImageCodecFlagsSystem" 注释 = "未在 GDI+ 1.0 版中使用。">
    常量 用户 <公开 类型 = 整数 值 = 0x00040000 注释 = "ImageCodecFlagsUser" 注释 = "未在 GDI+ 1.0 版中使用。">

    #
}

