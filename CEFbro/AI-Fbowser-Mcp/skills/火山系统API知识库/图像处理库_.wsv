类 GP缓存位图类 <公开 注释 = "CachedBitmap" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{

    # @begin
    # <> <include>
    # Gdiplus::GpCachedBitmap* nativeCachedBitmap;
    # mutable Gdiplus::Status lastResult;
    #
    # void @an<_OnInitExtra> ()    //初始化
    # {
    #     lastResult = Gdiplus::Ok;
    #     nativeCachedBitmap = NULL;
    # }
    #
    # void @an<_OnCleanupExtra> () //销毁
    # {
    #     this->Destory();
    # }
    #
    # void Destory()
    # {
    #     if (nativeCachedBitmap)
    #         Gdiplus::DllExports::GdipDeleteCachedBitmap(nativeCachedBitmap);
    #     nativeCachedBitmap = NULL;
    #     lastResult = Gdiplus::Ok;
    # }
    #
    # BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return nativeCachedBitmap == objCompare.nativeCachedBitmap;
    # }
    #
    # Gdiplus::Status SetStatus(Gdiplus::Status status) const
    # {
    #     if (status != Gdiplus::Ok)
    #         return (lastResult = status);
    #     else 
    #         return status;
    # }
    #
    # <> </include>
    # @end

    方法 取句柄 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (INT_P)nativeCachedBitmap;

    }

    方法 取最后状态 <公开 类型 = 整数 注释 = "GetLastStatus" 注释 = "本对象最近方法失败的状态。" @禁止流程检查 = 真>
    {
        @ Gdiplus::Status lastStatus = lastResult;
        @ lastResult = Gdiplus::Ok;
        @ return (int)lastStatus;
    }

    #

    方法 销毁 <公开 注释 = "可以手动销毁, 但超出作用域也会自动销毁." @嵌入式方法 = "">
    {
        @ @sn<this>.Destory();

    }

    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_位图 <类型 = GP位图类>
    参数 参数_图形 <类型 = GP图形类>
    {
        @ this->Destory();
        @ lastResult = Gdiplus::DllExports::GdipCreateCachedBitmap((Gdiplus::GpBitmap *)@<参数_位图>.nativeImage, @<参数_图形>.nativeGraphics, &nativeCachedBitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    #
}

