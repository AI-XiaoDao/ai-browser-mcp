        @     (float)@<参数_原图左边>, (float)@<参数_原图顶边>, (float)@<参数_原图宽度>, (float)@<参数_原图高度>, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, (Gdiplus::DrawImageAbort)@<参数_中断回调函数>, (VOID*)@<参数_回调参数>)) == Gdiplus::Ok;

