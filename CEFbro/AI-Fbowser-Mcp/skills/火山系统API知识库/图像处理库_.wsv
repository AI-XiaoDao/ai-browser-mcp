    }

    方法 清除颜色矩阵 <公开 类型 = 逻辑型 注释 = "ClearColorMatrix" 注释 = "清除指定类别的颜色调整矩阵。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_类型 <类型 = GP颜色调整类型 注释 = "指定清除颜色调整矩阵的类别。" @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetImageAttributesColorMatrix( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型> , FALSE, NULL, NULL, Gdiplus::ColorMatrixFlagsDefault )) == Gdiplus::Ok;

    }

    方法 置临界值 <公开 类型 = 逻辑型 注释 = "SetThreshold" 注释 = "设置指定类别的临界值（透明度范围）。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_临界值 <类型 = 小数 注释 = "临界值是一个从0到1，指定每个颜色成分分界点。" 注释 = "例如，假设临界值为0.7，假设你是提供一种颜色的红，绿，蓝230，50，220。"
            注释 = "红色部分，230>0.7 × 255，因此红色成分将改为255（全强度）。绿色部分，50<0.7 × 255，所以绿色成分将被更改为0。蓝色的部分，220>0.7 × 255，所以蓝色部分将改为255">
    参数 参数_类型 <类型 = GP颜色调整类型 注释 = "指定为其设置颜色临界值的类别。" @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetImageAttributesThreshold( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型>, TRUE, (float)@<参数_临界值>) ) == Gdiplus::Ok ;

    }

    方法 清除临界值 <公开 类型 = 逻辑型 注释 = "ClearThreshold" 注释 = "清除指定类别的临界值。" 返回值注释 = "成功返回真,失败返回假" @禁止流程检查 = 真>
    参数 参数_类型 <类型 = GP颜色调整类型 注释 = "指定为其清除颜色临界值的类别。" @默认值 = GP颜色调整类型.默认>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetImageAttributesThreshold( nativeImageAttr, (Gdiplus::ColorAdjustType)@<参数_类型>, FALSE, 0.0f )) == Gdiplus::Ok ;

    }

