        @ if (type != Gdiplus::PenTypeSolidColor) 
        @ {
        @      return FALSE;
        @ }
        @ Gdiplus::ARGB argb;
        @ SetStatus(Gdiplus::DllExports::GdipGetPenColor(nativePen, &argb));
        @ if(lastResult == Gdiplus::Ok)
        @ {
        @     @<参数_颜色>.data().SetValue(argb);
        @ }
        @ return lastResult == Gdiplus::Ok;
    }

