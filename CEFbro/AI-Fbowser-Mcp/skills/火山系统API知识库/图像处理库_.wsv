    方法 是否单位矩阵 <公开 类型 = 逻辑型 注释 = "IsIdentity" 注释 = "确定此矩阵是否为单位矩阵。" @禁止流程检查 = 真>
    {
        @ BOOL result = FALSE;
        @ SetStatus(Gdiplus::DllExports::GdipIsMatrixIdentity(nativeMatrix, &result));
        @ return result;

    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "Equals" 注释 = "确定此矩阵的元素是否等于另一个矩阵的元素。" @禁止流程检查 = 真>
    参数 参数_矩阵 <类型 = GP矩阵类 注释 = "要比较的矩阵">
    {
        @ BOOL result = FALSE;
        @ SetStatus(Gdiplus::DllExports::GdipIsMatrixEqual(nativeMatrix,@<参数_矩阵>.nativeMatrix, &result));
        @ return result;

    }

    #
}

