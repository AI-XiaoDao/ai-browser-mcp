类 GP位图类 <公开 基础类 = GP图像类 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"图像处理库.Gdiplus\"" @视窗.外部头文件 = "<combaseapi.h>,<winbase.h>">
{

    #

    方法 创建自文件 <公开 类型 = 逻辑型 注释 = "FromFile" 注释 = "基于文件创建一个 GP位图类 对象。" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_文件名 <类型 = 文本型 注释 = "图像文件路径">
    参数 参数_使用嵌入式色彩管理 <类型 = 逻辑型 注释 = "可选的。 指定新 GP位图类 对象是否根据嵌入在文件中的颜色管理信息应用颜色校正。" 注释 = "嵌入的信息可以包括国际色彩联盟 (ICC) 配置文件、伽马值和色度信息。"
            注释 = "真 指定启用色彩校正，假 指定不启用色彩校正。 默认值为 假。" @默认值 = 假>
    {
        @ this->Destory();
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ if(@<参数_使用嵌入式色彩管理>)
        @ {
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromFileICM(@<参数_文件名>, &bitmap);
        @ }
        @ else{      
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromFile(@<参数_文件名>, &bitmap);
        @ }
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "FromStream" 注释 = "基于字节集创建一个新的 GP位图类 对象。" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_字节集 <类型 = 字节集类 注释 = "图像字节集数据">
    参数 参数_使用嵌入式色彩管理 <类型 = 逻辑型 注释 = "可选的。 指定新 GP位图类 对象是否根据嵌入在字节集中的颜色管理信息应用颜色校正。" 注释 = "嵌入的信息可以包括国际色彩联盟 (ICC) 配置文件、伽马值和色度信息。"
            注释 = "真 指定启用色彩校正，假 指定不启用色彩校正。 默认值为 假。" @默认值 = 假>
    {
        @ this->Destory();
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ m_stream = CreateStream(@<参数_字节集>);
        @ if(@<参数_使用嵌入式色彩管理>)
        @ {
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromStreamICM(m_stream, &bitmap);
        @ }
        @ else{      
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromStream(m_stream, &bitmap);
        @ }
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建自扫描行 <公开 类型 = 逻辑型 注释 = "基于字节数组以及大小和格式信息创建一个 Bitmap::Bitmap 对象。" @禁止流程检查 = 真>
    参数 参数_宽度 <类型 = 整数 注释 = "指定位图宽度（以像素为单位）的整数。">
    参数 参数_高度 <类型 = 整数 注释 = "指定位图高度（以像素为单位）的整数。">
    参数 参数_跨度 <类型 = 整数 注释 = "指定相邻扫描行开始处之间字节偏移量的整数。" 注释 = "这通常（但不一定）是以像素格式表示的字节数（例如，2 表示每像素 16 位）乘以位图的宽度。"
            注释 = "传递给此参数的值必须为 4 的倍数。提供一个公式：左移(右移(参数_宽度*位深+31,5),2)">
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量">
    参数 参数_像素数据 <类型 = 字节集类 注释 = "指向包含像素数据。" @默认值 = 空对象>
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromScan0(@<参数_宽度>, @<参数_高度>, @<参数_跨度>, @<参数_像素格式>, (BYTE*)@<参数_像素数据>.GetPtr(),&bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自像素格式 <公开 类型 = 逻辑型 注释 = "创建一个指定大小和像素格式的 GP位图类 对象。" @禁止流程检查 = 真>
    参数 参数_宽度 <类型 = 整数 注释 = "指定位图宽度（以像素为单位）的整数。">
    参数 参数_高度 <类型 = 整数 注释 = "指定位图高度（以像素为单位）的整数。">
    参数 参数_像素格式 <类型 = 整数 注释 = "GP像素格式 常量" @默认值 = GP像素格式._32bppARGB>
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromScan0(@<参数_宽度>, @<参数_高度>,0, @<参数_像素格式>, NULL,&bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自图形 <公开 类型 = 逻辑型 注释 = "基于 GP图形类 对象、宽度和高度创建 GP位图类 对象。" @禁止流程检查 = 真>
    参数 参数_宽度 <类型 = 整数 注释 = "指定位图宽度（以像素为单位）的整数。">
    参数 参数_高度 <类型 = 整数 注释 = "指定位图高度（以像素为单位）的整数。">
    参数 参数_图形 <类型 = GP图形类 注释 = "该对象包含用于初始化新 GP位图类 对象的某些属性（例如，每英寸点数）的信息。">
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
