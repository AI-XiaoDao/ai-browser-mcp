    方法 复制 <公开 类型 = 逻辑型 注释 = "BitBlt" 注释 = "此方法不支持透明，但速度最快" @禁止流程检查 = 真>
    参数 参数_设备场景 <类型 = 变整数 注释 = "HDC 目标设备场景">
    参数 参数_左边 <类型 = 整数 注释 = "目标左边" @默认值 = 0>
    参数 参数_顶边 <类型 = 整数 注释 = "目标顶边" @默认值 = 0>
    参数 参数_宽度 <类型 = 整数 注释 = "目标宽度, -1 表示缓存图形的宽度" @默认值 = -1>
    参数 参数_高度 <类型 = 整数 注释 = "目标高度, -1 表示缓存图形的高度" @默认值 = -1>
    参数 参数_源左边 <类型 = 整数 @默认值 = 0>
    参数 参数_源顶边 <类型 = 整数 @默认值 = 0>
    参数 参数_光栅操作 <类型 = 整数 注释 = "默认: SRCCOPY" @默认值 = 13369376>
    {
        @ if(@<参数_宽度> == -1)
        @     @<参数_宽度> = m_Width;
        @ if(@<参数_高度> == -1)
        @     @<参数_高度> = m_Height;
        @ BOOL ret = ::BitBlt((HDC)@<参数_设备场景>, @<参数_左边>, @<参数_顶边>, @<参数_宽度>, @<参数_高度>, m_hdc, @<参数_源左边>, @<参数_源顶边>, @<参数_光栅操作>);
        @ return SetStatus(ret? Gdiplus::Ok: Gdiplus::GenericError) == Gdiplus::Ok;
    }

    方法 复制到窗口 <公开 类型 = 逻辑型 注释 = "BitBlt" 注释 = "此方法不支持透明，但速度最快" 折叠2 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "目标窗口句柄">
    参数 参数_左边 <类型 = 整数 注释 = "目标左边" @默认值 = 0>
    参数 参数_顶边 <类型 = 整数 注释 = "目标顶边" @默认值 = 0>
    参数 参数_宽度 <类型 = 整数 注释 = "目标宽度, -1 表示缓存图形的宽度" @默认值 = -1>
    参数 参数_高度 <类型 = 整数 注释 = "目标高度, -1 表示缓存图形的高度" @默认值 = -1>
    参数 参数_源左边 <类型 = 整数 @默认值 = 0>
    参数 参数_源顶边 <类型 = 整数 @默认值 = 0>
    参数 参数_光栅操作 <类型 = 整数 注释 = "默认: SRCCOPY" @默认值 = 13369376>
    {
        @ HWND hwnd=(HWND)@<窗口句柄>;
        @ HDC hdc = ::GetDC(hwnd);
