    方法 枚举 <公开 类型 = 整数 注释 = "Enumerate" @禁止流程检查 = 真>
    参数 参数_坐标组 <类型 = 数组坐标F 注释 = "输出参数">
    参数 参数_类型组 <类型 = 字节集类 注释 = "输出参数">
    {
        @ INT resultCount;
        @ SetStatus(Gdiplus::DllExports::GdipPathIterGetCount(nativeIterator, &resultCount));
        @ @<参数_坐标组>.data().resize(resultCount);
        @ @<参数_类型组>.Realloc(resultCount);
        @ SetStatus(Gdiplus::DllExports::GdipPathIterEnumerate(nativeIterator, &resultCount, @<参数_坐标组>.data().data(), (BYTE *)@<参数_类型组>.GetPtr(), resultCount));
        @ return resultCount;
    }

    方法 复制数据 <公开 类型 = 整数 注释 = "CopyData" @禁止流程检查 = 真>
    参数 参数_开始索引 <类型 = 整数>
    参数 参数_结束索引 <类型 = 整数>
    参数 参数_坐标组 <类型 = 数组坐标F 注释 = "输出参数">
    参数 参数_类型组 <类型 = 字节集类 注释 = "输出参数">
    {
        @ INT resultCount;
        @ SetStatus(Gdiplus::DllExports::GdipPathIterGetCount(nativeIterator, &resultCount));
        @ @<参数_坐标组>.data().resize(resultCount);
        @ @<参数_类型组>.Realloc(resultCount);
        @ SetStatus(Gdiplus::DllExports::GdipPathIterCopyData(nativeIterator, &resultCount, @<参数_坐标组>.data().data(), (BYTE *)@<参数_类型组>.GetPtr(), @<参数_开始索引>, @<参数_结束索引>));
        @ return resultCount;
    }

    #
}

类 GP路径渐变画刷类 <公开 基础类 = GP画刷类 注释 = "PathGradientBrush" 折叠 @文档 = "category = \"图像处理库.Gdiplus\"">
{

    # @begin
    # <> <include>
    # BOOL GetFocusScales(OUT DOUBLE& xScale, 
    #                           OUT DOUBLE& yScale) const
    # {
    #      return SetStatus(Gdiplus::DllExports::GdipGetPathGradientFocusScales(
    #                             (Gdiplus::GpPathGradient*) nativeBrush, (Gdiplus::REAL*)&xScale, (Gdiplus::REAL*)&yScale)) == Gdiplus::Ok;
