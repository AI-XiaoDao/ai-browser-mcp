    方法 更新到分层窗口 <公开 类型 = 逻辑型 注释 = "UpdateLayeredWindow" @禁止流程检查 = 真>
    参数 参数_窗口句柄 <类型 = 变整数 注释 = "分层窗口的句柄">
    参数 参数_hdc <类型 = 变整数 注释 = "屏幕 DC 的句柄。用于更新窗口内容时的调色板颜色匹配。0 表示使用默认调色板" @默认值 = 0>
    参数 参数_窗口尺寸 <类型 = 尺寸L 注释 = "指向指定分层窗口新大小, 默认为当前缓存图形大小" @默认值 = 空对象>
    参数 参数_源位置 <类型 = 坐标L 注释 = "0-255，默认为255" @默认值 = 空对象>
    参数 参数_不透明度 <类型 = 整数 注释 = "0-255，默认为255" @默认值 = 255>
    {
        @ if(@<参数_窗口尺寸>.IsNullObject())
        @ {
        @     @<参数_窗口尺寸>.data().Width = m_Width;
        @     @<参数_窗口尺寸>.data().Height = m_Height;
        @ }
        @ BLENDFUNCTION bf = {0};
        @ bf.BlendOp = AC_SRC_OVER;
        @ bf.BlendFlags = 0;
        @ bf.AlphaFormat = AC_SRC_ALPHA;
        @ bf.SourceConstantAlpha = @<参数_不透明度>;
        @ BOOL ret = ::UpdateLayeredWindow((HWND)@<参数_窗口句柄>, (HDC)@<参数_hdc>, NULL, (SIZE*)@<参数_窗口尺寸>.ptr(), m_hdc, (POINT*)@<参数_源位置>.ptr(), 0, &bf, ULW_ALPHA);
        @ return SetStatus(ret? Gdiplus::Ok: Gdiplus::GenericError) == Gdiplus::Ok;
    }

