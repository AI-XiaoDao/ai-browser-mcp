}

类 GP属性标签类型 <公开 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 短整数>
{
    常量 字节型 <公开 值 = 1 注释 = "PropertyTagTypeByte 指定值数据成员是一个字节数组。">
    常量 ASCII <公开 值 = 2 注释 = "PropertyTagTypeASCII 指定值数据成员是以空字符结尾的 ASCII 字符串。长度成员为字符串长度">
    常量 短整数型 <公开 值 = 3 注释 = "PropertyTagTypeShort 指定值数据成员是一个无符号短（16 位）整数数组。">
    常量 整数型 <公开 值 = 4 注释 = "PropertyTagTypeLong 指定值数据成员是一个无符号（32 位）整数数组。">
    常量 分数型 <公开 值 = 5 注释 = "PropertyTagTypeRational 指定值数据成员是无符号整数对的数组。每对代表一个分数；第一个整数是分子，第二个整数是分母。">
    常量 未定义 <公开 值 = 6 注释 = "PropertyTagTypeUndefined 指定值数据成员是一个字节数组，可以保存任何数据类型的值。">
    常量 有符号整数型 <公开 值 = 7 注释 = "PropertyTagTypeSLONG 指定值数据成员是有符号（32 位）整数数组。">
    常量 有符号分数型 <公开 值 = 8 注释 = "PropertyTagTypeSRational 指定值数据成员是有符号整数对的数组。每对代表一个分数；第一个整数是分子，第二个整数是分母。">

    #
}

类 GP属性标签 <公开 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @禁止创建对象 = 真>
{
    常量 新子文件类型 <公开 类型 = 整数 值 = @PropertyTagNewSubfileType 注释 = "子文件中的数据类型。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 子文件类型 <公开 类型 = 整数 值 = @PropertyTagSubfileType 注释 = "子文件中的数据类型。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 图像宽度 <公开 类型 = 整数 值 = @PropertyTagImageWidth 注释 = "每行的像素数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 1">
    常量 图像高度 <公开 类型 = 整数 值 = @PropertyTagImageHeight 注释 = "像素行数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 1">
    常量 位深 <公开 类型 = 整数 值 = @PropertyTagBitsPerSample 注释 = "每个颜色分量的位数。" 注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 压缩 <公开 类型 = 整数 值 = @PropertyTagCompression 注释 = "用于图像数据的压缩方案。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 光度学解释 <公开 类型 = 整数 值 = @PropertyTagPhotometricInterp 注释 = "如何解释像素数据。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 阈值 <公开 类型 = 整数 值 = @PropertyTagThreshHolding 注释 = "用于将灰色像素转换为黑白像素的技术。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 仿色或半色调宽 <公开 类型 = 整数 值 = @PropertyTagCellWidth 注释 = "仿色或半色调矩阵的宽度。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 仿色或半色调高 <公开 类型 = 整数 值 = @PropertyTagCellHeight 注释 = "仿色或半色调矩阵的高度。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 填充顺序 <公开 类型 = 整数 值 = @PropertyTagFillOrder 注释 = "字节中位的逻辑顺序。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 文档名称 <公开 类型 = 整数 值 = @PropertyTagDocumentName 注释 = "以 Null 结尾的字符串，该字符串指定从中扫描图像的文档的名称。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串的长度">
    常量 图像描述 <公开 类型 = 整数 值 = @PropertyTagImageDescription 注释 = "以 Null 结尾的字符串，指定图像的标题。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串的长度">
    常量 设备制造商 <公开 类型 = 整数 值 = @PropertyTagEquipMake 注释 = "以 Null 结尾的字符串，指定用于记录图像的设备制造商。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串的长度">
    常量 设备型号 <公开 类型 = 整数 值 = @PropertyTagEquipModel 注释 = "以 Null 结尾的字符串，指定用于记录图像的设备的型号名称或型号。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串的长度">
    常量 条带偏移量 <公开 类型 = 整数 值 = @PropertyTagStripOffsets 注释 = "对于每个条带，此条带的字节偏移量。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 条带数">
    常量 方向 <公开 类型 = 整数 值 = @PropertyTagOrientation 注释 = "在行和列中查看的图像方向。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 每像素采样数 <类型 = 整数 值 = @PropertyTagSamplesPerPixel 注释 = "每个像素的颜色分量数。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 每条带行数 <公开 类型 = 整数 值 = @PropertyTagRowsPerStrip 注释 = "每个条带的行数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 1">
    常量 条带字节数 <公开 类型 = 整数 值 = @PropertyTagStripBytesCount 注释 = "对于每个条带，该条带中的总字节数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 条带数">
    常量 最小采样值 <公开 类型 = 整数 值 = @PropertyTagMinSampleValue 注释 = "对于每个颜色分量，分配给该分量的最小值。" 注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 最大采样值 <公开 类型 = 整数 值 = @PropertyTagMaxSampleValue 注释 = "对于每个颜色分量，分配给该分量的最大值。" 注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 水平分辨率 <公开 类型 = 整数 值 = @PropertyTagXResolution 注释 = "图像宽度 (x) 方向的每个单位的像素数。" 注释 = "类型: 分数 , 成员数: 1">
    常量 垂直分辨率 <公开 类型 = 整数 值 = @PropertyTagYResolution 注释 = "图像高度 (y) 方向的每个单位的像素数。" 注释 = "类型: 分数 , 成员数: 1">
    常量 数据配置 <公开 类型 = 整数 值 = @PropertyTagPlanarConfig 注释 = "像素分量是以块状还是平面格式记录的。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 页名称 <公开 类型 = 整数 值 = @PropertyTagPageName 注释 = "以 Null 结尾的字符串，该字符串指定从中扫描图像的页面的名称。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串的长度">
    常量 水平位置 <公开 类型 = 整数 值 = @PropertyTagXPosition 注释 = "从页面左侧到图像左侧的偏移量。 度量单位由 PropertyTagResolutionUnit指定。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 垂直位置 <公开 类型 = 整数 值 = @PropertyTagYPosition 注释 = "从页面顶部到图像顶端的偏移量。 度量单位由 PropertyTagResolutionUnit指定。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 释放偏移 <公开 类型 = 整数 值 = @PropertyTagFreeOffset 注释 = "对于每个连续未使用的字符串，则为该字符串的字节偏移量。" 注释 = "类型: 整数型">
    常量 释放字节数 <公开 类型 = 整数 值 = @PropertyTagFreeByteCounts 注释 = "对于每个连续未使用字节的字符串，该字符串中的字节数。" 注释 = "类型: 整数型, 成员数: 连续未使用字节的字符串数。">
    常量 灰度单位 <公开 类型 = 整数 值 = @PropertyTagGrayResponseUnit
            注释 = "由 PropertyTagGrayResponseCurve 指定的数字的精度。 1 指定十分之一，2 指定百分之一，3 指定千分之几，依此类推。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 灰度密度 <公开 类型 = 整数 值 = @PropertyTagGrayResponseCurve 注释 = "对于灰度图像中每个可能的像素值，该像素值的光密度。" 注释 = "类型: 短整数型 , 成员数: 可能的像素值数量">
    常量 T4选项 <公开 类型 = 整数 值 = @PropertyTagT4Option 注释 = "与 T4 编码相关的一组标志。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 T6选项 <公开 类型 = 整数 值 = @PropertyTagT6Option 注释 = "与 T6 编码相关的一组标志。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 分辨率单位 <公开 类型 = 整数 值 = @PropertyTagResolutionUnit 注释 = "水平分辨率和垂直分辨率的测量单位。" 注释 = "类型: 整数型 , 成员数: 1, (2 英寸 3 厘米)">
    常量 页码 <公开 类型 = 整数 值 = @PropertyTagPageNumber 注释 = "扫描图像的页面的页码。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 转换函数 <公开 类型 = 整数 值 = @PropertyTagTransferFuncition 注释 = "指定图像转换函数的表。" 注释 = "类型: 短整数型 , 成员数: 表所需的 16 位字总数">
    常量 软件名 <公开 类型 = 整数 值 = @PropertyTagSoftwareUsed 注释 = "指定用于生成映像的设备的软件或固件的名称和版本的空终止字符串。"
            注释 = "类型: ASCII, 成员数: 包含 NULL 终止符的字符串长度">
    常量 创建时间 <公开 类型 = 整数 值 = @PropertyTagDateTime 注释 = "创建图像的日期和时间。" 注释 = "类型: ASCII, 成员数: 20">
    常量 作者 <公开 类型 = 整数 值 = @PropertyTagArtist 注释 = "指定创建图像的人的姓名的空终止字符串。" 注释 = "类型: ASCII, 成员数: 包含 NULL 终止符的字符串长度">
    常量 主机名 <公开 类型 = 整数 值 = @PropertyTagHostComputer 注释 = "指定用于创建图像的计算机和/或操作系统的空终止字符串。" 注释 = "类型: ASCII, 成员数: 包含 NULL 终止符的字符串长度">
    常量 预测器 <公开 类型 = 整数 值 = @PropertyTagPredictor 注释 = "在应用编码方案之前应用于图像数据的预测方案的类型。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 白点色度 <公开 类型 = 整数 值 = @PropertyTagWhitePoint 注释 = "图像白点的色度。" 注释 = "类型: 分数 , 成员数: 2">
    常量 主要色度 <公开 类型 = 整数 值 = @PropertyTagPrimaryChromaticities 注释 = "对于图像中三种基色中的每一种，该颜色的色度。" 注释 = "类型: 分数 , 成员数: 6">
    常量 调色板 <公开 类型 = 整数 值 = @PropertyTagColorMap 注释 = "调色板索引图像的调色板（查找表）。" 注释 = "类型: 短整数型 , 成员数: 调色板所需的 16 位字数">
    常量 半色调提示 <公开 类型 = 整数 值 = @PropertyTagHalftoneHints 注释 = "半色调功能使用的信息" 注释 = "类型: 短整数型 , 成员数: 2">
    常量 平铺宽度 <公开 类型 = 整数 值 = @PropertyTagTileWidth 注释 = "每个图块中的像素列数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 1">
    常量 平铺长度 <公开 类型 = 整数 值 = @PropertyTagTileLength 注释 = "每个图块中的像素行数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 1">
    常量 平铺偏移 <公开 类型 = 整数 值 = @PropertyTagTileOffset 注释 = "对于每个图块，该图块的字节偏移量。" 注释 = "类型: 整数型 , 成员数: 图块数">
    常量 平铺字节数 <公开 类型 = 整数 值 = @PropertyTagTileByteCounts 注释 = "对于每个图块，该图块中的字节数。" 注释 = "类型: 整数型 或 短整数型 , 成员数: 图块数">
    常量 置墨水 <公开 类型 = 整数 值 = @PropertyTagInkSet 注释 = "用于分离图像的油墨组。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 墨水名 <公开 类型 = 整数 值 = @PropertyTagInkNames 注释 = "以空字符结尾的串联字符串序列，用于指定分离图像中使用的油墨名称。"
            注释 = "类型: ASCII, 成员数: 包含 NULL 终止符的字符串长度">
    常量 墨水数 <公开 类型 = 整数 值 = @PropertyTagNumberOfInks 注释 = "墨水数量。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 点范围 <公开 类型 = 整数 值 = @PropertyTagDotRange 注释 = "对应于 0% 点和 100% 点的颜色分量值。" 注释 = "类型: 字节 或 短整数型 , 成员数: 2 或 2*每像素采样数">
    常量 打印目标 <公开 类型 = 整数 值 = @PropertyTagTargetPrinter 注释 = "描述预期打印环境的空终止字符串。" 注释 = "类型: ASCII, 成员数: 包含 NULL 终止符的字符串长度">
    常量 额外采样 <公开 类型 = 整数 值 = @PropertyTagExtraSamples 注释 = "额外颜色分量的数量。例如，一个额外的组件可能包含一个 alpha 值。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 采样格式 <公开 类型 = 整数 值 = @PropertyTagSampleFormat 注释 = "对于每个颜色分量，该分量的数字格式（无符号、有符号、浮点）。" 注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 最小采样值S <公开 类型 = 整数 值 = @PropertyTagSMinSampleValue 注释 = "对于每个颜色分量，该分量的最小值。" 注释 = "类型: 与像素分量数据最匹配的类型, 成员数: 每个像素的采样（分量）数">
    常量 最大采样值S <公开 类型 = 整数 值 = @PropertyTagSMaxSampleValue 注释 = "对于每个颜色分量，该分量的最大值。" 注释 = "类型: 与像素分量数据最匹配的类型, 成员数: 每个像素的采样（分量）数">
    常量 转换范围 <公开 类型 = 整数 值 = @PropertyTagTransferRange 注释 = "扩展转换函数范围的值表。" 注释 = "类型: 短整数型 , 成员数: 6">
    常量 ""
    常量 JPEG压缩 <公开 类型 = 整数 值 = @PropertyTagJPEGProc 注释 = "JPEG 压缩过程。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 JPEG格式 <公开 类型 = 整数 值 = @PropertyTagJPEGInterFormat 注释 = "JPEG 比特流开头的偏移量。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 JPEG长度 <公开 类型 = 整数 值 = @PropertyTagJPEGInterLength 注释 = "JPEG 比特流的长度，以字节为单位。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 JPEG重置间隔 <公开 类型 = 整数 值 = @PropertyTagJPEGRestartInterval 注释 = "重置间隔的长度。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 JPEG无损预测 <公开 类型 = 整数 值 = @PropertyTagJPEGLosslessPredictors 注释 = "对于每个颜色分量，该分量的无损预测器选择值。"
            注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 JPEG点变化值 <公开 类型 = 整数 值 = @PropertyTagJPEGPointTransforms 注释 = "对于每个颜色分量，该分量的点变换值。" 注释 = "类型: 短整数型 , 成员数: 每个像素的采样（分量）数">
    常量 JPEG量化表 <公开 类型 = 整数 值 = @PropertyTagJPEGQTables 注释 = "对于每个颜色分量，该分量的量化表的偏移量。" 注释 = "类型: 整数型 , 成员数: 每个像素的采样（分量）数">
    常量 JPEG量化表DC <公开 类型 = 整数 值 = @PropertyTagJPEGDCTables 注释 = "对于每个颜色分量，该分量到 DC 霍夫曼表（或无损霍夫曼表）的偏移量。"
            注释 = "类型: 整数型 , 成员数: 每个像素的采样（分量）数">
    常量 JPEG量化表AC <公开 类型 = 整数 值 = @PropertyTagJPEGACTables 注释 = "对于每个颜色分量，该分量到 AC 霍夫曼表的偏移量。" 注释 = "类型: 整数型 , 成员数: 每个像素的采样（分量）数">
    常量 ""
