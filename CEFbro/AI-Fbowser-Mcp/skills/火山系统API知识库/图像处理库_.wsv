    }

    方法 矩阵重置 <公开 类型 = 逻辑型 注释 = "ResetTransform" 注释 = "将此线性渐变画刷的变换矩阵重置为单位矩阵。这意味着不会发生任何转换。" @禁止流程检查 = 真>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipResetLineTransform((Gdiplus::GpLineGradient*)nativeBrush)) == Gdiplus::Ok;
    }

    方法 矩阵相乘 <公开 类型 = 逻辑型 注释 = "MultiplyTransform" 注释 = "用它自己和另一个矩阵的乘积更新这个画刷的变换矩阵。" @禁止流程检查 = 真>
    参数 参数_矩阵 <类型 = GP矩阵类 注释 = "要与此画刷的当前变换矩阵相乘的矩阵">
    参数 参数_矩阵顺序 <类型 = GP矩阵顺序 注释 = "可选的。 用于指定乘法的顺序。" 注释 = "GP矩阵顺序.前置 指定传递的矩阵在左侧，GP矩阵顺序.后置 指定传递的矩阵在右侧。" @默认值 = GP矩阵顺序.前置>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipMultiplyLineTransform((Gdiplus::GpLineGradient*)nativeBrush, @<参数_矩阵>.nativeMatrix, (Gdiplus::MatrixOrder)@<参数_矩阵顺序>)) == Gdiplus::Ok;
    }

    方法 矩阵平移 <公开 类型 = 逻辑型 注释 = "TranslateTransform" 注释 = "使用自身和平移矩阵的乘积更新此画刷的当前变换矩阵。" @禁止流程检查 = 真>
    参数 参数_水平偏移量 <类型 = 小数 注释 = "指定平移的水平分量">
    参数 参数_垂直偏移量 <类型 = 小数 注释 = "指定平移的垂直分量">
    参数 参数_矩阵顺序 <类型 = GP矩阵顺序 注释 = "可选的。 用于指定乘法的顺序。" 注释 = "GP矩阵顺序.前置 指定传递的矩阵在左侧，GP矩阵顺序.后置 指定传递的矩阵在右侧。" @默认值 = GP矩阵顺序.前置>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipTranslateLineTransform((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::REAL)@<参数_水平偏移量>, (Gdiplus::REAL)@<参数_垂直偏移量>, (Gdiplus::MatrixOrder)@<参数_矩阵顺序>)) == Gdiplus::Ok;
    }

    方法 矩阵缩放 <公开 类型 = 逻辑型 注释 = "ScaleTransform" 注释 = "使用自身和缩放矩阵的乘积更新此纹理画刷的当前变换矩阵。" @禁止流程检查 = 真>
    参数 参数_水平缩放量 <类型 = 小数 注释 = "指定要在 x 方向上缩放的量">
    参数 参数_垂直缩放量 <类型 = 小数 注释 = "指定要在 y 方向上缩放的量">
    参数 参数_矩阵顺序 <类型 = GP矩阵顺序 注释 = "可选的。 用于指定乘法的顺序。" 注释 = "GP矩阵顺序.前置 指定传递的矩阵在左侧，GP矩阵顺序.后置 指定传递的矩阵在右侧。" @默认值 = GP矩阵顺序.前置>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipScaleLineTransform((Gdiplus::GpLineGradient*)nativeBrush, (Gdiplus::REAL)@<参数_水平缩放量>, (Gdiplus::REAL)@<参数_垂直缩放量>, (Gdiplus::MatrixOrder)@<参数_矩阵顺序>)) == Gdiplus::Ok;
