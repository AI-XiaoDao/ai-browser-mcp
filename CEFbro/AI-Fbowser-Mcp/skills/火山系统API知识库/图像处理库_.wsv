    方法 销毁 <公开 注释 = "可以手动销毁, 但超出作用域也会自动销毁." @嵌入式方法 = "">
    {
        @ @sn<this>.Destory();

    }

    方法 克隆 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "创建一个新的 GP路径类 对象，该对象是本对象的副本。" @禁止流程检查 = 真>
    参数 参数_新路径 <类型 = GP路径类 "">
    {
        @ @<参数_新路径>.Destory();
        @ Gdiplus::GpPath* clone;
        @ SetStatus(Gdiplus::DllExports::GdipClonePath(nativePath, &clone));
        @ @<参数_新路径>.nativePath = clone;
        @ @<参数_新路径>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_填充模式 <类型 = GP填充模式 @默认值 = GP填充模式.交替>
    {
        @ this->Destory();
        @ lastResult = Gdiplus::DllExports::GdipCreatePath((Gdiplus::FillMode)@<参数_填充模式>, &nativePath);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自坐标组 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_坐标数组 <类型 = 数组坐标F>
    参数 参数_类型数组 <类型 = 字节集类 注释 = "成员值是 GP路径点类型 常量">
    参数 参数_填充模式 <类型 = GP填充模式 @默认值 = GP填充模式.交替>
    {
        @ this->Destory();
        @ INT count = @<参数_坐标数组>.data().size();
        @ lastResult = Gdiplus::DllExports::GdipCreatePath2(@<参数_坐标数组>.data().data(), @<参数_类型数组>.GetPtr(), count, (Gdiplus::FillMode)@<参数_填充模式>, &nativePath);
        @ return lastResult == Gdiplus::Ok;
    }

