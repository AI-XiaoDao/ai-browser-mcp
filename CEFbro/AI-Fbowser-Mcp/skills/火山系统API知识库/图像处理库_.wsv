    # @begin
    #

    方法 转换到图片_ <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 WEBP数据 <类型 = 字节集类 @输出名 = "m_Buff">
    参数 文件格式 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    {
        变量 返回的数据 <类型 = 字节集类>
        变量 图片宽 <类型 = 整数>
        变量 图片高 <类型 = 整数>
        返回的数据 = 转换到RGBA_ (WEBP数据, 取变量地址 (图片宽), 取变量地址 (图片高))
        返回的数据 = 到指定类型图片数据 (返回的数据, 图片宽, 图片高, 文件格式)
        返回 (返回的数据)
    }

    方法 转换到图片2_ <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 WEBP数据路径 <类型 = 文本型 @输出名 = "m_Buff">
    参数 文件格式 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    {
        变量 返回的数据 <类型 = 字节集类>
        变量 图片宽 <类型 = 整数>
        变量 图片高 <类型 = 整数>
        返回的数据 = 转换到RGBA_ (读入文件 (WEBP数据路径), 取变量地址 (图片宽), 取变量地址 (图片高))
        返回的数据 = 到指定类型图片数据 (返回的数据, 图片宽, 图片高, 文件格式)
        返回 (返回的数据)
    }

    方法 转换到RGBA_ <类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 WEBP数据 <类型 = 字节集类 @输出名 = "m_Buff">
    参数 返回的图片宽度 <类型 = 变整数>
    参数 返回的图片高度 <类型 = 变整数>
    {
        变量 返回的数据 <类型 = 字节集类>
        @  WebPDecoderConfig config;
        @  WebPDecBuffer*  output_buffer = &config.output;
        @  WebPBitstreamFeatures*  bitstream = &config.input;
        @  if (!WebPInitDecoderConfig(&config)) {
        // @   GS_E<<"WEBP Library version mismatch!\n";
        @   return @<返回的数据>;
        @  }
        @  output_buffer->colorspace = MODE_RGBA;
        @  config.options.no_fancy_upsampling = 1;
        @  config.options.bypass_filtering = 1;
        @  config.options.use_threads = 1;
        @  config.output.colorspace = MODE_RGBA;
        @  VP8StatusCode status = VP8_STATUS_OK;
        @  size_t data_size = 0;
        @  status = WebPDecode(m_Buff.GetPtr (), m_Buff.GetSize(), &config);
        @ if (VP8_STATUS_OK != status)
        @   return @<返回的数据>;
        @ // 获取宽高
        @ int w = output_buffer->width;
        @ int h = output_buffer->height;
        @ *(int*)@<返回的图片宽度> = w;
        @ *(int*)@<返回的图片高度> = h;

        @ @<返回的数据> = @an<CVolMem> ((void*)output_buffer->u.RGBA.rgba, output_buffer->u.RGBA.size);
        @ // 释放内存
        @   WebPFreeDecBuffer(output_buffer);

        返回 (返回的数据)
    }

    方法 到指定类型图片数据 <类型 = 字节集类 折叠>
    参数 RGBA数据 <类型 = 字节集类>
    参数 w <类型 = 整数>
    参数 h <类型 = 整数>
    参数 文件类型 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    {
        如果 (文件类型 != 0)
        {
            变量 临时文件名 <类型 = 文本型>
            变量 字节集 <类型 = 字节集类>
            临时文件名 = 取临时文件名 ()
            到指定类型图片文件 (临时文件名, 文件类型, w, h, RGBA数据)
            字节集 = 读入文件 (临时文件名)
            删除文件 (临时文件名)
            返回 (字节集)
        }
        变量 返回的数据 <类型 = 字节集类>
        变量 i <类型 = 整数>
        变量 len <类型 = 整数>
        @ unsigned char* data = stbi_write_png_to_mem(@<RGBA数据>.GetPtr(), 0, int(@<w>), int(@<h>), 4, &@<len>);
        @ if(!data){return @<返回的数据>;}
        循环 (, len, i)
        {
            @ @<返回的数据>.AddValue_S_BYTE((int)data[@<i>]);
        }
        返回 (返回的数据)
    }

    方法 到指定类型图片文件 <类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 文件类型 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    参数 w <类型 = 整数 @输出名 = "w">
    参数 h <类型 = 整数 @输出名 = "h">
    参数 data <类型 = 字节集类>
    {
        如果 (文件类型 == 1)
        {
            @ return stbi_write_bmp(GetMbsText (@<文件路径>.GetText (), CVolMem(), NULL), int(w), int(h), 4, @<data>.GetPtr()) == 1;
        }
        否则 (文件类型 == 2)
        {
            @ return stbi_write_tga(GetMbsText (@<文件路径>.GetText (), CVolMem(), NULL), int(w), int(h), 4, @<data>.GetPtr()) == 1;
        }
        否则
        {
            @ return stbi_write_png(GetMbsText (@<文件路径>.GetText (), CVolMem(), NULL), int(w), int(h), 4, @<data>.GetPtr(), 0) == 1;
        }
    }
}

