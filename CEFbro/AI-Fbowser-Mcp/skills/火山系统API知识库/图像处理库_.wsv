    方法 缩略显示 <公开 注释 = "缩略显示图片" 折叠>
    参数 容器句柄 <类型 = 变整数 注释 = "显示图片的容器句柄">
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 左边 <类型 = 小数 注释 = "目标容器的x坐标" @默认值 = 0>
    参数 顶边 <类型 = 小数 注释 = "目标容器的y坐标" @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "缩略大小" @默认值 = 32>
    参数 高度 <类型 = 整数 注释 = "缩略大小" @默认值 = 32>
    {
        变量 图形 <类型 = GP图形类>
        变量 图像 <类型 = GP图像类>
        变量 缩略图 <类型 = GP图像类>
        图形.创建自窗口句柄 (容器句柄)
        如果 (图片数据.取字节集长度 () == 0)
        {
            图像.创建自文件 (图片来源)
        }
        否则
        {
            图像.创建自字节集 (图片数据)
        }
        图像.取图像缩略图 (宽度, 高度, 缩略图)
        图形.画图像缩放 (缩略图, 左边, 顶边, 缩略图.取宽度 (), 缩略图.取高度 ())
        图形.销毁 ()
        图像.销毁 ()
        缩略图.销毁 ()
    }

    方法 圆形显示 <公开 类型 = 字节集类 注释 = "圆形化显示图片" 返回值注释 = "返回转换后的图片数据" 折叠>
    参数 图片数据 <类型 = 字节集类 注释 = "提供PNG图片数据，本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "提供PNG图片，本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 宽度 <类型 = 整数 注释 = "缩略大小" @默认值 = 120>
    参数 高度 <类型 = 整数 注释 = "缩略大小" @默认值 = 120>
    {
        变量 位图 <类型 = GP位图类>
        变量 位图2 <类型 = GP位图类>
        变量 图像 <类型 = GP图像类>
        变量 图像2 <类型 = GP图像类>
        变量 图形 <类型 = GP图形类>
        变量 图形2 <类型 = GP图形类>
        变量 画刷 <类型 = GP纹理画刷类>
        变量 位图数据 <类型 = 字节集类>
        变量 图像数据 <类型 = 字节集类>
        如果 (图片数据.取字节集长度 () == 0)
        {
            图像.创建自文件 (图片来源)
        }
        否则
        {
            图像.创建自字节集 (图片数据)
        }
        位图.创建自像素格式 (宽度, 高度)
        图形.创建自图像 (位图)
        图形.画图像缩放 (图像, 0, 0, 宽度, 高度)
        位图.保存到字节集 (位图数据, GP图像格式.PNG)
        图像2.创建自字节集 (位图数据)
        画刷.创建 (图像2, GP环绕模式.固定)
        位图2.创建自像素格式 (宽度, 高度)
        图形2.创建自图像 (位图2)
        图形2.置平滑模式 (GP平滑模式.抗锯齿)
        图形2.填充椭圆 (画刷, 0, 0, 宽度, 高度)
        位图2.保存到字节集 (图像数据, GP图像格式.PNG)
        位图.销毁 ()
        图像.销毁 ()
        图形.销毁 ()
        画刷.销毁 ()
        位图2.销毁 ()
        图像2.销毁 ()
        图形2.销毁 ()
        返回 (图像数据)
    }

    方法 模糊显示 <公开 类型 = 字节集类 注释 = "对图片进行模糊化处理" 返回值注释 = "返回转换后的图片数据" 折叠>
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 模糊半径 <类型 = 整数>
    参数 图像品质 <类型 = 整数 @默认值 = 100>
    参数 转换格式 <类型 = 整数 注释 = "0、JPG　1、BMP　2、PNG　3、GIF" @默认值 = 0>
    参数 保存路径 <类型 = 文本型 注释 = "留空则不会保存图片" @默认值 = "">
    {
        变量 图形 <类型 = GP图形类>
        变量 位图1 <类型 = GP位图类>
        变量 位图2 <类型 = GP位图类>
        变量 源图形 <类型 = GP图形类>
        变量 宽度值 <类型 = 整数>
        变量 高度值 <类型 = 整数>
        变量 图像 <类型 = 字节集类>
        变量 编码器 <类型 = GP编码器参数集>
        如果 (图片数据.取字节集长度 () == 0)
        {
            位图1.创建自文件 (图片来源)
        }
        否则
        {
            位图1.创建自字节集 (图片数据)
        }
        模糊半径 = 模糊半径 * 2
        源图形.创建自图像 (位图1)
        源图形.置平滑模式 (GP平滑模式.抗锯齿)
        源图形.置混合品质 (GP混合品质.伽玛校正)
        源图形.置算法模式 (GP算法模式.高质量双线性)
        源图形.置像素偏移模式 (GP像素偏移模式.无效)
        如果 (模糊半径 == 0)
        {
            宽度值 = 0
            高度值 = 0
        }
        否则
        {
            宽度值 = 位图1.取宽度 () / 模糊半径
            高度值 = 位图1.取高度 () / 模糊半径
        }
        位图2.创建自像素格式 (宽度值, 高度值, 位图1.取像素格式 ())
        图形.创建自图像 (位图2)
        图形.画图像缩放 (位图1, 0, 0, 宽度值, 高度值)
        源图形.画图像缩放 (位图2, 0, 0, 位图1.取宽度 (), 位图1.取高度 ())
        编码器.创建 ()
        编码器.置参数整数 (0, GP编码器.品质, 图像品质)
        如果 (转换格式 == 0)
        {
            位图1.保存到字节集 (图像, GP图像格式.JPEG, 编码器)
        }
        否则 (转换格式 == 1)
        {
            位图1.保存到字节集 (图像, GP图像格式.BMP, 编码器)
        }
        否则 (转换格式 == 2)
        {
            位图1.保存到字节集 (图像, GP图像格式.PNG, 编码器)
        }
        否则 (转换格式 == 3)
        {
            位图1.保存到字节集 (图像, GP图像格式.GIF, 编码器)
        }
        如果真 (保存路径 != "")
        {
            写到文件 (保存路径, 图像)
        }
        图形.销毁 ()
        位图1.销毁 ()
        位图2.销毁 ()
        编码器.销毁 ()
        源图形.销毁 ()
        返回 (图像)
    }

    方法 旋转图片 <公开 类型 = 字节集类 注释 = "对图片进行旋转处理" 返回值注释 = "返回转换后的图片数据" 折叠>
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 旋转方式 <类型 = 整数 注释 = "0、水平翻转　1、垂直翻转　2、90度旋转　3、180度旋转　4、270度旋转" @默认值 = 0>
    参数 转换格式 <类型 = 整数 注释 = "0、JPG　1、BMP　2、PNG　3、GIF" @默认值 = 0>
    参数 保存路径 <类型 = 文本型 注释 = "留空则不会保存图片" @默认值 = "">
    {
        变量 图像 <类型 = GP图像类>
        变量 图像2 <类型 = 字节集类>
        变量 编码器 <类型 = GP编码器参数集>
        如果 (图片数据.取字节集长度 () == 0)
        {
            图像.创建自文件 (图片来源)
        }
        否则
        {
            图像.创建自字节集 (图片数据)
        }
        编码器.创建 ()
        如果 (旋转方式 == 0)
        {
            编码器.置参数整数 (0, GP编码器.转换, (整数)GP编码器值.水平翻转)
        }
        否则 (旋转方式 == 1)
        {
            编码器.置参数整数 (0, GP编码器.转换, (整数)GP编码器值.垂直翻转)
        }
        否则 (旋转方式 == 2)
        {
            编码器.置参数整数 (0, GP编码器.转换, (整数)GP编码器值.旋转90度)
        }
        否则 (旋转方式 == 3)
        {
            编码器.置参数整数 (0, GP编码器.转换, (整数)GP编码器值.旋转180度)
        }
        否则 (旋转方式 == 4)
        {
            编码器.置参数整数 (0, GP编码器.转换, (整数)GP编码器值.旋转270度)
        }
        如果 (转换格式 == 0)
        {
            图像.保存到字节集 (图像2, GP图像格式.JPEG, 编码器)
        }
        否则 (转换格式 == 1)
        {
            图像.保存到字节集 (图像2, GP图像格式.BMP, 编码器)
        }
        否则 (转换格式 == 2)
        {
            图像.保存到字节集 (图像2, GP图像格式.PNG, 编码器)
        }
        否则 (转换格式 == 3)
        {
            图像.保存到字节集 (图像2, GP图像格式.GIF, 编码器)
        }
        如果真 (保存路径 != "")
        {
            写到文件 (保存路径, 图像2)
        }
        图像.销毁 ()
        编码器.销毁 ()
        图像.销毁 ()
        返回 (图像2)
    }

    方法 转换格式 <公开 类型 = 字节集类 注释 = "转换图片格式" 返回值注释 = "返回转换后的图片数据" 折叠>
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 图像品质 <类型 = 整数 @默认值 = 100>
    参数 转换格式 <类型 = 整数 注释 = "0、JPG　1、BMP　2、PNG　3、GIF" @默认值 = 0>
    参数 保存路径 <类型 = 文本型 注释 = "留空则不会保存图片" @默认值 = "">
    {
        变量 图像 <类型 = GP图像类>
        变量 图像2 <类型 = 字节集类>
        变量 编码器 <类型 = GP编码器参数集>
        如果 (图片数据.取字节集长度 () == 0)
        {
            图像.创建自文件 (图片来源)
        }
        否则
        {
            图像.创建自字节集 (图片数据)
        }
        编码器.创建 ()
        编码器.置参数整数 (0, GP编码器.品质, 图像品质)
        如果 (转换格式 == 0)
        {
            图像.保存到字节集 (图像2, GP图像格式.JPEG, 编码器)
        }
        否则 (转换格式 == 1)
        {
            图像.保存到字节集 (图像2, GP图像格式.BMP, 编码器)
        }
        否则 (转换格式 == 2)
        {
            图像.保存到字节集 (图像2, GP图像格式.PNG, 编码器)
        }
        否则 (转换格式 == 3)
        {
            图像.保存到字节集 (图像2, GP图像格式.GIF, 编码器)
        }
        如果真 (保存路径 != "")
        {
            写到文件 (保存路径, 图像2)
        }
        图像.销毁 ()
        编码器.销毁 ()
        图像.销毁 ()
        返回 (图像2)
    }
}

