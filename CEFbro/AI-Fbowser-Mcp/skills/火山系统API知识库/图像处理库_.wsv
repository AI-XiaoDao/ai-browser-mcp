        @ return item;

    }

    方法 取所有属性项目 <公开 类型 = GP属性项目集 注释 = "GetAllPropertyItems" 注释 = "获取存储在此 GP图像类 对象中的所有属性项（元数据）。" @禁止流程检查 = 真>
    {
        @ UINT totalBufferSize,numProperties;
