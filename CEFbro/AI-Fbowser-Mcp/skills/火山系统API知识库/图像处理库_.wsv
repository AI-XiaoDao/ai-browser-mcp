        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自表面 <公开 类型 = 逻辑型 注释 = "基于 DirectDraw 表面创建一个 GP位图类 对象。" 注释 = "GP位图类 对象维护对 DirectDraw 表面的引用，直到 GP位图类 对象被销毁或超出范围。"
            @禁止流程检查 = 真>
    参数 参数_DirectDrawSurface <类型 = 变整数 注释 = "指向 IDrectDrawSurface7 COM 接口的指针。">
    {
