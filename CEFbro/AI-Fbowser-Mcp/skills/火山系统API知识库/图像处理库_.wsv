    方法 取路径类型组 <公开 类型 = 字节数组类 注释 = "GetPathTypes" 返回值注释 = "每一个成员为 GP路径点类型 常量组合" @禁止流程检查 = 真>
    {
        变量 types <类型 = 字节数组类>
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetPointCount(nativePath, &count));
        @ @<types>.data().InitCount(count,TRUE);
        @ SetStatus(Gdiplus::DllExports::GdipGetPathTypes(nativePath, (BYTE*)@<types>.data().GetData() ,count));
        返回 (types)

    }

    方法 取路径坐标组 <公开 类型 = 数组坐标F 注释 = "GetPathPoints" @禁止流程检查 = 真>
    {
        变量 points <类型 = 数组坐标F>
        @ INT count = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetPointCount(nativePath, &count));
        @ @<points>.data().resize(count);
        @ SetStatus(Gdiplus::DllExports::GdipGetPathPoints(nativePath, (Gdiplus::GpPointF*)@<points>.data().data() ,count));
        返回 (points)


