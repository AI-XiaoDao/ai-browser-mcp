#             m_size = objCopyFrom.m_size;\
#             m_count = objCopyFrom.m_count;\
#             m_ptr = (cppType*)malloc(m_size);\
#             assert(m_ptr);\
#             memcpy(m_ptr, objCopyFrom.m_ptr, m_size);\
#         }\
#     }\
#     void Destory()\
#     {\
#         if(m_ptr)\
#         {\
#             free(m_ptr);\
#         }\
#         m_ptr = NULL;\
#         m_size = 0;\
#         m_count = 0; \   
#     }\
#     cppType* Create(UINT count, UINT byteSize)\
#     {\
#         this->Destory();\
#         m_count = count;\
#         m_size = byteSize;\
#         m_ptr = (cppType*)malloc(m_size);\
#         return m_ptr;\
#     }\
# <>     </include>
#
#
# @end

类 数组基础模板类 <公开 注释 = "" 注释 = "模板类型1: CPP数据类型 的包装类, 必须有一个 CPP数据类型 参数的构造函数" 折叠 折叠2 @视窗.外部头文件 = "<vector>"
        @文档 = "category = \"图像处理库.Gdiplus.辅助类\"" @模板基础类 = 真>
{
    方法 首成员 <公开 类型 = 模板类型1 注释 = "front" 注释 = "访问第一个元素" @嵌入式方法 = "">
    {
        @ @dt<模板类型1>(@sn<this>.data().front())

    }

    方法 尾成员 <公开 类型 = 模板类型1 注释 = "back" 注释 = "访问最后一个元素" @嵌入式方法 = "">
    {
        @ @dt<模板类型1>(@sn<this>.data().back())

    }

    方法 取数据指针 <公开 类型 = 变整数 注释 = "data" 注释 = "返回指向内存中数组第一个元素的指针" @嵌入式方法 = "">
    {
        @ (INT_P)(@sn<this>.data().data())

    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty" 注释 = "检查容器是否无元素" @嵌入式方法 = "">
    {
        @ @sn<this>.data().empty()

    }

    方法 取成员数 <公开 类型 = 变整数 注释 = "size" 注释 = "返回容纳的元素数" @嵌入式方法 = "">
    {
        @ (INT_P)(@sn<this>.data().size())

    }

    方法 取最大成员数 <公开 类型 = 变整数 注释 = "max_size" 注释 = "返回根据系统或库实现限制的容器可保有的元素最大数量" @嵌入式方法 = "">
    {
        @ (INT_P)(@sn<this>.data().max_size())

    }

    方法 置预分配尺寸 <公开 注释 = "reserve" 注释 = "设置预留存储空间" @嵌入式方法 = "">
    参数 参数_新容量 <类型 = 变整数>
    {
        @ @sn<this>.data().reserve(@<参数_新容量>)

    }

    方法 取预分配尺寸 <公开 类型 = 变整数 注释 = "capacity" 注释 = "获取预留存储空间" @嵌入式方法 = "">
    {
        @ (INT_P)(@sn<this>.data().capacity())

    }

    方法 缩小以适合 <公开 注释 = "shrink_to_fit" 注释 = "通过释放未使用的内存减少内存的使用" @嵌入式方法 = "">
    {
        @ @sn<this>.data().shrink_to_fit()

    }

    方法 清空 <公开 注释 = "clear" 注释 = "从容器擦除所有元素" @嵌入式方法 = "">
    {
        @ @sn<this>.data().clear()

    }

    方法 插入 <公开 类型 = 变整数 注释 = "insert" 注释 = "在指定索引插入成员" 返回值注释 = "返回被插入值的索引。" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "插入到此位置之前" "">
    参数 参数_值 <类型 = 模板类型1 注释 = "要插入的值">
    {
        @ @sn<this>.insert_at(@<参数_位置>, @<参数_值>.data())

    }

    方法 插入重复 <公开 类型 = 变整数 注释 = "insert" 注释 = "在指定索引插入指定数量的成员" 返回值注释 = "返回首个插入值的索引" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "插入到此位置之前">
    参数 参数_数量 <类型 = 变整数 注释 = "要插入的数量">
    参数 参数_值 <类型 = 模板类型1 注释 = "要插入的值">
    {
        @ @sn<this>.insert_at( @<参数_位置>, @<参数_数量> , @<参数_值>.data())

    }

    方法 插入容器 <公开 类型 = 变整数 注释 = "insert" 注释 = "插入指定容器的所有元素到本对象" 返回值注释 = "返回首个插入值的索引" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "插入到此位置之前" "">
    参数 参数_被插入容器 <注释 = "被插入的容器" @匹配类型 = 通用类>
    {
        @ @sn<this>.insert_cont( @<参数_位置>, @<参数_被插入容器>.data() )

    }

    方法 插入容器部分 <公开 类型 = 变整数 注释 = "insert" 注释 = "插入指定向量类的部分元素到本对象" 返回值注释 = "返回首个插入值的索引" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "插入到此位置之前" "">
    参数 参数_被插入容器 <注释 = "被插入的容器" @匹配类型 = 通用类>
    参数 参数_起始位置 <类型 = 变整数>
    参数 参数_数量 <类型 = 变整数>
    {
        @ @sn<this>.insert_cont( @<参数_位置>, @<参数_被插入容器>.data(), @<参数_起始位置>, @<参数_数量> )

    }

    方法 安置 <公开 类型 = 变整数 注释 = "emplace" 注释 = "插入新元素到指定索引前面,将 参数_值 直接转发到元素类型的构造函数" 返回值注释 = "返回插入值的索引" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "插入到此索引之前">
    参数 参数_值 <注释 = "要插入的值的构造函数参数" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @sn<this>.emplace_at(@<参数_位置>, @<参数_值>)

    }

    方法 删除 <公开 类型 = 变整数 注释 = "erase" 注释 = "从容器擦除指定的元素。" 返回值注释 = "返回移除元素的下一个元素索引" @嵌入式方法 = "">
    参数 参数_位置 <类型 = 变整数 注释 = "要擦除的成员位置">
    {
        @ @sn<this>.erase_at(@<参数_位置>)

    }

    方法 安置后面 <公开 注释 = "emplace_back" 注释 = "添加新元素到容器尾, 将 参数_值 直接转发到元素类型的构造函数" @嵌入式方法 = "">
    参数 参数_值 <注释 = "要插入的值的构造函数参数" @匹配类型 = 所有类型 @可扩展 = "">
    {
        @ @sn<this>.data().emplace_back(@<参数_值>)

    }

    方法 添加 <公开 注释 = "push_back" 注释 = "将元素添加到容器末尾" @嵌入式方法 = "">
    参数 参数_值 <类型 = 模板类型1>
    {
        @ @sn<this>.data().push_back(@<参数_值>.data())

    }

    方法 添加扩展 <公开 注释 = "push_back" 注释 = "将可扩展元素添加到容器末尾" @嵌入式方法 = "">
    参数 参数_值 <类型 = 模板类型1 @可扩展 = "">
    {
        @ @sn<this>.push_back_args(@<参数_值>)

    }

    方法 弹出后面 <公开 注释 = "pop_back" 注释 = "移除容器的末元素。" @嵌入式方法 = "">
    {
        @ @sn<this>.data().pop_back()

    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "operator[]" 注释 = "获取指定成员的值" 注释 = "如果超出范围, 结果是未定义的" @嵌入式方法 = "">
    参数 参数_索引 <类型 = 变整数>
    {
        @ @dt<模板类型1>(@sn<this>.m_data[@<参数_索引>])

    }

    方法 置成员 <公开 注释 = "operator[]" 注释 = "设置指定成员的值" 注释 = "如果超出范围, 结果是未定义的" @嵌入式方法 = "">
    参数 参数_索引 <类型 = 变整数>
    参数 参数_值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_data[@<参数_索引>] = @<参数_值>.data()

    }

    方法 重置大小 <公开 注释 = "resize" 注释 = "改变容器中可存储元素的个数" @嵌入式方法 = "">
    参数 参数_新大小 <类型 = 变整数>
    {
        @ @sn<this>.data().resize(@<参数_新大小>)

    }

    方法 重置大小初始值 <公开 注释 = "resize" 注释 = "改变容器中可存储元素的个数, 并给新成员设置初始值" @嵌入式方法 = "">
    参数 参数_新大小 <类型 = 变整数>
    参数 参数_值 <类型 = 模板类型1 注释 = "用以初始化新元素的值">
    {
        @ @sn<this>.data().resize(@<参数_新大小>, @<参数_值>.data())

    }

    方法 交换 <公开 注释 = "swap" 注释 = "将内容与 参数_要交换的数组 的交换。" @嵌入式方法 = "">
    参数 参数_要交换的数组 <类型 = 数组基础模板类>
    {
        @ @sn<this>.data().swap(@<参数_要交换的数组>.data())

    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来枚举本向量中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = enum_vector\r\nhas_loop_body = true">
    {
        @ ZY_FOREACH(@sn<this>)
    }

    方法 枚举反向循环 <公开 注释 = "  启动一个循环来枚举本向量中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = enum_vector_r\r\nhas_loop_body = true">
    {
        @ ZY_FOREACH_R(@sn<this>)

    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
            注释 = "本类或本类继承类的\"枚举循环\"嵌套,本方法将返回所处最近层\"枚举循环\"的枚举成员值." @嵌入式方法 = "parent = \"enum_vector,enum_vector_r\"">
    {
        @ @dt<模板类型1>(*iter)
    }

