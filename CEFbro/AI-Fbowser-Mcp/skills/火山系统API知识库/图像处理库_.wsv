        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromGdiDib((BITMAPINFO *)@<参数_BITMAPINFO>,(VOID*)@<参数_位图数据>, &bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自位图句柄 <公开 类型 = 逻辑型 注释 = "基于 Windows 图形设备接口 (GDI) 位图的句柄和 GDI 调色板的句柄创建 GP位图类 对象。" @禁止流程检查 = 真>
    参数 参数_位图句柄 <类型 = 变整数 注释 = "HBITMAP, GDI 位图句柄。">
    参数 参数_调色板句柄 <类型 = 变整数 注释 = "HPALETTE, 如果 <参数_位图句柄> 不是与设备无关的位图 (DIB)，则用于定义位图颜色的 GDI 调色板的句柄。" @默认值 = 0>
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromHBITMAP((HBITMAP)@<参数_位图句柄>,(HPALETTE)@<参数_调色板句柄>, &bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自图标句柄 <公开 类型 = 逻辑型 注释 = "基于图标创建位图对象。" @禁止流程检查 = 真>
    参数 参数_图标句柄 <类型 = 变整数 注释 = "GDI 图标句柄。">
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromHICON((HICON)@<参数_图标句柄>, &bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自资源 <公开 类型 = 逻辑型 注释 = "基于资源创建位图对象。" @禁止流程检查 = 真>
    参数 参数_位图资源 <类型 = BMP位图资源>
    参数 参数_实例句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ if(!@<参数_实例句柄>) {
        @     MEMORY_BASIC_INFORMATION mbi;
        @     static int dummy;
        @     VirtualQuery(&dummy, &mbi, sizeof(mbi));
        @     @<参数_实例句柄> = reinterpret_cast<INT_P>(mbi.AllocationBase);
        @ }
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromResource((HINSTANCE)@<参数_实例句柄>, MAKEINTRESOURCE(@<参数_位图资源>), &bitmap);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;


    }

    方法 创建自位图句柄Ex <公开 类型 = 逻辑型 注释 = "基于 Windows 图形设备接口 (GDI) 位图的句柄和 GDI 调色板的句柄创建 GP位图类 对象。" 注释 = "支持透明通道" 折叠 @禁止流程检查 = 真>
    参数 参数_位图句柄 <类型 = 变整数 注释 = "HBITMAP, GDI 位图句柄。">
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ BITMAP bmp;
        @ BITMAPINFO bmInfo = {0};
        @ if(!GetObjectW((HBITMAP)@<参数_位图句柄>, sizeof(BITMAP),&bmp)) {
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ HDC hdc = CreateCompatibleDC (NULL);
        @ if(!hdc) {
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ bmInfo.bmiHeader.biSize = sizeof(BITMAPINFOHEADER);
        @ int cbCopied = GetDIBits (hdc, (HBITMAP)@<参数_位图句柄>, 0, bmp.bmHeight, NULL, &bmInfo, DIB_RGB_COLORS);
        @ if(cbCopied == 0) {
        @     DeleteDC (hdc);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ if(bmInfo.bmiHeader.biBitCount < 32) {
        @     DeleteDC (hdc);
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromHBITMAP((HBITMAP)@<参数_位图句柄>,NULL, &bitmap);
        @     SetNativeImage(bitmap);
        @     return lastResult == Gdiplus::Ok;
        @ }
        @ BYTE* pData = (BYTE*)Gdiplus::DllExports::GdipAlloc(bmInfo.bmiHeader.biSizeImage);
        @ if(!pData) {
        @     DeleteDC (hdc);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ cbCopied = GetDIBits (hdc, (HBITMAP)@<参数_位图句柄>, 0, bmp.bmHeight, pData, &bmInfo, 0);
        @ if(cbCopied == 0) {
        @     DeleteDC (hdc);
        @     Gdiplus::DllExports::GdipFree(pData);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromScan0(bmp.bmWidth, bmp.bmHeight, 0, PixelFormat32bppPARGB, NULL,&bitmap);
        @ if(lastResult != Gdiplus::Ok) {
        @     DeleteDC (hdc);
        @     Gdiplus::DllExports::GdipFree(pData);
        @     return false;
        @ }
        @ Gdiplus::Rect rc(0,0,bmp.bmWidth,bmp.bmHeight);
        @ Gdiplus::BitmapData bmpData;
        @ lastResult = Gdiplus::DllExports::GdipBitmapLockBits(bitmap, &rc, Gdiplus::ImageLockModeRead | Gdiplus::ImageLockModeWrite, PixelFormat32bppPARGB, &bmpData);
        @ if(lastResult != Gdiplus::Ok) {
        @     DeleteDC (hdc);
        @     Gdiplus::DllExports::GdipDisposeImage(bitmap);
        @     Gdiplus::DllExports::GdipFree(pData);
        @     return false;
        @ }
        @ LONG nLinesize = bmp.bmWidth * 4;
        @ for(int i=0; i<bmp.bmHeight; ++i) {
        @     memcpy((BYTE*)bmpData.Scan0 + i * nLinesize, pData + (bmp.bmHeight - i - 1) * nLinesize, nLinesize);
        @ }
        @ Gdiplus::DllExports::GdipBitmapUnlockBits(bitmap, &bmpData);
        @ DeleteDC (hdc);
        @ Gdiplus::DllExports::GdipFree(pData);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自图标句柄Ex <公开 类型 = 逻辑型 注释 = "基于图标创建位图对象。" 注释 = "支持透明通道" @禁止流程检查 = 真>
    参数 参数_图标句柄 <类型 = 变整数 注释 = "HICON">
    {
        @ Gdiplus::GpBitmap *bitmap = NULL;
        @ ICONINFO info = {0};
        @ BITMAP bmp;
        @ BITMAPINFO bmInfo = {0};
        @ if(!GetIconInfo((HICON)@<参数_图标句柄>, &info))
        @ {
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ if(!GetObjectW(info.hbmMask, sizeof(BITMAP),&bmp)) {  
        @     if(info.hbmColor) DeleteObject(info.hbmColor);
        @     if(info.hbmMask) DeleteObject(info.hbmMask);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ if(info.hbmColor) DeleteObject(info.hbmColor);
        @ if(info.hbmMask) DeleteObject(info.hbmMask);
        @ HDC hdc = GetDC (NULL);
        @ HDC mdc = CreateCompatibleDC (hdc);
        @ if(!mdc) {
        @     ReleaseDC(NULL,hdc);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ bmInfo.bmiHeader.biSize = sizeof(BITMAPINFOHEADER);
        @ bmInfo.bmiHeader.biBitCount = 32;
        @ bmInfo.bmiHeader.biWidth = bmp.bmWidth;
        @ bmInfo.bmiHeader.biHeight = bmp.bmHeight;
        @ bmInfo.bmiHeader.biPlanes = 1;
        @ bmInfo.bmiHeader.biCompression = 0;
        @ BYTE* pData = NULL;
        @ HBITMAP hBitmap = CreateDIBSection (mdc, &bmInfo, DIB_RGB_COLORS, (void**)&pData, NULL, 0);
        @ if(!hBitmap) {
        @     DeleteDC(mdc);
        @     ReleaseDC(NULL,hdc);
        @     SetStatus (Gdiplus::GenericError);
        @     return false;
        @ }
        @ HGDIOBJ hOldBmp = SelectObject (mdc, hBitmap);
        @ if(!DrawIconEx (mdc, 0, 0, (HICON)@<参数_图标句柄>, bmp.bmWidth, bmp.bmHeight, 0, NULL, DI_NORMAL))
        @ {
        @     SelectObject (mdc, hOldBmp);
        @     ReleaseDC (NULL, hdc);
        @     DeleteObject(hBitmap);
        @     DeleteDC (mdc);
        @     lastResult = Gdiplus::DllExports::GdipCreateBitmapFromHICON((HICON)@<参数_图标句柄>, &bitmap);
        @     SetNativeImage(bitmap);
        @     return lastResult == Gdiplus::Ok;
        @ }
        @ lastResult = Gdiplus::DllExports::GdipCreateBitmapFromScan0(bmp.bmWidth, bmp.bmHeight, 0, PixelFormat32bppPARGB, NULL,&bitmap);
        @ if(lastResult != Gdiplus::Ok) {
        @     SelectObject (mdc, hOldBmp);
        @     DeleteObject(hBitmap);
        @     DeleteDC (mdc);
        @     ReleaseDC (NULL, hdc);
        @     return false;
        @ }
        @ Gdiplus::Rect rc(0,0,bmp.bmWidth,bmp.bmHeight);
        @ Gdiplus::BitmapData bmpData;
        @ lastResult = Gdiplus::DllExports::GdipBitmapLockBits(bitmap, &rc, Gdiplus::ImageLockModeRead | Gdiplus::ImageLockModeWrite, PixelFormat32bppPARGB, &bmpData);
        @ if(lastResult != Gdiplus::Ok) {
        @     SelectObject (mdc, hOldBmp);
        @     DeleteObject(hBitmap);
        @     DeleteDC (mdc);
        @     ReleaseDC (NULL, hdc);
        @     Gdiplus::DllExports::GdipDisposeImage(bitmap);
        @     return false;
        @ }
        @ LONG nLinesize = bmp.bmWidth * 4;
        @ for(int i=0; i<bmp.bmHeight; ++i) {
        @     memcpy(((BYTE*)bmpData.Scan0) + i * nLinesize, pData + (bmp.bmHeight - i - 1) * nLinesize, nLinesize);
        @ }
        @ Gdiplus::DllExports::GdipBitmapUnlockBits(bitmap, &bmpData);
        @ SelectObject (mdc, hOldBmp);
        @ DeleteObject(hBitmap);
        @ DeleteDC (mdc);
        @ ReleaseDC (NULL, hdc);
        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;


    }

    方法 克隆位图 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "通过复制该位图的一部分来创建一个新的 GP位图类 对象。" @禁止流程检查 = 真>
