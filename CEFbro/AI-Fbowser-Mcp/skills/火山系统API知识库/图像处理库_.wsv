类 GP初始类 <公开 基础类 = Gdiplus 注释 = "本库改自于“kyozy”的模块。此类全是静态方法, 包括 初始化, 卸载 等静态方法" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus\""
        @禁止创建对象 = 真>
{
    方法 初始化GDI <公开 静态 类型 = 变整数 注释 = "GdiplusStartup"
            注释 = "函数初始化 Windows GDI+。 在进行任何其他 GDI+ 调用之前调用 GP初始类.初始化GDI，并在使用完 GDI+ 后调用 GP初始类.卸载GDI。">
    {
        返回 (初始化 ())
    }

    方法 卸载GDI <公开 静态 注释 = "GdiplusShutdown 卸载GDI+, 注意: 在此之前必须销毁其他所有GDI+对象">
    参数 令牌 <类型 = 变整数 注释 = "由 GP初始类.初始化GDI 返回">
    {
        卸载 (令牌)
    }
}

