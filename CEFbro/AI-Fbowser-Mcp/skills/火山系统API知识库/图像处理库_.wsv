# @def_macro ZY_DEC_ARR_PTR(cppType) \
# <>     <include> \
#     cppType* m_ptr; \
#     UINT m_size; \
#     UINT m_count; \
#     void @an<_OnInitExtra> () \
#     { \
#         m_ptr = NULL; \
#         m_size = 0; \
#         m_count = 0; \
