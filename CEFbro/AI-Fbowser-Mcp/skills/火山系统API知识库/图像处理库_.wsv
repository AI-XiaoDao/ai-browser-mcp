    参数 参数_原图顶边 <类型 = 整数 注释 = "指定要绘制的源图像部分左上角的 y 坐标L">
    参数 参数_原图宽度 <类型 = 整数 注释 = "指定要绘制的源图像部分的宽度">
    参数 参数_原图高度 <类型 = 整数 注释 = "指定要绘制的源图像部分的高度">
    参数 参数_原图单位 <类型 = GP单位 注释 = "指定图像的测量单位。 默认值为单位像素。" @默认值 = GP单位.像素>
    参数 参数_图像属性 <类型 = GP图像属性类 注释 = "指定渲染图像时要应用的颜色调整。" @默认值 = 空对象>
    参数 参数_中断回调函数 <类型 = 变整数 注释 = "逻辑型 (变整数 回调参数)" @默认值 = 0>
    参数 参数_回调参数 <类型 = 变整数 注释 = "传递给回调函数的参数" @默认值 = 0>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipDrawImageRectRectI(nativeGraphics,@<参数_图像>.nativeImage, @<参数_左边>, @<参数_顶边>, @<参数_宽度>, @<参数_高度>, 
        @     @<参数_原图左边>, @<参数_原图顶边>, @<参数_原图宽度>, @<参数_原图高度>, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, (Gdiplus::DrawImageAbort)@<参数_中断回调函数>, (VOID*)@<参数_回调参数>)) == Gdiplus::Ok;

    }

