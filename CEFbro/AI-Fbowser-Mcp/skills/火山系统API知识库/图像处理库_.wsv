    参数 参数_矩形 <类型 = 矩形F>
    参数 参数_环绕模式 <类型 = GP环绕模式 @默认值 = GP环绕模式.平铺>
    {
        @ this->Destory();
        @ Gdiplus::GpTexture *texture = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateTexture2(@<参数_图像>.nativeImage, (Gdiplus::WrapMode)@<参数_环绕模式>, @<参数_矩形>.data().X,
        @    @<参数_矩形>.data().Y, 
        @    @<参数_矩形>.data().Width, 
        @    @<参数_矩形>.data().Height, &texture);
        @ SetNativeBrush(texture);
        @ return lastResult == Gdiplus::Ok;
    }

