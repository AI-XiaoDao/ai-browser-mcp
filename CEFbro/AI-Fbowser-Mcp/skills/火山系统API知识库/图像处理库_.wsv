        @ SetNativeImage(bitmap);
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自GDI设备无关位图 <公开 类型 = 逻辑型 注释 = "基于 BITMAPIINFO 结构和像素数据创建一个 GP位图类 对象。" @禁止流程检查 = 真>
    参数 参数_BITMAPINFO <类型 = 变整数 注释 = "指向 GDI BITMAPINFO 结构的指针。该结构定义了几个位图属性，例如大小和像素格式。">
    参数 参数_位图数据 <类型 = 变整数 注释 = "指向包含像素数据的字节数组的指针。">
    {
