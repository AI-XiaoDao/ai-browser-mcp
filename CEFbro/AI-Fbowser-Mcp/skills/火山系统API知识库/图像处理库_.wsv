    方法 画图像九宫 <公开 类型 = 逻辑型 注释 = "DrawImage" @禁止流程检查 = 真>
    参数 参数_图像 <类型 = GP图像类>
    参数 参数_左边 <类型 = 小数 注释 = "指定要绘制的目标矩形左上角的 x 坐标L">
    参数 参数_顶边 <类型 = 小数 注释 = "指定要绘制的目标矩形左上角的 y 坐标L">
    参数 参数_宽度 <类型 = 小数 注释 = "指定要绘制的目标矩形的宽度">
    参数 参数_高度 <类型 = 小数 注释 = "指定要绘制的目标矩形的高度">
    参数 参数_九宫左边距 <类型 = 整数 注释 = "指定要绘制的图像左边距">
    参数 参数_九宫右边距 <类型 = 整数 注释 = "如果为-1，则等于 <参数_九宫左边距>" @默认值 = -1>
    参数 参数_九宫上边距 <类型 = 整数 注释 = "如果为-1，则等于 <参数_九宫左边距>" @默认值 = -1>
    参数 参数_九宫下边距 <类型 = 整数 注释 = "如果为-1，则等于 <参数_九宫左边距>" @默认值 = -1>
    参数 参数_原图单位 <类型 = GP单位 注释 = "指定图像的测量单位。 默认值为单位像素。" @默认值 = GP单位.像素>
    参数 参数_图像属性 <类型 = GP图像属性类 注释 = "指定渲染图像时要应用的颜色调整。" @默认值 = 空对象>
    {
        @ int leftMargin = @<参数_九宫左边距>;
        @ int rightMargin = @<参数_九宫右边距>;
        @ int topMargin = @<参数_九宫上边距>;
        @ int bottomMargin = @<参数_九宫下边距>;
        @ if(rightMargin < 0)
        @     rightMargin = leftMargin;
        @ if(topMargin < 0)
        @     topMargin = leftMargin;
        @ if(bottomMargin < 0)
        @     bottomMargin = leftMargin;
        @ UINT width = 0, height = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetImageWidth(@<参数_图像>.nativeImage, &width));
        @ SetStatus(Gdiplus::DllExports::GdipGetImageHeight(@<参数_图像>.nativeImage, &height));
        @ if(leftMargin + rightMargin > (int)width) {
        @     leftMargin = width / 2;
        @     rightMargin = leftMargin;
        @ } 
        @ if(topMargin + bottomMargin > (int)height) {
        @     topMargin = height / 2;
        @     bottomMargin = topMargin;
        @ }
        @ // 画上左部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)@<参数_左边>,(float)@<参数_顶边>,(float)leftMargin,(float)topMargin, 
        @     0.0f, 0.0f,(float)leftMargin, (float)topMargin, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画上中部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + leftMargin), (float)@<参数_顶边>, (float)(@<参数_宽度> - leftMargin - rightMargin), (float)topMargin,
        @     (float)leftMargin, 0.0f, (float)(width - leftMargin - rightMargin), (float)topMargin, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画上右部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + @<参数_宽度> - rightMargin), (float)@<参数_顶边>, (float)rightMargin, (float)topMargin,
        @     (float)(width - rightMargin), 0, (float)rightMargin, (float)topMargin,(Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画中左部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)@<参数_左边>, (float)(@<参数_顶边> + topMargin), (float)leftMargin, (float)(@<参数_高度> - topMargin - bottomMargin),
        @     0.0f, (float)topMargin, (float)leftMargin, (float)(height - topMargin - bottomMargin), (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画中中部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + leftMargin), (float)(@<参数_顶边> + topMargin), 
        @     (float)(@<参数_宽度> - leftMargin - rightMargin), (float)(@<参数_高度> - topMargin - bottomMargin),
        @     (float)leftMargin, (float)rightMargin, (float)(width - leftMargin - rightMargin), (float)(height - topMargin - bottomMargin), (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画中右部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + @<参数_宽度> - rightMargin), (float)(@<参数_顶边> + topMargin), 
        @     (float)rightMargin, (float)(@<参数_高度> - topMargin - bottomMargin),
        @     (float)(width - rightMargin), (float)topMargin, (float)rightMargin, (float)(height - topMargin - bottomMargin), (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画下左部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)@<参数_左边>,(float)(@<参数_顶边> + @<参数_高度> - bottomMargin), (float)leftMargin,(float)bottomMargin, 
        @     0.0f, (float)(height - bottomMargin),(float)leftMargin, (float)bottomMargin, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画下中部分
        @ SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + leftMargin), (float)(@<参数_顶边> + @<参数_高度> - bottomMargin), 
        @     (float)(@<参数_宽度> - leftMargin - rightMargin), (float)bottomMargin,
        @     (float)leftMargin, (float)(height - bottomMargin), (float)(width - leftMargin - rightMargin),(float)bottomMargin, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL));
        @ // 画下右部分
        @ return SetStatus(Gdiplus::DllExports::GdipDrawImageRectRect(nativeGraphics,@<参数_图像>.nativeImage,(float)(@<参数_左边> + @<参数_宽度> - rightMargin), (float)(@<参数_顶边> + @<参数_高度> - bottomMargin), 
        @     (float)rightMargin, (float)bottomMargin,
        @     (float)(width - rightMargin), (float)(height - bottomMargin), (float)rightMargin, (float)bottomMargin, (Gdiplus::Unit)@<参数_原图单位>, @<参数_图像属性>.nativeImageAttr, NULL, NULL)) == Gdiplus::Ok;


    }

    方法 枚举图元文件坐标 <公开 类型 = 逻辑型 注释 = "EnumerateMetafile" @禁止流程检查 = 真>
    参数 参数_图元文件 <类型 = GP图元文件类>
    参数 参数_目标点 <类型 = 坐标F>
    参数 参数_回调函数 <类型 = 变整数
            注释 = "BOOL (CALLBACK * EnumerateMetafileProc)(EmfPlusRecordType 记录类型,UINT 标志,UINT 数据大小,const BYTE* 数据指针,VOID* 回调参数)">
    参数 参数_回调函数参数 <类型 = 变整数 @默认值 = 0>
    参数 参数_图像属性 <类型 = GP图像属性类 @默认值 = 空对象>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipEnumerateMetafileDestPoint(
        @                    nativeGraphics,
        @                    (const Gdiplus::GpMetafile *)@<参数_图元文件>.nativeImage,
        @                    @<参数_目标点>.data(),
        @                    (Gdiplus::EnumerateMetafileProc)@<参数_回调函数>,
        @                    (VOID*)@<参数_回调函数参数>,
        @                    @<参数_图像属性>.nativeImageAttr)) == Gdiplus::Ok;

    }

