    参数 参数_宽度 <类型 = 小数 注释 = "指定此画笔宽度的实数。 默认值为 1.0。" @默认值 = 1.0>
    {
        @ this->Destory();
        @ Gdiplus::Unit unit = Gdiplus::UnitWorld;
        @ nativePen = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreatePen1(@<参数_颜色>,(Gdiplus::REAL)@<参数_宽度>, unit, &nativePen);
        @ return lastResult == Gdiplus::Ok;
    }

