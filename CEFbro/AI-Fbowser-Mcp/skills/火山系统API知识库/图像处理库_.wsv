    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_标志 <类型 = 整数 注释 = "GP调色板标志 常量组合">
    参数 参数_项目数组 <类型 = 整数数组类 注释 = "ARGB 颜色数组。">
    {
        @ this->Destory();
        @ UINT count = (UINT)@<参数_项目数组>.data().GetCount();
        @ if(count ==0 ) return false;
        @ Gdiplus::ColorPalette* ptr = this->Create(sizeof(UINT)*2  + count * sizeof(Gdiplus::ARGB));
        @ if(!ptr) return false;
        @ ptr->Flags = @<参数_标志>;
        @ ptr->Count = count;
        @ memcpy (&ptr->Entries[0], @<参数_项目数组>.data ().GetData (), count * sizeof (Gdiplus::ARGB)));
        @ return true;

    }

