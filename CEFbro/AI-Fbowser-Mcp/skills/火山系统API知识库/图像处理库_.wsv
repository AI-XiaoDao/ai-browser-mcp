        @ Gdiplus::GpBitmap* gpdstBitmap;
        @ SetStatus(Gdiplus::DllExports::GdipCloneBitmapArea(@<参数_矩形>.data().X,@<参数_矩形>.data().Y,@<参数_矩形>.data().Width,@<参数_矩形>.data().Height, @<参数_像素格式>,(Gdiplus::GpBitmap *)nativeImage, &gpdstBitmap));
        @ @<参数_新位图>.nativeImage = gpdstBitmap;
        @ @<参数_新位图>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;
    }

