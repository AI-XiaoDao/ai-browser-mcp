类 SVG矢量图形类_ <公开 注释 = "本类简化了调用，使用全局快捷操作。你也可以根据情况拆分调用。" 折叠 折叠2 @文档 = "category = \"图像处理库.SVG矢量图形\"" @全局类 = 真
        "@视窗.外部库.debug-x64" = "lunasvg_debug.lib" "@视窗.外部库.release-x64" = "lunasvg_release.lib"
        "@视窗.外部库.release-win32" = "lunasvg_release32.lib" "@视窗.外部库.debug-win32" = "lunasvg_debug32.lib" @视窗.库文件搜寻目录 = "svg\\lib"
        @视窗.外部头文件 = "svg\\lib\\lunasvg.h">
{
    变量 SVG绘制 <类型 = SVG绘制类_>
    变量 SVG图片 <类型 = SVG图片类_>

    方法 SVG转图片数据_ <公开 类型 = 字节集类 注释 = "将SVG数据转成字节集图片数据" 折叠>
    参数 SVG文本来源 <类型 = 文本型 注释 = "svg文本型数据" @默认值 = "">
    参数 SVG字节集来源 <类型 = 字节集类 注释 = "svg字节集型数据" @默认值 = 空对象>
    参数 SVG路径来源 <类型 = 文本型 注释 = "例如：“C:\\\\图片.svg”" @默认值 = "">
    参数 文件类型 <类型 = 整数 注释 = "转换后返回的数据类型。0、png 1、bmp 2、tga" @默认值 = 0>
    参数 宽度 <类型 = 整数 @默认值 = 0>
    参数 高度 <类型 = 整数 @默认值 = 0>
    参数 图标颜色 <类型 = 整数 注释 = "默认-1不修改原色值" @默认值 = -1>
    参数 背景颜色 <类型 = 整数 注释 = "当文件类型为bmp时且背景颜色为透明色，自动为白色，因为bmp不支持透明" @默认值 = 颜色类.透明色>
    {
        变量 空字节集 <类型 = 字节集类>
        变量 图标数据 <类型 = 字节集类>
        变量 原色 <类型 = 字节集类>
        变量 现色 <类型 = 文本型>
        如果真 (图标颜色 != -1)
        {
            现色 = 颜色_取HTML色值 (图标颜色)
        }
        如果 (文件是否存在 (SVG路径来源))
        {
            图标数据 = 读入文件 (SVG路径来源)
        }
        否则 (字节集是否为空 (SVG字节集来源) == 假)
        {
            图标数据 = SVG字节集来源
        }
        否则 (文本是否为空 (SVG文本来源) == 假)
        {
            图标数据 = 文本到UTF8_ (SVG文本来源, 假)
        }
        否则
        {
            返回 (空字节集)
        }
        如果真 (图标颜色 != -1)
        {
            原色 = 取原色值 (图标数据)
            如果 (原色.取字节集长度 () == 1)
            {
                图标数据 = 添加现色值 (图标数据, 现色)
            }
            否则
            {
                子字节集替换 (图标数据, 原色, 文本到UTF8_ (现色))
            }
        }
        如果真 (SVG绘制.加载SVG数据 (图标数据) == 假)
        {
            返回 (空字节集)
        }
        如果真 (文件类型 < 0 || 文件类型 > 2)
        {
            文件类型 = 0
        }
        背景颜色 = RGB到RGBA (背景颜色)
        如果真 (文件类型 == 1 && 背景颜色 == 0)
        {
            背景颜色 = RGB到RGBA (颜色类.白色)
        }
        SVG图片 = SVG绘制.取图片 (宽度, 高度, 背景颜色)
        SVG图片.分配RGBA ()
        返回 (SVG图片.到数据 (文件类型))
    }

    方法 SVG转图片文件_ <公开 类型 = 逻辑型 注释 = "将SVG数据转成本地图片文件" 折叠>
    参数 SVG文本来源 <类型 = 文本型 注释 = "svg文本型数据" @默认值 = "">
    参数 SVG字节集来源 <类型 = 字节集类 注释 = "svg字节集型数据" @默认值 = 空对象>
    参数 SVG路径来源 <类型 = 文本型 注释 = "例如：“C:\\\\图片.svg”" @默认值 = "">
    参数 保存路径 <类型 = 文本型 注释 = "例如：“C:\\\\图片.png” ；只支持png 、bmp、tga">
    参数 文件类型 <类型 = 整数 注释 = "转换后返回的数据类型。0、png 1、bmp 2、tga" @默认值 = 0>
    参数 宽度 <类型 = 整数 @默认值 = 0>
    参数 高度 <类型 = 整数 @默认值 = 0>
    参数 图标颜色 <类型 = 整数 注释 = "默认-1不修改原色值" @默认值 = -1>
    参数 背景颜色 <类型 = 整数 注释 = "当文件类型为bmp时且背景颜色为透明色，自动为白色，因为bmp不支持透明" @默认值 = 颜色类.透明色>
    {
        变量 图标数据 <类型 = 字节集类>
        变量 原色 <类型 = 字节集类>
        变量 现色 <类型 = 文本型>
        如果真 (图标颜色 != -1)
        {
            现色 = 颜色_取HTML色值 (图标颜色)
        }
        如果 (文件是否存在 (SVG路径来源))
        {
            图标数据 = 读入文件 (SVG路径来源)
        }
        否则 (字节集是否为空 (SVG字节集来源) == 假)
        {
            图标数据 = SVG字节集来源
        }
        否则 (文本是否为空 (SVG文本来源) == 假)
        {
            图标数据 = 文本到UTF8_ (SVG文本来源, 假)
        }
        否则
        {
            返回 (假)
        }
        如果真 (图标颜色 != -1)
        {
            原色 = 取原色值 (图标数据)
            如果 (原色.取字节集长度 () == 1)
            {
                图标数据 = 添加现色值 (图标数据, 现色)
            }
            否则
            {
                子字节集替换 (图标数据, 原色, 文本到UTF8_ (现色))
            }
        }
        如果真 (SVG绘制.加载SVG数据 (图标数据) == 假)
        {
            返回 (假)
        }
        如果真 (文件类型 < 0 || 文件类型 > 2)
        {
            文件类型 = 0
        }
        背景颜色 = RGB到RGBA (背景颜色)
        如果真 (文件类型 == 1 && 背景颜色 == 0)
        {
            背景颜色 = RGB到RGBA (颜色类.白色)
        }
        SVG图片 = SVG绘制.取图片 (宽度, 高度, 背景颜色)
        SVG图片.分配RGBA ()
        返回 (SVG图片.到文件 (保存路径, 文件类型))
    }

    方法 取原色值 <类型 = 字节集类 折叠>
    参数 内容 <类型 = 字节集类>
    {
        变量 开始 <类型 = 文本型 值 = "\"#">
        变量 结束 <类型 = 文本型 值 = "\"">
        变量 结果 <类型 = 字节集类>
        结果 = 文本到UTF8_ ("#")
        结果.添加字节集 (取字节集中间_ (内容, 文本到UTF8_ (开始), 文本到UTF8_ (结束)))
        返回 (结果)
    }

    方法 添加现色值 <类型 = 字节集类 折叠>
    参数 内容 <类型 = 字节集类>
    参数 现色 <类型 = 文本型>
    {
        变量 开始 <类型 = 文本型 值 = "p-id=\"">
        变量 开始2 <类型 = 文本型 值 = "fill=\"">
        变量 结束 <类型 = 文本型 值 = "\"">
        变量 结果 <类型 = 字节集类>
        变量 位值 <类型 = 整数>
        结果 = 取字节集中间_ (内容, 文本到UTF8_ (开始), 文本到UTF8_ (结束))
        位值 = 内容.寻找字节集 (结果)
        如果 (位值 == -1)
        {
            返回 (内容)
        }
        内容.插入字节集 (位值 + 取字节集长度 (结果) + 1, 文本到UTF8_ (" " + 开始2 + 现色 + 结束))
        返回 (内容)
    }

    方法 RGB到RGBA <类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 RGB <类型 = 整数>
    参数 透明通道 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    参数 颜色透明时返回0 <类型 = 逻辑型 注释 = "颜色等于透明色时返回0" @默认值 = 真>
    {
        如果真 (颜色透明时返回0 && RGB == 颜色类.透明色)
        {
            返回 (0)
        }
        @ UINT r,g,b ;
        @ r = GetRValue(@<RGB>);
        @ g = GetGValue(@<RGB>);
        @ b = GetBValue(@<RGB>);
        @ UINT argb  = (r << 24) | (g << 16) | (b << 8) | @<透明通道>;
        @ return argb;
    }
}

类 SVG绘制类_ <注释 = "本类库修改自“林峰”的模块" 折叠 @文档 = "category = \"图像处理库.SVG矢量图形\"">
{
    变量 临时文件名 <类型 = 文本型>

    # @begin
    # <> <include>
    #     std::unique_ptr<lunasvg::Document> document = NULL;
    # <> </include>
    # @begin

    方法 类_清理 <折叠>
    {
        如果真 (文件是否存在 (临时文件名))
        {
            删除文件 (临时文件名)
        }
    }

    方法 加载SVG文件 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 SVG文件路径 <类型 = 文本型>
    {
        @ document = lunasvg::Document::loadFromFile(GetMbsText (@<SVG文件路径>.GetText (), CVolMem(), NULL));
        @ if(!document){return false;}return true;
    }

    方法 加载SVG数据 <公开 类型 = 逻辑型 折叠>
    参数 SVG数据 <类型 = 字节集类>
    {
        如果真 (文件是否存在 (临时文件名))
        {
            删除文件 (临时文件名)
        }
        临时文件名 = 取临时文件名 ()
        写到文件 (临时文件名, SVG数据)
        返回 (加载SVG文件 (临时文件名))
    }

    方法 RGB到RGBA <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 RGB <类型 = 整数>
    参数 透明通道 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    参数 颜色透明时返回0 <类型 = 逻辑型 注释 = "颜色等于透明色时返回0" @默认值 = 真>
    {
        如果真 (颜色透明时返回0 && RGB == 颜色类.透明色)
        {
            返回 (0)
        }
        @ UINT r,g,b ;
        @ r = GetRValue(@<RGB>);
        @ g = GetGValue(@<RGB>);
        @ b = GetBValue(@<RGB>);
        @ UINT argb  = (r << 24) | (g << 16) | (b << 8) | @<透明通道>;
        @ return argb;
    }

    方法 RGB到ARGB <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 RGB <类型 = 整数>
    参数 透明通道 <类型 = 整数 注释 = "0xFF" @默认值 = 255>
    参数 颜色透明时返回0 <类型 = 逻辑型 注释 = "颜色等于透明色时返回0" @默认值 = 真>
    {
        如果真 (颜色透明时返回0 && RGB == 颜色类.透明色)
        {
            返回 (0)
        }
        @ UINT r,g,b ;
        @ r = GetRValue(@<RGB>);
        @ g = GetGValue(@<RGB>);
        @ b = GetBValue(@<RGB>);
        @ UINT argb  = (@<透明通道> << 24) | (r << 16) | (g << 8) | b;
        @ return argb;
    }

    方法 取图片 <公开 类型 = SVG图片类_ 折叠>
    参数 宽度 <类型 = 整数 @默认值 = 0>
    参数 高度 <类型 = 整数 @默认值 = 0>
    参数 背景颜色 <类型 = 整数 @默认值 = 0x00000000>
    {
        变量 图片数据 <类型 = SVG图片类_>
        @ @<图片数据>.bitmap = lunasvg::Bitmap(document->renderToBitmap(@<宽度>,@<高度>,@<背景颜色>));
        返回 (图片数据)
    }
}

类 SVG图片类_ <折叠 @文档 = "category = \"图像处理库.SVG矢量图形\"">
{

    # @begin
    # <> <include>
    # public: lunasvg::Bitmap bitmap;
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom){bitmap = objCopyFrom.bitmap;}
    # <> </include>
    # @end

    方法 分配RGBA <公开 注释 = "分配颜色" 折叠>
    {
        @ bitmap.convertToRGBA();
    }

    方法 到文件 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 文件类型 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    {
        @ CU8String u8str (@<文件路径>.GetText());
        如果 (文件类型 == 1)
        {
            @ return stbi_write_bmp(u8str.GetText(), int(bitmap.width()), int(bitmap.height()), 4, bitmap.data()) == 1;
        }
        否则 (文件类型 == 2)
        {
            @ return stbi_write_tga(u8str.GetText(), int(bitmap.width()), int(bitmap.height()), 4, bitmap.data()) == 1;
        }
        否则
        {
            @ return stbi_write_png(u8str.GetText(), int(bitmap.width()), int(bitmap.height()), 4, bitmap.data(), 0) == 1;
        }
    }

    方法 到数据 <公开 类型 = 字节集类 注释 = "图片数据为ARGB" 折叠>
    参数 文件类型 <类型 = 整数 注释 = "0、png 1、bmp 2、tga" @默认值 = 0>
    {
        如果 (文件类型 != 0)
        {
            变量 临时文件名 <类型 = 文本型>
            变量 字节集 <类型 = 字节集类>
            临时文件名 = 取临时文件名 ()
            到文件 (临时文件名, 文件类型)
            字节集 = 读入文件 (临时文件名)
            删除文件 (临时文件名)
            返回 (字节集)
        }
        变量 返回的数据 <类型 = 字节集类>
        变量 i <类型 = 整数>
        变量 len <类型 = 整数>
        @ unsigned char* data = stbi_write_png_to_mem(bitmap.data(), 0, int(bitmap.width()), int(bitmap.height()), 4, &@<len>);
        @ if(!data){return @<返回的数据>;}
        循环 (, len, i)
        {
            @ @<返回的数据>.AddValue_S_BYTE((int)data[@<i>]);
        }
        返回 (返回的数据)
    }

    方法 宽度 <公开 属性读 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ return bitmap.width();
    }

    方法 高度 <公开 属性读 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ return bitmap.height();
    }
}

