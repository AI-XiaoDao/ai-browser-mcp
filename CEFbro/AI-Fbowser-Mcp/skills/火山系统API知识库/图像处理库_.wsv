    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_参数个数 <类型 = 整数 注释 = "最少1个参数" @默认值 = 1>
    {
        @ if( @<参数_参数个数> < 1) return false;
        @ m_data.Alloc(sizeof(Gdiplus::EncoderParameters) + (@<参数_参数个数>-1) * sizeof(Gdiplus::EncoderParameter), TRUE);
        @ m_deque.resize(@<参数_参数个数>);
        @ ptr()->Count = @<参数_参数个数>;
        @ return true;
    }

