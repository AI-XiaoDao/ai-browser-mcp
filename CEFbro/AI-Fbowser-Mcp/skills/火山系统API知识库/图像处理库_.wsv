    常量 旋转90度水平翻转 <公开 值 = 5 注释 = "Rotate90FlipX">
    常量 旋转180度水平翻转 <公开 值 = 6 注释 = "Rotate180FlipX">
    常量 旋转270度水平翻转 <公开 值 = 7 注释 = "Rotate270FlipX">
    常量 不旋转垂直翻转 <公开 值 = 6 注释 = "RotateNoneFlipY">
    常量 旋转90度垂直翻转 <公开 值 = 7 注释 = "Rotate90FlipY">
    常量 旋转180度垂直翻转 <公开 值 = 4 注释 = "Rotate180FlipY">
    常量 旋转270度垂直翻转 <公开 值 = 5 注释 = "Rotate270FlipY">
    常量 不旋转水平和垂直翻转 <公开 值 = 2 注释 = "RotateNoneFlipXY">
    常量 旋转90度水平和垂直翻转 <公开 值 = 3 注释 = "Rotate90FlipXY">
    常量 旋转180度水平和垂直翻转 <公开 值 = 0 注释 = "Rotate180FlipXY">
    常量 旋转270度水平和垂直翻转 <公开 值 = 1 注释 = "Rotate270FlipXY">

