        @ return (INT_P)hEmf;


    }

    方法 播放记录 <公开 类型 = 逻辑型 注释 = "PlayRecord"
            注释 = "与 Graphics::EnumerateMetafile 结合使用以播放 EMF+ 如果数据是 EMF 或 EMF+，则数据必须是 DWORD 对齐的。 如果它是 WMF，它必须是 WORD 对齐的。" @禁止流程检查 = 真>
    参数 参数_记录类型 <类型 = 整数 注释 = "EmfPlusRecordType">
    参数 参数_标志 <类型 = 整数>
    参数 参数_数据大小 <类型 = 整数>
    参数 参数_数据指针 <类型 = 变整数>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipPlayMetafileRecord((Gdiplus::GpMetafile *)nativeImage, (Gdiplus::EmfPlusRecordType)@<参数_记录类型>,@<参数_标志>,@<参数_数据大小>,(const BYTE *)@<参数_数据指针>)) == Gdiplus::Ok;


    }

    方法 置下层光栅化限制 <公开 类型 = 逻辑型 注释 = "SetDownLevelRasterizationLimit" @禁止流程检查 = 真>
    参数 参数_光栅化限制 <类型 = 整数>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetMetafileDownLevelRasterizationLimit((Gdiplus::GpMetafile *)nativeImage, @<参数_光栅化限制>)) == Gdiplus::Ok;
    }

    方法 取下层光栅化限制 <公开 类型 = 整数 注释 = "GetDownLevelRasterizationLimit" @禁止流程检查 = 真>
    {
        @ UINT    metafileRasterizationLimitDpi = 0;
        @ SetStatus(Gdiplus::DllExports::GdipGetMetafileDownLevelRasterizationLimit((Gdiplus::GpMetafile *)nativeImage, &metafileRasterizationLimitDpi));
        @ return metafileRasterizationLimitDpi;
    }

    方法 EMF到WMF数据 <公开 静态 类型 = 字节集类 注释 = "EmfToWmfBits" @禁止流程检查 = 真>
    参数 参数_EMF句柄 <类型 = 变整数 注释 = "HENHMETAFILE">
    参数 参数_映射模式 <类型 = 整数 注释 = "MM_ANISOTROPIC" @默认值 = 8>
    参数 参数_标志 <类型 = 整数 @默认值 = 0>
    {
        @ UINT cbData16 = Gdiplus::DllExports::GdipEmfToWmfBits((HENHMETAFILE)@<参数_EMF句柄>,0, NULL, @<参数_映射模式>, @<参数_标志>);
        @ @an<CVolMem> buff;
        @ buff.Alloc(cbData16, TRUE);
        @ Gdiplus::DllExports::GdipEmfToWmfBits((HENHMETAFILE)@<参数_EMF句柄>,cbData16 , (LPBYTE)buff.GetPtr(), @<参数_映射模式>, @<参数_标志>);
        @ return buff;
    }

    #
}

