类 GP混合品质 <公开 注释 = "CompositingQuality" 注释 = "当源像素与目标像素组合在一起以生成生成的像素时，组合完成。 组合的质量与输出的视觉质量直接相关，与呈现时间成反比。"
        注释 = "质量越高，呈现时间越慢。 这是因为质量级别越高，复合期间需要考虑周围像素越多。" 注释 = "线性质量设置 (AssumeLinear) 通过以略低的速度提供比默认质量更好的质量来妥协。" 折叠 折叠2
        @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 整数>
{
    常量 无效 <公开 值 = -1 注释 = "CompositingQualityInvalid">
    常量 默认 <公开 值 = 0 注释 = "CompositingQualityDefault">
    常量 高性能 <公开 值 = 1 注释 = "CompositingQualityHighSpeed">
    常量 高质量 <公开 值 = 2 注释 = "CompositingQualityHighQuality">
    常量 伽玛校正 <公开 值 = 3 注释 = "CompositingQualityGammaCorrected">
    常量 假定线性 <公开 值 = 4 注释 = "CompositingQualityAssumeLinear">

    #
}

