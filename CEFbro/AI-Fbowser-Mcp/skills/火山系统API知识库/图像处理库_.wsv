    方法 克隆 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "创建一个新的 GP区域类 对象，该对象是本对象的副本。" @禁止流程检查 = 真>
    参数 参数_新区域 <类型 = GP区域类 "">
    {
        @ @<参数_新区域>.Destory();
        @ Gdiplus::GpRegion* clone;
        @ SetStatus(Gdiplus::DllExports::GdipCloneRegion(nativeRegion, &clone));
        @ @<参数_新区域>.nativeRegion = clone;
        @ @<参数_新区域>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;

    }

