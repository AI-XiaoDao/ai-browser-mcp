    方法 取句柄 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (INT_P)nativeImage;


    }

    方法 取最后状态 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ Gdiplus::Status lastStatus = lastResult;
        @ lastResult = Gdiplus::Ok;
        @ return (int)lastStatus;
    }

    方法 销毁 <公开 注释 = "可以手动销毁, 但超出作用域也会自动销毁." @禁止流程检查 = 真>
    {
        @ this->Destory();

    }

    方法 克隆 <公开 类型 = 逻辑型 注释 = "Clone" 注释 = "创建一个新的 GP图像类 对象，该对象是本对象的副本。" @禁止流程检查 = 真>
    参数 参数_新图像 <类型 = GP图像类 "">
    {
        @ @<参数_新图像>.Destory();
        @ Gdiplus::GpImage* clone;
        @ SetStatus(Gdiplus::DllExports::GdipCloneImage(nativeImage, &clone));
        @ @<参数_新图像>.nativeImage = clone;
        @ @<参数_新图像>.lastResult = lastResult;
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自文件 <公开 类型 = 逻辑型 注释 = "FromFile" 注释 = "基于文件创建一个 GP图像类 对象。" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_文件名 <类型 = 文本型 注释 = "图像文件路径">
    参数 参数_使用嵌入式色彩管理 <类型 = 逻辑型 注释 = "可选的。 指定新 GP图像类 对象是否根据嵌入在文件中的颜色管理信息应用颜色校正。" 注释 = "嵌入的信息可以包括国际色彩联盟 (ICC) 配置文件、伽马值和色度信息。"
            注释 = "真 指定启用色彩校正，假 指定不启用色彩校正。 默认值为 假。" @默认值 = 假>
    {
        @ this->Destory();
        @ if(@<参数_使用嵌入式色彩管理>)
        @ {
        @     lastResult = Gdiplus::DllExports::GdipLoadImageFromFileICM(@<参数_文件名>, &nativeImage);
        @ }
        @ else{      
        @     lastResult = Gdiplus::DllExports::GdipLoadImageFromFile(@<参数_文件名>, &nativeImage);
        @ }
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "FromStream" 注释 = "基于字节集创建一个新的 GP图像类 对象。" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_字节集 <类型 = 字节集类 注释 = "图像字节集数据">
    参数 参数_使用嵌入式色彩管理 <类型 = 逻辑型 注释 = "可选的。 指定新 GP图像类 对象是否根据嵌入在字节集中的颜色管理信息应用颜色校正。" 注释 = "嵌入的信息可以包括国际色彩联盟 (ICC) 配置文件、伽马值和色度信息。"
            注释 = "真 指定启用色彩校正，假 指定不启用色彩校正。 默认值为 假。" @默认值 = 假>
    {
        @ this->Destory();
        @ m_stream = CreateStream(@<参数_字节集>);
        @ if(@<参数_使用嵌入式色彩管理>)
        @ {
        @     lastResult = Gdiplus::DllExports::GdipLoadImageFromStreamICM(m_stream, &nativeImage);
        @ }
        @ else{      
        @     lastResult = Gdiplus::DllExports::GdipLoadImageFromStream(m_stream, &nativeImage);
        @ }
        @ return lastResult == Gdiplus::Ok;
    }

    方法 保存到文件 <公开 类型 = 逻辑型 注释 = "Save" 注释 = "将此图像保存到文件中。" @嵌入式方法 = "">
    参数 参数_文件名 <类型 = 文本型>
    参数 参数_图像格式 <类型 = "字节 []" 注释 = "GP图像格式 枚举常量" @默认值 = GP图像格式.BMP>
    参数 参数_编码器参数 <类型 = GP编码器参数集 注释 = "该对象包含编码器使用的参数。" @默认值 = 空对象>
    {
        @ @sn<this>.Save(@<参数_文件名>.GetText(), &@<参数_图像格式>[0], @<参数_编码器参数>.ptr())
    }

    方法 保存到字节集 <公开 类型 = 逻辑型 注释 = "Save" 注释 = "将此图像保存到字节集中。" @嵌入式方法 = "">
    参数 参数_字节集 <类型 = 字节集类 注释 = "目标字节集, 图像将保存到此字节集类对象中">
    参数 参数_图像格式 <类型 = "字节 []" 注释 = "GP图像格式 枚举常量" @默认值 = GP图像格式.BMP>
    参数 参数_编码器参数 <类型 = GP编码器参数集 注释 = "该对象包含编码器使用的参数。" @默认值 = 空对象>
    {
        @ @sn<this>.Save(@<参数_字节集>, &@<参数_图像格式>[0], @<参数_编码器参数>.ptr())
    }

    方法 保存添加 <公开 类型 = 逻辑型 注释 = "SaveAdd" 注释 = "将帧添加到先前调用 保存到文件 或 保存到字节集 方法时指定的文件或字节集中。" 注释 = "使用此方法将多帧图像中的选定帧保存到另一个多帧图像。"
            @禁止流程检查 = 真>
    参数 参数_编码器参数 <类型 = GP编码器参数集 注释 = "该对象包含编码器使用的参数。" @默认值 = 空对象>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSaveAdd(nativeImage,@<参数_编码器参数>.ptr())) == Gdiplus::Ok;

    }

    方法 保存添加图像 <公开 类型 = 逻辑型 注释 = "SaveAdd" 注释 = "将帧添加到先前调用 保存到文件 或 保存到字节集 方法时指定的文件或字节集中。" @禁止流程检查 = 真>
    参数 参数_图像 <类型 = GP图像类 注释 = "包含要添加的帧的 GP图像类 对象。">
    参数 参数_编码器参数 <类型 = GP编码器参数集 注释 = "该对象包含编码器使用的参数。" @默认值 = 空对象>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSaveAddImage(nativeImage, @<参数_图像>.nativeImage, @<参数_编码器参数>.ptr())) == Gdiplus::Ok;



    }

    方法 取类型 <公开 类型 = GP图像类型 注释 = "GetType" 注释 = "获取此 GP图像类 对象的类型（位图或元文件）。" @禁止流程检查 = 真>
    {
        @ Gdiplus::ImageType type = Gdiplus::ImageTypeUnknown;
        @ SetStatus(Gdiplus::DllExports::GdipGetImageType(nativeImage, &type));
        @ return type;

