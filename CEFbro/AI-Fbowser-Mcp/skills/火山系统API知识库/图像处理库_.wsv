    常量 缩略图条带字节数 <公开 类型 = 整数 值 = @PropertyTagThumbnailStripBytesCount 注释 = "对于每个缩略图图像条带，该条带中的总字节数。"
            注释 = "类型: 整数型 或 短整数型 , 成员数: 缩略图中的条带数">
    常量 缩略图水平分辨率 <公开 类型 = 整数 值 = @PropertyTagThumbnailResolutionX 注释 = "宽度方向的缩略图分辨率。分辨率单位在 缩略图分辨率单位 中给出。">
    常量 缩略图垂直分辨率 <公开 类型 = 整数 值 = @PropertyTagThumbnailResolutionY 注释 = "高度方向的缩略图分辨率。分辨率单位在 缩略图分辨率单位 中给出。">
    常量 缩略图平面配置 <公开 类型 = 整数 值 = @PropertyTagThumbnailPlanarConfig 注释 = "缩略图中的像素分量是以块状还是平面格式记录的。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 缩略图分辨率单位 <公开 类型 = 整数 值 = @PropertyTagThumbnailResolutionUnit 注释 = "缩略图的水平分辨率和垂直分辨率的度量单位。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 缩略图转换函数 <公开 类型 = 整数 值 = @PropertyTagThumbnailTransferFunction 注释 = "指定缩略图的转换函数的表。" 注释 = "类型: 短整数型 , 成员数: 表所需的 16 位字总数">
    常量 缩略图软件名 <公开 类型 = 整数 值 = @PropertyTagThumbnailSoftwareUsed 注释 = "指定用于生成缩略图的设备的软件或固件的名称和版本的空终止字符串。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 缩略图创建时间 <公开 类型 = 整数 值 = @PropertyTagThumbnailDateTime 注释 = "创建缩略图的日期和时间。" 注释 = "类型: ASCII , 成员数: 20">
    常量 缩略图作者 <公开 类型 = 整数 值 = @PropertyTagThumbnailArtist 注释 = "指定创建缩略图的人的姓名的空终止字符串。" 注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 缩略图白点色度 <公开 类型 = 整数 值 = @PropertyTagThumbnailWhitePoint 注释 = "缩略图白点的色度。" 注释 = "类型: 分数 , 成员数: 2">
    常量 缩略图主要色度 <公开 类型 = 整数 值 = @PropertyTagThumbnailPrimaryChromaticities 注释 = "对于缩略图中的三种基色中的每一种，该颜色的色度。"
            注释 = "类型: 分数 , 成员数: 6">
    常量 缩略图YCbCr系数 <公开 类型 = 整数 值 = @PropertyTagThumbnailYCbCrCoefficients 注释 = "缩略图图像从 RGB 到 YCbCr 数据的转换系数。"
            注释 = "类型: 分数 , 成员数: 3">
    常量 缩略图YCbCr子采样 <公开 类型 = 整数 值 = @PropertyTagThumbnailYCbCrSubsampling 注释 = "与缩略图图像的亮度分量相关的色度分量的采样率。"
            注释 = "类型: 短整数型 , 成员数: 2">
    常量 缩略图YCbCr位置 <公开 类型 = 整数 值 = @PropertyTagThumbnailYCbCrPositioning 注释 = "色度分量相对于缩略图图像的亮度分量的位置。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 缩略图参考黑白点 <公开 类型 = 整数 值 = @PropertyTagThumbnailRefBlackWhite 注释 = "缩略图的参考黑点值和参考白点值。" 注释 = "类型: 分数 , 成员数: 6">
    常量 缩略图版权信息 <公开 类型 = 整数 值 = @PropertyTagThumbnailCopyRight 注释 = "包含缩略图版权信息的空终止字符串。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 亮度表 <公开 类型 = 整数 值 = @PropertyTagLuminanceTable 注释 = "亮度表和色度表用于控制JPEG质量。一个有效的亮度或色度表有 64 个 短整数 类型的条目。"
            注释 = "如果图像具有亮度表或色度表，则它必须同时具有这两个表" 注释 = "类型: 短整数型 , 成员数: 64">
    常量 色度表 <公开 类型 = 整数 值 = @PropertyTagChrominanceTable 注释 = "亮度表和色度表用于控制JPEG质量。一个有效的亮度或色度表有 64 个 短整数 类型的条目。"
            注释 = "如果图像具有亮度表或色度表，则它必须同时具有这两个表。" 注释 = "类型: 短整数型 , 成员数: 64">
    常量 帧延迟 <公开 类型 = 整数 值 = @PropertyTagFrameDelay 注释 = "动画 GIF 图像中两帧之间的时间延迟，以百分之一秒为单位。" 注释 = "类型: 整数型 , 成员数: 图像中的帧数">
    常量 循环次数 <公开 类型 = 整数 值 = @PropertyTagLoopCount 注释 = "对于动画 GIF 图像，显示动画的次数。 值 0 指定动画应无限显示。" 注释 = "类型: 短整数型 , 成员数: 1">
    常量 像素单位 <公开 类型 = 整数 值 = @PropertyTagPixelUnit 注释 = "PropertyTagPixelPerUnitX 和 PropertyTagPixelPerUnitY 的单位。"
            注释 = "类型: 字节型 , 成员数: 1 (0 - 未知)">
    常量 水平每像素单位 <公开 类型 = 整数 值 = @PropertyTagPixelPerUnitX 注释 = "x 方向上的每单位像素数。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 垂直每像素单位 <公开 类型 = 整数 值 = @PropertyTagPixelPerUnitY 注释 = "y 方向上的每单位像素数。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 直方图调色板 <公开 类型 = 整数 值 = @PropertyTagPaletteHistogram 注释 = "调色板直方图。" 注释 = "类型: 字节型 , 成员数: 直方图的长度">
    常量 曝光时间 <公开 类型 = 整数 值 = @PropertyTagExifExposureTime 注释 = "曝光时间，以秒为单位。" 注释 = "类型: 分数 , 成员数: 1">
    常量 焦距 <公开 类型 = 整数 值 = @PropertyTagExifFNumber 注释 = "焦距" 注释 = "类型: 分数 , 成员数: 1">
    常量 曝光模式 <公开 类型 = 整数 值 = @PropertyTagExifExposureProg 注释 = "相机在拍摄照片时用来设置曝光的程序类。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "0 - 未定义 1 - 手动 2 - 普通程序 3 - 光圈优先 4 - 快门优先 5 - 创意程序（偏向景深）" 注释 = "6 - 动作程序（偏向于快速快门） 7 - 人像模式（用于特写） 背景失焦的照片）"
            注释 = "8 - 风景模式（用于背景对焦的风景照片） 9 至 255 - 保留">
    常量 光谱感应 <公开 类型 = 整数 值 = @PropertyTagExifSpectralSense 注释 = "指定所用相机每个通道的光谱灵敏度的空终止字符串。 该字符串与 ASTM 技术委员会制定的标准兼容。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 感光度 <公开 类型 = 整数 值 = @PropertyTagExifISOSpeed 注释 = "ISO 12232 中指定的相机或输入设备的 ISO 速度和 ISO 纬度。" 注释 = "类型: 短整数型 , 成员数: 任意">
    常量 光电转换函数 <公开 类型 = 整数 值 = @PropertyTagExifOECF 注释 = "ISO 14524 中规定的光电转换函数 (OECF)。OECF 是相机光学输入和图像值之间的关系。"
            注释 = "类型: 未定义 , 成员数: 任意">
    常量 版本 <公开 类型 = 整数 值 = @PropertyTagExifVer 注释 = "支持的 EXIF 标准版本。 不存在该字段意味着不符合标准。" 注释 = "通过将 0210 记录为 4 字节 ASCII 字符串表示符合标准。"
            注释 = "因为类型是 PropertyTagTypeUndefined，所以没有 NULL 终止符。" 注释 = "类型: 未定义 , 成员数: 4 (默认: 0210)">
    常量 原始时间 <公开 类型 = 整数 值 = @PropertyTagExifDTOrig 注释 = "生成原始图像数据的日期和时间。 对于 DSC，拍摄照片的日期和时间。 格式为 YYYY:MM:DD HH:MM:SS，"
            注释 = "时间以 24 小时格式显示，日期和时间由一个空白字符 (0x2000) 分隔。" 注释 = "字符串长度为 20 字节，包括 NULL 终止符。 当该字段为空时，它被视为未知。"
            注释 = "类型: ASCII , 成员数: 20">
    常量 数字时间 <公开 类型 = 整数 值 = @PropertyTagExifDTDigitized 注释 = "图像作为数字数据存储的日期和时间。 例如，如果 DSC 捕获图像并同时记录文件，"
            注释 = "则 原始时间 和 数字时间 将具有相同的内容。" 注释 = "格式为 YYYY:MM:DD HH:MM:SS，时间以 24 小时格式显示，日期和时间由一个空白字符 (0x2000) 分隔。"
            注释 = "字符串长度为 20 字节，包括 NULL 终止符。 当该字段为空时，它被视为未知。" 注释 = "类型: ASCII , 成员数: 20">
    常量 压缩配置 <公开 类型 = 整数 值 = @PropertyTagExifCompConfig 注释 = "特定于压缩数据的信息。 每个分量的通道从第一个分量到第四个分量依次排列。"
            注释 = "对于未压缩的数据，数据排列在 光度学解释 标签中给出。" 注释 = "但是，由于 光度学解释 只能表示 Y、Cb 和 Cr 的顺序，因此在压缩数据使用 Y、Cb 和 Cr 以外的组件并支持其他序列的情况下提供此标记。"
            注释 = "类型: 未定义 , 成员数: 4" 注释 = "4 5 6 0（如果 RGB 未压缩） 1 2 3 0（其他情况）"
            注释 = "0 - 不存在 1 - Y 2 - Cb 3 - Cr 4 - R 5 - G 6 - B 其他 - 保留">
    常量 压缩比率 <公开 类型 = 整数 值 = @PropertyTagExifCompBPP 注释 = "特定于压缩数据的信息。用于压缩图像的压缩模式以单位 BPP 表示。" 注释 = "类型: 分数 , 成员数: 1">
    常量 快门速度 <公开 类型 = 整数 值 = @PropertyTagExifShutterSpeed 注释 = "快门速度。单位是摄影曝光加性系统 (APEX) 值。" 注释 = "类型: 分数 , 成员数: 1">
    常量 光圈 <公开 类型 = 整数 值 = @PropertyTagExifAperture 注释 = "镜头光圈。单位是 APEX 值。" 注释 = "类型: 分数 , 成员数: 1">
    常量 亮度 <公开 类型 = 整数 值 = @PropertyTagExifBrightness 注释 = "亮度值。 单位是 APEX 值。 通常它在 -99.99 到 99.99 的范围内给出。"
            注释 = "类型: 有符号分数 , 成员数: 1">
    常量 曝光偏差 <公开 类型 = 整数 值 = @PropertyTagExifExposureBias 注释 = "曝光偏差。 单位是 APEX 值。 通常它在 -99.99 到 99.99 的范围内给出。"
            注释 = "类型: 有符号分数 , 成员数: 1">
    常量 最大光圈 <公开 类型 = 整数 值 = @PropertyTagExifMaxAperture 注释 = "镜头的最小 F 数。 单位是 APEX 值。 通常在00.00到99.99的范围内给出，但不限于此范围。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 主体距离 <公开 类型 = 整数 值 = @PropertyTagExifSubjectDist 注释 = "到对象的距离，以米为单位。" 注释 = "类型: 分数 , 成员数: 1">
    常量 测光模式 <公开 类型 = 整数 值 = @PropertyTagExifMeteringMode 注释 = "测光模式。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "0 - 未知 1 - 平均 2 - 中央重点测光 3 - 点测光 4 - 多点测光 5 - 模式" 注释 = "6 - 局部测光 7 到 254 - 保留 255 - 其他">
    常量 白平衡 <公开 类型 = 整数 值 = @PropertyTagExifLightSource 注释 = "光源类型。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "0 - 未知 1 - 日光 2 - 荧光灯 3 - 钨丝灯 17 - 标准灯A 18 - 标准灯B"
            注释 = "19 - 标准灯C 20 - D55 21 - D65 22 - D75 23 至 254 - 保留 255 - 其他">
    常量 闪光灯 <公开 类型 = 整数 值 = @PropertyTagExifFlash 注释 = "闪光状态。 当使用频闪灯（闪光灯）拍摄图像时，会记录此标记。" 注释 = "Bit 0 表示闪光状态，Bit 1 和 2 表示闪光返回状态。"
            注释 = "类型: 短整数型 , 成员数: 1" 注释 = "指示闪光灯是否闪光的位 0 值： 0b - 闪光灯未闪光 1b - 闪光灯已闪光"
            注释 = "指示返回光状态的位 1 和 2 的值： 00b - 无闪光灯返回检测功能 01b - 保留 10b - 未检测到闪光灯返回光 11b - 检测到闪光灯返回光"
            注释 = "产生的闪光灯标签值： 0x0000 - 闪光灯未触发 0x0001 - 闪光灯已触发 0x0005 - 未检测到闪光灯返回光">
    常量 实际焦距 <公开 类型 = 整数 值 = @PropertyTagExifFocalLength 注释 = "镜头的实际焦距，以毫米为单位。 不转换为 35 毫米胶片相机的焦距。" 注释 = "类型: 分数 , 成员数: 1">
    常量 主体区域 <公开 类型 = 整数 值 = @PropertyTagExifSubjectArea>
    常量 制造商注释 <公开 类型 = 整数 值 = @PropertyTagExifMakerNote 注释 = "注释标签。 EXIF 编写器制造商用来记录信息的标签。 内容由制造商决定。" 注释 = "类型: 未定义 , 成员数: 任意">
    常量 用户注释 <公开 类型 = 整数 值 = @PropertyTagExifUserComment 注释 = "注释标签。 EXIF 用户用来编写关于图像的关键字或评论的标签，除了 图像描述 中的那些，"
            注释 = "并且没有 图像描述 标签的字符代码限制。" 注释 = "类型: 未定义 , 成员数: 任意">
    常量 创建时间秒数 <公开 类型 = 整数 值 = @PropertyTagExifDTSubsec 注释 = "为 创建时间 标签指定几分之一秒的空终止字符串。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 原始时间秒数 <公开 类型 = 整数 值 = @PropertyTagExifDTOrigSS 注释 = "为 原始时间 标签指定几分之一秒的空终止字符串。"
            注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 数字时间秒数 <公开 类型 = 整数 值 = @PropertyTagExifDTDigSS 注释 = "为 数字时间 标签指定几分之一秒的空终止字符串。" 注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 FPX版本 <公开 类型 = 整数 值 = @PropertyTagExifFPXVer
            注释 = "FPXR 文件支持的 FlashPix 格式版本。 如果 FPXR 函数支持 FlashPix 格式版本 1.0，这与 PropertyTagExifVer 类似，"
            注释 = "将 0100 记录为 4 字节 ASCII 字符串。 因为类型是 未定义，所以没有 NULL 终止符。" 注释 = "类型: 未定义 , 成员数: 4" 注释 = "0100 - FlashPix格式版本1.0  其他 - 保留">
    常量 颜色空间 <公开 类型 = 整数 值 = @PropertyTagExifColorSpace 注释 = "色彩空间说明符。 通常 sRGB (=1) 用于根据 PC 显示器条件和环境定义色彩空间。"
            注释 = "如果使用 sRGB 以外的色彩空间，则设置未校准 (=0xFFFF)。 记录为未校准的图像数据在转换为 FlashPix 时可被视为 sRGB。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "0x1 - sRGB 0xFFFF - 未校准  其他 - 保留">
    常量 有效宽度 <公开 类型 = 整数 值 = @PropertyTagExifPixXDim 注释 = "特定于压缩数据的信息。 记录压缩文件时，无论是否有填充数据或重新启动标标签，"
            注释 = "都必须在该标签中记录有意义图像的有效宽度。 此标签不应存在于未压缩的文件中。" 注释 = "类型: 短整数型 或 整数型 , 成员数: 1">
    常量 有效高度 <公开 类型 = 整数 值 = @PropertyTagExifPixYDim 注释 = "特定于压缩数据的信息。 记录压缩文件时，无论是否有填充数据或重新启动标记，都必须在此标签中记录有意义图像的有效高度。"
            注释 = "此标记不应存在于未压缩的文件中。 由于在垂直方向不需要填充数据，因此该有效图像高度标签中记录的行数将与 SOF 中记录的行数相同。" 注释 = "类型: 短整数型 或 整数型 , 成员数: 1">
    常量 相关音频文件 <公开 类型 = 整数 值 = @PropertyTagExifRelatedWav
            注释 = "与图像数据相关的音频文件的名称。 唯一记录的相关信息是 EXIF 音频文件名和扩展名（一个 ASCII 字符串，由 8 个字符加上句点 (.) 和 3 个字符组成）。"
            注释 = "不记录路径。 使用此标签时，必须按照 EXIF 音频格式录制音频文件。 编写者还可以将 APP2 中的音频数据存储为 FlashPix 扩展流数据。" 注释 = "类型: ASCII , 成员数: 13">
    常量 互操作 <公开 类型 = 整数 值 = @PropertyTagExifInterop 注释 = "偏移到包含互操作性信息的属性项块。" 注释 = "类型: 整数型 , 成员数: 1">
    常量 闪光灯输出量 <公开 类型 = 整数 值 = @PropertyTagExifFlashEnergy 注释 = "拍摄图像时的频闪能量，以光束烛光功率秒 (BCPS) 为单位。" 注释 = "类型: 分数 , 成员数: 1">
    常量 空间频率响应 <公开 类型 = 整数 值 = @PropertyTagExifSpatialFR 注释 = "相机或输入设备空间频率表以及图像宽度、图像高度和对角线方向的 SFR 值，如 ISO 12233 中所指定。"
            注释 = "类型: 未定义 , 成员数: 任意">
    常量 焦平面水平分辨率 <公开 类型 = 整数 值 = @PropertyTagExifFocalXRes 注释 = "相机焦平面上每单位图像宽度 (x) 方向上的像素数。 该单位在 焦平面分辨率单位 中指定。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 焦平面垂直分辨率 <公开 类型 = 整数 值 = @PropertyTagExifFocalYRes 注释 = "相机焦平面上每单位图像高度 (y) 方向上的像素数。 该单位在 焦平面分辨率单位 中指定。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 焦平面分辨率单位 <公开 类型 = 整数 值 = @PropertyTagExifFocalResUnit 注释 = "焦平面水平分辨率 和 焦平面垂直分辨率 的度量单位。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "2 英寸 3 厘米">
    常量 主体位置 <公开 类型 = 整数 值 = @PropertyTagExifSubjectLoc 注释 = "主要拍摄对象在场景中的位置。 此标签的值表示相对于左边缘的主要对象中心的像素。" 注释 = "第一个值表示列号，第二个值表示行号。"
            注释 = "类型: 短整数型 , 成员数: 2">
    常量 曝光指数 <公开 类型 = 整数 值 = @PropertyTagExifExposureIndex 注释 = "拍摄图像时在相机或输入设备上选择的曝光指数。" 注释 = "类型: 分数 , 成员数: 1">
    常量 感光模式 <公开 类型 = 整数 值 = @PropertyTagExifSensingMethod 注释 = "相机或输入设备上的图像传感器类型。" 注释 = "类型: 短整数型 , 成员数: 1"
            注释 = "1 - 未定义 2 - 单芯片彩色区域传感器 3 - 两芯片彩色区域传感器 4 - 三芯片彩色区域传感器" 注释 = "5 - 彩色连续区域传感器 7 - 三线传感器 8 - 彩色连续线性传感器 其他 - 保留">
    常量 文件源 <公开 类型 = 整数 值 = @PropertyTagExifFileSource 注释 = "图片来源。 如果 DSC 记录了图像，则此标签的值为 3。" 注释 = "类型: 未定义 , 成员数: 1">
    常量 场景类型 <公开 类型 = 整数 值 = @PropertyTagExifSceneType 注释 = "场景类型。 如果是DSC记录图像，则该标签的值必须设置为1，表示图像是直接拍摄的。" 注释 = "类型: 未定义 , 成员数: 1">
    常量 滤色器阵列图案 <公开 类型 = 整数 值 = @PropertyTagExifCfaPattern 注释 = "使用单芯片彩色区域传感器时图像传感器的滤色器阵列 (CFA) 几何图案。 它不适用于所有传感方法。"
            注释 = "类型: 未定义 , 成员数: 任意">
    常量 ""
    常量 GPS版本 <公开 类型 = 整数 值 = @PropertyTagGpsVer 注释 = "全球定位系统 (GPS) IFD 的版本，指定为 2.0.0.0。 当 PropertyTagGpsIFD 标签存在时，这个标签是强制性的。"
            注释 = "当版本为 2.0.0.0 时，标签值为 0x02000000。" 注释 = "类型: 字节型 , 成员数: 4">
    常量 GPS纬度参考 <公开 类型 = 整数 值 = @PropertyTagGpsLatitudeRef 注释 = "指定纬度是北还是南的空终止字符串。 N 指定北纬，S 指定南纬。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS纬度 <公开 类型 = 整数 值 = @PropertyTagGpsLatitude 注释 = "纬度表示为三个分数，分别给出度、分和秒。 表示度、分、秒时，格式为 dd/1、mm/1、ss/1。"
            注释 = "当使用度和分时，例如，分钟的分数最多保留两位小数，格式为 dd/1、mmmm/100、0/1。" 注释 = "类型: 分数 , 成员数: 3">
    常量 GPS经度参考 <公开 类型 = 整数 值 = @PropertyTagGpsLongitudeRef 注释 = "指定经度是东经还是西经的空终止字符串。 E 指定东经，W 指定西经。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS经度 <公开 类型 = 整数 值 = @PropertyTagGpsLongitude 注释 = "经度。 经度表示为三个分数，分别给出度、分和秒。 表示度、分、秒时，格式为 ddd/1、mm/1、ss/1。"
            注释 = "当使用度和分时，例如，分钟的分数最多保留两位小数，格式为 ddd/1、mmmm/100、0/1。" 注释 = "类型: 分数 , 成员数: 3">
    常量 GPS高度参考 <公开 类型 = 整数 值 = @PropertyTagGpsAltitudeRef 注释 = "参考高度，以米为单位。" 注释 = "类型: 字节型 , 成员数: 1">
    常量 GPS高度 <公开 类型 = 整数 值 = @PropertyTagGpsAltitude 注释 = "高度，以米为单位，基于 GPS高度参考 指定的参考高度。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS时间 <公开 类型 = 整数 值 = @PropertyTagGpsGpsTime 注释 = "作为协调世界时 (UTC) 的时间。该值表示为给出小时、分钟和秒的三个分数。" 注释 = "类型: 分数 , 成员数: 3">
    常量 GPS卫星 <公开 类型 = 整数 值 = @PropertyTagGpsGpsSatellites 注释 = "指定用于测量的 GPS 卫星的空终止字符串。 此标签可用于指定每个卫星的 ID 号、仰角、方位角、SNR 和其他信息。"
            注释 = "未指定格式。 如果 GPS 接收器无法进行测量，则标签的值必须设置为 NULL。" 注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 GPS状态 <公开 类型 = 整数 值 = @PropertyTagGpsGpsStatus 注释 = "以空字符结尾的字符串，用于指定记录图像时 GPS 接收器的状态。" 注释 = "A 表示正在进行测量，V 表示测量是互操作性。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS测量模式 <公开 类型 = 整数 值 = @PropertyTagGpsGpsMeasureMode 注释 = "指定 GPS 测量模式的空终止字符串。 2指定2-D测量，3指定3-D测量。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS数据精度 <公开 类型 = 整数 值 = @PropertyTagGpsGpsDop 注释 = "GPS DOP（数据精度）。 HDOP 值在 2-D 测量期间写入，PDOP 值在 3-D 测量期间写入。"
            注释 = "类型: 分数 , 成员数: 1">
    常量 GPS速度参考 <公开 类型 = 整数 值 = @PropertyTagGpsSpeedRef 注释 = "指定用于表示 GPS 接收器移动速度的单位的空终止字符串。 K、M 和 N 分别代表公里/小时、英里/小时和节。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS速度 <公开 类型 = 整数 值 = @PropertyTagGpsSpeed 注释 = "GPS 接收器移动的速度。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS轨迹参考 <公开 类型 = 整数 值 = @PropertyTagGpsTrackRef 注释 = "以空字符结尾的字符串，指定给出 GPS 接收器移动方向的参考。 T 指定真方向，M 指定磁方向。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS轨迹 <公开 类型 = 整数 值 = @PropertyTagGpsTrack 注释 = "GPS 接收器移动的方向。 值的范围是从 0.00 到 359.99。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS图像方向参考 <公开 类型 = 整数 值 = @PropertyTagGpsImgDirRef 注释 = "以空字符结尾的字符串，用于指定捕获图像时的图像方向参考。 T 指定真方向，M 指定磁方向。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS图像方向 <公开 类型 = 整数 值 = @PropertyTagGpsImgDir 注释 = "拍摄时图像的方向。值的范围是从 0.00 到 359.99。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS地图基准 <公开 类型 = 整数 值 = @PropertyTagGpsMapDatum 注释 = "指定 GPS 接收器使用的大地测量数据的空终止字符串。"
            注释 = "如果调查数据仅限于日本，则此标签的值为 TOKYO 或 WGS-84。" 注释 = "类型: ASCII , 成员数: 包含 NULL 终止符的字符串长度">
    常量 GPS目标纬度参考 <公开 类型 = 整数 值 = @PropertyTagGpsDestLatRef 注释 = "指定目标点的纬度是北纬还是南纬的空终止字符串。 N 指定北纬，S 指定南纬。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS目标纬度 <公开 类型 = 整数 值 = @PropertyTagGpsDestLat 注释 = "目的地的纬度。 纬度表示为三个分数，分别给出度、分和秒。 表示度、分、秒时，格式为 dd/1、mm/1、ss/1。"
            注释 = "当使用度和分时，例如，分钟的分数最多保留两位小数，格式为 dd/1、mmmm/100、0/1。" 注释 = "类型: 分数 , 成员数: 3">
    常量 GPS目标经度参考 <公开 类型 = 整数 值 = @PropertyTagGpsDestLongRef 注释 = "指定目标点的经度是东经还是西经的空终止字符串。 E 指定东经，W 指定西经。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS目标经度 <公开 类型 = 整数 值 = @PropertyTagGpsDestLong 注释 = "目标点的经度。 经度表示为三个有理值，分别给出度、分和秒。 表示度、分、秒时，格式为ddd/1、mm/1、ss/1。"
            注释 = "当使用度和分时，例如，分钟的分数最多保留两位小数，格式为 ddd/1、mmmm/100、0/1。" 注释 = "类型: 分数 , 成员数: 3">
    常量 GPS目标方位参考 <公开 类型 = 整数 值 = @PropertyTagGpsDestBearRef 注释 = "以空字符结尾的字符串，指定用于将方位提供给目标点的参考。 T 指定真方向，M 指定磁方向。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS目标方位 <公开 类型 = 整数 值 = @PropertyTagGpsDestBear 注释 = "指向目的地。值的范围是从 0.00 到 359.99。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS目标点参考 <公开 类型 = 整数 值 = @PropertyTagGpsDestDistRef 注释 = "以空字符结尾的字符串，指定用于表示到目标点的距离的单位。 K、M 和 N 分别代表公里、英里和节。"
            注释 = "类型: ASCII , 成员数: 2（一个字符加上 NULL 终止符）">
    常量 GPS目标点 <公开 类型 = 整数 值 = @PropertyTagGpsDestDist 注释 = "到目标点的距离。" 注释 = "类型: 分数 , 成员数: 1">
    常量 GPS处理方法 <公开 类型 = 整数 值 = @PropertyTagGpsProcessingMethod>
    常量 GPS地区信息 <公开 类型 = 整数 值 = @PropertyTagGpsAreaInformation>
    常量 GPS日期 <公开 类型 = 整数 值 = @PropertyTagGpsDate>
    常量 GPS差分 <公开 类型 = 整数 值 = @PropertyTagGpsDifferential>

    #
}

类 GP图像锁定模式 <公开 注释 = "ImageLockMode" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @禁止创建对象 = 真>
{
    常量 读 <公开 类型 = 整数 值 = 0x0001 注释 = "ImageLockModeRead 指定图像的一部分被锁定以供读取。">
    常量 写 <公开 类型 = 整数 值 = 0x0002 注释 = "ImageLockModeWrite 指定图像的一部分被锁定以进行写入。">
    常量 用户输入缓冲区 <公开 类型 = 整数 值 = 0x0004 注释 = "ImageLockModeUserInputBuf 指定用于读取或写入像素数据的缓冲区由用户分配。">

    #
}

类 GP线性渐变模式 <公开 注释 = "LinearGradientMode" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 整数>
{
    常量 水平 <公开 值 = 0 注释 = "LinearGradientModeHorizontal">
    常量 垂直 <公开 值 = 1 注释 = "LinearGradientModeVertical">
    常量 正向对角线 <公开 值 = 2 注释 = "LinearGradientModeForwardDiagonal">
    常量 反向对角线 <公开 值 = 3 注释 = "LinearGradientModeBackwardDiagonal">

    #
}

类 GP阴影风格 <公开 注释 = "LinearGradientMode" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 整数>
{
    常量 水平线 <公开 值 = 0 注释 = "HatchStyleHorizontal 水平线的图案。">
    常量 垂直线 <公开 值 = 1 注释 = "HatchStyleVertical 垂直线的图案。">
    常量 左斜线 <公开 值 = 2 注释 = "HatchStyleForwardDiagonal 从左上到右下的对角线的线条图案。">
    常量 右斜线 <公开 值 = 3 注释 = "HatchStyleBackwardDiagonal 从右上到左下的对角线的线条图案。">
    常量 十字线 <公开 值 = 4 注释 = "HatchStyleCross 指定交叉的水平线和垂直线。">
    常量 交叉斜线 <公开 值 = 5 注释 = "HatchStyleDiagonalCross 指定互相交叉的正向对角线和反向对角线。这些直线是锯齿消除的。">
    常量 百分05阴影 <公开 值 = 6 注释 = "HatchStyle05Percent 指定 5% 阴影。前景色与背景色的比例为 5:100。">
    常量 百分10阴影 <公开 值 = 7 注释 = "HatchStyle10Percent 指定 10% 阴影。前景色与背景色的比例为 10:100。">
    常量 百分20阴影 <公开 值 = 8 注释 = "HatchStyle20Percent 指定 20% 阴影。前景色与背景色的比例为 20:100。">
    常量 百分25阴影 <公开 值 = 9 注释 = "HatchStyle25Percent 指定 25% 阴影。前景色与背景色的比例为 25:100。">
    常量 百分30阴影 <公开 值 = 10 注释 = "HatchStyle30Percent 指定 30% 阴影。前景色与背景色的比例为 30:100。">
    常量 百分40阴影 <公开 值 = 11 注释 = "HatchStyle40Percent 指定 40% 阴影。前景色与背景色的比例为 40:100。">
    常量 百分50阴影 <公开 值 = 12 注释 = "HatchStyle50Percent 指定 50% 阴影。前景色与背景色的比例为 50:100。">
    常量 百分60阴影 <公开 值 = 13 注释 = "HatchStyle60Percent 指定 60% 阴影。前景色与背景色的比例为 60:100。">
    常量 百分70阴影 <公开 值 = 14 注释 = "HatchStyle70Percent 指定 70% 阴影。前景色与背景色的比例为 70:100。">
    常量 百分75阴影 <公开 值 = 15 注释 = "HatchStyle75Percent 指定 75% 阴影。前景色与背景色的比例为 75:100。">
    常量 百分80阴影 <公开 值 = 16 注释 = "HatchStyle80Percent 指定 80% 阴影。前景色与背景色的比例为 80:100。">
    常量 百分90阴影 <公开 值 = 17 注释 = "HatchStyle90Percent 指定 90% 阴影。前景色与背景色的比例为 90:100。">
    常量 细向下对角线 <公开 值 = 18 注释 = "HatchStyleLightDownwardDiagonal 指定从顶点到底点向右倾斜的对角线，并且比 左斜线 间隔更近 50%，但没有抗锯齿。">
    常量 细向上对角线 <公开 值 = 19 注释 = "HatchStyleLightUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其两边夹角比 右斜线 小 50%，但这些直线不是锯齿消除的。">
    常量 粗向下对角线 <公开 值 = 20 注释 = "HatchStyleDarkDownwardDiagonal 指定从顶点到底点向右倾斜的对角线，其两边夹角比 左斜线 小 50%，宽度是其两倍。此阴影图案不是锯齿消除的。">
    常量 粗向上对角线 <公开 值 = 21 注释 = "HatchStyleDarkUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其两边夹角比 左斜线 小 50%，宽度是其两倍，但这些直线不是锯齿消除的。">
    常量 宽向下对角线 <公开 值 = 22 注释 = "HatchStyleWideDownwardDiagonal 指定从顶点到底点向右倾斜的对角线，其间距与阴影样式 左斜线 相同，宽度是其三倍，但它们不是锯齿消除的。">
    常量 宽向上对角线 <公开 值 = 23 注释 = "HatchStyleWideUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其间距与阴影样式 右斜线 相同，宽度是其三倍，但它们不是锯齿消除的。">
    常量 细垂直线 <公开 值 = 24 注释 = "HatchStyleLightVertical 指定垂直线的两边夹角比 垂直线 小 50%。">
    常量 细水平线 <公开 值 = 25 注释 = "HatchStyleLightHorizontal 指定水平线，其两边夹角比 水平线 小 50%。">
    常量 密垂直线 <公开 值 = 26 注释 = "HatchStyleNarrowVertical 指定垂直线的两边夹角比阴影样式 垂直线 小 75%（或者比 细垂直线 小 25%）。">
    常量 密水平线 <公开 值 = 27 注释 = "HatchStyleNarrowHorizontal 指定水平线的两边夹角比阴影样式 水平线 小 75%（或者比 细水平线 小 25%）。">
    常量 粗垂直线 <公开 值 = 28 注释 = "HatchStyleDarkVertical 指定垂直线的两边夹角比 垂直线 小 50% 并且宽度是其两倍。">
    常量 粗水平线 <公开 值 = 29 注释 = "HatchStyleDarkHorizontal 指定水平线的两边夹角比水平小 50% 并且宽度是 水平线 的两倍。">
    常量 右斜虚线 <公开 值 = 30 注释 = "HatchStyleDashedDownwardDiagonal 指定虚线对角线，这些对角线从顶点到底点向右倾斜。">
    常量 左斜虚线 <公开 值 = 31 注释 = "HatchStyleDashedUpwardDiagonal 指定虚线对角线，这些对角线从顶点到底点向左倾斜。">
    常量 水平虚线 <公开 值 = 32 注释 = "HatchStyleDashedHorizontal 指定虚线水平线。">
    常量 垂直虚线 <公开 值 = 33 注释 = "HatchStyleDashedVertical 指定虚线垂直线。">
    常量 小五彩纸屑 <公开 值 = 34 注释 = "HatchStyleSmallConfetti 指定带有五彩纸屑外观的阴影。">
    常量 大五彩纸屑 <公开 值 = 35 注释 = "HatchStyleLargeConfetti 指定具有五彩纸屑外观的阴影，并且它是由比 小五彩纸屑 更大的片构成的。">
    常量 曲线 <公开 值 = 36 注释 = "HatchStyleZigZag 指定由 Z 字形构成的水平线。">
    常量 波浪线 <公开 值 = 37 注释 = "HatchStyleWave 指定由代字号“~”构成的水平线。">
    常量 对角砖块 <公开 值 = 38 注释 = "HatchStyleDiagonalBrick 指定具有分层砖块外观的阴影，它从顶点到底点向左倾斜。">
    常量 水平砖块 <公开 值 = 39 注释 = "HatchStyleHorizontalBrick 指定具有水平分层砖块外观的阴影。">
    常量 编织 <公开 值 = 40 注释 = "HatchStyleWeave 指定具有织物外观的阴影。">
    常量 花格子 <公开 值 = 41 注释 = "HatchStylePlaid 指定具有格子花呢材料外观的阴影。">
    常量 草皮 <公开 值 = 42 注释 = "HatchStyleDivot 指定具有草皮层外观的阴影。">
    常量 十字点线 <公开 值 = 43 注释 = "HatchStyleDottedGrid 指定互相交叉的水平线和垂直线，每一直线都是由点构成的。">
    常量 交叉点线 <公开 值 = 44 注释 = "HatchStyleDottedDiamond 指定互相交叉的正向对角线和反向对角线，每一对角线都是由点构成的。">
    常量 瓦片 <公开 值 = 45 注释 = "HatchStyleShingle 指定带有对角分层鹅卵石外观的阴影，它从顶点到底点向右倾斜。">
    常量 网格 <公开 值 = 46 注释 = "HatchStyleTrellis 指定具有格架外观的阴影。">
    常量 球形 <公开 值 = 47 注释 = "HatchStyleSphere 指定具有球体彼此相邻放置的外观的阴影。">
    常量 小网格 <公开 值 = 48 注释 = "HatchStyleSmallGrid 指定互相交叉的水平线和垂直线，其两边夹角比阴影样式 十字线 小 50%。">
    常量 小棋盘 <公开 值 = 49 注释 = "HatchStyleSmallCheckerBoard 指定带有棋盘外观的阴影。">
    常量 大棋盘 <公开 值 = 50 注释 = "HatchStyleLargeCheckerBoard 指定具有棋盘外观的阴影，棋盘所具有的方格大小是 SmallCheckerBoard 大小的两倍。">
    常量 边线金刚石 <公开 值 = 51 注释 = "HatchStyleOutlinedDiamond 指定互相交叉的正向对角线和反向对角线，但这些对角线不是锯齿消除的。">
    常量 金刚石 <公开 值 = 52 注释 = "HatchStyleSolidDiamond 指定具有对角放置的棋盘外观的阴影。">
    常量 无阴影线 <公开 值 = 53 注释 = "HatchStyleTotal 指定无影线从而允许画笔透明">
    常量 大网格 <公开 值 = 4 注释 = "HatchStyleLargeGrid 指定阴影样式 十字线">

    #
}

