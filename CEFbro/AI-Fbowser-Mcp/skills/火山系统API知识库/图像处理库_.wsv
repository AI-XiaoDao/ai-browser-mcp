    {
        @ Gdiplus::REAL width, height;
        @ Gdiplus::Status status;
        @ status = SetStatus(Gdiplus::DllExports::GdipGetImageDimension(nativeImage,&width, &height));
        @ @<参数_尺寸>.data().Width  = width;
        @ @<参数_尺寸>.data().Height  = height;
        @ return status == Gdiplus::Ok;

    }

    方法 取边界 <公开 类型 = GP单位 注释 = "GetBounds" 注释 = "获取此图像的边界矩形。" @嵌入式方法 = "">
