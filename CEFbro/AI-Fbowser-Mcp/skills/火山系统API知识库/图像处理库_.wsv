    }

    方法 取制表位 <公开 类型 = GP数组单精度 注释 = "GetTabStop" 返回值注释 = "数组中的每个制表位偏移量（第一个除外）都是相对于前一个的。第一个制表位偏移量相对于由 “参数_初始偏移量” 指定的初始偏移位置。"
            返回值注释 = "例如，如果初始偏移位置是 8，第一个制表位偏移量是 50，则第一个制表位的位置是 58。如果初始偏移位置是零，则第一个制表位偏移量相对于位置 0（即原点字符串）。" @禁止流程检查 = 真>
    参数 参数_初始偏移量 <类型 = 小数类 注释 = "文本行开头和第一个制表位之间的空格数" @默认值 = 空对象>
    {
        @ INT count;
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatTabStopCount(nativeFormat, &count));
        @ @dt<GP数组单精度> ret;
        @ ret.data().resize(count);
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatTabStops(nativeFormat,count, (Gdiplus::REAL*)&@<参数_初始偏移量.值>,ret.data().data()));
        @ return ret;

    }

    方法 置数字替换 <公开 类型 = 逻辑型 注释 = "SetDigitSubstitution" @禁止流程检查 = 真>
    参数 参数_数字替换 <类型 = GP文本数字替换 注释 = "GP文本数字替换 枚举">
    参数 参数_语言 <类型 = 短整数 @默认值 = 0>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetStringFormatDigitSubstitution(nativeFormat, @<参数_语言>, (Gdiplus::StringDigitSubstitute)@<参数_数字替换>)) == Gdiplus::Ok;

    }

    方法 取数字替换语言 <公开 类型 = 短整数 注释 = "GetDigitSubstitutionLanguage" @禁止流程检查 = 真>
    {
        @ LANGID language;
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatDigitSubstitution(nativeFormat, &language, NULL));
        @ return language;

    }

    方法 取数字替换方法 <公开 类型 = GP文本数字替换 注释 = "GetDigitSubstitutionMethod" 返回值注释 = "返回 GP文本数字替换 枚举" @禁止流程检查 = 真>
    {
        @ Gdiplus::StringDigitSubstitute substitute;
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatDigitSubstitution(nativeFormat, NULL, &substitute));
        @ return (@dt<GP文本数字替换>)substitute;

    }

    方法 置修整 <公开 类型 = 逻辑型 注释 = "SetTrimming" @禁止流程检查 = 真>
    参数 参数_修整 <类型 = GP文本修整 注释 = "GP文本修整 枚举">
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetStringFormatTrimming(nativeFormat, (Gdiplus::StringTrimming)@<参数_修整>)) == Gdiplus::Ok;

    }

    方法 取修整 <公开 类型 = GP文本修整 注释 = "GetTrimming" 返回值注释 = "返回 GP文本修整 枚举" @禁止流程检查 = 真>
    {
        @ Gdiplus::StringTrimming trimming;
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatTrimming(nativeFormat, &trimming));
        @ return (@dt<GP文本修整>)trimming;

    }

    方法 置测量字符范围 <公开 类型 = 逻辑型 注释 = "SetMeasurableCharacterRanges" @禁止流程检查 = 真>
    参数 参数_字符范围数组 <类型 = GP数组字符范围>
    {
        @ return SetStatus(Gdiplus::DllExports::GdipSetStringFormatMeasurableCharacterRanges(nativeFormat, (INT)@<参数_字符范围数组>.data().size(),
        @ @<参数_字符范围数组>.data().data())) == Gdiplus::Ok;

    }

    方法 取测量字符范围数 <公开 类型 = 整数 注释 = "GetMeasurableCharacterRangeCount" @禁止流程检查 = 真>
    {
        @ INT count;
        @ SetStatus(Gdiplus::DllExports::GdipGetStringFormatMeasurableCharacterRangeCount(nativeFormat, &count));
        @ return count;

    }

    #
}

