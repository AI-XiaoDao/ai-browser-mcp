    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_字体族 <类型 = GP字体族类>
    参数 参数_字体大小 <类型 = 小数 "">
    参数 参数_风格 <类型 = 整数 注释 = "GP字体风格 常量组合" @默认值 = 0>
    参数 参数_单位 <类型 = GP单位 @默认值 = GP单位.世界坐标>
    {
        @ this->Destory();
        @ Gdiplus::GpFont *font = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateFont(@<参数_字体族>.nativeFamily, 
        @                    (Gdiplus::REAL)@<参数_字体大小>,
        @                    @<参数_风格>,
        @                    (Gdiplus::Unit)@<参数_单位>,
        @                    &font);
        @ SetNativeFont(font); 
        @ return lastResult == Gdiplus::Ok;
    }

    方法 创建自名称 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_字体名 <类型 = 文本型>
    参数 参数_字体大小 <类型 = 小数 "">
    参数 参数_风格 <类型 = 整数 注释 = "GP字体风格 常量组合" @默认值 = 0>
    参数 参数_单位 <类型 = GP单位 @默认值 = GP单位.世界坐标>
    参数 参数_字体集 <类型 = GP字体集类 @默认值 = 空对象>
    {
        @ this->Destory();
        @ Gdiplus::GpFontFamily *nativeFamily = NULL;
        @ lastResult = Gdiplus::DllExports::GdipCreateFontFamilyFromName(@<参数_字体名>.GetText(), @<参数_字体集>.nativeFontCollection, &nativeFamily);
        @ if (lastResult != Gdiplus::Ok)
        @ {
        @    lastResult = Gdiplus::DllExports::GdipGetGenericFontFamilySerif(&nativeFamily);
        @    if (lastResult != Gdiplus::Ok)
        @       return FALSE;
        @  }
        @ lastResult = Gdiplus::DllExports::GdipCreateFont(nativeFamily,
        @                            (Gdiplus::REAL)@<参数_字体大小>,
        @                            @<参数_风格>,
        @                            (Gdiplus::Unit)@<参数_单位>,
        @                            &nativeFont);
        @ if (lastResult != Gdiplus::Ok)
        @ {
        @   lastResult = Gdiplus::DllExports::GdipGetGenericFontFamilySerif(&nativeFamily);
        @   if (lastResult != Gdiplus::Ok)
        @       return FALSE;
        @   lastResult = Gdiplus::DllExports::GdipCreateFont(
        @            nativeFamily,
        @            (Gdiplus::REAL)@<参数_字体大小>,
        @             @<参数_风格>,
        @            (Gdiplus::Unit)@<参数_单位>,
        @            &nativeFont);
        @  }
        @ return lastResult == Gdiplus::Ok;

    }

    方法 创建自默认字体 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ this->Destory();
        @ HFONT hFont = (HFONT)::GetStockObject (DEFAULT_GUI_FONT);
        @ LOGFONTW logFont;
        @ if(!::GetObjectW(hFont, sizeof(LOGFONTW), &logFont))
        @ {
        @     return FALSE;
        @ }
        @ Gdiplus::GpFont *font = NULL;
        @ HDC hdc = ::GetDC(NULL);
        @ lastResult =  Gdiplus::DllExports::GdipCreateFontFromLogfontW(hdc, &logFont, &font);
        @ SetNativeFont(font); 
        @ ::ReleaseDC(NULL,hdc);
        @ return lastResult == Gdiplus::Ok;

    }

