类 GP图像标志 <公开 注释 = "ImageFlags" 注释 = "指定包含在 GP图像类 对象中的像素数据的属性。 GP图像类::取图像标志 方法返回此枚举的一个元素。" 折叠 折叠2
        @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @禁止创建对象 = 真>
{
    常量 无 <公开 类型 = 整数 值 = 0 注释 = "ImageFlagsNone 指定无格式信息">
    常量 可缩放 <公开 类型 = 整数 值 = 0x0001 注释 = "ImageFlagsScalable 指定可以缩放图像。">
    常量 含透明 <公开 类型 = 整数 值 = 0x0002 注释 = "ImageFlagsHasAlpha 指定像素数据包含 alpha 值。">
    常量 含半透明 <公开 类型 = 整数 值 = 0x0004 注释 = "ImageFlagsHasTranslucent 指定像素数据具有除 0（透明）和 255（不透明）以外的 alpha 值。">
    常量 可部分缩放 <公开 类型 = 整数 值 = 0x0008 注释 = "ImageFlagsPartiallyScalable 指定像素数据可部分缩放，但有一些限制。">
    常量 色彩空间RGB <公开 类型 = 整数 值 = 0x0010 注释 = "ImageFlagsColorSpaceRGB 指定使用 RGB 颜色空间存储图像。">
    常量 色彩空间CMYK <公开 类型 = 整数 值 = 0x0020 注释 = "ImageFlagsColorSpaceCMYK 指定使用 CMYK 颜色空间存储图像。">
    常量 色彩空间灰度 <公开 类型 = 整数 值 = 0x0040 注释 = "ImageFlagsColorSpaceGRAY 指定图像是灰度图像。">
    常量 色彩空间YCBCR <公开 类型 = 整数 值 = 0x0080 注释 = "ImageFlagsColorSpaceYCBCR 指定使用 YCBCR 颜色空间存储图像。">
    常量 色彩空间YCCK <公开 类型 = 整数 值 = 0x0100 注释 = "ImageFlagsColorSpaceYCCK 指定使用 YCCK 颜色空间存储图像。">
    常量 含DPI <公开 类型 = 整数 值 = 0x1000 注释 = "ImageFlagsHasRealDPI 指定每英寸点数信息存储在图像中。">
    常量 含像素尺寸 <公开 类型 = 整数 值 = 0x2000 注释 = "ImageFlagsHasRealPixelSize 指定像素大小存储在图像中。">
    常量 只读 <公开 类型 = 整数 值 = 0x00010000 注释 = "ImageFlagsReadOnly 指定像素数据为只读。">
    常量 高速缓存 <公开 类型 = 整数 值 = 0x00020000 注释 = "ImageFlagsCaching 指定可以缓存像素数据以加快访问速度。">

    #
}

类 GP像素格式 <公开 注释 = "PixelFormat" 注释 = "指定包含在 GP图像类 对象中的像素数据的属性。 GP图像类::取属性 方法返回此枚举的一个元素。" 折叠 折叠2
        @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @禁止创建对象 = 真>
{
    常量 Undefined <公开 类型 = 整数 值 = 0 注释 = "PixelFormatUndefined 未定义">
    常量 Indexed <公开 类型 = 整数 值 = 0x00010000 注释 = "PixelFormatIndexed 该像素数据包含颜色索引值，这意味着这些值是系统颜色表中颜色的索引，而不是单个颜色值。">
    常量 GDI <公开 类型 = 整数 值 = 0x00020000 注释 = "PixelFormatGDI 是 GDI 支持的格式">
    常量 Alpha <公开 类型 = 整数 值 = 0x0002 注释 = "PixelFormatAlpha 有一个 alpha 分量">
    常量 PAlpha <公开 类型 = 整数 值 = 0x0004 注释 = "PixelFormatPAlpha 预乘 alpha">
    常量 _1bppIndexed <公开 类型 = 整数 值 = @PixelFormat1bppIndexed 注释 = "PixelFormat1bppIndexed 指定格式为每像素 1 位，索引。">
    常量 _4bppIndexed <公开 类型 = 整数 值 = @PixelFormat4bppIndexed 注释 = "PixelFormat4bppIndexed 指定格式为每像素 4 位，索引。">
    常量 _8bppIndexed <公开 类型 = 整数 值 = @PixelFormat8bppIndexed 注释 = "PixelFormat8bppIndexed 指定格式为每像素 8 位，索引。">
    常量 _16bppGrayScale <公开 类型 = 整数 值 = @PixelFormat16bppGrayScale 注释 = "PixelFormat16bppGrayScale 指定格式为每像素 16 位，灰度。">
    常量 _16bppRGB555 <公开 类型 = 整数 值 = @PixelFormat16bppRGB555
            注释 = "PixelFormat16bppRGB555 指定格式为每像素 16 位； 5 位分别用于红色、绿色和蓝色分量。剩余位不使用。">
    常量 _16bppRGB5665 <公开 类型 = 整数 值 = @PixelFormat16bppRGB565
            注释 = "PixelFormat16bppRGB565 指定格式为每像素 16 位； 5 位用于红色分量，6 位用于绿色分量，5 位用于蓝色分量。">
    常量 _16bppARGB1555 <公开 类型 = 整数 值 = @PixelFormat16bppARGB1555
            注释 = "PixelFormat16bppARGB1555 指定格式为每像素 16 位； 1 位用于 alpha 分量，而 5 位用于红色、绿色和蓝色分量。">
    常量 _24bppRGB <公开 类型 = 整数 值 = @PixelFormat24bppRGB 注释 = "PixelFormat24bppRGB 指定格式为每像素 24 位； 8 位分别用于红色、绿色和蓝色分量。">
    常量 _32bppRGB <公开 类型 = 整数 值 = @PixelFormat32bppRGB 注释 = "PixelFormat32bppRGB 指定格式为每像素 32 位； 8 位分别用于红色、绿色和蓝色分量。其余 8 位未使用。">
    常量 _32bppARGB <公开 类型 = 整数 值 = @PixelFormat32bppARGB 注释 = "PixelFormat32bppARGB 指定格式为每像素 32 位； 8 位分别用于 alpha、红色、绿色和蓝色分量。">
    常量 _32bppPARGB <公开 类型 = 整数 值 = @PixelFormat32bppPARGB
            注释 = "PixelFormat32bppPARGB 指定格式为每像素 32 位； 8 位分别用于 alpha、红色、绿色和蓝色分量。根据 alpha 分量预乘红色、绿色和蓝色分量。">
    常量 _48bppRGB <公开 类型 = 整数 值 = @PixelFormat48bppRGB 注释 = "PixelFormat48bppRGB 指定格式为每像素 48 位；红色、绿色和蓝色分量各使用 16 位。">
    常量 _64bppARGB <公开 类型 = 整数 值 = @PixelFormat64bppARGB 注释 = "PixelFormat64bppARGB 指定格式为每像素 64 位；每个 16 位用于 alpha、红色、绿色和蓝色分量。">
    常量 _64bppPARGB <公开 类型 = 整数 值 = @PixelFormat64bppPARGB
            注释 = "PixelFormat64bppPARGB 指定格式为每像素 64 位；每个 16 位用于 alpha、红色、绿色和蓝色分量。根据 alpha 分量预乘红色、绿色和蓝色分量。">
    常量 _32bppCMYK <公开 类型 = 整数 值 = @PixelFormat32bppCMYK 注释 = "PixelFormat32bppCMYK 指定格式为每像素 32 位； 8 位分别用于 青色、品色、黄色和黑色 分量。">

    #
}

类 GP调色板标志 <公开 注释 = "PaletteFlags" 注释 = "指示调色板中颜色数据的属性。" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @禁止创建对象 = 真>
{
    常量 含透明 <公开 类型 = 整数 值 = 0x0001 注释 = "PaletteFlagsHasAlpha 表示一个或多个调色板条目包含 alpha（透明度）信息。">
    常量 灰度 <公开 类型 = 整数 值 = 0x0002 注释 = "PaletteFlagsGrayScale 指示调色板仅包含灰度条目。">
    常量 半色 <公开 类型 = 整数 值 = 0x0004 注释 = "PaletteFlagsHalftone 表示调色板是 Windows 半色调调色板。">

    #
}

类 GP编码器值 <公开 注释 = "EncoderValue" 注释 = "枚举指定可以作为参数传递给图像编码器的值。有关图像编码器的更多信息，请参阅使用图像编码器和解码器。" 折叠 折叠2
        @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 整数>
{
    常量 颜色类型CMYK <公开 值 = 0 注释 = "EncoderValueColorTypeCMYK 未在 GDI+ 1.0 版中使用。">
    常量 颜色类型YCCK <公开 值 = 1 注释 = "EncoderValueColorTypeYCCK 未在 GDI+ 1.0 版中使用。">
    常量 压缩LZW <公开 值 = 2 注释 = "EncoderValueCompressionLZW 对于 TIFF 图像，指定 LZW 压缩方法。">
    常量 压缩CCITT3 <公开 值 = 3 注释 = "EncoderValueCompressionCCITT3 对于 TIFF 图像，指定 CCITT3 压缩方法。">
    常量 压缩CCITT4 <公开 值 = 4 注释 = "EncoderValueCompressionCCITT4 对于 TIFF 图像，指定 CCITT4 压缩方法。">
    常量 压缩RLE <公开 值 = 5 注释 = "EncoderValueCompressionRle 对于 TIFF 图像，指定 Rle 压缩方法。">
    常量 压缩无 <公开 值 = 6 注释 = "EncoderValueCompressionNone  对于 TIFF 图像，指定不压缩。">
    常量 扫描方式隔行 <公开 值 = 7 注释 = "EncoderValueScanMethodInterlaced 未在 GDI+ 1.0 版中使用。">
    常量 扫描方式非隔行 <公开 值 = 8 注释 = "EncoderValueScanMethodNonInterlaced 未在 GDI+ 1.0 版中使用。">
    常量 版本GIF87 <公开 值 = 9 注释 = "EncoderValueVersionGif87 未在 GDI+ 1.0 版中使用。">
    常量 版本GIF89 <公开 值 = 10 注释 = "EncoderValueVersionGif89 未在 GDI+ 1.0 版中使用。">
    常量 渲染渐进 <公开 值 = 11 注释 = "EncoderValueRenderProgressive 未在 GDI+ 1.0 版中使用。">
    常量 渲染非渐进 <公开 值 = 12 注释 = "EncoderValueRenderNonProgressive 未在 GDI+ 1.0 版中使用。">
    常量 旋转90度 <公开 值 = 13 注释 = "EncoderValueTransformRotate90 对于 JPEG 图像，指定无损 90 度顺时针旋转。">
    常量 旋转180度 <公开 值 = 14 注释 = "EncoderValueTransformRotate180 对于 JPEG 图像，指定无损 180 度旋转。">
    常量 旋转270度 <公开 值 = 15 注释 = "EncoderValueTransformRotate270 对于 JPEG 图像，指定无损 270 度顺时针旋转。">
    常量 水平翻转 <公开 值 = 16 注释 = "EncoderValueTransformFlipHorizontal 对于 JPEG 图像，指定无损水平翻转。">
    常量 垂直翻转 <公开 值 = 17 注释 = "EncoderValueTransformFlipVertical 对于 JPEG 图像，指定无损垂直翻转。">
    常量 多帧 <公开 值 = 18 注释 = "EncoderValueMultiFrame 指定多帧编码。">
    常量 最后一帧 <公开 值 = 19 注释 = "EncoderValueLastFrame 指定多帧图像的最后一帧。">
    常量 刷新 <公开 值 = 20 注释 = "EncoderValueFlush 指定要关闭的编码器对象。">
    常量 帧维面延时 <公开 值 = 21 注释 = "EncoderValueFrameDimensionTime 未在 GDI+ 1.0 版中使用。">
    常量 帧维面分辨率 <公开 值 = 22 注释 = "EncoderValueFrameDimensionResolution 未在 GDI+ 1.0 版中使用。">
    常量 帧维面页 <公开 值 = 23 注释 = "EncoderValueFrameDimensionPage 对于 TIFF 图像，指定页维面">

    #
}

类 GP旋转翻转类型 <公开 注释 = "RotateFlipType" 注释 = "枚举指定图像的旋转方向和用于翻转图像的轴。" 折叠 折叠2 @文档 = "category = \"图像处理库.Gdiplus.枚举\"" @常量类 = 整数>
