    方法 销毁 <公开 注释 = "可以手动销毁, 但超出作用域也会自动销毁." @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    {
        @ this->Destory();

    }

    方法 创建 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 参数_宽度 <类型 = 整数>
    参数 参数_高度 <类型 = 整数>
    参数 参数_hdc <类型 = 变整数 @默认值 = 0>
    {
        @ this->Destory();
        @ BITMAPINFO bi;
        @ ZeroMemory(&bi, sizeof(BITMAPINFO));
        @ m_hdc = ::CreateCompatibleDC ((HDC)@<参数_hdc>);
        @ if(!m_hdc) return FALSE;
        @ bi.bmiHeader.biSize = sizeof(BITMAPINFOHEADER);
        @ bi.bmiHeader.biWidth = @<参数_宽度>;
        @ bi.bmiHeader.biHeight = @<参数_高度>;
        @ bi.bmiHeader.biPlanes = 1;
        @ bi.bmiHeader.biBitCount = 32;
        @ m_hBitmap = ::CreateDIBSection (m_hdc, &bi, DIB_RGB_COLORS, NULL, NULL,0);
        @ if(!m_hBitmap) {
        @     ::DeleteDC(m_hdc);
        @     m_hdc = NULL;
        @     return FALSE;
        @ }
        @ ::SelectObject(m_hdc, m_hBitmap);
        @ if( SetStatus(Gdiplus::DllExports::GdipCreateFromHDC(m_hdc, &nativeGraphics)) != Gdiplus::Ok)
        @ {
        @    ::DeleteObject (m_hBitmap);
        @    ::DeleteDC (m_hdc);
        @    return FALSE;
        @ }
        @ m_Width = @<参数_宽度>;
        @ m_Height = @<参数_高度>;
        @ return TRUE;
    }

    方法 创建自场景句柄 <公开 类型 = 逻辑型 注释 = "FromHDC" 注释 = "创建一个缓存图形类对象, 仅仅使用 <参数_HDC>的 宽度 和 高度" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_场景句柄 <类型 = 变整数>
    参数 参数_保留 <类型 = 变整数 @默认值 = 0>
    {
        @ this->Destory();
        @ m_Width = ::GetDeviceCaps ((HDC)@<参数_场景句柄>, HORZRES);
        @ m_Height = ::GetDeviceCaps ((HDC)@<参数_场景句柄>, VERTRES);
        @ return @<创建>(m_Width, m_Height, @<参数_场景句柄>);
    }

    方法 创建自窗口句柄 <公开 类型 = 逻辑型 注释 = "FromHDC" 注释 = "创建一个缓存图形类对象, 仅仅使用 <参数_窗口句柄>的 宽度 和 高度" @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    参数 参数_窗口句柄 <类型 = 变整数>
    参数 参数_保留 <类型 = 逻辑型 @默认值 = 假>
    {
        @ this->Destory();
        @ RECT rc;
        @ ::GetClientRect((HWND)@<参数_窗口句柄>, &rc);
        @ return @<创建>(rc.right - rc.left, rc.bottom - rc.top, 0);
    }

