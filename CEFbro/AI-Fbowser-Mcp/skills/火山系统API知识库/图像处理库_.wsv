    方法 测量文本矩形 <公开 类型 = 逻辑型 注释 = "MeasureString" 注释 = "测量字符串在指定字体、文本格式 和 布局矩形 中的范围。" @嵌入式方法 = "">
    参数 参数_文本 <类型 = 文本型>
    参数 参数_字体 <类型 = GP字体类 "">
    参数 参数_布局矩形 <类型 = 矩形F 注释 = "此矩形作为测量的参考, 可仅设置左边顶边, 也可仅设置宽度高度" "">
    参数 参数_文本格式 <类型 = GP文本格式类 @默认值 = 空对象>
    参数 参数_测量矩形 <类型 = 矩形F 注释 = "输出参数" "">
    {
        @ @sn<this>.MeasureString(@<参数_文本>, @<参数_字体>.nativeFont, @<参数_布局矩形>.data(), @<参数_文本格式>.nativeFormat, @<参数_测量矩形>.ptr());

    }

    方法 测量文本矩形2 <公开 类型 = 逻辑型 注释 = "MeasureString" 注释 = "测量字符串在指定字体、文本格式 和 布局矩形 中的范围。" @嵌入式方法 = "">
    参数 参数_文本 <类型 = 文本型>
    参数 参数_字体 <类型 = GP字体类 "">
    参数 参数_布局矩形 <类型 = 矩形F "">
    参数 参数_文本格式 <类型 = GP文本格式类 @默认值 = 空对象>
    参数 参数_测量矩形 <类型 = 矩形F 注释 = "输出参数" "">
    参数 参数_适合字符数 <类型 = 整数 注释 = "输出参数, 实际适合布局矩形的字符数" @需求类型 = 可写入变量>
    参数 参数_适合行数 <类型 = 整数 注释 = "输出参数, 适合布局矩形的行数" @需求类型 = 可写入变量>
    {
        @ @sn<this>.MeasureString(@<参数_文本>, @<参数_字体>.nativeFont, @<参数_布局矩形>.data(), @<参数_文本格式>.nativeFormat, @<参数_测量矩形>.ptr(), &@<参数_适合字符数>, &@<参数_适合行数>);

    }

    方法 测量字符范围 <公开 类型 = 逻辑型 注释 = "MeasureCharacterRanges" 注释 = "获取一组区域，每个区域限定字符串中的字符位置范围。" @禁止流程检查 = 真>
    参数 参数_文本 <类型 = 文本型>
    参数 参数_字体 <类型 = GP字体类 "">
    参数 参数_布局矩形 <类型 = 矩形F 注释 = "此矩形作为测量的参考" "">
    参数 参数_文本格式 <类型 = GP文本格式类 注释 = "设置 文本格式.置测量字符范围()" "">
    参数 参数_区域数 <类型 = 整数 注释 = "指定预期接收到区域数组中的区域数。 此数字应等于 <参数_文本格式>  对象中当前的字符范围数。">
    参数 参数_区域集 <类型 = GP数组区域类 注释 = "输出参数, 直接传递空数组对象, 函数执行完毕后, 数组每个区域都限定了一个文本范围。">
    {
        @ if (@<参数_区域数> <= 0)
        @ {
        @      return Gdiplus::InvalidParameter;
        @ }
        @ Gdiplus::GpRegion **nativeRegions = new Gdiplus::GpRegion* [@<参数_区域数>];
        @ if (!nativeRegions)
        @ {
        @      return Gdiplus::OutOfMemory;
        @ }
        @ @<参数_区域集>.InitCount (VOL_RUNTIME_CLASS (@dt<GP区域类>), 0, @<参数_区域数>);
        @ for (INT i = 0; i < @<参数_区域数>; i++)
        @ {
        @      nativeRegions[i] = ((@dt<GP区域类>&)@<参数_区域集>.GetAt(i)).nativeRegion;
        @ }
        @ Gdiplus::Status status = SetStatus(Gdiplus::DllExports::GdipMeasureCharacterRanges(
        @            nativeGraphics,
        @            @<参数_文本>.GetText(),
        @            (INT)@<参数_文本>.GetLength(),
        @            @<参数_字体>.nativeFont,
        @            @<参数_布局矩形>.data(),
        @            @<参数_文本格式>.nativeFormat,
        @            @<参数_区域数>,
        @            nativeRegions
        @        ));
        @ delete [] nativeRegions;
        @ return status == Gdiplus::Ok ;
    }

