    方法 取子夹数目 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    {
        @ return GetTabItemCount((HWND)@<选择夹句柄>);
    }

    方法 取现行子夹 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    {
        @ return GetCurrentTabIndex((HWND)@<选择夹句柄>);
    }

    方法 置现行子夹 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ return SetCurrentTabIndex((HWND)@<选择夹句柄>,@<索引>);
    }

    方法 取子夹名称 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ std::wstring str = GetTabItemText((HWND)@<选择夹句柄>,@<索引>);
        @ return str.c_str();
    }

    方法 置子夹名称 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    参数 名称 <类型 = 文本型>
    {
        @ return SetTabItemText((HWND)@<选择夹句柄>,@<索引>,@<名称>.GetText());
    }

    方法 置表头方向 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 方向 <类型 = 整数 注释 = "0、上 1、下  2、左  3、右">
    {
        @ return SetTabDirection((HWND)@<选择夹句柄>,@<方向>);
    }

    方法 取表头方向 <公开 类型 = 整数 返回值注释 = "0、上 1、下  2、左  3、右" 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    {
        @ return GetTabDirection((HWND)@<选择夹句柄>);
    }

    方法 允许多行表头 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 是否允许 <类型 = 逻辑型 @默认值 = 真>
    {
        @ return SetTabMultiLine((HWND)@<选择夹句柄>,@<是否允许> ? true:false);
    }

    方法 添加子夹 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 名称 <类型 = 文本型>
    {
        @ return AddTabItem((HWND)@<选择夹句柄>,@<名称>.GetText());
    }

    方法 插入子夹 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    参数 名称 <类型 = 文本型>
    {
        @ return InsertTabItem((HWND)@<选择夹句柄>,@<索引>,@<名称>.GetText());
    }

    方法 删除子夹 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ return DeleteTabItem((HWND)@<选择夹句柄>,@<索引>);
    }

    方法 删除所有子夹 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 选择夹句柄 <类型 = 变整数>
    {
        @ return ClearAllTabItems((HWND)@<选择夹句柄>);
    }
}

