类 外部列表框类_ <公开 折叠 @文档 = "category = \"外部组件操作库.列表框\"">
{
    方法 置滚动条状态 <公开 类型 = 逻辑型 注释 = "显示隐藏滚动条" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 类型 <类型 = 整数 注释 = "0、横向滚动条 1、纵向滚动条 3、横纵向滚动条">
    参数 是否显示 <类型 = 逻辑型 注释 = "真：显示  假：隐藏" "">
    {
        @ return ShowScrollBar((HWND)@<窗口句柄>, @<类型>, @<是否显示>);
    }

    方法 清空列表 <公开 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    {
        @ SendMessageW((HWND)@<列表框句柄>, LB_RESETCONTENT, 0, 0);
    }

    方法 取项目数 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_GETCOUNT, 0, 0);
    }

    方法 加入项目 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    参数 项目文本 <类型 = 文本型>
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_INSERTSTRING, -1, (LPARAM)@<项目文本>.GetText());
    }

    方法 插入项目 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    参数 项目索引 <类型 = 整数 注释 = "0表示第一项">
    参数 项目文本 <类型 = 文本型>
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_INSERTSTRING, -1, (LPARAM)@<项目文本>.GetText());
    }

    方法 删除项目 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    参数 项目索引 <类型 = 整数 注释 = "0表示第一项">
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_DELETESTRING, @<项目索引>, 0);
    }

    方法 取选中项 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_GETCURSEL, 0, 0);
    }

    方法 置选中项 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    参数 项目索引 <类型 = 整数 注释 = "0表示第一项">
    {
        @ return SendMessageW((HWND)@<列表框句柄>, LB_SETCURSEL, 0, 0);
    }

    方法 取项目文本 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 列表框句柄 <类型 = 变整数>
    参数 项目索引 <类型 = 整数 注释 = "0表示第一项">
    {
        变量 Buffer <类型 = 文本型>
        @ HWND hWnd = (HWND)@<列表框句柄>;
        @ INT_PTR dwLen = SendMessageW(hWnd, LB_GETTEXTLEN, @<项目索引>, 0);
        @ dwLen++;
        @ LPWSTR Buffer = new TCHAR[dwLen]();
        @ SendMessageW(hWnd, LB_GETTEXT, @<项目索引>, (LPARAM)Buffer);
        @ @<Buffer> = Buffer;
        @ delete[] Buffer;
        @ return @<Buffer>.GetText();
    }
}

