    方法 取表项数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    {
        @  return GetItemCountExternal((HWND)@<列表句柄>);
    }

    方法 取列数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    {
        @  return GetColumnCountExternal((HWND)@<列表句柄>);
    }

    方法 置标题 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 行号 <类型 = 整数>
    参数 列号 <类型 = 整数>
    参数 标题 <类型 = 文本型>
    {
        @  return SetSubItemTextExternal((HWND)@<列表句柄>,@<行号>,@<列号>,@<标题>);
    }

    方法 取标题 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 行号 <类型 = 整数>
    参数 列号 <类型 = 整数>
    {
        @ TCHAR szText[256];
        @  GetSubItemTextExternal((HWND)@<列表句柄>,@<行号>,@<列号>,szText, 256);
        @ return szText;
    }

    方法 取列标题 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 列号 <类型 = 整数>
    {
        @ TCHAR szText[256];
        @  GetColumnHeaderTextExternal((HWND)@<列表句柄>,@<列号>,szText, 256);
        @ return szText;
    }

    方法 置列标题 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 列号 <类型 = 整数>
    参数 标题 <类型 = 文本型>
    {
        @ return SetColumnHeaderTextExternal((HWND)@<列表句柄>,@<列号>,@<标题>);
    }

    方法 取列宽 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 列号 <类型 = 整数>
    {
        @ return GetColumnWidthExternal((HWND)@<列表句柄>,@<列号>);
    }

    方法 置列宽 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 列号 <类型 = 整数>
    参数 列宽 <类型 = 整数>
    {
        @ return SetColumnWidthExternal((HWND)@<列表句柄>,@<列号>,@<列宽>);
    }

    方法 刷新列表 <公开 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    {
        @ RedrawListViewExternal((HWND)@<列表句柄>);
    }

    方法 插入表项 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 插入位置 <类型 = 整数 注释 = "默认-1为插入到尾部" @默认值 = -1>
    参数 标题 <类型 = 文本型 @默认值 = "">
    {
        @ int hs ;
        @ hs=@<插入位置>;
        @ if(@<插入位置>==-1) {
        @ hs = GetItemCountExternal((HWND)@<列表句柄>);
        @ }
        @  return InsertItemIntoExternalListView((HWND)@<列表句柄>, hs, @<标题>);
    }

    方法 插入列 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 插入位置 <类型 = 整数 注释 = "默认-1为插入到尾部" @默认值 = -1>
    参数 标题 <类型 = 文本型 @默认值 = "">
    参数 列宽 <类型 = 整数 @默认值 = 50>
    {
        @ int ls ;
        @ ls=@<插入位置>;
        @ if(@<插入位置>==-1) {
        @ ls = GetColumnCountExternal((HWND)@<列表句柄>);
        @ }
        @ return InsertColumnIntoExternalListView((HWND)@<列表句柄>, ls,@<标题>, @<列宽>);
    }

    方法 删除列 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 列号 <类型 = 整数>
    {
        @ return DeleteColumnFromExternalListView((HWND)@<列表句柄>, @<列号>);
    }

    方法 删除表项 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    参数 行号 <类型 = 整数>
    {
        @ return DeleteItemFromExternalListView((HWND)@<列表句柄>, @<行号>);
    }

    方法 全部删除 <公开 类型 = 逻辑型 注释 = "删除所有行列" 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    {
        @ return ClearExternalListView((HWND)@<列表句柄>);
    }

    方法 删除所有表项 <公开 类型 = 逻辑型 注释 = "只删除表项，保留表头" 折叠 @禁止流程检查 = 真>
    参数 列表句柄 <类型 = 变整数>
    {
        @ return DeleteAllItemsFromExternalListView((HWND)@<列表句柄>);
    }
}
