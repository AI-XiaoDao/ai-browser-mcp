<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"数据操作库\"">

类 拼接符 <公开 折叠 折叠2 @文档 = "category = \"数据操作库.拼接符\"" @禁止创建对象 = 真>
{
    变量 回车符 <公开 静态 类型 = 文本型 值 = "\r" 注释 = "\\r">
    变量 换行符 <公开 静态 类型 = 文本型 值 = "\r\n" 注释 = "回车+换行 \\r\\n">
    变量 换行符2 <公开 静态 类型 = 文本型 值 = "\n" 注释 = "\\n">
    变量 制表符 <公开 静态 类型 = 文本型 值 = "\t" 注释 = "\\t">
    变量 单引号 <公开 静态 类型 = 文本型 值 = "\'" 注释 = "英文 \'">
    变量 双引号 <公开 静态 类型 = 文本型 值 = "\"" 注释 = "英文 \"">
    变量 左引号 <公开 静态 类型 = 文本型 值 = "“" 注释 = "中文“">
    变量 右引号 <公开 静态 类型 = 文本型 值 = "”" 注释 = "中文 ”">
    变量 反斜杠 <公开 静态 类型 = 文本型 值 = "\\" 注释 = "\\">
}

