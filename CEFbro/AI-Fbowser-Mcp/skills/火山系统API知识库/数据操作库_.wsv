    方法 取文本中间_批量 <公开 静态 类型 = 文本数组类 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 如果找不到返回空 <类型 = 逻辑型 @默认值 = 假>
    参数 不区分大小写 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 结果数组 <类型 = 文本数组类>
        变量 原始数据长度 <类型 = 整数>
        变量 开始文本长度 <类型 = 整数>
        变量 开始位置 <类型 = 整数 值 = 0>
        变量 结束位置 <类型 = 整数 值 = 0>
        开始文本长度 = 取文本长度 (开始文本)
        原始数据长度 = 取文本长度 (原始文本)
        判断循环 (真)
        {
            开始位置 = 寻找文本 (原始文本, 开始文本, 结束位置, 不区分大小写)
            如果 (开始位置 == -1)
            {
                跳出循环
            }
            结束位置 = 寻找文本 (原始文本, 结束文本, 开始位置 + 开始文本长度, 不区分大小写)
            如果 (结束位置 == -1)
            {
                跳出循环
            }
            如果 (结束位置 - 开始位置 - 开始文本长度 > 0)
            {
                结果数组.加入成员 (取文本中间 (原始文本, 开始位置 + 开始文本长度, 结束位置 - 开始位置 - 开始文本长度))
            }
            否则 (如果找不到返回空)
            {
                结果数组.加入成员 ("")
            }
        }
        返回 (结果数组)
    }

