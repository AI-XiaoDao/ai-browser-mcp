    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    参数 不区分大小写 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (取文本中间_ (原始文本, 开始文本, 结束文本, 开始搜索位置, 是否包含起始文本, 如果找不到返回原始文本, 不区分大小写))
    }

    方法 取文本中间2_ <公开 静态 类型 = 文本型 注释 = "从右往左找" 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型 注释 = "从右往左，右侧文本">
    参数 结束文本 <类型 = 文本型 注释 = "从右往左，左侧文本">
    参数 开始搜索位置 <类型 = 整数 注释 = "-1表示从文本尾部开始查找，非负数，表示从文本总长度-本参数值处开始查找" @默认值 = -1>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    参数 不区分大小写 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        开始位置 = 倒找文本 (原始文本, 开始文本, 开始搜索位置, 不区分大小写)
        如果真 (开始位置 < 1)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
        }
        开始搜索位置 = 取文本长度 (开始文本) - 开始位置
        结束位置 = 倒找文本 (原始文本, 结束文本, 开始位置 - 1, 不区分大小写)
        如果真 (结束位置 == -1)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
            返回 ("")
        }
        结束位置 = 结束位置 + 取文本长度 (结束文本)
        如果真 (开始位置 < 结束位置)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
        }
        如果真 (是否包含起始文本)
        {
            开始位置 = 开始位置 + 取文本长度 (开始文本)
            结束位置 = 结束位置 - 取文本长度 (结束文本)
        }
        如果真 (结束位置 == -1)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
        }
        中间文本 = 取文本中间 (原始文本, 结束位置, 开始位置 - 结束位置)
        如果真 (结束位置 - 开始位置 == 0 && 如果找不到返回原始文本)
        {
            返回 (原始文本)
        }
        返回 (中间文本)
    }

