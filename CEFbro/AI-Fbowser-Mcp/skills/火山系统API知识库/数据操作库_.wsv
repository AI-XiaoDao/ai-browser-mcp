    方法 文本_取文本像素宽度 <公开 静态 类型 = 整数 注释 = "计算汉字、字母、数字在组件中所占的宽度，不支持标点符号" 返回值注释 = "返回宽度值" 折叠>
    参数 文本内容 <类型 = 文本型>
    参数 字体大小 <类型 = 小数 @默认值 = 11>
    参数 选择模式 <类型 = 整数 注释 = "1、纯中文　2、非纯中文(包含有字母数字)" @默认值 = 1>
    {
        变量 结果 <类型 = 整数>
        如果 (选择模式 == 1)
        {
            结果 = (整数)四舍五入 (字体大小 * 96 / 72) * 取文本长度 (文本内容) + 6
        }
        否则
        {
            变量 总长度 <类型 = 小数>
            变量 中文长度 <类型 = 小数>
            变量 非中文长度比 <类型 = 小数>
            变量 最终长度 <类型 = 小数>
            变量 最终宽度 <类型 = 小数>
            总长度 = 取文本长度 (文本内容)
            中文长度 = 取文本长度 (匹配所有中文_ (文本内容))
            非中文长度比 = (小数)(总长度 - 中文长度) / 2
            最终长度 = 中文长度 + 非中文长度比
            最终宽度 = 四舍五入 (字体大小 * 96 / 72) * 最终长度 + 6 + 非中文长度比 * 1
            结果 = (整数)四舍五入 (最终宽度)
        }
        返回 (结果)
    }

    方法 文本_取文本占位宽度 <公开 静态 类型 = 整数 注释 = "计算文字在组件中所占的宽度;" 注释 = "宽度充足" 折叠 折叠2>
    参数 父窗口 <类型 = 窗口容器组件 注释 = "本对象">
    参数 文本内容 <类型 = 文本型>
    参数 字体大小 <类型 = 文本型 @默认值 = "宋体, 11, 0, 0, 0, 0, 0">
    {
        变量 画板1 <类型 = 画板>
        变量 动态 <类型 = 动态画板类_>
        变量 大小值 <类型 = 整数>
        画板1 = 动态.创建画板 (父窗口)
        画板1.字体 = 字体大小
        动态.销毁对象_画板 ()
        大小值 = 画板1.取宽度 (文本内容) + 10
        画板1.销毁 ()
        返回 (大小值)
    }

