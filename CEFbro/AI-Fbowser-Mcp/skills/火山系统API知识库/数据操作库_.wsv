类 剪辑板类_ <公开 折叠 折叠2 @文档 = "category = \"数据操作库.剪辑板操作\"" @全局类 = 真>
{
    方法 剪辑板_置剪辑板图片 <公开 静态 注释 = "图片路径;" 注释 = "将文件复制到剪辑板" 折叠 折叠2>
    参数 图片来源 <类型 = 文本型>
    {
        变量 图片 <类型 = COM对象类>
        变量 句柄 <类型 = 变整数>
        变量 图片句柄 <类型 = 变整数>
        变量 位图对象 <类型 = 位图对象类>
        位图对象 = 载入位图文件 (图片来源)
        图片.创建图片对象 (位图对象)
        图片句柄 = 图片.读无参数属性 ("Handle", 变整数)
        句柄 = 窗口_取窗口组件句柄 ()
        @ OpenClipboard((HWND)@<句柄>);
        @ EmptyClipboard();
        @ SetClipboardData(2,(HWND)@<图片句柄>);
        @ CloseClipboard();
    }

    方法 剪辑板_置剪辑板图片2 <公开 静态 注释 = "字节集类;" 注释 = "将文件复制到剪辑板" 折叠 折叠2>
    参数 图片数据 <类型 = 字节集类>
    {
        变量 图片 <类型 = COM对象类>
        变量 句柄 <类型 = 变整数>
        变量 图片句柄 <类型 = 变整数>
        变量 位图对象 <类型 = 位图对象类>
        位图对象 = 载入位图数据 (图片数据)
        图片.创建图片对象 (位图对象)
        图片句柄 = 图片.读无参数属性 ("Handle", 变整数)
        句柄 = 窗口_取窗口组件句柄 ()
        @ OpenClipboard((HWND)@<句柄>);
        @ EmptyClipboard();
        @ SetClipboardData(2,(HWND)@<图片句柄>);
        @ CloseClipboard();
    }

    方法 剪辑板_保存剪辑板文件 <公开 静态 类型 = 逻辑型 注释 = "将剪辑板中的文件粘贴到指定的位置" 折叠>
    参数 保存位置 <类型 = 文本型>
    参数 是否覆盖 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 文件列表 <类型 = 文本数组类>
        变量 返回值 <类型 = 文本型>
        如果真 (取文本右边 (保存位置, 1) != "\\")
        {
            保存位置 = 保存位置 + "\\"
        }
        检查加入路径字符 (保存位置)
        文件列表 = 剪辑板_取剪辑板文件 (返回值)
        如果 (返回值 == "1")
        {
            如果 (创建目录 (保存位置) == 假)
            {
                返回 (假)
            }
            文件列表.枚举循环 ()
            {
                变量 目标文件名 <类型 = 文本型>
                目标文件名 = 保存位置 + 取文件名无路径部分 (文件列表.取枚举值 ())
                如果 (是否覆盖 == 假)
                {
                    变量 临时文件名 <类型 = 文本型>
                    变量 编号 <类型 = 整数 值 = 1>
                    变量 扩展名 <类型 = 文本型>
                    变量 插入位置 <类型 = 整数>
                    扩展名 = 取文件名后缀 (目标文件名)
                    如果 (文本是否为空 (扩展名) == 假)
                    {
                        插入位置 = 寻找文本 (目标文件名, 扩展名) - 1
                    }
                    否则
                    {
                        插入位置 = -1
                    }
                    临时文件名 = 目标文件名
                    判断循环 (文件是否存在 (临时文件名) == 真)
                    {
                        临时文件名 = 目标文件名
                        插入文本 (临时文件名, 插入位置, " - 副本 (" + 到文本 (编号) + ")")
                        编号 = 编号 + 1
                    }
                    目标文件名 = 临时文件名
                }
                复制文件 (文件列表.取枚举值 (), 目标文件名)
            }
            返回 (真)
        }
        否则 (返回值 == "2")
        {
            如果 (创建目录 (保存位置) == 假)
            {
                返回 (假)
            }
            文件列表.枚举循环 ()
            {
                变量 目标文件名 <类型 = 文本型>
                目标文件名 = 保存位置 + 取文件名无路径部分 (文件列表.取枚举值 ())
                如果 (是否覆盖 == 假)
                {
                    变量 临时文件名 <类型 = 文本型>
                    变量 编号 <类型 = 整数 值 = 1>
                    变量 扩展名 <类型 = 文本型>
                    变量 插入位置 <类型 = 整数>
                    扩展名 = 取文件名后缀 (目标文件名)
                    如果 (文本是否为空 (扩展名) == 假)
                    {
                        插入位置 = 寻找文本 (目标文件名, 扩展名) - 1
                    }
                    否则
                    {
                        插入位置 = -1
                    }
                    临时文件名 = 目标文件名
                    判断循环 (文件是否存在 (临时文件名) == 真)
                    {
                        临时文件名 = 目标文件名
                        插入文本 (临时文件名, 插入位置, " - 副本 (" + 到文本 (编号) + ")")
                        编号 = 编号 + 1
                    }
                    目标文件名 = 临时文件名
                }
                移动文件 (文件列表.取枚举值 (), 目标文件名)
            }
            返回 (真)
        }
        否则
        {
            返回 (假)
        }
    }

    方法 剪辑板_置剪辑板文件 <公开 静态 类型 = 逻辑型 注释 = "将文件复制或剪切到剪辑板里" 折叠>
    参数 文件列表 <类型 = 文本数组类>
    参数 是否复制 <类型 = 逻辑型 注释 = "默认复制文件，假为剪切文件" @默认值 = 真>
    {
        变量 文件列表_ <类型 = 字节集类>
        文件列表.枚举循环 ()
        {
            文件列表_.添加文本到字节集 (文件列表.取枚举值 ())
            文件列表_.添加字节集内容 (0, 0)
        }
        返回 (置文件 (文件列表_, 是否复制))
    }

    方法 置文件 <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 缓冲区 <类型 = 字节集类>
    参数 是否复制 <类型 = 逻辑型 注释 = "默认复制文件，假为剪切文件" @默认值 = 真>
    {
        @ if (::OpenClipboard (NULL) == false) return false;
        @ if (::EmptyClipboard () == false) return false;
        @ UINT uDropEffect;
        @ DROPFILES dropFiles;
        @ UINT uDropFilesLen;
        @ HGLOBAL hGblFiles, hGblEffect;
        @ char *szData, *szFileList;
        @ DWORD *dwDropEffect;
        @ uDropEffect = ::RegisterClipboardFormatW (CFSTR_PREFERREDDROPEFFECT);
        @ hGblEffect = ::GlobalAlloc (GMEM_ZEROINIT | GMEM_MOVEABLE | GMEM_DDESHARE, sizeof(DWORD));
        @ if (hGblEffect == NULL) return false;
        @ dwDropEffect = (DWORD*)::GlobalLock (hGblEffect);
        @ if (@<是否复制> == TRUE)
        @     *dwDropEffect = DROPEFFECT_COPY;
        @ else 
        @     *dwDropEffect = DROPEFFECT_MOVE;
        @ ::GlobalUnlock (hGblEffect);
        @ uDropFilesLen = sizeof(DROPFILES);
        @ dropFiles.pFiles = uDropFilesLen;
        @ dropFiles.pt.x = 0;
        @ dropFiles.pt.y = 0;
        @ dropFiles.fNC = FALSE;
        @ dropFiles.fWide = TRUE;
        @ hGblFiles = ::GlobalAlloc (GMEM_ZEROINIT | GMEM_MOVEABLE | GMEM_DDESHARE, uDropFilesLen + @<缓冲区>.GetSize () + 8);
        @ if (hGblFiles == NULL) return false;
        @ szData = (char*)::GlobalLock (hGblFiles);
        @ memcpy (szData, (LPVOID)(&dropFiles), uDropFilesLen);
        @ szFileList = szData + uDropFilesLen;
        @ memcpy (szFileList, @<缓冲区>.GetPtr (), @<缓冲区>.GetSize ());
        @ ::GlobalUnlock (hGblFiles);
        @ HANDLE hRetD = ::SetClipboardData (CF_HDROP, hGblFiles);
        @ HANDLE hRetE = ::SetClipboardData (uDropEffect, hGblEffect);
        @ ::CloseClipboard ();
        @ ::GlobalFree (hGblFiles);
        @ ::GlobalFree (hGblEffect);
        @ if (hRetD == NULL || hRetE == NULL)
        @     return false;
        @ else
        @     return true;
    }

    方法 剪辑板_取剪辑板文件 <公开 静态 类型 = 文本数组类 注释 = "获取剪辑板中保存的文件，同时可判断是复制文件还是剪切文件" 折叠>
    参数 返回的类型 <类型 = 文本型 注释 = "0、获取失败　1、复制文件　3剪切文件" @默认值 = "0">
    {
        变量 文件列表 <类型 = 文本数组类 注释 = "从剪贴板获取的文件列表">
        变量 返回值 <类型 = 文本型>
        @ if (::IsClipboardFormatAvailable (CF_HDROP) == false) return @<文件列表>;
        @ if (::OpenClipboard (NULL))
        @ {
        @     HDROP hDrop = HDROP (::GetClipboardData (CF_HDROP));
        @     if (hDrop)
        @     {
        @         DWORD dwEffect, *dw;
        @         UINT uDropEffect = ::RegisterClipboardFormatW (CFSTR_PREFERREDDROPEFFECT);
        @         dw = (DWORD*)(::GetClipboardData (uDropEffect));
        @         if(dw == NULL)
        @             dwEffect = DROPEFFECT_COPY;
        @         else
        @             dwEffect = *dw;
        @         UINT nFiles = DragQueryFileW (hDrop, 0xFFFFFFFF, NULL, 0);
        @         TCHAR szFile[MAX_PATH];
        @         for (UINT count = 0; count < nFiles; count++ )
        @         {
        @             DragQueryFileW (hDrop, count, szFile, sizeof(szFile));
        @             @<文件列表>.data ().Add (szFile);
        @         }
        @         if (dwEffect & DROPEFFECT_MOVE)
        @         {
        @             @<返回值> = "2";
        @         } else if (dwEffect & DROPEFFECT_COPY)
        @         {
        @             @<返回值> = "1";
        @         }
        @     }
        @ ::CloseClipboard();
        @ }
        返回的类型 = 返回值
        返回 (文件列表)
    }

    方法 剪辑板_取剪辑板图片_字节集 <公开 静态 类型 = 逻辑型 注释 = "获取剪贴板中的图片数据" 折叠>
    参数 返回的字节集数据 <类型 = 字节集类>
    {
        变量 临时位图 <类型 = 位图对象类>
        变量 结果 <类型 = 逻辑型>
        结果 = 剪辑板_取剪辑板图片_位图 (临时位图)
        临时位图.取图片数据 (返回的字节集数据, , )
        返回 (结果)
    }

    方法 剪辑板_取剪辑板图片_位图 <公开 静态 类型 = 逻辑型 注释 = "获取剪贴板中的图片数据" 折叠 @禁止流程检查 = 真>
    参数 返回的位图数据 <类型 = 位图对象类>
    {
        变量 位图字节集 <类型 = 字节集类 @输出名 = "BitmapBuffer">
        @ if (::IsClipboardFormatAvailable (CF_DIB) == FALSE) return FALSE;
        @ if (::OpenClipboard (NULL) == FALSE) return FALSE;
        @ GLOBALHANDLE hGMem = ::GetClipboardData (CF_DIB);
        @ if (hGMem == NULL) return FALSE;
        @ BITMAPFILEHEADER bmpHeader;
        @ bmpHeader.bfType = 'MB';
        @ bmpHeader.bfSize = sizeof(BITMAPFILEHEADER) + GlobalSize (hGMem);
        @ bmpHeader.bfReserved1 = 0;
        @ bmpHeader.bfReserved2 = 0;
        @ bmpHeader.bfOffBits = sizeof(BITMAPFILEHEADER) + sizeof (BITMAPINFOHEADER);
        @ LPBITMAPINFO lpBI;
        @ lpBI = (LPBITMAPINFO)::GlobalLock (hGMem);
        @ BitmapBuffer.Append ((void*)&bmpHeader, sizeof (BITMAPFILEHEADER));
        @ BitmapBuffer.Append (lpBI, GlobalSize (hGMem));
        @ ::GlobalUnlock (hGMem);
        @ ::CloseClipboard ();
        返回的位图数据 = 载入位图数据 (位图字节集)
        如果 (返回的位图数据.为空 () == 真)
        {
            返回 (假)
        }
        否则
        {
            返回 (真)
        }
    }
}

类 剪辑板监听类_ <公开 折叠 @文档 = "category = \"数据操作库.剪辑板监听\"">
{
    变量 句柄 <类型 = 变整数>
    变量 指针 <静态 类型 = 变整数>

    方法 监听_ <公开 注释 = "开始监听剪辑板变动" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ @<指针>=(@dt<变整数>)this;
        @ @<句柄> = (@dt<变整数>)@<监听输出>;
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ INT_PTR hData = SetWindowLongPtrW(hWnd, GWLP_WNDPROC, (INT_PTR)@<pfnWindowProc>);
        @ SetPropW(hWnd, L"Clipboard_Monitor", (HANDLE)hData);
        @ SetPropW(hWnd, L"Clipboard_Callback", (HANDLE)@<句柄>);
        @ SetPropW(hWnd, L"Clipboard_Viewer", SetClipboardViewer(hWnd));
    }

    方法 停止_ <公开 注释 = "停止监听剪辑板变动" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ HANDLE hWndNewNext = GetPropW(hWnd, L"Clipboard_Viewer");
        @ ChangeClipboardChain(hWnd, (HWND)hWndNewNext);
        @ HANDLE WndFunc = GetPropW(hWnd, L"Clipboard_Monitor");
        @ SetWindowLongPtrW(hWnd, GWLP_WNDPROC, (INT_PTR)WndFunc);
        @ RemovePropW(hWnd, L"Clipboard_Monitor");
        @ RemovePropW(hWnd, L"Clipboard_Callback");
        @ RemovePropW(hWnd, L"Clipboard_Viewer");
    }

    方法 pfnWindowProc <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 hWnd <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        @ HWND hWnd = (HWND)@<hWnd>;
        @ int uMsg = @<uMsg>;
        @ WPARAM wParam = (WPARAM)@<wParam>;
        @ LPARAM lParam = (LPARAM)@<lParam>;
        @ HANDLE WndFunc = GetPropW(hWnd, L"Clipboard_Monitor"),
        @ CalFunc = GetPropW(hWnd, L"Clipboard_Callback");
        @ HWND viewer = (HWND)GetPropW(hWnd, L"Clipboard_Viewer");
        @ if (uMsg == WM_DRAWCLIPBOARD || uMsg == WM_CHANGECBCHAIN || uMsg == WM_DESTROY)
        @ {
        @ if (CalFunc && CallWindowProcW((WNDPROC)CalFunc, hWnd, uMsg, wParam, lParam) == 1) return 1;
        @ if (uMsg == WM_CHANGECBCHAIN)
        @ {
        @ if ((HWND)wParam == viewer) viewer = (HWND)lParam;
        @ else SendMessageW(viewer, uMsg, (WPARAM)wParam, (LPARAM)lParam);
        @ }
        @ }
        @ else if (uMsg == WM_DESTROY) ChangeClipboardChain(hWnd, viewer);
        @ return CallWindowProcW((WNDPROC)WndFunc, hWnd, uMsg, wParam, lParam);
    }

    方法 监听输出 <静态 折叠>
    {
        变量 图片数据 <类型 = 字节集类>
        剪辑板_取剪辑板图片_字节集 (图片数据)
        读指针处对象 (指针, 剪辑板监听类_).剪辑板监听事件 (取剪辑板文本 (), 图片数据, 剪辑板_取剪辑板文件 ())
    }

    方法 剪辑板监听事件 <公开 定义事件 类型 = 整数 注释 = "复制数据时将触发本事件" 折叠>
    参数 文字信息 <类型 = 文本型>
    参数 图片信息 <类型 = 字节集类 注释 = "如果是图片则以字节集形式返回">
    参数 文件信息 <类型 = 文本数组类 注释 = "获取剪辑板中保存的文件，同时可判断是复制文件还是剪切文件." 注释 = "0、获取失败　1、复制文件　3剪切文件">
}

# //======

类 文本替换类_ <公开 折叠 折叠2 @文档 = "category = \"数据操作库.文本替换\"" @全局类 = 真>
{
    方法 子文本替换_ <公开 静态 类型 = 文本型 注释 = "正则方式替换数据" 折叠>
    参数 原始数据 <类型 = 文本型>
    参数 寻找的数据 <类型 = 文本数组类 注释 = "可加入多个">
    参数 替换为 <类型 = 文本型 @默认值 = "">
    参数 是否区分大小写 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 正则 <类型 = 正则类_>
        变量 结果 <类型 = 文本型>
        置文本预分配字符数 (结果, 取文本长度 (原始数据))
        结果 = 原始数据
        初始化COM库_ ()
        寻找的数据.枚举循环 ()
        {
            正则.创建 (寻找的数据.取枚举值 (), 结果, 是否区分大小写)
            结果 = 正则.替换 (替换为)
        }
        关闭COM库_ ()
        返回 (结果)
    }
}

