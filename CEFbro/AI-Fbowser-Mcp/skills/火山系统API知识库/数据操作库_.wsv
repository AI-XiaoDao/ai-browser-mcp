    方法 取文本长度_ <公开 静态 类型 = 整数 注释 = "同易语言" 折叠 @禁止流程检查 = 真>
    参数 文本 <类型 = 文本型>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<文本>,-1,NULL,NULL,0,NULL); 
        @ char *c = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<文本>,-1,c,dwNum,0,NULL);

        @ char* cha=c;
        @    int count{};   
        @    for (int i = 0; cha[i]; i++)
        @    {
        @        count++;
        @    }
        @    return count;

    }

