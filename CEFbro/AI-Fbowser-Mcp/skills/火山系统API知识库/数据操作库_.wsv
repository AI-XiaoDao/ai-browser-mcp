    方法 文本_取组件文本占位数量 <公开 静态 类型 = 整数 注释 = "计算该组件中每行最多能容纳的文字数量" 折叠>
    参数 父窗口 <类型 = 窗口容器组件 注释 = "本对象" "">
    参数 文本内容 <类型 = 文本型 注释 = "如果为空，则按中文字填充计算。不为空，则按提供的文字来计算。" @默认值 = "">
    参数 组件宽度 <类型 = 整数>
    参数 字体大小 <类型 = 文本型 @默认值 = "宋体, 11, 0, 0, 0, 0, 0">
    {
        变量 画板1 <类型 = 画板>
        变量 动态 <类型 = 动态画板类_>
        变量 大小值 <类型 = 整数>
        变量 临时内容 <类型 = 文本型>
        变量 文字容量 <类型 = 整数>
        变量 i <类型 = 整数>
        画板1 = 动态.创建画板 (父窗口)
        画板1.字体 = 字体大小
        动态.销毁对象_画板 ()
        如果 (删全部空_ (文本内容) != "")
        {
            循环 (, 取文本长度 (文本内容), i)
            {
                大小值 = 画板1.取宽度 (取文本左边 (文本内容, i + 1)) + 10
                如果 (大小值 > 组件宽度)
                {
                    文字容量 = i
                    跳出循环
                }
                否则
                {
                    文字容量 = i + 1
                }
            }
        }
        否则
        {
            循环 (, 5000, i)
            {
                加入文本 (临时内容, "字")
                大小值 = 画板1.取宽度 (临时内容) + 10
                如果真 (大小值 > 组件宽度)
                {
                    文字容量 = i
                    跳出循环
                }
            }
        }
        画板1.销毁 ()
        返回 (文字容量)
    }

    方法 文本_是否为空文本 <公开 静态 类型 = 逻辑型 折叠>
    参数 数据 <类型 = 文本型>
    参数 是否去除空格 <类型 = 逻辑型 注释 = "真：空格换行不算为内容  假：空格换行算为内容" @默认值 = 真>
    {
        如果真 (是否去除空格)
        {
            数据 = 删全部空_ (数据)
        }
        返回 (取文本长度 (数据) == 0)
    }

    方法 删全部空_ <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 待处理的数据 <类型 = 文本型>
    参数 清除回车符 <类型 = 逻辑型 注释 = "\\r" @默认值 = 真>
    参数 清除换行符 <类型 = 逻辑型 注释 = "\\n" @默认值 = 真>
    参数 清除制表符 <类型 = 逻辑型 注释 = "\\t" @默认值 = 真>
    {
        @ CWString str;
        @ str = @<待处理的数据>;
        @ str.Replace(_T(" "),_T(""));
        @ str.Replace(_T(" "),_T(""));
        @ str.Replace(_T("　"),_T(""));
        如果真 (清除回车符)
        {
            @ str.Replace(_T("\r"),_T(""));
        }
        如果真 (清除换行符)
        {
            @ str.Replace(_T("\n"),_T(""));
        }
        如果真 (清除制表符)
        {
            @ str.Replace(_T("\t"),_T(""));
        }
        @ return str;
    }

    方法 取文本中间_ <公开 静态 类型 = 文本型 注释 = "从左往右找" 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 @默认值 = 0>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    参数 不区分大小写 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        开始位置 = 寻找文本 (原始文本, 开始文本, 开始搜索位置, 不区分大小写)
        如果真 (开始位置 == -1)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
        }
        开始搜索位置 = 开始位置 + 取文本长度 (开始文本)
        结束位置 = 寻找文本 (原始文本, 结束文本, 开始搜索位置, 不区分大小写) + 取文本长度 (结束文本)
        如果真 (是否包含起始文本 == 假)
        {
            开始位置 = 开始搜索位置
            结束位置 = 寻找文本 (原始文本, 结束文本, 开始搜索位置, 不区分大小写)
        }
        如果真 (结束位置 == -1)
        {
            如果真 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            返回 (原始文本)
        }
        中间文本 = 取文本中间 (原始文本, 开始位置, 结束位置 - 开始位置)
        如果真 (结束位置 - 开始位置 == 0 && 如果找不到返回原始文本)
        {
            返回 (原始文本)
        }
        返回 (中间文本)
    }

    方法 文本_取文本中间 <公开 静态 类型 = 文本型 注释 = "从左往右找" 折叠>
    参数 原始文本 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
