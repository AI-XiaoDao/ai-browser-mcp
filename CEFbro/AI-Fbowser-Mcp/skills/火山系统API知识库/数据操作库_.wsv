        判断循环 (真)
        {
            开始位置 = 寻找文本 (原始文本, 开始文本, 结束位置, 不区分大小写)
            如果 (开始位置 == -1)
            {
                跳出循环
            }
            结束位置 = 寻找文本 (原始文本, 结束文本, 开始位置 + 开始文本长度, 不区分大小写)
            如果 (结束位置 == -1)
            {
                跳出循环
            }
            如果 (结束位置 - 开始位置 - 开始文本长度 > 0)
            {
                如果 (是否换行 == 假)
                {
                    加入文本 (结果组, 取文本中间 (原始文本, 开始位置 + 开始文本长度, 结束位置 - 开始位置 - 开始文本长度))
                }
                否则
                {
                    加入文本 (结果组, 取文本中间 (原始文本, 开始位置 + 开始文本长度, 结束位置 - 开始位置 - 开始文本长度) + "\r\n")
                }
            }
            否则 (如果找不到返回空)
            {
                如果 (是否换行 == 假)
                {
                    加入文本 (结果组, "")
                }
                否则
                {
                    加入文本 (结果组, "\r\n")
                }
            }
        }
        返回 (结果组)
    }

