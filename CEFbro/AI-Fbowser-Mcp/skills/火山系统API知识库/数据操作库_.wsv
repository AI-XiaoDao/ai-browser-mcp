    方法 子文本替换_连续 <公开 静态 注释 = "源文本 = \"你好，火山\" ." 注释 = "连续子文本替换_ (源文本, \"你好\", \"Hello\", \"火山\", \"火山中文编程\") ."
            注释 = "得到结果：Hello，火山中文编程" 折叠 折叠2 @嵌入式方法 = "req_obj_param_pointer = true">
    参数 源文本 <类型 = 文本型 编辑时信息 = "88880, 0, 0, 0">
    参数 替换参数 <类型 = 文本型 注释 = "必须提供偶数个,前者为欲替换值,后者为替换值,两两一组" 编辑时信息 = "88880, 0, 0, 0" @可扩展 = "">
    {
        @ @dt<文本处理类_>::SuperReplaceSubText(@<源文本>, NUM_CHARS_OF_TEXT (@sn<pm_types>), @<替换参数>)
    }

