    {
        @ lw::fp::create_arrar<@<数组类型>>(@<成员>)
    }

    方法 数组连续加入成员_ <公开 静态 注释 = "将一些数据连续加入到一个数组中" 注释 = "  示例: 数组连续加入成员_(整数数组,1,2,3)" 注释 = "  等价于：" 注释 = "        整数数组.加入成员(1)"
