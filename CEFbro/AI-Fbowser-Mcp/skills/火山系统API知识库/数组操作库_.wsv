        变量 继续循环 <类型 = 逻辑型 值 = 真>
        左地址 = 待排序的变量.取数组指针 () + 最小索引 * 取数据类型尺寸 (整数)
        右地址 = 待排序的变量.取数组指针 () + 最大索引 * 取数据类型尺寸 (整数)
        左索引 = 最小索引
        右索引 = 最大索引
        基准数 = 待排序的变量.取成员 ((最小索引 + 最大索引) / 2)
        判断循环 (继续循环)
        {
            判断循环 (左索引 <= 最大索引 && 读指针处值 (左地址, 整数) < 基准数)
            {
                左地址 = 左地址 + 取数据类型尺寸 (整数)  // 这样计算地址,比"数组.取成员(索引)" "取数组指针()+索引*取数据类型尺寸 (整数)" 快很多!
                左索引 = 左索引 + 1
            }
            判断循环 (右索引 >= 0 && 读指针处值 (右地址, 整数) > 基准数)
            {
                右地址 = 右地址 - 取数据类型尺寸 (整数)
                右索引 = 右索引 - 1
            }
            如果 (左索引 <= 右索引)
            {
                待排序的变量.交换成员 (左索引, 右索引)
                如果 (绑定数组指针 != 0)
                {
                    尝试自动交换成员 (绑定数组指针, 左索引, 右索引, 待绑定的附加数组类型)
                }

                左索引 = 左索引 + 1
                左地址 = 左地址 + 取数据类型尺寸 (整数)

                右索引 = 右索引 - 1
                右地址 = 右地址 - 取数据类型尺寸 (整数)
            }
            继续循环 = 左索引 <= 右索引
        }


        如果 (最小索引 < 右索引)
        {
