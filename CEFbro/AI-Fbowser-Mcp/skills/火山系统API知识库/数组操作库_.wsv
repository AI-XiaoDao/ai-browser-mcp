类 数组辅助类2_ <公开 注释 = "std::sort方式" 折叠 折叠2 @文档 = "category = \"数组操作库.数组排序对比\"" @全局类 = 真>
{
    方法 数组排序2_ <公开 静态 折叠 @视窗.外部头文件 = "algorithm">
    参数 文本数组 <类型 = 文本数组类>
    参数 排序方式 <类型 = 逻辑型 注释 = "真：从小到大  假：从大到小" @默认值 = 真>
    {
        @ INT_P count = @<文本数组>.data().GetCount();
        @ if (count <= 0) return ;
        @ if (@<排序方式>)
        @     std::sort(@<文本数组>.data().GetData(), @<文本数组>.data().GetData() + count, [](const WCHAR* lhs, const WCHAR* rhs) { return wcscmp(lhs, rhs) > 0; });
        @ else
        @     std::sort(@<文本数组>.data().GetData(), @<文本数组>.data().GetData() + count, [](const WCHAR* lhs, const WCHAR* rhs) { return wcscmp(lhs, rhs) < 0; });
    }

    方法 对比数组差_ <公开 静态 注释 = "比较两个数组内容，将未能同时出现在两个数组中的数据，记录在结果数据中" 折叠 @视窗.外部头文件 = "algorithm\r\nvector\r\niterator">
    参数 数组A <类型 = 文本数组类 注释 = "内部会对数组进行排序，如果不想改变这个数组，可以先复制一份">
    参数 数组B <类型 = 文本数组类 注释 = "内部会对数组进行排序，如果不想改变这个数组，可以先复制一份">
    参数 结果数组 <类型 = 文本数组类 注释 = "返回对称差数组">
    {
        结果数组.删除所有成员 ()
        如果 (数组A.取成员数 () == 0 || 数组B.取成员数 () == 0)
        {
            返回
        }
        @ auto less = [](const WCHAR* lhs, const WCHAR* rhs) { return wcscmp(lhs, rhs) < 0; };
        @ std::sort(@<数组A>.data().GetData(), @<数组A>.data().GetData() + @<数组A>.data().GetCount(), less);
        @ std::sort(@<数组B>.data().GetData(), @<数组B>.data().GetData() + @<数组B>.data().GetCount(), less);
        @ std::vector<const WCHAR*> v_symDifference;
        @ std::set_symmetric_difference(@<数组A>.data().GetData(), @<数组A>.data().GetData() + @<数组A>.data().GetCount(),
        @     @<数组B>.data().GetData(), @<数组B>.data().GetData() + @<数组B>.data().GetCount(),
        @     std::back_inserter(v_symDifference), less);
        @ if (v_symDifference.empty()) return;
        @ @<结果数组>.data().SetAlignElementCount((INT_P)v_symDifference.size());
        @ for (size_t i = 0; i < v_symDifference.size(); i++)
        @     @<结果数组>.data().Add(v_symDifference[i]);
    }
}

类 数组辅助扩展类_ <公开 折叠 折叠2 @文档 = "category = \"数组操作库.数组综合处理\"" @全局类 = 真 @禁止继承 = 真 @禁止创建对象 = 真
        @视窗.外部头文件 = "szfzl\\functional.hpp" @视窗.附加编译参数 = "cpp:/std:c++17">
{
    方法 数组映射_ <公开 静态 注释 = "将方法应用于数组中的每个成员" 注释 = "  示例: 整数数组 = [1,2,3]"
            注释 = "        结果数组 = 数组映射_(匿名函数(置参数一(整数) * 2), 整数数组, 整数数组类)" 注释 = "        结果数组 = [2,4,6]"
            注释 = "  示例: 文本数组 = [\"1\",\"2\",\"3\"]" 注释 = "        结果文本数组 = 数组映射_ (匿名函数_ (置参数一 (文本型) + 置参数一 (文本型))"
            注释 = "        结果文本数组 = [\"11\",\"22\",\"33\"]" 注释 = "  示例: 整数数组 = [1,2,3]"
            注释 = "        结果文本数组 = 数组映射_(匿名函数(到文本(置参数一(整数))), 整数数组, 文本数组类)" 注释 = "        结果文本数组 = [\"2\",\"4\",\"6\"]" 折叠 折叠2
            @嵌入式方法 = "">
    参数 引入方法 <类型 = 逻辑型 "">
    参数 欲操作的数组 <@匹配类型 = 所有类型>
    参数 返回类型 <@匹配类型 = 所有类型 @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ lw::fp::transform<@<返回类型>>(@<引入方法>, @<欲操作的数组>)
    }

    方法 数组过滤_ <公开 静态 注释 = "将方法应用于数组中的每个成员, 如果方法返回值为真则保留成员." 注释 = "  示例: 整数数组 = [1,2,3,4]"
            注释 = "        结果数组 = 数组过滤_ (匿名函数_ (置参数一 (整数) % 2 == 0), 整数数组)" 注释 = "        结果数组 = [2,4]" 注释 = "  示例: 整数数组 = [1,2,3,4]"
            注释 = "        结果数组 = 数组过滤_ (方法到逻辑_ (是否为奇数), 整数数组)" 注释 = "        结果数组 = [1,3]" 注释 = "  示例: 文本数组 = [\"1\",\"2\",\"3\"]"
            注释 = "        结果文本数组 = 数组过滤_ (方法到逻辑_ (文本数字是否为奇数), 文本数组)" 注释 = "        结果文本数组 = [\"1\",\"3\"]" 折叠 折叠2 @嵌入式方法 = "">
    参数 引入方法 <类型 = 逻辑型 "">
    参数 欲操作的数组 <@匹配类型 = 所有类型 @返回值类型 = 0>
    {
        @ lw::fp::filter(@<引入方法>, @<欲操作的数组>)
    }

    方法 数组折叠_ <公开 静态 注释 = "将数组中的所有成员和初始值\"累加\",两两运算的方式得到一个值,默认初始值为数组中第一个成员." 注释 = "  示例: 整数数组 = [1,2,3]"
            注释 = "        结果数组 = 数组折叠_ (匿名函数2_ (置参数一 (整数) + 置参数二 (整数)), 整数数组, 整数)" 注释 = "        整数和结果 = 10"
            注释 = "  示例: 文本数组 = [\"1\",\"2\",\"3\"]" 注释 = "        结果文本数组 = 数组折叠_ (匿名函数2_ (置参数一 (文本型) + 置参数二 (文本型)), 文本数组, 文本型)"
            注释 = "        文本结果 = \"123\"" 折叠 折叠2 @嵌入式方法 = "">
    参数 引入方法 <类型 = 逻辑型 注释 = "传入一个二元方法,即有两个参数的方法,第一个参数会传入累积结果,第二个则是下标范围 1至最大成员数 - 1 的数组成员" "">
    参数 欲操作的数组 <@匹配类型 = 所有类型>
    参数 返回类型 <@匹配类型 = 所有类型 @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ lw::fp::fold<@<返回类型>>(@<引入方法>,@<欲操作的数组>)
    }

    方法 创建数组类_ <公开 静态 注释 = "快速创建一个数组" 注释 = "  示例: 创建数组类_ = 创建数组类(整数数组类,1, 2, 3)" 注释 = "  等价于：" 注释 = "        整数数组.加入成员(1)"
            注释 = "        整数数组.加入成员(2)" 注释 = "        整数数组.加入成员(3)" 折叠 折叠2 @嵌入式方法 = "">
    参数 数组类型 <@匹配类型 = 所有类型 @需求类型 = 数据类型 @返回值类型 = 0>
