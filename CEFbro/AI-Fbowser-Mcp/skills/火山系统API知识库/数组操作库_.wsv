类 数组反转类_ <公开 折叠 折叠2 @文档 = "category = \"数组操作库.数组反转\"" @全局类 = 真>
{
    方法 反转数组_文本 <公开 静态 类型 = 文本数组类 折叠>
    参数 待处理的数组 <类型 = 文本数组类>
    {
        变量 结果 <类型 = 文本数组类>
        变量 总数 <类型 = 整数>
        变量 i <类型 = 整数>
        结果.预分配尺寸 = 1024 * 1024 * 7
        总数 = 待处理的数组.取成员数 ()
        循环 (, 总数, i)
        {
            结果.加入成员 (待处理的数组.取成员 (总数 - i - 1))
        }
        返回 (结果)
    }

    方法 反转数组_短整数 <公开 静态 类型 = 短整数数组类 折叠>
    参数 待处理的数组 <类型 = 短整数数组类>
    {
        变量 结果 <类型 = 短整数数组类>
        变量 总数 <类型 = 整数>
        变量 i <类型 = 整数>
        结果.重置数组 (待处理的数组.取成员数 ())
        总数 = 待处理的数组.取成员数 ()
        循环 (, 总数, i)
        {
            结果.置成员值 (i, 待处理的数组.取成员 (总数 - i - 1))
        }
        返回 (结果)
    }

