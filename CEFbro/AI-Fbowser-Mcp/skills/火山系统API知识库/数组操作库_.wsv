类 数组去重复类_ <公开 折叠 折叠2 @文档 = "category = \"数组操作库.数组去重复\"" @全局类 = 真>
{
    方法 数组去重复_文本 <公开 静态 类型 = 文本数组类 折叠>
    参数 待处理的数组 <类型 = 文本数组类>
    {
        变量 临时数组 <类型 = 文本独有数组类>
        变量 临时数组2 <类型 = 文本数组类>
        临时数组.预分配尺寸 = 待处理的数组.取成员数 ()
        待处理的数组.枚举循环 ()
        {
            临时数组.加入成员 (待处理的数组.取枚举值 ())
        }
        临时数组2.预分配尺寸 = 临时数组.取成员数 ()
        临时数组.枚举循环 ()
        {
            临时数组2.加入成员 (临时数组.取枚举值 ())
        }
        返回 (临时数组2)
    }

