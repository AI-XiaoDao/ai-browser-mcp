                {
                    返回 (1)
                }
                否则 (字符1 == '\0' && 字符2 == '\0')
                {
                    返回 (0)
                }
                文本指针1 = 文本指针1 + 1
                文本指针2 = 文本指针2 + 1
                内部跳转 ("不区分大小写")
            }
        }
        返回 (0)
    }
}

