    方法 内部文本指针比较 <类型 = 整数 返回值注释 = "如果返回值小于0,表示\"文本指针1\"小于\"文本指针2\"" 返回值注释 = "如果等于0,表示\"文本指针1\"等于\"文本指针2\""
            返回值注释 = "如果大于0,表示\"文本指针1\"大于\"文本指针2." 折叠>
    参数 文本指针1 <类型 = 变整数>
    参数 文本指针2 <类型 = 变整数>
    参数 区分大小写 <类型 = 逻辑型>
    {
        变量 字符1 <类型 = 字符>
        变量 字符2 <类型 = 字符>
        如果 (区分大小写)
        {
            内部标签 ("区分大小写")
            {
                字符1 = 读指针处值 (文本指针1, 字符)
                字符2 = 读指针处值 (文本指针2, 字符)
                如果 (字符1 < 字符2)
                {
                    返回 (-1)
                }
                否则 (字符1 > 字符2)
                {
                    返回 (1)
                }
                否则 (字符1 == '\0' && 字符2 == '\0')
                {
                    返回 (0)
                }
                文本指针1 = 文本指针1 + 2
                文本指针2 = 文本指针2 + 2
                内部跳转 ("区分大小写")
            }

        }
        否则
        {
            内部标签 ("不区分大小写")
            {
                字符1 = 内部字符到小写 (读指针处值 (文本指针1, 字符))
                字符2 = 内部字符到小写 (读指针处值 (文本指针2, 字符))
                如果 (字符1 < 字符2)
                {
                    返回 (-1)
                }
                否则 (字符1 > 字符2)
                {
                    返回 (1)
                }
                否则 (字符1 == '\0' && 字符2 == '\0')
                {
                    返回 (0)
                }
                文本指针1 = 文本指针1 + 2
                文本指针2 = 文本指针2 + 2
                内部跳转 ("不区分大小写")
            }

        }
        返回 (0)
    }

    方法 内部取文本数组成员指针 <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 数组 <类型 = 文本数组类>
    参数 索引位置 <类型 = 整数>
    {
        @ (INT_P)@<数组>.data ().GetAt (@<索引位置>)
    }

    方法 内部标签 <静态 注释 = "goto" 折叠 @嵌入式方法 = "has_loop_body = true">
    参数 内部标签名 <类型 = 文本型 @需求类型 = 立即数或常量>
    {
        @ @pvpt<内部标签名>:
    }

    方法 内部跳转 <静态 注释 = " goto" 折叠 @嵌入式方法 = "">
    参数 内部标签名 <类型 = 文本型 编辑时信息 = "17553E, 0, 0, 0" @需求类型 = 立即数或常量>
    {
        @ goto @pvpt<内部标签名>;
    }

    方法 内部字符到小写 <静态 类型 = 字符 折叠 "//@视窗.前缀文本" = "inline">
    参数 当前字符 <类型 = 字符>
    {
        如果 (当前字符 >= 'A' && 当前字符 <= 'Z')
        {
            返回 (当前字符 + (字符)' ')
        }
        返回 (当前字符)
    }

