    方法 交换数组成员事件 <公开 定义事件 类型 = 整数 折叠>
    参数 绑定数组指针 <类型 = 变整数 注释 = "读指针处对象(绑定数组指针,*数组类).交换成员(索引1,索引2)">
    参数 索引1 <类型 = 整数>
    参数 索引2 <类型 = 整数>

    方法 尝试自动交换成员 <折叠>
    参数 绑定数组指针 <类型 = 变整数 注释 = "读指针处对象(绑定数组指针,*数组类).交换成员(索引1,索引2)">
    参数 索引1 <类型 = 整数>
    参数 索引2 <类型 = 整数>
    参数 待绑定的附加数组类型 <类型 = 数组排序类型>
    {
        如果 (待绑定的附加数组类型 == 数组排序类型.无)
        {
            返回
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.自定义)  // 用户自定义了
        {
            交换数组成员事件 (绑定数组指针, 索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.整数数组类)
        {
            读指针处对象 (绑定数组指针, 整数数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.字节数组类)
        {
            读指针处对象 (绑定数组指针, 字节数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.字符数组类)
        {
            读指针处对象 (绑定数组指针, 字符数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.短整数数组类)
        {
            读指针处对象 (绑定数组指针, 短整数数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.长整数数组类)
        {
            读指针处对象 (绑定数组指针, 长整数数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.小数数组类)
        {
            读指针处对象 (绑定数组指针, 小数数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.变整数数组类)
        {
            读指针处对象 (绑定数组指针, 变整数数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.文本数组类)
        {
            读指针处对象 (绑定数组指针, 文本数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.字节集数组类)
        {
            读指针处对象 (绑定数组指针, 字节集数组类).交换成员 (索引1, 索引2)
        }
        否则 (待绑定的附加数组类型 == 数组排序类型.对象数组类)
        {
            读指针处对象 (绑定数组指针, 对象数组类).交换成员 (索引1, 索引2)
        }
        // 否则 (待绑定的附加数组类型 == 数组排序类型.数组类)
        {
            // 读指针处对象 (绑定数组指针, 数组类).交换成员 (索引1, 索引2)
        }


    }

    方法 内部文本排序指针小于基准 <类型 = 逻辑型 折叠>
    参数 文本数组地址 <类型 = 变整数>
    参数 基准文本地址 <类型 = 变整数>
    参数 UTF16 <类型 = 逻辑型>
    {
        变量 文本地址 <类型 = 变整数>
        文本地址 = 读指针处值 (文本数组地址, 变整数)
        如果 (基准文本地址 == 0 || 文本地址 == 0)
        {
            返回 (文本地址 < 基准文本地址)
        }
        如果 (UTF16)
        {
            返回 (内部文本指针比较 (文本地址, 基准文本地址, 真) < 0)
        }
        返回 (内部文本指针比较2 (文本地址, 基准文本地址, 真) < 0)
    }

    方法 内部文本排序指针大于基准 <类型 = 逻辑型 折叠>
    参数 文本数组地址 <类型 = 变整数>
    参数 基准文本地址 <类型 = 变整数>
    参数 UTF16 <类型 = 逻辑型>
    {
        变量 文本地址 <类型 = 变整数>
        文本地址 = 读指针处值 (文本数组地址, 变整数)
        如果 (基准文本地址 == 0 || 文本地址 == 0)
        {
            返回 (文本地址 > 基准文本地址)
        }
        如果 (UTF16)
        {
            返回 (内部文本指针比较 (文本地址, 基准文本地址, 真) > 0)
        }
        返回 (内部文本指针比较2 (文本地址, 基准文本地址, 真) > 0)
    }

    方法 内部文本排序大到小 <折叠>
    参数 最小索引 <类型 = 整数 "">
    参数 最大索引 <类型 = 整数 注释 = "成员数-1">
    参数 待排序的变量 <类型 = 变整数数组类 注释 = "可以挂接待排序的变量">
    参数 绑定交换数组指针1 <类型 = 变整数>
    参数 绑定交换数组类型1 <类型 = 数组排序类型>
    参数 绑定交换数组指针2 <类型 = 变整数 注释 = "数组.取对象自身指针()">
    参数 绑定交换数组类型2 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!">
    参数 UTF16 <类型 = 逻辑型>
    {
        变量 左索引 <类型 = 整数>
        变量 右索引 <类型 = 整数>
        变量 基准文本地址 <类型 = 变整数>
        变量 继续循环 <类型 = 逻辑型 值 = 真>
        变量 左地址 <类型 = 变整数>
        变量 右地址 <类型 = 变整数>
        左地址 = 待排序的变量.取数组指针 () + 最小索引 * 取数据类型尺寸 (变整数)
        右地址 = 待排序的变量.取数组指针 () + 最大索引 * 取数据类型尺寸 (变整数)

        左索引 = 最小索引
        右索引 = 最大索引
        基准文本地址 = 待排序的变量.取成员 ((最小索引 + 最大索引) / 2)  // 获取数组,中间的数值

        判断循环 (继续循环)
        {

            判断循环 (左索引 <= 最大索引 && 内部文本排序指针大于基准 (左地址, 基准文本地址, UTF16))
            {
                左索引 = 左索引 + 1
                左地址 = 左地址 + 取数据类型尺寸 (变整数)  // 这样计算地址,比"数组.取成员(索引)" "取数组指针()+索引*取数据类型尺寸 (整数)" 快很多!
            }
            判断循环 (右索引 >= 0 && 内部文本排序指针小于基准 (右地址, 基准文本地址, UTF16))
            {
                右索引 = 右索引 - 1
                右地址 = 右地址 - 取数据类型尺寸 (变整数)
            }
            如果 (左索引 <= 右索引)
            {
                待排序的变量.交换成员 (左索引, 右索引)

                如果 (绑定交换数组指针1 != 0)
                {
                    尝试自动交换成员 (绑定交换数组指针1, 左索引, 右索引, 绑定交换数组类型1)
                }
                如果 (绑定交换数组指针2 != 0)
                {
                    尝试自动交换成员 (绑定交换数组指针2, 左索引, 右索引, 绑定交换数组类型2)
                }

                左索引 = 左索引 + 1
                左地址 = 左地址 + 取数据类型尺寸 (变整数)

                右索引 = 右索引 - 1
                右地址 = 右地址 - 取数据类型尺寸 (变整数)

            }
            继续循环 = 左索引 <= 右索引
        }

        如果 (最小索引 < 右索引)
        {
            内部文本排序大到小 (最小索引, 右索引, 待排序的变量, 绑定交换数组指针1, 绑定交换数组类型1, 绑定交换数组指针2, 绑定交换数组类型2, UTF16)  // 递归
        }
        如果 (左索引 < 最大索引)
        {
            内部文本排序大到小 (左索引, 最大索引, 待排序的变量, 绑定交换数组指针1, 绑定交换数组类型1, 绑定交换数组指针2, 绑定交换数组类型2, UTF16)  // 递归
        }


    }

    方法 内部文本排序小到大 <折叠>
    参数 最小索引 <类型 = 整数 "">
    参数 最大索引 <类型 = 整数 注释 = "成员数-1">
    参数 待排序的变量 <类型 = 变整数数组类 注释 = "可以挂接待排序的变量">
    参数 绑定交换数组指针1 <类型 = 变整数>
    参数 绑定交换数组类型1 <类型 = 数组排序类型>
    参数 绑定交换数组指针2 <类型 = 变整数 注释 = "数组.取对象自身指针()">
    参数 绑定交换数组类型2 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!">
    参数 UTF16 <类型 = 逻辑型>
    {
        变量 左地址 <类型 = 变整数>
        变量 右地址 <类型 = 变整数>
        变量 左索引 <类型 = 整数>
        变量 右索引 <类型 = 整数>
        变量 基准文本地址 <类型 = 变整数>
        变量 继续循环 <类型 = 逻辑型 值 = 真>
        左地址 = 待排序的变量.取数组指针 () + 最小索引 * 取数据类型尺寸 (变整数)
        右地址 = 待排序的变量.取数组指针 () + 最大索引 * 取数据类型尺寸 (变整数)

        左索引 = 最小索引
        右索引 = 最大索引
        基准文本地址 = 待排序的变量.取成员 ((最小索引 + 最大索引) / 2)

        判断循环 (继续循环)
        {
            判断循环 (左索引 <= 最大索引 && 内部文本排序指针小于基准 (左地址, 基准文本地址, UTF16))
            {
                左地址 = 左地址 + 取数据类型尺寸 (变整数)  // 这样计算地址,比"数组.取成员(索引)" "取数组指针()+索引*取数据类型尺寸 (整数)" 快很多!
                左索引 = 左索引 + 1
            }


            // 指针_比较内存 (读指针处值 (右地址, 变整数), 基准文本地址, 选择 (基准长度 > 读指针处值 (右地址4, 整数), 读指针处值 (右地址4, 整数), 基准长度)) > 0
            判断循环 (右索引 >= 0 && 内部文本排序指针大于基准 (右地址, 基准文本地址, UTF16))
            {
                右地址 = 右地址 - 取数据类型尺寸 (变整数)
                右索引 = 右索引 - 1
            }
            如果 (左索引 <= 右索引)
            {
                待排序的变量.交换成员 (左索引, 右索引)

                如果 (绑定交换数组指针1 != 0)
                {
                    尝试自动交换成员 (绑定交换数组指针1, 左索引, 右索引, 绑定交换数组类型1)
                }
                如果 (绑定交换数组指针2 != 0)
                {
                    尝试自动交换成员 (绑定交换数组指针2, 左索引, 右索引, 绑定交换数组类型2)
                }

                左索引 = 左索引 + 1
                左地址 = 左地址 + 取数据类型尺寸 (变整数)


                右索引 = 右索引 - 1
                右地址 = 右地址 - 取数据类型尺寸 (变整数)

            }
            继续循环 = 左索引 <= 右索引
        }


        如果 (最小索引 < 右索引)
        {
            内部文本排序小到大 (最小索引, 右索引, 待排序的变量, 绑定交换数组指针1, 绑定交换数组类型1, 绑定交换数组指针2, 绑定交换数组类型2, UTF16)  // 递归
        }
        如果 (左索引 < 最大索引)
        {
            内部文本排序小到大 (左索引, 最大索引, 待排序的变量, 绑定交换数组指针1, 绑定交换数组类型1, 绑定交换数组指针2, 绑定交换数组类型2, UTF16)  // 递归
        }

    }

