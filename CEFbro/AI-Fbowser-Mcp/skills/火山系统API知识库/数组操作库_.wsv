<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"数组操作库\"">

类 数组快速排序类_ <公开 折叠 @文档 = "category = \"数组操作库.数组快速排序\"">
{
    方法 排序文本_ <公开 折叠>
    参数 待排序的变量 <类型 = 文本数组类>
    参数 排序方式 <类型 = 逻辑型 注释 = "真：从小到大  假：从大到小" @默认值 = 真>
    参数 待绑定的附加数组 <类型 = 变整数 注释 = "数组.取对象自身指针()" @默认值 = 0>
    参数 待绑定的附加数组类型 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!" @默认值 = 数组排序类型.自定义>
    {
        如果 (待排序的变量.取成员数 () <= 1)
        {
            返回
        }
        变量 指针数组 <类型 = 变整数数组类>
        变量 i <类型 = 整数>
        变量 成员指针 <类型 = 变整数>
        变量 数组指针 <类型 = 变整数>
        指针数组.重置数组 (待排序的变量.取成员数 ())
        数组指针 = 指针数组.取数组指针 ()
        循环 (0, 待排序的变量.取成员数 (), i)
        {
            成员指针 = 内部取文本数组成员指针 (待排序的变量, i)
            写指针处值 (数组指针, 成员指针)  // 指针数组.置成员值 (i, 成员指针)
            数组指针 = 数组指针 + 取变整数尺寸 ()
        }
        排序文本_指针2 (指针数组, 排序方式, 待绑定的附加数组, 待绑定的附加数组类型, 待排序的变量.取对象自身指针 (), 数组排序类型.文本数组类, 真)
    }

    方法 排序文本_指针 <公开 折叠>
    参数 待排序的变量 <类型 = 变整数数组类 注释 = "文本指针数组，尾部必须有\"\\0\"">
    参数 排序方式 <类型 = 逻辑型 注释 = "真：从小到大  假：从大到小" @默认值 = 真>
    参数 待绑定的附加数组 <类型 = 变整数 注释 = "数组.取对象自身指针()" @默认值 = 0>
    参数 待绑定的附加数组类型 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!" @默认值 = 数组排序类型.自定义>
    {
        如果 (待排序的变量.取成员数 () <= 1)
        {
            返回
        }
        排序文本_指针2 (待排序的变量, 排序方式, 待绑定的附加数组, 待绑定的附加数组类型, 0, , 假)
    }

    方法 排序文本_指针2 <公开 折叠>
    参数 待排序的变量 <类型 = 变整数数组类 注释 = "文本指针数组">
    参数 排序方式 <类型 = 逻辑型 注释 = "真：从小到大  假：从大到小" @默认值 = 真>
    参数 待绑定的附加数组 <类型 = 变整数 注释 = "数组.取对象自身指针()" @默认值 = 0>
    参数 待绑定的附加数组类型 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!" @默认值 = 数组排序类型.自定义>
    参数 待绑定的附加数组2 <类型 = 变整数 注释 = "数组.取对象自身指针()" @默认值 = 0>
    参数 待绑定的附加数组类型2 <类型 = 数组排序类型 注释 = "如果提供了准确的类型,那么内部会自动进行交换,就不需要在事件里进行交换了!" @默认值 = 数组排序类型.自定义>
    参数 UTF16 <类型 = 逻辑型 注释 = "真=UTF16    假=GBK|UTF-8" @默认值 = 真>
    {
        如果 (待排序的变量.取成员数 () <= 1)
        {
            返回
        }
        如果 (排序方式)
        {
            内部文本排序小到大 (0, 待排序的变量.取成员数 () - 1, 待排序的变量, 待绑定的附加数组, 待绑定的附加数组类型, 待绑定的附加数组2, 待绑定的附加数组类型2, UTF16)
        }
        否则
        {
            内部文本排序大到小 (0, 待排序的变量.取成员数 () - 1, 待排序的变量, 待绑定的附加数组, 待绑定的附加数组类型, 待绑定的附加数组2, 待绑定的附加数组类型2, UTF16)
        }
    }

