        返回 (Sheets对象.读无参数属性 ("Count", 整数))
    }
}

类 Excel表_ <折叠 @文档 = "category = \"文件打印库.附加类\"">
{
    变量 Worksheet对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." 折叠>
    参数 参_Worksheet对象 <类型 = COM对象类>
    {
        Worksheet对象 = 参_Worksheet对象
        返回 (Worksheet对象.是否为空 () == 假)
    }

    方法 激活 <公开 注释 = "激活该工作表,作为当前活动窗口." 折叠>
    {
        Worksheet对象.无参数及返回值方法 ("Activate")
    }

    方法 打印方向 <公开 属性读 类型 = 整数 注释 = "返回纵向或横向打印模式" 返回值注释 = "1 纵向模式;2 横向模式." 折叠>
    {
        返回 (Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类).读无参数属性 ("Orientation", 整数))
    }

    方法 打印方向 <公开 属性写 注释 = "设置纵向或横向打印模式" 折叠>
    参数 所欲设置的值 <类型 = 整数 注释 = "1 纵向模式;2 横向模式.">
    {
        Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("Orientation", 所欲设置的值)
    }

    方法 打印 <公开 注释 = "打印对象.\"开始页号\"和\"终止页号\"的说明中的\"页面\"是指打印的页面,而不是工作表或工作簿中的整个页面." 折叠>
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号.如果值为-1时,则省略此参数,则从起始位置开始打印." @默认值 = -1>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号.如果值为-1时,则省略此参数,则打印至最后一页." @默认值 = -1>
    参数 打印份数 <类型 = 整数 注释 = "打印份数.如果值为-1时,则省略此参数,则只打印一份." @默认值 = -1>
    参数 打印前预览 <类型 = 逻辑型 注释 = "如果为真,将在打印对象之前调用打印预览.如果为假,则立即打印对象." @默认值 = 假>
    参数 活动打印机 <类型 = 文本型 注释 = "设置活动打印机的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    参数 输出文件 <类型 = 逻辑型 注释 = "如果为真,则打印到文件.如果未指定\"输出文件名\",将提示用户输入输出文件的名称." @默认值 = 假>
    参数 逐份打印 <类型 = 逻辑型 注释 = "如果为真,则逐份打印多个副本." @默认值 = 真>
    参数 输出文件名 <类型 = 文本型 注释 = "如果\"输出文件\"设置为真,则此参数指定要打印到的文件的名称.如果值为空文本时,则省略此参数." @默认值 = "">
    参数 区域打印 <类型 = 逻辑型 注释 = "如果为真,则忽略打印区域并打印整个对象." @默认值 = 真>
    {
        变量 局_开始页号 <类型 = COM变体型>
        变量 局_终止页号 <类型 = COM变体型>
        变量 局_打印份数 <类型 = COM变体型>
        变量 局_活动打印机 <类型 = COM变体型>
        变量 局_输出文件名 <类型 = COM变体型>
        如果 (开始页号 != -1)
        {
            局_开始页号.赋值 (开始页号)
        }
        如果 (终止页号 != -1)
        {
            局_终止页号.赋值 (终止页号)
        }
        如果 (打印份数 != -1)
        {
            局_打印份数.赋值 (打印份数, )
        }
        如果 (活动打印机 != "")
        {
            局_活动打印机.赋值 (活动打印机, )
        }
        如果 (输出文件名 != "")
        {
            局_输出文件名.赋值 (输出文件名, )
        }
        Worksheet对象.无返回值方法 ("PrintOut", 局_开始页号, 局_终止页号, 局_打印份数, 打印前预览, 局_活动打印机, 输出文件, 逐份打印, 局_输出文件名, 区域打印)
    }

    方法 置页面边距 <公开 注释 = "4个页面边距设置.边距的设置均以磅为单位.与打印相关." 注释 = "注意：打印机设置中没有任何打印机时,会使页面纸张大小设置失败." 折叠 折叠2>
    参数 左 <类型 = 小数 @默认值 = 50.4>
    参数 右 <类型 = 小数 @默认值 = 50.4>
    参数 上 <类型 = 小数 @默认值 = 54>
    参数 下 <类型 = 小数 @默认值 = 54>
    参数 纸张大小 <类型 = Excel纸张大小_ 注释 = "Excel纸张大小_*.某些打印机可能不支持列出的所有纸张大小." @默认值 = Excel纸张大小_.不改变>
    {
        变量 pagesetup <类型 = COM对象类>
        pagesetup = Worksheet对象.读无参数对象型属性 ("PageSetup", COM对象类)  // 返回一个 页面设置对象,该对象包含指定对象的所有页面设置.
        pagesetup.写属性 ("LeftMargin", 左)
        pagesetup.写属性 ("RightMargin", 右)
        pagesetup.写属性 ("TopMargin", 上)
        pagesetup.写属性 ("BottomMargin", 下)
        如果 (纸张大小 != Excel纸张大小_.不改变)
        {
            pagesetup.写属性 ("PaperSize", 纸张大小)
        }
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "返回对象名称" 折叠>
    {
        返回 (Worksheet对象.读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "设置对象名称" 折叠>
    参数 所欲设置的值 <类型 = 文本型>
    {
        Worksheet对象.写属性 ("Name", 所欲设置的值)
    }

    方法 添加图片 <公开 注释 = "添加一幅硬盘中的图片文件" 折叠>
    参数 文件名 <类型 = 文本型 注释 = "要创建图片的文件.">
    参数 链接到文件 <类型 = 逻辑型 注释 = "若指定为真,就建立图片与其源文件之间的链接.若指定为假,就使图片成为与其源文件的相互独立的复制品.">
    参数 全部保存 <类型 = 逻辑型 注释 = "若为真,则将链接图片和插入图片的文档全部保存;若为假,则只在文档中保存链接信息.如果链接到文件为假,则本参数必须为真">
    参数 左边 <类型 = 小数 注释 = "图片左上角相对于文档左上角的位置(以磅为单位).">
    参数 顶边 <类型 = 小数 注释 = "图片左上角相对于文档顶部的位置(以磅为单位).">
    参数 宽度 <类型 = 小数 注释 = "图片的宽度,-1 表示保留现有文件的宽度." @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "图片的高度,-1 表示保留现有文件的高度." @默认值 = -1>
    {
        Worksheet对象.读无参数对象型属性 ("Shapes", COM对象类).无返回值方法 ("AddPicture", 文件名, 链接到文件, 全部保存, 左边, 顶边, 宽度, 高度)
    }
}

