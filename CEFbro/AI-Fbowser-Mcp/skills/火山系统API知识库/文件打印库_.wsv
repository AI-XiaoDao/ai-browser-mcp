    常量 信封C6 <公开 值 = @xlPaperEnvelopeC6 注释 = "信封 C6(114 毫米 x 162 毫米)">
    常量 信封C65 <公开 值 = @xlPaperEnvelopeC65 注释 = "信封 C65(114 毫米 x 229 毫米)">
