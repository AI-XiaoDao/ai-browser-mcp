    常量 文档标记 <公开 值 = @wdPrintMarkup 注释 = "当前文档中的标记">
    常量 文档批注 <公开 值 = @wdPrintComments 注释 = "当前文档中的批注">
    常量 文档样式 <公开 值 = @wdPrintStyles 注释 = "当前文档中的样式">
    常量 自动图文集 <公开 值 = @wdPrintAutoTextEntries 注释 = "当前文档中的自动图文集条目">
    常量 按键分配方案 <公开 值 = @wdPrintKeyAssignments 注释 = "当前文档中的按键分配方案">
    常量 信封 <公开 值 = @wdPrintEnvelope 注释 = "信封;封皮;包裹物.">
    常量 内容加批注 <公开 值 = @wdPrintDocumentWithMarkup 注释 = "当前文档内容(包括标记)">
}

类 Word保存选项_ <折叠 折叠2 @文档 = "category = \"文件打印库.附加类\"" @常量类 = 整数>
{
    常量 提示更改 <公开 值 = @wdPromptToSaveChanges 注释 = "提示用户保存待定更改" "">
    常量 自动保存 <公开 值 = @wdSaveChanges 注释 = "自动保存待定更改,而不提示用户" "">
    常量 不保存 <公开 值 = @wdDoNotSaveChanges 注释 = "不保存待定的更改">
}

类 Word保存格式_ <折叠 折叠2 @文档 = "category = \"文件打印库.附加类\"" @常量类 = 整数>
{
    常量 文档 <公开 值 = @wdWordDocument 注释 = "Word档_格式">
    常量 原格式 <公开 值 = @wdOriginalDocumentFormat 注释 = "原始文档格式">
    常量 提示选择 <公开 值 = @wdPromptUser 注释 = "提示用户选择文档格式">
}

类 Word格式化_ <折叠 折叠2 @文档 = "category = \"文件打印库.附加类\"" @常量类 = 整数>
{
    常量 自动识别 <公开 值 = @wdOpenFormatAuto 注释 = "自动识别">
    常量 Word <公开 值 = @wdOpenFormatDocument 注释 = "Word格式">
    常量 Word模板 <公开 值 = @wdOpenFormatTemplate 注释 = "用作Word模板">
    常量 RTF <公开 值 = @wdOpenFormatRTF 注释 = "RTF格式">
    常量 TXT文本 <公开 值 = @wdOpenFormatText 注释 = "TXT文本文件">
    常量 Unicode <公开 值 = @wdOpenFormatUnicodeText 注释 = "Unicode文本格式">
    常量 兼容Word <公开 值 = @wdOpenFormatAllWord 注释 = "与Word早期版本向后兼容的Word格式">
    常量 HTML <公开 值 = @wdOpenFormatWebPages 注释 = "HTML格式">
    常量 XML <公开 值 = @wdOpenFormatXML 注释 = "XML格式">
    常量 XML文档 <公开 值 = @wdOpenFormatXMLDocument 注释 = "XML文档格式">
    常量 宏XML文档 <公开 值 = @wdOpenFormatXMLDocumentMacroEnabled 注释 = "启用了宏的XML文档格式">
    常量 XML模板 <公开 值 = @wdOpenFormatXMLTemplate 注释 = "XML模板格式">
    常量 宏XML模板 <公开 值 = @wdOpenFormatXMLTemplateMacroEnabled 注释 = "启用了宏的XML模板格式">
    常量 兼容模板 <公开 值 = @wdOpenFormatAllWordTemplates 注释 = "兼容早期版本Word模板格式">
    常量 系列化XML <公开 值 = @wdOpenFormatXMLDocumentSerialized 注释 = "打开XML文件格式保存为一个XML文件">
    常量 宏系列化XML <公开 值 = @wdOpenFormatXMLDocumentMacroEnabledSerialized 注释 = "打开XML文件格式启用了宏保存为一个XML文件">
}

