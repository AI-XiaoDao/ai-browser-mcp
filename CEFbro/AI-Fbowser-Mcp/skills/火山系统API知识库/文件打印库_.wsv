    常量 当前页面 <公开 值 = @wdPrintCurrentPage 注释 = "当前页面">
    常量 指定范围 <公开 值 = @wdPrintFromTo 注释 = "指定范围">
    常量 页面范围 <公开 值 = @wdPrintRangeOfPages 注释 = "指定的页面范围">
}

类 Word打印项目_ <折叠 折叠2 @文档 = "category = \"文件打印库.附加类\"" @常量类 = 整数>
{
    常量 文档内容 <公开 值 = @wdPrintDocumentContent 注释 = "当前文档内容">
