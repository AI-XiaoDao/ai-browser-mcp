<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <编辑时信息 = "F998A, 0, 0, 0" @文档 = "category = \"文件打印库\"">

类 文件打印类_ <公开 折叠 "">
{
    变量 Excel <类型 = Excel程_ 折叠>
    变量 工作表 <类型 = Excel表_>
    变量 工作簿 <类型 = Excel簿_>
    变量 工作簿集 <类型 = Excel簿集_>
    变量 工作表集 <类型 = Excel表集_>
    变量 Word <类型 = Word程_>
    变量 文档集 <类型 = Word档集_>
    变量 文档 <类型 = Word档_>
    变量 word初始 <类型 = 逻辑型>
    变量 excel初始 <类型 = 逻辑型>
    变量 pdf初始 <类型 = 逻辑型>
    变量 全局PDFtoPrinter来源 <类型 = 文本型>
    变量 互斥 <类型 = 许可锁类_>

    方法 初始化Excel打印_ <公开 类型 = 逻辑型 注释 = "Excel、TXT、图片均通过此命令开启打印功能。可重复执行初始" 折叠>
    参数 是否结束进程 <类型 = 逻辑型 注释 = "结束offices、wps进程进行初始化" @默认值 = 真>
    {
        如果真 (是否结束进程)
        {
            进程_结束进程_批量 ("wps.exe")
            进程_结束进程_批量 ("excel.exe")
        }
        excel初始 = 假
        如果 (Excel.获取 ())
        {
            Excel.注册事件 ()
            excel初始 = 真
            返回 (真)
        }
        否则
        {
            如果 (Excel.创建 ())
            {
                Excel.宏设置 ()
                Excel.注册事件 ()
                excel初始 = 真
                返回 (真)
            }
            否则
            {
                调试输出 ("请检查本地计算机是否安装了office Excel程序")
            }
        }
        返回 (假)
    }

    方法 初始化Word打印_ <公开 类型 = 逻辑型 注释 = "可重复执行初始" 折叠>
    参数 是否结束进程 <类型 = 逻辑型 注释 = "结束offices、wps进程进行初始化" @默认值 = 真>
    {
        如果真 (是否结束进程)
        {
            进程_结束进程_批量 ("wps.exe")
            进程_结束进程_批量 ("word.exe")
            进程_结束进程_批量 ("winword.exe")
        }
        word初始 = 假
        如果 (Word.获取 ())
        {
            Word.注册事件 ()
            word初始 = 真
            返回 (真)
        }
        否则
        {
            如果 (Word.创建 ())
            {
                Word.宏设置 ()
                Word.注册事件 ()
                word初始 = 真
                返回 (真)
            }
            否则
            {
                调试输出 ("请检查本地计算机是否安装了office Word程序")
            }
        }
        返回 (假)
    }

    方法 初始化PDF打印_ <公开 类型 = 逻辑型 注释 = "调用“PDFtoPrinter”来打印。可重复执行初始."
            注释 = "PDFtoPrinter下载：https://xf3v74qido.feishu.cn/file/M1UNbK5hLoFsGvx3l2Wc6actnIe" 折叠 折叠2>
    参数 PDFtoPrinter来源 <类型 = 文本型 注释 = "默认为软件目录下PDFtoPrinter.exe" @默认值 = "">
    {
        如果真 (文本是否为空 (PDFtoPrinter来源) == 真)
        {
            PDFtoPrinter来源 = 取运行目录 () + "PDFtoPrinter.exe"
        }
        如果真 (文件是否存在 (PDFtoPrinter来源) == 假)
        {
            调试输出 ("未找到PDFtoPrinter来源")
            pdf初始 = 假
            返回 (假)
        }
        pdf初始 = 真
        全局PDFtoPrinter来源 = PDFtoPrinter来源
        返回 (真)
    }

    方法 打印Excel_ <公开 类型 = 逻辑型 折叠>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\表格.xlsx”">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号，序号从1开始。如果值为-1时,则从起始位置开始打印" @默认值 = -1>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号，序号从1开始。如果值为-1时,则打印至最后一页" @默认值 = -1>
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 打印方向 <类型 = 整数 注释 = "1、纵向　2、横向　（默认按原文档设置的方向打印）" @默认值 = -1>
    参数 工作表索引号 <类型 = 整数 注释 = "从1开始，大于0时则按该索引号打印" @默认值 = 1>
    参数 工作表名称 <类型 = 文本型 注释 = "索引号默认0，设置本名称，则按该工作表名打印" @默认值 = "">
    {
        互斥.加锁 ()
        如果真 (文件是否存在 (文件来源) == 假 || excel初始 == 假)
        {
            调试输出 ("未找到文件或未初始化")
            互斥.解锁 ()
            返回 (假)
        }
        如果真 (工作表索引号 == 0 && 文本是否为空 (工作表名称) == 真)
        {
            调试输出 ("工作表索引号和工作表名称设置错误")
            互斥.解锁 ()
            返回 (假)
        }
        Excel.显示警告 = 假
        工作簿集 = Excel.工作簿集
        工作簿集.打开 (文件来源, , , , , , , 假)
        工作簿 = 工作簿集.取工作簿 (, 文件_取文件名 (文件来源))
        工作表集 = 工作簿.工作表集
        工作表 = 工作表集.取工作表 (工作表索引号, 工作表名称)
        工作表.激活 ()
        如果 (打印方向 != -1)
        {
            如果 (打印方向 == 1)
            {
                工作表.打印方向 = 1
            }
            否则
            {
                工作表.打印方向 = 2
            }
        }
        如果真 (文本是否为空 (指定打印机) == 假)
        {
            Excel.打印机 = 指定打印机
        }
        工作表.打印 (开始页号, 终止页号, 打印份数, , 指定打印机, , , , 假)
        Excel.活动工作簿.关闭 (, )
        互斥.解锁 ()
        返回 (真)
    }

    方法 打印图片_ <公开 类型 = 逻辑型 折叠>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\图片.jpg">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 打印方向 <类型 = 整数 注释 = "1、纵向　2、横向　（默认按原文档设置的方向打印）" @默认值 = -1>
    参数 左边 <类型 = 小数 注释 = "图片左上角相对于文档左上角的位置(以磅为单位)" @默认值 = 0>
    参数 顶边 <类型 = 小数 注释 = "图片左上角相对于文档顶部的位置(以磅为单位)" @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "图片的宽度,-1 表示保留现有文件的宽度。 给了宽度，高度会自动计算" @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "图片的高度,-1 表示保留现有文件的高度。 给了高度，宽度会自动计算" @默认值 = -1>
    {
        变量 尺寸 <类型 = 尺寸类>
        互斥.加锁 ()
        如果真 (文件是否存在 (文件来源) == 假 || excel初始 == 假)
        {
            调试输出 ("未找到文件或未初始化")
            互斥.解锁 ()
            返回 (假)
        }
        Excel.可视 = 假
        Excel.显示警告 = 假
        工作簿集 = Excel.工作簿集
        工作簿 = 工作簿集.新建工作簿 (, 1)
        如果真 (工作簿集.工作簿数量 < 1)
        {
            调试输出 ("未找到工作簿")
            互斥.解锁 ()
            返回 (假)
        }
        工作表集 = 工作簿.工作表集
        工作表 = 工作表集.取工作表 (1, )
        工作表.名称 = "Sheet1"
        尺寸 = 图片_取图片尺寸_路径 (文件来源)
        如果 (宽度 != -1 && 高度 == -1)
        {
            如果 (宽度 < 594)
            {
                高度 = (小数)图片_计算图片缩放高度 ((整数)宽度, 尺寸.高度, 尺寸.宽度)
            }
            否则
            {
                高度 = (小数)图片_计算图片缩放高度 (593, 尺寸.高度, 尺寸.宽度)
            }
        }
        否则 (宽度 == -1 && 高度 != -1)
        {
            如果 (高度 < 823)
            {
                宽度 = (小数)图片_计算图片缩放宽度 ((整数)高度, 尺寸.高度, 尺寸.宽度)
            }
            否则
            {
                宽度 = (小数)图片_计算图片缩放宽度 (822, 尺寸.高度, 尺寸.宽度)
            }
        }
        否则 (宽度 == -1 && 高度 == -1)
        {
            如果 (尺寸.宽度 + 左边 < 594 && 尺寸.高度 + 顶边 < 823)
            {
                宽度 = 尺寸.宽度
                高度 = 尺寸.高度
            }
            否则
            {
                宽度 = 尺寸.宽度 - 左边
                高度 = 尺寸.高度 - 顶边
                如果真 (宽度 > 593)
                {
                    判断循环 (宽度 > 593 - 左边)
                    {
                        高度 = 高度 - 1
                        宽度 = (小数)图片_计算图片缩放宽度 ((整数)高度, 尺寸.高度 - (整数)顶边, 尺寸.宽度 - (整数)左边)
                    }
                }
                尺寸.宽度 = (整数)宽度
                尺寸.高度 = (整数)高度
                如果真 (高度 > 822 - 高度)
                {
                    判断循环 (高度 > 822)
                    {
                        宽度 = 宽度 - 1
                        高度 = (小数)图片_计算图片缩放高度 ((整数)宽度, 尺寸.高度, 尺寸.宽度)
                    }
                }
            }
        }
        工作表.添加图片 (文件来源, 真, 真, 左边, 顶边, 宽度, 高度)
        工作表.激活 ()
        工作表.置页面边距 (1, 1, 1, 1)
        如果 (打印方向 != -1)
        {
            如果 (打印方向 == 1)
            {
                工作表.打印方向 = 1
            }
            否则
            {
                工作表.打印方向 = 2
            }
        }
        如果真 (文本是否为空 (指定打印机) == 假)
        {
            Excel.打印机 = 指定打印机
        }
        工作表.打印 (1, 1, , , , , , , 假)
        Excel.活动工作簿.关闭 (, )
        互斥.解锁 ()
        返回 (真)
    }

    方法 打印图片_预览 <公开 类型 = 逻辑型 折叠>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\图片.jpg">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 打印方向 <类型 = 整数 注释 = "1、纵向　2、横向　（默认按原文档设置的方向打印）" @默认值 = -1>
    参数 左边 <类型 = 小数 注释 = "图片左上角相对于文档左上角的位置(以磅为单位)" @默认值 = 10>
    参数 顶边 <类型 = 小数 注释 = "图片左上角相对于文档顶部的位置(以磅为单位)" @默认值 = 10>
    参数 宽度 <类型 = 小数 注释 = "图片的宽度,默认-1表示按纸张大小缩放至最大宽度(图片尺寸不足则按图片原尺寸)。给了宽度，高度会自动计算" @默认值 = -1>
    参数 高度 <类型 = 小数 注释 = "图片的高度,默认-1表示按纸张大小缩放至最大高度(图片尺寸不足则按图片原尺寸)。给了高度，宽度会自动计算" @默认值 = -1>
    {
        变量 尺寸 <类型 = 尺寸类>
        互斥.加锁 ()
        如果真 (文件是否存在 (文件来源) == 假 || excel初始 == 假)
        {
            调试输出 ("未找到文件或未初始化")
            互斥.解锁 ()
            返回 (假)
            判断窗口是否响应_ ()
        }
        Excel.显示警告 = 假
        工作簿集 = Excel.工作簿集
        工作簿 = 工作簿集.新建工作簿 (, 1)
        如果真 (工作簿集.工作簿数量 < 1)
        {
            调试输出 ("未找到工作簿")
            互斥.解锁 ()
            返回 (假)
        }
        工作表集 = 工作簿.工作表集
        工作表 = 工作表集.取工作表 (1, )
        工作表.名称 = "Sheet1"
        尺寸 = 图片_取图片尺寸_路径 (文件来源)
        如果 (宽度 != -1 && 高度 == -1)
        {
            如果 (宽度 < 594)
            {
                高度 = (小数)图片_计算图片缩放高度 ((整数)宽度, 尺寸.高度, 尺寸.宽度)
            }
            否则
            {
                高度 = (小数)图片_计算图片缩放高度 (593, 尺寸.高度, 尺寸.宽度)
            }
        }
        否则 (宽度 == -1 && 高度 != -1)
        {
            如果 (高度 < 823)
            {
                宽度 = (小数)图片_计算图片缩放宽度 ((整数)高度, 尺寸.高度, 尺寸.宽度)
            }
            否则
            {
                宽度 = (小数)图片_计算图片缩放宽度 (822, 尺寸.高度, 尺寸.宽度)
            }
        }
        否则 (宽度 == -1 && 高度 == -1)
        {
            如果 (尺寸.宽度 + 左边 < 594 && 尺寸.高度 + 顶边 < 823)
            {
                宽度 = 尺寸.宽度
                高度 = 尺寸.高度
            }
            否则
            {
                宽度 = 尺寸.宽度 - 左边
                高度 = 尺寸.高度 - 顶边
                如果真 (宽度 > 593)
                {
                    判断循环 (宽度 > 593 - 左边)
                    {
                        高度 = 高度 - 1
                        宽度 = (小数)图片_计算图片缩放宽度 ((整数)高度, 尺寸.高度 - (整数)顶边, 尺寸.宽度 - (整数)左边)
                    }
                }
                尺寸.宽度 = (整数)宽度
                尺寸.高度 = (整数)高度
                如果真 (高度 > 822 - 高度)
                {
                    判断循环 (高度 > 822)
                    {
                        宽度 = 宽度 - 1
                        高度 = (小数)图片_计算图片缩放高度 ((整数)宽度, 尺寸.高度, 尺寸.宽度)
                    }
                }
            }
        }
        工作表.添加图片 (文件来源, 真, 真, 左边, 顶边, 宽度, 高度)
        工作表.激活 ()
        工作表.置页面边距 (1, 1, 1, 1)
        如果 (打印方向 != -1)
        {
            如果 (打印方向 == 1)
            {
                工作表.打印方向 = 1
            }
            否则
            {
                工作表.打印方向 = 2
            }
        }
        如果真 (文本是否为空 (指定打印机) == 假)
        {
            Excel.打印机 = 指定打印机
        }
        Excel.可视 = 真
        互斥.解锁 ()
        返回 (真)
    }

    方法 打印TXT_ <公开 类型 = 逻辑型 折叠>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\文档.txt”">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 打印方向 <类型 = 整数 注释 = "1、纵向　2、横向　（默认按原文档设置的方向打印）" @默认值 = -1>
    {
        返回 (打印Excel_ (文件来源, 指定打印机, , , 打印份数, 打印方向))
    }

    方法 打印Word_ <公开 类型 = 逻辑型 折叠>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\文档.doc”">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 打印范围 <类型 = Word打印范围_ @默认值 = Word打印范围_.整个文档>
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号，序号从1开始。如果值为-1时,则从起始位置开始打印." 注释 = "当“打印范围”设置为“指定范围”才生效" @默认值 = -1>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号，序号从1开始。如果值为-1时,则打印至最后一页." 注释 = "当“打印范围”设置为“指定范围”才生效" @默认值 = -1>
    参数 打印页码 <类型 = 文本型 注释 = "例如,“2,6-10”表示打印第2页以及第6至第10页." 注释 = "当“打印范围”设置为“当前页面”或“页面范围”时才生效" @默认值 = "">
    参数 页面类型 <类型 = 整数 注释 = "要打印的页面类型：0、所有页　1、只有奇数页　2、只有偶数页" @默认值 = 0>
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 打印方向 <类型 = 整数 注释 = "1、纵向　2、横向　（默认按原文档设置的方向打印）" @默认值 = -1>
    参数 缩放宽度 <类型 = 整数 注释 = "指定将待打印页面缩放到的宽度，以缇为单位(20缇=1磅;72磅=1英寸)" @默认值 = 0>
    参数 缩放高度 <类型 = 整数 注释 = "指定将打印页面缩放到的高度，以缇为单位(20缇=1磅;72磅=1英寸)" @默认值 = 0>
    {
        互斥.加锁 ()
        如果真 (文件是否存在 (文件来源) == 假 || word初始 == 假)
        {
            调试输出 ("未找到文件或未初始化")
            互斥.解锁 ()
            返回 (假)
        }
        Word.可视 = 假
        Word.显示警告 = Word警告_.不显示
        文档集 = Word.文档集
        文档集.打开 (文件来源, , , , , , , , , , , 假)
        文档 = 文档集.取文档 (, 文件_取文件名 (文件来源))
        文档.激活 ()
        文档 = Word.活动文档
        如果 (打印方向 != -1)
        {
            如果 (打印方向 == 0)
            {
                文档.页面方向 = 0
            }
            否则
            {
                文档.页面方向 = 1
            }
        }
        Word.打印 (, , 打印范围, 开始页号, 终止页号, , 打印份数, 打印页码, 页面类型, , , , , , , 缩放宽度, 缩放高度)
        文档集.关闭 ()
        互斥.解锁 ()
        返回 (真)
    }

    方法 打印PDF_ <公开 类型 = 逻辑型 注释 = "调用“PDFtoPrinter”来打印."
            注释 = "PDFtoPrinter下载：https://xf3v74qido.feishu.cn/file/M1UNbK5hLoFsGvx3l2Wc6actnIe" 折叠 折叠2>
    参数 文件来源 <类型 = 文本型 注释 = "例如：“C:\\\\文件.pdf">
    参数 指定打印机 <类型 = 文本型 注释 = "留空按默认打印机打印，不留空则按指定打印机" @默认值 = "">
    参数 打印页码 <类型 = 文本型 注释 = "例如,“2,6-10”表示打印第2页以及第6至第10页" @默认值 = "1">
    参数 打印份数 <类型 = 整数 注释 = "打印份数。默认只打印一份" @默认值 = -1>
    参数 密码 <类型 = 文本型 @默认值 = "">
    {
        变量 打印参数 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        互斥.加锁 ()
        如果真 (文件是否存在 (文件来源) == 假 || pdf初始 == 假)
        {
            调试输出 ("未找到文件或未初始化")
            互斥.解锁 ()
            返回 (假)
        }
        如果真 (文本是否为空 (指定打印机) == 真)
        {
            指定打印机 = 打印机_取默认打印机 ()
        }
        加入文本 (打印参数, 全局PDFtoPrinter来源 + " /s " + 文件来源 + " pages=" + 打印页码 + " " + "\"" + 指定打印机 + "\"")
        如果真 (打印份数 != -1)
        {
            加入文本 (打印参数, " copies=" + 到文本 (打印份数))
        }
        如果真 (文本是否为空 (密码) == 假)
        {
            加入文本 (打印参数, " /p:password")
        }
        结果 = 运行 (打印参数, 真, 程序窗口显示方式.隐藏窗口)
        互斥.解锁 ()
        返回 (结果)
    }
}

# //====

类 Excel程_ <折叠 折叠2 @文档 = "category = \"文件打印库.附加类\"" @视窗.外部头文件 = "..\\..\\sys\\office\\Excel2021\\lib\\Excelconstant.h">
{
    变量 Application对象 <类型 = COM对象类>
    变量 Application事件 <类型 = COM对象事件类>

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建Excel对象" 返回值注释 = "成功返回真." 返回值注释 = "失败返回假,没有安装 Microsoft Office Excel 程序." 折叠 "">
    {
        返回 (Application对象.创建 ("Excel.Application", ""))
    }

    方法 获取 <公开 类型 = 逻辑型 注释 = "获取当前操作系统中已经存在的\"Excel对象\"填入本对象中,本对象中的原有内容将被覆盖." 折叠>
    {
        返回 (Application对象.获取 ("Excel.Application"))
    }

    方法 注册事件 <公开 类型 = 逻辑型 注释 = "使用定义事件前需先运行一次注册事件,在\"创建\"方法成功后执行." 折叠>
    {
        返回 (Application事件.挂接 (Application对象, "{00024413-0000-0000-C000-000000000046}"))
    }

    方法 版本 <公开 属性读 类型 = 文本型 注释 = "Excel 版本号,与Office版本对应如下:" 注释 = "1.0----Office 1.0" 注释 = "5.0----Office 4.2."
            注释 = "7.0----Office 95." 注释 = "8.0----Office 97." 注释 = "9.0----Office 2000." 注释 = "10.0----Office XP/2002."
            注释 = "11.0----Office XP/2003." 注释 = "12.0----Office XP/2007." 注释 = "14.0----Office 2010." 注释 = "15.0----Office 2013."
            注释 = "16.0----Office 2016." 注释 = "16.0----Office 2021." 折叠 折叠2 "">
    {
        返回 (Application对象.读无参数属性 ("Version", 文本型))
    }

    方法 宏设置 <公开 注释 = "设置是否启用宏并信任VBA工程对象模型的访问,需要在文档未打开前使用." 折叠>
    参数 启用宏方式 <类型 = 整数 注释 = "1.启用所有宏." 注释 = "2.通过通知禁用VBA宏." 注释 = "3.禁用无数字签署的VBA宏." 注释 = "4.不提供通知,禁用VBA宏." 折叠2 @默认值 = 1>
    参数 兼容 <类型 = 逻辑型 注释 = "启用VBA宏时启用Excel4.0宏" @默认值 = 真>
    参数 信任 <类型 = 逻辑型 注释 = "是否信任对VBA工程对象模型的访问" @默认值 = 真>
    {
        写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Office\\" + 版本 + "\\Excel\\Security\\VBAWarnings", 启用宏方式)  // 启用宏方式
        写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Office\\" + 版本 + "\\Excel\\Security\\XL4MacroWarningFollowVBA", 选择 (兼容, 1, 0))  // 启用VBA宏时启用Excel4.0宏
        写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Office\\" + 版本 + "\\Excel\\Security\\AccessVBOM", 选择 (信任, 1, 0))  // 是否信任对VBA工程对象模型的访问
    }

    方法 显示警告 <公开 属性写 注释 = "设置程序是否显示特定的警告和消息" 折叠>
    参数 是否显示 <类型 = 逻辑型>
    {
        Application对象.写属性 ("DisplayAlerts", 是否显示)
    }

    方法 工作簿集 <公开 属性读 类型 = Excel簿集_ 注释 = "返回一个\"工作簿\"集合,该集合代表所有打开的工作簿.此为只读属性." 折叠 "">
    {
        变量 局_工作簿集 <类型 = Excel簿集_>
        局_工作簿集.置对象 (Application对象.读无参数对象型属性 ("Workbooks", COM对象类))
        返回 (局_工作簿集)
    }

    方法 活动工作簿 <公开 属性读 类型 = Excel簿_ 注释 = "返回一个\"Excel簿_\"对象,该对象代表活动窗口中位于(窗口顶部的工作簿).如果未打开任何窗口,或者\"信息\"窗口或\"剪贴板\"窗口为活动窗口,则返回空对象."
            折叠>
    {
        变量 局_工作簿 <类型 = Excel簿_>
        局_工作簿.置对象 (Application对象.读无参数对象型属性 ("ActiveWorkbook", COM对象类))
        返回 (局_工作簿)
    }

    方法 可视 <公开 属性写 注释 = "设置对象是否可见" 折叠>
    参数 所欲设置的值 <类型 = 逻辑型>
    {
        Application对象.写属性 ("Visible", 所欲设置的值)
    }

    方法 退出 <公开 注释 = "退出Excel应用程序." 折叠>
    {
        Application对象.无参数及返回值方法 ("Quit")
    }

    方法 打印机 <公开 属性读 类型 = 文本型 注释 = "返回活动打印机的名称" 折叠>
    {
        返回 (Application对象.读无参数属性 ("ActivePrinter", 文本型))
    }

    方法 打印机 <公开 属性写 注释 = "设置活动打印机的名称.格式是\"[打印机名] 在 [端口]:\",端口名后需要冒号\":\",如\"Canon Printer 在 Ne03:\".其中\"在\"英文系统中则为\"on\"." 折叠>
    参数 欲设置的数值 <类型 = 文本型>
    {
        Application对象.写属性 ("ActivePrinter", 欲设置的数值)
    }
}

类 Excel簿集_ <折叠 @文档 = "category = \"文件打印库.附加类\"">
{
    变量 Workbooks对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." 折叠 "">
    参数 集合对象 <类型 = COM对象类 注释 = "Workbooks集合">
    {
        Workbooks对象 = 集合对象
        返回 (Workbooks对象.是否为空 () == 假)
    }

    方法 取工作簿 <公开 类型 = Excel簿_ 注释 = "从工作簿集合中返回一个工作簿" 折叠>
    参数 索引号 <类型 = 整数 注释 = "二选一,从1开始,对象在工作簿集合的索引号.为0时.忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.当\"索引号\"不为0时.忽略该参数." @默认值 = "">
    {
        变量 局_WorkBook <类型 = Excel簿_>
        如果 (索引号 == 0)
        {
            如果 (名称 != "")  // 名称不为空时根据名称取出工作簿
            {
                局_WorkBook.置对象 (Workbooks对象.读对象型属性 ("Item", COM对象类, 名称))  // 使用名称
            }
        }
        否则
        {
            局_WorkBook.置对象 (Workbooks对象.读对象型属性 ("Item", COM对象类, 索引号))  // 使用索引号
        }
        返回 (局_WorkBook)
    }

    方法 打开 <公开 注释 = "打开一个工作簿" 折叠 "">
    参数 文件名 <类型 = 文本型 注释 = "要打开的工作簿的文件名">
    参数 只读模式 <类型 = 逻辑型 注释 = "如果为真,则以只读模式打开工作簿." @默认值 = 假>
    参数 密码 <类型 = 文本型 注释 = "包含打开受保护工作簿所需密码的字符串.如果省略此参数并且工作簿需要密码,则会提示用户输入密码." @默认值 = "">
    参数 写权限密码 <类型 = 文本型 注释 = "包含写入写保护的工作簿所需密码的字符串.如果省略此参数并且工作簿需要密码,则将提示用户输入密码." @默认值 = "">
    参数 显示建议消息 <类型 = 逻辑型 注释 = "当该工作簿以建议只读选项保存时,如果该选项为真,则不让程序显示只读的建议消息." @默认值 = 假>
    参数 分隔符 <类型 = 整数 注释 = "1 TAB;2 逗号;3 空格;4 分号;5 不使用分隔符;6 自定义.此参数指定要用作分隔符的字符." @默认值 = 5>
    参数 自定义分隔符 <类型 = 文本型 注释 = "如果文件是文本文件且分隔符参数为6自定义时,此参数指定要用作分隔符的字符.如分隔符字符串长度大于1,只使用字符串的第一个字符." @默认值 = "">
    参数 可视 <类型 = 逻辑型 注释 = "如果版本号4.0程序,则此参数为真时可打开该外接程序以使其成为可见窗口.如果此参数为假或被省略,则以隐藏方式打开外接程序,并且无法设为可见.此选项不适用于在版本号5.0或更高版本中创建的加载项."
            @默认值 = 假>
    参数 请求通知 <类型 = 逻辑型 注释 = "当文件不能以可读写模式打开时,如果此参数为真,则可将该文件添加到文件通知列表.程序将以只读模式打开该文件并轮询文件通知列表,并在文件可用时向用户发出通知.如果此参数为假或省略,则不会请求通知."
            @默认值 = 假>
    参数 添加到使用列表 <类型 = 逻辑型 注释 = "如果为真,则将该工作簿添加到最近使用的文件列表中." @默认值 = 假>
    参数 打开方式 <类型 = Excel打开方式_ 注释 = "Excel打开方式_.*" @默认值 = Excel打开方式_.正常>
    {
        变量 COM变体 <类型 = COM变体型>
        Workbooks对象.无返回值方法 ("Open", 文件名, 0, 只读模式, 分隔符, 密码, 写权限密码, 显示建议消息, COM变体, 自定义分隔符, 可视, 请求通知, COM变体, 添加到使用列表, 假, 打开方式)
    }

    方法 新建工作簿 <公开 类型 = Excel簿_ 注释 = "新建一个工作簿.新工作簿将成为活动工作簿." 折叠>
    参数 模板 <类型 = 文本型 注释 = "确定如何创建新工作簿.如果此参数为指定现有Excel文件名的字符串,那么创建新工作簿将以该指定的文件作为模板." 注释 = "如果省略此参数,将根据工作表数目设置添加对应空白工作表数量."
            @默认值 = "">
    参数 工作表数目 <类型 = 整数 注释 = "自动插入到新工作簿中的工作表数目" @默认值 = 1>
    {
        变量 局_工作簿 <类型 = Excel簿_>
        Workbooks对象.读无参数属性 ("Parent", COM对象类).写属性 ("SheetsInNewWorkbook", 工作表数目)
        局_工作簿.置对象 (Workbooks对象.对象型方法 ("Add", COM对象类, 模板))
        返回 (局_工作簿)
    }

    方法 工作簿数量 <公开 属性读 类型 = 整数 注释 = "返回集合中对象的数量" 折叠>
    {
        返回 (Workbooks对象.读无参数属性 ("Count", 整数))
    }
}

类 Excel簿_ <折叠 @文档 = "category = \"文件打印库.附加类\"">
{
    变量 Workbook对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." 折叠>
