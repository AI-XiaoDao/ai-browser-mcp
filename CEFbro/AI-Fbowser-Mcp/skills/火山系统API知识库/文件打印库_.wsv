    }

    方法 关闭 <公开 注释 = "关闭对象" 折叠>
    参数 保存更改 <类型 = 逻辑型 注释 = "如果工作簿无更改,则忽略该参数.如果工作簿存在更改且其在其他打开的窗口中显示,则忽略此参数." 注释 = "如果工作簿中有改动且工作簿未显示在任何其他打开的窗口中,则由此参数指定是否应保存更改."
            注释 = "如果设为真,则保存对工作簿所做的更改." 注释 = "如果还没有与工作簿关联的文件名,则使用保存文件名.如果省略保存文件名,则要求用户提供文件名." @默认值 = 假>
    参数 保存文件名 <类型 = 文本型 注释 = "保存此文件名下的更改" @默认值 = "">
    {
        Workbook对象.无返回值方法 ("Close", 保存更改, 保存文件名)
    }

    方法 工作表集 <公开 属性读 类型 = Excel表集_ 注释 = "返回一个\"Excel表集_\"类,该集合代表指定工作簿中所有的工作表." 折叠>
    {
        变量 局_工作表集 <类型 = Excel表集_>
        局_工作表集.置对象 (Workbook对象.读无参数对象型属性 ("Sheets", COM对象类))
        返回 (局_工作表集)
    }
}

类 Excel表集_ <折叠 @文档 = "category = \"文件打印库.附加类\"">
{
    变量 Sheets对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." 折叠>
