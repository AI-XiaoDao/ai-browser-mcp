    方法 生成数据2 <折叠>
    参数 条码内容 <类型 = 文本型>
    参数 显示画板 <类型 = 画板>
    参数 条码格式 <类型 = 整数 @默认值 = 1>
    参数 背景色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 条码颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 线条高度 <类型 = 整数 @默认值 = 80>
    参数 左边位 <类型 = 整数 @默认值 = 5>
    参数 顶边位 <类型 = 整数 @默认值 = 10>
    参数 条码宽度 <类型 = 整数 注释 = "-1为默认宽度，此值非精确值" @默认值 = -1>
    参数 字体 <类型 = 文本型 @默认值 = "宋体, 11, 1">
    参数 画板跟随条码大小 <类型 = 逻辑型 @默认值 = 假>
    参数 数字居中坐标 <类型 = 整数 注释 = "条码数字居中坐标值" @默认值 = -1>
    {
        变量 格式化条码 <类型 = 文本型>
        变量 条码长度 <类型 = 整数>
        变量 宽度系数 <类型 = 小数>
        变量 系数 <类型 = 小数>
        变量 系数2 <类型 = 小数>
        变量 i <类型 = 整数>
        显示画板.自动重画 = 真
        显示画板.字体 = 字体
        条码内容 = 到半角 (条码内容)
        循环 (, 取文本长度 (条码内容), i)
        {
            如果真 (取代码_ (条码内容, i) < 0)
            {
                显示画板.写文本行 ("条码不支持中文")
                返回
            }
        }
        如果 (条码格式 < 0 || 条码格式 > 2)
        {
            条码格式 = 1
        }
        如果 (条码格式 == 2)
        {
            如果真 (到文本 ((变整数)文本到长整数 (条码内容)) != 条码内容)
            {
                显示画板.写文本行 ("code128C 格式必须为纯数字")
                返回
            }
            如果真 (取文本长度 (条码内容) % 2 != 0)
            {
                显示画板.写文本行 ("code128C格式，长度必须是偶数")
            }
        }
        如果 (条码格式 == 1)
        {
            循环 (, 取文本长度 (条码内容), i)
            {
                如果真 (取代码_ (取文本中间 (条码内容, i, 1), ) < 32 || 取代码_ (取文本中间 (条码内容, i, 1), ) > 126)
                {
                    显示画板.写文本行 ("超出 code128B 编码范围")
                    返回
                }
            }
        }
        如果 (条码格式 == 0)
        {
            循环 (, 取文本长度 (条码内容), i)
            {
                如果真 (取代码_ (取文本中间 (条码内容, i, 1), ) < 32 || 取代码_ (取文本中间 (条码内容, i, 1), ) > 95)
                {
                    显示画板.写文本行 ("超出code128A 编码范围")
                    返回
                }
            }
        }
        显示画板.刷子颜色 = 条码颜色
        显示画板.画板背景色 = 背景色
        格式化条码 = 格式化条码 (条码内容, 条码格式)
        条码长度 = 取文本长度 (格式化条码)
        如果 (条码宽度 == -1)
        {
            如果 (条码格式 == 2)
            {
                宽度系数 = 207 / 条码长度
            }
            否则
            {
                宽度系数 = 334 / 条码长度
            }
        }
        否则
        {
            宽度系数 = (条码宽度 + 70) / 条码长度
        }
        循环 (, 取文本长度 (格式化条码), i)
        {
            如果真 (取文本中间 (格式化条码, i, 1) == "b")
            {
                系数 = (i - 1) * 宽度系数
                系数2 = i * 宽度系数
                // 显示画板.画矩形 ((整数)系数 + 左边位, 顶边位, (整数)系数2 + 左边位, 顶边位 + 线条高度)
                显示画板.填充矩形 ((整数)系数 + 左边位, 顶边位, (整数)系数2 + 左边位, 顶边位 + 线条高度)
            }
        }
        如果 (数字居中坐标 == -1)
        {
            显示画板.定位写出 (左边位 + 10, 顶边位 + 线条高度, 条码内容)
        }
        否则
        {
            显示画板.定位写出 (左边位 + 数字居中坐标, 顶边位 + 线条高度, 条码内容)
        }
        条宽 = (整数)系数2 + 左边位 + 5
        条高 = 顶边位 + 线条高度 + 20
        如果真 (画板跟随条码大小 == 真)
        {
            显示画板.宽度 = 条宽
            显示画板.高度 = 条高
        }
        如果真 (单宽2 == 0)
        {
            单宽2 = 条宽
            条高2 = 条高
        }
        后台画板 = 显示画板
    }

    方法 格式化条码 <类型 = 文本型 折叠>
    参数 欲编码文本 <类型 = 文本型>
    参数 条码格式 <类型 = 整数>
    {
        变量 完整条码编码 <类型 = 文本型>
        变量 编码信息序号 <类型 = 整数>
        变量 校验码编码 <类型 = 文本型>
        变量 格式化条码 <类型 = 文本型>
        变量 内容编码 <类型 = 文本型>
        变量 编码位数 <类型 = 整数>
        变量 开始码 <类型 = 文本型>
        变量 结束码 <类型 = 文本型>
        变量 校验码 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 i <类型 = 整数>
        如果 (条码格式 == 1)
        {
            开始码 = "211214"
            结束码 = "2331112"
            校验码 = 104
            编码位数 = 1
        }
        否则 (条码格式 == 2)
        {
            开始码 = "211232"
            结束码 = "2331112"
            校验码 = 105
            编码位数 = 2
        }
        否则
        {
            开始码 = "211412"
            结束码 = "2331112"
            校验码 = 103
            编码位数 = 1
        }
        长度 = 取文本长度 (欲编码文本)
        循环 (, 长度 / 编码位数, i)
        {
            编码信息序号 = 编码序号 (取文本中间 (欲编码文本, i * 编码位数, 编码位数), 条码格式)
            如果真 (编码信息序号 != 0)
            {
                内容编码 = 内容编码 + 编码组 [编码信息序号 - 1]
                校验码 = 校验码 + (i + 1) * 文本到整数 (序号组 [编码信息序号 - 1])
            }
        }
        校验码 = 校验码 % 103
        校验码编码 = 编码组 [校验码]
        完整条码编码 = 开始码 + 内容编码 + 校验码编码 + 结束码
        循环 (, 取文本长度 (完整条码编码), i)
        {
            循环 (, 文本到整数 (取文本中间 (完整条码编码, i, 1)), )
            {
                如果 ((i + 1) % 2 == 1)
                {
                    格式化条码 = 格式化条码 + "b"
                }
                否则
                {
                    格式化条码 = 格式化条码 + "w"
                }
            }
        }
        返回 (格式化条码)
    }

    方法 编码序号 <类型 = 整数 折叠>
    参数 欲获取编码文本 <类型 = 文本型>
    参数 条码格式 <类型 = 整数>
    {
        变量 i <类型 = 整数>
        循环 (, 107, i)
        {
            如果 (条码格式 == 0)
            {
                如果真 (codeA组 [i] == 欲获取编码文本)
                {
                    返回 (i + 1)
                }
            }
            否则 (条码格式 == 1)
            {
                如果真 (codeB组 [i] == 欲获取编码文本)
                {
                    返回 (i + 1)
                }
            }
            否则 (条码格式 == 2)
            {
                如果真 (codeC组 [i] == 欲获取编码文本)
                {
                    返回 (i + 1)
                }
            }
        }
        返回 (0)


    }
}
