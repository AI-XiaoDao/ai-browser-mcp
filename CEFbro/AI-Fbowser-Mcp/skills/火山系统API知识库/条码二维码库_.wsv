    方法 生成条形码_批量2 <公开 折叠>
    参数 条码内容 <类型 = 文本数组类>
    参数 显示画板 <类型 = 画板>
    参数 条码格式 <类型 = 整数 注释 = "0、code128A编码　1、code128B编码　2、code128C编码  ；1支持字母" @默认值 = 1>
    参数 背景色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 条码颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 线条高度 <类型 = 整数 @默认值 = 80>
    参数 左边位 <类型 = 整数 @默认值 = 5>
    参数 顶边位 <类型 = 整数 @默认值 = 10>
    参数 条码宽度 <类型 = 整数 注释 = "-1为默认宽度，此值非精确值" @默认值 = -1>
    参数 字体 <类型 = 文本型 注释 = "例如：\"宋体, 11, 1, 0, 0, 0, 0\" ；11表示字体大小，1表示加粗" @默认值 = "宋体, 11, 1">
    参数 画板跟随条码大小 <类型 = 逻辑型 @默认值 = 假>
    参数 数字居中坐标 <类型 = 整数 注释 = "条码数字居中坐标值" @默认值 = -1>
    {
        变量 临时画板 <类型 = 画板>
        变量 最终高度 <类型 = 整数>
        变量 左边值 <类型 = 整数>
        变量 顶边值 <类型 = 整数>
        变量 结果 <类型 = 小数>
        变量 行数 <类型 = 整数>
        变量 列数 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        变量 i3 <类型 = 整数>
        连续赋值 (0, 单宽2, 条高2)
        临时画板.清除 ()
        如果真 (条码内容.取成员数 () > 0)
        {
            生成数据2 (条码内容.取成员 (0), 临时画板, 条码格式, 背景色, 条码颜色, 线条高度, 左边位, 顶边位, 条码宽度, 字体, 假, 数字居中坐标)
        }
        显示画板.清除 ()
        后台画板.清除 ()
        列数 = 显示画板.宽度 / 单宽2
        循环 (, 99999, i)
        {
            顶边值 = (条高2 + 20) * i + 顶边位
            如果真 (i == 0)
            {
                顶边值 = 顶边位
            }
            循环 (, 列数, i2)
            {
                如果真 (i3 >= 条码内容.取成员数 ())
                {
                    跳出循环
                }
                左边值 = 单宽2 * i2 + 12 + 左边位
                如果 (左边值 < 11)
                {
                    左边值 = 左边位
                }
                否则
                {
                    左边值 = 左边值 + 12 * i2 - 左边位 + 左边位
                }
                生成数据2 (条码内容.取成员 (i3), 显示画板, 条码格式, 背景色, 条码颜色, 线条高度, 左边值, 顶边值, 条码宽度, 字体, 假, 数字居中坐标)
                i3 = i3 + 1
                最终高度 = 顶边值 + 顶边位
            }
        }
        结果 = (小数)条码内容.取成员数 () / 列数
        如果 (结果 > 条码内容.取成员数 () / 列数)
        {
            行数 = (整数)结果 + 1
        }
        否则
        {
            行数 = (整数)结果
        }
        如果真 (画板跟随条码大小 == 真)
        {
            显示画板.高度 = 最终高度 + 条高2
            后台画板.高度 = 最终高度 + 条高2
        }
    }

