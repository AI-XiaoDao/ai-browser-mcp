    方法 注册表写字节集_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 "">
    参数 键值 <类型 = 字节集类 "">
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    参数 键值类型 <类型 = 整数 注释 = "可调用常量值，如：“注册表键值类型常量.REG_DWORD”."
            注释 = "0、REG_NONE 1、REG_SZ 2、REG_EXPAND_SZ 3、REG_BINARY 4、REG_DWORD 5、REG_DWORD_BIG_ENDIAN"
            注释 = "6、REG_LINK 7、REG_MULTI_SZ 8、REG_RESOURCE_LIST 9、REG_FULL_RESOURCE_DESCRIPTOR"
            注释 = "10、REG_RESOURCE_REQUIREMENTS_LIST 11、REG_QWORD" @默认值 = 4 "">
    {
        变量 临时节点 <类型 = 变整数>
        变量 lpData <类型 = 变整数>
        变量 cbData <类型 = 整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if (!@<临时节点>) return false;
        @ DWORD flag = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_CREATE_SUB_KEY | KEY_WRITE, &临时节点);
        @ if (lRes = 2)
        @ lRes = RegCreateKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, NULL, REG_OPTION_NON_VOLATILE, flag | KEY_CREATE_SUB_KEY | KEY_WRITE, NULL, &临时节点, NULL);
        @ if (lRes != ERROR_SUCCESS) return false;
        lpData = 取字节集指针 (键值)
        cbData = 取字节集长度 (键值)
        @ lRes = RegSetValueExW(临时节点, @<键名称>.GetText(), 0, @<键值类型>, (LPBYTE)@<lpData>, @<cbData>);
        @ RegCloseKey(临时节点);
        @ return (lRes == ERROR_SUCCESS);
    }

    方法 注册表导出_ <公开 静态 类型 = 逻辑型
            注释 = "注册表导出_ (\"C:\\\\注册表.reg\", \"HKEY_LOCAL_MACHINE\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Run\")" 折叠>
    参数 保存路径 <类型 = 文本型>
    参数 全路径注册项名 <类型 = 文本型>
    {
        返回 (运行 ("regedit /e " + 保存路径 + " " + 全路径注册项名, 假, ))
    }

    方法 注册表导入_ <公开 静态 类型 = 逻辑型 折叠>
    参数 欲导入的注册表文件 <类型 = 文本型>
    {
        如果真 (文件是否存在 (欲导入的注册表文件) == 假)
        {
            返回 (假)
        }
        返回 (运行 ("regedit /s " + 欲导入的注册表文件, 假, ))
    }

    方法 注册表创建项_ <公开 静态 类型 = 逻辑型 注释 = "例如：注册表创建项_ (2, \"主项\\\\子项\") ；相当于：[HKEY_CURRENT_USER\\主项\\子项]" 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 项名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @  DWORD dwOperat = REG_CREATED_NEW_KEY;
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @  HKEY  hKey;
        @  LONG  lResult  = RegCreateKeyEx((HKEY)@<临时节点>,@<项名称>,NULL,NULL,NULL,option,NULL,&hKey,&dwOperat); 
        @  if(lResult != ERROR_SUCCESS)
        @  {
        @   RegCloseKey(hKey);
        @   SetLastError(lResult);
        @   return false;
        @  }
        @  RegCloseKey(hKey);
        @ return true;
    }

    方法 注册表枚举键名_ <公开 静态 注释 = "例如：" 注释 = "注册表枚举键名_ (2, \"主项\", 名称变量)  ，就会得到主项下的\"子项\"和\"子项2\"两个名称  ;"
            注释 = "[HKEY_CURRENT_USER\\主项\\子项]" 注释 = "[HKEY_CURRENT_USER\\主项\\子项2]" 折叠 折叠2>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 返回的键名组 <类型 = 文本数组类>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        返回的键名组.删除所有成员 ()
        @ HKEY hKey = (HKEY)@<临时节点>;
        @ LPCTSTR lpsubkey = (LPCTSTR)@<键路径>;
        @ #define MAX_KEY_LENGTH 255
        @ #define MAX_VALUE_NAME 16383
        @     HKEY hTestKey;
        @     REGSAM  option = KEY_READ;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @     if (RegOpenKeyEx(hKey, lpsubkey, 0, option, &hTestKey) != ERROR_SUCCESS) return;
        @     TCHAR    achKey[MAX_KEY_LENGTH];
        @     DWORD    cbName;
        @     TCHAR    achClass[MAX_PATH] = TEXT("");
        @     DWORD    cchClassName = MAX_PATH;
        @     DWORD    cSubKeys = 0;
        @     DWORD    cbMaxSubKey; 
        @     DWORD    cchMaxClass;
        @     DWORD    cValues;
        @     DWORD    cchMaxValue;
        @     DWORD    cbMaxValueData;
        @     DWORD    cbSecurityDescriptor;
        @     FILETIME ftLastWriteTime;
        @     DWORD i, retCode;
        @     DWORD cchValue = MAX_VALUE_NAME;
        @     retCode = RegQueryInfoKey(
        @         hTestKey,
        @         achClass,
        @         &cchClassName,
        @         NULL,
        @         &cSubKeys,
        @         &cbMaxSubKey,
        @         &cchMaxClass,
        @         &cValues,
        @         &cchMaxValue,
        @         &cbMaxValueData,
        @         &cbSecurityDescriptor,
        @         &ftLastWriteTime);
        @     if (cSubKeys)
        @     {
        @         for (i = 0; i < cSubKeys; i++)
        @         {
        @             cbName = MAX_KEY_LENGTH;
        @             retCode = RegEnumKeyEx(hTestKey, i,
        @                 achKey,
        @                 &cbName,
        @                 NULL,
        @                 NULL,
        @                 NULL,
        @                 &ftLastWriteTime);
        @             if (retCode == ERROR_SUCCESS)
        @             {
        @                 @<返回的键名组>.data ().Add2 (achKey);
        @             }
        @         }
        @     }
        @ 
        @     RegCloseKey(hTestKey);
    }

    方法 注册表枚举键值名_ <公开 静态 注释 = "例如：" 注释 = "注册表枚举键值名_ (2, \"主项\\\\子项\", 名称变量)  ，就会得到子项下的\"测试1\"和\"测试2\"两个名称  ;"
            注释 = "[HKEY_CURRENT_USER\\主项\\子项]" 注释 = "\"测试1\"=\"内容1\"" 注释 = "\"测试2\"=\"内容2\"" 折叠 折叠2>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 返回的值名称组 <类型 = 文本数组类>
    参数 返回的值类型组 <类型 = 整数数组类 @默认值 = 空对象>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        返回的值名称组.删除所有成员 ()
        如果 (返回的值类型组 != 空对象)
        {
            返回的值类型组.删除所有成员 ()
        }
        @ HKEY hKey = (HKEY)@<临时节点>;
        @ LPCTSTR lpsubkey = (LPCTSTR)@<键路径>;
        @ #define MAX_KEY_LENGTH 255
        @ #define MAX_VALUE_NAME 16383
        @     HKEY hTestKey;
        @     REGSAM  option = KEY_READ;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @     if (RegOpenKeyEx(hKey, lpsubkey, 0, option, &hTestKey) != ERROR_SUCCESS) return;
        @     TCHAR    achKey[MAX_KEY_LENGTH];
        @     DWORD    cbName;
        @     TCHAR    achClass[MAX_PATH] = TEXT("");
        @     DWORD    cchClassName = MAX_PATH;
        @     DWORD    cSubKeys = 0;
        @     DWORD    cbMaxSubKey;
        @     DWORD    cchMaxClass;
        @     DWORD    cValues; 
        @     DWORD    cchMaxValue;
        @     DWORD    cbMaxValueData; 
        @     DWORD    cbSecurityDescriptor;
        @     FILETIME ftLastWriteTime;
        @     DWORD i, retCode;
        @     TCHAR  achValue[MAX_VALUE_NAME];
        @     DWORD cchValue = MAX_VALUE_NAME;
        @     retCode = RegQueryInfoKey(
        @         hTestKey,
        @         achClass,
        @         &cchClassName, 
        @         NULL,
        @         &cSubKeys,
        @         &cbMaxSubKey,
        @         &cchMaxClass,
        @         &cValues,
        @         &cchMaxValue,
        @         &cbMaxValueData,
        @         &cbSecurityDescriptor,
        @         &ftLastWriteTime);
        @     if (cValues)
        @     {
        @         for (i = 0, retCode = ERROR_SUCCESS; i < cValues; i++)
        @         {
        @             DWORD dwValueType = 0;
        @             cchValue = MAX_VALUE_NAME;
        @             achValue[0] = '\0';
        @             retCode = RegEnumValue(hTestKey, i,achValue,&cchValue,NULL,&dwValueType,NULL,NULL);
        @             if (retCode == ERROR_SUCCESS)
        @             {
        @                 @<返回的值名称组>.data ().Add2 (achValue);
        @             }
        @             if( !@<返回的值类型组>.IsNullObject () )
        @             {
        @                  @<返回的值类型组>.data().Add2((INT)dwValueType);   
        @             }
        @         }
        @     }
        @     RegCloseKey(hTestKey);
    }

