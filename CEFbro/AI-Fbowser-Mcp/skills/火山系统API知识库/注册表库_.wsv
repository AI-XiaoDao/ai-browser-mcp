    方法 注册表删除键_ <公开 静态 类型 = "逻辑型  " 注释 = "例如：　;" 注释 = "注册表删除键_ (2, \"主项\\\\子项\")　;" 注释 = "相当于删除\"子项\"处"
            注释 = "[HKEY_CURRENT_USER\\主项\\子项]" 注释 = "\"测试\"=\"内容\"" 注释 = "" 注释 = "注册表删除键_ (2, \"主项\")　;" 注释 = "相当于删除整个\"主项\"处"
            返回值注释 = "不存在也返回真" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<winreg.h>" @视窗.预定义宏 = "_WIN32_WINNT=0x0600">
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if ( (INT_PTR) @<临时节点> >=0) return false;
        @ REGSAM X86X64 = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY Hwndkey;
        @ if ( RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, X86X64 | KEY_ALL_ACCESS,   (PHKEY)&Hwndkey) != ERROR_SUCCESS)  return 0;
        @ if (Hwndkey <=0)  return true;
        @ if( RegDeleteKeyW((HKEY)Hwndkey, _T("")) ==ERROR_SUCCESS ) return true; 
        @ if(RegDeleteTreeA((HKEY)Hwndkey,0)==ERROR_SUCCESS)
        @ {
        @   if( RegDeleteKeyW((HKEY)Hwndkey, _T("")) ==ERROR_SUCCESS ) return true;
        @ }
        @  RegCloseKey ((HKEY)Hwndkey);
        @  return false;
    }

    方法 注册表删除键值_ <公开 静态 类型 = 逻辑型 注释 = "例如：注册表删除键值_ (2, \"主项\\\\子项\", \"测试\") ;" 注释 = "相当于删除\"测试\"项："
            注释 = "[HKEY_CURRENT_USER\\主项\\子项]" 注释 = "\"测试\"=\"内容\"" 折叠 折叠2 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        变量 bRes <类型 = 逻辑型>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if (!@<临时节点>) return false;
        @ DWORD flag = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_ALL_ACCESS, &临时节点);
        @ @<bRes> = RegDeleteValueW(临时节点, @<键名称>.GetText()) == ERROR_SUCCESS;
        @ RegCloseKey(临时节点);
        @ return @<bRes>;
    }

    方法 注册表定位打开_ <公开 静态 类型 = 逻辑型
            注释 = "注册表定位打开_ (\"HKEY_LOCAL_MACHINE\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Run\", \"Sysdiag\")" 折叠>
    参数 键路径 <类型 = 文本型 注释 = "完整的注册表路径；例如：\"HKEY_LOCAL_MACHINE\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Run\"">
    参数 键值 <类型 = 文本型 注释 = "需要定位到的键值名称；例如：\"Sysdiag\"" @默认值 = "">
    参数 定位次数 <类型 = 整数 注释 = "可能会定位错误，建议设置次数为2－3左右" @默认值 = 3>
    {
        变量 窗口句柄 <类型 = 整数>
        变量 窗口句柄2 <类型 = 变整数>
        变量 窗口句柄3 <类型 = 变整数>
        变量 临时内容 <类型 = 文本型>
        变量 代码值 <类型 = 整数>
        变量 结果 <类型 = 变整数>
        变量 i <类型 = 整数>
        窗口句柄 = 定位api.FindWindow ("RegEdit_RegEdit", 0)
        运行 ("regedit.exe")
        延迟_ (100)
        窗口句柄 = 定位api.FindWindow ("RegEdit_RegEdit", 0)
        如果真 (窗口句柄 == 0)
        {
            返回 (假)
        }
        结果 = 定位api.ShowWindow (窗口句柄, 5)
        结果 = 定位api.SetForegroundWindow (窗口句柄)
        窗口句柄2 = 定位api.FindWindowEx (窗口句柄, 0, "SysTreeView32", 0)
        结果 = 定位api.SetForegroundWindow (窗口句柄2)
        结果 = 定位api.SetFocus (窗口句柄2)
        计次循环 (定位次数)
        {
            计次循环 (30)
            {
                结果 = 定位api.SendMessage (窗口句柄2, 256, 39, 0)
            }
            循环 (, 取文本长度 (键路径), i)
            {
                临时内容 = 取文本中间 (键路径, i, 1)
                如果 (临时内容 == "\\")
                {
                    结果 = 定位api.SendMessage (窗口句柄2, 256, 39, 0)
                }
                否则
                {
                    代码值 = 取代码_ (到大写 (临时内容), )
                    结果 = 定位api.SendMessage (窗口句柄2, 258, 代码值, 0)
                }
            }
        }
        如果真 (键值 != "")
        {
            窗口句柄3 = 定位api.FindWindowEx (窗口句柄, 0, "SysListView32", 0)
            结果 = 定位api.SetForegroundWindow (窗口句柄3)
            结果 = 定位api.SetFocus (窗口句柄3)
            延迟_ (100)
            结果 = 定位api.SendMessage (窗口句柄3, 256, 36, 0)
            循环 (, 取文本长度 (键值), i)
            {
                临时内容 = 取文本中间 (键值, i, 1)
                如果 (临时内容 == 键值)
                {
                    结果 = 定位api.SendMessage (窗口句柄3, 256, 39, 0)
                }
                否则
                {
                    代码值 = 取代码_ (到大写 (临时内容), )
                    结果 = 定位api.SendMessage (窗口句柄3, 258, 代码值, 0)
                }
            }
        }
        结果 = 定位api.SetForegroundWindow (窗口句柄)
        结果 = 定位api.SetFocus (窗口句柄)
        返回 (真)

    }

    # @ @def_macro _VOL_REG_OPER_HEADER  \
    # @     CVolString strPath;  \
    # @     const TCHAR* szItemName = @<全路径注册项名>.GetText ();  \
    # @     const TCHAR* ps = _tcsrchr (szItemName, '\\');  \
    # @     if (ps != NULL)  \
    # @     {  \
    # @         strPath.SetText (szItemName, ps - szItemName);  \
    # @         szItemName = ps + 1;  \
    # @     }

    方法 注册表是否存在_ <公开 静态 类型 = 逻辑型 折叠>
    参数 根节点 <类型 = 整数 注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if ( (INT_PTR) @<临时节点> >=0) return false;
        @ REGSAM X86X64 = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY hKey;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<临时节点>, @<键路径>.GetText (), 0, X86X64 | KEY_QUERY_VALUE, &hKey) == ERROR_SUCCESS)
        @ {
        @     DWORD dwType, dwDataSize;
        @     const BOOL_P blpExist = (::RegQueryValueEx (hKey, @<键名称>.GetText (), NULL, &dwType, NULL, &dwDataSize) == ERROR_SUCCESS);
        @     ::RegCloseKey (hKey);
        @     return (BOOL)blpExist;
        @ }
        返回 (假)
    }
}

