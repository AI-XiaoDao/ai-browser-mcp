<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"注册表库\"">

类 注册表类_ <公开 折叠 @全局类 = 真>
{
    常量 HKEY_CLASSES_ROOT <类型 = 变整数 值 = @"@(INT_P)HKEY_CLASSES_ROOT" "">
    常量 HKEY_CURRENT_USER <类型 = 变整数 值 = @"@(INT_P)HKEY_CURRENT_USER">
    常量 HKEY_LOCAL_MACHINE <类型 = 变整数 值 = @"@(INT_P)HKEY_LOCAL_MACHINE">
    常量 HKEY_USERS <类型 = 变整数 值 = @"@(INT_P)HKEY_USERS">
    常量 HKEY_CURRENT_CONFIG <类型 = 变整数 值 = @"@(INT_P)HKEY_CURRENT_CONFIG">

    方法 注册表读文本_ <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 @默认值 = "">
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @  HKEY hSubKey;
        @  TCHAR buffer[4096] = {0};
        @ DWORD dwBufferSize = sizeof(TCHAR)*sizeof(buffer);
        @  LONG lResult = RegOpenKeyEx((HKEY)@<临时节点>,@<键路径>,0,option,&hSubKey);
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return buffer;
        @  }
        @  lResult = RegQueryValueEx(hSubKey,@<键名称> , NULL, NULL ,(LPBYTE)buffer,&dwBufferSize);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return buffer;
        @  }
        @  RegCloseKey(hSubKey);
        @  return buffer;
    }

    方法 注册表读整数_ <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 返回值 <类型 = 整数>
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @  HKEY hSubKey;
        @ DWORD dwBufferSize = 4;
        @  LONG lResult = RegOpenKeyEx((HKEY)@<临时节点>,@<键路径>,0,option,&hSubKey);
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @  lResult = RegQueryValueEx(hSubKey,@<键名称> , NULL, NULL ,(LPBYTE)&@<返回值>,&dwBufferSize);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @  RegCloseKey(hSubKey);
        返回 (返回值)
    }

    方法 注册表读长整数_ <公开 静态 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 返回值 <类型 = 长整数>
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @  HKEY hSubKey;
        @ DWORD dwBufferSize = 8;
        @  LONG lResult = RegOpenKeyEx((HKEY)@<临时节点>,@<键路径>,0,option,&hSubKey);
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @  lResult = RegQueryValueEx(hSubKey,@<键名称> , NULL, NULL ,(LPBYTE)&@<返回值>,&dwBufferSize);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @  RegCloseKey(hSubKey);
        返回 (返回值)
    }

    方法 注册表读字节集_ <公开 静态 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 @默认值 = "">
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时节点 <类型 = 变整数>
        变量 hLocal <类型 = 变整数>
        变量 cbData <类型 = 整数>
        变量 lpData <类型 = 字节集类>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if (!@<临时节点>) return @<lpData>;
        @ DWORD flag = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_QUERY_VALUE, &临时节点);
        @ if (lRes != ERROR_SUCCESS) return @<lpData>;
        @ DWORD Data, cbData;
        @ if (RegQueryValueExW(临时节点, @<键名称>.GetText(), NULL, &Data, NULL, &cbData) == ERROR_SUCCESS)
        @ {
        @ LPBYTE lpData = new BYTE[cbData];
        @ memset(lpData, 0, cbData);
        @ RegQueryValueExW(临时节点, @<键名称>.GetText(), NULL, &Data, lpData, &cbData);
        @ @<hLocal> = (INT_PTR)lpData;
        @ @<cbData> = cbData;
        lpData = 指针到字节集 (hLocal, cbData)
        @ delete[] lpData;
        @ }
        @ RegCloseKey(临时节点);
        @ return @<lpData>;
    }

    方法 注册表写文本_ <公开 静态 类型 = 逻辑型 注释 = "例如：注册表写文本_ (2, \"主项\\\\子项\", \"测试\", \"内容\") ;" 注释 = "相当于："
            注释 = "[HKEY_CURRENT_USER\\主项\\子项]" 注释 = "\"测试\"=\"内容\"" 折叠 折叠2 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 "">
    参数 键值 <类型 = 文本型 "">
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    参数 键值类型 <类型 = 整数 注释 = "可调用常量值，如：“注册表键值类型常量.REG_DWORD”."
            注释 = "0、REG_NONE 1、REG_SZ 2、REG_EXPAND_SZ 3、REG_BINARY 4、REG_DWORD 5、REG_DWORD_BIG_ENDIAN"
            注释 = "6、REG_LINK 7、REG_MULTI_SZ 8、REG_RESOURCE_LIST 9、REG_FULL_RESOURCE_DESCRIPTOR"
            注释 = "10、REG_RESOURCE_REQUIREMENTS_LIST 11、REG_QWORD" @默认值 = 1 "">
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if (!@<临时节点>) return false;
        @ DWORD flag = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_CREATE_SUB_KEY | KEY_WRITE , &临时节点);
        @ if (lRes = 2)
        @ lRes = RegCreateKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, NULL, REG_OPTION_NON_VOLATILE, flag | KEY_CREATE_SUB_KEY | KEY_WRITE, NULL, &临时节点, NULL);
        @ if (lRes != ERROR_SUCCESS) return false;
        @ DWORD cbData = (DWORD)wcslen(@<键值>.GetText());
        @ cbData++;
        @ LPWSTR lpData = new TCHAR[cbData]();
        @ wcscpy(lpData, @<键值>.GetText());
        @ lRes = RegSetValueExW(临时节点, @<键名称>.GetText(), 0, @<键值类型>, (LPBYTE)lpData, cbData * sizeof(TCHAR));
        @ delete[] lpData;
        @ RegCloseKey(临时节点);
        @ return (lRes == ERROR_SUCCESS);
    }

    方法 注册表写整数_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 "">
    参数 键值 <类型 = 整数 "">
    参数 是否64位 <类型 = 逻辑型 注释 = "如果为真，带有KEY_WOW64_64KEY，如果为假，带有KEY_WOW64_32KEY" @默认值 = 假>
    参数 键值类型 <类型 = 整数 注释 = "可调用常量值，如：“注册表键值类型常量.REG_DWORD”."
            注释 = "0、REG_NONE 1、REG_SZ 2、REG_EXPAND_SZ 3、REG_BINARY 4、REG_DWORD 5、REG_DWORD_BIG_ENDIAN"
            注释 = "6、REG_LINK 7、REG_MULTI_SZ 8、REG_RESOURCE_LIST 9、REG_FULL_RESOURCE_DESCRIPTOR"
            注释 = "10、REG_RESOURCE_REQUIREMENTS_LIST 11、REG_QWORD" @默认值 = 4 "">
    {
        变量 临时节点 <类型 = 变整数>
        如果 (根节点 == 1)
        {
            临时节点 = HKEY_CLASSES_ROOT
        }
        否则 (根节点 == 2)
        {
            临时节点 = HKEY_CURRENT_USER
        }
        否则 (根节点 == 3)
        {
            临时节点 = HKEY_LOCAL_MACHINE
        }
        否则 (根节点 == 4)
        {
            临时节点 = HKEY_USERS
        }
        否则 (根节点 == 5)
        {
            临时节点 = HKEY_CURRENT_CONFIG
        }
        @ if (!@<临时节点>) return false;
        @ DWORD flag = @<是否64位> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_CREATE_SUB_KEY | KEY_WRITE, &临时节点);
        @ if (lRes = 2)
        @ lRes = RegCreateKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, NULL, REG_OPTION_NON_VOLATILE, flag | KEY_WRITE | KEY_CREATE_SUB_KEY, NULL, &临时节点, NULL);
        @ if (lRes != ERROR_SUCCESS) return false;
        @ lRes = RegSetValueExW(临时节点, @<键名称>.GetText(), 0, @<键值类型>, (LPBYTE)&@<键值>, sizeof(INT));
        @ RegCloseKey(临时节点);
        @ return (lRes == ERROR_SUCCESS);
    }

    方法 注册表写长整数_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 整数 注释 = "例如调整常量：“注册表根类型常量.HKEY_CURRENT_USER”."
            注释 = "1、HKEY_CLASSES_ROOT　2、HKEY_CURRENT_USER　3、HKEY_LOCAL_MACHINE　4、HKEY_USERS　5、HKEY_CURRENT_CONFIG">
    参数 键路径 <类型 = 文本型>
