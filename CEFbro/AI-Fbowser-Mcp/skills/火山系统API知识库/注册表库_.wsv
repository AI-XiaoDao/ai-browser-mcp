        @ HKEY 临时节点;
        @ LSTATUS lRes = RegOpenKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, flag | KEY_CREATE_SUB_KEY | KEY_WRITE, &临时节点);
        @ if (lRes = 2)
        @ lRes = RegCreateKeyExW((HKEY)@<临时节点>, @<键路径>.GetText(), 0, NULL, REG_OPTION_NON_VOLATILE, flag | KEY_WRITE | KEY_CREATE_SUB_KEY, NULL, &临时节点, NULL);
        @ if (lRes != ERROR_SUCCESS) return false;
        @ lRes = RegSetValueExW(临时节点, @<键名称>.GetText(), 0, @<键值类型>, (LPBYTE)&@<键值>, sizeof(INT_P));
        @ RegCloseKey(临时节点);
        @ return (lRes == ERROR_SUCCESS);
