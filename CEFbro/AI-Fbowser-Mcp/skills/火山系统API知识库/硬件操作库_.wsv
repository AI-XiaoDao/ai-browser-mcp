类 硬件序列号类_ <公开 折叠 折叠2 @文档 = "category = \"硬件操作库.硬件序列号\"" @全局类 = 真
        @视窗.外部头文件 = "..\\..\\sys\\sysHardwareInfo\\include\\WinOperateModule.h"
        @视窗.外部源文件 = "..\\..\\sys\\sysHardwareInfo\\include\\WinOperateModule.cpp">
{
    变量 全局长度限制 <静态 类型 = 整数>
    变量 硬盘序列 <静态 类型 = 文本型>
    变量 主板序列 <静态 类型 = 文本型>
    变量 CPU序列 <静态 类型 = 文本型>
    变量 BIOS序列 <静态 类型 = 文本型>
    变量 网卡序列 <静态 类型 = 文本型>

    方法 USB_取USB序列号 <公开 静态 类型 = 文本数组类 折叠 @禁止流程检查 = 真>
    {
        变量 wmi <类型 = COM对象类>
        变量 server <类型 = COM对象类>
        变量 object <类型 = COM对象类>
        变量 i <类型 = 整数>
        变量 properties <类型 = COM对象类>
        变量 x <类型 = COM对象类>
        变量 y <类型 = COM对象类>
        变量 z <类型 = COM对象类>
        变量 deviceID <类型 = 文本型>
        变量 description <类型 = 文本型>
        变量 sn <类型 = 文本型>
        变量 snList <类型 = 文本数组类>
        COM初始化类.初始化COM ()
        wmi.创建 ("WbemScripting.SWbemLocator")
        server = wmi.对象型方法 ("Connectserver", COM对象类, ".", "root\\CIMV2")
        object = server.对象型方法 ("ExecQuery", COM对象类, "select * from Win32_USBHub")
        循环 (0, object.读无参数属性 ("Count", 整数) - 1, i, 1)
        {
            x = object.对象型方法 ("ItemIndex", COM对象类, i)
            properties = x.读无参数对象型属性 ("Properties_", COM对象类)
            y = properties.对象型方法 ("item", COM对象类, "PnPDeviceID")
            deviceID = y.读无参数属性 ("Value", 文本型)
            z = properties.对象型方法 ("item", COM对象类, "Description")
            description = z.读无参数属性 ("Value", 文本型)
            如果真 (description == "USB 大容量存储设备" || description == "USB Mass Storage Device")
            {
                sn = 取文本右边 (deviceID, 取文本长度 (deviceID) - 倒找文本 (deviceID, "\\", , 假) - 1)
                调试输出 (sn, deviceID, description)
                snList.加入成员 (sn)
            }
        }
        wmi.清除 ()
        COM初始化类.清理COM ()
        返回 (snList)
    }

    方法 机器码_取机器码 <公开 静态 类型 = 文本型 折叠>
    参数 获取类型 <类型 = 整数 注释 = "1、硬盘　2、主板　3、CPU　4、BIOS　5、网卡　6、硬盘+主板　7、硬盘+主板+CPU."
            注释 = "8、硬盘＋主板+CPU+BIOS　9、主板+CPU　10、主板+CPU+BIOS　11、CPU+BIOS　12、主板+BIOS" @默认值 = 1>
    参数 长度限制 <类型 = 整数 注释 = "提供偶数，最小10位，最大20位" @默认值 = 12>
    {
        变量 i <类型 = 整数>
        连续赋值 ("", 硬盘序列, 主板序列, CPU序列, BIOS序列, 网卡序列)
        全局长度限制 = 长度限制
        如果真 (全局长度限制 % 2 != 0)
        {
            全局长度限制 = 全局长度限制 + 1
        }
        如果真 (全局长度限制 < 10)
        {
            全局长度限制 = 10
        }
        如果真 (全局长度限制 > 20)
        {
            全局长度限制 = 20
        }
        如果真 (获取类型 == 1 || 获取类型 == 6 || 获取类型 == 7 || 获取类型 == 8)
        {
            启动线程 (取码线程, 1, )
        }
        如果真 (获取类型 == 2 || 获取类型 == 6 || 获取类型 == 7 || 获取类型 == 8 || 获取类型 == 9 || 获取类型 == 10 || 获取类型 == 12)
        {
            启动线程 (取码线程, 2, )
        }
        如果真 (获取类型 == 3 || 获取类型 == 7 || 获取类型 == 8 || 获取类型 == 9 || 获取类型 == 10 || 获取类型 == 11)
        {
            启动线程 (取码线程, 3, )
        }
        如果真 (获取类型 == 4 || 获取类型 == 8 || 获取类型 == 10 || 获取类型 == 11 || 获取类型 == 12)
        {
            启动线程 (取码线程, 4, )
        }
        如果真 (获取类型 == 5)
        {
            启动线程 (取码线程, 5, )
        }
        如果 (获取类型 == 1)
        {
            判断循环 (硬盘序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 2)
        {
            判断循环 (主板序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 3)
        {
            判断循环 (CPU序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 4)
        {
            判断循环 (BIOS序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 5)
        {
            判断循环 (网卡序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 6)
        {
            判断循环 (硬盘序列 == "" || 主板序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 7)
        {
            判断循环 (硬盘序列 == "" || 主板序列 == "" || CPU序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 8)
        {
            判断循环 (硬盘序列 == "" || 主板序列 == "" || CPU序列 == "" || BIOS序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 9)
        {
            判断循环 (主板序列 == "" || CPU序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 10)
        {
            判断循环 (主板序列 == "" || CPU序列 == "" || BIOS序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 11)
        {
            判断循环 (CPU序列 == "" || BIOS序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        否则 (获取类型 == 12)
        {
            判断循环 (主板序列 == "" || BIOS序列 == "")
            {
                i = i + 1
                延迟_ (1)
                如果真 (i > 3000)
                {
                    跳出循环
                }
            }
        }
        返回 (文本_字母转整数 (组合数值 (硬盘序列 + 主板序列 + CPU序列 + BIOS序列 + 网卡序列)))
    }

    方法 硬盘_取硬盘特征字 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 硬盘序号 <类型 = 整数 注释 = "默认取第一个硬盘" @默认值 = 0>
    {
        变量 驱动名 <类型 = 文本型 值 = "\\\\.\\PhysicalDrive">
        驱动名 = 驱动名 + 到文本 (硬盘序号)
        @ HANDLE hPhysicalDriveIOCTL = ::CreateFileW(@<驱动名>,0,FILE_SHARE_READ|FILE_SHARE_WRITE,NULL,OPEN_EXISTING,NULL,NULL);
        @ if ( hPhysicalDriveIOCTL == INVALID_HANDLE_VALUE ) return 0;
        变量 bufferSize <类型 = 整数 值 = 1024 @输出名 = "bufferSize">
        变量 lpOutBuffer <类型 = 字节集类 @输出名 = "lpOutBuffer">
        变量 lpInBuffer <类型 = 字节集类 @输出名 = "lpInBuffer">
        lpInBuffer = 取空白字节集 (12)
        lpOutBuffer = 取空白字节集 (bufferSize)
        @ DWORD lpBytesReturned = 0;
        @ BOOL st = ::DeviceIoControl(hPhysicalDriveIOCTL,2954240,lpInBuffer.GetPtr(),12,lpOutBuffer.GetPtr(),bufferSize,&lpBytesReturned,0);
        @ ::CloseHandle(hPhysicalDriveIOCTL);
        @ if (!st) return 0;
        返回 (取整数绝对值 (取数据摘要_CRC32 (lpOutBuffer)))
    }

    方法 硬盘_取硬盘序列号 <公开 静态 类型 = 文本型 注释 = "获取存储设备磁盘驱动器信息，包括：硬盘、U盘、移动硬盘等多个或单个设备" 返回值注释 = "如果获取不到则返回系统所在盘的磁盘序列号(注：会受格式化影响变动)" 折叠
            @禁止流程检查 = 真>
    {
        变量 硬盘 <类型 = 硬盘信息类_>
        @ CoInitialize(NULL);
        @ @<硬盘>=@dt<硬盘信息类_>(CWinHardwareInformation::GetIEnumWbemClassObject(1));
        @ CoUninitialize();
        如果真 (文本是否为空 (硬盘.序列号))
        {
            返回 (到文本 (取磁盘序列号 (取字符 (读环境变量 ("SystemDrive"), 0))))
        }
        返回 (硬盘.序列号)
    }

    方法 硬盘_取硬盘序列号所有 <公开 静态 类型 = 文本数组类 注释 = "获取存储设备磁盘驱动器信息，包括：硬盘、U盘、移动硬盘等多个或单个设备" 返回值注释 = "如果获取不到则返回系统所在盘的磁盘序列号(注：会受格式化影响变动)" 折叠
            @禁止流程检查 = 真>
