    方法 CPU_置CPU亲和性 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 指定核心 <类型 = 整数 注释 = "从0开始" @默认值 = 0>
    {
        @     DWORD_PTR affinityMask =  static_cast<DWORD_PTR>(1) << @<指定核心>;
        @     DWORD processId = @<进程ID>; 
        @     HANDLE hProcess = OpenProcess(PROCESS_SET_INFORMATION, FALSE, processId);
        @     if (hProcess == NULL) {
        @         return false;
        @     }
        @     if (SetProcessAffinityMask(hProcess, affinityMask) == 0) {
        @         CloseHandle(hProcess);
        @         return false;
        @     }
        @     CloseHandle(hProcess);
        @     return true;
    }

