类 磁盘空间类_ <公开 折叠 折叠2 @文档 = "category = \"硬件操作库.硬盘空间\"" @全局类 = 真>
{
    方法 磁盘_枚举磁盘 <公开 静态 类型 = 整数 注释 = "获取当前所有磁盘空间信息" 返回值注释 = "返回分区总数" 折叠>
    参数 返回的盘符 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的分区大小 <类型 = 长整数数组类 注释 = "单位KB" @默认值 = 空对象>
    参数 返回的剩余空间 <类型 = 长整数数组类 注释 = "单位KB" @默认值 = 空对象>
    参数 返回的已用空间 <类型 = 长整数数组类 注释 = "单位KB" @默认值 = 空对象>
    {
        变量 分区组 <类型 = 文本数组类>
        变量 总量 <类型 = 长整数>
        变量 剩余 <类型 = 长整数>
        磁盘_枚举盘符 (, 分区组)
        返回的盘符 = 分区组
        分区组.枚举循环 ()
        {
            总量 = 取磁盘总空间 (取字符 (分区组.取枚举值 (), 0))
            剩余 = 取磁盘剩余空间 (取字符 (分区组.取枚举值 (), 0))
            返回的分区大小.加入成员 (总量)
            返回的剩余空间.加入成员 (剩余)
            返回的已用空间.加入成员 (总量 - 剩余)
        }
        返回 (分区组.取成员数 ())
    }

    方法 磁盘_取磁盘空间 <公开 静态 注释 = "取指定磁盘空间信息" 折叠>
    参数 指定盘符 <类型 = 文本型 注释 = "例如“C:\\\\”">
    参数 返回的分区大小 <类型 = 长整数类 注释 = "单位KB  取值：返回的分区大小.值" @默认值 = 空对象>
    参数 返回的剩余空间 <类型 = 长整数类 注释 = "单位KB" @默认值 = 空对象>
    参数 返回的已用空间 <类型 = 长整数类 注释 = "单位KB" @默认值 = 空对象>
    {
        变量 总量 <类型 = 长整数>
        变量 剩余 <类型 = 长整数>
        总量 = 取磁盘总空间 (取字符 (指定盘符, 0))
        剩余 = 取磁盘剩余空间 (取字符 (指定盘符, 0))
        返回的分区大小.值 = 总量
        返回的剩余空间.值 = 剩余
        返回的已用空间.值 = 总量 - 剩余
    }
}

