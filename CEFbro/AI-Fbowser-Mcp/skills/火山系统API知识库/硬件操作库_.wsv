类 CPU核心类_ <公开 折叠 @全局类 = 真>
{
    方法 CPU_取CPU核心数 <公开 静态 类型 = 整数 注释 = "逻辑线程数" 折叠 @禁止流程检查 = 真>
    {
        @     SYSTEM_INFO sysInfo;
        @     GetSystemInfo(&sysInfo);
        @     return sysInfo.dwNumberOfProcessors;
    }

    方法 CPU_取CPU核心数2 <公开 静态 类型 = 整数 注释 = "取出物理核心数和逻辑线程数" 返回值注释 = "返回物理核心数" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\niostream\r\nvector\r\nWinBase.h" @视窗.预定义宏 = "_WIN32_WINNT=0x0601">
    参数 返回的逻辑线程数 <类型 = 整数类 @默认值 = 空对象>
    {
        @ SYSTEM_INFO sysInfo;
        @ GetSystemInfo(&sysInfo);
        @ DWORD logicalCores = sysInfo.dwNumberOfProcessors;
        @ DWORD physicalCores = 0;
        @ DWORD size = 0;
        @ GetLogicalProcessorInformationEx(RelationProcessorCore, NULL, &size);
        @ if (GetLastError() == ERROR_INSUFFICIENT_BUFFER) {
        @ std::vector<BYTE> buffer(size);
        @ PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX ptr =
        @ reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(buffer.data());
        @ if (GetLogicalProcessorInformationEx(RelationProcessorCore, ptr, &size)) {
        @ while (size > 0) {
        @ if (ptr->Relationship == RelationProcessorCore) {
        @ physicalCores++;
        @ }
        @ size -= ptr->Size;
        @ ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(
        @ reinterpret_cast<BYTE*>(ptr) + ptr->Size);
        @ }
        @ }
        @ }
        @ @<返回的逻辑线程数.值>=logicalCores;
        @ return physicalCores;
    }

    方法 CPU_取CPU大小核数 <公开 静态 类型 = 整数 返回值注释 = "返回性能核(P-Core)，即大核" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream\r\nvector"
            @视窗.预定义宏 = "_WIN32_WINNT=0x0A00">
    参数 返回的能效核 <类型 = 整数类 注释 = "能效核(E-Core)，即小核" @默认值 = 空对象>
    {
        @ int pCores = 0, eCores = 0;
        @ DWORD size = 0;
        @ std::vector<BYTE> buffer;
        @ if (!GetLogicalProcessorInformationEx(RelationAll, nullptr, &size) &&
        @ GetLastError() == ERROR_INSUFFICIENT_BUFFER) {
        @ buffer.resize(size);
        @ if (GetLogicalProcessorInformationEx(RelationAll,
        @ reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(buffer.data()),
        @ &size)) {
        @ auto ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(buffer.data());
        @ while (size > 0 && ptr->Size > 0) {
        @ if (ptr->Relationship == RelationProcessorCore) {
        @ if (ptr->Processor.EfficiencyClass > 0) {
        @ pCores++;
        @ }
        @ else {
        @ eCores++;
        @ }
        @ }
        @ size -= ptr->Size;
        @ ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(
        @ reinterpret_cast<BYTE*>(ptr) + ptr->Size);
        @ }
        @ }
        @ }
        @ @<返回的能效核.值>=eCores;
        @ return pCores;
    }

    方法 CPU_是否支持超线程 <公开 静态 类型 = 逻辑型 注释 = "Hyper-Threading" 折叠 折叠2 @视窗.外部头文件 = "windows.h\r\niostream\r\nvector\r\nWinBase.h"
            @视窗.预定义宏 = "_WIN32_WINNT=0x0601" @禁止流程检查 = 真>
    {
        @ SYSTEM_INFO sysInfo;
        @ GetSystemInfo(&sysInfo);
        @ DWORD logicalCores = sysInfo.dwNumberOfProcessors;
        @ DWORD physicalCores = 0;
        @ DWORD size = 0;
        @ GetLogicalProcessorInformationEx(RelationProcessorCore, NULL, &size);
        @ if (GetLastError() == ERROR_INSUFFICIENT_BUFFER) {
        @ std::vector<BYTE> buffer(size);
        @ PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX ptr =
        @ reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(buffer.data());
        @ if (GetLogicalProcessorInformationEx(RelationProcessorCore, ptr, &size)) {
        @ for (DWORD offset = 0; offset < size; ) {
        @ if (ptr->Relationship == RelationProcessorCore) {
        @ physicalCores++;
        @ }
        @ offset += ptr->Size;
        @ ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(
        @ reinterpret_cast<BYTE*>(ptr) + ptr->Size);
        @ }
        @ }
        @ }
        @ return physicalCores;
    }

    方法 CPU_是否有小核 <公开 静态 类型 = 逻辑型 注释 = "判断CPU是否存在能效核(E-Core)。适用win10-11之类较新系统" 折叠 折叠2
            @视窗.外部头文件 = "windows.h\r\niostream\r\nvector\r\nWinBase.h" @视窗.预定义宏 = "_WIN32_WINNT=0x0601" @禁止流程检查 = 真>
    {
        @ bool isHybrid = false;
        @ DWORD size = 0;
        @ GetLogicalProcessorInformationEx(RelationAll, nullptr, &size);
        @ if (GetLastError() == ERROR_INSUFFICIENT_BUFFER) {
        @ std::vector<BYTE> buffer(size);
        @ auto ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(buffer.data());
        @ if (GetLogicalProcessorInformationEx(RelationAll, ptr, &size)) {
        @ while (size > 0) {
        @ if (ptr->Relationship == RelationProcessorCore) {
        @ if (ptr->Processor.EfficiencyClass > 0) {
        @ isHybrid = true;
        @ break;
        @ }
        @ }
        @ size -= ptr->Size;
        @ ptr = reinterpret_cast<PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX>(
        @ reinterpret_cast<BYTE*>(ptr) + ptr->Size);
        @ }
        @ }
        @ }
        @ return isHybrid;
    }

    方法 CPU_是否有小核2 <公开 静态 类型 = 逻辑型 注释 = "判断CPU是否存在能效核(E-Core)。适用于旧系统" 折叠 折叠2
            @视窗.外部头文件 = "windows.h\r\niostream\r\nstring\r\nintrin.h" @禁止流程检查 = 真>
    参数 返回的型号 <类型 = 文本型 编辑时信息 = "5528F, 0, 0, 0" @默认值 = "">
    {
        @ int CPUInfo[4] = { -1 };
        @ std::string brand;
        @ __cpuid(CPUInfo, 0x80000002);
        @ for (int i = 0; i < 4; i++) {
        @ brand.append(reinterpret_cast<char*>(&CPUInfo[i]), 4);
        @ }
        @ __cpuid(CPUInfo, 0x80000003);
        @ for (int i = 0; i < 4; i++) {
        @ brand.append(reinterpret_cast<char*>(&CPUInfo[i]), 4);
        @ }
        @ __cpuid(CPUInfo, 0x80000004);
        @ for (int i = 0; i < 4; i++) {
        @ brand.append(reinterpret_cast<char*>(&CPUInfo[i]), 4);
        @ }
        @ bool isHybrid = (brand.find("i5-12") != std::string::npos ||
        @ brand.find("i7-12") != std::string::npos ||
        @ brand.find("i9-12") != std::string::npos ||
        @ brand.find("i5-13") != std::string::npos ||
        @ brand.find("i7-13") != std::string::npos ||
        @ brand.find("i9-13") != std::string::npos ||
        @ brand.find("i5-14") != std::string::npos ||
        @ brand.find("i7-14") != std::string::npos ||
        @ brand.find("i9-14") != std::string::npos);
        @ @<返回的型号>=brand.c_str();
        @ return isHybrid;
    }
}

