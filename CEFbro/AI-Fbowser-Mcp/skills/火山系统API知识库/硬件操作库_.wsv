类 串口信息类_ <公开 折叠 @文档 = "category = \"硬件操作库.串口信息\"">
{

    # @begin
    # #include <windows.h>
    # #include <devguid.h>
    # #include <setupapi.h>
    # #pragma comment(lib, "Setupapi.lib")
    # static const DWORD friendly_name_max_length = 256;
    # static const DWORD hardware_id_max_length = 256;
    # @end

    方法 枚举串口 <公开 类型 = 整数 返回值注释 = "返回串口总数" 折叠>
    参数 返回的名称组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的硬件ID组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 名称 <类型 = 文本型>
        变量 ID <类型 = 文本型>
        变量 名称组 <类型 = 文本数组类>
        变量 ID组 <类型 = 文本数组类>
        @ HDEVINFO hDevInfo = SetupDiGetClassDevs( (const GUID *)&GUID_DEVCLASS_PORTS,NULL,NULL,DIGCF_PRESENT);
        @   if(hDevInfo)
        @   {
        @     SP_DEVINFO_DATA SpDevInfo={sizeof(SP_DEVINFO_DATA)};
        @   unsigned int device_info_set_index = 0;
        @    while(SetupDiEnumDeviceInfo(hDevInfo, device_info_set_index,  &SpDevInfo))
        @     {
        @       TCHAR szName[512] = {0};
        @        device_info_set_index++;
        @        TCHAR friendly_name[friendly_name_max_length];
        @        DWORD friendly_name_actual_length = 0;
        @       if(SetupDiGetDeviceRegistryProperty(hDevInfo, &SpDevInfo, SPDRP_FRIENDLYNAME,
        @         NULL, (PBYTE)szName, friendly_name_max_length, &friendly_name_actual_length))
        @       {
        @         _tprintf(_T("%s\n"), szName);
        @         @<名称>=szName;
        @       }
        @ TCHAR hardware_id[hardware_id_max_length];
        @  DWORD hardware_id_actual_length = 0;
        @  BOOL got_hardware_id = SetupDiGetDeviceRegistryProperty(hDevInfo, &SpDevInfo,SPDRP_HARDWAREID,NULL,(PBYTE)hardware_id,hardware_id_max_length,&hardware_id_actual_length);
        @ @<ID>=hardware_id;
        名称组.加入成员 (名称)
        ID组.加入成员 (ID)
        @     }
        @     SetupDiDestroyDeviceInfoList(hDevInfo);
        @   }
        返回的名称组 = 名称组
        返回的硬件ID组 = ID组
        返回 (名称组.取成员数 ())
    }
}
