    方法 取码线程 <静态 类型 = 整数 折叠>
    参数 用户标记 <类型 = 变整数>
    {
        如果 (用户标记 == 1)
        {
            硬盘序列 = 硬盘_取硬盘序列号 ()
            加入文本 (硬盘序列, "1")
        }
        否则 (用户标记 == 2)
        {
            主板序列 = 主板_取主板序列号 ()
            加入文本 (主板序列, "2")
        }
        否则 (用户标记 == 3)
        {
            CPU序列 = CPU_取CPU序列号2 ()
            加入文本 (CPU序列, "3")
        }
        否则 (用户标记 == 4)
        {
            BIOS序列 = BIOS_取BIOS序列号 ()
            加入文本 (BIOS序列, "4")
        }
        否则 (用户标记 == 5)
        {
            网卡序列 = 网卡_取网卡MAC ()
            加入文本 (网卡序列, "5")
        }
        返回 (0)
    }

    方法 组合数值 <静态 类型 = 文本型 折叠>
    参数 数据 <类型 = 文本型>
    {
        变量 临时数据 <类型 = 文本型>
        变量 长度值 <类型 = 整数>
        变量 临时值 <类型 = 整数>
        变量 组合值 <类型 = 文本型>
        变量 最终值 <类型 = 文本型>
        变量 i <类型 = 整数>
        临时数据 = 数据
        长度值 = 取文本长度 (临时数据)
        如果真 (长度值 < 全局长度限制)
        {
            加入文本 (临时数据, 数据)
            加入文本 (临时数据, 数据)
            长度值 = 取文本长度 (临时数据)
            如果真 (长度值 < 全局长度限制)
            {
                全局长度限制 = 长度值
            }
        }
        循环 (, 长度值, i)
        {
            临时值 = 文本到整数 (取文本中间 (临时数据, 长度值 - i - 1, 1))
            加入整数文本 (组合值, 文本到整数 (取文本中间 (临时数据, i, 1)) + 临时值 * 临时值)
        }
        长度值 = 取文本长度 (组合值)
        循环 (, 长度值 / 2, i)
        {
            加入整数文本 (最终值, 文本到整数 (取文本中间 (组合值, i, 1)))
            加入整数文本 (最终值, 文本到整数 (取文本中间 (组合值, 长度值 / 2 + i, 1)))
            如果真 (取文本长度 (最终值) >= 全局长度限制)
            {
                跳出循环
            }
        }
        组合值 = ""
        返回 (最终值)
    }
}

