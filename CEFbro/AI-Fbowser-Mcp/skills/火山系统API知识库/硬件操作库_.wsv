<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"硬件操作库\"">

类 硬件综合信息类_ <公开 折叠 折叠2 @文档 = "category = \"硬件操作库.硬件信息\"" @全局类 = 真>
{
    方法 CPU_取CPU信息 <公开 静态 类型 = 逻辑型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream\r\nwbemidl.h\r\ncomdef.h"
            @视窗.外部库 = "wbemuuid.lib">
    参数 返回的制造商 <类型 = 文本型 @默认值 = "">
    参数 返回的产品名称 <类型 = 文本型 @默认值 = "">
    参数 返回的序列号 <类型 = 文本型 注释 = "ID" @默认值 = "">
    {
        @ CoInitialize(NULL);
        @  HRESULT hres = CoInitializeSecurity(
        @         NULL, -1, NULL, NULL,
        @         RPC_C_AUTHN_LEVEL_DEFAULT,
        @         RPC_C_IMP_LEVEL_IMPERSONATE,
        @         NULL, EOAC_NONE, NULL);
        @     if (FAILED(hres)) {
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemLocator* pLoc = NULL;
        @     hres = CoCreateInstance(
        @         CLSID_WbemLocator, 0, CLSCTX_INPROC_SERVER,
        @         IID_IWbemLocator, (LPVOID*)&pLoc);
        @     if (FAILED(hres)) {
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemServices* pSvc = NULL;
        @     hres = pLoc->ConnectServer(
        @         _bstr_t(L"ROOT\\CIMV2"), NULL, NULL,
        @         0, NULL, 0, 0, &pSvc);
        @     if (FAILED(hres)) {
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     hres = CoSetProxyBlanket(
        @         pSvc, RPC_C_AUTHN_WINNT, RPC_C_AUTHZ_NONE,
        @         NULL, RPC_C_AUTHN_LEVEL_CALL,
        @         RPC_C_IMP_LEVEL_IMPERSONATE,
        @         NULL, EOAC_NONE);
        @     if (FAILED(hres)) {
        @         pSvc->Release();
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     IEnumWbemClassObject* pEnumerator = NULL;
        @     hres = pSvc->ExecQuery(
        @         bstr_t("WQL"),
        @         bstr_t("SELECT * FROM Win32_Processor"),
        @         WBEM_FLAG_FORWARD_ONLY | WBEM_FLAG_RETURN_IMMEDIATELY,
        @         NULL, &pEnumerator);
        @     if (FAILED(hres)) {
        @         pSvc->Release();
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemClassObject* pclsObj = NULL;
        @     ULONG uReturn = 0;
        @     while (pEnumerator) {
        @         hres = pEnumerator->Next(WBEM_INFINITE, 1, &pclsObj, &uReturn);
        @         if (0 == uReturn) break;
        @         VARIANT vtProp;
        @         hres = pclsObj->Get(L"Manufacturer", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @ @<返回的制造商>=vtProp.bstrVal;
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"Name", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @             std::wstring cpuName = vtProp.bstrVal;
        @             size_t pos;
        @             while ((pos = cpuName.find(L"  ")) != std::wstring::npos) {
        @                 cpuName.replace(pos, 2, L" ");
        @             }
        @ @<返回的产品名称>=cpuName.c_str();
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"ProcessorId", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres)) {
        @ @<返回的序列号>=vtProp.bstrVal;
        @             VariantClear(&vtProp);
        @         }
        @    }
        @     pSvc->Release();
        @     pLoc->Release();
        @     if (pEnumerator) pEnumerator->Release();
        @     CoUninitialize();
        @     return true;
    }

    方法 主板_取BIOS信息 <公开 静态 类型 = 逻辑型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream\r\nwbemidl.h\r\ncomdef.h"
            @视窗.外部库 = "wbemuuid.lib">
    参数 返回的制造商 <类型 = 文本型 @默认值 = "">
    参数 返回的产品名称 <类型 = 文本型 @默认值 = "">
    参数 返回的序列号 <类型 = 文本型 @默认值 = "">
    参数 返回的版本号 <类型 = 文本型 @默认值 = "">
    参数 返回的发布日期 <类型 = 文本型 @默认值 = "">
    {
        @ CoInitialize(NULL);
        @     HRESULT hres = CoInitializeSecurity(
        @         NULL,
        @         -1,
        @         NULL,
        @         NULL,
        @         RPC_C_AUTHN_LEVEL_DEFAULT,
        @         RPC_C_IMP_LEVEL_IMPERSONATE,
        @         NULL,
        @         EOAC_NONE,
        @         NULL
        @     );
        @     if (FAILED(hres)) {
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemLocator* pLoc = NULL;
        @     hres = CoCreateInstance(
        @         CLSID_WbemLocator,
        @         0,
        @         CLSCTX_INPROC_SERVER,
        @         IID_IWbemLocator,
        @         (LPVOID*)&pLoc
        @     );
        @     if (FAILED(hres)) {
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemServices* pSvc = NULL;
        @     hres = pLoc->ConnectServer(
        @         _bstr_t(L"ROOT\\CIMV2"),
        @         NULL,
        @         NULL,
        @         0,
        @         NULL,
        @         0,
        @         0,
        @         &pSvc
        @     );
        @     if (FAILED(hres)) {
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     hres = CoSetProxyBlanket(
        @         pSvc,
        @         RPC_C_AUTHN_WINNT,
        @         RPC_C_AUTHZ_NONE,
        @         NULL,
        @         RPC_C_AUTHN_LEVEL_CALL,
        @         RPC_C_IMP_LEVEL_IMPERSONATE,
        @         NULL,
        @         EOAC_NONE
        @     );
        @     if (FAILED(hres)) {
        @         pSvc->Release();
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     IEnumWbemClassObject* pEnumerator = NULL;
        @     hres = pSvc->ExecQuery(
        @         bstr_t("WQL"),
        @         bstr_t("SELECT * FROM Win32_BIOS"),
        @         WBEM_FLAG_FORWARD_ONLY | WBEM_FLAG_RETURN_IMMEDIATELY,
        @         NULL,
        @         &pEnumerator
        @     );
        @     if (FAILED(hres)) {
        @         pSvc->Release();
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemClassObject* pclsObj = NULL;
        @     ULONG uReturn = 0;
        @     while (pEnumerator) {
        @         hres = pEnumerator->Next(WBEM_INFINITE, 1, &pclsObj, &uReturn);
        @         if (0 == uReturn) break;
        @         VARIANT vtProp;
        @         hres = pclsObj->Get(L"Manufacturer", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @ @<返回的制造商>=vtProp.bstrVal;
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"Name", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @ @<返回的产品名称>=vtProp.bstrVal;
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"SerialNumber", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres)) {
        @             if (vtProp.vt == VT_NULL) {
        @ @<返回的序列号>="";
        @             } else {
        @ @<返回的序列号>=vtProp.bstrVal;
        @             }
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"Version", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @ @<返回的版本号>=vtProp.bstrVal;
        @             VariantClear(&vtProp);
        @         }
        @         hres = pclsObj->Get(L"ReleaseDate", 0, &vtProp, 0, 0);
        @         if (SUCCEEDED(hres) && (vtProp.vt != VT_NULL)) {
        @             std::wstring releaseDate = vtProp.bstrVal;
        @             std::wstring formattedDate = L"(格式错误)";
        @             if (releaseDate.length() >= 8) {
        @                 formattedDate = releaseDate.substr(0, 4) + L"-" +
        @                                 releaseDate.substr(4, 2) + L"-" +
        @                                 releaseDate.substr(6, 2);
        @             }
        @ @<返回的发布日期>=formattedDate.c_str();
        @             VariantClear(&vtProp);
        @         }
        @         pclsObj->Release();
        @         std::wcout << std::endl;
        @     }
        @     pSvc->Release();
        @     pLoc->Release();
        @     pEnumerator->Release();
        @     CoUninitialize();
        @     return true;
    }

    方法 主板_取主板信息 <公开 静态 类型 = 逻辑型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream\r\nwbemidl.h\r\ncomdef.h"
            @视窗.外部库 = "wbemuuid.lib">
    参数 返回的制造商 <类型 = 文本型 @默认值 = "">
    参数 返回的产品名称 <类型 = 文本型 @默认值 = "">
    参数 返回的序列号 <类型 = 文本型 @默认值 = "">
    参数 返回的版本号 <类型 = 文本型 @默认值 = "">
    {
        @ CoInitialize(NULL);
        @     HRESULT hres = CoInitializeSecurity(NULL, -1, NULL, NULL, RPC_C_AUTHN_LEVEL_DEFAULT,
        @         RPC_C_IMP_LEVEL_IMPERSONATE, NULL, EOAC_NONE, NULL);
        @     IWbemLocator* pLoc = NULL;
        @     hres = CoCreateInstance(CLSID_WbemLocator, 0, CLSCTX_INPROC_SERVER,
        @         IID_IWbemLocator, (LPVOID*)&pLoc);
        @     if (FAILED(hres)) {
        @         CoUninitialize();
        @         return false;
        @     }
        @     IWbemServices* pSvc = NULL;
        @     hres = pLoc->ConnectServer(_bstr_t(L"ROOT\\CIMV2"), NULL, NULL, 0, NULL, 0, 0, &pSvc);
        @     if (FAILED(hres)) {
        @         pLoc->Release();
        @         CoUninitialize();
        @         return false;
        @     }
        @     hres = CoSetProxyBlanket(pSvc, RPC_C_AUTHN_WINNT, RPC_C_AUTHZ_NONE, NULL,
        @         RPC_C_AUTHN_LEVEL_CALL, RPC_C_IMP_LEVEL_IMPERSONATE, NULL, EOAC_NONE);
        @     IEnumWbemClassObject* pEnumerator = NULL;
        @     hres = pSvc->ExecQuery(bstr_t("WQL"), bstr_t("SELECT * FROM Win32_BaseBoard"),
        @         WBEM_FLAG_FORWARD_ONLY | WBEM_FLAG_RETURN_IMMEDIATELY, NULL, &pEnumerator);
        @     if (SUCCEEDED(hres)) {
        @         IWbemClassObject* pclsObj = NULL;
        @         ULONG uReturn = 0;
        @         while (pEnumerator->Next(WBEM_INFINITE, 1, &pclsObj, &uReturn) == S_OK) {
        @             VARIANT vtProp;
        @             if (pclsObj->Get(L"Manufacturer", 0, &vtProp, 0, 0) == S_OK) {
        @ @<返回的制造商>=vtProp.bstrVal;
        @                 VariantClear(&vtProp);
        @             }
        @             if (pclsObj->Get(L"Product", 0, &vtProp, 0, 0) == S_OK) {
        @ @<返回的产品名称>=vtProp.bstrVal;
        @                 VariantClear(&vtProp);
        @             }
        @             if (pclsObj->Get(L"SerialNumber", 0, &vtProp, 0, 0) == S_OK) {
        @ @<返回的序列号>=vtProp.bstrVal;
        @                 VariantClear(&vtProp);
        @             }
        @ if (pclsObj->Get(L"Version", 0, &vtProp, 0, 0) == S_OK) {
        @     if (vtProp.vt == VT_BSTR && wcslen(vtProp.bstrVal) > 0 && 
        @         _wcsicmp(vtProp.bstrVal, L"Not Applicable") != 0) {
        @ @<返回的版本号>=vtProp.bstrVal;
        @     } else {
        @ @<返回的版本号>="";
        @     }
        @     VariantClear(&vtProp);
        @ }
        @             pclsObj->Release();
        @         }
        @     }
        @     pEnumerator->Release();
        @     pSvc->Release();
        @     pLoc->Release();
        @     CoUninitialize();
        @     return true;
    }

    方法 硬盘_枚举分区信息 <公开 静态 类型 = 整数 返回值注释 = "返回分区总数" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\nwinioctl.h\r\niostream\r\nvector\r\niomanip\r\nsstream\r\nalgorithm\r\nstring">
    参数 返回的分区 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的驱动器 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的卷名 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的分区名 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的序列号 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的总容量 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的已用空间 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的剩余空间 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    {
        变量 临时信息 <类型 = 文本型>
        @     DWORD drives = GetLogicalDrives();
        @     if (drives == 0) {
        @         return -1;
        @     }
        @     int partitionCount = 0;
        @     std::vector<std::wstring> partitionDetails;
        @     for (wchar_t drive = L'A'; drive <= L'Z'; drive++) {
        @         if (drives & (1 << (drive - L'A'))) {
        @             partitionCount++;
        @             std::wstring driveLetter = std::wstring() + drive + L":";
        @             std::wstring rootPath = driveLetter + L"\\";
        @             WCHAR volumeLabel[MAX_PATH] = { 0 };
        @             WCHAR volumeName[MAX_PATH] = { 0 };
        @             DWORD serialNumber = 0;
        @             ULARGE_INTEGER freeBytes, totalBytes;
        @             BOOL labelResult = GetVolumeInformationW(
        @                 rootPath.c_str(),
        @                 volumeLabel, MAX_PATH,
        @                 &serialNumber,
        @                 NULL, NULL, NULL, 0);
        @             std::wstring queryPath = L"\\\\?\\" + driveLetter + L"\\";
        @             BOOL nameResult = GetVolumeNameForVolumeMountPointW(
        @                 queryPath.c_str(),
        @                 volumeName, MAX_PATH);
        @             BOOL spaceResult = GetDiskFreeSpaceExW(
        @                 rootPath.c_str(),
        @                 &freeBytes, &totalBytes, NULL);
        @             std::wstring volumeLabelStr = labelResult && wcslen(volumeLabel) > 0 ? 
        @                 volumeLabel : (driveLetter + L"盘");
        @             std::wstring volumeNameStr = nameResult ? 
        @                 volumeName : L"N/A";
        @             double totalSizeGB = 0, freeSizeGB = 0, usedSizeGB = 0;
        @             if (spaceResult) {
        @                 totalSizeGB = totalBytes.QuadPart / (1024.0 * 1024.0 * 1024.0);
        @                 freeSizeGB = freeBytes.QuadPart / (1024.0 * 1024.0 * 1024.0);
        @                 usedSizeGB = totalSizeGB - freeSizeGB;
        @             }
        @             std::stringstream serialStream;
        @             if (labelResult) {
        @                 serialStream << std::hex << std::setw(8) << std::setfill('0') << serialNumber;
        @             } else {
        @                 serialStream << "N/A";
        @             }
        @ std::ostringstream Temporary1;
        @ Temporary1 << "#" << partitionCount ;
        @ @<临时信息>=Temporary1.str().c_str();
        返回的分区.加入成员 (临时信息)
        @ @<临时信息>=driveLetter.c_str();
        返回的驱动器.加入成员 (临时信息)
        @ @<临时信息>=volumeNameStr.c_str();
        返回的卷名.加入成员 (临时信息)
        @ @<临时信息>=volumeLabelStr.c_str();
        返回的分区名.加入成员 (临时信息)
        @ @<临时信息>=serialStream.str().c_str();
        返回的序列号.加入成员 (临时信息)
        @     std::wostringstream Temporary2;
        @     Temporary2 << std::fixed << std::setprecision(2) << totalSizeGB << L" GB";
        @ @<临时信息>=Temporary2.str().c_str();
        返回的总容量.加入成员 (临时信息)
        @     std::wostringstream Temporary3;
        @     Temporary3 << std::fixed << std::setprecision(2) << usedSizeGB << L" GB";
        @ @<临时信息>=Temporary3.str().c_str();
        返回的已用空间.加入成员 (临时信息)
        @     std::wostringstream Temporary4;
        @     Temporary4 << std::fixed << std::setprecision(2) << freeSizeGB << L" GB";
        @ @<临时信息>=Temporary4.str().c_str();
        返回的剩余空间.加入成员 (临时信息)
        @         }
        @     }
        @     return partitionCount;
    }

    方法 硬盘_枚举硬盘信息 <公开 静态 类型 = 整数 返回值注释 = "返回硬盘总数" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\nwinioctl.h\r\niostream\r\nvector\r\niomanip\r\nsstream\r\nalgorithm\r\nstring">
    参数 返回的物理硬盘 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的设备路径 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的硬盘容量 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的序列号 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    参数 返回的型号 <类型 = 文本数组类 编辑时信息 = "9EE4E, 0, 0, 0" @默认值 = 空对象>
    {
        变量 临时信息 <类型 = 文本型>
        @     const int MAX_DISKS = 16;
        @     int physicalDiskCount = 0;
        @     ULONGLONG totalCapacityGB = 0;
        @     for (int i = 0; i < MAX_DISKS; i++) {
        @         std::wstring devicePath = L"\\\\.\\PhysicalDrive" + std::to_wstring(i);
        @         HANDLE hDevice = CreateFileW(devicePath.c_str(),0,FILE_SHARE_READ | FILE_SHARE_WRITE,NULL,OPEN_EXISTING,0,NULL);
        @         if (hDevice == INVALID_HANDLE_VALUE) {
        @             continue;
        @         }
        @         DISK_GEOMETRY_EX diskGeometry = { 0 };
        @         DWORD bytesReturned = 0;
        @         BOOL geometryResult = DeviceIoControl(hDevice,IOCTL_DISK_GET_DRIVE_GEOMETRY_EX,NULL,0,&diskGeometry,sizeof(diskGeometry),&bytesReturned,NULL);
        @         STORAGE_PROPERTY_QUERY query{};
        @         query.PropertyId = StorageDeviceProperty;
        @         query.QueryType = PropertyStandardQuery;
        @         STORAGE_DESCRIPTOR_HEADER header{};
        @         BOOL propertyResult = DeviceIoControl(hDevice,IOCTL_STORAGE_QUERY_PROPERTY,&query,sizeof(query),&header,sizeof(header),&bytesReturned,NULL);
        @         if (geometryResult || propertyResult) {
        @             physicalDiskCount++;
        @             double diskSizeGB = diskGeometry.DiskSize.QuadPart / (1024.0 * 1024.0 * 1024.0);
        @             totalCapacityGB += diskGeometry.DiskSize.QuadPart;
        @ std::ostringstream Temporary1;
        @ Temporary1 << "#" << physicalDiskCount;
        @ @<临时信息>=Temporary1.str().c_str();
        返回的物理硬盘.加入成员 (临时信息)
        @ std::ostringstream Temporary2;
        @ Temporary2 << "\\\\.\\PhysicalDrive" << i;
        @ @<临时信息>=Temporary2.str().c_str();
        返回的设备路径.加入成员 (临时信息)
        @ std::ostringstream Temporary3;
        @ Temporary3 << std::fixed << std::setprecision(2) << diskSizeGB << " GB";
        @ @<临时信息>=Temporary3.str().c_str();
        返回的硬盘容量.加入成员 (临时信息)
        @             if (propertyResult && header.Size > 0) {
        @                 std::vector<BYTE> buffer(header.Size);
        @                 if (DeviceIoControl(hDevice,IOCTL_STORAGE_QUERY_PROPERTY,&query,sizeof(query),buffer.data(),static_cast<DWORD>(buffer.size()),&bytesReturned,NULL)) {
        @                     auto descriptor = reinterpret_cast<STORAGE_DEVICE_DESCRIPTOR*>(buffer.data());
        @                     if (descriptor->ProductIdOffset > 0) {
        @                         std::ostringstream Temporary4;
        @                          Temporary4 << (char*)(buffer.data() + descriptor->ProductIdOffset);
        @ @<临时信息>=Temporary4.str().c_str();
        返回的型号.加入成员 (临时信息)
        @                     }
        @                     if (descriptor->SerialNumberOffset > 0) {
        @                         std::string serial((char*)(buffer.data() + descriptor->SerialNumberOffset));
        @                         serial.erase(std::remove_if(serial.begin(), serial.end(), [](char c) {
        @                             return !isprint(c) || isspace(c);
        @                             }), serial.end());
        @ @<临时信息>=serial.c_str();
        返回的序列号.加入成员 (临时信息)
        @                     }
        @                 }
        @             }
        @         }
        @         CloseHandle(hDevice);
        @     }
        @     return physicalDiskCount;
    }

    方法 网卡_枚举网卡信息 <公开 静态 类型 = 整数 返回值注释 = "返回总数" 折叠 折叠2
            @视窗.外部头文件 = "winsock2.h\r\niphlpapi.h\r\niostream\r\niomanip\r\nvector\r\nsstream" @视窗.外部库 = "iphlpapi.lib\r\nws2_32.lib"
            @禁止流程检查 = 真>
    参数 返回的网卡名称 <类型 = 文本数组类 编辑时信息 = "A2345, 0, 0, 0" @默认值 = 空对象>
    参数 返回的网卡MAC <类型 = 文本数组类 编辑时信息 = "A2345, 0, 0, 0" @默认值 = 空对象>
    参数 返回的网卡描述 <类型 = 文本数组类 编辑时信息 = "A2345, 0, 0, 0" @默认值 = 空对象>
    {
        变量 临时信息 <类型 = 文本型>
        @     WSADATA wsaData;
        @     if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        @         return -1;
        @     }
        @     PIP_ADAPTER_ADDRESSES pAddresses = nullptr;
        @     ULONG outBufLen = 0;
        @     DWORD dwRetVal = 0;
        @     int adapterCount = 0;
        @     GetAdaptersAddresses(AF_UNSPEC, GAA_FLAG_INCLUDE_PREFIX, nullptr, pAddresses, &outBufLen);
        @     pAddresses = (PIP_ADAPTER_ADDRESSES)malloc(outBufLen);
        @     if (pAddresses == nullptr) {
        @         WSACleanup();
        @         return -1;
        @     }
        @     dwRetVal = GetAdaptersAddresses(AF_UNSPEC, GAA_FLAG_INCLUDE_PREFIX, nullptr, pAddresses, &outBufLen);
        @     if (dwRetVal == NO_ERROR) {
        @         PIP_ADAPTER_ADDRESSES pCurrAddresses = pAddresses;
        @         while (pCurrAddresses) {
        @             adapterCount++;
        @ @<临时信息>=pCurrAddresses->FriendlyName;
        返回的网卡名称.加入成员 (临时信息)
        @ @<临时信息>=pCurrAddresses->Description;
        返回的网卡描述.加入成员 (临时信息)
        @             if (pCurrAddresses->PhysicalAddressLength > 0) {
        @                 std::ostringstream macStream;
        @                 macStream << std::hex << std::setfill('0');
        @                 for (DWORD i = 0; i < pCurrAddresses->PhysicalAddressLength; i++) {
        @                     if (i > 0) macStream << "-";
        @                     macStream << std::setw(2) 
        @                              << static_cast<int>(pCurrAddresses->PhysicalAddress[i]);
        @                 }
        @ @<临时信息>=macStream.str().c_str();
        返回的网卡MAC.加入成员 (临时信息)
        @             } else {
        返回的网卡MAC.加入成员 ("N/A")
        @             }
        @             std::wcout << std::endl;
        @             pCurrAddresses = pCurrAddresses->Next;
        @         }
        @     }
        @     if (pAddresses) free(pAddresses);
        @     WSACleanup();
        @     return adapterCount;
    }
}

