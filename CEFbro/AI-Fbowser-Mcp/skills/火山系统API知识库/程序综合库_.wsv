类 鼠标按键事件类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.发送模拟鼠键\"" @全局类 = 真>
{
    方法 键盘_发送模拟按键 <公开 静态 折叠>
    参数 句柄 <类型 = 变整数>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">
    参数 字母是否大写 <类型 = 逻辑型 @默认值 = 假>
    {
        如果 (字母是否大写 == 假)
        {
            投递消息_ (句柄, 257, 键代码, 0)
        }
        否则
        {
            投递消息_ (句柄, 258, 键代码, 0)
        }
    }

    方法 鼠标_发送鼠标双击 <公开 静态 注释 = "左键双击" 折叠>
    参数 句柄 <类型 = 变整数>
    参数 横向位置 <类型 = 整数 @默认值 = 0>
    参数 纵向位置 <类型 = 整数 @默认值 = 0>
    {
        投递消息_ (句柄, 515, 0, 横向位置 + 纵向位置 * 65536)
        投递消息_ (句柄, 514, 0, 横向位置 + 纵向位置 * 65536)
    }

    方法 鼠标_发送鼠标单击 <公开 静态 注释 = "左键单击" 折叠>
    参数 句柄 <类型 = 变整数>
    参数 是否等待 <类型 = 逻辑型 @默认值 = 假>
    参数 横向位置 <类型 = 整数 @默认值 = 0>
    参数 纵向位置 <类型 = 整数 @默认值 = 0>
    {
        如果 (是否等待 == 假)
        {
            投递消息_ (句柄, 513, 1, 横向位置 + 纵向位置 * 65536)
            投递消息_ (句柄, 514, 0, 横向位置 + 纵向位置 * 65536)
        }
        否则
        {
            发送消息_ (句柄, 513, 1, 横向位置 + 纵向位置 * 65536)
            发送消息_ (句柄, 514, 0, 横向位置 + 纵向位置 * 65536)
        }
    }

    方法 鼠标_发送鼠标滚轮 <公开 静态 折叠>
    参数 句柄 <类型 = 变整数>
    参数 类型 <类型 = 整数 注释 = "判断滚动方向，下滚：1　上滚：2" @默认值 = 1>
    {
        如果 (类型 == 1)
        {
            投递消息_ (句柄, 522, -7864304, 25100873)
        }
        否则
        {
            投递消息_ (句柄, 522, 7864304, 25100873)
        }
    }

    方法 键盘_发送回车 <公开 静态 折叠>
    参数 句柄 <类型 = 变整数>
    {
        投递消息_ (句柄, 260, 13, 0)
        投递消息_ (句柄, 261, 13, 0)
    }

    方法 键盘_发送置组件内容 <公开 静态 注释 = "鼠键_发送置组件内容 (编辑框1.取窗口句柄 (),\"消息内容\")" 折叠>
    参数 句柄 <类型 = 变整数>
    参数 内容 <类型 = 文本型>
    {
        发送消息_ (句柄, 194, 0, 取文本指针 (内容))
    }

    方法 键盘_发送复制 <公开 静态 折叠>
    参数 句柄 <类型 = 变整数>
    {
        键盘_发送全选 (句柄)
        发送消息_ (句柄, 769, 0, 0)
