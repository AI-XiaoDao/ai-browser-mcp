类 字体列表类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.字体安装信息\"" @全局类 = 真>
{

    # @begin
    #     BOOL CALLBACK nEnumFontFamExProc (LPLOGFONTW lplf, LPTEXTMETRIC lptm, DWORD iType, LPARAM lpData) {
    #         (*(@dt<文本数组类>*)lpData).data ().Add (CVolString (lplf->lfFaceName));
    #         return TRUE;
    #     }
    # @end

    方法 字体_枚举字体 <公开 静态 类型 = 整数 注释 = "获取系统中所有的字体名称" 返回值注释 = "成功返回字体数量" 折叠 @禁止流程检查 = 真>
    参数 返回的字体名称 <类型 = 文本数组类 @默认值 = 空对象>
    参数 字符集 <类型 = 字体范围类 注释 = "指定返回哪个字符集的字体，默认为系统当前的区域设置" @默认值 = 字体范围类.简体中文GB2312>
    参数 指定字体 <类型 = 文本型 注释 = "可用于判断指定的字体是否存在" @默认值 = 空对象>
    {
        变量 窗口句柄 <类型 = 变整数 值 = 0>
        @ @<返回的字体名称>.data ().RemoveAll ();
        @ HDC hdc = ::GetDC ((@<窗口句柄> == 0) ? NULL : (HWND)@<窗口句柄>);
        @ LOGFONTW lf;
        @ memset (&lf, 0, sizeof (LOGFONTW));
        @ lf.lfCharSet = (BYTE)@<字符集>;
        @ if (@<指定字体>.GetLength ()<= 32) lstrcat (lf.lfFaceName, @<指定字体>.GetText ());
        @ ::EnumFontFamiliesExW (hdc, (LPLOGFONTW)&lf, (FONTENUMPROCW)&nEnumFontFamExProc, (LPARAM)&@<返回的字体名称>, 0);
        @ ::ReleaseDC ((@<窗口句柄> == 0) ? NULL : (HWND)@<窗口句柄>, hdc);
        @ return (INT)@<返回的字体名称>.data ().GetCount ();
    }
}

