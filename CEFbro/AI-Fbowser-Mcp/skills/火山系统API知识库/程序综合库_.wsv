    变量 远程桌面连接 <公开 静态 类型 = 文本型 值 = "mstsc">
    变量 远程桌面连接防失效 <公开 静态 类型 = 文本型 值 = "%windir%\\System32\\tscon.exe ID /dest:console" 注释 = "防止服务器关闭远程桌面连接后，鼠标、键盘、剪切板等失效">
    变量 网络连接设置 <公开 静态 类型 = 文本型 值 = "ncpa.cpl">
    变量 日期和时间 <公开 静态 类型 = 文本型 值 = "timedate.cpl" 注释 = "控制面板">
    变量 日期和时间2 <公开 静态 类型 = 文本型 值 = "start ms-settings:dateandtime">
    变量 系统属性 <公开 静态 类型 = 文本型 值 = "control sysdm.cpl">
    变量 系统设置 <公开 静态 类型 = 文本型 值 = "start ms-settings:system">
    变量 卸载程序 <公开 静态 类型 = 文本型 值 = "appwiz.cpl">
    变量 防火墙 <公开 静态 类型 = 文本型 值 = "control firewall.cpl">
    变量 蓝牙和其他设备 <公开 静态 类型 = 文本型 值 = "start ms-settings:bluetooth">
    变量 电源和睡眠 <公开 静态 类型 = 文本型 值 = "start ms-settings:powersleep">
    变量 设备和打印机 <公开 静态 类型 = 文本型 值 = "control printers">
    变量 查看正在打印 <公开 静态 类型 = 文本型 值 = "rundll32 printui.dll,PrintUIEntry /o /n \"">
    变量 电源 <公开 静态 类型 = 文本型 值 = "powercfg.cpl">
