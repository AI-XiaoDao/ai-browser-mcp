    方法 窗口_置窗口样式 <公开 静态 注释 = "设置窗口有无边框、最大化、最小化、可否调节大小等" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否隐藏边框 <类型 = 逻辑型 注释 = "真：无边框窗口　；本参设置真后，除调整大小外，其它参数均失效。如果再保留了大小可调节，将只剩下边框而无标题栏" @默认值 = 假>
    参数 是否有最大化 <类型 = 逻辑型 注释 = "真：显示最大化按钮" @默认值 = 假>
    参数 是否有最小化 <类型 = 逻辑型 注释 = "真：显示最小化按钮" @默认值 = 真>
    参数 是否有调整大小 <类型 = 逻辑型 注释 = "真：窗口大小可调节" @默认值 = 假>
    参数 是否隐藏图标 <类型 = 逻辑型 注释 = "真：隐藏图标，并隐藏标题栏所有控件　；本参设置真后，除调整大小外，其它参数均失效" @默认值 = 假>
    {
        @ bool 无边框 = @<是否隐藏边框>;
        @ bool 最大化 = @<是否有最大化>;
        @ bool 最小化 = @<是否有最小化>;
        @ bool 可调节 = @<是否有调整大小>;
        @ bool 可隐藏 = @<是否隐藏图标>;
        @ if (无边框==true)
        @ {
        @   if (可调节==true)
        @    {
        @     ::SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE, GetWindowLong((HWND)@<窗口句柄>,GWL_STYLE) & ~WS_CAPTION|WS_THICKFRAME);
        @     ::SetWindowPos((HWND)@<窗口句柄>,NULL,0,0,0,0,SWP_NOMOVE|SWP_NOSIZE|SWP_FRAMECHANGED);
        @    }
        @   else
        @    {
        @     SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_POPUP|WS_VISIBLE);
        @    }
        @ }
        @ else if (可隐藏==true)
        @ {
        @   if (可调节==true)
        @    {
        @     SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_CAPTION|WS_THICKFRAME|WS_VISIBLE);
        @    }
        @   else
        @    {
        @     SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_POPUP|WS_VISIBLE);
        @    }
        @ }
        @ else if(最大化==true && 最小化==true && 可调节==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_THICKFRAME|WS_MINIMIZEBOX|WS_MAXIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最大化==true && 最小化==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_MINIMIZEBOX|WS_MAXIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最大化==true && 可调节==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_THICKFRAME|WS_MAXIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最小化==true && 可调节==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_THICKFRAME|WS_MINIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最大化==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_MAXIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最小化==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_MINIMIZEBOX|WS_VISIBLE);
        @ }
        @ else if(最小化==false && 最大化==false && 可调节==true)
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_THICKFRAME|WS_VISIBLE);
        @ }
        @ else
        @ {
        @ SetWindowLong((HWND)@<窗口句柄>,GWL_STYLE,WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_VISIBLE);
        @ }
    }

    方法 窗口_置窗口无边框 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 偏移量 <类型 = 整数 值 = -16>
        变量 替换值 <类型 = 变整数 值 = 369164288>
        @ SetWindowLongA((HWND)@<窗口句柄>,@<偏移量>,(long)@<替换值>);
    }

    方法 窗口_窗口句柄是否有效 <公开 静态 类型 = 逻辑型 返回值注释 = "有效返回真" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return IsWindow((HWND)@<窗口句柄>);
    }

    方法 窗口_窗口是否激活 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ WINDOWINFO pwi;
        @ memset(&pwi, 0, sizeof(WINDOWINFO));
        @ pwi.cbSize = sizeof(WINDOWINFO);
        @ GetWindowInfo((HWND)@<窗口句柄>, &pwi);
        @ return (BOOL)pwi.dwWindowStatus;
    }

    方法 窗口_窗口是否响应 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return SendMessageTimeoutW((HWND)@<窗口句柄>, 0, 0, 0, SMTO_ABORTIFHUNG, 128, 0);
    }

    方法 窗口_窗口是否存在 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @默认值 = -1>
    {
        如果真 (窗口句柄 == -1)
        {
            窗口句柄 = 窗口属性api2.GetForegroundWindow ()
        }
        返回 (窗口属性api2.IsWindow (窗口句柄))
    }

    方法 窗口_置窗口透明 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 透明区颜色 <类型 = 整数 注释 = "让该区域透明">
    {
        @ int ret;
        @ HWND hwnd = (HWND)@<窗口句柄>; 
        @ ret = GetWindowLongPtr(hwnd, GWL_EXSTYLE);
        @ ret |= WS_EX_LAYERED; 
        @ SetWindowLongPtr(hwnd, GWL_EXSTYLE, ret);
        @ SetLayeredWindowAttributes(hwnd, (COLORREF)@<透明区颜色>, 0, LWA_COLORKEY); 
    }

    方法 窗口_置窗口透明度 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 透明度 <类型 = 整数 注释 = "0-255之间，0完全透明，255完全不透明">
    {
        @ SetWindowLongPtr((HWND)@<窗口句柄>, GWL_EXSTYLE,
        @ GetWindowLongPtr((HWND)@<窗口句柄>, GWL_EXSTYLE) | WS_EX_LAYERED);
        @ SetLayeredWindowAttributes((HWND)@<窗口句柄>, 0, @<透明度>, LWA_ALPHA);
    }

    方法 窗口_重绘窗口 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 "">
    参数 清除背景 <类型 = 逻辑型 注释 = "真为清除" @默认值 = 假>
    {
        @ return InvalidateRect((HWND)@<窗口句柄>, NULL, @<清除背景>);
    }

    方法 窗口_刷新窗口 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return UpdateWindow((HWND)@<窗口句柄>);
    }

    方法 窗口_禁止关闭窗口 <公开 静态 类型 = 逻辑型 注释 = "不允许通过窗口关闭按钮来关闭窗口" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否禁止 <类型 = 逻辑型 注释 = "默认为禁止关闭" @默认值 = 真>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ HMENU hMenu = GetSystemMenu(hWnd, false);
        @ if (!hMenu) return false;
        @ int uEnable = MF_BYPOSITION;
        @ if (@<是否禁止>) uEnable |= MF_GRAYED;
        @ EnableMenuItem(hMenu, 6, uEnable);
        @ RECT rc;
        @ GetWindowRect(hWnd, &rc);
        @ return RedrawWindow(NULL, &rc, 0, RDW_INVALIDATE | RDW_ALLCHILDREN | RDW_UPDATENOW);
    }

    方法 程序_隐藏任务栏图标 <公开 静态 注释 = "隐藏任务栏上显示的程序图标" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ DWORD exStyle = GetWindowLongW((HWND)@<窗口句柄>, GWL_EXSTYLE);
        @ exStyle &= ~WS_EX_APPWINDOW;
        @ exStyle |= WS_DISABLED;
        @ SetWindowLongW((HWND)@<窗口句柄>, GWL_EXSTYLE, exStyle);
        @ SetWindowPos((HWND)@<窗口句柄>, nullptr, 0, 0, 0, 0,
        @     SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_FRAMECHANGED);
    }

    方法 窗口_嵌入桌面 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "待嵌入桌面的窗口句柄">
    {
        @ HWND hWnd = FindWindowW(_T("Progman"), _T("Program Manager"));
        @ return (INT_P)SetParent((HWND)@<窗口句柄>,hWnd);
    }

    方法 窗口_嵌入窗口 <公开 静态 类型 = 变整数 注释 = "嵌入本程序子窗口" 折叠>
    参数 父窗口句柄 <类型 = 变整数>
    参数 待嵌入的窗口 <类型 = 窗口 注释 = "子窗口">
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 是否显示边框 <类型 = 逻辑型 注释 = "是否显示窗口边框" @默认值 = 假>
    {
        变量 窗口值 <类型 = 变整数>
        变量 替换值 <类型 = 变整数>
        变量 窗口属性 <类型 = 窗口属性api>
        变量 子窗口句柄 <类型 = 变整数>
        待嵌入的窗口.可视 = 假
        待嵌入的窗口.创建窗口 ()
        如果真 (是否显示边框 == 假)
        {
            待嵌入的窗口.窗口边框 = 窗口边框类型.无边框
        }
        子窗口句柄 = 待嵌入的窗口.取窗口句柄 ()
        如果真 (宽度 < 1)
        {
            宽度 = 待嵌入的窗口.宽度
        }
        如果真 (高度 < 1)
        {
            高度 = 待嵌入的窗口.高度
        }
        窗口属性.SetParent (子窗口句柄, 父窗口句柄)
        窗口值 = 窗口属性.GetWindowLongA (子窗口句柄, -16)
        替换值 = 位与 (窗口值, 位取反 (-2147483648))
        替换值 = 位或 (替换值, 1073741824)
        如果真 (窗口值 != 替换值)
        {
            窗口属性.SetWindowLongA (子窗口句柄, -16, 替换值)
        }
        窗口属性.MoveWindow (子窗口句柄, 左边, 顶边, 宽度, 高度, 1)
        待嵌入的窗口.可视 = 真
        返回 (子窗口句柄)
    }

    方法 窗口_嵌入窗口2 <公开 静态 注释 = "嵌入外部窗口" 折叠>
    参数 父窗口句柄 <类型 = 变整数>
    参数 子窗口句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    {
        变量 窗口属性 <类型 = 窗口属性api>
        变量 窗口尺寸 <类型 = 矩形_>
        窗口_显示隐藏窗口组件 (子窗口句柄, 窗口显示命令常量.SW_HIDE)
        窗口尺寸 = 窗口_取窗口组件矩形 (子窗口句柄)
        如果真 (宽度 < 1)
        {
            宽度 = 窗口尺寸.右边 - 窗口尺寸.左边
        }
        如果真 (高度 < 1)
        {
            高度 = 窗口尺寸.底边 - 窗口尺寸.顶边
        }
        窗口属性.SetParent (子窗口句柄, 父窗口句柄)
        窗口属性.MoveWindow (子窗口句柄, 左边, 顶边, 宽度, 高度, 1)
        窗口_显示隐藏窗口组件 (子窗口句柄, 窗口显示命令常量.SW_SHOWNORMAL)
    }

    方法 窗口_嵌入窗口3 <公开 静态 注释 = "嵌入本程序子窗口" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数>
    参数 待嵌入的窗口 <类型 = 窗口 注释 = "子窗口">
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    {
        变量 子窗口句柄 <类型 = 变整数>
        待嵌入的窗口.可视 = 假
        待嵌入的窗口.创建窗口 ()
        子窗口句柄 = 待嵌入的窗口.取窗口句柄 ()
        如果真 (宽度 < 1)
        {
            宽度 = 待嵌入的窗口.宽度
        }
        如果真 (高度 < 1)
        {
            高度 = 待嵌入的窗口.高度
        }
        窗口_嵌入窗口4 (父窗口句柄, 子窗口句柄, , , 宽度, 高度)
        待嵌入的窗口.可视 = 真
    }

    方法 窗口_嵌入窗口4 <公开 静态 类型 = 逻辑型 注释 = "嵌入外部窗口" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数>
    参数 子窗口句柄 <类型 = 变整数 注释 = "子窗口">
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "默认为子窗口本身尺寸" @默认值 = 0>
    参数 是否显示边框 <类型 = 逻辑型 注释 = "是否显示窗口边框" @默认值 = 假>
    {
        变量 窗口尺寸 <类型 = 矩形_>
        窗口_显示隐藏窗口组件 (子窗口句柄, 窗口显示命令常量.SW_HIDE)
        如果真 (是否显示边框 == 假)
        {
            窗口_置窗口无边框 (子窗口句柄)
        }
        窗口尺寸 = 窗口_取窗口组件矩形 (子窗口句柄)
        如果真 (宽度 < 1)
        {
            宽度 = 窗口尺寸.右边 - 窗口尺寸.左边
        }
        如果真 (高度 < 1)
        {
            高度 = 窗口尺寸.底边 - 窗口尺寸.顶边
        }
        @ HWND hWnd = (HWND)@<父窗口句柄>,
        @ nhWnd = (HWND)@<子窗口句柄>;
        @ if (!hWnd)
        @ {
        @ HANDLE hWndParentOld = GetPropW(nhWnd, L"hwndparentold_tmp"),
        @ dwStyle = GetPropW(nhWnd, L"styleold_tmp");
        @ SetWindowLongW(nhWnd, GWL_STYLE, (LONG)dwStyle);
        @ SetParent(nhWnd, (HWND)hWndParentOld);
        @ RemovePropW(nhWnd, L"hwndparentold_tmp");
        @ RemovePropW(nhWnd, L"styleold_tmp");
        @ }
        @ else
        @ {
        @ SetParent(nhWnd, hWnd);
        @ HWND hWndParentOld = GetParent(nhWnd);
        @ INT dwStyleOld = GetWindowLongW(nhWnd, GWL_STYLE),
        @ dwStyle = GetWindowLongW(nhWnd, GWL_STYLE),
        @ dwNewStyle = dwStyle & ~WS_POPUP;
        @ dwNewStyle |= WS_CHILD;
        @ SetPropW(nhWnd, L"hwndparentold_tmp", hWndParentOld);
        @ SetPropW(nhWnd, L"styleold_tmp", (HANDLE)dwStyle);
        @ if (dwStyle != dwNewStyle) SetWindowLongW(nhWnd, GWL_STYLE, dwNewStyle);
        @ }
        @ RECT rc;
        @ memset(&rc, 0, sizeof(RECT));
        @ GetWindowRect(nhWnd, &rc);
        @ int m_Width = @<宽度>, m_Height = @<高度>;
        @ if (m_Width == -1) m_Width = rc.right - rc.left;
        @ if (m_Height == -1) m_Height = rc.bottom - rc.top;
        @ bool jg = MoveWindow(nhWnd, @<左边>, @<顶边>, m_Width, m_Height, true);
        窗口_显示隐藏窗口组件 (子窗口句柄, 窗口显示命令常量.SW_SHOWNORMAL)
        @ return jg;
    }
}

类 窗口显示命令常量 <公开 折叠 折叠2 @文档 = "category = \"程序综合库.窗口显示常量\"" @常量类 = 整数>
{
    常量 SW_HIDE <公开 值 = @SW_HIDE 注释 = "(0)：隐藏窗口，并激活其他窗口">
    常量 SW_SHOWNORMAL <公开 值 = @SW_SHOWNORMAL 注释 = "(1)：激活并显示窗口。如果窗口最小化或最大化，则系统将其恢复到原来的尺寸和位置。在首次显示窗口时，通常使用此标志">
    常量 SW_NORMAL <公开 值 = @SW_NORMAL 注释 = "(2)：与 SW_SHOWNORMAL 相同，但窗口不会被激活">
    常量 SW_SHOWMINIMIZED <公开 值 = @SW_SHOWMINIMIZED 注释 = "(3)：激活窗口并将其最小化">
    常量 SW_SHOWMAXIMIZED <公开 值 = @SW_SHOWMAXIMIZED 注释 = "(4)：激活窗口并将其最大化">
    常量 SW_MAXIMIZE <公开 值 = @SW_MAXIMIZE 注释 = "(3)：与 SW_SHOWMAXIMIZED 相同（注意：尽管数值上与 SW_SHOWMINIMIZED 相同，但在上下文中应视为不同）">
    常量 SW_SHOWNOACTIVATE <公开 值 = @SW_SHOWNOACTIVATE 注释 = "(4)：显示窗口但不改变当前激活的窗口">
    常量 SW_SHOW <公开 值 = @SW_SHOW 注释 = "(5)：激活窗口并以当前大小和位置显示它">
    常量 SW_MINIMIZE <公开 值 = @SW_MINIMIZE 注释 = "(6)：最小化窗口且激活下一个顶级窗口">
    常量 SW_SHOWMINNOACTIVE <公开 值 = @SW_SHOWMINNOACTIVE 注释 = "(7)：将窗口最小化但不激活它。当窗口最小化时，此值类似于 SW_SHOWNOACTIVATE">
    常量 SW_SHOWNA <公开 值 = @SW_SHOWNA 注释 = "(8)：以当前状态显示窗口。与 SW_SHOWNOACTIVATE 类似，除了窗口未被最小化或最大化">
    常量 SW_RESTORE <公开 值 = @SW_RESTORE 注释 = "(9)：激活并显示窗口。如果窗口最小化或最大化，则系统将其恢复到原来的尺寸和位置">
    常量 SW_SHOWDEFAULT <公开 值 = @SW_SHOWDEFAULT
            注释 = "(10)：如果程序之前由 ShellExecute 启动，则使用启动应用程序时传递给 CreateProcess 的 STARTUPINFO 结构中的 wShowWindow 成员所指定的行为">
}

类 窗口组件枚举类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.组件枚举\"" @视窗.外部头文件 = "<vector>" @全局类 = 真>
{
    方法 窗口_枚举组件 <公开 静态 类型 = 组件信息类_ 注释 = "枚举当前窗口指定组件信息" 注释 = "同类名情况有：" 注释 = "1、按钮、超级按钮、单选框、颜色选择器、三态选择框、选择框、分组框;"
            注释 = "2、树形框、增强树形框、目录框;" 注释 = "3、编辑框、IP编辑框;" 注释 = "4、图片框、组件布局器;" 注释 = "5、横向滚动条、纵向滚动条;" 注释 = "6、列表框、选择列表框、文件框" 折叠 折叠2
            @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件类名 <类型 = 文本型 注释 = "此参数为组件类名，可直接调用常量如：组件类名常量类.按钮">
    参数 附加标题 <类型 = 文本型 注释 = "当不同组件类名一样时，可设置组件标题，然后多一层标题筛选(模糊筛选)，结果更准确。默认则不参与筛选" @默认值 = "">
    参数 附加宽度 <类型 = 整数 注释 = "当不同组件类名一样时，可设置组件宽度，然后多一层宽度筛选，结果更准确。默认则不参与筛选，附加宽高和附加标题参数，只需要提供一种即可" @默认值 = -1>
    参数 附加高度 <类型 = 整数 注释 = "当不同组件类名一样时，可设置组件高度，然后多一层高度筛选，结果更准确。默认则不参与筛选，宽度和高度需要同时提供" @默认值 = -1>
    {
        变量 句柄 <类型 = 变整数>
        变量 句柄组 <类型 = 变整数数组类>
        变量 窗口信息类 <类型 = 组件信息类_>
        窗口_枚举窗口句柄 (父窗口句柄, 组件类名, 句柄组)
        句柄组.枚举循环 ()
        {
            句柄 = 句柄组.取枚举值 ()
            如果真 (窗口_取窗口组件类名 (句柄) == 组件类名)
            {
                如果 (附加标题 != "")
                {
                    如果真 (寻找文本 (窗口_取窗口组件标题 (句柄), 附加标题, , 真) != -1)
                    {
                        窗口信息类.控件句柄.加入成员 (句柄)
                        窗口信息类.控件ID.加入成员 (窗口_取窗口组件ID (句柄))
                        窗口信息类.控件标题.加入成员 (窗口_取窗口组件标题 (句柄))
                        窗口信息类.控件左边.加入成员 (窗口_取窗口组件左边 (句柄))
                        窗口信息类.控件顶边.加入成员 (窗口_取窗口组件顶边 (句柄))
                        窗口信息类.控件宽度.加入成员 (窗口_取窗口组件宽度 (句柄))
                        窗口信息类.控件高度.加入成员 (窗口_取窗口组件高度 (句柄))
                    }
                }
                否则 (附加宽度 > -1 && 附加高度 > -1)
                {
                    如果 (窗口_取窗口组件宽度 (句柄) == 附加宽度 && 窗口_取窗口组件高度 (句柄) == 附加高度)
                    {
                        窗口信息类.控件句柄.加入成员 (句柄)
                        窗口信息类.控件ID.加入成员 (窗口_取窗口组件ID (句柄))
                        窗口信息类.控件标题.加入成员 (窗口_取窗口组件标题 (句柄))
                        窗口信息类.控件左边.加入成员 (窗口_取窗口组件左边 (句柄))
                        窗口信息类.控件顶边.加入成员 (窗口_取窗口组件顶边 (句柄))
                        窗口信息类.控件宽度.加入成员 (窗口_取窗口组件宽度 (句柄))
                        窗口信息类.控件高度.加入成员 (窗口_取窗口组件高度 (句柄))
                    }
                }
                否则
                {
                    窗口信息类.控件句柄.加入成员 (句柄)
                    窗口信息类.控件ID.加入成员 (窗口_取窗口组件ID (句柄))
                    窗口信息类.控件标题.加入成员 (窗口_取窗口组件标题 (句柄))
                    窗口信息类.控件左边.加入成员 (窗口_取窗口组件左边 (句柄))
                    窗口信息类.控件顶边.加入成员 (窗口_取窗口组件顶边 (句柄))
                    窗口信息类.控件宽度.加入成员 (窗口_取窗口组件宽度 (句柄))
                    窗口信息类.控件高度.加入成员 (窗口_取窗口组件高度 (句柄))
                }
            }
        }
        返回 (窗口信息类)
    }

    方法 窗口_枚举窗口 <公开 静态 类型 = 控件信息类_ 注释 = "枚举当前窗口所有组件信息" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        变量 句柄 <类型 = 变整数>
        变量 句柄组 <类型 = 变整数数组类>
        变量 窗口信息类 <类型 = 控件信息类_>
        窗口_枚举窗口句柄 (父窗口句柄, , 句柄组)
        窗口信息类.控件句柄 = 句柄组
        句柄组.枚举循环 ()
        {
            句柄 = 句柄组.取枚举值 ()
            窗口信息类.控件ID.加入成员 (窗口_取窗口组件ID (句柄))
            窗口信息类.控件标题.加入成员 (窗口_取窗口组件标题 (句柄))
            窗口信息类.控件类名.加入成员 (窗口_取窗口组件类名 (句柄))
            窗口信息类.控件左边.加入成员 (窗口_取窗口组件左边 (句柄))
            窗口信息类.控件顶边.加入成员 (窗口_取窗口组件顶边 (句柄))
            窗口信息类.控件宽度.加入成员 (窗口_取窗口组件宽度 (句柄))
            窗口信息类.控件高度.加入成员 (窗口_取窗口组件高度 (句柄))
        }
        返回 (窗口信息类)
    }

    # @ struct ENUMCHILDINFO
    # @ {
    # @     CVolString lpClassName;
    # @     @dt<变整数数组类>* aryhWnd;
    # @ };
    # @ BOOL CALLBACK EnumChildProc(HWND hWnd, ENUMCHILDINFO* lParam) {
    # @     if (hWnd) {
    # @         TCHAR szClassName[MAX_PATH] = { 0 };
    # @         GetClassName(hWnd, szClassName, MAX_PATH);
    # @         if (lParam->lpClassName.IsNullObject() || (INT)lParam->lpClassName.compare((CVolString)szClassName, FALSE) == 0) {
    # @             lParam->aryhWnd->data().Add2((@dt<变整数>)hWnd);
    # @         }
    # @         return TRUE;
    # @     }
    # @     return FALSE;
    # @ }

    方法 窗口_枚举窗口句柄 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "0：枚举屏幕上所有的顶级窗口句柄　指定句柄：枚举该父句柄下所有组件句柄" @默认值 = 0>
    参数 组件类名 <类型 = 文本型 @默认值 = 空对象>
    参数 返回的窗口句柄 <类型 = 变整数数组类>
    {
        @ @<返回的窗口句柄>.data().RemoveAll();
        @ ENUMCHILDINFO pMem;
        @ pMem.lpClassName = @<组件类名>;
        @ pMem.aryhWnd = &@<返回的窗口句柄>;
        @ EnumChildWindows((HWND)@<父窗口句柄>, (WNDENUMPROC)EnumChildProc, (LPARAM)&pMem);
        @ return (INT)@<返回的窗口句柄>.data().GetCount();
    }

    方法 窗口_枚举窗口2 <公开 静态 类型 = 整数 注释 = "枚举屏幕上所有的顶级窗口信息" 折叠>
    参数 返回的窗口信息 <类型 = 窗口信息组_>
    {
        变量 数量 <类型 = 整数>
        变量 信息 <类型 = 对象数组类>
        变量 信息类 <类型 = 窗口信息类_>
        数量 = 窗口_枚举窗口3 (信息)
        计次循环 (数量)
        {
            信息类 = (窗口信息类_)信息.取成员 (取循环索引 ())
            返回的窗口信息.窗口句柄.加入成员 (信息类.窗口句柄)
            返回的窗口信息.窗口标题.加入成员 (信息类.窗口标题)
            返回的窗口信息.窗口类名.加入成员 (信息类.窗口类名)
            返回的窗口信息.进程ID.加入成员 (信息类.进程ID)
        }
        返回 (数量)
    }

    # @ static BOOL CALLBACK EnumWindowsProc(HWND hwnd, LPARAM lParam)
    # @ {
    # @     std::vector<HWND>* info = (std::vector<HWND>*) lParam;
    # @     info->push_back(hwnd);
    # @     return TRUE;
    # @ }

    方法 窗口_枚举窗口3 <公开 静态 类型 = 整数 注释 = "枚举屏幕上所有的顶级窗口信息" 折叠 @禁止流程检查 = 真>
    参数 返回的窗口信息 <类型 = 对象数组类 注释 = "取对象成员转强成“窗口信息_”">
    {
        变量 info <类型 = 窗口信息类_>
        返回的窗口信息.删除所有成员 ()
        @ std::vector<HWND> info;
        @ EnumWindows((WNDENUMPROC)&EnumWindowsProc, (LPARAM)&info);
        @ for (DWORD i = 0; i < info.size(); i++)
        @ {
        @     @<info.窗口句柄> = (INT_PTR)info[i];
        info.进程ID = 进程_窗口句柄取进程ID (info.窗口句柄)
        info.窗口标题 = 窗口_取窗口组件标题 (info.窗口句柄)
        info.窗口类名 = 窗口_取窗口组件类名 (info.窗口句柄)
        返回的窗口信息.加入成员 (info)
        @ }
        返回 (返回的窗口信息.取成员数 ())
    }

    方法 窗口_穷举窗口句柄 <公开 静态 类型 = 变整数数组类 返回值注释 = "返回所有有效的窗口句柄" 折叠>
    参数 起始数 <类型 = 整数 @默认值 = 500>
    参数 穷举数量 <类型 = 整数 @默认值 = 6000000>
    {
        变量 句柄组 <类型 = 变整数数组类>
        变量 i <类型 = 整数>
        循环 (起始数, 穷举数量, i)
        {
            如果真 (窗口_窗口句柄是否有效 (i))
            {
                句柄组.加入成员 (i)
            }
        }
        返回 (句柄组)
    }
}

类 窗口组件位置尺寸类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.窗口尺寸调整\"" @全局类 = 真>
{
    方法 窗口_置窗口组件位置大小 <公开 静态 类型 = 逻辑型 注释 = "改变窗口组件的位置或尺寸，只支持MFC、WTL库" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数 @默认值 = -1>
    参数 顶边 <类型 = 整数 @默认值 = -1>
    参数 宽度 <类型 = 整数 @默认值 = -1>
    参数 高度 <类型 = 整数 @默认值 = -1>
    {
        @ HWND hWnd = (HWND)@<句柄>;
        @ RECT rc;
        @ GetWindowRect(hWnd, &rc);
        @ LONG left = @<左边>,
        @ top = @<顶边>,
        @ width = @<宽度>,
        @ height = @<高度>;
        @ if (left == -1) left = rc.left;
        @ if (top == -1) top = rc.top;
        @ if (width == -1) width = rc.right - rc.left;
        @ if (height == -1) height = rc.bottom - rc.top;
        @ return MoveWindow(hWnd, left, top, width, height, true);
    }

    方法 窗口_置窗口最小化 <公开 静态 折叠 折叠2 @视窗.外部头文件 = "<Windows.h>" @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ CloseWindow((HWND)@<窗口句柄>);
    }

    方法 窗口_置窗口最大化 <公开 静态 注释 = "会覆盖系统桌面任务栏区" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ ShowWindow((HWND)@<窗口句柄>, SW_SHOWMAXIMIZED);
    }

    方法 窗口_置窗口最大化2 <公开 静态 注释 = "不会覆盖系统桌面任务栏区" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否无边框 <类型 = 逻辑型 @默认值 = 假>
    {
        @ RECT rect1; 
        @ GetWindowRect((HWND)@<窗口句柄>, &rect1);
        @         int width1 = rect1.right - rect1.left;  
        @         int height1 = rect1.bottom - rect1.top;
        @ RECT rect2;
        @ GetClientRect((HWND)@<窗口句柄>, &rect2);
        @         int width2 = rect2.right - rect2.left;  
        @         int height2 = rect2.bottom - rect2.top;
        @         int width3 = width1 - width2;
        @         int width4 =width3;
        @         int height3 = height1 - height2;

        @     APPBARDATA appBarData;
        @     appBarData.cbSize = sizeof(APPBARDATA);
        @ SHAppBarMessage(ABM_GETTASKBARPOS, &appBarData);
        @         int height4 = appBarData.rc.bottom - appBarData.rc.top;
        @   height4 = height4-height3;

        @ if(@<是否无边框>==true) 
        @ {
        @ width3 = width4 = height4 = 0;
        @ }
        @ else
        @ {
        @ width3 = -width3/2;
        @ }
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ RECT workArea;  
        @ SystemParametersInfo(SPI_GETWORKAREA, 0, &workArea, 0);  
        @ SetWindowPos(hWnd, HWND_TOP, width3, workArea.top,  
        @     workArea.right - workArea.left+width4, workArea.bottom - workArea.top+height4,  
        @     SWP_NOZORDER | SWP_NOACTIVATE);  
    }

    方法 窗口_置窗口还原 <公开 静态 类型 = 逻辑型 注释 = "恢复一个最小化的窗口" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return OpenIcon((HWND)@<窗口句柄>);
    }

    方法 窗口_置窗口还原2 <公开 静态 注释 = "将窗口还原到最近一次的大小和位置" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ ShowWindow((HWND)@<窗口句柄>, SW_RESTORE);
    }

    方法 窗口_取窗口组件左边 <公开 静态 类型 = 整数 注释 = "支持窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    {
        @ RECT rt;
        @ ::GetWindowRect((HWND)@<句柄>,&rt);
        @ return rt.left;
    }

    方法 窗口_取窗口组件顶边 <公开 静态 类型 = 整数 注释 = "支持窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    {
        @ RECT rt;
        @ ::GetWindowRect((HWND)@<句柄>,&rt);
        @ return rt.top;
    }

    方法 窗口_取窗口组件宽度 <公开 静态 类型 = 整数 注释 = "支持窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    {
        @ RECT rt;
        @ ::GetWindowRect((HWND)@<句柄>,&rt);
        @ return rt.right- rt.left;
    }

    方法 窗口_取窗口组件高度 <公开 静态 类型 = 整数 注释 = "支持窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    {
        @ RECT rt;
        @ ::GetWindowRect((HWND)@<句柄>,&rt);
        @ return rt.bottom - rt.top;

    }

    方法 窗口_取窗口组件矩形 <公开 静态 类型 = 矩形_ 注释 = "支持窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    {
        变量 rc <类型 = 矩形_>
        @ WINDOWINFO pwi;
        @ memset(&pwi, 0, sizeof(WINDOWINFO));
        @ pwi.cbSize = sizeof(WINDOWINFO);
        @ GetWindowInfo((HWND)@<句柄>, &pwi);
        @ @<rc.左边> = pwi.rcWindow.left;
        @ @<rc.顶边> = pwi.rcWindow.top;
        @ @<rc.右边> = pwi.rcWindow.right;
        @ @<rc.底边> = pwi.rcWindow.bottom;
        @ return @<rc>;
    }

    方法 窗口_取窗口组件坐标 <公开 静态 类型 = 控件坐标值_ 注释 = "返回窗口或组件内的鼠标位置，不包括屏幕坐标，支持窗口或组件" 折叠>
    参数 句柄 <类型 = 变整数>
    {
        变量 坐标 <类型 = 控件坐标值_>
        窗口属性api.ScreenToClient (句柄, 坐标)
        返回 (坐标)
    }
}

类 窗口组件位置尺寸类2_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.窗口尺寸调整\"" @全局类 = 真>
{
    方法 窗口_置窗口组件位置大小_MFC <公开 静态 注释 = "改变窗口组件的位置或尺寸，只支持MFC库" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数 注释 = "  提供新的左边位置,如果当前组件为顶层窗口,则相对屏幕左边位置," 注释 = "否则相对其所处父组件的用户区左边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有左边位置不变."
            折叠2 @默认值 = 数值范围.最小整数值>
    参数 顶边 <类型 = 整数 注释 = "  提供新的顶边位置,如果当前组件为顶层窗口,则相对屏幕顶边位置," 注释 = "否则相对其所处父组件的用户区顶边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有顶边位置不变."
            折叠2 @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供组件新的宽度,如果为-1则保持原有宽度不变." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "提供组件新的高度,如果为-1则保持原有高度不变." @默认值 = -1>
    {
        @ CWnd* pWnd = CWnd::FromHandle((HWND)@<窗口句柄>);
        @ if (pWnd != NULL)
        @ {
        @     CRect rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParentWnd = pWnd->GetParent ();
        @     if (pParentWnd != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParentWnd->ScreenToClient (&rt);
        @     CRect rtOld (rt);
        @     if (@<左边> != INT_MIN)  { rt.right = @<左边> + rt.Width ();  rt.left = @<左边>;  }
        @     if (@<顶边> != INT_MIN)  { rt.bottom = @<顶边> + rt.Height ();  rt.top = @<顶边>;  }
        @     if (@<宽度> != -1)  rt.right = rt.left + @<宽度>;
        @     if (@<高度> != -1)  rt.bottom = rt.top + @<高度>;
        @     if (rtOld != rt)
        @         pWnd->MoveWindow (&rt);
        @ }
    }

    方法 移动_MFC <公开 静态 注释 = "改变窗口组件的位置或尺寸，只支持MFC库" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 左边 <类型 = 整数 注释 = "  提供新的左边位置,如果当前组件为顶层窗口,则相对屏幕左边位置," 注释 = "否则相对其所处父组件的用户区左边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有左边位置不变."
            折叠2 @默认值 = 数值范围.最小整数值>
    参数 顶边 <类型 = 整数 注释 = "  提供新的顶边位置,如果当前组件为顶层窗口,则相对屏幕顶边位置," 注释 = "否则相对其所处父组件的用户区顶边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有顶边位置不变."
            折叠2 @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供组件新的宽度,如果为-1则保持原有宽度不变." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "提供组件新的高度,如果为-1则保持原有高度不变." @默认值 = -1>
    {
        窗口_置窗口组件位置大小_MFC (窗口句柄, 左边, 顶边, 宽度, 高度)
    }

    方法 窗口_置左边_MFC <公开 静态 注释 = "设置组件位置" 折叠>
    参数 组件句柄 <类型 = 变整数>
    参数 所欲设置的位置 <类型 = 整数>
    {
        @ CWnd* pWnd = CWnd::FromHandle((HWND)@<组件句柄>);
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     pWnd->SetWindowPos (NULL, @<所欲设置的位置>, rt.top, 0, 0, (SWP_NOSIZE | SWP_NOACTIVATE | SWP_NOZORDER));
        @ }
    }

    方法 窗口_置顶边_MFC <公开 静态 注释 = "设置组件位置" 折叠>
    参数 组件句柄 <类型 = 变整数>
    参数 所欲设置的位置 <类型 = 整数>
    {
        @ CWnd* pWnd = CWnd::FromHandle((HWND)@<组件句柄>);
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     pWnd->SetWindowPos (NULL, rt.left, @<所欲设置的位置>,  0, 0, (SWP_NOSIZE | SWP_NOACTIVATE | SWP_NOZORDER));
        @ }
    }

