类 连续赋值类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.连续赋值\"" @全局类 = 真>
{
    方法 连续赋值_ <公开 静态 折叠 @嵌入式方法 = "">
    参数 赋值函数 <注释 = "可调用模板：“赋值模板.可视”;" 注释 = "静态方法有且只有2个参数，无返回值;" 注释 = " ★ 函数原型:void fun(Tv 值, Ty & 欲被赋值的对象)." 注释 = " 注意:"
            注释 = " 1. 该函数参数不限制类型." 注释 = " 2. 该函数参数二必须传引用（火山类自动传引用，但基本数据类型需要 @视窗.后缀文本 \"&\")" @匹配方法 = "">
    参数 所欲赋予的值 <注释 = " 该参数将用于在“连续赋值_”定义中传递（传引用为可选，因为火山类自动传引用，基本数据类型一般无需传引用）" @匹配类型 = 所有类型>
    参数 所欲赋值到的变量 <注释 = " 该可扩展对象参数，将且必须在“连续赋值_”定义中传引用（火山类自动传引用，但基本数据类型需要 @视窗.后缀文本 \"&\"）"
            注释 = " 并在其中被执行赋值操作, 该赋值操作不局限于 \"=\"符号, 属性写/方法函数 均可适用" @匹配类型 = 所有类型 @可扩展 = "d_text = \" , \"">
    {
        @ ctag (@<赋值函数>, @<所欲赋予的值>, @<所欲赋值到的变量>)
    }

    # @begin
    # <> <global>
    # <> <include> 
    # #include <functional>
    # #include <type_traits>
    # template <typename F>
    # struct __function_traits;
    # template <typename R, typename... Args>
    # struct __function_traits<R(*)(Args...)> {
    #     using args_types = std::tuple<Args...>;
    # };
    # template <typename R, typename... Args>
    # struct __function_traits<std::function<R(Args...)>> {
    #     using args_types = std::tuple<Args...>;
    # };
    # template <typename F>
    # struct __function_traits : __function_traits<decltype(&F::operator())> {};
    # template <typename C, typename R, typename... Args>
    # struct __function_traits<R(C::*)(Args...) const> {
    #     using args_types = std::tuple<Args...>;
    # };
    # template <typename C, typename R, typename... Args>
    # struct __function_traits<R(C::*)(Args...)> {
    #     using args_types = std::tuple<Args...>;
    # };
    # #ifndef _WIN64
    # template <typename R, typename... Args>
    # struct __function_traits<R(__stdcall*)(Args...)> {
    #     using args_types = std::tuple<Args...>;
    # };
    # #endif
    # template <typename F, typename V, class... T>
    # inline void ctag(F&& fun, V&& value, T&&... args)
    # {
    #     using traits = __function_traits<std::decay_t<F>>;
    #     using Tv = std::tuple_element_t<0, typename traits::args_types>;
    #     using Tf = std::tuple_element_t<1, typename traits::args_types>;
    #     std::function<void(Tv, Tf)> wrapped = std::forward<F>(fun);
    #     std::initializer_list<int>{(wrapped(value, std::forward<T>(args)), 0)...};
    # }
    # <> </include> 
    # <> </global>
    # @end
}

