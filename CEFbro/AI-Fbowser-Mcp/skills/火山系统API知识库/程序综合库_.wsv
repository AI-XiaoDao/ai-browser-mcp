类 窗口启动等待类_ <公开 注释 = "等待判断窗口启动显示完毕" 折叠 @文档 = "category = \"程序综合库.窗口启动等待\"">
{
    变量 额外时长 <类型 = 整数>
    变量 句柄组 <类型 = 变整数数组类>
    变量 时钟1 <类型 = 时钟类_>

    方法 启动监视_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数 注释 = "本窗口句柄">
    参数 额外延迟时长 <类型 = 整数 注释 = "默认不延迟。当窗口启动显示完成后是否额外等待" @默认值 = 0>
    {
        句柄组.加入成员 (窗口句柄)
        额外时长 = 额外延迟时长
        时钟1.启动时钟_ (2)
    }

    方法 时钟类__周期事件_ <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_>
    参数 标记值 <类型 = 整数>
    参数 时钟ID <类型 = 整数>
    {
        变量 总数 <类型 = 整数>
        变量 i <类型 = 整数>
        总数 = 句柄组.取成员数 ()
        循环 (, 总数, i)
        {
            如果真 (窗口_窗口是否可见 (句柄组.取成员 (总数 - i - 1)))
            {
                如果真 (额外时长 > 0)
                {
                    延迟2_ (额外时长)
                }
                启动完毕事件 (句柄组.取成员 (总数 - i - 1))
                句柄组.删除成员 (总数 - i - 1)
            }
        }
        如果真 (句柄组.取成员数 () == 0)
        {
            时钟1.停止时钟_ ()
        }
        返回 (0)
    }

    方法 启动完毕事件 <公开 定义事件 类型 = 整数 注释 = "窗口启动完毕显示后触发本事件" 折叠>
    参数 窗口句柄 <类型 = 变整数 注释 = "如果是多个窗口时，以此判断">
}

