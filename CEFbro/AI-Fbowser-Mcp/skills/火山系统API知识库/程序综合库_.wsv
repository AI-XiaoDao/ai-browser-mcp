        @ PostMessage((HWND)@<窗口句柄>,WM_MENUCOMMAND,@<子项索引>,(LPARAM)GetSubMenu(GetSubMenu(::GetMenu((HWND)@<窗口句柄>),@<菜单列索引>),@<主项索引>));
    }

    方法 菜单_模拟点击菜单C <公开 静态 注释 = "数字名点击命令无效时，使用本命令测试" 折叠>
    参数 窗口句柄 <类型 = 变整数>
