类 微信程序多开类_ <公开 折叠 @文档 = "category = \"程序综合库.微信多开\"">
{
    变量 互斥 <类型 = 互斥体类_>

    方法 微信多开_ <公开 类型 = 逻辑型 注释 = "如果是非通过本命令打开的微信，请先结束掉" 折叠>
    参数 运行数量 <类型 = 整数 @默认值 = 2>
    参数 微信路径 <类型 = 文本型 注释 = "默认留空可自动获取，如果获取失败可手动指定。例如“C:\\\\wx\\WeChat.exe”" @默认值 = "">
    参数 微信主程序名 <类型 = 逻辑型 注释 = "真：WeChat.exe   假：Weixin.exe   (Weixin是最新版微信)" @默认值 = 假>
    {
        变量 键组 <类型 = 文本数组类 编辑时信息 = "0, 58883, 0, 0">
        变量 路径值 <类型 = 文本型 编辑时信息 = "0, 58883, 0, 0">
        变量 结果 <类型 = 逻辑型>
        变量 ID组 <类型 = 整数数组类>
        变量 名称 <类型 = 文本数组类>
        名称.加入成员 ("_WeChat_App_Instance_Identity_Mutex_Name")
        进程_进程提权 ()
        如果 (微信路径 == "")
        {
            路径值 = 注册表读文本_ (2, "Software\\Tencent\\" + 选择 (微信主程序名, "WeChat", "Weixin"), "InstallPath", ) + "\\" + 选择 (微信主程序名, "WeChat", "Weixin") + ".exe"
            如果真 (取文本长度 (路径值) < 13)
            {
                路径值 = 注册表读文本_ (1, "weixin\\DefaultIcon", )
                路径值 = 取文本左边2_ (路径值, ",", 真)
                如果真 (取文本长度 (路径值) < 4)
                {
                    路径值 = 注册表读文本_ (3, "SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\" + 选择 (微信主程序名, "WeChat", "Weixin"), "DisplayIcon")
                    如果真 (取文本长度 (路径值) < 4)
                    {
                        注册表枚举键值名_ (1, "Local Settings\\Software\\Microsoft\\Windows\\Shell\\MuiCache", 键组, , )
                        键组.枚举循环 ()
                        {
                            路径值 = 键组.取枚举值 ()
                            如果真 (寻找文本 (路径值, 选择 (微信主程序名, "WeChat", "Weixin") + ".exe", , 真) != -1)
                            {
                                跳出循环
                            }
                            路径值 = ""
                        }
                    }
                }
            }
            如果真 (取文本长度 (路径值) < 4)
            {
                调试输出 ("获取微信路径失败！！！")
                返回 (假)
            }
        }
        否则 (文件是否存在 (微信路径))
        {
            路径值 = 微信路径
        }
        否则
        {
            调试输出 ("获取微信路径失败！！！")
            返回 (假)
        }
        如果真 (取文本长度 (路径值) > 3)
        {
            如果真 (运行数量 < 1)
            {
                运行数量 = 1
            }
            如果 (文件是否存在 (路径值))
            {
                如果 (微信主程序名)
                {
                    进程_结束进程_批量 ("Weixin.exe")
                    计次循环 (运行数量)
                    {
                        结果 = 互斥.关闭互斥体_路径 (路径值, 名称)
                    }
                }
                否则
                {
                    互斥_关闭互斥体运行程序 (路径值, "_WeChat_App_Instance_Identity_Mutex_Name", 运行数量)
                }
            }
            否则
            {
                调试输出 ("获取微信路径失败！！！")
            }
        }
        返回 (结果)
    }
}

