类 窗口类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.窗口操作\"" @全局类 = 真>
{
    方法 窗口_窗口写字 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 内容 <类型 = 文本型 @默认值 = "水印标记">
    参数 字体 <类型 = 文本型 @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 @默认值 = 20>
    参数 字体颜色 <类型 = 整数 @默认值 = 颜色类.红色>
    参数 横坐标 <类型 = 整数 @默认值 = 5>
    参数 纵坐标 <类型 = 整数 @默认值 = 5>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ if (!hWnd) hWnd = GetForegroundWindow();
        @ HDC hDC = GetDC(hWnd);
        @ if (!hDC) return;
        @ LOGFONTW lf;
        @ memset(&lf, 0, sizeof(LOGFONTW));
        @ lf.lfCharSet = GB2312_CHARSET;
        @ wcscpy(lf.lfFaceName,  @<字体>.GetText());
        @ lf.lfHeight = @<字体大小>;
        @ HFONT hFont = CreateFontIndirectW(&lf);
        @ HGDIOBJ hFontOld = SelectObject(hDC, hFont);
        @ int bkModeOld = SetBkMode(hDC, TRANSPARENT);
        @ COLORREF crFontOld = SetTextColor(hDC, @<字体颜色>);
        @ TextOutW(hDC, @<横坐标>, @<纵坐标>, @<内容>.GetText(), (int)wcslen(@<内容>.GetText()));
        @ SetBkMode(hDC, bkModeOld);
        @ SetTextColor(hDC, crFontOld);
        @ SelectObject(hDC, hFontOld);
        @ DeleteObject(hFont);
        @ ReleaseDC(hWnd, hDC);
    }

    方法 窗口_锁定窗口 <公开 静态 类型 = 逻辑型 注释 = "禁止窗口操作鼠标及键盘" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否锁定 <类型 = 逻辑型 注释 = "真为锁定，假为解锁" @默认值 = 真>
    {
        @ return EnableWindow((HWND)@<窗口句柄>, @<是否锁定> == false);
    }

    方法 窗口_窗口闪烁 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 闪烁类型 <类型 = 整数 注释 = "0、停止　1、标题　2、任务栏　3、标题与任务栏　4、连续" @默认值 = 1>
    参数 闪烁次数 <类型 = 整数 @默认值 = 1>
    参数 闪烁速度 <类型 = 整数 注释 = "单位为毫秒" @默认值 = 0>
    {
        @ FLASHWINFO fi;
        @ memset(&fi, 0, sizeof(FLASHWINFO));
        @ fi.cbSize = sizeof(FLASHWINFO);
        @ fi.hwnd = (HWND)@<窗口句柄>;
        @ fi.uCount = @<闪烁次数>;
        @ fi.dwFlags = @<闪烁类型>;
        @ fi.dwTimeout = @<闪烁速度>;
        @ return FlashWindowEx(&fi);
    }

    方法 程序_取关联程序路径 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 程序来源路径 <类型 = 文本型>
    {
        @ TCHAR appPath[MAX_PATH] = {0};
        @ long status = (long)FindExecutable((LPCWSTR)(INT_P)@<程序来源路径>.GetText (), NULL, appPath); 
        @ if(status > 32) return appPath;
        @ return "File does not exist";
    }

    方法 窗口_限制窗口大小 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 最小宽度 <类型 = 整数 @默认值 = 0>
    参数 最小高度 <类型 = 整数 @默认值 = 0>
    参数 最大宽度 <类型 = 整数 @默认值 = 0>
    参数 最大高度 <类型 = 整数 @默认值 = 0>
    参数 横向位置 <类型 = 整数 注释 = "点击最大化时,左侧间距" @默认值 = 200>
    参数 纵向位置 <类型 = 整数 注释 = "点击最大化时,顶部间距" @默认值 = 50>
    参数 是否取消限制 <类型 = 逻辑型 @默认值 = 假>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ INT_P oldPreviewProc = (INT_P)GetPropW(hWnd, L"Limit size");
        @ if(@<是否取消限制>==true)
        @ {
        @ if (oldPreviewProc)
        @     {
        @     SetWindowLongPtrW(hWnd, GWLP_WNDPROC, oldPreviewProc);
        @     RemovePropW(hWnd, L"Limit size");
        @     RemovePropW(hWnd, L"minimum width");
        @     RemovePropW(hWnd, L"minimum height");
        @     RemovePropW(hWnd, L"maximum width");
        @     RemovePropW(hWnd, L"maximum height");
        @     RemovePropW(hWnd, L"left limit"); 
        @     RemovePropW(hWnd, L"top limit");
        @     }
        @ return;  
        @ }
        @ if (oldPreviewProc)
        @ {
        @     SetWindowLongPtrW(hWnd, GWLP_WNDPROC, oldPreviewProc);
        @     RemovePropW(hWnd, L"Limit size");
        @     RemovePropW(hWnd, L"minimum width");
        @     RemovePropW(hWnd, L"minimum height");
        @     RemovePropW(hWnd, L"maximum width");
        @     RemovePropW(hWnd, L"maximum height");
        @     RemovePropW(hWnd, L"left limit"); 
        @     RemovePropW(hWnd, L"top limit");
        @ }
        @ SetPropW(hWnd, L"minimum width", (HANDLE)@<最小宽度>);
        @ SetPropW(hWnd, L"minimum height", (HANDLE)@<最小高度>);
        @ SetPropW(hWnd, L"maximum width", (HANDLE)@<最大宽度>);
        @ SetPropW(hWnd, L"maximum height", (HANDLE)@<最大高度>);
        @ SetPropW(hWnd, L"left limit", (HANDLE)(LONG)@<横向位置>); 
        @ SetPropW(hWnd, L"top limit", (HANDLE)(LONG)@<纵向位置>); 
        @  oldPreviewProc = (INT_P)SetWindowLongPtrW(hWnd, GWLP_WNDPROC, (LONG_PTR)@<WindowProc>);
        @ SetPropW(hWnd, L"Limit size", (HANDLE)oldPreviewProc);
    }

    方法 WindowProc <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ INT_P oldPreviewProc = (INT_P)GetPropW(hWnd, L"Limit size");
        @ if (@<uMsg> == WM_GETMINMAXINFO && &oldPreviewProc)
        @ {
        @ MINMAXINFO* minMaxInfo = (MINMAXINFO*)@<lParam>;
        @ minMaxInfo->ptMinTrackSize.x = (LONG)GetPropW(hWnd, L"minimum width");
        @ minMaxInfo->ptMinTrackSize.y = (LONG)GetPropW(hWnd, L"minimum height");
        @ minMaxInfo->ptMaxTrackSize.x = (LONG)GetPropW(hWnd, L"maximum width");
        @ minMaxInfo->ptMaxTrackSize.y = (LONG)GetPropW(hWnd, L"maximum height");
        @   
        @     WINDOWPOS* windowPos = (WINDOWPOS*)@<lParam>;
        @         int leftLimit = (int)GetPropW(hWnd, L"left limit");  
        @         int topLimit = (int)GetPropW(hWnd, L"top limit");  
        @         if (windowPos->x < leftLimit)  
        @         {  
        @             windowPos->x = leftLimit;  
        @         }  
        @         if (windowPos->y < topLimit)  
        @         {  
        @             windowPos->y = topLimit;  
        @         }  
        @ return (INT_PTR)DefWindowProcW(hWnd, (UINT)@<uMsg>, (WPARAM)@<wParam>, (LPARAM)@<lParam>);
        @ }
        @ return (INT_PTR)CallWindowProcW((WNDPROC)oldPreviewProc, hWnd, (UINT)@<uMsg>, (WPARAM)@<wParam>, (LPARAM)@<lParam>);
    }

    方法 窗口_窗口总在最前 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否总在最前 <类型 = 逻辑型 @默认值 = 真>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>, hWndInsertAfter = HWND_NOTOPMOST;
        @ if (@<是否总在最前>)
        @ {
        @ SetForegroundWindow(hWnd);
        @ hWndInsertAfter = HWND_TOPMOST;
        @ }
        @ return SetWindowPos(hWnd, hWndInsertAfter, 0, 0, 0, 0, SWP_NOSIZE | SWP_NOMOVE);
    }

    方法 窗口_窗口置顶 <公开 静态 注释 = "非总在最前" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ SendMessage((HWND)@<窗口句柄>,274,61728,0);
        @ SetWindowPos((HWND)@<窗口句柄>,(HWND)-1,0,0,0,0,3);
        @ SetWindowPos((HWND)@<窗口句柄>,(HWND)-2,0,0,0,0,3);
    }

    方法 调整层次_ <公开 静态 类型 = 逻辑型 注释 = "改变窗口组件的当前所处显示层次" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 欲调整到的层次 <类型 = 整数 注释 = "0、顶层 1、底层 -1、最高层 -2、次高层" @默认值 = 0>
    {
        @ return SetWindowPos((HWND)@<窗口句柄>, (HWND)@<欲调整到的层次>, 0, 0, 0, 0, SWP_NOACTIVATE | SWP_NOMOVE | SWP_NOSIZE);
    }

    方法 窗口_调整层次 <公开 静态 类型 = 逻辑型 注释 = "改变窗口组件的当前所处显示层次" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 欲调整到的层次 <类型 = 整数 注释 = "0、顶层 1、底层 -1、最高层 -2、次高层" @默认值 = 0>
    {
        返回 (调整层次_ (窗口句柄, 欲调整到的层次))
    }

    方法 窗口_激活显示窗口 <公开 静态 类型 = 逻辑型 注释 = "支持激活显示最小化窗口" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 样式 <类型 = 窗口显示命令常量 注释 = "默认激活并显示窗口" @默认值 = 窗口显示命令常量.SW_SHOWNORMAL>
    {
        @ ShowWindow((HWND)@<窗口句柄>, (INT)@<样式>);
        @ return SetForegroundWindow((HWND)@<窗口句柄>);
    }

    方法 窗口_圆角化窗口组件 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 圆角宽度 <类型 = 整数 @默认值 = 5>
    参数 圆角高度 <类型 = 整数 @默认值 = 5>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ RECT rc;
        @ ::GetWindowRect(hWnd, &rc);
        @ HRGN hRgn = CreateRoundRectRgn(0, 0, rc.right - rc.left+1, rc.bottom - rc.top+1, @<圆角宽度>, @<圆角高度>);
        @ SetWindowRgn(hWnd, hRgn, true);
        @ DeleteObject(hRgn);
    }

    方法 窗口_显示隐藏窗口组件 <公开 静态 类型 = 逻辑型 注释 = "支持外部窗口或组件" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 样式 <类型 = 窗口显示命令常量 注释 = "默认隐藏窗口" @默认值 = 窗口显示命令常量.SW_HIDE>
    {
