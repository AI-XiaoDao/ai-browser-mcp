类 程序重启类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.程序重启\"" @全局类 = 真>
{
    方法 程序_开机自动运行 <公开 静态 类型 = 逻辑型 注释 = "将程序加入开机自动运行，或取消自动运行" 折叠>
    参数 类型 <类型 = 逻辑型 注释 = "真：加入开机自动运行　假：取消自动运行" @默认值 = 真>
    参数 程序来源 <类型 = 文本型 注释 = "默认留空则为自身程序，否则为指定程序" @默认值 = "">
    {
        变量 结果 <类型 = 逻辑型>
        进程_进程提权 ()
        如果 (程序来源 != "")
        {
            如果真 (文件是否存在 (程序来源) == 假)
            {
                返回 (假)
            }
            如果 (类型 == 真)
            {
                结果 = 注册表写文本_ (3, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 文件_取文件名2 (程序来源), 程序来源)
            }
            否则
            {
                结果 = 注册表删除键值_ (3, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 程序来源)
            }
        }
        否则
        {
            如果 (类型 == 真)
            {
                结果 = 注册表写文本_ (3, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 文件_取文件名2 (程序_取程序完整路径 ()), 程序_取程序完整路径 ())
            }
            否则
            {
                结果 = 注册表删除键值_ (3, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 文件_取文件名2 (程序_取程序完整路径 ()))
            }
        }
        返回 (结果)
    }

    方法 程序_重启程序自身 <公开 静态 折叠>
    参数 是否立即重启 <类型 = 逻辑型 @默认值 = 真>
    参数 重启等等时长 <类型 = 整数 注释 = "当“是否立即重启”为假时，本参数才能起效" @默认值 = 3>
    {
        变量 命令 <类型 = 文本型 值 = "taskkill /f /im \"进程名\" &start \"\" \"程序路径\" &exit">
        变量 命令2 <类型 = 文本型 值 = "taskkill /f /im \"进程名\" &ping 127.0.1 -n 秒 &start \"\" \"程序路径\" &exit">
        如果 (是否为调试版 () == 假)
        {
            如果 (是否立即重启)
            {
                子文本替换_连续 (命令, "进程名", 取执行文件名 (), "程序路径", 取运行目录 () + 取执行文件名 ())
                运行 ("cmd /c " + 命令, , 程序窗口显示方式.隐藏窗口)
            }
            否则
            {
                子文本替换_连续 (命令2, "进程名", 取执行文件名 (), "程序路径", 取运行目录 () + 取执行文件名 (), "秒", 到文本 (重启等等时长))
                运行 ("cmd /c " + 命令2, , 程序窗口显示方式.隐藏窗口)
            }
        }
        否则
        {
            调试输出 ("请在编译后测试重启效果")
        }
    }
}

