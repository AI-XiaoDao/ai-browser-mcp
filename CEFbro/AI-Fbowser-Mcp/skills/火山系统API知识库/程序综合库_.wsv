类 菜单操作类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.菜单操作\"" @全局类 = 真 @视窗.外部头文件 = "string">
{
    方法 菜单_模拟点击菜单 <公开 静态 注释 = "通过菜单标题来寻找点击" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单标题 <类型 = 文本型 注释 = "需要点击的菜单标题">
    参数 是否模糊查找 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 标题组 <类型 = 文本数组类>
        变量 ID组 <类型 = 整数数组类>
        变量 ID值 <类型 = 整数>
        菜单_枚举菜单 (窗口句柄, , , 标题组, ID组, )
        标题组.枚举循环 ()
        {
            如果 (是否模糊查找)
            {
                如果真 (寻找文本 (标题组.取枚举值 (), 菜单标题, , 真) != -1)
                {
                    ID值 = ID组.取成员 (标题组.取枚举索引 ())
                    跳出循环
                }
            }
            否则
            {
                如果真 (标题组.取枚举值 () == 菜单标题)
                {
                    ID值 = ID组.取成员 (标题组.取枚举索引 ())
                    跳出循环
                }
            }
        }
        投递消息_ (窗口句柄, 273, ID值, 0)
    }

    方法 菜单_模拟点击菜单2 <公开 静态 注释 = "通过菜单ID来寻找点击" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单列索引 <类型 = 整数 注释 = "从0开始，纵向顺序，第几个菜单列">
    参数 菜单ID <类型 = 整数>
    {
        变量 根句柄 <类型 = 变整数>
        变量 子句柄 <类型 = 变整数>
        根句柄 = 菜单_取菜单根句柄 (窗口句柄)
        子句柄 = 菜单_取子菜单句柄 (根句柄, 菜单列索引)
        投递消息_ (窗口句柄, 273, 菜单ID, 0)
    }

    方法 菜单_模拟点击菜单3 <公开 静态 注释 = "通过菜单索引来寻找点击" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单列索引 <类型 = 整数 注释 = "从0开始，纵向顺序，第几个菜单列">
    参数 菜单项索引 <类型 = 整数 注释 = "横向顺序，第几行">
    {
        变量 根句柄 <类型 = 变整数>
        变量 子句柄 <类型 = 变整数>
        根句柄 = 菜单_取菜单根句柄 (窗口句柄)
        子句柄 = 菜单_取子菜单句柄 (根句柄, 菜单列索引)
        投递消息_ (窗口句柄, 273, 菜单_取菜单ID (子句柄, 菜单项索引), 0)
    }

    方法 菜单_模拟点击菜单A <公开 静态 注释 = "数字名点击命令无效时，使用本命令测试" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单列索引 <类型 = 整数 注释 = "从0开始，纵向顺序，第几个菜单列">
    参数 菜单项索引 <类型 = 整数 注释 = "横向顺序，第几行">
    参数 是否激活窗口 <类型 = 逻辑型 @默认值 = 真>
    {
        @ if(@<是否激活窗口>==TRUE){
        @ ShowWindow((HWND)@<窗口句柄>, SW_SHOWNOACTIVATE);
        @ SetForegroundWindow((HWND)@<窗口句柄>);}
        @ PostMessage((HWND)@<窗口句柄>,WM_MENUCOMMAND,@<菜单项索引>,(LPARAM)GetSubMenu(::GetMenu((HWND)@<窗口句柄>),@<菜单列索引>));
    }

    方法 菜单_模拟点击菜单B <公开 静态 注释 = "数字名点击命令无效时，使用本命令测试" 折叠>
    参数 窗口句柄 <类型 = 变整数>
