类 程序运行检测类_ <公开 注释 = "检测程序是否有重复运行" 折叠 @文档 = "category = \"程序综合库.程序运行检测\"">
{
    变量 本句柄 <类型 = 变整数>
    变量 本标记 <类型 = 文本型>

    方法 类_清理 <折叠>
    {
        关闭互斥_ ()
    }

    方法 程序是否已运行_ <公开 类型 = 逻辑型 注释 = "检测是否有同类程序已经在运行中(排除自身以外)" 折叠>
    参数 软件标记 <类型 = 文本型 @默认值 = "程序A">
    {
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        如果 (文本是否为空 (本标记))
        {
            循环 (, 50, i)
            {
                如果真 (尝试检测 (软件标记 + 到文本 (i + 1)) == 假)
                {
                    如果 (尝试创建 (软件标记 + 到文本 (i + 1)))
                    {
                        本标记 = 软件标记 + 到文本 (i + 1)
                        跳出循环
                    }
                    否则
                    {
                        循环 (, 50, i2)
                        {
                            如果真 (尝试检测 (软件标记 + 到文本 (i2 + 1)) == 假)
                            {
                                尝试创建 (软件标记 + 到文本 (i2 + 1))
                                本标记 = 软件标记 + 到文本 (i2 + 1)
                                跳出循环
                            }
                        }
                    }
                }
                如果真 (文本是否为空 (本标记) == 假)
                {
                    跳出循环
                }
            }
            如果 (循环检测 (软件标记))
            {
                返回 (真)
            }
        }
        否则
        {
            如果 (循环检测 (软件标记))
            {
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 关闭互斥_ <公开 注释 = "关闭本程序互斥体" 折叠>
    {
        如果 (本句柄 > 0)
        {
            @ CloseHandle((HANDLE)@<本句柄>); 
        }
        本句柄 = 0
    }

    方法 循环检测 <类型 = 逻辑型 注释 = "排除自身外，其余是否存在" 折叠>
    参数 软件标记 <类型 = 文本型 @默认值 = "程序A">
    {
        变量 结果 <类型 = 逻辑型>
        计次循环 (50)
        {
            如果真 (本标记 != 软件标记 + 到文本 (取循环索引 () + 1))
            {
                如果 (尝试检测 (软件标记 + 到文本 (取循环索引 () + 1)))
                {
                    结果 = 真
                }
            }
        }
        返回 (结果)
    }

    方法 尝试检测 <类型 = 逻辑型 注释 = "可创建返回假，不可创建返回真" 折叠 @禁止流程检查 = 真>
    参数 软件标记 <类型 = 文本型 @默认值 = "程序A">
    {
        @ HANDLE hMutex = CreateMutex(NULL, TRUE, @<软件标记>); 
        @ if (GetLastError() == ERROR_ALREADY_EXISTS) {
        @     CloseHandle(hMutex); 
        @ return true;
        @     } else
        @     CloseHandle(hMutex); 
        @ return false;
    }

    方法 尝试创建 <类型 = 逻辑型 注释 = "创建成功返回真，已存在返回假" 折叠 @禁止流程检查 = 真>
    参数 软件标记 <类型 = 文本型 @默认值 = "程序A">
    {
        @ HANDLE hMutex = CreateMutex(NULL, TRUE, @<软件标记>); 
        @ if (GetLastError() == ERROR_ALREADY_EXISTS) {
        @ return false;
        @     } else
        @ @<本句柄>=(@dt<变整数>)hMutex;
        @ return true;
    }
}

