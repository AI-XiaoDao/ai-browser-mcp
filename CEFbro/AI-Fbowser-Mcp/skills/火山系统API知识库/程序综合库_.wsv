    方法 菜单_是否为子菜单 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单项索引 <类型 = 整数 注释 = "横向顺序，第几行">
    {
        @  MENUITEMINFO mii = { sizeof(MENUITEMINFO) };
        @ mii.fMask = MIIM_ID | MIIM_STRING | MIIM_SUBMENU;
        @ int bufferSize = 256;
        @ mii.dwTypeData = new TCHAR[bufferSize];
        @ mii.cch = bufferSize - 1;
        @ GetMenuItemInfo((HMENU)@<菜单句柄>, @<菜单项索引>, TRUE, &mii);
        @ return (bool)mii.hSubMenu;
    }

    方法 菜单_取子菜单标题 <公开 静态 类型 = 文本型 注释 = "只能获取菜单项的标题" 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单ID <类型 = 整数>
    {
        @ const int bufferSize = 256;
        @ TCHAR buffer[bufferSize];
        @  GetMenuString((HMENU)@<菜单句柄>, @<菜单ID>, buffer, bufferSize, MF_BYCOMMAND);
        @ return buffer;
    }

    方法 菜单_取菜单标题 <公开 静态 类型 = 文本型 注释 = "获取关于菜单项的详细标题" 返回值注释 = "返回菜单标题" 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单项索引 <类型 = 整数 注释 = "横向顺序，第几行">
    参数 返回的ID <类型 = 整数类 @默认值 = 空对象>
    {
        @  MENUITEMINFO mii = { sizeof(MENUITEMINFO) };
        @ mii.fMask = MIIM_ID | MIIM_STRING | MIIM_SUBMENU;
        @ int bufferSize = 256;
        @ mii.dwTypeData = new TCHAR[bufferSize];
        @ mii.cch = bufferSize - 1;
        @ GetMenuItemInfo((HMENU)@<菜单句柄>, @<菜单项索引>, TRUE, &mii);
        @       if (mii.hSubMenu) {
        @            @<返回的ID.值>=-1;
        @       }
        @       else {
        @            @<返回的ID.值>=mii.wID;
        @       }
        @ return mii.dwTypeData;
    }

    方法 菜单_取菜单标题2 <公开 静态 类型 = 文本型 注释 = "获取关于菜单项的详细标题" 返回值注释 = "返回菜单标题" 折叠 @禁止流程检查 = 真>
