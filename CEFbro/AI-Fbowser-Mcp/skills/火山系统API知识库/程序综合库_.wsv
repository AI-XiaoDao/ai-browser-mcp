    方法 取菜单根句柄_ <公开 类型 = 变整数 注释 = "从窗口句柄获取到菜单根句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    {
        @ HMENU 菜单句柄 = GetMenu ((HWND)@<窗口句柄>); 
        @ return (INT_P)菜单句柄;
    }

    方法 取子菜单句柄_ <公开 类型 = 变整数 注释 = "多级时，可一级级的往下取" 折叠 @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 菜单项索引 <类型 = 整数 注释 = "菜单项行或列索引">
    {
        @ return (int) GetSubMenu((HMENU)@<菜单根句柄>,@<菜单项索引>);
    }

    方法 弹出菜单_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 横坐标 <类型 = 整数 注释 = "默认为鼠标水平位置" @默认值 = -1>
    参数 纵坐标 <类型 = 整数 注释 = "默认为鼠标垂直位置" @默认值 = -1>
    {
        如果真 (横坐标 == -1)
        {
            横坐标 = 取鼠标水平位置 ()
        }
        如果真 (纵坐标 == -1)
        {
            纵坐标 = 取鼠标垂直位置 ()
        }
        @ TrackPopupMenu((HMENU)@<菜单根句柄>,0,@<横坐标>,@<纵坐标>,0,(HWND)@<窗口句柄>,0);
    }

    方法 修改菜单标题_ <公开 折叠 @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 菜单行索引 <类型 = 整数>
