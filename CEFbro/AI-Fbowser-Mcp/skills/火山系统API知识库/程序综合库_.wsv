类 信息事件类_ <公开 注释 = "用于在同一程序内，跨窗、跨类交互操作，包括支持DLL" 折叠 @文档 = "category = \"程序综合库.信息交互\"">
{
    变量 发送器 <类型 = 事件发送器>
    变量 接收器 <类型 = 事件接收器>
    变量 内存 <类型 = 共享内存类_>
    变量 标识组 <静态 类型 = 文本数组类>

    方法 类_清理 <折叠>
    {
        标识组.删除所有成员 ()
        内存.释放句柄_ ()
    }

    方法 初始化标识_ <公开 类型 = 逻辑型 注释 = "本命令用在接收方" 折叠>
    参数 标识名 <类型 = 文本型 注释 = "可随意命名，唯一标识名，不可重名" @默认值 = "标识">
    参数 是否清空标识 <类型 = 逻辑型 注释 = "清空原有的标识信息" @默认值 = 假>
    {
        变量 数据块 <类型 = 字节集类>
        变量 句柄 <类型 = 变整数>
        如果真 (是否清空标识)
        {
            标识组.删除所有成员 ()
        }
        如果真 (文本是否为空 (标识名))
        {
            标识名 = "标识"
        }
        数据块 = 内存.读共享数据_ (标识名)
        句柄 = 取字节集数据 (数据块, 0, 变整数)
        如果真 (数据块.取字节集长度 () > 0 && 句柄 > 0 && 指针是否有效_ (句柄))
        {
            返回 (假)
        }
        标识组.加入成员 (标识名)
        返回 (内存.写共享数据_ (标识名, 到字节集 (取变量地址 (接收器))))
    }

    方法 取标识信息_ <公开 类型 = 文本数组类 注释 = "取出所有标识信息" 折叠>
    {
        返回 (标识组)
    }

    方法 连接标识_ <公开 类型 = 变整数 注释 = "本命令用在发送方。先执行“初始化标识_”，然后通过此命令连接" 返回值注释 = "成功返回>0" 折叠>
    参数 标识名 <类型 = 文本型 注释 = "要与“初始化标识_”设置的一致" @默认值 = "标识">
    {
        变量 数据块 <类型 = 字节集类>
        变量 句柄 <类型 = 变整数>
        数据块 = 内存.读共享数据_ (标识名)
        句柄 = 取字节集数据 (数据块, 0, 变整数)
        如果真 (数据块.取字节集长度 () > 0 && 句柄 > 0 && 指针是否有效_ (句柄))
        {
            发送器.挂接 (读指针处对象 (句柄, 事件接收器))
        }
        返回 (句柄)
    }

    方法 断开连接_ <公开 注释 = "本命令用在发送方" 折叠>
    {
        发送器.取消挂接 ()
    }

    方法 发送信息_ <公开 类型 = 逻辑型 注释 = "发送的数据将通过“信息到达事件_”输出。本命令用在发送方" 折叠>
    参数 文本参数 <类型 = 文本型 @默认值 = "">
    参数 字节集参数 <类型 = 字节集类 @默认值 = 空对象>
    参数 整数参数 <类型 = 整数 @默认值 = -1>
    参数 变整数参数 <类型 = 变整数 @默认值 = -1>
    参数 小数参数 <类型 = 小数 @默认值 = -1>
    参数 逻辑型参数 <类型 = 逻辑型 @默认值 = 假>
    参数 文本参数组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 字节集参数组 <类型 = 字节集数组类 @默认值 = 空对象>
    参数 整数参数组 <类型 = 整数数组类 @默认值 = 空对象>
    参数 变整数参数组 <类型 = 变整数数组类 @默认值 = 空对象>
    参数 小数参数组 <类型 = 小数数组类 @默认值 = 空对象>
    参数 逻辑型参数组 <类型 = 逻辑型数组类 @默认值 = 空对象>
    {
        变量 结构体 <类型 = 信息事件结构类>
        结构体.文本参数 = 文本参数
        结构体.字节集参数 = 字节集参数
        结构体.整数参数 = 整数参数
        结构体.变整数参数 = 变整数参数
        结构体.小数参数 = 小数参数
        结构体.逻辑型参数 = 逻辑型参数
        结构体.文本参数组 = 文本参数组
        结构体.字节集参数组 = 字节集参数组
        结构体.整数参数组 = 整数参数组
        结构体.变整数参数组 = 变整数参数组
        结构体.小数参数组 = 小数参数组
        结构体.逻辑型参数组 = 逻辑型参数组
        返回 (选择 (发送器.发送事件 (, , 结构体, 1) == 1, 真, 假))
    }

    方法 发送对象_ <公开 类型 = 逻辑型 注释 = "发送的数据将通过“对象到达事件_”输出。本命令用在发送方" 折叠>
    参数 对象参数 <类型 = 对象类 注释 = "新建个类+变量的结构体数据，并公开变量，然后将类名填入此参数即可">
    {
        返回 (选择 (发送器.发送事件 (, , 对象参数, 2) == 1, 真, 假))
    }

    方法 事件接收器_接收到事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 事件接收器>
    参数 标记值 <类型 = 整数>
    参数 事件参数 <类型 = COM变体型数组类>
    参数 事件返回值 <类型 = COM变体型>
    参数 事件附加对象 <类型 = 对象类>
    参数 事件附加值 <类型 = 变整数>
    {
        如果 (事件附加值 == 1)
        {
            变量 结构体 <类型 = 信息事件结构类>
            结构体 = (信息事件结构类)事件附加对象
            信息到达事件_ (结构体.文本参数, 结构体.字节集参数, 结构体.整数参数, 结构体.变整数参数, 结构体.小数参数, 结构体.逻辑型参数, 结构体.文本参数组, 结构体.字节集参数组, 结构体.整数参数组, 结构体.变整数参数组, 结构体.小数参数组, 结构体.逻辑型参数组)
        }
        否则 (事件附加值 == 2)
        {
            对象到达事件_ (事件附加对象)
        }
        返回 (1)
    }

    方法 信息到达事件_ <公开 定义事件 类型 = 整数 折叠>
    参数 文本参数 <类型 = 文本型>
    参数 字节集参数 <类型 = 字节集类>
    参数 整数参数 <类型 = 整数>
    参数 变整数参数 <类型 = 变整数>
    参数 小数参数 <类型 = 小数>
    参数 逻辑型参数 <类型 = 逻辑型>
    参数 文本参数组 <类型 = 文本数组类>
    参数 字节集参数组 <类型 = 字节集数组类>
    参数 整数参数组 <类型 = 整数数组类>
    参数 变整数参数组 <类型 = 变整数数组类>
    参数 小数参数组 <类型 = 小数数组类>
    参数 逻辑型参数组 <类型 = 逻辑型数组类>

    方法 对象到达事件_ <公开 定义事件 类型 = 整数 折叠>
    参数 对象数据 <类型 = 对象类 注释 = "例如新建一个同类型的对象结构数据，命名为“结构体”，然后用如下命令将收到的数据转回结构体." 注释 = "结构体 = (同类型的对象结构数据)对象数据">
}

