类 字体描述类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.字体描述文本\"" @全局类 = 真>
{
    方法 字体_取字体信息 <公开 静态 类型 = 字体信息组_ 折叠>
    参数 字体描述文本 <类型 = 文本型>
    {
        变量 字体信息 <类型 = 字体信息组_>
        变量 数据组 <类型 = 文本数组类>
        子文本替换 (字体描述文本, " ", "")
        数据组 = 取文本中间_批量 ("," + 字体描述文本 + ",", ",", ",")
        如果真 (数据组.取成员数 () == 7)
        {
            字体信息.字体名称 = 数据组.取成员 (0)
            字体信息.字体尺寸 = 文本到整数 (数据组.取成员 (1))
            字体信息.是否加粗 = 选择 (数据组.取成员 (2) == "1", 真, 假)
            字体信息.是否斜体 = 选择 (数据组.取成员 (3) == "1", 真, 假)
            字体信息.是否有下划线 = 选择 (数据组.取成员 (4) == "1", 真, 假)
            字体信息.是否有删除线 = 选择 (数据组.取成员 (5) == "1", 真, 假)
            字体信息.旋转角度 = 文本到整数 (数据组.取成员 (6))
        }
        返回 (字体信息)
    }
}

类 字体信息组_ <公开 注释 = "\"字体_取字体信息\"的辅助类" 折叠 @文档 = "category = \"程序综合库.字体描述文本.附加类\"">
{
    变量 字体名称 <公开 类型 = 文本型>
    变量 字体尺寸 <公开 类型 = 整数>
    变量 是否加粗 <公开 类型 = 逻辑型>
    变量 是否斜体 <公开 类型 = 逻辑型>
    变量 是否有下划线 <公开 类型 = 逻辑型>
    变量 是否有删除线 <公开 类型 = 逻辑型>
    变量 旋转角度 <公开 类型 = 整数>

    #
}

