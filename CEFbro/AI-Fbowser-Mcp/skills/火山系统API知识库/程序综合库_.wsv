类 鼠标指针类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.鼠标指针\"" @全局类 = 真>
{
    方法 鼠标_移动鼠标 <公开 静态 折叠>
    参数 横坐标 <类型 = 变整数>
    参数 纵坐标 <类型 = 变整数>
    {
        @ SetCursorPos(@<横坐标>,@<纵坐标>);
    }

    方法 鼠标_显示隐藏指针 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 是否隐藏 <类型 = 逻辑型 @默认值 = 真>
    {
        @ ::ShowCursor(@<是否隐藏>);
    }

    方法 鼠标_置鼠标指针 <公开 静态 注释 = "修改指定区的鼠标指针类型" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 指针类型 <类型 = 标准鼠标指针类型 注释 = "例如：标准鼠标指针类型.手型" @默认值 = 标准鼠标指针类型.标准箭头型>
    参数 指针路径 <类型 = 文本型 注释 = "扩展名为cur的鼠标指针文件路径" @默认值 = 空对象>
    {
        @ HCURSOR hCursor;
        @ if (!@<指针路径>.IsEmpty())
        @     hCursor = LoadCursorFromFile(@<指针路径>.GetText());
        @ else
        @     hCursor = LoadCursor(NULL, (LPCWSTR)@<指针类型>);
        @ SetClassLongPtr((HWND)@<窗口句柄>, GCLP_HCURSOR, (LONG_PTR)hCursor);
    }

    方法 鼠标_捕获鼠标指针 <公开 静态 折叠>
    参数 句柄 <类型 = 变整数>
    {
        @ SetCapture((HWND)@<句柄>);
    }

    方法 鼠标_释放鼠标指针 <公开 静态 折叠>
    {
        @ ReleaseCapture();
    }
}

