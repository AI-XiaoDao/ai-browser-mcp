    }

    方法 菜单_刷新菜单 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ DrawMenuBar((HWND)@<窗口句柄>);
    }

    方法 菜单_弹出菜单 <公开 静态 折叠>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    参数 菜单根句柄 <类型 = 变整数>
    参数 横坐标 <类型 = 整数 注释 = "默认为鼠标水平位置" @默认值 = -1>
    参数 纵坐标 <类型 = 整数 注释 = "默认为鼠标垂直位置" @默认值 = -1>
    {
        如果真 (横坐标 == -1)
        {
            横坐标 = 取鼠标水平位置 ()
        }
        如果真 (纵坐标 == -1)
        {
            纵坐标 = 取鼠标垂直位置 ()
        }
        @ TrackPopupMenu((HMENU)@<菜单根句柄>,0,@<横坐标>,@<纵坐标>,0,(HWND)@<窗口句柄>,0);
    }

    方法 菜单_置图标 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单行索引 <类型 = 整数>
    参数 标志或ID <类型 = 整数 @默认值 = 1024>
    参数 未选图标句柄 <类型 = 变整数>
    参数 已选图标句柄 <类型 = 变整数>
    {
        @ return SetMenuItemBitmaps ((HMENU)@<菜单句柄>, @<菜单行索引>, @<标志或ID>, (HBITMAP)@<未选图标句柄>,(HBITMAP)@<已选图标句柄>);
    }

    方法 枚举子项 <静态 折叠>
    参数 菜单句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    参数 索引2 <类型 = 整数>
    参数 返回的根标题 <类型 = 文本数组类>
    参数 返回的根句柄 <类型 = 变整数数组类>
    参数 返回的标题 <类型 = 文本数组类>
    参数 返回的ID <类型 = 整数数组类>
    参数 返回的菜单列 <类型 = 整数数组类>
    参数 返回的菜单项索引 <类型 = 整数数组类>
    {
        变量 临时ID <类型 = 整数类>
        变量 临时标题 <类型 = 文本型>
        变量 根句柄 <类型 = 变整数>
        变量 返回的根标题2 <类型 = 文本数组类>
        变量 返回的根句柄2 <类型 = 变整数数组类>
        变量 返回的标题2 <类型 = 文本数组类>
        变量 返回的ID2 <类型 = 整数数组类>
        变量 返回的菜单列2 <类型 = 整数数组类>
        变量 返回的菜单项索引2 <类型 = 整数数组类>
        变量 i <类型 = 整数>
        根句柄 = 菜单_取子菜单句柄 (菜单句柄, 索引)
        循环 (, 菜单_取菜单数量 (根句柄), i)
        {
            临时标题 = 菜单_取菜单标题 (根句柄, i, 临时ID)
            如果真 (菜单_是否为子菜单 (根句柄, i))
            {
                返回的根标题.加入成员 (临时标题)
                返回的根句柄.加入成员 (菜单_取子菜单句柄 (根句柄, i))
                枚举子项 (根句柄, i, 索引2, 返回的根标题2, 返回的根句柄2, 返回的标题2, 返回的ID2, 返回的菜单列2, 返回的菜单项索引2)
                返回的根标题.添加数组 (返回的根标题2)
                返回的根句柄.添加数组 (返回的根句柄2)
                返回的标题.添加数组 (返回的标题2)
                返回的ID.添加数组 (返回的ID2)
                返回的菜单列.添加数组 (返回的菜单列2)
                返回的菜单项索引.添加数组 (返回的菜单项索引2)
            }
            返回的标题.加入成员 (临时标题)
            返回的ID.加入成员 (临时ID.值)
            返回的菜单列.加入成员 (索引2)
            返回的菜单项索引.加入成员 (i)
        }
    }
}

