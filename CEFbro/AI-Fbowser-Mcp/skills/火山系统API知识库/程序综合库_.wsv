    方法 菜单_创建根菜单 <公开 静态 类型 = 变整数 返回值注释 = "返回创建的菜单句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单根名称 <类型 = 文本型>
    {
        变量 子句柄 <类型 = 变整数>
        @ HMENU hMenu = GetMenu ((HWND)@<窗口句柄>); 
        @ HMENU h = CreatePopupMenu ();
        @ @<子句柄>=(@dt<变整数>)h;
        @ AppendMenu (hMenu, 16,(UINT_PTR)h, @<菜单根名称>);
        返回 (子句柄)
    }

    方法 菜单_添加菜单 <公开 静态 类型 = 逻辑型 注释 = "成功返回真" 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单标题 <类型 = 文本型 @默认值 = "">
    参数 类型 <类型 = 整数 注释 = "0、普通 1、禁用 2、打勾 3、下拉菜单 4、分隔条" @默认值 = 0>
    参数 标志或ID <类型 = 整数 @默认值 = 0>
    参数 返回的下拉菜单句柄 <类型 = 变整数类 @默认值 = 空对象>
    {
        如果 (类型 == 0)
        {
            @ return AppendMenu((HMENU)@<菜单句柄>, MF_STRING, @<标志或ID>, @<菜单标题>);
        }
        否则 (类型 == 1)
        {
            @ return AppendMenu((HMENU)@<菜单句柄>, MF_GRAYED, @<标志或ID>, @<菜单标题>);
        }
        否则 (类型 == 2)
        {
            @ return AppendMenu((HMENU)@<菜单句柄>, MF_CHECKED, @<标志或ID>, @<菜单标题>);
        }
        否则 (类型 == 3)
        {
            @ @<返回的下拉菜单句柄.值> = (INT_PTR)CreatePopupMenu();
            @ return AppendMenu((HMENU)@<菜单句柄>, MF_POPUP, @<返回的下拉菜单句柄.值>, @<菜单标题>);
        }
        否则
        {
            @ return AppendMenu((HMENU)@<菜单句柄>, MF_SEPARATOR, 0, NULL);
        }
        返回 (假)
    }

    方法 菜单_插入菜单项 <公开 静态 类型 = 逻辑型 注释 = "可能需要再执行“菜单_刷新菜单”" 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 插入位索引 <类型 = 整数>
    参数 新菜单名称 <类型 = 文本型 注释 = "- 表示添加分隔线">
    参数 新菜单ID <类型 = 整数>
    {
        @ bool jg;
        @ UINT hID = GetMenuItemID ((HMENU)@<菜单句柄>,@<插入位索引>);
        @ if (@<新菜单名称>==L"-") {
        @ jg= InsertMenu((HMENU)@<菜单句柄>,hID, MF_SEPARATOR, @<新菜单ID>,L""); 
        @ }
        @ else {
        @ jg= InsertMenu((HMENU)@<菜单句柄>,hID, MF_UNCHECKED, @<新菜单ID>,@<新菜单名称>);
        @ }
        @ return jg;
    }

    方法 菜单_插入菜单项2 <公开 静态 类型 = 逻辑型 注释 = "可能需要再执行“菜单_刷新菜单”" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单列索引 <类型 = 整数 注释 = "从0开始，纵向顺序，第几个菜单列">
    参数 插入位索引 <类型 = 整数>
    参数 新菜单名称 <类型 = 文本型 注释 = "- 表示添加分隔线">
