类 标记类_ <公开 折叠 @文档 = "category = \"程序综合库.组件标记\"">
{
    方法 添加标记_ <公开 类型 = 逻辑型 注释 = "在指定窗口或组件的属性表中增加一个新项，或者修改一个现有项。;" 注释 = "支持跨窗口跨类" 折叠 折叠2>
    参数 组件句柄 <类型 = 变整数 注释 = "指向的该窗口或组件的句柄;" 注释 = "为空则取窗口句柄" 折叠2 @默认值 = -1>
    参数 标记名 <类型 = 文本型>
    参数 标记值 <类型 = 变整数>
    {
        如果真 (组件句柄 == -1)
        {
            组件句柄 = 取窗口句柄_ ()
        }
        返回 (标记类api.SetPropW (组件句柄, 标记名, 标记值))
    }

    方法 取标记_ <公开 类型 = 变整数 注释 = "支持跨窗口跨类" 折叠>
    参数 组件句柄 <类型 = 变整数 注释 = "指向的该窗口或组件的句柄;" 注释 = "为空则取窗口句柄" 折叠2 @默认值 = -1>
    参数 标记名 <类型 = 文本型>
    {
        如果真 (组件句柄 == -1)
        {
            组件句柄 = 窗口_取窗口组件句柄 ()
        }
        返回 (标记类api.GetPropW (组件句柄, 标记名))
    }

    方法 删除标记_ <公开 类型 = 逻辑型 注释 = "支持跨窗口跨类" 折叠>
    参数 组件句柄 <类型 = 变整数 注释 = "指向的该窗口或组件的句柄;" 注释 = "为空则取窗口句柄" 折叠2 @默认值 = -1>
    参数 标记名 <类型 = 文本型>
    {
        如果真 (组件句柄 == -1)
        {
            组件句柄 = 窗口_取窗口组件句柄 ()
        }
        返回 (标记类api.RemovePropW (组件句柄, 标记名))
    }
}

# //=====

类 同步缩放类_ <公开 折叠 @文档 = "category = \"程序综合库.组件缩放\"">
{
    变量 父句柄 <类型 = 变整数 折叠>
    变量 原窗口宽度 <类型 = 整数>
    变量 原窗口高度 <类型 = 整数>
    变量 左组 <类型 = 整数数组类>
    变量 顶组 <类型 = 整数数组类>
    变量 宽组 <类型 = 整数数组类>
    变量 高组 <类型 = 整数数组类>
    变量 句柄组 <类型 = 变整数数组类>
    变量 父句柄组 <类型 = 变整数数组类>
    变量 父尺寸组 <类型 = "整数数组类 [2]">
    变量 水平句柄列表组 <类型 = "变整数数组类 [20]">
    变量 垂直句柄列表组 <类型 = "变整数数组类 [20]">
    变量 句柄序1 <类型 = 整数>
    变量 句柄序2 <类型 = 整数>
    变量 固定左组 <类型 = 逻辑型数组类>
    变量 固定顶组 <类型 = 逻辑型数组类>
    变量 固定宽组 <类型 = 逻辑型数组类>
    变量 固定高组 <类型 = 逻辑型数组类>
    变量 最小宽组 <类型 = 整数数组类>
    变量 最小高组 <类型 = 整数数组类>
    变量 最小左组 <类型 = 整数数组类>
    变量 最小顶组 <类型 = 整数数组类>
    变量 临时左 <类型 = 整数>
    变量 临时顶 <类型 = 整数>
    变量 临时宽 <类型 = 整数>
    变量 临时高 <类型 = 整数>
    变量 左补 <类型 = 整数 值 = 8>
    变量 顶补 <类型 = 整数 值 = 30>

    方法 初始化缩放_ <公开 折叠>
    参数 父窗口句柄 <类型 = 变整数>
    {
        变量 矩形 <类型 = 矩形_>
        矩形 = 窗口_取窗口组件矩形 (父窗口句柄)
        原窗口宽度 = 矩形.右边 - 矩形.左边
        原窗口高度 = 矩形.底边 - 矩形.顶边
        父句柄 = 父窗口句柄
    }

    方法 加入缩放组_ <公开 注释 = "使同排组件平均水平缩放，使同列组件平均垂直缩放" 折叠>
    参数 父容器句柄 <类型 = 变整数 注释 = "该缩放组件的父窗口或父容器句柄">
    参数 缩放类型 <类型 = 整数 注释 = "1、为水平缩放，2、为垂直缩放；默认为1" @默认值 = 1>
    参数 组件1句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件2句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件3句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件4句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件5句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件6句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件7句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件8句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件9句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件10句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件11句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件12句柄 <类型 = 变整数 @默认值 = 0>
    {
        变量 水平缩放 <类型 = 逻辑型>
        变量 垂直缩放 <类型 = 逻辑型>
        如果真 (句柄序1 > 20 || 句柄序2 > 20)
        {
            信息框_ ("最多支持20组缩放！", 64, "提示！")
            返回
        }
        如果真 (缩放类型 < 1 || 缩放类型 > 2)
        {
            缩放类型 = 1
        }
        如果 (缩放类型 == 1)
        {
            水平缩放 = 真
        }
        否则
        {
            垂直缩放 = 真
        }
        如果真 (父容器句柄 > 0)
        {
            父句柄组.加入成员 (父容器句柄)
            父尺寸组 [0].加入成员 (窗口_取窗口组件宽度 (父容器句柄))
            父尺寸组 [1].加入成员 (窗口_取窗口组件高度 (父容器句柄))
        }
        如果真 (组件1句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件1句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件1句柄, , 句柄序2)
            }
        }
        如果真 (组件2句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件2句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件2句柄, , 句柄序2)
            }
        }
        如果真 (组件3句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件3句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件3句柄, , 句柄序2)
            }
        }
        如果真 (组件4句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件4句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件4句柄, , 句柄序2)
            }
        }
        如果真 (组件5句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件5句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件5句柄, , 句柄序2)
            }
        }
        如果真 (组件6句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件6句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件6句柄, , 句柄序2)
            }
        }
        如果真 (组件7句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件7句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件7句柄, , 句柄序2)
            }
        }
        如果真 (组件8句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件8句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件8句柄, , 句柄序2)
            }
        }
        如果真 (组件9句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件9句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件9句柄, , 句柄序2)
            }
        }
        如果真 (组件10句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件10句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件10句柄, , 句柄序2)
            }
        }
        如果真 (组件11句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件11句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件11句柄, , 句柄序2)
            }
        }
        如果真 (组件12句柄 > 0)
        {
            如果真 (水平缩放 == 真)
            {
                记录坐标 (1, 组件12句柄, 句柄序1)
            }
            如果真 (垂直缩放 == 真)
            {
                记录坐标 (2, 组件12句柄, , 句柄序2)
            }
        }
        句柄序1 = 句柄序1 + 1
        句柄序2 = 句柄序2 + 1
    }

    方法 记录坐标 <折叠>
    参数 类型 <类型 = 整数 注释 = "1、水平　2、垂直">
    参数 子组件句柄 <类型 = 变整数>
    参数 句柄序号1 <类型 = 整数 注释 = "水平" @默认值 = 0>
    参数 句柄序号2 <类型 = 整数 注释 = "垂直" @默认值 = 0>
    {
        加入缩放_ (子组件句柄)
        如果 (类型 == 1)
        {
            水平句柄列表组 [句柄序号1].加入成员 (子组件句柄)
        }
        否则
        {
            垂直句柄列表组 [句柄序号2].加入成员 (子组件句柄)
        }
    }

    方法 加入缩放_ <公开 折叠>
    参数 句柄 <类型 = 变整数 注释 = "组件句柄">
    参数 固定左边 <类型 = 逻辑型 @默认值 = 真>
    参数 固定顶边 <类型 = 逻辑型 @默认值 = 真>
    参数 固定宽度 <类型 = 逻辑型 @默认值 = 真>
    参数 固定高度 <类型 = 逻辑型 @默认值 = 真>
    参数 最小左边 <类型 = 整数 注释 = "默认为原组件左边" @默认值 = -1>
    参数 最小顶边 <类型 = 整数 注释 = "默认为原组件顶边" @默认值 = -1>
    参数 最小宽度 <类型 = 整数 注释 = "默认为原组件宽度" @默认值 = -1>
    参数 最小高度 <类型 = 整数 注释 = "默认为原组件高度" @默认值 = -1>
    {
        变量 局部临时左 <类型 = 整数>
        变量 局部临时顶 <类型 = 整数>
        变量 临时句柄 <类型 = 变整数>
        变量 i <类型 = 整数>
        循环 (, 句柄组.取成员数 (), i)
        {
            如果真 (句柄组.取成员 (i) == 句柄)
            {
                返回
            }
        }
        临时句柄 = 取父窗口句柄_ (句柄)
        如果 (临时句柄 == 父句柄)
        {
            局部临时左 = 窗口_取窗口组件左边 (句柄) - 窗口_取窗口组件左边 (父句柄) - 8
            局部临时顶 = 窗口_取窗口组件顶边 (句柄) - 窗口_取窗口组件顶边 (父句柄) - 30
        }
        否则
        {
            局部临时左 = 窗口_取窗口组件左边 (句柄) - 窗口_取窗口组件左边 (临时句柄)
            局部临时顶 = 窗口_取窗口组件顶边 (句柄) - 窗口_取窗口组件顶边 (临时句柄)
        }
        句柄组.加入成员 (句柄)
        左组.加入成员 (局部临时左)
        固定左组.加入成员 (固定左边)
        顶组.加入成员 (局部临时顶)
        固定顶组.加入成员 (固定顶边)
        宽组.加入成员 (窗口_取窗口组件宽度 (句柄))
        固定宽组.加入成员 (固定宽度)
        高组.加入成员 (窗口_取窗口组件高度 (句柄))
        固定高组.加入成员 (固定高度)
        如果真 (最小左边 == -1)
        {
            最小左边 = 局部临时左
        }
        如果真 (最小顶边 == -1)
        {
            最小顶边 = 局部临时顶
        }
        如果真 (最小宽度 == -1)
        {
            最小宽度 = 窗口_取窗口组件宽度 (句柄)
        }
        如果真 (最小高度 == -1)
        {
            最小高度 = 窗口_取窗口组件高度 (句柄)
        }
        最小左组.加入成员 (最小左边)
        最小顶组.加入成员 (最小顶边)
        最小宽组.加入成员 (最小宽度)
        最小高组.加入成员 (最小高度)
    }

    方法 置缩放组偏差_ <公开 注释 = "特定情况下，加入加入缩放组的组件，出现的左顶位置偏差，可用本命令校正" 折叠>
    参数 左边减位 <类型 = 逻辑型 注释 = "为真时左边位-8" @默认值 = 真>
    参数 顶边减位 <类型 = 逻辑型 注释 = "为真是顶边位-30" @默认值 = 真>
    {
        左补 = 0
        顶补 = 0
        如果真 (左边减位 == 真)
        {
            左补 = 8
        }
        如果真 (顶边减位 == 真)
        {
            顶补 = 30
        }
    }

    方法 启用同步缩放_ <公开 折叠>
    {
        变量 左差值 <类型 = 整数>
        变量 顶差值 <类型 = 整数>
        变量 宽差值 <类型 = 整数>
        变量 高差值 <类型 = 整数>
        变量 矩形 <类型 = 矩形_>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        矩形 = 窗口_取窗口组件矩形 (父句柄)
        宽差值 = 矩形.右边 - 矩形.左边 - 原窗口宽度
        高差值 = 矩形.底边 - 矩形.顶边 - 原窗口高度
        左差值 = 宽差值
        顶差值 = 高差值
        循环 (, 左组.取成员数 (), i)
        {
            如果 (固定左组.取成员 (i) == 真)
            {
                临时左 = 左组.取成员 (i)
            }
            否则
            {
                如果 (左组.取成员 (i) + 左差值 >= 最小左组.取成员 (i))
                {
                    临时左 = 左组.取成员 (i) + 左差值
                }
                否则
                {
                    临时左 = 最小左组.取成员 (i)
                }
            }
            如果 (固定顶组.取成员 (i) == 真)
            {
                临时顶 = 顶组.取成员 (i)
            }
            否则
            {
                如果 (顶组.取成员 (i) + 顶差值 >= 最小顶组.取成员 (i))
                {
                    临时顶 = 顶组.取成员 (i) + 顶差值
                }
                否则
                {
                    临时顶 = 最小顶组.取成员 (i)
                }
            }
            如果 (固定宽组.取成员 (i) == 真)
            {
                临时宽 = 宽组.取成员 (i)
            }
            否则
            {
                如果 (宽组.取成员 (i) + 宽差值 >= 最小宽组.取成员 (i))
                {
                    临时宽 = 宽组.取成员 (i) + 宽差值
                }
                否则
                {
                    临时宽 = 最小宽组.取成员 (i)
                }
            }
            如果 (固定高组.取成员 (i) == 真)
            {
                临时高 = 高组.取成员 (i)
            }
            否则
            {
                如果 (高组.取成员 (i) + 高差值 >= 最小高组.取成员 (i))
                {
                    临时高 = 高组.取成员 (i) + 高差值
                }
                否则
                {
                    临时高 = 最小高组.取成员 (i)
                }
            }
            窗口_置窗口组件位置大小 (句柄组.取成员 (i), 临时左, 临时顶, 临时宽, 临时高)
        }
        变量 临时原宽度值 <类型 = 整数>
        变量 临时原高度值 <类型 = 整数>
        变量 临时宽差值 <类型 = 整数>
        变量 临时高差值 <类型 = 整数>
        变量 水平平均值 <类型 = 整数>
        变量 垂直平均值 <类型 = 整数>
        变量 实时左边 <类型 = 整数>
        变量 实时顶边 <类型 = 整数>
        变量 实时宽度 <类型 = 整数>
        变量 实时高度 <类型 = 整数>
        循环 (, 父句柄组.取成员数 (), i)
        {
            临时原宽度值 = 父尺寸组 [0].取成员 (i)
            临时原高度值 = 父尺寸组 [1].取成员 (i)
            临时宽差值 = 窗口_取窗口组件宽度 (父句柄组.取成员 (i)) - 临时原宽度值
            临时高差值 = 窗口_取窗口组件高度 (父句柄组.取成员 (i)) - 临时原高度值
            循环 (, 水平句柄列表组 [i].取成员数 (), i2)
            {
                水平平均值 = 临时宽差值 / 水平句柄列表组 [i].取成员数 ()
                实时宽度 = 窗口_取窗口组件宽度 (水平句柄列表组 [i].取成员 (i2))
                实时高度 = 窗口_取窗口组件高度 (水平句柄列表组 [i].取成员 (i2))
                如果 (取父窗口句柄_ (水平句柄列表组 [i].取成员 (i2)) == 父句柄)
                {
                    实时左边 = 窗口_取窗口组件左边 (水平句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件左边 (父句柄组.取成员 (i)) - 左补
                    实时顶边 = 窗口_取窗口组件顶边 (水平句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件顶边 (父句柄组.取成员 (i)) - 顶补
                }
                否则
                {
                    实时左边 = 窗口_取窗口组件左边 (水平句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件左边 (父句柄组.取成员 (i))
                    实时顶边 = 窗口_取窗口组件顶边 (水平句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件顶边 (父句柄组.取成员 (i))
                }
                如果 (i2 == 0)
                {
                    窗口_置窗口组件位置大小 (水平句柄列表组 [i].取成员 (i2), 实时左边, 实时顶边, 实时宽度 + 水平平均值, 实时高度)
                }
                否则
                {
                    窗口_置窗口组件位置大小 (水平句柄列表组 [i].取成员 (i2), 实时左边 + 水平平均值 * i2, 实时顶边, 实时宽度 + 水平平均值, 实时高度)
                }
            }

            循环 (, 垂直句柄列表组 [i].取成员数 (), i2)
            {
                垂直平均值 = 临时高差值 / 垂直句柄列表组 [i].取成员数 ()
                实时宽度 = 窗口_取窗口组件宽度 (垂直句柄列表组 [i].取成员 (i2))
                实时高度 = 窗口_取窗口组件高度 (垂直句柄列表组 [i].取成员 (i2))
                如果 (取父窗口句柄_ (垂直句柄列表组 [i].取成员 (i2)) == 父句柄)
                {
                    实时左边 = 窗口_取窗口组件左边 (垂直句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件左边 (父句柄组.取成员 (i)) - 左补
                    实时顶边 = 窗口_取窗口组件顶边 (垂直句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件顶边 (父句柄组.取成员 (i)) - 顶补
                }
                否则
                {
                    实时左边 = 窗口_取窗口组件左边 (垂直句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件左边 (父句柄组.取成员 (i))
                    实时顶边 = 窗口_取窗口组件顶边 (垂直句柄列表组 [i].取成员 (i2)) - 窗口_取窗口组件顶边 (父句柄组.取成员 (i))
                }
                如果 (i2 == 0)
                {
                    窗口_置窗口组件位置大小 (垂直句柄列表组 [i].取成员 (i2), 实时左边, 实时顶边, 实时宽度, 实时高度 + 垂直平均值)
                }
                否则
                {
                    窗口_置窗口组件位置大小 (垂直句柄列表组 [i].取成员 (i2), 实时左边, 实时顶边 + 垂直平均值 * i2, 实时宽度, 实时高度 + 垂直平均值)
                }
            }
        }
    }
}

类 同步缩放类2_ <公开 折叠 @文档 = "category = \"程序综合库.组件缩放\"">
{
    变量 旧窗口地址列表 <静态 类型 = 组件地址哈希表 折叠>
    变量 布局列表 <静态 类型 = 自适应结构组>
    变量 容器句柄列表 <静态 类型 = 变整数数组类>
    变量 句柄列表 <静态 类型 = 变整数数组类>

    常量 WM_SIZE <类型 = 整数 值 = 0x0005 折叠>
    常量 WM_SIZING <类型 = 整数 值 = 0x0214>
    常量 GWLP_WNDPROC <类型 = 整数 值 = -4>
    常量 WM_SYSCOMMAND <类型 = 整数 值 = 0x0112>
    常量 SC_MAXIMIZE <类型 = 整数 值 = 0xf030>
    常量 SC_MINIMIZE <类型 = 整数 值 = 0xF020>
    常量 SC_NOMAL <类型 = 整数 值 = 0xf120>
    常量 SC_RESTORE <类型 = 整数 值 = 61728>
    常量 ""
    常量 WM_NCLBUTTONDBLCLK <类型 = 整数 值 = 0x00A3>

    方法 初始化_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 旧地址 <类型 = 变整数>
        如果真 (旧窗口地址列表.是否存在 (窗口句柄) == 假)
        {
            旧地址 = SetWindowLongPtrW (窗口句柄, GWLP_WNDPROC, 取静态方法地址 (消息循环))  // 子类化窗口
            旧窗口地址列表.插入 (窗口句柄, 旧地址)
            // ===
            枚举控件 (窗口句柄, 取静态方法地址 (枚举回调), 0)  // 枚举并绑定容器控件
            // ===
            绑定容器 (窗口句柄, 真)
            如果真 (容器句柄列表.所指定值是否存在 (窗口句柄) == 假)  // 主窗口需要考虑菜单栏和标题栏高度,所以单独设定
            {
                容器句柄列表.加入成员 (窗口句柄)
            }
            // ===
            如果真 (句柄列表.所指定值是否存在 (窗口句柄) == 假)  // 存放窗口句柄,用于统一还原子类化
            {
                句柄列表.加入成员 (窗口句柄)
            }
            // ===
        }
    }

    方法 移除控件_ <公开 注释 = "移出组件" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        计次循环 (句柄列表.取成员数 ())
        {
            如果真 (句柄列表.取成员 (取循环索引 ()) == 窗口句柄)
            {
                SetWindowLongPtrW (窗口句柄, GWLP_WNDPROC, 旧窗口地址列表.取值 (窗口句柄))
                句柄列表.删除成员 (取循环索引 ())
                跳出循环
            }
        }
    }

    方法 关闭自适应_ <公开 折叠 @禁止流程检查 = 真>
    {
        计次循环 (句柄列表.取成员数 ())
        {
            变量 窗口句柄 <类型 = 变整数>
            窗口句柄 = 句柄列表.取成员 (取循环索引 ())
            SetWindowLongPtrW (窗口句柄, GWLP_WNDPROC, 旧窗口地址列表.取值 (窗口句柄))
        }
    }

    方法 取矩形 <静态 类型 = 矩形_ 注释 = "返回指定窗口的矩形信息" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 rc <类型 = 矩形_>
        @ WINDOWINFO pwi;
        @ memset(&pwi, 0, sizeof(WINDOWINFO));
        @ pwi.cbSize = sizeof(WINDOWINFO);
        @ GetWindowInfo((HWND)@<窗口句柄>, &pwi);
        @ @<rc.左边> = pwi.rcWindow.left;
        @ @<rc.顶边> = pwi.rcWindow.top;
        @ @<rc.右边> = pwi.rcWindow.right;
        @ @<rc.底边> = pwi.rcWindow.bottom;
        @ return @<rc>;
    }

    方法 取窗口矩形 <静态 类型 = 矩形_ 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 rc <类型 = 矩形_>
        @ RECT rc;
        @ GetWindowRect((HWND)@<窗口句柄>, &rc);
        @ @<rc.左边> = rc.left;
        @ @<rc.顶边> = rc.top;
        @ @<rc.右边> = rc.right;
        @ @<rc.底边> = rc.bottom;
        @ return @<rc>;
    }

    方法 绑定容器 <静态 类型 = 整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 是否是窗口 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 "" <注释 = "//自适应结构类">
        变量 子控件数 <类型 = 整数>
        变量 控件矩形数组 <类型 = RECT数组组>
        变量 控件比例数组 <类型 = 位置大小组>
        变量 子控件句柄数组 <类型 = 变整数数组类>
        变量 "" <注释 = "//常规变量">
        变量 子控件句柄 <类型 = 变整数>
        变量 父控件矩形 <类型 = 矩形_>
        变量 比例 <类型 = 位置大小类>
        变量 子控件矩形 <类型 = 矩形_>
        循环判断首 ()
        {
            如果真 (子控件句柄 > 0)
            {
                子控件句柄数组.加入成员 (子控件句柄)
            }
            子控件句柄 = FindWindowExA (句柄, 子控件句柄, 0, 0)
        }
        循环判断尾 (子控件句柄 != 0)
        父控件矩形 = 取矩形 (句柄)
        计次循环 (子控件句柄数组.取成员数 ())
        {
            子控件矩形 = 取窗口矩形 (子控件句柄数组.取成员 (取循环索引 ()))
            控件矩形数组.加入成员 (子控件矩形)
            比例.左边 = (小数)(控件矩形数组.取成员 (取循环索引 ()).左边 - 父控件矩形.左边) / (父控件矩形.右边 - 父控件矩形.左边)
            比例.顶边 = (小数)(控件矩形数组.取成员 (取循环索引 ()).顶边 - 父控件矩形.顶边 - 选择 (是否是窗口, GetSystemMetrics (4), 0)) / (父控件矩形.顶边 - 父控件矩形.底边)
            比例.宽度 = (小数)(控件矩形数组.取成员 (取循环索引 ()).右边 - 控件矩形数组.取成员 (取循环索引 ()).左边) / (父控件矩形.右边 - 父控件矩形.左边)
            比例.高度 = (小数)(控件矩形数组.取成员 (取循环索引 ()).底边 - 控件矩形数组.取成员 (取循环索引 ()).顶边) / (父控件矩形.顶边 - 父控件矩形.底边)
            控件比例数组.加入成员 (比例)
        }
        子控件数 = 控件矩形数组.取成员数 ()
        变量 临时 <类型 = 自适应结构类>
        临时.句柄 = 句柄
        临时.子控件数 = 子控件数
        临时.控件矩形数组 = 控件矩形数组
        临时.控件比例数组 = 控件比例数组
        临时.子控件句柄数组 = 子控件句柄数组
        布局列表.加入成员 (临时)  // 保存到数组
        返回 (子控件数)
    }

    方法 枚举回调 <静态 折叠>
    参数 句柄 <类型 = 变整数>
    参数 自定义参数 <类型 = 变整数>
    {
        变量 容器句柄 <类型 = 变整数>
        容器句柄 = 取父句柄 (句柄)
        如果真 (容器句柄列表.所指定值是否存在 (容器句柄) == 假)  // 过滤重复的容器句柄
        {
            容器句柄列表.加入成员 (容器句柄)
        }
        绑定容器 (容器句柄, 假)  // 枚举并绑定容器控件
    }

    方法 消息循环 <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 hwnd <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        // 如果真 (uMsg == WM_NCLBUTTONDBLCLK)  // 禁止双击标题栏
        {
            // 返回 (0)
        }
        // ===
        如果真 (wParam == SC_MINIMIZE)  // 防止最小化时程序崩溃
        {
            返回 (CallWindowProcW (旧窗口地址列表.取值 (hwnd), hwnd, uMsg, wParam, lParam))
        }
        // ===
        如果真 (uMsg == WM_SIZE)  // 尺寸改变事件
        {
            如果真 (是否最小化 (hwnd) == 假)
            {
                容器句柄列表.枚举循环 ()
                {
                    控件自适应 (容器句柄列表.取枚举值 ())  // 控件自适应
                }
            }
            返回 (CallWindowProcW (旧窗口地址列表.取值 (hwnd), hwnd, uMsg, wParam, lParam))
        }
        返回 (CallWindowProcW (旧窗口地址列表.取值 (hwnd), hwnd, uMsg, wParam, lParam))
    }

    方法 控件自适应 <静态 折叠>
    参数 句柄 <类型 = 变整数>
    {
        变量 容器控件 <类型 = 矩形_>
        容器控件 = 取矩形 (句柄)
        变量 子控件数 <类型 = 整数>
        变量 控件矩形数组 <类型 = RECT数组组>
        变量 控件比例数组 <类型 = 位置大小组>
        变量 子控件句柄数组 <类型 = 变整数数组类>
        布局列表.枚举循环 ()
        {
            变量 临时 <类型 = 自适应结构类>
            临时 = 布局列表.取枚举值 ()
            如果真 (临时.句柄 == 句柄)
            {
                子控件数 = 临时.子控件数
                控件矩形数组 = 临时.控件矩形数组
                控件比例数组 = 临时.控件比例数组
                子控件句柄数组 = 临时.子控件句柄数组
                跳出循环
            }
        }
        变量 子控件句柄 <类型 = 变整数>
        计次循环 (子控件数)
        {
            变量 左边界 <类型 = 整数>
            变量 顶边界 <类型 = 整数>
            变量 新宽度 <类型 = 整数>
            变量 新高度 <类型 = 整数>
            子控件句柄 = 子控件句柄数组.取成员 (取循环索引 ())
            左边界 = (整数)((容器控件.右边 - 容器控件.左边) * 控件比例数组.取成员 (取循环索引 ()).左边)
            顶边界 = (整数)((容器控件.顶边 - 容器控件.底边) * 控件比例数组.取成员 (取循环索引 ()).顶边)
            新宽度 = (整数)(控件比例数组.取成员 (取循环索引 ()).宽度 * (容器控件.右边 - 容器控件.左边))
            新高度 = (整数)(控件比例数组.取成员 (取循环索引 ()).高度 * (容器控件.顶边 - 容器控件.底边))
            SetWindowPos (子控件句柄, 0, 左边界, 顶边界, 新宽度, 新高度, 0)
        }
    }

    方法 取父句柄 <静态 类型 = 变整数 注释 = "取一个窗口的父句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return (INT_PTR)GetParent((HWND)@<窗口句柄>);
    }

    方法 取类名 <静态 类型 = 文本型 注释 = "取指定窗口句柄的窗口类名" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ TCHAR szClassName[MAX_PATH] = { 0 };
        @ GetClassNameW((HWND)@<窗口句柄>, szClassName, MAX_PATH);
        @ return szClassName;
    }

    方法 枚举控件 <折叠>
    参数 句柄 <类型 = 变整数>
    参数 回调函数 <类型 = 变整数>
    参数 自定义参数 <类型 = 变整数>
    {
        EnumChildWindows (句柄, 回调函数, 自定义参数)
    }

    方法 是否最小化 <静态 类型 = 逻辑型 注释 = "已最小化返回真" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return IsIconic((HWND)@<窗口句柄>);
    }

    方法 是否最大化 <静态 类型 = 逻辑型 注释 = "已最大化返回真" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ return IsZoomed((HWND)@<窗口句柄>);
    }

    #
}

