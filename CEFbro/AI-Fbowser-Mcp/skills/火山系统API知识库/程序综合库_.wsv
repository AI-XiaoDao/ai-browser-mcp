类 发送消息类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.发送消息库\"" @全局类 = 真>
{
    方法 发送消息_ <公开 静态 类型 = 变整数 注释 = "将信息发送到窗口组件,并等待返回" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息类型 <类型 = 整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    {
        @ return(SendMessage((HWND)@<窗口句柄>,@<消息类型>,(WPARAM)@<参数1>,(LPARAM)@<参数2>));
    }

    方法 投递消息_ <公开 静态 注释 = "将信息发送到窗口组件,不等待直接返回" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息类型 <类型 = 整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    {
        @ PostMessage((HWND)@<窗口句柄>,@<消息类型>,(WPARAM)@<参数1>,(LPARAM)@<参数2>);
    }

    方法 消息_投递文本 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    参数 内容 <类型 = 文本型>
    {
        @ WORD* wKeyCode = (WORD*)@<内容>.GetText();
        @ DWORD dwCount = @<内容>.GetLength();
        @ for (DWORD i = 0; i < dwCount; i++)
        @ {
        @     PostMessage((HWND)@<句柄>, WM_CHAR, (WPARAM)wKeyCode[i], 0);
        @ }
    }
}

