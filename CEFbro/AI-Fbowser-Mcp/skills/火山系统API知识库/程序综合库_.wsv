    }

    方法 修改端口_ <公开 类型 = 逻辑型 注释 = "[协议和端口]中的设置。注意设置协议“修改协议_”" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新端口 <类型 = 整数 注释 = "留空为所有端口，否则为指定">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("LocalPorts", 新端口))
    }

    方法 修改协议_ <公开 类型 = 逻辑型 注释 = "[协议和端口]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新类型 <类型 = 整数
            注释 = "256、全部　0、自定义　1、ICMPV4　2、IGMP　6、TCP　17、UDP　41、IPV6　43、IPV6-ROUTE　44、IPV6-FRAG　47、GRE　58、ICMPV6　59、IPV6-NONXT　60、IPV6-OPTS　112、VRRP　113、PGM　115、L2TP">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("Protocol", 新类型))
    }

    方法 修改地址_ <公开 注释 = "[作用域]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新IP地址 <类型 = 文本型 注释 = "留空为所有IP地址，否则为指定">
    参数 是否本地 <类型 = 逻辑型 注释 = "真：本地　假：远程" @默认值 = 真>
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        如果 (是否本地)
        {
            INetFwRule.写属性 ("LocalAddresses", 新IP地址)
        }
        否则
        {
            INetFwRule.写属性 ("RemoteAddresses", 新IP地址)
        }
    }

