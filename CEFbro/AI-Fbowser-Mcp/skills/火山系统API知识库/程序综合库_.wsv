    方法 窗口_置窗口组件焦点2 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ HWND hWnd = (HWND)@<窗口句柄>, nhWnd;
        @ DWORD idAttachTo = GetCurrentThreadId(),
        @ idAttach = GetWindowThreadProcessId(hWnd, 0);
        @ AttachThreadInput(idAttach, idAttachTo, true);
        @ nhWnd = SetFocus(hWnd);
        @ AttachThreadInput(idAttach, idAttachTo, false);
        @ return nhWnd == hWnd;
    }

