类 屏幕快照类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.屏幕快照\"" @全局类 = 真 @视窗.外部头文件 = "atlimage.h">
{
    方法 快照_ <公开 静态 类型 = 字节集类 注释 = "如果是截取指定窗口并带有标题栏，请将宽高设置0" 返回值注释 = "返回快照数据" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "默认0截全屏，指定句柄则截图指定窗口" @默认值 = 0>
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "默认0截取全宽度。高分屏下请用“取屏幕宽度_ ()”" @默认值 = 0>
    参数 高度 <类型 = 整数 注释 = "默认0截取全高度。高分屏下请用“取屏幕高度_ ()”" @默认值 = 0>
    参数 保存地址 <类型 = 文本型 注释 = "直接对快照数据进行保存" @默认值 = "">
    参数 保存格式 <类型 = 整数 注释 = "1、BMP　2、PNG　3、JPG" @默认值 = 1>
    {
        变量 返回的字节集 <类型 = 字节集类>
        @ int KWidth , KHeight , X , Y;
        @ HWND hwnd_=(HWND)@<窗口句柄>;
        @ if(@<窗口句柄>==0){
        @ hwnd_=NULL;
        @ KWidth=@<宽度>;
        @ KHeight=@<高度>;
        @ X=@<左边>;
        @ Y=@<顶边>;
        @ }
        @ else {
        @ RECT rt;
        @ ::GetWindowRect(hwnd_,&rt);
        @ if(@<宽度> != 0 && @<高度> != 0){
        @ KWidth=@<宽度>;
        @ KHeight=@<高度>;
        @ } else {
        @ KWidth=rt.right- rt.left;
        @ KHeight=rt.bottom - rt.top;
        @ }
        @ X=@<左边>;
        @ Y=@<顶边>;
        @ }
        @ CVolString lpszPath=@<保存地址>;
        @ int format=@<保存格式>;
        @ HDC hDCScreen;
        @ if(hwnd_==NULL){hDCScreen = ::GetDC(NULL);}else{hDCScreen = ::GetDC(hwnd_);}
        @ int nBitPerPixel = GetDeviceCaps(hDCScreen, BITSPIXEL);
        @ if(nBitPerPixel<=0) {return "" ;};
        @ int nWidthScreen;
        @ int nHeightScreen;
        @ if(KWidth==0 || KHeight==0){nWidthScreen = GetDeviceCaps(hDCScreen, HORZRES);nHeightScreen = GetDeviceCaps(hDCScreen, VERTRES);}else{nWidthScreen=KWidth;nHeightScreen=KHeight;}
        @ CImage m_MyImage;
        @ m_MyImage.Create(nWidthScreen, nHeightScreen, nBitPerPixel);
        @ HDC hDCImg = m_MyImage.GetDC();
        @ if(@<窗口句柄>==0){
        @ BitBlt(hDCImg, 0, 0, nWidthScreen, nHeightScreen, hDCScreen, X, Y, SRCCOPY);
        @ } else {
        @      if(@<宽度> != 0 && @<高度> != 0){
        @ BitBlt(hDCImg, 0, 0, nWidthScreen, nHeightScreen, hDCScreen, X, Y, SRCCOPY);
        @      } else {
        @ PrintWindow(hwnd_, hDCImg, 0);  // PW_CLIENTONLY 仅复制客户区,0复制整个窗口
        @       }
        @ }
        变量 位图对象 <类型 = 位图对象类>
        @ HBITMAP hbmp = (HBITMAP)m_MyImage.operator HBITMAP();
        @ @<位图对象>=@dt<位图对象类> (hbmp, GOADT_DELETE_OBJECT);
        位图对象.取图片数据 (返回的字节集, , )
        @ if(lpszPath != L""){
        @ if(format==1){m_MyImage.Save(lpszPath, Gdiplus::ImageFormatBMP);};
        @ if(format==2){m_MyImage.Save(lpszPath, Gdiplus::ImageFormatPNG);}
        @ if(format==3){m_MyImage.Save(lpszPath, Gdiplus::ImageFormatJPEG);}
        @ }
        @ m_MyImage.ReleaseDC();
        @ ::ReleaseDC(hwnd_ == NULL ? NULL : hwnd_, hDCScreen);
        返回 (返回的字节集)
    }
}

