    方法 修改菜单图标_内置 <公开 类型 = 逻辑型 注释 = "内置形式设置火山自带菜单图标" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    参数 菜单列索引 <类型 = 整数>
    参数 菜单行索引 <类型 = 整数 注释 = "主项或子项所在处行号">
    参数 子菜单行索引 <类型 = 整数 注释 = "子项所在处行号，给予下拉菜单项行索引，即可修改下拉的子菜单；默认则按主菜单区修改；只能修改第一级子项" @默认值 = -1>
    参数 位图文件 <类型 = 视窗文件资源>
    {
        变量 图标句柄 <类型 = 变整数>
        图标句柄 = 内置取图标句柄 (位图文件)
        @ HMENU 菜单句柄 = GetMenu ((HWND)@<窗口句柄>); 
        @ HMENU 菜单项句柄 = GetSubMenu (菜单句柄, @<菜单列索引>);
        如果 (子菜单行索引 == -1)
        {
            @ return (int) SetMenuItemBitmaps (菜单项句柄, @<菜单行索引>, MF_BYPOSITION, (HBITMAP)@<图标句柄>, (HBITMAP)@<图标句柄>);
        }
        否则
        {
            @ HMENU 菜单项句柄2 = GetSubMenu (菜单项句柄, @<子菜单行索引>);
            @ return (int) SetMenuItemBitmaps (菜单项句柄2, @<菜单行索引>, MF_BYPOSITION, (HBITMAP)@<图标句柄>, (HBITMAP)@<图标句柄>);
        }
    }

    方法 修改菜单图标_内置2 <公开 类型 = 逻辑型 注释 = "通过“取根菜单句柄_”取得根句柄，再通过“取子菜单句柄_”取得子项句柄." 注释 = "如果是多级子项，则层层往下取，最后使用“修改菜单图标_内置2”修改图标" 折叠 折叠2
            @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 菜单行索引 <类型 = 整数>
    参数 位图文件 <类型 = 视窗文件资源>
    {
        变量 图标句柄 <类型 = 变整数>
        图标句柄 = 内置取图标句柄 (位图文件)
        @ return (int) SetMenuItemBitmaps ((HMENU)@<菜单根句柄>, @<菜单行索引>, MF_BYPOSITION, (HBITMAP)@<图标句柄>, (HBITMAP)@<图标句柄>);
    }

    方法 修改菜单图标_路径 <公开 类型 = 整数 注释 = "路径形式设置火山自带菜单图标" 返回值注释 = "如果调用成功会返回非零值，否则失败为0" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    参数 菜单列索引 <类型 = 整数>
    参数 菜单行索引 <类型 = 整数 注释 = "主项或子项所在处行号">
    参数 子菜单行索引 <类型 = 整数 注释 = "子项所在处行号，给予下拉菜单项行索引，即可修改下拉的子菜单；默认则按主菜单区修改；只能修改第一级子项" @默认值 = -1>
    参数 位图文件 <类型 = 文本型 注释 = "图标文件路径">
    {
        @ HMENU 菜单句柄 = GetMenu ((HWND)@<窗口句柄>); 
        @ HMENU 菜单项句柄 = GetSubMenu (菜单句柄, @<菜单列索引>);
        @ int X = GetSystemMetrics (SM_CXMENUCHECK);
        @ int Y = GetSystemMetrics (SM_CYMENUCHECK);
        @ HANDLE 图标句柄 = LoadImage (0,@<位图文件>, IMAGE_BITMAP, X, Y, LR_LOADFROMFILE);
        如果 (子菜单行索引 == -1)
        {
            @ return (int) SetMenuItemBitmaps (菜单项句柄, @<菜单行索引>, 1024, (HBITMAP)图标句柄, (HBITMAP)图标句柄);
        }
        否则
        {
            @ HMENU 菜单项句柄2 = GetSubMenu (菜单项句柄, @<子菜单行索引>);
            @ return (int) SetMenuItemBitmaps (菜单项句柄2, @<菜单行索引>, 1024, (HBITMAP)图标句柄, (HBITMAP)图标句柄);
        }
    }

    方法 修改菜单图标_路径2 <公开 类型 = 整数 注释 = "通过“取根菜单句柄_”取得根句柄，再通过“取子菜单句柄_”取得子项句柄." 注释 = "如果是多级子项，则层层往下取，最后使用“修改菜单图标_内置2”修改图标"
            返回值注释 = "如果调用成功会返回非零值，否则失败为0" 折叠 折叠2 @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 菜单行索引 <类型 = 整数>
    参数 位图文件 <类型 = 文本型 注释 = "图标文件路径">
    {
        @ int X = GetSystemMetrics (SM_CXMENUCHECK);
        @ int Y = GetSystemMetrics (SM_CYMENUCHECK);
        @ HANDLE 图标句柄 = LoadImage (0,@<位图文件>, IMAGE_BITMAP, X, Y, LR_LOADFROMFILE);
        @ return (int) SetMenuItemBitmaps ((HMENU)@<菜单根句柄>, @<菜单行索引>, 1024, (HBITMAP)图标句柄, (HBITMAP)图标句柄);
    }

    方法 置菜单图标_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单行索引 <类型 = 整数>
    参数 标志或ID <类型 = 整数 @默认值 = 1024>
    参数 未选图标句柄 <类型 = 变整数>
    参数 已选图标句柄 <类型 = 变整数>
    {
        @ return SetMenuItemBitmaps ((HMENU)@<菜单句柄>, @<菜单行索引>, @<标志或ID>, (HBITMAP)@<未选图标句柄>,(HBITMAP)@<已选图标句柄>);
    }

    方法 刷新菜单_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ DrawMenuBar((HWND)@<窗口句柄>);
    }

    方法 内置取图标句柄 <类型 = 变整数 折叠>
    参数 图标来源 <类型 = 视窗文件资源>
    {
        变量 图片 <类型 = COM对象类>
        变量 图片资源 <类型 = 位图对象类>
        变量 图片句柄 <类型 = 变整数>
        变量 临时图标 <类型 = 菜单素材类>
        变量 图标数据 <类型 = 字节集类>
        临时图标.图标 = 图标来源
        素材组1.加入成员 (临时图标)
        临时图标 = 素材组1.取成员 (素材组1.取成员数 () - 1)
        文件资源到字节集 (临时图标.图标, 图标数据)
        图片资源 = 载入位图数据 (图标数据)
        图片.创建图片对象 (图片资源)
        图片句柄 = 图片.无参数方法 ("Handle", 变整数)
        对象组.加入成员 (图片)
        返回 (图片句柄)
    }

    方法 取图标句柄 <类型 = 变整数数组类 折叠>
    参数 图标来源 <类型 = 菜单模板类>
    {
        变量 临时图标 <类型 = 菜单素材类>
        变量 图片句柄 <类型 = 变整数数组类>
        图标来源.枚举循环 ()
        {
            临时图标 = 图标来源.取枚举值 ()
            图片句柄.加入成员 (内置取图标句柄 (临时图标.图标))
        }
        返回 (图片句柄)
    }
}

类 菜单模板类 <基础类 = 对象数组模板类 折叠2 @文档 = "category = \"程序综合库.图文菜单.附加类\"" @模板实现类 = "菜单素材类">

类 菜单素材类 <折叠 @文档 = "category = \"程序综合库.图文菜单.附加类\"">
{
    变量 图标 <公开 类型 = 视窗文件资源>
}

类 菜单创建组类 <公开 折叠 @文档 = "category = \"程序综合库.图文菜单.附加类\"">
{
    变量 图标组 <公开 类型 = 菜单模板类>
    变量 素材 <类型 = 菜单素材类>
    变量 名称组 <公开 类型 = 文本数组类>

    方法 加入菜单素材组 <公开 折叠>
    参数 菜单主项名称 <类型 = 文本型 注释 = "- 表示添加分隔线">
    参数 图标 <类型 = 视窗文件资源 @默认值 = 空资源.空文件>
    {
        素材.图标 = 图标
        图标组.加入成员 (素材)
        名称组.加入成员 (菜单主项名称)
    }
}

