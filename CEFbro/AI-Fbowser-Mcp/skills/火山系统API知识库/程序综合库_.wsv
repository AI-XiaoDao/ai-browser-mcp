    方法 修改边缘遍历_ <公开 类型 = 逻辑型 注释 = "[高级]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新设置 <类型 = 整数 注释 = "0、阻止边缘遍历　1、允许边缘遍历　2、遵从应用程序">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("EdgeTraversalOptions", 新设置))
    }

    方法 修改接口类型_ <公开 类型 = 逻辑型 注释 = "[高级]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新类型 <类型 = 文本型 注释 = "All、所有类型　Lan、局域网　RemoteAccess、远程访问　Wireless、无线　；可以用分号组合：Lan,Wireless,RemoteAccess">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("InterfaceTypes", 新类型))
    }

    方法 置出站属性_ <公开 折叠>
    参数 域 <类型 = 整数 注释 = "0、阻止　1、允许" @默认值 = 1>
    参数 专用 <类型 = 整数 注释 = "0、阻止　1、允许" @默认值 = 1>
    参数 公用 <类型 = 整数 注释 = "0、阻止　1、允许" @默认值 = 1>
    {
        置指定出站_ (1, 域)
        置指定出站_ (2, 专用)
        置指定出站_ (4, 公用)
