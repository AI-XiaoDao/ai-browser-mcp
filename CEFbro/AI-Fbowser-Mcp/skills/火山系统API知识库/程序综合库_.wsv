    方法 程序_取程序图标 <公开 静态 类型 = 字节集类 注释 = "只支持单图" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()" @默认值 = 0>
    参数 程序来源 <类型 = 文本型>
    参数 显示容器句柄 <类型 = 变整数 注释 = "将图标直接显示到组件上，留空则不会显示。例如：“图片框1.取窗口句柄 ()”" @默认值 = 0>
    参数 图标大小 <类型 = 整数 注释 = "0、16*16　1、32*32　2、48*48　3、256*256" @默认值 = 2>
    {
        变量 返回的字节集 <类型 = 字节集类>
        变量 临时大小 <类型 = 整数>
        变量 临时选择 <类型 = 整数>
        变量 返回值指针 <类型 = 变整数>
        如果 (图标大小 == 0)
        {
            临时大小 = 16
            临时选择 = 1
        }
        否则 (图标大小 == 1)
        {
            临时大小 = 32
            临时选择 = 0
        }
        否则 (图标大小 == 2)
        {
            临时大小 = 48
            临时选择 = 2
        }
        否则 (图标大小 == 3)
        {
            临时大小 = 256
            临时选择 = 4
        }

        @ SHFILEINFO sfi = {0};
        @ HDC  hDC;
        @ if((HWND)@<显示容器句柄> != 0)
        @ {
        @ hDC = GetDC ((HWND)@<显示容器句柄>);
        @ }
        @ SHGetFileInfo(@<程序来源>.GetText(), 0, &sfi, sizeof(sfi), SHGFI_SYSICONINDEX);
        @ IImageList* imageList = nullptr;
        @ SHGetImageList(@<临时选择>, IID_IImageList, (void**)&imageList);//1、16   0、32   2、48   4、256
        @ HICON hIcon = sfi.hIcon;
        @ if (imageList)
        @ {
        @    hIcon = ImageList_GetIcon((HIMAGELIST)imageList, sfi.iIcon, 0);
        @    if (hIcon)
        @        DestroyIcon(sfi.hIcon);
        @    else
        @        hIcon = sfi.hIcon;
        @    imageList->Release();
        @ }
        @ if((HWND)@<显示容器句柄> != 0)
        @ {
        @ DrawIconEx (hDC, 0, 0, hIcon, @<临时大小>, @<临时大小>, 0, 0, 0|3);
        @ ReleaseDC ((HWND)@<显示容器句柄>, hDC);
        @ }
        @ char * 数据1;
        @  数据1= SaveIcon(hIcon,32);
        @ @<返回值指针> = *(int *)数据1 ;
        返回的字节集.重分配字节集 ((整数)返回值指针)
        返回值指针 = 返回的字节集.取字节集指针 ()
        @  memcpy((char*)@<返回值指针>,数据1+4,*(int *)数据1);
        @ delete[] 数据1;
        @ DestroyIcon(hIcon) ;
        返回 (返回的字节集)
    }

    方法 程序_取程序图标2 <公开 静态 类型 = 字节集类 注释 = "支持多图" 折叠>
    参数 程序来源 <类型 = 字节集类 注释 = "读入文件 ()，程序文件的字节集数据来源">
    参数 图标大小 <类型 = 文本型 注释 = "默认空为提取所有图标数据，也可指定范围，如“16,32”则为提取16*16,32*32分辨率图标，多个时用逗号间隔，提取后会存放在同一个ico文件中."
            注释 = "支持16*16、32*32、48*48、64*64范围的图标" @默认值 = "">
    参数 颜色深度 <类型 = 整数 注释 = "当指定图标大小的时候，可选择颜色深度如4、8、16、32，0则表示所有深度的图片" @默认值 = 0>
    参数 图标组索引 <类型 = 整数 注释 = "默认-1取图片数最多的图标组。可先用“程序_取程序图标数”命令来获取总数量，然后按索引取指定图标" @默认值 = -1>
    {
        变量 返回图标 <类型 = 字节集类>
        变量 位置1 <类型 = 整数>
        变量 位置指针 <类型 = 变整数>
        变量 i <类型 = 整数>
        变量 节的位置 <类型 = 变整数>
        变量 节的大小 <类型 = 整数>
        变量 内存相对偏移 <类型 = 整数>
        变量 内存大小 <类型 = 整数>
        变量 文件相对偏移 <类型 = 整数>
        变量 pe位 <类型 = 整数>
        // 欲解析文件 = 读入文件 (文件位置, )
        位置指针 = 程序来源.取字节集指针 ()
        // 位置1 = 寻找字节集 (欲解析文件, 文本到多字节 (".rsrc", 假), )  //  找到图标位置,  此方法据说不够好,不过比较简单
        位置1 = 取资源表 (程序来源.取对象自身指针 (), 取变量地址 (pe位))  // 理论上更合适的方法
        如果 (位置1 < 0)
        {
            返回图标.清空字节集 ()
            返回 (返回图标)
        }
        内存相对偏移 = 读指针处值 (位置指针 + 位置1 + 12, 整数)
        内存大小 = 读指针处值 (位置指针 + 位置1 + 16, 整数)
        文件相对偏移 = 读指针处值 (位置指针 + 位置1 + 20, 整数)
        节的位置 = 位置指针 + 读指针处值 (位置指针 + 位置1 + 20, 整数)  // 跳转到资源表
        节的大小 = 读指针处值 (节的位置 + 24, 整数)
        // 读取图标组
        变量 图标组 <类型 = 长整数>
        变量 图片数量 <类型 = 整数>
        变量 图标指针 <类型 = 变整数>
        变量 需要提取的图片 <类型 = 变整数数组类>
        图标组 = 读取指定数据 (节的位置, 14, , , , 位置指针 + 位置1, 程序来源.取对象自身指针 (), pe位, 图标组索引)  // 读取图标组数据
        图片数量 = 读指针处值 (位置指针 + 4 + 读指针处值 (取变量地址 (图标组), 整数), 字符)
        图标指针 = 位置指针 + 读指针处值 (取变量地址 (图标组), 整数) + 6
        如果 (图片数量 > 1000)  // 数据不正常不可能有这么多
        {
            返回图标.清空字节集 ()
            返回 (返回图标)
        }
        变量 需提取图片 <类型 = 整数到整数哈希表>
        变量 分割后 <类型 = 文本数组类>
        变量 是否全取 <类型 = 逻辑型 值 = 假>
        变量 图标数据 <类型 = 长整数>
        变量 图标id <类型 = 字符>
        变量 合成值 <类型 = 字节集类>
        变量 数据总长度 <类型 = 整数 值 = 0>
        如果 (图标大小 != "")
        {
            分割文本 (图标大小, ",", 分割后, , )
            循环 (0, 分割后.取成员数 (), i)
            {
                需提取图片.插入 (文本到整数 (分割后.取成员 (i)), 1)
            }
        }
        否则
        {
            是否全取 = 真
        }
        循环 (0, 图片数量, i)
        {
            如果 ((是否全取 || 需提取图片.是否存在 (无符号字节到整数 (读指针处值 (图标指针 + i * 14, 字节)))) && (颜色深度 == 0 || 颜色深度 == 无符号字节到整数 (读指针处值 (图标指针 + i * 14 + 6, 字节))))
            {
                图标id = 读指针处值 (图标指针 + i * 14 + 12, 字符)
                图标数据 = 读取指定数据 (节的位置, 3, 0, 图标id, , 位置指针 + 位置1, 程序来源.取对象自身指针 (), pe位, 图标组索引)  // 读取图标组数据
                需要提取的图片.加入成员 (图标指针 + i * 14)  // 加入图标头指针
                需要提取的图片.加入成员 (位置指针 + 读指针处值 (取变量地址 (图标数据), 整数))  // 加入图标数据指针
                需要提取的图片.加入成员 (读指针处值 (取变量地址 (图标数据) + 4, 整数))  // 加入数据长度,以数据实际长度为准
                数据总长度 = 数据总长度 + 读指针处值 (取变量地址 (图标数据) + 4, 整数)
            }
        }
        如果 (数据总长度 == 0)  // 无数据返回空字节集
        {
            返回图标.清空字节集 ()
            返回 (返回图标)
        }
        返回图标.重分配字节集 (6 + 16 * 需要提取的图片.取成员数 () / 3 + 数据总长度)
        变量 前指针 <类型 = 变整数>
        变量 后指针 <类型 = 变整数>
        前指针 = 返回图标.取字节集指针 () + 6
        后指针 = 前指针 + 16 * 需要提取的图片.取成员数 () / 3
        写指针处值 (前指针 - 6, (字符)0)
        写指针处值 (前指针 - 4, (字符)1)
        写指针处值 (前指针 - 2, (字符)(需要提取的图片.取成员数 () / 3))
        循环 (0, 需要提取的图片.取成员数 (), i, 3)
        {
            内存复制 (前指针, 需要提取的图片.取成员 (i), 14)
            前指针 = 前指针 + 12
            内存复制 (后指针, 需要提取的图片.取成员 (i + 1), (整数)需要提取的图片.取成员 (i + 2))
            写指针处值 (前指针, (整数)(后指针 - 返回图标.取字节集指针 ()))
            写指针处值 (前指针 - 4, (整数)需要提取的图片.取成员 (i + 2))  // 发现的错误,以实际大小为准
            后指针 = 后指针 + 需要提取的图片.取成员 (i + 2)
            前指针 = 前指针 + 4
            图标指针 = 图标指针 + 14
        }
        后指针 = 后指针 - 前指针
        返回 (返回图标)
    }

    方法 程序_取程序图标数 <公开 静态 类型 = 整数 折叠>
    参数 程序数据 <类型 = 字节集类 注释 = "读入文件 ()">
    {
        变量 pe位 <类型 = 整数>
        变量 资源表偏移 <类型 = 整数>
        变量 项目头 <类型 = 变整数>
        变量 数量 <类型 = 整数>
        变量 i <类型 = 整数>
        资源表偏移 = 取资源表 (程序数据.取对象自身指针 (), 取变量地址 (pe位))
        如果 (资源表偏移 < 0)
        {
            返回 (0)
        }
        项目头 = 程序数据.取字节集指针 () + 读指针处值 (程序数据.取字节集指针 () + 资源表偏移 + 20, 整数)
        数量 = 读指针处值 (项目头 + 14, 字符) + 读指针处值 (项目头 + 12, 字符)
        循环 (0, 数量, i)
        {
            如果 (读指针处值 (项目头 + 16 + i * 8, 整数) == 14)
            {
                项目头 = 项目头 + 位与 (读指针处值 (项目头 + 16 + i * 8 + 4, 整数), 0x7FFFFFFF)
                返回 (读指针处值 (项目头 + 14, 字符) + 读指针处值 (项目头 + 12, 字符))
            }
        }
        返回 (0)
    }

    方法 读取指定数据 <静态 类型 = 长整数 返回值注释 = "前四字节偏移，后四字节大小" 折叠>
    参数 起始点 <类型 = 变整数 注释 = "资源项目开始点">
    参数 类型 <类型 = 整数 注释 = "数据类型 14 图标组，3图标">
    参数 最大最小 <类型 = 整数 注释 = "-1最小0等于编号，1最大值" @默认值 = -1>
    参数 编号 <类型 = 整数 注释 = "只有最大最小取0时，取指定编号数" @默认值 = 1>
    参数 语言类型 <类型 = 整数 注释 = "汉语2052英语1033" @默认值 = 1033>
    参数 当前节电 <类型 = 变整数 注释 = "内存偏移转文件偏移的值" "">
    参数 首节电 <类型 = 变整数 注释 = "载入文件的地址">
    参数 pe位 <类型 = 整数>
    参数 指定图标组 <类型 = 整数 "">
    {
        变量 i <类型 = 整数>
        变量 j <类型 = 整数>
        变量 项目头 <类型 = 变整数>
        变量 返回值 <类型 = 长整数>
        变量 数量 <类型 = 整数>
        变量 ""
        // 项目目录(16字节)->项目表(8字节)一共三层
        // 第一层
        // 项目头 = 起始点 + 读指针处值 (起始点 + 20, 整数)  // 跳转到资源表
        项目头 = 起始点
        数量 = 读指针处值 (项目头 + 14, 字符) + 读指针处值 (项目头 + 12, 字符)
        循环 (0, 数量, i)
        {
            如果 (读指针处值 (项目头 + 16 + i * 8, 整数) == 类型)
            {
                项目头 = 起始点 + 位与 (读指针处值 (项目头 + 16 + i * 8 + 4, 整数), 0x7FFFFFFF)  // 指向下一个项目目录
                跳出循环
            }
        }
        // 返回值 = 指针到字节集 (项目头, 16)
        // 第二层
        变量 最大或最小值 <类型 = 整数 值 = 0>
        变量 编号1 <类型 = 整数>
        变量 编号位置 <类型 = 整数 值 = -1>
        如果 (最大最小 < 0)
        {
            最大最小 = 0x7FFFFFFF
        }
        否则 (最大最小 > 0)
        {
            最大最小 = 0xFFFFFFFF
        }
        数量 = 读指针处值 (项目头 + 14, 字符) + 读指针处值 (项目头 + 12, 字符)
        // 此处修改为取固定的id
        变量 局项目头 <类型 = 变整数>
        局项目头 = 项目头
        循环 (0, 数量, i)
        {
            编号1 = 读指针处值 (项目头 + 16 + i * 8, 整数)
            如果 (类型 == 14)  //   图标组修改为取体积最大的(体积大包含图片多大概率就是需要显示的图标组
            {
                项目头 = 局项目头
                项目头 = 起始点 + 位与 (读指针处值 (项目头 + 16 + i * 8 + 4, 整数), 0x7FFFFFFF)  // 指向下一个项目目录
                // 第三层 是语言 默认取汉语// 修改为默认取英语
                编号位置 = -1
                循环 (0, 读指针处值 (项目头 + 14, 字符), j)
                {
                    编号1 = 读指针处值 (项目头 + 16 + j * 8, 整数)
                    如果 (编号1 == 语言类型)
                    {
                        编号位置 = j
                        跳出循环
                    }
                }
                如果 (编号位置 == -1)  // 没有找到指定编号
                {
                    编号位置 = 0  // 找不到指定编号就返回第一个
                }
                项目头 = 起始点 + 读指针处值 (项目头 + 16 + 编号位置 * 8 + 4, 整数)  // 指向实际地址
                如果 (指定图标组 != -1 && 指定图标组 == i)
                {
                    写指针处值 (取变量地址 (返回值), 相对内存地址转文件地址 (当前节电, 读指针处值 (项目头, 整数), 首节电, pe位))
                    写指针处值 (取变量地址 (返回值) + 4, 读指针处值 (项目头 + 4, 整数))
                    返回 (返回值)
                }
                如果 (读指针处值 (项目头 + 4, 整数) > 最大或最小值)
                {
                    最大或最小值 = 读指针处值 (项目头 + 4, 整数)
                    写指针处值 (取变量地址 (返回值), 相对内存地址转文件地址 (当前节电, 读指针处值 (项目头, 整数), 首节电, pe位))
                    写指针处值 (取变量地址 (返回值) + 4, 读指针处值 (项目头 + 4, 整数))
                }
                到循环尾
            }
            如果 (最大最小 == 0 && 编号1 == 编号)
            {
                最大或最小值 = 编号1
                编号位置 = i
                跳出循环
            }
            否则 (最大最小 < 0 && 最大或最小值 > 编号1)
            {
                最大或最小值 = 编号1
                编号位置 = i
                跳出循环
            }
            否则 (最大最小 > 0 && 最大或最小值 < 编号1)
            {
                最大或最小值 = 编号1
                编号位置 = i
                跳出循环
            }
        }
        如果 (类型 == 14)
        {
            返回 (返回值)
        }
        如果 (编号位置 == -1)  // 没有找到指定编号
        {
            返回 (返回值)
        }
        项目头 = 起始点 + 位与 (读指针处值 (项目头 + 16 + 编号位置 * 8 + 4, 整数), 0x7FFFFFFF)  // 指向下一个项目目录
        // 第三层 是语言 默认取汉语// 修改为默认取英语
        编号位置 = -1
        循环 (0, 读指针处值 (项目头 + 14, 字符), i)
        {
            编号1 = 读指针处值 (项目头 + 16 + i * 8, 整数)
            如果 (编号1 == 语言类型)
            {
                编号位置 = i
                跳出循环
            }
        }
        如果 (编号位置 == -1)  // 没有找到指定编号
        {
            编号位置 = 0  // 找不到指定编号就返回第一个
        }
        项目头 = 起始点 + 读指针处值 (项目头 + 16 + 编号位置 * 8 + 4, 整数)  // 指向实际地址
        // 写指针处值 (取变量地址 (返回值), 读指针处值 (项目头, 整数) + 转换值)
        写指针处值 (取变量地址 (返回值), 相对内存地址转文件地址 (当前节电, 读指针处值 (项目头, 整数), 首节电, pe位))
        写指针处值 (取变量地址 (返回值) + 4, 读指针处值 (项目头 + 4, 整数))
        返回 (返回值)  // 前四字节偏移,后四字节大小
    }

    方法 相对内存地址转文件地址 <静态 类型 = 整数 返回值注释 = "文件偏移值" 折叠>
    参数 节点 <类型 = 变整数>
    参数 相对内存地址 <类型 = 整数>
    参数 首节点 <类型 = 变整数 @默认值 = 0>
    参数 位置1 <类型 = 整数 注释 = "PE 标志位">
    {
        // 从当前节点向后查找
        // +20+24
        变量 节偏移 <类型 = 整数>
        变量 节大小 <类型 = 整数>
        变量 内存偏移 <类型 = 整数>
        变量 内存大小 <类型 = 整数>
        变量 "//位置1" <类型 = 整数>
        变量 程序字节集 <类型 = 字节集类>
        内存偏移 = 读指针处值 (节点 + 12, 整数)
        内存大小 = 读指针处值 (节点 + 16, 整数)
        节偏移 = 读指针处值 (节点 + 20, 整数)
        节大小 = 读指针处值 (节点 + 24, 整数)
        如果 (相对内存地址 < 内存大小 + 内存偏移)  // 正常情况应该属于这种
        {
            返回 (相对内存地址 + 节偏移 - 内存偏移)
        }
        首节点 = 读指针处对象 (首节点, 字节集类).取字节集指针 ()
        // 位置1 = 位置1 + 6  // 直接跳到数量位置
        变量 节表数量 <类型 = 字符>
        变量 可选PE大小 <类型 = 字符>
        变量 i <类型 = 整数>
        节表数量 = 读指针处值 (首节点 + 位置1 + 6, 字符)
        可选PE大小 = 读指针处值 (首节点 + 位置1 + 20, 字符)
        // 位置1 = 位置1 + 24
        位置1 = 位置1 + 24 + 可选PE大小  // 直接跳到可选头
        节点 = 首节点 + 位置1
        循环 (0, 节表数量, i)
        {
            内存偏移 = 读指针处值 (节点 + 12, 整数)
            内存大小 = 读指针处值 (节点 + 16, 整数)
            节偏移 = 读指针处值 (节点 + 20, 整数)
            节大小 = 读指针处值 (节点 + 24, 整数)
            如果 (相对内存地址 < 内存大小 + 内存偏移)  // 非正常情况应该属于这种
            {
                返回 (相对内存地址 + 节偏移 - 内存偏移)
            }
            节点 = 节点 + 40
        }
        返回 (-3)
    }

    方法 取资源表 <静态 类型 = 整数 返回值注释 = "资源表偏移" 折叠>
    参数 首节点指针 <类型 = 变整数 注释 = "字节集对象指针">
    参数 pe位 <类型 = 变整数 注释 = "取出pe标志位">
    {
        变量 位置1 <类型 = 整数>
        变量 首节点 <类型 = 变整数>
        首节点 = 读指针处对象 (首节点指针, 字节集类).取字节集指针 ()
        如果 (读指针处值 (首节点, 字节) != (字节)'M' || 读指针处值 (首节点 + 1, 字节) != (字节)'Z')
        {
            返回 (-1)  // 非程序
        }
        首节点 = 读指针处值 (首节点 + 60, 整数) + 首节点
        如果 (读指针处值 (首节点, 字节) != (字节)'P' || 读指针处值 (首节点 + 1, 字节) != (字节)'E')
        {
            返回 (-1)  // 非程序
        }
        位置1 = (整数)(首节点 - 读指针处对象 (首节点指针, 字节集类).取字节集指针 ())
        首节点 = 读指针处对象 (首节点指针, 字节集类).取字节集指针 ()
        写指针处值 (pe位, 位置1)
        // 位置1 = 位置1 + 6  // 直接跳到数量位置
        变量 节表数量 <类型 = 字符>
        变量 可选PE大小 <类型 = 字符>
        变量 偏移 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 节点 <类型 = 变整数>
        变量 内存偏移 <类型 = 整数>
        节表数量 = 读指针处值 (首节点 + 位置1 + 6, 字符)
        可选PE大小 = 读指针处值 (首节点 + 位置1 + 20, 字符)
        // 位置1 = 位置1 + 24
        位置1 = 位置1 + 24 + 可选PE大小 - 14 * 8  // 直接跳到资源表
        偏移 = 读指针处值 (首节点 + 位置1, 整数)
        节点 = 首节点 + 位置1 + 14 * 8
        循环 (0, 节表数量, i)
        {
            内存偏移 = 读指针处值 (节点 + 12, 整数)
            如果 (偏移 == 内存偏移)  // 正常情况应该属于这种
            {
                返回 ((整数)(节点 - 首节点))
            }
            节点 = 节点 + 40
        }
        返回 (-3)
    }
}

类 窗口图标类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.程序图标\"" @全局类 = 真>
{
    方法 程序_置窗口图标 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "取窗口句柄 ()">
    参数 图标来源 <类型 = 文本型 注释 = "ico图标">
    {
        变量 图标句柄 <类型 = 变整数>
        @ @<图标句柄>=(@dt<变整数>)LoadImageW(0,@<图标来源>,1,NULL,NULL,0x040 + 0x010);
        @ SendMessage((HWND)@<窗口句柄>,128,0,@<图标句柄>);
        @ SendMessage((HWND)@<窗口句柄>,128,1,@<图标句柄>);
    }
}

