类 屏幕取色类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.屏幕取色\"" @全局类 = 真>
{
    方法 颜色_RGB颜色转ARGB <公开 静态 类型 = 整数 折叠 "">
    参数 RGB颜色 <类型 = 整数>
    参数 透明度 <类型 = 整数 注释 = "0到255，默认为255，不透明。" @默认值 = 255>
    {
        变量 Color <类型 = 字节数组类>
        Color.添加字节集 (到字节集 (RGB颜色), 0, 4)
        Color.交换成员 (0, 2)
        Color.置成员值 (3, (字节)透明度)
        返回 (取字节集数据 (Color.取字节集 (), , 整数))
    }

    方法 颜色_ARGB颜色转RGB <公开 静态 类型 = 整数 折叠 "">
    参数 RGB颜色 <类型 = 整数>
    参数 返回的透明度 <类型 = 整数类 @默认值 = 空对象>
    {
        变量 Color <类型 = 字节数组类>
        Color.添加字节集 (到字节集 (RGB颜色), 0, 4)
        Color.交换成员 (0, 2)
        返回的透明度.值 = Color.取字节集 ().取字节集数据 (3, 整数)
        Color.置成员值 (3, 0)
        返回 (取字节集数据 (Color.取字节集 (), , 整数))
    }

    方法 颜色_取屏幕坐标色值 <公开 静态 类型 = 整数 注释 = "十进制" 折叠 @禁止流程检查 = 真>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        @ HDC hdc = GetDC(NULL);
        @ INT ret = GetPixel(hdc,@<横向位置>,@<纵向位置>);
        @ ReleaseDC(NULL,hdc);
        @ return ret;
    }

    方法 颜色_取屏幕坐标色值2 <公开 静态 折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 返回的十进制色值 <类型 = 文本型 @默认值 = "">
    参数 返回的十六进制色值 <类型 = 文本型 @默认值 = "">
    参数 返回的RGB色值 <类型 = 文本型 @默认值 = "">
    参数 返回的VB色值 <类型 = 文本型 @默认值 = "">
    参数 返回的C色值 <类型 = 文本型 注释 = "C/C++" @默认值 = "">
    参数 返回的HTML色值 <类型 = 文本型 @默认值 = "">
    参数 返回的Delphi色值 <类型 = 文本型 @默认值 = "">
    {
        变量 十进制 <类型 = 整数>
        变量 十六进制 <类型 = 文本型>
        变量 RGB <类型 = 文本型>
        变量 VB <类型 = 文本型>
        变量 C <类型 = 文本型>
        变量 HTML <类型 = 文本型>
        变量 Delphi <类型 = 文本型>
        变量 R <类型 = 整数>
        变量 G <类型 = 整数>
        变量 B <类型 = 整数>
        十进制 = 颜色_取屏幕坐标色值 (横向位置, 纵向位置)
        R = 取颜色红色分量 (十进制)
        G = 取颜色绿色分量 (十进制)
        B = 取颜色蓝色分量 (十进制)
        十六进制 = 取十六进制文本 (R, 2) + 取十六进制文本 (G, 2) + 取十六进制文本 (B, 2)
        RGB = 到文本 (R) + "," + 到文本 (G) + "," + 到文本 (B)
        C = 取十六进制文本 (B, 2) + 取十六进制文本 (G, 2) + 取十六进制文本 (R, 2)
        VB = "&h" + C + "&"
        Delphi = "$" + C
        C = "0x" + C
        HTML = "#" + 十六进制
        返回的十进制色值 = 到文本 (十进制)
        返回的十六进制色值 = 十六进制
        返回的RGB色值 = RGB
        返回的VB色值 = VB
        返回的C色值 = C
        返回的HTML色值 = HTML
        返回的Delphi色值 = Delphi
    }

    方法 颜色_取屏幕坐标色值_句柄 <公开 静态 类型 = 整数 注释 = "十进制" 折叠 @禁止流程检查 = 真>
    参数 场景句柄 <类型 = 变整数 @默认值 = 0>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        @ HDC hdc = GetDC((HWND)@<场景句柄>);
        @ INT ret = GetPixel(hdc,@<横向位置>,@<纵向位置>);
        @ ReleaseDC(NULL,hdc);
        @ return ret;
    }
}

