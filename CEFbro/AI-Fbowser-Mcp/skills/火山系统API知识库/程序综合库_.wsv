类 系统音量类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统音量\"" @视窗.外部头文件 = "<mmdeviceapi.h>\r\n<endpointvolume.h>">
{

    # @ IAudioEndpointVolume* pIAudioEndpointVolume = NULL;
    # @ BOOL InitializeVolume() {
    # @     BOOL lRes = FALSE;
    # @     HRESULT hr;
    # @     hr = CoInitialize(NULL);
    # @     IMMDeviceEnumerator* pIMMDeviceEnumerator = NULL;
    # @     hr = CoCreateInstance(__uuidof(MMDeviceEnumerator), NULL, CLSCTX_INPROC_SERVER, __uuidof(IMMDeviceEnumerator), (void**)&pIMMDeviceEnumerator);
    # @     if (hr == S_OK && pIMMDeviceEnumerator) {
    # @         IMMDevice* pIMMDevice = NULL;
    # @         hr = pIMMDeviceEnumerator->GetDefaultAudioEndpoint(eRender, eConsole, &pIMMDevice);
    # @         if (hr == S_OK && pIMMDevice) {
    # @             hr = pIMMDevice->Activate(__uuidof(IAudioEndpointVolume), CLSCTX_INPROC_SERVER, NULL, (void**)&pIAudioEndpointVolume);
    # @             lRes = hr == S_OK && pIAudioEndpointVolume;
    # @             pIMMDevice->Release();
    # @         }
    # @         pIMMDeviceEnumerator->Release();
    # @     }
    # @     CoUninitialize();
    # @     return lRes;
    # @ }

    方法 取音量_ <公开 类型 = 整数 返回值注释 = "返回-1表示获取音量失败" 折叠 @禁止流程检查 = 真>
    {
        @ if (!InitializeVolume())
        @     return -1;
        @ float fLevel = 0;
        @ HRESULT hr = pIAudioEndpointVolume->GetMasterVolumeLevelScalar(&fLevel);
        @ pIAudioEndpointVolume->Release();
        @ if (hr == S_OK)
        @     return (INT)RoundDouble(fLevel * 100, 0);
        @ else
        @     return -1;
    }

    方法 置音量_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 音量大小 <类型 = 整数 注释 = "0-100">
    参数 声道 <类型 = 整数 注释 = "0、立体声道 1、左声道 2、右声道" @默认值 = 0>
    {
        @ if (!InitializeVolume())
        @     return false;
        @ float fLevel = 0;
        @ if (@<音量大小> < 0)
        @     fLevel = 0;
        @ else if (@<音量大小> > 100)
        @     fLevel = 1;
        @ else
        @     fLevel = (float)@<音量大小> / 100;
        @ HRESULT hr = S_FALSE;
        @ if (@<声道> <= 0 || @<声道> > 2){hr = pIAudioEndpointVolume->SetMasterVolumeLevelScalar(fLevel, NULL);}
        @ else if (@<声道> ==1){hr = pIAudioEndpointVolume->SetChannelVolumeLevelScalar(0, fLevel, NULL);}
        @ else if (@<声道> ==2){hr = pIAudioEndpointVolume->SetChannelVolumeLevelScalar(1, fLevel, NULL);}
        @ pIAudioEndpointVolume->Release();
        @ return (INT)hr==0;
    }

    方法 置最大音量_ <公开 类型 = 逻辑型 折叠>
    {
        返回 (置音量_ (100))
    }

    方法 置静音_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 状态 <类型 = 逻辑型 注释 = "真为静音，假为非静音">
    {
        @ if (!InitializeVolume())
        @     return false;
        @ HRESULT hr = pIAudioEndpointVolume->SetMute(@<状态>, NULL);
        @ pIAudioEndpointVolume->Release();
        @ return (INT)hr==0;
    }

    方法 是否静音_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ if (!InitializeVolume())
        @     return false;
        @ BOOL bMute = FALSE;
        @ HRESULT hr = pIAudioEndpointVolume->GetMute(&bMute);
        @ pIAudioEndpointVolume->Release();
        @ return bMute;
    }
}

