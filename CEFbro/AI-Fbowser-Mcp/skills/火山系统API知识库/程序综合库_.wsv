类 界面滚动条类_ <公开 注释 = "给窗口界面或布局界面设置个纵向滚动条" 折叠 @文档 = "category = \"程序综合库.界面滚动条\"">
{
    变量 全局隐藏类型 <类型 = 整数 值 = 0 折叠>
    变量 全局是否隐藏 <类型 = 逻辑型 值 = 假>
    变量 滚动方向 <静态 类型 = 整数 值 = 1>
    变量 滚动距离 <静态 类型 = 整数 值 = 50>
    变量 微调距离 <类型 = 整数 值 = 10>
    变量 禁用滚轮 <静态 类型 = 逻辑型>
    变量 宽值 <静态 类型 = 整数数组类>
    变量 高值 <静态 类型 = 整数数组类>
    变量 宽值2 <静态 类型 = 整数数组类>
    变量 高值2 <静态 类型 = 整数数组类>
    变量 创建句柄 <静态 类型 = 变整数>
    变量 句柄组 <类型 = "变整数数组类 [2]">
    变量 指针 <静态 类型 = 变整数>
    变量 锁 <类型 = 许可锁类_>

    方法 类_初始化 <折叠>
    {
        @ @<指针>=(@dt<变整数>)this;
    }

    方法 绑定滚动条_ <公开 类型 = 逻辑型 注释 = "给窗口界面或布局界面设置个滚动条" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    参数 隐藏类型 <类型 = 整数 注释 = "0、横向条　1、纵向条　3、全部" @默认值 = 0>
    参数 是否隐藏 <类型 = 逻辑型 @默认值 = 假>
    参数 右侧间距 <类型 = 整数 注释 = "设置被绑定的界面，其右侧空余间隔距离" @默认值 = 8>
    参数 底部间距 <类型 = 整数 注释 = "设置被绑定的界面，其底部空余间隔距离" @默认值 = 8>
    {
        变量 临时句柄 <类型 = 变整数>
        变量 结果 <类型 = 逻辑型>
        锁.加锁 ()
        句柄组 [0].枚举循环 ()
        {
            如果真 (句柄组 [0].取枚举值 () == 句柄)
            {
                结果 = 真
                跳出循环
            }
        }
        如果真 (结果 == 假)
        {
            如果真 (隐藏类型 < 0)
            {
                隐藏类型 = 0
            }
            如果真 (隐藏类型 > 3)
            {
                隐藏类型 = 3
            }
            全局隐藏类型 = 隐藏类型
            全局是否隐藏 = 是否隐藏
            临时句柄 = 安装 (句柄, 取静态方法地址 (消息处理))
            如果真 (临时句柄 > 0)
            {
                句柄组 [0].加入成员 (句柄)
                句柄组 [1].加入成员 (临时句柄)
                宽值.加入成员 (0)
                高值.加入成员 (0)
                宽值2.加入成员 (右侧间距)
                高值2.加入成员 (底部间距)
                取子控件尺寸 (句柄)
                更新滚动条 (句柄)
                锁.解锁 ()
                返回 (真)
            }
        }
        锁.解锁 ()
        返回 (假)
    }

    方法 取消绑定_ <公开 类型 = 逻辑型 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 结果 <类型 = 逻辑型>
        锁.加锁 ()
        句柄组 [0].枚举循环 ()
        {
            如果真 (句柄组 [0].取枚举值 () == 句柄)
            {
                滚动到零位_ (句柄)
                卸载 (句柄, 句柄组 [1].取枚举值 ())
                更新滚动条 (句柄, 真)
                句柄组 [0].删除成员 (句柄组 [0].取枚举索引 ())
                句柄组 [1].删除成员 (句柄组 [0].取枚举索引 ())
                宽值.删除成员 (句柄组 [0].取枚举索引 ())
                高值.删除成员 (句柄组 [0].取枚举索引 ())
                宽值2.删除成员 (句柄组 [0].取枚举索引 ())
                高值2.删除成员 (句柄组 [0].取枚举索引 ())
                结果 = 真
                跳出循环
            }
        }
        锁.解锁 ()
        返回 (结果)
    }

    方法 取消所有绑定_ <公开 折叠>
    {
        变量 句柄 <类型 = 变整数>
        锁.加锁 ()
        句柄组 [0].枚举循环 ()
        {
            句柄 = 句柄组 [0].取枚举值 ()
            滚动到零位_ (句柄)
            卸载 (句柄, 句柄组 [1].取枚举值 ())
            更新滚动条 (句柄, 真)
        }
        句柄组 [0].删除所有成员 ()
        句柄组 [1].删除所有成员 ()
        宽值.删除所有成员 ()
        高值.删除所有成员 ()
        宽值2.删除所有成员 ()
        高值2.删除所有成员 ()
        锁.解锁 ()
    }

    方法 重置滚动条_ <公开 注释 = "对于已绑定过的界面，重新按现界面刷新滚动条状态" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        取子控件尺寸 (句柄)
        更新滚动条 (句柄)
    }

    方法 禁用滚动条_ <公开 注释 = "禁用或激活滚动条" 折叠>
    参数 语句 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    参数 禁用类型 <类型 = 整数 注释 = "0、横向条　1、纵向条　3、全部" @默认值 = 3>
    参数 禁用位置 <类型 = 整数 注释 = "0、激活　1、禁用上调　2、禁用下调　3、禁用全部" @默认值 = 3>
    {
        如果真 (禁用类型 < 0)
        {
            禁用类型 = 0
        }
        如果真 (禁用类型 > 3)
        {
            禁用类型 = 3
        }
        如果真 (禁用位置 < 0)
        {
            禁用位置 = 0
        }
        如果真 (禁用位置 > 3)
        {
            禁用位置 = 3
        }
        如果真 (禁用类型 == 0 || 禁用类型 == 3)
        {
            滚动条Api类.EnableScrollBar (语句, 0, 禁用位置)
        }
        如果真 (禁用类型 == 1 || 禁用类型 == 3)
        {
            滚动条Api类.EnableScrollBar (语句, 1, 禁用位置)
        }
    }

    方法 隐藏滚动条_ <公开 注释 = "隐藏或显示滚动条" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    参数 隐藏类型 <类型 = 整数 注释 = "0、横向条　1、纵向条　3、全部" @默认值 = 0>
    参数 是否隐藏 <类型 = 逻辑型 @默认值 = 真>
    {
        句柄组 [0].枚举循环 ()
        {
            如果真 (句柄组 [0].取枚举值 () == 句柄)
            {
                计次循环 (100)
                {
                    发送消息_ (句柄, 277, 2, 0)
                    发送消息_ (句柄, 276, 2, 0)
                }
                跳出循环
            }
        }
        如果真 (隐藏类型 < 0)
        {
            隐藏类型 = 0
        }
        如果真 (隐藏类型 > 3)
        {
            隐藏类型 = 3
        }
        全局隐藏类型 = 隐藏类型
        全局是否隐藏 = 是否隐藏
        更新滚动条 (句柄)
    }

    方法 禁用鼠标滚轮_ <公开 折叠>
    参数 是否禁用 <类型 = 逻辑型 @默认值 = 真>
    {
        禁用滚轮 = 是否禁用
    }

    方法 置滚动方向_ <公开 折叠>
    参数 方向 <类型 = 整数 注释 = "0、横向　1、纵向" @默认值 = 1>
    {
        滚动方向 = 方向
    }

    方法 置滚动距离_ <公开 注释 = "鼠标滚轮单次滚动距离" 折叠>
    参数 距离 <类型 = 整数 @默认值 = 50>
    {
        滚动距离 = 距离
    }

    方法 置微调距离_ <公开 注释 = "点击滚动条调节按钮，单次变动距离" 折叠>
    参数 距离 <类型 = 整数 @默认值 = 10>
    {
        微调距离 = 距离
    }

    方法 置滚动条坐标_ <公开 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    参数 横向信息 <类型 = 滚动条信息类 注释 = "“取滚动条坐标_”命令所取得的数据" @默认值 = 空对象>
    参数 纵向信息 <类型 = 滚动条信息类 注释 = "“取滚动条坐标_”命令所取得的数据" @默认值 = 空对象>
    {
        变量 信息类 <类型 = 滚动条信息类>
        滚动到零位_ (句柄)
        信息类 = 取滚动条坐标_ (句柄, 0)
        滚动条Api类.ScrollWindow (句柄, 信息类.位置 - 横向信息.位置, 0, 0, 0)
        滚动条Api类.SetScrollPos (句柄, 0, -(信息类.位置 - 横向信息.位置), 1)
        信息类 = 取滚动条坐标_ (句柄, 1)
        滚动条Api类.ScrollWindow (句柄, 0, 信息类.位置 - 纵向信息.位置, 0, 0)
        滚动条Api类.SetScrollPos (句柄, 1, -(信息类.位置 - 纵向信息.位置), 1)
    }

    方法 滚动到零位_ <公开 注释 = "横向纵向均0位" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 信息值 <类型 = 滚动条信息类>
        变量 信息值2 <类型 = 滚动条信息类>
        信息值 = 取滚动条坐标_ (句柄, 1)
        信息值2 = 取滚动条坐标_ (句柄, 0)
        判断循环 (信息值.位置 > 0 || 信息值2.位置 > 0)
        {
            发送消息_ (句柄, 277, 2, 0)
            发送消息_ (句柄, 276, 2, 0)
            信息值 = 取滚动条坐标_ (句柄, 1)
            信息值2 = 取滚动条坐标_ (句柄, 0)
        }
    }

    方法 滚动到顶_ <公开 注释 = "到0位" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 信息值 <类型 = 滚动条信息类>
        信息值 = 取滚动条坐标_ (句柄, 1)
        判断循环 (信息值.位置 > 0)
        {
            发送消息_ (句柄, 277, 2, 0)
            信息值 = 取滚动条坐标_ (句柄, 1)
        }
    }

    方法 滚动到底_ <公开 注释 = "最底边" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 信息值 <类型 = 滚动条信息类>
        信息值 = 取滚动条坐标_ (句柄, 1)
        判断循环 (信息值.最大位置 - 信息值.位置 > 信息值.页尺寸)
        {
            发送消息_ (句柄, 277, 1, 0)
            信息值 = 取滚动条坐标_ (句柄, 1)
        }
        发送消息_ (句柄, 277, 1, 0)
    }

    方法 滚动到左_ <公开 注释 = "到0位" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 信息值 <类型 = 滚动条信息类>
        信息值 = 取滚动条坐标_ (句柄, 0)
        判断循环 (信息值.位置 > 0)
        {
            发送消息_ (句柄, 276, 2, 0)
            信息值 = 取滚动条坐标_ (句柄, 0)
        }
    }

    方法 滚动到右_ <公开 注释 = "最右边" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "窗口或布局界面句柄">
    {
        变量 信息值 <类型 = 滚动条信息类>
        信息值 = 取滚动条坐标_ (句柄, 0)
        判断循环 (信息值.最大位置 - 信息值.位置 > 信息值.页尺寸)
        {
            发送消息_ (句柄, 276, 1, 0)
            信息值 = 取滚动条坐标_ (句柄, 0)
        }
        发送消息_ (句柄, 276, 1, 0)
    }

    方法 取滚动条坐标_ <公开 类型 = 滚动条信息类 注释 = "取出当前坐标位，可通过“置滚动条坐标_”来定位之前取出的坐标位" 返回值注释 = "返回“滚动条信息类”" 折叠>
    参数 句柄 <类型 = 变整数>
    参数 滚动条类型 <类型 = 整数 注释 = "0、水平滚动条　1、垂直滚动条" @默认值 = 1>
    {
        变量 滚动信息 <类型 = 滚动条信息类>
        变量 返回值 <类型 = 滚动条信息类>
        如果真 (滚动条类型 < 0)
        {
            滚动条类型 = 0
        }
        如果真 (滚动条类型 > 1)
        {
            滚动条类型 = 1
        }
        滚动信息.结构大小 = 28
        滚动信息.总结构 = 23
        滚动条Api类.GetScrollInfo (句柄, 滚动条类型, 滚动信息)
        返回 (滚动信息)
    }

    方法 取子控件尺寸 <折叠>
    参数 句柄 <类型 = 变整数>
    {
        变量 hWndChild <类型 = 变整数>
        变量 rc <类型 = RECT矩形>
        变量 pt <类型 = POINT坐标>
        变量 i <类型 = 整数>
        hWndChild = 滚动条Api类.GetWindow (句柄, 5)
        判断循环 (hWndChild != 0)
        {
            滚动条Api类.GetWindowRect (hWndChild, rc)
            pt.x = rc.left
            pt.y = rc.top
            滚动条Api类.ScreenToClient (句柄, pt)
            滚动条Api类.OffsetRect (rc, pt.x - rc.left, pt.y - rc.top)
            循环 (, 句柄组 [0].取成员数 (), i)
            {
                如果真 (句柄组 [0].取成员 (i) == 句柄)
                {
                    如果真 (rc.right > 宽值.取成员 (i))
                    {
                        宽值.置成员值 (i, rc.right)
                    }
                    如果真 (rc.bottom > 高值.取成员 (i))
                    {
                        高值.置成员值 (i, rc.bottom)
                    }
                }
            }
            hWndChild = 滚动条Api类.GetWindow (hWndChild, 2)
        }
        循环 (, 句柄组 [0].取成员数 (), i)
        {
            如果真 (句柄组 [0].取成员 (i) == 句柄)
            {
                宽值.置成员值 (i, 宽值.取成员 (i) + 宽值2.取成员 (i))
                高值.置成员值 (i, 高值.取成员 (i) + 高值2.取成员 (i))
            }
        }
    }

    方法 更新滚动条 <折叠>
    参数 句柄 <类型 = 变整数>
    参数 归零 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 pt <类型 = POINT坐标>
        变量 nMaxWidth <类型 = 整数>
        变量 nMaxHeight <类型 = 整数>
        变量 rc <类型 = RECT矩形>
        变量 nWidth <类型 = 整数>
        变量 nHeight <类型 = 整数>
        变量 bVert <类型 = 逻辑型>
        变量 bHorz <类型 = 逻辑型>
        变量 信息类 <类型 = 滚动条信息类>
        变量 i <类型 = 整数>
        pt.x = 滚动条Api类.GetScrollPos (句柄, 0)
        pt.y = 滚动条Api类.GetScrollPos (句柄, 1)
        循环 (, 句柄组 [0].取成员数 (), i)
        {
            如果真 (句柄组 [0].取成员 (i) == 句柄)
            {
                nMaxWidth = 宽值.取成员 (i)
                nMaxHeight = 高值.取成员 (i)
            }
        }
        如果 (归零 == 真)
        {
            nWidth = 3072
            nHeight = 2048
        }
        否则
        {
            滚动条Api类.GetClientRect (句柄, rc)
            nWidth = rc.right - rc.left
            nHeight = rc.bottom - rc.top
        }
        如果 (nMaxWidth > nWidth && nMaxHeight > nHeight)
        {
            如果真 (全局是否隐藏)
            {
                如果 (全局隐藏类型 == 0)
                {
                    滚动条Api类.ShowScrollBar (句柄, 0, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 1)
                {
                    滚动条Api类.ShowScrollBar (句柄, 1, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 3)
                {
                    滚动条Api类.ShowScrollBar (句柄, 3, 选择 (全局是否隐藏 == 真, 0, 1))
                }
            }
            bVert = 真
            bHorz = 真
        }
        否则 (nMaxWidth > nWidth)
        {
            如果真 (全局是否隐藏)
            {
                如果 (全局隐藏类型 == 0)
                {
                    滚动条Api类.ShowScrollBar (句柄, 0, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 1)
                {
                    滚动条Api类.ShowScrollBar (句柄, 1, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 3)
                {
                    滚动条Api类.ShowScrollBar (句柄, 3, 选择 (全局是否隐藏 == 真, 0, 1))
                }
            }
            bHorz = 真
        }
        否则 (nMaxHeight > nHeight)
        {
            如果真 (全局是否隐藏)
            {
                如果 (全局隐藏类型 == 0)
                {
                    滚动条Api类.ShowScrollBar (句柄, 0, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 1)
                {
                    滚动条Api类.ShowScrollBar (句柄, 1, 选择 (全局是否隐藏 == 真, 0, 1))
                }
                否则 (全局隐藏类型 == 3)
                {
                    滚动条Api类.ShowScrollBar (句柄, 3, 选择 (全局是否隐藏 == 真, 0, 1))
                }
            }
            bVert = 真
        }
        否则
        {
            滚动条Api类.ShowScrollBar (句柄, 3, 0)
        }
        如果 (归零 == 真)
        {
            nWidth = 3072
            nHeight = 2048
        }
        否则
        {
            滚动条Api类.GetClientRect (句柄, rc)
            nWidth = rc.right - rc.left
            nHeight = rc.bottom - rc.top
        }
        信息类.结构大小 = 取数据尺寸 (信息类)
        信息类.最小位置 = 0
        信息类.总结构 = 23
        如果 (bVert)
        {
            信息类.最大位置 = nMaxHeight
            信息类.页尺寸 = nHeight
            如果真 (pt.y <= nMaxHeight)
            {
                信息类.位置 = pt.y
            }
            滚动条Api类.SetScrollInfo (句柄, 1, 信息类, 真)
        }
        否则
        {
            信息类.最大位置 = 0
            信息类.页尺寸 = 0
            信息类.位置 = 0
            滚动条Api类.SetScrollInfo (句柄, 1, 信息类, 真)
        }
        如果 (bHorz)
        {
            信息类.最大位置 = nMaxWidth
            信息类.页尺寸 = nWidth
            如果真 (pt.x <= nMaxWidth)
            {
                信息类.位置 = pt.x
            }
            滚动条Api类.SetScrollInfo (句柄, 0, 信息类, 真)
        }
        否则
        {
            信息类.最大位置 = 0
            信息类.页尺寸 = 0
            信息类.位置 = 0
            滚动条Api类.SetScrollInfo (句柄, 0, 信息类, 真)
        }
    }

    方法 消息处理 <静态 类型 = 变整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 wMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        如果真 (窗口_取窗口组件类名 (窗口_取鼠标处窗口句柄 ()) != "msctls_trackbar32")
        {
            如果 (wMsg == 277)
            {
                返回 (读指针处对象 (指针, 界面滚动条类_).纵横滚动 (句柄, wMsg, wParam, lParam, 1))
            }
            否则 (wMsg == 276)
            {
                返回 (读指针处对象 (指针, 界面滚动条类_).纵横滚动 (句柄, wMsg, wParam, lParam, 0))
            }
            否则 (wMsg == 522 && 禁用滚轮 == 假)  // 滚轮
            {
                返回 (读指针处对象 (指针, 界面滚动条类_).鼠标滚动 (句柄, wMsg, wParam, lParam, 滚动方向))
            }
            否则 (wMsg == 5)
            {
                返回 (读指针处对象 (指针, 界面滚动条类_).更新尺寸 (句柄, wMsg, wParam, lParam))
            }
        }
        读指针处对象 (指针, 界面滚动条类_).句柄组 [0].枚举循环 ()
        {
            如果真 (读指针处对象 (指针, 界面滚动条类_).句柄组 [0].取枚举值 () == 句柄)
            {
                返回 (滚动条Api类.CallWindowProcA (读指针处对象 (指针, 界面滚动条类_).句柄组 [1].取枚举值 (), 句柄, wMsg, wParam, lParam))
            }
        }
        返回 (滚动条Api类.CallWindowProcA (创建句柄, 句柄, wMsg, wParam, lParam))
    }

    方法 纵横滚动 <类型 = 变整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 wMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    参数 方向 <类型 = 整数 注释 = "0、横向　1、纵向">
    {
        变量 调节类型 <类型 = 整数>
        变量 nPos <类型 = 整数>
        变量 信息类 <类型 = 滚动条信息类>
        变量 可调大小 <类型 = 整数>
        变量 调节大小 <类型 = 整数>
        变量 消息 <类型 = 变整数>
        调节类型 = 滚动条Api类.LOWORD (wParam)
        nPos = 滚动条Api类.HIWORD (wParam)
        信息类.结构大小 = 取数据尺寸 (信息类)
        信息类.总结构 = 23
        如果 (方向 == 1)
        {
            滚动条Api类.GetScrollInfo (句柄, 1, 信息类)
        }
        否则
        {
            滚动条Api类.GetScrollInfo (句柄, 0, 信息类)
        }
        可调大小 = 信息类.最大位置 - 信息类.页尺寸
        如果 (调节类型 == 0)  // 上调节按钮
        {
            如果真 (信息类.位置 != 0)
            {
                如果 (信息类.位置 < 微调距离)
                {
                    调节大小 = 信息类.位置
                }
                否则
                {
                    调节大小 = 微调距离
                }
            }
        }
        否则 (调节类型 == 1)  // 下调节按钮
        {
            如果真 (信息类.位置 != 可调大小)
            {
                如果 (可调大小 - 信息类.位置 < 微调距离)
                {
                    调节大小 = -(可调大小 - 信息类.位置)
                }
                否则
                {
                    调节大小 = -微调距离
                }
            }
        }
        否则 (调节类型 == 2)  // 上滑块区
        {
            如果真 (信息类.位置 != 0)
            {
                如果 (信息类.位置 - 信息类.页尺寸 < 0)
                {
                    调节大小 = 信息类.位置
                }
                否则
                {
                    调节大小 = 信息类.页尺寸
                }
            }
        }
        否则 (调节类型 == 3)  // 下滑块区
        {
            如果真 (信息类.位置 != 可调大小)
            {
                如果 (可调大小 - 信息类.位置 < 信息类.页尺寸)
                {
                    调节大小 = -(可调大小 - 信息类.位置)
                }
                否则
                {
                    调节大小 = -信息类.页尺寸
                }
            }
        }
        否则 (调节类型 == 5)  // 拖动
        {
            调节大小 = 信息类.位置 - nPos
        }
        如果 (方向 == 1)
        {
            滚动条Api类.ScrollWindow (句柄, 0, 调节大小, 0, 0)
            滚动条Api类.SetScrollPos (句柄, 1, 信息类.位置 - 调节大小, 1)
        }
        否则
        {
            滚动条Api类.ScrollWindow (句柄, 调节大小, 0, 0, 0)
            滚动条Api类.SetScrollPos (句柄, 0, 信息类.位置 - 调节大小, 1)
        }
        消息 = 滚动条Api类.CallWindowProcA (创建句柄, 句柄, wMsg, wParam, lParam)
        返回 (消息)
    }

    方法 鼠标滚动 <类型 = 变整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 wMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    参数 方向 <类型 = 整数 注释 = "0、横向　1、纵向">
    {
        变量 调节类型 <类型 = 整数>
        变量 信息类 <类型 = 滚动条信息类>
        变量 可调大小 <类型 = 整数>
        变量 调节大小 <类型 = 整数>
        变量 消息 <类型 = 变整数>
        变量 结果 <类型 = 逻辑型>
        调节类型 = 滚动条Api类.LOWORD (wParam)
        滚动条Api类.HIWORD (wParam)
        信息类.结构大小 = 取数据尺寸 (信息类)
        信息类.总结构 = 23
        如果 (方向 == 1)
        {
            滚动条Api类.GetScrollInfo (句柄, 1, 信息类)
        }
        否则
        {
            滚动条Api类.GetScrollInfo (句柄, 0, 信息类)
        }
        可调大小 = 信息类.最大位置 - 信息类.页尺寸
        如果真 (调节类型 == 0 && wParam == -7864320)  // 下
        {
            结果 = 真
        }
        如果真 (调节类型 == 0 && wParam == 4287102976)  // 下
        {
            结果 = 真
        }
        如果 (结果)
        {
            如果 (可调大小 - 信息类.位置 < 滚动距离)
            {
                调节大小 = -(可调大小 - 信息类.位置)
            }
            否则
            {
                调节大小 = -滚动距离
            }
        }
        否则 (调节类型 == 0 && wParam == 7864320)
        {
            如果 (信息类.位置 < 滚动距离)
            {
                调节大小 = 信息类.位置
            }
            否则
            {
                调节大小 = 滚动距离
            }
        }
        如果 (方向 == 1)
        {
            滚动条Api类.ScrollWindow (句柄, 0, 调节大小, 0, 0)
            滚动条Api类.SetScrollPos (句柄, 1, 信息类.位置 - 调节大小, 1)
        }
        否则
        {
            滚动条Api类.ScrollWindow (句柄, 调节大小, 0, 0, 0)
            滚动条Api类.SetScrollPos (句柄, 0, 信息类.位置 - 调节大小, 1)
        }
        消息 = 滚动条Api类.CallWindowProcA (创建句柄, 句柄, wMsg, wParam, lParam)
        返回 (消息)
    }

    方法 更新尺寸 <类型 = 变整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 wMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        滚动到零位_ (句柄)
        如果真 (滚动条Api类.IsIconic (句柄) == 0)
        {
            更新滚动条 (句柄)
        }
        返回 (滚动条Api类.CallWindowProcA (创建句柄, 句柄, wMsg, wParam, lParam))
    }

    方法 卸载 <折叠>
    参数 句柄 <类型 = 变整数>
    参数 绑定句柄 <类型 = 变整数>
    {
        滚动条Api类.SetWindowLongPtrW (句柄, -4, 绑定句柄)
    }

    方法 安装 <类型 = 变整数 折叠>
    参数 句柄 <类型 = 变整数>
    参数 消息程序 <类型 = 变整数>
    {
        创建句柄 = 滚动条Api类.SetWindowLongPtrW (句柄, -4, 消息程序)
        返回 (创建句柄)
    }
}

