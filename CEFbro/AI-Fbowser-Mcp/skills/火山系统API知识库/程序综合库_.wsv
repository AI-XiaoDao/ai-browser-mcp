    方法 键盘_键代码转键名 <公开 静态 类型 = 文本型 折叠>
    参数 键代码 <类型 = 整数>
    {
        变量 lParam <类型 = 整数>
        变量 String <类型 = 文本型>
        <折叠> 如果 (键代码 == 19)
        {
            String = "Pause"
        }
        <折叠> 否则 (键代码 == 20)
        {
            String = "Caps Lock"
        }
        <折叠> 否则 (键代码 == 106)
        {
            String = "*"
        }
        <折叠> 否则 (键代码 == 107)
        {
            String = "+"
        }
        <折叠> 否则 (键代码 == 144)
        {
            String = "Num Lock"
        }
        <折叠> 否则 (键代码 == 145)
        {
            String = "Scroll Lock"
        }
        <折叠> 否则 (键代码 == 33)
        {
            String = "Page Up"
        }
        <折叠> 否则 (键代码 == 34)
        {
            String = "Page Down"
        }
        <折叠> 否则 (键代码 == 35)
        {
            String = "End"
        }
        <折叠> 否则 (键代码 == 36)
        {
            String = "Home"
        }
        <折叠> 否则 (键代码 == 37)
        {
            String = "←"
        }
        <折叠> 否则 (键代码 == 38)
        {
            String = "↑"
        }
        <折叠> 否则 (键代码 == 39)
        {
            String = "→"
        }
        <折叠> 否则 (键代码 == 40)
        {
            String = "↓"
        }
        <折叠> 否则 (键代码 == 45)
        {
            String = "Ins"
        }
        <折叠> 否则 (键代码 == 46)
        {
            String = "Del"
        }
        <折叠> 否则 (键代码 == 91)
        {
            String = "左Win"
        }
        <折叠> 否则 (键代码 == 92)
        {
            String = "右Win"
        }
        <折叠> 否则
        {
            lParam = 位左移 (键盘类API.MapVirtualKeyW (键代码, 0), 16)
            String = 取空白文本 (256)
            键盘类API.GetKeyNameTextW (lParam, String, 256)
        }
        返回 (String)
    }

    方法 键盘_取键盘大小写状态 <公开 静态 类型 = 逻辑型 注释 = "取当前的输入状态" 返回值注释 = "返回真为大写，返回假则为小写" 折叠>
    {
        返回 (键盘类API.GetKeyState (20))
    }

    方法 键盘_取小键盘状态 <公开 静态 类型 = 逻辑型 注释 = "取当前的输入状态" 返回值注释 = "返回真为开，返回假则为关" 折叠>
    {
        返回 (键盘类API.GetKeyState (144))
    }
