类 CPU使用率类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.CPU使用率\"" @视窗.外部头文件 = "cpu\\CPU.h" @视窗.外部源文件 = "cpu\\CPU.cpp" @全局类 = 真>
{

    # @ CCPUMemDiskStatus m_CpuMemDiskStatus;

    方法 CPU_取CPU使用率 <公开 静态 类型 = 整数 折叠 折叠2 @禁止流程检查 = 真 "">
    {
        @ m_CpuMemDiskStatus.SystemCpuInit();
        @ Sleep(500);
        @ double CpuMemDisk = m_CpuMemDiskStatus.GetSystemCpuCurrentUsage();
        @ m_CpuMemDiskStatus.SystemCpuUnInit();
        @ return RoundDouble (CpuMemDisk, 0);
    }
}

