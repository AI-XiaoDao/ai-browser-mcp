        如果真 (sysenv.方法 ("Remove", 整数, 环境变量名称) == 0)
        {
            bool = 真
        }
        sysenv.清除 ()
        objcet.清除 ()
        返回 (bool)
    }

    方法 取环境变量数_ <公开 静态 类型 = 整数 折叠>
    参数 用户环境变量 <类型 = 逻辑型 注释 = "真为当前用户环境变量，假为系统环境变量" @默认值 = 真>
    {
        变量 objcet <类型 = COM对象类>
        变量 sysenv <类型 = COM对象类>
        变量 length <类型 = 整数>
        objcet.创建 ("WScript.Shell", )
        sysenv = objcet.对象型方法 ("Environment", COM对象类, 选择 (用户环境变量, "user", "system"))
        length = sysenv.读无参数属性 ("length", 整数)
