类 调色板类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.调色板\"" @全局类 = 真>
{
    方法 颜色_弹出调色板 <公开 静态 类型 = 逻辑型 注释 = "颜色类.取颜色值 (颜色值.红色, 颜色值.绿色, 颜色值.蓝色)" 返回值注释 = "取得颜色值返回真" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 返回的颜色值 <类型 = 颜色值类_ 注释 = "返回“颜色值类_”">
    参数 初始颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 自定义颜色 <类型 = 整数数组类 注释 = "默认为统一白色，最多有效设置16种颜色" @默认值 = 空对象>
    {
        变量 颜色值 <类型 = 整数>
        变量 i <类型 = 整数>
        @  CHOOSECOLOR cc;
        @  static COLORREF acrCustClr[16];
        如果 (是否为空对象 (自定义颜色) == 假)
        {
            循环 (, 自定义颜色.取成员数 (), i)
            {
                颜色值 = 自定义颜色.取成员 (i)
                @ acrCustClr[@<i>]=@<颜色值>;
            }
        }
        否则
        {
            循环 (, 16, i)
            {
                颜色值 = 颜色类.白色
                @ acrCustClr[@<i>]=@<颜色值>;
            }
        }
        @  ZeroMemory(&cc, sizeof(cc));
        @  cc.lStructSize = sizeof(cc);
        @  cc.hwndOwner = (HWND)@<窗口句柄>;
        @  cc.lpCustColors = (LPDWORD)acrCustClr;
        @  cc.rgbResult = @<初始颜色>;
        @  cc.Flags = CC_FULLOPEN | CC_RGBINIT; 
        @  if (ChooseColor(&cc) == TRUE) {
        @   @<返回的颜色值.红色> = (cc.rgbResult & 0x0000ff);
        @   @<返回的颜色值.绿色> = (cc.rgbResult & 0x00FF00) >> 8;
        @   @<返回的颜色值.蓝色> = (cc.rgbResult & 0xff0000) >> 16;
        @   return true;
        @  }
        @   return false;
    }
}

