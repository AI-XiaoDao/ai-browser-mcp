    方法 创建菜单体_ <公开 类型 = 变整数 注释 = "菜单点击事件将从“我的主窗口_接收到命令”中返回，从“命令代码”参数中判断是某个菜单被点击(菜单ID)" 返回值注释 = "返回根菜单句柄，用于“创建下拉项”" 折叠
            @禁止流程检查 = 真>
    参数 菜单根名称 <类型 = 文本型>
    参数 创建组 <类型 = 菜单创建组类 注释 = "本参数包含了菜单名称和菜单图标，通过新建“菜单创建组类”变量，然后高调用变量，创建组.加入菜单素材组(\"名称1\",图标1)." 注释 = "最后将变量名填入本参数即可" 折叠2>
    参数 菜单起始ID <类型 = 整数 @默认值 = 20000>
    {
        变量 图标句柄组 <类型 = 变整数数组类>
        变量 根句柄 <类型 = 变整数>
        @ HMENU h = CreateMenu ();//创建一个菜单
        @ @<根句柄>=(@dt<变整数>)h;

        @ const INT nCount = (INT)@<创建组.名称组>.data ().GetCount ();
        @ for (INT i = 0; i < nCount; i++)
        @ {
        @ CVolString 名称项 = (@<创建组.名称组>.data ().GetAt (i));
        @ if (名称项==L"-")
        @ {
        @ AppendMenu (h, MF_SEPARATOR, i,L"");//追加菜单项
        @ }
        @ else
        @ AppendMenu (h, 0 + 0, i+@<菜单起始ID>,名称项);
        @ }

        @ HMENU 菜单体 = CreateMenu ();//创建一个菜单
        @ AppendMenu (菜单体, 16,(UINT_PTR)h, @<菜单根名称>);

        图标句柄组 = 取图标句柄 (创建组.图标组)
        @ const INT nCount2 = (INT)@<图标句柄组>.data ().GetCount ();
        @ for (INT i = 0; i < nCount2; i++)
        @ {
        @ INT_P 句柄 = @<图标句柄组>.data ().GetAt (i);
        @ SetMenuItemBitmaps (h, i, MF_BYPOSITION, (HBITMAP)句柄,(HBITMAP)句柄);
        @ }
        返回 (根句柄)
    }

    方法 创建根菜单_ <公开 类型 = 变整数 返回值注释 = "返回创建的菜单句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单根名称 <类型 = 文本型>
    {
        变量 子句柄 <类型 = 变整数>
        @ HMENU hMenu = GetMenu ((HWND)@<窗口句柄>); 
        @ HMENU h = CreatePopupMenu ();
        @ @<子句柄>=(@dt<变整数>)h;
        @ AppendMenu (hMenu, 16,(UINT_PTR)h, @<菜单根名称>);
        返回 (子句柄)
    }

    方法 创建下拉项_ <公开 类型 = 变整数 返回值注释 = "返回子菜单句柄" 折叠 @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 菜单主项名称 <类型 = 文本型>
    参数 菜单主项图标 <类型 = 视窗文件资源 @默认值 = 空资源.空文件>
    参数 菜单子项创建组 <类型 = 菜单创建组类 注释 = "本参数包含了菜单名称和菜单图标，通过新建“菜单创建组类”变量，然后高调用变量，创建组.加入菜单素材组(\"名称1\",图标1)." 注释 = "最后将变量名填入本参数即可" 折叠2>
    参数 菜单起始ID <类型 = 整数 @默认值 = 22000>
    {
        变量 图标句柄组 <类型 = 变整数数组类>
        变量 图标句柄 <类型 = 变整数>
        变量 子句柄 <类型 = 变整数>
        图标句柄 = 内置取图标句柄 (菜单主项图标)
        @ HMENU h = CreatePopupMenu ();//创建一个下拉式子菜单
        @ @<子句柄>=(@dt<变整数>)h;
        @ AppendMenu ((HMENU)@<菜单根句柄>, 16, (UINT_PTR)h,@<菜单主项名称>);

        @ const INT nCount = (INT)@<菜单子项创建组.名称组>.data ().GetCount ();
        @ for (INT i = 0; i < nCount; i++)
        @ {
        @ CVolString 名称项 = (@<菜单子项创建组.名称组>.data ().GetAt (i));
        @ if (名称项==L"-")
        @ {
        @ AppendMenu (h, MF_SEPARATOR, i,L"");//追加菜单项
        @ }
        @ else
        @ AppendMenu (h, 0 + 0, i+@<菜单起始ID>,名称项);
        @ }

        @ int 数量 = GetMenuItemCount((HMENU)@<菜单根句柄>)-1;//取菜单数量
        @ SetMenuItemBitmaps ((HMENU)@<菜单根句柄>, 数量, MF_BYPOSITION, (HBITMAP)@<图标句柄>,(HBITMAP)@<图标句柄>);

        图标句柄组 = 取图标句柄 (菜单子项创建组.图标组)
        @ const INT nCount2 = (INT)@<图标句柄组>.data ().GetCount ();
        @ for (INT i = 0; i < nCount2; i++)
        @ {
        @ INT_P 句柄 = @<图标句柄组>.data ().GetAt (i);
        @ SetMenuItemBitmaps (h, i, MF_BYPOSITION, (HBITMAP)句柄,(HBITMAP)句柄);
        @ }
        返回 (子句柄)
    }

    方法 插入菜单项_ <公开 折叠 @禁止流程检查 = 真>
    参数 菜单根句柄 <类型 = 变整数 注释 = "“取菜单根句柄_”，“取子菜单句柄_”，“创建菜单体_”，“创建下拉项_”时返回的句柄">
    参数 插入位索引 <类型 = 整数>
    参数 新菜单名称 <类型 = 文本型 注释 = "- 表示添加分隔线">
    参数 新菜单图标 <类型 = 视窗文件资源 @默认值 = 空资源.空文件>
    参数 新菜单ID <类型 = 整数>
    {
        变量 图标句柄 <类型 = 变整数>
        图标句柄 = 内置取图标句柄 (新菜单图标)
        @ UINT hID = GetMenuItemID ((HMENU)@<菜单根句柄>,@<插入位索引>);
        @ if (@<新菜单名称>==L"-")
        @ {
        @ InsertMenu((HMENU)@<菜单根句柄>,hID, MF_SEPARATOR, @<新菜单ID>,L"");
        @ }
        @ else
        @ {
        @ InsertMenu((HMENU)@<菜单根句柄>,hID, MF_UNCHECKED, @<新菜单ID>,@<新菜单名称>);
        @ }
        @ SetMenuItemBitmaps ((HMENU)@<菜单根句柄>, @<插入位索引>, MF_BYPOSITION, (HBITMAP)@<图标句柄>,(HBITMAP)@<图标句柄>);
    }

