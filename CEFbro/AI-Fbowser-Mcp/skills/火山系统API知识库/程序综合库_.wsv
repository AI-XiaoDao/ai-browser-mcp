类 图标句柄类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.图标句柄\"" @全局类 = 真>
{
    方法 图标_取图标句柄 <公开 静态 类型 = 变整数 折叠>
    参数 图标数据 <类型 = 字节集类>
    {
        变量 图片 <类型 = COM对象类>
        变量 临时图组 <静态 类型 = 对象数组类>
        变量 图片资源 <类型 = 位图对象类>
        变量 图片句柄 <类型 = 变整数>
        变量 索引 <类型 = 整数>
        初始化COM库_ ()
        索引 = 临时图组.加入成员 (新建对象 (COM对象类))
        图片资源 = 载入位图数据 (图标数据)
        ((COM对象类)临时图组.取成员 (索引)).创建图片对象 (图片资源)
        图片句柄 = ((COM对象类)临时图组.取成员 (索引)).无参数方法 ("Handle", 变整数)
        关闭COM库_ ()
        返回 (图片句柄)
    }

    方法 图标_取图标句柄2 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 实例句柄 <类型 = 变整数 注释 = "可空" @默认值 = 0>
    参数 图标路径 <类型 = 文本型>
    参数 图像类型 <类型 = 整数 注释 = "0、bmp位图 1、ico图标 3、cur光标" @默认值 = 0>
    参数 宽度 <类型 = 整数 @默认值 = 16>
    参数 高度 <类型 = 整数 @默认值 = 16>
    {
        @ return (INT_P)LoadImage((HINSTANCE)@<实例句柄>,@<图标路径>.GetText(),@<图像类型>,@<宽度>,@<高度>,LR_LOADFROMFILE | LR_CREATEDIBSECTION | LR_DEFAULTSIZE);
    }

    方法 图标_取图标句柄3 <公开 静态 类型 = 变整数 注释 = "ico" 折叠 @禁止流程检查 = 真>
    参数 图标数据 <类型 = 字节集类>
    参数 宽度 <类型 = 整数 @默认值 = 16>
    参数 高度 <类型 = 整数 @默认值 = 16>
    {
        @ #pragma pack(push, 2)
        @ typedef struct {
        @     WORD idReserved;
        @     WORD idType;
        @     WORD idCount;
        @ } ICONDIR, *PICONDIR;
        @ typedef struct {
        @     BYTE bWidth;
        @     BYTE bHeight;
        @     BYTE bColorCount;
        @     BYTE bReserved;
        @     WORD wPlanes;
        @     WORD wBitCount;
        @     DWORD dwBytesInRes;
        @     DWORD dwImageOffset;
        @ } ICONDIRENTRY, *PICONDIRENTRY;
        @ #pragma pack(pop)
        @ if (@<图标数据>.GetSize() < sizeof(ICONDIR)) return 0;
        @ PICONDIR pIconDir = (PICONDIR)@<图标数据>.GetPtr();
        @ if (pIconDir->idReserved != 0 || pIconDir->idType != 1) return 0;
        @ int bestMatchIndex = -1;
        @ int bestSizeDiff = INT_MAX;
        @ int bestBitDepth = 0;
        @ for (int i = 0; i < pIconDir->idCount; ++i) {
        @     PICONDIRENTRY entry = (PICONDIRENTRY)(@<图标数据>.GetPtr() + sizeof(ICONDIR) + i * sizeof(ICONDIRENTRY));
        @     int actualWidth = entry->bWidth == 0 ? 256 : entry->bWidth;
        @     int actualHeight = entry->bHeight == 0 ? 256 : entry->bHeight;
        @     int sizeDiff = abs(actualWidth - @<宽度>) + abs(actualHeight - @<高度>);
        @         
        @     if (sizeDiff < bestSizeDiff || 
        @         (sizeDiff == bestSizeDiff && entry->wBitCount > bestBitDepth)) {
        @         bestSizeDiff = sizeDiff;
        @         bestMatchIndex = i;
        @         bestBitDepth = entry->wBitCount;
        @     }
        @ }
        @ if (bestMatchIndex == -1) return 0;
        @ PICONDIRENTRY bestEntry = (PICONDIRENTRY)(@<图标数据>.GetPtr() + sizeof(ICONDIR) + bestMatchIndex * sizeof(ICONDIRENTRY));
        @ DWORD imageOffset = bestEntry->dwImageOffset;
        @ DWORD imageSize = bestEntry->dwBytesInRes;
        @ if (imageOffset + imageSize > @<图标数据>.GetSize()) return 0;
        @ return (INT_P)CreateIconFromResourceEx(
        @         (PBYTE)@<图标数据>.GetPtr() + imageOffset,
        @         imageSize,
        @         TRUE,
        @         0x00030000,
        @         @<宽度>,
        @         @<高度>,
        @         LR_CREATEDIBSECTION | LR_DEFAULTSIZE
        @     );
    }
}

