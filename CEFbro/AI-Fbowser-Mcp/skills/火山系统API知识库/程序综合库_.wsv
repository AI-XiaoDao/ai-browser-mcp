    变量 屏幕 <公开 静态 类型 = 文本型 值 = "start ms-settings:display">
    变量 字体 <公开 静态 类型 = 文本型 值 = "control fonts">
    变量 声音 <公开 静态 类型 = 文本型 值 = "control mmsys.cpl sounds" 注释 = "控制面板">
    变量 声音2 <公开 静态 类型 = 文本型 值 = "start ms-settings:sound">
    变量 键盘 <公开 静态 类型 = 文本型 值 = "control keyboard">
    变量 任务栏 <公开 静态 类型 = 文本型 值 = "start ms-settings:taskbar">
    变量 背景主题 <公开 静态 类型 = 文本型 值 = "start ms-settings:personalization">
    变量 语言 <公开 静态 类型 = 文本型 值 = "start ms-settings:regionlanguage">
}

