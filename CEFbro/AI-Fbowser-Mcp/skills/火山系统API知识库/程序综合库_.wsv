<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"程序综合库\"">

类 格式化类_ <公开 注释 = "从宽字符串读取数据，将文本数据以指定的格式，分配到对应的变量中" 折叠 折叠2 @文档 = "category = \"程序综合库.格式化数据\"" @全局类 = 真>
{
    方法 取格式数据_ <公开 静态 注释 = "swscanf" 折叠 @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 文本数据 <类型 = 文本型>
    参数 格式文本 <类型 = 文本型 注释 = "%c: 字符、%d: 整数。例如：文本是：\"ab_1_2.png\"，格式为：\"ab_%d_%d.png\"，那么会得到1和2两个数字">
    参数 存放变量 <注释 = "获取的数据存放变量." 注释 = "文本型变量需要通过新建的变量“取空白文本 (xxx)”，数值型变量需要通过“取变量地址 (xxx)”" @匹配类型 = 通用基本型
            @可扩展 = "d_text = \" , \"">
    {
        @ swscanf (@<文本数据>.GetText(),@<格式文本>.GetText(),@<存放变量>)
    }

    方法 取格式数据_数值 <公开 静态 注释 = "swscanf" 折叠 @嵌入式方法 = "">
    参数 文本数据 <类型 = 文本型>
    参数 格式文本 <类型 = 文本型 注释 = "%c: 字符、%d: 整数。例如：文本是：\"ab_1_2.png\"，格式为：\"ab_%d_%d.png\"，那么会得到1和2两个数字">
    参数 存放变量 <注释 = "获取的数据存放变量." 注释 = "直接传递数值型变量，无需取变量地址" @匹配类型 = 通用数值型 @需求类型 = 可写入变量 @可扩展 = "d_text = \",&\"">
    {
        @ swscanf (@<文本数据>.GetText(),@<格式文本>.GetText(),&@<存放变量>)
    }
}

# //======

类 链表排序例子 <折叠>
{
    变量 案例1 <类型 = 文本型
            值 = "<火山程序 类型 = \"通常\" 版本 = 1 />\r\n\r\n类 我的主窗口 <基础类 = 窗口 @视窗.布局 = \"client_size = \\\"534, 279\\\"\">\r\n{\r\n    变量 按钮1 <类型 = 按钮 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 101\\r\\npos = \\\"234, 243, 64, 26\\\"\" 标题 = \"排序\">\r\n    变量 编辑框1 <类型 = 编辑框 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 102\\r\\npos = \\\"4, 6, 521, 224\\\"\" 是否允许多行 = 真\r\n            滚动条 = 纵向滚动条>\r\n    变量 list <类型 = 排序模板组>\r\n\r\n    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 注释 = \"当本组件及其中所有子组件均被创建完毕后发送此事件.\">\r\n    参数 来源对象 <类型 = 我的主窗口 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        变量 数据组 <类型 = 文本数组类>\r\n        数据组.加入成员 (\"C:\\\\哈哈哈哈\\\\63m镭射\\\\1个侯q110\\\\1742306855312_结果.jpeg\")\r\n        数据组.加入成员 (\"C:\\\\哈哈哈哈\\\\63m镭射\\\\20个侯q147\\\\1742295918154_结果.jpeg\")\r\n        数据组.加入成员 (\"C:\\\\哈哈哈哈\\\\63m镭射\\\\2个侯q81\\\\1742312024254_结果.jpeg\")\r\n        数据组.加入成员 (\"C:\\\\哈哈哈哈\\\\63m镭射\\\\5个侯q16\\\\5vfIl76UJ2pt_结果.jpeg\")\r\n        加入数据 (数据组)  // 这里模拟枚举到的目录文件\r\n\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本行 (\" 内容:\" + 读取.内容)\r\n        }\r\n        返回 (0)\r\n    }\r\n\r\n    方法 加入数据\r\n    参数 数据包 <类型 = 文本数组类>\r\n    {\r\n        变量 临时数据 <类型 = 数据模板>\r\n        数据包.枚举循环 ()\r\n        {\r\n            临时数据.内容 = 数据包.取枚举值 ()\r\n            list.加入成员 (临时数据)\r\n        }\r\n    }\r\n\r\n    方法 按钮_被单击 <接收事件 类型 = 整数 注释 = \"当按钮被单击后发送此事件\">\r\n    参数 来源对象 <类型 = 按钮 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        list.排序 (自定义排序)\r\n        编辑框1.加入文本行 (\"-----按名称小到大排序-------\")\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本行 (\" 内容:\" + 读取.内容)\r\n        }\r\n        返回 (0)\r\n    }\r\n\r\n    方法 自定义排序 <静态 类型 = 逻辑型>\r\n    参数 数据1 <类型 = 数据模板>\r\n    参数 数据2 <类型 = 数据模板>\r\n    {\r\n        变量 a1 <类型 = 整数>\r\n        变量 a2 <类型 = 整数>\r\n        a1 = 文本到整数 (取文本中间_ (数据1.内容, \"镭射\\\\\", \"个侯q\"))\r\n        a2 = 文本到整数 (取文本中间_ (数据2.内容, \"镭射\\\\\", \"个侯q\"))\r\n        如果 (a1 <= a2)\r\n        {\r\n            返回 (真)\r\n        }\r\n        返回 (假)\r\n    }\r\n}\r\n\r\n类 数据模板 <公开 基础类 = 扩展对象类>\r\n{\r\n    变量 内容 <公开 类型 = 文本型>\r\n}\r\n\r\n类 排序模板组 <公开 基础类 = 链表排序类_ @模板实现类 = \"数据模板\">"
            编辑时信息 = "0, 99608, 0, 0">
    变量 案例2 <类型 = 文本型
            值 = "<火山程序 类型 = \"通常\" 版本 = 1 />\r\n\r\n类 我的主窗口 <基础类 = 窗口 @视窗.布局 = \"client_size = \\\"534, 279\\\"\">\r\n{\r\n    变量 按钮1 <类型 = 按钮 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 101\\r\\npos = \\\"234, 243, 64, 26\\\"\" 标题 = \"排序\">\r\n    变量 编辑框1 <类型 = 编辑框 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 102\\r\\npos = \\\"4, 6, 521, 224\\\"\" 是否允许多行 = 真\r\n            滚动条 = 纵向滚动条>\r\n    变量 list <类型 = 排序模板组>\r\n\r\n    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 注释 = \"当本组件及其中所有子组件均被创建完毕后发送此事件.\">\r\n    参数 来源对象 <类型 = 我的主窗口 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        变量 数据组 <类型 = 文本数组类>\r\n        数据组.加入成员 (\"ab_1_4.png\")\r\n        数据组.加入成员 (\"ab_2_2.png\")\r\n        数据组.加入成员 (\"ab_1_1.png\")\r\n        数据组.加入成员 (\"ab_1_3.png\")\r\n        数据组.加入成员 (\"ab_2_1.png\")\r\n        数据组.加入成员 (\"ab_1_2.png\")\r\n        数据组.加入成员 (\"ab_2_3.png\")\r\n        数据组.加入成员 (\"ab_1_2(2).png\")\r\n        加入数据 (数据组)  // 这里模拟枚举到的目录文件\r\n\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本行 (\" 内容:\" + 读取.内容)\r\n        }\r\n        返回 (0)\r\n    }\r\n\r\n    方法 加入数据\r\n    参数 数据包 <类型 = 文本数组类>\r\n    {\r\n        变量 临时数据 <类型 = 数据模板>\r\n        数据包.枚举循环 ()\r\n        {\r\n            临时数据.内容 = 数据包.取枚举值 ()\r\n            list.加入成员 (临时数据)\r\n        }\r\n    }\r\n\r\n    方法 按钮_被单击 <接收事件 类型 = 整数 注释 = \"当按钮被单击后发送此事件\">\r\n    参数 来源对象 <类型 = 按钮 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        list.排序 (自定义排序)\r\n        编辑框1.加入文本行 (\"-----按名称小到大排序-------\")\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本行 (\" 内容:\" + 读取.内容)\r\n        }\r\n        返回 (0)\r\n    }\r\n\r\n    方法 自定义排序 <静态 类型 = 逻辑型>\r\n    参数 数据1 <类型 = 数据模板>\r\n    参数 数据2 <类型 = 数据模板>\r\n    {\r\n        变量 a1 <类型 = 整数>\r\n        变量 b1 <类型 = 整数>\r\n        变量 a2 <类型 = 整数>\r\n        变量 b2 <类型 = 整数>\r\n        取格式数据_数值 (数据1.内容, \"ab_%d_%d.png\", a1, b1)\r\n        取格式数据_数值 (数据2.内容, \"ab_%d_%d.png\", a2, b2)\r\n        如果 (a1 < a2)\r\n        {\r\n            返回 (真)\r\n        }\r\n        否则 (a1 == a2)\r\n        {\r\n            如果 (b1 < b2)\r\n            {\r\n                返回 (真)\r\n            }\r\n            否则 (b1 == b2)\r\n            {\r\n                // 这里进行第三个条件判断\r\n                返回 (假)  // 暂时返回假不排序\r\n            }\r\n        }\r\n        返回 (假)\r\n    }\r\n}\r\n\r\n类 数据模板 <公开 基础类 = 扩展对象类>\r\n{\r\n    变量 内容 <公开 类型 = 文本型>\r\n}\r\n\r\n类 排序模板组 <公开 基础类 = 链表排序类_ @模板实现类 = \"数据模板\">\r\n">
    变量 案例3 <类型 = 文本型
            值 = "<火山程序 类型 = \"通常\" 版本 = 1 />\r\n\r\n类 我的主窗口 <基础类 = 窗口 @视窗.布局 = \"client_size = \\\"534, 279\\\"\">\r\n{\r\n    变量 按钮3 <类型 = 按钮 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 101\\r\\npos = \\\"266, 243, 77, 26\\\"\" 标题 = \"首字母排序\">\r\n    变量 按钮2 <类型 = 按钮 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 102\\r\\npos = \\\"170, 243, 64, 26\\\"\" 标题 = \"ID排序\">\r\n    变量 按钮1 <类型 = 按钮 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 103\\r\\npos = \\\"81, 243, 64, 26\\\"\" 标题 = \"身高排序\">\r\n    变量 编辑框1 <类型 = 编辑框 折叠2 隐藏值属性 = \"0\" @视窗.布局 = \"id = 104\\r\\npos = \\\"4, 6, 521, 224\\\"\" 是否允许多行 = 真\r\n            滚动条 = 纵向滚动条>\r\n    变量 list <类型 = 排序模板组>\r\n\r\n    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 注释 = \"当本组件及其中所有子组件均被创建完毕后发送此事件.\">\r\n    参数 来源对象 <类型 = 我的主窗口 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        变量 临时数据 <类型 = 数据模板>\r\n        临时数据.ID = 1\r\n        临时数据.姓名 = \"张三\"\r\n        临时数据.身高 = 1.78\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 2\r\n        临时数据.姓名 = \"李四\"\r\n        临时数据.身高 = 1.72\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 3\r\n        临时数据.姓名 = \"王五\"\r\n        临时数据.身高 = 1.70\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 4\r\n        临时数据.姓名 = \"赵六\"\r\n        临时数据.身高 = 1.75\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 5\r\n        临时数据.姓名 = \"孙七\"\r\n        临时数据.身高 = 1.73\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 6\r\n        临时数据.姓名 = \"周八\"\r\n        临时数据.身高 = 1.80\r\n        list.加入成员 (临时数据)\r\n        临时数据.ID = 7\r\n        临时数据.姓名 = \"吴九\"\r\n        临时数据.身高 = 1.77\r\n        list.加入成员 (临时数据)\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本 (\"ID:\" + 到文本 (读取.ID) + \" 姓名:\" + 读取.姓名 + \" 身高:\" + 到文本 (读取.身高) + \"\\r\\n\")\r\n        }\r\n        返回 (0)\r\n    }\r\n\r\n    方法 按钮_被单击 <接收事件 类型 = 整数 注释 = \"当按钮被单击后发送此事件\">\r\n    参数 来源对象 <类型 = 按钮 注释 = \"提供事件产生的具体来源对象\">\r\n    参数 标记值 <类型 = 整数 注释 = \"用户调用\\\"挂接事件\\\"命令时所提供的\\\"标记值\\\"参数值,非此方式挂接事件则本参数值固定为0.\">\r\n    {\r\n        如果 (来源对象 == 按钮1)\r\n        {\r\n            list.排序 (身高排序_从小到大)\r\n            编辑框1.加入文本行 (\"-----按身高小到大排序-------\")\r\n        }\r\n        否则 (来源对象 == 按钮2)\r\n        {\r\n            list.排序 (ID排序_从大到小)\r\n            编辑框1.加入文本行 (\"-----按ID大到小排序-------\")\r\n        }\r\n        否则 (来源对象 == 按钮3)\r\n        {\r\n            list.排序 (首字母排序)\r\n            编辑框1.加入文本行 (\"-----按首字母小到大排序-------\")\r\n        }\r\n        变量 读取 <类型 = 数据模板>\r\n        list.枚举循环 ()\r\n        {\r\n            读取 = list.取枚举值 ()\r\n            编辑框1.加入文本 (\"ID:\" + 到文本 (读取.ID) + \" 姓名:\" + 读取.姓名 + \" 身高:\" + 到文本 (读取.身高) + \"\\r\\n\")\r\n        }\r\n\r\n        返回 (0)\r\n    }\r\n\r\n    方法 身高排序_从小到大 <静态 类型 = 逻辑型>\r\n    参数 数据1 <类型 = 数据模板>\r\n    参数 数据2 <类型 = 数据模板>\r\n    {\r\n        如果 (数据1.身高 >= 数据2.身高)\r\n        {\r\n            返回 (假)\r\n        }\r\n        返回 (真)\r\n    }\r\n\r\n    方法 ID排序_从大到小 <静态 类型 = 逻辑型>\r\n    参数 数据1 <类型 = 数据模板>\r\n    参数 数据2 <类型 = 数据模板>\r\n    {\r\n        如果 (数据1.ID >= 数据2.ID)\r\n        {\r\n            返回 (真)\r\n        }\r\n        返回 (假)\r\n    }\r\n\r\n    方法 首字母排序 <静态 类型 = 逻辑型>\r\n    参数 数据1 <类型 = 数据模板>\r\n    参数 数据2 <类型 = 数据模板>\r\n    {\r\n        变量 a1 <类型 = 整数>\r\n        变量 a2 <类型 = 整数>\r\n        a1 = 文本到整数 (文本_字母转整数 (拼音_取拼音首2 (取文本左边 (数据1.姓名, 1))))\r\n        a2 = 文本到整数 (文本_字母转整数 (拼音_取拼音首2 (取文本左边 (数据2.姓名, 1))))\r\n        如果 (a1 < a2)\r\n        {\r\n            返回 (真)\r\n        }\r\n        返回 (假)\r\n    }\r\n}\r\n\r\n类 数据模板 <公开 基础类 = 扩展对象类>\r\n{\r\n    变量 ID <公开 类型 = 整数>\r\n    变量 姓名 <公开 类型 = 文本型>\r\n    变量 身高 <公开 类型 = 小数>\r\n}\r\n\r\n类 排序模板组 <公开 基础类 = 链表排序类_ @模板实现类 = \"数据模板\">\r\n">
}

类 链表排序类_ <公开 基础类 = 扩展对象类 注释 = "基于C++标准模板库list." 注释 = "进入库内部，在“链表排序例子”中可查看配套例子" 折叠 折叠2 @文档 = "category = \"程序综合库.list排序\""
        @视窗.外部头文件 = "<list>" @模板基础类 = 真>
{
    方法 初始化 <公开 注释 = " { } 初始化数据" 折叠 @嵌入式方法 = "">
    参数 所欲插入的值 <类型 = 模板类型1 @可扩展 = "">
    {
        @ @sn<this>.m_list = { @<所欲插入的值> }
    }

    方法 加入成员 <公开 注释 = "在链表尾加入一个值" 折叠 编辑时信息 = "45551, 0, 0, 0" @嵌入式方法 = "">
    参数 所欲插入的值 <类型 = 模板类型1 编辑时信息 = "45551, 0, 0, 0">
    {
        @ @sn<this>.m_list.push_back (@<所欲插入的值>)
    }

    方法 加入成员首 <公开 注释 = "在链表首(头部)加入一个值" 折叠 @嵌入式方法 = "">
    参数 所欲插入的值 <类型 = 模板类型1 编辑时信息 = "45551, 0, 0, 0">
    {
        @ @sn<this>.m_list.push_front (@<所欲插入的值>)
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本链表中已有成员的数目" 折叠 @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_list.size ()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本链表是否为空" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.empty ()
    }

    方法 取成员首 <公开 类型 = 模板类型1 注释 = "返回第一个成员(不检查是否存在第一个成员)" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.front ()
    }

    方法 取成员尾 <公开 类型 = 模板类型1 注释 = "返回最后一个成员(不检查是否存在最后一个成员)" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.back ()
    }

    方法 批量复制 <公开 类型 = 链表排序类_ 注释 = "复制\"N\"个\"数据\",赋值(并返回)自身(注意:会清空之前所有数据)" 折叠 @嵌入式方法 = "">
    参数 欲批量复制的个数 <类型 = 整数>
    参数 数据 <类型 = 模板类型1>
    {
        @ @sn<this>.m_list.assign (@<欲批量复制的个数>,@<数据>)
    }

    方法 交换 <公开 类型 = 链表排序类_ 注释 = "与欲交换的链表置换数据(并返回自身)" 折叠 @嵌入式方法 = "">
    参数 欲交换的链表 <类型 = 链表排序类_>
    {
        @ @sn<this>.m_list.swap (@<欲交换的链表>.m_list)
    }

    方法 删除成员尾 <公开 注释 = "移除最后一个成员" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.pop_back ()
    }

    方法 删除成员首 <公开 注释 = "移除第一个成员" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.pop_front ()
    }

    方法 删除指定成员 <公开 注释 = "移除所有值为val的成员" 折叠 @嵌入式方法 = "">
    参数 满足条件的成员 <类型 = 模板类型1>
    {
        @ @sn<this>.m_list.remove_if([&](const @dt<模板类型1>& _Other) { return (BOOL)(@<满足条件的成员> == _Other);})
    }

    方法 删除条件成员 <公开 注释 = "移除所有符合op(elem)为true的元素" 折叠 @嵌入式方法 = "">
    参数 条件函数 <注释 = " bool 条件函数 (const 模板类型1 & value);" @匹配方法 = "">
    {
        @ @sn<this>.m_list.remove_if(@<条件函数>)
    }

    方法 清空 <公开 注释 = "清除本链表中的所有内容" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.clear ()
    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来正向枚举本链表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值." 折叠 折叠2
            @嵌入式方法 = "name = iter\r\nhas_loop_body = true">
    {
        @ std::list<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_list;
        @ for (std::list<@dt<模板类型1>>::iterator _vlistitr = @sn<rand_name0>.begin (); _vlistitr != @sn<rand_name0>.end (); _vlistitr++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个循环来逆向枚举本链表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值." 折叠 折叠2
            @嵌入式方法 = "name = r_iter\r\nhas_loop_body = true">
    {
        @ std::list<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_list;
        @ for (std::list<@dt<模板类型1>>::reverse_iterator _vlistitr = @sn<rand_name0>.rbegin (); _vlistitr != @sn<rand_name0>.rend (); _vlistitr++)
    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前所枚举到的成员值,"
            注释 = "如果有多层本类或本类继承类的\"枚举循环\"/\"逆向枚举循环\"嵌套,本方法将返回最近层\"枚举循环\"/" 注释 = "\"逆向枚举循环\"所枚举到的成员值." 折叠 折叠2
            @嵌入式方法 = "parent = \"iter, r_iter\"">
    {
        @ *_vlistitr
    }

    方法 插入成员 <公开 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用" 注释 = "在循环过程中指向的位置的前方插入\"个数\"个成员" 折叠 折叠2
            @嵌入式方法 = "parent = \"iter, r_iter\"">
    参数 数据 <类型 = 模板类型1>
    参数 个数 <类型 = 整数 @默认值 = 1>
    {
        @ @sn<this>.m_list.insert(_vlistitr,@<个数>,@<数据>)
    }

    方法 删除成员 <公开 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用" 注释 = "删除在循环过程中指向的位置的成员" 折叠 折叠2
            @嵌入式方法 = "parent = \"iter, r_iter\"">
    {
        @ @sn<this>.m_list.erase(_vlistitr)
    }

    方法 重定义成员数 <公开 折叠 @嵌入式方法 = "">
    参数 成员数 <类型 = 整数>
    {
        @ @sn<this>.m_list.resize(@<成员数>)
    }

    方法 排序 <公开 折叠 @嵌入式方法 = "">
    参数 比较方法 <注释 = "新建个类，基础类为\"扩展对象类\"，再新建N个变量，并公开，然后代入本参数即可" @匹配方法 = "排序模板函数">
    {
        @ (BOOL)@sn<this>.m_list.sort (@<比较方法>)
    }

    方法 排序模板函数 <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 对象1 <类型 = 模板类型1>
    参数 对象2 <类型 = 模板类型1>
    {
        返回 (真)  // 此处返回仅仅个例子
    }

    方法 合并排序 <公开 注释 = "在 比较方法() 准则下进行合并,合并后的元素有序" 折叠 @嵌入式方法 = "">
    参数 欲合并链表 <类型 = 链表排序类_>
    参数 比较方法 <注释 = "逻辑型 比较方法(A,B)" @匹配方法 = "">
    {
        @ (BOOL)@sn<this>.m_list.merge (@<欲合并链表>.m_list,@<比较方法>)
    }

    方法 逆序 <公开 注释 = "将所有元素逆序" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.reverse()
    }

    方法 去重_相邻 <公开 注释 = "如果存在若干相邻数值相同的元素，就移除重复元素，只留一个" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_list.unique()
    }

    # @ <include>
    # @ std::list<std::remove_pointer<@dt<模板类型1>*>::type> m_list;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_list = objCopyFrom.m_list; }
    # @ inline_ BOOL _IsSelfEqual (const @sn<current_class>& objCompare) { return m_list == objCompare.m_list; } 
    # @ </include>
}

