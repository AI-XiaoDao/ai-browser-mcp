类 防火墙规则组_ <公开 折叠 @文档 = "category = \"程序综合库.防火墙.附加类\"">
{
    变量 规则名称 <公开 类型 = 文本型 值 = "A测试规则" 注释 = "（Name）">
    变量 规则描述 <公开 类型 = 文本型 值 = "" 注释 = "（Description）">
    变量 应用程序名 <公开 类型 = 文本型 值 = "" 注释 = "可选，可执行文件的绝对路径　（ApplicationName）">
    变量 服务名称 <公开 类型 = 文本型 值 = "" 注释 = "可选，指定应用程序的服务名称属性　（serviceName）">
    变量 协议类型 <公开 类型 = 整数 值 = 6
            注释 = "可选，256、全部　0、自定义　1、ICMPV4　2、IGMP　6、TCP　17、UDP　41、IPV6　43、IPV6-ROUTE　44、IPV6-FRAG　47、GRE　58、ICMPV6　59、IPV6-NONXT　60、IPV6-OPTS　112、VRRP　113、PGM　115、L2TP　（Protocol）">
    变量 本地端口 <公开 类型 = 整数 注释 = "留空为所有端口，否则为指定　协议类型为：tcp,udp 下有效  格式类型请参考本地规则　（LocalPorts）" "">
    变量 远程端口 <公开 类型 = 整数 注释 = "留空为所有端口，否则为指定　协议类型为：tcp,udp 下有效  格式类型请参考本地规则　（RemotePorts）">
    变量 本地地址 <公开 类型 = 文本型 值 = "" 注释 = "留空为所有IP地址，否则为指定　（LocalAddresses）">
    变量 远程地址 <公开 类型 = 文本型 值 = "" 注释 = "留空为所有IP地址，否则为指定　（RemoteAddresses）">
    变量 Icmp类型和代码 <公开 类型 = 文本型 值 = "" 注释 = "留空为所有，否则指定  格式类型请参考本地规则　（IcmpTypesAndCodes）">
    变量 方向 <公开 类型 = 整数 值 = 1 注释 = "1、入站规则　2、出站规则　3、安全规则　（Direction）">
    变量 接口 <公开 类型 = COM变体型 注释 = "（Interfaces）">
    变量 接口类型 <公开 类型 = 文本型 值 = "All"
            注释 = "All、所有类型　Lan、局域网　RemoteAccess、远程访问　Wireless、无线　；可以用分号组合：Lan,Wireless,RemoteAccess　（InterfaceTypes）">
    变量 是否启用 <公开 类型 = 逻辑型 值 = 真 注释 = "真=启用　假=不启用　（Enabled）">
    变量 分组 <公开 类型 = 文本型 值 = "火山组" 注释 = "可选，设置了分组是表示预定义规则，某些属性无法修改　（Grouping）">
    变量 配置文件类型 <公开 类型 = 整数 值 = 2147483647 注释 = "可选，2147483647(7fffffff)=所有　1=域　2=家庭或专用　4=公共   ；何时应用该规则　（Profiles）">
    变量 操作 <公开 类型 = 整数 值 = 1 注释 = "0、阻止连接　1、允许连接   2、安全连接　（Action）">
    变量 启用边缘遍历 <公开 类型 = 逻辑型 注释 = "（EdgeTraversal）">
    变量 边缘遍历选项 <公开 类型 = 整数 值 = 0 注释 = "0、阻止边缘遍历　1、允许边缘遍历　2、遵从用户　2、遵从应用程序　EdgeTraversalOptions">
}

