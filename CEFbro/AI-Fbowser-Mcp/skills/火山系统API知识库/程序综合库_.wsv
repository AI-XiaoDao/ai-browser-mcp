        @ HMENU hMenu = GetMenu((HWND)@<窗口句柄>); 
        @ HMENU hSubMenu = GetSubMenu(hMenu, @<菜单列索引>); 
        @ bool jg;
        @ UINT hID = GetMenuItemID (hSubMenu,@<插入位索引>);
        @ if (@<新菜单名称>==L"-") {
        @ jg= InsertMenu(hSubMenu,hID, MF_SEPARATOR, @<新菜单ID>,L""); 
        @ }
        @ else {
        @ jg= InsertMenu(hSubMenu,hID, MF_UNCHECKED, @<新菜单ID>,@<新菜单名称>);
        @ }
        @ return jg;
    }

