类 系统重定向类_ <公开 注释 = "当32位程序尝试访问System32目录时，实际上会被重定向到SysWOW64目录." 注释 = "这是因为64位Windows系统中，System32目录默认存放的是64位的系统文件."
        注释 = "而32位的系统文件存放在SysWOW64目录下" 折叠 折叠2 @文档 = "category = \"程序综合库.系统重定向\"">
{

    # @ PVOID oldValue = nullptr;

    方法 禁用重定向_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ return Wow64DisableWow64FsRedirection(&oldValue);
    }

    方法 恢复重定向_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ return Wow64RevertWow64FsRedirection(oldValue);
    }
}

