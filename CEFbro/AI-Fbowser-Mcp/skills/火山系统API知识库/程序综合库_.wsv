    方法 程序_删除程序自身4 <公开 静态 折叠 @禁止流程检查 = 真>
    {
        @ CVolString strFileName;
        @ TCHAR buf [MAX_PATH + 1];
        @ buf [0] = '\0';
        @ if (::GetModuleFileName (NULL, buf, NUM_ELEMENTS_OF (buf) - 1) > 0)
        @ {
        @     const TCHAR* ps = _tcsrchr (buf, OS_PATH_CHAR);
        @     strFileName.SetText (ps == NULL ? buf : ps + 1);
        @ }
        @ WCHAR szCommandLine[MAX_PATH + 10];
        @ memset(szCommandLine,0,sizeof(szCommandLine));
        @ wchar_t hebrew_str[_MAX_FNAME] = { 0 };
        @ CStringW xx(_T("ping www.baidu.com -n 1&del /f  "+strFileName));
        @ lstrcpynW(hebrew_str, (LPCTSTR)xx, _MAX_FNAME);
        @ swprintf(szCommandLine, L"/c %s", hebrew_str);
        @ ShellExecute(NULL, L"open", L"cmd.exe", szCommandLine, NULL, SW_HIDE);
        @ ExitProcess(0);
    }

    方法 程序_置编辑框阅读顺序 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 句柄 <类型 = 变整数>
    参数 是否从右到左 <类型 = 逻辑型 注释 = "真：从右到左  假：从左到右" @默认值 = 真>
    {
        @ LONG_PTR exStyle = GetWindowLongPtr((HWND)@<句柄>, GWL_EXSTYLE);
        @ if(@<是否从右到左>==true)
        @ exStyle |= WS_EX_RTLREADING|WS_EX_LEFTSCROLLBAR|WS_EX_RIGHT|WS_EX_CLIENTEDGE;
        @ else
        @ exStyle = WS_EX_LTRREADING|WS_EX_RIGHTSCROLLBAR|WS_EX_LEFT|WS_EX_CLIENTEDGE;
        @ SetWindowLongPtr((HWND)@<句柄>, GWL_EXSTYLE, exStyle);
    }

    方法 程序_屏蔽编辑框右键 <公开 静态 类型 = 逻辑型 注释 = "只能屏蔽自身程序的编辑框" 折叠 @禁止流程检查 = 真>
    参数 编辑框句柄 <类型 = 变整数>
    参数 菜单回调子程序 <类型 = 变整数 @默认值 = 0>
    {
        @ HWND hWnd = (HWND)@<编辑框句柄>;
        @ if (!IsWindow(hWnd)) return false;
        @ HANDLE WndProc;
        @ WndProc = GetPropW(hWnd, L"GWL_WNDPROC");
        @ if (WndProc)
        @ {
        @ SetWindowLongPtrW(hWnd, GWLP_WNDPROC, (LONG_PTR)WndProc);
        @ RemovePropW(hWnd, L"GWL_WNDPROC");
        @ RemovePropW(hWnd, L"lProc");
        @ }
        @ SetPropW(hWnd, L"lProc", (HANDLE)@<菜单回调子程序>);
        @ WndProc = (HANDLE)SetWindowLongPtrW(hWnd, GWLP_WNDPROC, (LONG_PTR)@<屏蔽编辑框右键消息>);
        @ SetPropW(hWnd, L"GWL_WNDPROC", WndProc);
        @ return true;
    }

    方法 屏蔽编辑框右键消息 <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 hWnd <类型 = 变整数>
    参数 Msg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        @ HWND hWnd = (HWND)@<hWnd>;
        @ int Msg = @<Msg>;
        @ HANDLE WndProc;
        @ if (Msg == WM_RBUTTONDOWN || Msg == WM_RBUTTONUP || Msg == WM_RBUTTONDBLCLK)
        @ {
        @ WndProc = GetPropW(hWnd, L"lProc");
        @ return (INT_PTR)CallWindowProcW((WNDPROC)WndProc, NULL, 0, NULL, NULL);
        @ }
        @ else
        @ {
        @ WndProc = GetPropW(hWnd, L"GWL_WNDPROC");
        @ return (INT_PTR)CallWindowProcW((WNDPROC)WndProc, hWnd, Msg, (WPARAM)@<wParam>, (LPARAM)@<lParam>);
        @ }
    }
}

