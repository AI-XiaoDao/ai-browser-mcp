类 系统HOSTS处理类_ <公开 折叠 @全局类 = 真>
{
    方法 系统_读取Hosts <公开 静态 类型 = 文本数组类 返回值注释 = "返回所有的的HOST内容" 折叠>
    参数 返回的HOSTS信息 <类型 = 文本型 注释 = "非数组格式" @默认值 = "">
    {
        变量 临时目录 <类型 = 文本型>
        变量 结果组 <类型 = 文本数组类>
        临时目录 = 系统_取系统文件目录 () + "drivers\\etc\\hosts"
        返回的HOSTS信息 = 读入文本文件 (系统_取系统文件目录 () + "drivers\\etc\\hosts", , 文本编码类型.UTF8)
        分割文本 (返回的HOSTS信息, "\r\n", 结果组, 假)
        返回 (结果组)
    }

    方法 系统_添加Hosts <公开 静态 类型 = 逻辑型 折叠>
    参数 目标网站‌ <类型 = 文本型>
    参数 重定向地址 <类型 = 文本型>
    {
        变量 临时目录 <类型 = 文本型>
        变量 内容组 <类型 = 文本数组类>
        变量 临时内容 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        临时目录 = 系统_取系统文件目录 () + "drivers\\etc\\hosts"
        结果 = 置文件属性_ (临时目录, 0)
        如果真 (结果 == 假)
        {
            返回 (假)
        }
        内容组 = 系统_读取Hosts ()
        结果 = 假
        内容组.枚举循环 ()
        {
            如果真 (寻找文本 (内容组.取枚举值 (), 目标网站‌, , 真) != -1)
            {
                内容组.置成员值 (内容组.取枚举索引 (), 重定向地址 + " " + 目标网站‌)
                结果 = 真
                跳出循环
            }
        }
        如果真 (结果 == 假)
        {
            内容组.加入成员 (重定向地址 + " " + 目标网站‌)
        }
        内容组.枚举循环 ()
        {
            如果 (内容组.取枚举索引 () + 1 < 内容组.取成员数 ())
            {
                加入文本 (临时内容, 内容组.取枚举值 () + "\r\n")
            }
            否则
            {
                加入文本 (临时内容, 内容组.取枚举值 ())
            }
        }
        结果 = 写出文本文件 (临时内容, 临时目录, , 文本编码类型.UTF8)
        置文件属性_ (临时目录, 1)
        返回 (结果)
    }

    方法 系统_删除Hosts <公开 静态 类型 = 逻辑型 折叠>
    参数 目标网站‌ <类型 = 文本型>
    {
        变量 临时目录 <类型 = 文本型>
        变量 内容组 <类型 = 文本数组类>
        变量 临时内容 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        临时目录 = 系统_取系统文件目录 () + "drivers\\etc\\hosts"
        结果 = 置文件属性_ (临时目录, 0)
        如果真 (结果 == 假)
        {
            返回 (假)
        }
        内容组 = 系统_读取Hosts ()
        结果 = 假
        内容组.枚举循环 ()
        {
            如果真 (寻找文本 (内容组.取枚举值 (), 目标网站‌, , 真) != -1)
            {
                内容组.删除成员 (内容组.取枚举索引 ())
                结果 = 真
                跳出循环
            }
        }
        如果真 (结果 == 假)
        {
            调试输出 ("未找到该目标网站")
            返回 (假)
        }
        内容组.枚举循环 ()
        {
            如果 (内容组.取枚举索引 () + 1 < 内容组.取成员数 ())
            {
                加入文本 (临时内容, 内容组.取枚举值 () + "\r\n")
            }
            否则
            {
                加入文本 (临时内容, 内容组.取枚举值 ())
            }
        }
        结果 = 写出文本文件 (临时内容, 临时目录, , 文本编码类型.UTF8)
        置文件属性_ (临时目录, 1)
        返回 (结果)
    }
}

