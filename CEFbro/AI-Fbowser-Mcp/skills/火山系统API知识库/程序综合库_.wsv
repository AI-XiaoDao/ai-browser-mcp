类 端口检测 <公开 折叠 折叠2 @文档 = "category = \"程序综合库.端口检测\"" @全局类 = 真>
{
    方法 端口_端口是否被占用 <公开 静态 类型 = 逻辑型 返回值注释 = "返回真表示被占用" 折叠>
    参数 指定端口 <类型 = 整数 注释 = "例如：2019">
    参数 是否结束进程 <类型 = 逻辑型 注释 = "如果被占用，是否结束其进程" @默认值 = 假>
    参数 返回被占用程序信息 <类型 = 文本型 注释 = "返回被占用程序的来源路径" @默认值 = "">
    {
        变量 ID <类型 = 整数>
        ID = 进程_端口取进程ID (指定端口)
        如果真 (ID > 0)
        {
            返回被占用程序信息 = 进程_取进程路径_ID (ID)
            如果真 (是否结束进程)
            {
                进程_结束进程_ID (ID)
            }
            返回 (真)
        }
        返回 (假)
    }

    方法 端口_端口是否被占用2 <公开 静态 类型 = 逻辑型 返回值注释 = "返回真表示被占用" 折叠>
    参数 指定端口 <类型 = 整数 注释 = "例如：2019">
    参数 检查类型 <类型 = 整数 注释 = "1、TCP　2、UDP" @默认值 = 1>
    参数 是否结束进程 <类型 = 逻辑型 注释 = "如果被占用，是否结束其进程" @默认值 = 假>
    参数 返回被占用程序信息 <类型 = 文本型 注释 = "返回被占用程序的来源路径" @默认值 = "">
    {
        变量 返回信息 <类型 = 文本型>
        变量 结果组 <类型 = 文本数组类>
        变量 子信息 <类型 = 文本型>
        变量 ID信息 <类型 = 文本数组类>
        变量 监听端口 <类型 = 文本数组类>
        变量 端口信息 <类型 = 文本数组类>
        变量 端口 <类型 = 整数>
        变量 ID <类型 = 整数>
        变量 结果 <类型 = 逻辑型>
        运行控制台程序 ("cmd /c netstat -ano |findstr " + 到文本 (指定端口), 返回信息)
        如果真 (取文本长度 (返回信息) > 30)
        {
            分割文本 (返回信息, "\n", 结果组)
            结果组.枚举循环 ()
            {
                子信息 = 删首尾空 (结果组.取枚举值 ())
                如果真 (寻找文本 (子信息, "0.0.0.0") != -1)
                {
                    端口 = 文本到整数 (取文本右边_ (删首尾空 (取文本中间_ (子信息, 选择 (检查类型 == 1, "TCP", "UDP"), "0.0.0.0:0")), ":"))
                    如果真 (端口 == 指定端口)
                    {
                        ID信息.加入成员 (删首尾空 (取文本右边 (子信息, 5)))
                        端口信息.加入成员 (取文本左边 (子信息, 3))
                    }
                }
            }
            端口信息.枚举循环 ()
            {
                如果 (检查类型 == 1 && 端口信息.取枚举值 () == "TCP")
                {
                    ID = 文本到整数 (ID信息.取成员 (端口信息.取枚举索引 ()))
                    返回被占用程序信息 = 进程_取进程路径_ID (ID)
                    结果 = 真
                    跳出循环
                }
                否则 (检查类型 == 2 && 端口信息.取枚举值 () == "UDP")
                {
                    ID = 文本到整数 (ID信息.取成员 (端口信息.取枚举索引 ()))
                    返回被占用程序信息 = 进程_取进程路径_ID (ID)
                    结果 = 真
                    跳出循环
                }
            }
        }
        如果真 (结果 == 真 && 是否结束进程)
        {
            进程_结束进程_ID (ID)
        }
        返回 (结果)
    }
}

