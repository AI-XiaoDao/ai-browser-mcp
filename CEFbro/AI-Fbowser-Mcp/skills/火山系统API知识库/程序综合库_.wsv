    参数 主项1索引 <类型 = 整数 注释 = "横向顺序，第几行">
    参数 主项2索引 <类型 = 整数 注释 = "横向顺序，第几行">
    参数 子项索引 <类型 = 整数 注释 = "横向顺序，第几行">
    参数 是否激活窗口 <类型 = 逻辑型 @默认值 = 真>
    {
        @ if(@<是否激活窗口>==TRUE){
        @ ShowWindow((HWND)@<窗口句柄>, SW_SHOWNOACTIVATE);
        @ SetForegroundWindow((HWND)@<窗口句柄>);}
        @ PostMessage((HWND)@<窗口句柄>,WM_MENUCOMMAND,@<子项索引>,(LPARAM)GetSubMenu(GetSubMenu(GetSubMenu(::GetMenu((HWND)@<窗口句柄>),@<菜单列索引>),@<主项1索引>),@<主项2索引>));
    }

    方法 菜单_枚举菜单 <公开 静态 类型 = 整数 返回值注释 = "返回菜单总数，不含主根数量" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 返回的根标题 <类型 = 文本数组类 注释 = "包含子根" @默认值 = 空对象>
    参数 返回的根句柄 <类型 = 变整数数组类 注释 = "包含子根" @默认值 = 空对象>
    参数 返回的子标题 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的ID <类型 = 整数数组类 @默认值 = 空对象>
    参数 返回的菜单列 <类型 = 整数数组类 @默认值 = 空对象>
    参数 返回的菜单项索引 <类型 = 整数数组类 @默认值 = 空对象>
    {
        变量 临时ID <类型 = 整数类>
        变量 临时标题 <类型 = 文本型>
        变量 根句柄 <类型 = 变整数>
        变量 子句柄 <类型 = 变整数>
        变量 返回的根标题2 <类型 = 文本数组类>
        变量 返回的根句柄2 <类型 = 变整数数组类>
        变量 返回的标题2 <类型 = 文本数组类>
        变量 返回的ID2 <类型 = 整数数组类>
        变量 返回的菜单列2 <类型 = 整数数组类>
        变量 返回的菜单项索引2 <类型 = 整数数组类>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        根句柄 = 菜单_取菜单根句柄 (窗口句柄)
        循环 (, 菜单_取菜单数量 (根句柄), i)
        {
            子句柄 = 菜单_取子菜单句柄 (根句柄, i)
            返回的根标题.加入成员 (菜单_取菜单标题 (根句柄, i))
            返回的根句柄.加入成员 (子句柄)
            循环 (, 菜单_取菜单数量 (子句柄), i2)
            {
                临时标题 = 菜单_取菜单标题 (子句柄, i2, 临时ID)
                如果真 (菜单_是否为子菜单 (子句柄, i2))
                {
                    返回的根标题.加入成员 (临时标题)
                    返回的根句柄.加入成员 (菜单_取子菜单句柄 (子句柄, i2))
                    枚举子项 (子句柄, i2, i, 返回的根标题2, 返回的根句柄2, 返回的标题2, 返回的ID2, 返回的菜单列2, 返回的菜单项索引2)
                    返回的根标题.添加数组 (返回的根标题2)
                    返回的根句柄.添加数组 (返回的根句柄2)
                    返回的子标题.添加数组 (返回的标题2)
                    返回的ID.添加数组 (返回的ID2)
                    返回的菜单列.添加数组 (返回的菜单列2)
                    返回的菜单项索引.添加数组 (返回的菜单项索引2)
                }
                返回的子标题.加入成员 (临时标题)
                返回的ID.加入成员 (临时ID.值)
                返回的菜单列.加入成员 (i)
                返回的菜单项索引.加入成员 (i2)
            }
        }
        返回 (返回的根标题.取成员数 ())
    }

    方法 菜单_枚举子菜单 <公开 静态 类型 = 整数 返回值注释 = "返回子菜单总数" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 菜单标题 <类型 = 文本型 注释 = "需要点击的菜单标题">
    参数 是否模糊查找 <类型 = 逻辑型 @默认值 = 真>
    参数 返回的标题 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的ID <类型 = 整数数组类 @默认值 = 空对象>
    {
        变量 临时ID <类型 = 整数类>
        变量 临时标题 <类型 = 文本型>
        变量 根句柄 <类型 = 变整数>
        变量 返回的标题2 <类型 = 文本数组类>
        变量 返回的ID2 <类型 = 整数数组类>
        变量 i <类型 = 整数>
        变量 标题组 <类型 = 文本数组类>
        变量 句柄组 <类型 = 变整数数组类>
        菜单_枚举菜单 (窗口句柄, 标题组, 句柄组, )
        标题组.枚举循环 ()
        {
            如果 (是否模糊查找)
            {
                如果真 (寻找文本 (标题组.取枚举值 (), 菜单标题, , 真) != -1)
                {
                    根句柄 = 句柄组.取成员 (标题组.取枚举索引 ())
                    跳出循环
                }
            }
            否则
            {
                如果真 (标题组.取枚举值 () == 菜单标题)
                {
                    根句柄 = 句柄组.取成员 (标题组.取枚举索引 ())
                    跳出循环
                }
            }
        }
        循环 (, 菜单_取菜单数量 (根句柄), i)
        {
            临时标题 = 菜单_取菜单标题 (根句柄, i, 临时ID)
            如果真 (菜单_是否为子菜单 (根句柄, i))
            {
                菜单_枚举子菜单2 (根句柄, i, 返回的标题2, 返回的ID2)
                返回的标题.添加数组 (返回的标题2)
                返回的ID.添加数组 (返回的ID2)
            }
            返回的标题.加入成员 (临时标题)
            返回的ID.加入成员 (临时ID.值)
        }
        返回 (返回的标题.取成员数 ())
    }

    方法 菜单_枚举子菜单2 <公开 静态 类型 = 整数 返回值注释 = "返回子菜单总数" 折叠>
