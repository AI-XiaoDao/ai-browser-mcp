类 系统执行命令类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统命令类\"" @全局类 = 真>
{
    方法 系统_执行命令 <公开 静态 注释 = "调用cmd命令来执行系统功能" 折叠>
    参数 类型 <类型 = 文本型 注释 = "调用常量，例如：“系统命令常量.控制面板”">
    参数 是否查看打印任务 <类型 = 逻辑型 注释 = "调用“系统命令常量.查看正在打印”时使用。本参数为真时，下面参数才能生效" @默认值 = 假>
    参数 打印机名称 <类型 = 文本型 注释 = "留空为默认打印机，指定名称则为指定打印机。(调用“系统命令常量.查看正在打印”时使用)" @默认值 = "">
    {
        如果真 (是否查看打印任务)
        {
            如果 (打印机名称 == "")
            {
                打印机名称 = 打印机_取默认打印机 () + "\""
            }
            否则
            {
                打印机名称 = 打印机名称 + "\""
            }
        }
        如果 (类型 == 系统命令常量.ODBC数据源32 || 类型 == 系统命令常量.ODBC数据源64)
        {
            类型 = 读环境变量 ("SystemRoot") + "\\" + 类型
        }
        否则 (类型 == 系统命令常量.远程桌面连接防失效)
        {
            变量 启动时间 <类型 = 长整数>
            变量 类型2 <类型 = 文本型>
            计次循环 (11)
            {
                类型2 = 类型
                子文本替换 (类型2, "ID", 到文本 (取循环索引 ()))
                启动时间 = 取启动时间 ()
                运行 ("cmd /c " + 类型2, 真, 程序窗口显示方式.隐藏窗口)
                如果 (取启动时间 () - 启动时间 > 200)
                {
                    跳出循环
                }
            }
            返回
        }
        运行 ("cmd /c" + 类型 + 选择 (是否查看打印任务, 打印机名称, ""), , 选择 (类型 == 系统命令常量.CMD命令窗, 程序窗口显示方式.普通激活, 程序窗口显示方式.隐藏窗口))
    }
}

类 系统命令常量 <公开 折叠 @文档 = "category = \"程序综合库.系统命令类.命令常量\"">
{
    变量 控制面板 <公开 静态 类型 = 文本型 值 = "control">
    变量 管理工具 <公开 静态 类型 = 文本型 值 = "control admintools">
    变量 设备管理器 <公开 静态 类型 = 文本型 值 = "devmgmt.msc">
    变量 任务管理器 <公开 静态 类型 = 文本型 值 = "taskmgr">
    变量 计算机管理 <公开 静态 类型 = 文本型 值 = "compmgmt.msc">
    变量 事件查看器 <公开 静态 类型 = 文本型 值 = "eventvwr">
    变量 系统任务计划 <公开 静态 类型 = 文本型 值 = "taskschd.msc">
    变量 组件服务 <公开 静态 类型 = 文本型 值 = "dcomcnfg">
    变量 服务 <公开 静态 类型 = 文本型 值 = "services.msc">
    变量 组策略 <公开 静态 类型 = 文本型 值 = "gpedit.msc">
    变量 记事本 <公开 静态 类型 = 文本型 值 = "notepad">
    变量 画图板 <公开 静态 类型 = 文本型 值 = "mspaint">
    变量 注册表 <公开 静态 类型 = 文本型 值 = "regedit">
    变量 计算器 <公开 静态 类型 = 文本型 值 = "calc">
    变量 屏幕键盘 <公开 静态 类型 = 文本型 值 = "osk">
    变量 环境变量 <公开 静态 类型 = 文本型 值 = "rundll32.exe sysdm.cpl,EditEnvironmentVariables">
    变量 CMD命令窗 <公开 静态 类型 = 文本型 值 = "cmd.exe">
    变量 ODBC数据源64 <公开 静态 类型 = 文本型 值 = "System32\\odbcad32.exe">
    变量 ODBC数据源32 <公开 静态 类型 = 文本型 值 = "SysWOW64\\odbcad32.exe">
    变量 DirectX诊断工具 <公开 静态 类型 = 文本型 值 = "dxdiag">
    变量 本机用户和组 <公开 静态 类型 = 文本型 值 = "lusrmgr.msc">
