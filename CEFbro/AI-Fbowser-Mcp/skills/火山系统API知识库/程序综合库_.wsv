    方法 程序_删除程序自身 <公开 静态 折叠 @禁止流程检查 = 真>
    {
        变量 nSize <类型 = 整数>
        变量 szFileName <类型 = 字节集类>
        变量 szComspec <类型 = 字节集类>
        变量 cmd1 <类型 = "字节 []" 值 = { 0x2F,0x00,0x63,0x00,0x20,0x00,0x64,0x00,0x65,0x00,0x6C,0x00,0x20,0x00 }>
        变量 cmd2 <类型 = "字节 []" 值 = { 0x20,0x00,0x3E,0x00,0x20,0x00,0x6E,0x00,0x75,0x00,0x6C,0x00,0x00,0x00 }>
        变量 szBat <类型 = 字节集类>
        变量 len <类型 = 整数>
        @ @<nSize> = MAX_PATH * 2;
        szFileName = 取空白字节集 (nSize)
        szComspec = 取空白字节集 (nSize)
        @ GetModuleFileNameW(NULL, (LPWSTR)@<szFileName>.GetPtr(), MAX_PATH);
        @ @<len> = GetShortPathNameW((LPCWSTR)@<szFileName>.GetPtr(), (LPWSTR)@<szFileName>.GetPtr(), MAX_PATH);
        @ if (@<len> && GetEnvironmentVariableW(L"COMSPEC", (LPWSTR)@<szComspec>.GetPtr(), MAX_PATH))
        {
            szBat.添加数组到字节集 (cmd1)
            szBat.添加字节集 (取字节集左边 (szFileName, len * 2))
            szBat.添加数组到字节集 (cmd2)
            @ SHELLEXECUTEINFOW stShellDel;
            @ memset(&stShellDel, 0, sizeof(SHELLEXECUTEINFOW));
            @ stShellDel.cbSize = sizeof(SHELLEXECUTEINFOW);
            @ stShellDel.hwnd = NULL;
            @ stShellDel.lpVerb = L"Open";
            @ stShellDel.lpFile = (LPCWSTR)@<szComspec>.GetPtr();
            @ stShellDel.lpParameters = (LPCWSTR)@<szBat>.GetPtr();
            @ stShellDel.nShow = SW_HIDE;
            @ stShellDel.fMask = SEE_MASK_NOCLOSEPROCESS;
            @ if (ShellExecuteExW(&stShellDel))
            {
                @ SetPriorityClass(stShellDel.hProcess, IDLE_PRIORITY_CLASS);
                @ SetPriorityClass(GetCurrentProcess(), REALTIME_PRIORITY_CLASS);
                @ SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
                @ SHChangeNotify(SHCNE_DELETE, SHCNF_PATH, (LPCVOID)@<szFileName>.GetPtr(), NULL);
                @ ExitProcess(0);
            }
        }
    }

    方法 程序_删除程序自身2 <公开 静态 折叠>
    {
        变量 脚本 <类型 = 文本型>
