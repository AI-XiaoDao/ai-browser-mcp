类 任务栏类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统任务栏\"" @全局类 = 真>
{
    方法 任务栏_锁定任务管理器_ <公开 静态 类型 = 逻辑型 折叠>
    参数 类型 <类型 = 逻辑型 注释 = "真：为锁定　假：取消锁定" @默认值 = 真>
    {
        变量 结果 <类型 = 逻辑型>
        如果 (类型 == 真)
        {
            结果 = 注册表写文本_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "DisableTaskMgr", "1")
        }
        否则
        {
            结果 = 注册表删除键值_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "DisableTaskMgr")
        }
        返回 (结果)
    }

    方法 任务栏_取任务栏高度 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @     APPBARDATA appBarData;
        @     appBarData.cbSize = sizeof(APPBARDATA);
        @ SHAppBarMessage(ABM_GETTASKBARPOS, &appBarData);
        @ return appBarData.rc.bottom - appBarData.rc.top;
    }

    方法 任务栏_取任务栏高度2 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        变量 pDevMode <类型 = 屏幕分辨率_>
        @ APPBARDATA ABD = { sizeof(APPBARDATA) };
        @ SHAppBarMessage(ABM_GETTASKBARPOS, &ABD);
        @ SHAppBarMessage(ABM_GETSTATE, &ABD);
        pDevMode = 系统_取屏幕分辨率 ()
        @ LONG Height = 0;
        @ if (!ABD.rc.left && ABD.rc.right == @<pDevMode.屏幕宽度>)
        @ Height = ABD.rc.bottom - ABD.rc.top;
        @ else if(!ABD.rc.top && ABD.rc.bottom == @<pDevMode.屏幕高度>)
        @ Height = ABD.rc.right - ABD.rc.left;
        @ return Height;
    }

    方法 系统_锁解任务栏程序 <公开 静态 注释 = "不支持Win10" 折叠>
    参数 目录程序 <类型 = 文本型 注释 = "提供程序路径名称，或lnk快捷方式;" 注释 = "例如：\"C:\\Users\\Administrator\\Desktop\\\\程序.lnk\"　；或\"C:\\\\程序.exe\""
            折叠2>
    参数 类型 <类型 = 整数 注释 = "1、锁定　2、解锁" @默认值 = 1>
    {
        变量 脚本 <类型 = 文本型
                值 = "Const CSIDL_COMMON_PROGRAMS = &H17\r\nConst CSIDL_PROGRAMS = &H2\r\nSet objShell = CreateObject(\"Shell.Application\")\r\nobjpath = left(objFile,instrrev(objFile,\"\\\")-1)\r\nSet objAllUsersProgramsFolder = objShell.NameSpace(objpath)\r\nstrAllUsersProgramsPath = objAllUsersProgramsFolder.Self.Path\r\nSet objFolder = objShell.Namespace(strAllUsersProgramsPath)\r\nSet objFolderItem = objFolder.ParseName(mid(objFile,instrrev(objFile,\"\\\")+1))\r\nSet colVerbs = objFolderItem.Verbs\r\nFor Each objVerb in colVerbs"
                编辑时信息 = "0, C3327, 0, 0">
        变量 脚本锁 <类型 = 文本型
                值 = "    If Replace(objVerb.name, \"&\", \"\") = \"锁定到任务栏(K)\" Then objVerb.DoIt\r\nNext\r\ncreateobject(\"scripting.filesystemobject\").deletefile wscript.scriptfullname"
                编辑时信息 = "0, C3327, 0, 0">
        变量 脚本解 <类型 = 文本型
                值 = "    If Replace(objVerb.name, \"&\", \"\") = \"从任务栏脱离(K)\" Then objVerb.DoIt\r\nNext\r\ncreateobject(\"scripting.filesystemobject\").deletefile wscript.scriptfullname"
                编辑时信息 = "0, C3327, 0, 0">
        变量 合并脚本 <类型 = 文本型 编辑时信息 = "0, C3327, 0, 0">
        变量 路径 <类型 = 文本型 编辑时信息 = "0, C3327, 0, 0">
        如果真 (文件_取扩展名 (目录程序) == ".exe" || 文件_取扩展名 (目录程序) == ".lnk")
        {
            路径 = "objFile = \"" + 目录程序 + "\"\r\n"
            如果 (类型 == 1)
            {
                合并脚本 = 路径 + 脚本 + "\r\n" + 脚本锁
            }
            否则
            {
                合并脚本 = 路径 + 脚本 + "\r\n" + 脚本解
            }
            写出文本文件 (合并脚本, 取运行目录 () + "jbs.vbs", , 文本编码类型.多字节)
            置文件属性 (取运行目录 () + "jbs.vbs", 文件属性.隐藏文件)
            执行_ (取运行目录 () + "jbs.vbs")
        }
    }
}

