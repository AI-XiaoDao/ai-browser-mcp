类 系统内存类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统内存\"" @全局类 = 真>
{
    方法 内存_取指定进程内存大小 <公开 静态 类型 = 长整数 折叠 折叠2 @视窗.外部头文件 = "winternl.h" @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "如果是系统进程或一些拒绝访问的进程，会无法获取内存信息" 编辑时信息 = "693AA, 0, 0, 0">
    {
        @ typedef struct _VM_COUNTERS_EX {
        @     SIZE_T PeakVirtualSize;
        @     SIZE_T VirtualSize;
        @     ULONG PageFaultCount;
        @     SIZE_T PeakWorkingSetSize;
        @     SIZE_T WorkingSetSize;
        @     SIZE_T QuotaPeakPagedPoolUsage;
        @     SIZE_T QuotaPagedPoolUsage;
        @     SIZE_T QuotaPeakNonPagedPoolUsage;
        @     SIZE_T QuotaNonPagedPoolUsage;
        @     SIZE_T PagefileUsage;
        @     SIZE_T PeakPagefileUsage;
        @     SIZE_T PrivateUsage;
        @ } VM_COUNTERS_EX;
        @ typedef struct _VM_COUNTERS_EX2 {
        @     VM_COUNTERS_EX CountersEx;
        @     SIZE_T PrivateWorkingSetSize;
        @     ULONGLONG SharedCommitUsage;
        @ } VM_COUNTERS_EX2, * PVM_COUNTERS_EX2;
        @ typedef NTSTATUS(WINAPI* ZWQUERYINFORMATIONPROCESS)(
        @  HANDLE  ProcessHandle,
        @  int ProcessInformationClass,
        @  PVOID  ProcessInformation,
        @  ULONG  ProcessInformationLength,
        @  PULONG ReturnLength);
        @ VM_COUNTERS_EX2 vm;
        @ HANDLE hProcess = OpenProcess(PROCESS_QUERY_INFORMATION|PROCESS_VM_READ, FALSE, @<进程ID>);
        @ if (hProcess == NULL) {
        @    CloseHandle(hProcess);
        @ return  -1; }
        @ ZWQUERYINFORMATIONPROCESS ZwQueryInformationProcess = (ZWQUERYINFORMATIONPROCESS)GetProcAddress(GetModuleHandleA("Ntdll.dll"), "ZwQueryInformationProcess");
        @ ZwQueryInformationProcess(hProcess, 3, &vm, sizeof(vm), 0);
        @ CloseHandle(hProcess);
        @ return vm.PrivateWorkingSetSize/1024;
    }

    方法 内存_取内存使用率 <公开 静态 类型 = 整数 折叠>
    {
        变量 内存 <类型 = 内存信息类_>
        内存 = 内存_取内存信息 ()
        返回 (内存.物理内存的使用率)
    }

    方法 内存_取内存信息 <公开 静态 类型 = 内存信息类_ 折叠 @禁止流程检查 = 真>
    {
        变量 信息 <类型 = 内存信息类_>
        @ MEMORYSTATUSEX statex;
        @ statex.dwLength = sizeof (statex);
        @ GlobalMemoryStatusEx (&statex);
        @ @<信息.物理内存的使用率>=(@dt<整数>)statex.dwMemoryLoad;
        @ @<信息.物理内存总量>=(@dt<长整数>)statex.ullTotalPhys;
        @ @<信息.物理内存的剩余量>=(@dt<长整数>)statex.ullAvailPhys;
        @ @<信息.系统页面文件大小>=(@dt<长整数>)statex.ullTotalPageFile;
        @ @<信息.系统可用页面文件大小>=(@dt<长整数>)statex.ullAvailPageFile;
        @ @<信息.虚拟内存的总量>=(@dt<长整数>)statex.ullTotalVirtual;
        @ @<信息.虚拟内存的剩余量>=(@dt<长整数>)statex.ullAvailVirtual;
        返回 (信息)
    }
}

类 内存信息类_ <公开 折叠 @文档 = "category = \"程序综合库.系统内存.附加类\"">
{
    变量 物理内存的使用率 <公开 类型 = 整数 注释 = "介于0-100之间的百分数字">
