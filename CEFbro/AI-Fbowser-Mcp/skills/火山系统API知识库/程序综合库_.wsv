        }
        否则
        {
            写数值注册项 (注册表根目录类型.现行用户, "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\HideFileExt", 1)
        }
        如果真 (是否立即生效)
        {
            临时左 = 取鼠标水平位置 ()
            临时右 = 取鼠标垂直位置 ()
            键盘_模拟按键 (按键码.D键, , , , 真)
            延迟2_ (300)
            鼠标_显示隐藏指针 (真)
            鼠标_模拟鼠标左键单击2 (0, 0)
            键盘_模拟按键 (按键码.F5键)
            鼠标_移动鼠标 (临时左, 临时右)
            鼠标_显示隐藏指针 (假)
            键盘_模拟按键 (按键码.D键, , , , 真)
        }
    }

