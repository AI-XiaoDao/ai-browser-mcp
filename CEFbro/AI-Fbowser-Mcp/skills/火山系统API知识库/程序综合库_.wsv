类 屏幕尺寸类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.屏幕尺寸\"" @全局类 = 真>
{
    方法 取屏幕宽度_ <公开 静态 类型 = 整数 注释 = "获取当前用户区屏幕宽度" 折叠 @禁止流程检查 = 真>
    {
        @ HDC hdc = GetDC(NULL);
        @ int client_width = GetDeviceCaps(hdc, DESKTOPHORZRES);
        @  ReleaseDC(NULL, hdc);
        @ return client_width;
    }

    方法 取屏幕高度_ <公开 静态 类型 = 整数 注释 = "获取当前用户区屏幕高度" 折叠 @禁止流程检查 = 真>
    {
        @ HDC hdc = GetDC(NULL);
        @ int client_height = GetDeviceCaps(hdc, DESKTOPVERTRES);
        @  ReleaseDC(NULL, hdc);
        @ return client_height;
    }

    方法 取屏幕宽度2_ <公开 静态 类型 = 整数 注释 = "获取当前用户区屏幕宽度" 折叠>
    {
        返回 (窗口属性api.GetSystemMetrics (16))
    }

    方法 取屏幕高度2_ <公开 静态 类型 = 整数 注释 = "获取当前用户区屏幕高度，不包括任务栏区域。" 折叠>
    {
        返回 (窗口属性api.GetSystemMetrics (17) + 22)
    }

    方法 取屏幕高度3_ <公开 静态 类型 = 整数 注释 = "获取当前用户区屏幕高度，不包括任务栏、标题栏区域。" 折叠>
    {
        返回 (窗口属性api.GetSystemMetrics (17))
    }

    方法 组件位置_ <公开 静态 类型 = 矩形类 注释 = "获取并返回当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)中的所处矩形位置"
            返回值注释 = "如果当前组件存在父组件,所返回位置矩形基于其用户区左上角,否则基于屏幕左上角." 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 矩形变量1 <类型 = 矩形类>
        @     RECT rt;
        @     GetWindowRect ((HWND)@<窗口句柄>,&rt);
        @     @<矩形变量1>.Copy (&rt);  
        返回 (矩形变量1)
    }

    方法 宽度_ <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ RECT rect;  
        @ GetWindowRect((HWND)@<窗口句柄>, &rect);
        @         int width = rect.right - rect.left;  
        @ return width;
    }

    方法 高度_ <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ RECT rect;  
        @ GetWindowRect((HWND)@<窗口句柄>, &rect);
        @         int height = rect.bottom - rect.top;
        @ return height;
    }

    方法 取用户区宽度_ <公开 静态 类型 = 整数 注释 = "  返回窗口或窗口组件用户区域的宽度,对窗口而言,用户区域" 注释 = "为窗口区域减去标题栏+菜单栏+边框后的区域" 折叠 折叠2 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ RECT rect;  
        @ GetClientRect((HWND)@<窗口句柄>, &rect);
        @         int width = rect.right - rect.left;  
        @ return width;
    }

    方法 取用户区高度_ <公开 静态 类型 = 整数 注释 = "  返回窗口或窗口组件用户区域的高度,对窗口而言,用户区域为" 注释 = "窗口区域减去标题栏+菜单栏+边框后的区域" 折叠 折叠2 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ RECT rect;  
        @ GetClientRect((HWND)@<窗口句柄>, &rect);
        @         int height = rect.bottom - rect.top;
        @ return height;
    }
}

