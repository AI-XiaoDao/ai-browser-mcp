    方法 窗口_窗口组件ID取组件句柄 <公开 静态 类型 = 变整数 注释 = "通过组件ID来获取组件句柄" 折叠>
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件ID <类型 = 整数>
    {
        变量 句柄组 <类型 = 变整数数组类>
        变量 句柄 <类型 = 变整数>
        变量 ID <类型 = 整数>
        窗口_枚举窗口句柄 (父窗口句柄, , 句柄组)
        句柄组.枚举循环 ()
        {
            句柄 = 句柄组.取枚举值 ()
            ID = 窗口_取窗口组件ID (句柄)
            如果真 (ID == 组件ID)
            {
                跳出循环
            }
        }
        返回 (句柄)
    }

    方法 窗口_窗口组件ID取组件句柄_批量 <公开 静态 类型 = 变整数数组类 注释 = "通过组件ID来获取组件句柄" 折叠>
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 组件ID组 <类型 = 整数数组类>
    {
        变量 句柄组 <类型 = 变整数数组类>
        变量 句柄 <类型 = 变整数>
        变量 结果 <类型 = 变整数数组类>
        变量 ID <类型 = 整数>
        变量 i <类型 = 整数>
        窗口_枚举窗口句柄 (父窗口句柄, , 句柄组)
        组件ID组.枚举循环 ()
        {
            循环 (, 句柄组.取成员数 (), i)
            {
                句柄 = 句柄组.取成员 (i)
                ID = 窗口_取窗口组件ID (句柄)
                如果真 (ID == 组件ID组.取枚举值 ())
                {
                    结果.加入成员 (句柄)
                    跳出循环
                }
            }
        }
        返回 (结果)
    }

    方法 组件_取控件内容 <公开 静态 类型 = 文本型 注释 = "例如取指定编辑框中的内容" 折叠 @禁止流程检查 = 真>
    参数 控件句柄 <类型 = 变整数>
    {
        变量 Buffer <类型 = 文本型>
        @ HWND hWnd = (HWND)@<控件句柄>;
        @ INT_PTR nSize = SendMessageW(hWnd, WM_GETTEXTLENGTH, NULL, NULL);
        @ nSize += sizeof(TCHAR);
        @ LPWSTR Buffer = new TCHAR[nSize];
        @ wmemset(Buffer, 0, nSize);
        @ SendMessageW(hWnd, WM_GETTEXT, nSize, (LPARAM)Buffer);
        @ @<Buffer> = Buffer;
        @ delete[] Buffer;
        @ return @<Buffer>.GetText();
    }

    方法 组件_置控件内容 <公开 静态 注释 = "例如往指定的编辑框里写入内容" 折叠 @禁止流程检查 = 真>
