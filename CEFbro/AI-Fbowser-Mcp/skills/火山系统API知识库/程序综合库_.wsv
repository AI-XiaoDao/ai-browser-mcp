类 屏幕处理类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.显示器\"" @全局类 = 真>
{

    # @ <include>
    # @ static BOOL CALLBACK Monitorenumproc(HMONITOR Arg1, HDC Arg2, LPRECT Arg3, LPARAM Arg4)
    # @ {
    # @     int* p = (int*)Arg4;
    # @     *p = *p + 1;
    # @     return TRUE;
    # @ }
    # @ </include>

    方法 系统_取屏幕数量 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        变量 数量 <类型 = 整数>
        @ EnumDisplayMonitors(NULL, NULL, Monitorenumproc, (@dt<变整数>)&@<数量>);
        返回 (数量)
    }

    方法 系统_取屏幕分辨率 <公开 静态 类型 = 屏幕分辨率_ 注释 = "返回：屏幕分辨率_" 折叠 @禁止流程检查 = 真>
    参数 显示器序 <类型 = 整数 @默认值 = 0>
    {
        变量 pDevMode <类型 = 屏幕分辨率_>
        @ DISPLAY_DEVICEW pDisplayDevice;
        @ memset(&pDisplayDevice, 0, sizeof(DISPLAY_DEVICEW));
        @ pDisplayDevice.cb = sizeof(DISPLAY_DEVICEW);
        @ BOOL bRes = EnumDisplayDevicesW(NULL, @<显示器序>, &pDisplayDevice, EDD_GET_DEVICE_INTERFACE_NAME);
        @ if (!bRes) return @<pDevMode>;
        @ DEVMODEW pDevMode;
        @ memset(&pDevMode, 0, sizeof(DEVMODEW));
        @ pDevMode.dmSize = sizeof(DEVMODEW);
        @ bRes = EnumDisplaySettingsW(pDisplayDevice.DeviceName, ENUM_CURRENT_SETTINGS, &pDevMode);
        @ if (!bRes) return @<pDevMode>;
        @ @<pDevMode.颜色> = pDevMode.dmBitsPerPel;
        @ @<pDevMode.屏幕宽度> = pDevMode.dmPelsWidth;
        @ @<pDevMode.屏幕高度> = pDevMode.dmPelsHeight;
        @ @<pDevMode.屏幕刷新频率> = pDevMode.dmDisplayFrequency;
        @ return @<pDevMode>;
    }

    方法 系统_置屏幕分辨率 <公开 静态 类型 = 逻辑型 折叠>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 位数 <类型 = 整数 @默认值 = 32>
    参数 刷新频率 <类型 = 整数 @默认值 = 60>
    参数 设置类型 <类型 = 整数 注释 = "1、正式更改　2、临时更改" @默认值 = 1>
    {
        变量 NewDevMode <类型 = 屏幕处理结构类>
        变量 Result <类型 = 整数>
        如果 (设置类型 > 2 || 设置类型 < 1)
        {
            设置类型 = 0
        }
        否则
        {
            设置类型 = 4
        }
        屏幕处理api.EnumDisplaySettingsA (0, 0, NewDevMode)
        NewDevMode.dmSize = 192
        NewDevMode.dmFields = 连续位或 (1048576, 524288, 262144, 4194304)
        NewDevMode.dmPelsWidth = 宽度
        NewDevMode.dmPelsHeight = 高度
        NewDevMode.dmBitsPerPel = 位数
        NewDevMode.dmDisplayFrequency = 刷新频率
        Result = 屏幕处理api.ChangeDisplaySettingsA (NewDevMode, 设置类型)
        返回 (Result == 0)
    }

    方法 系统_关闭显示器 <公开 静态 折叠>
    {
        发送消息_ (屏幕处理api.GetActiveWindow (), 274, 61808, 2)
    }

    方法 系统_开启显示器 <公开 静态 折叠>
    {
        发送消息_ (屏幕处理api.GetActiveWindow (), 274, 61808, -1)
    }

    方法 系统_枚举显示器 <公开 静态 类型 = 整数 注释 = "取出所有显示器的信息" 返回值注释 = "返回显示器数量" 折叠 @禁止流程检查 = 真>
    参数 返回的屏幕信息 <类型 = 屏幕信息组类 注释 = "新建此类型的变量，用于接收此参数返回的信息." 注释 = "可以枚举循环，屏幕信息.取枚举值 ().左边  ；顶边  ；宽度  ；高度  ；名称，分别取出屏幕的位置、分辨率及名称."
            注释 = "如果副显示器在左边，则“左边”这个值是负" @默认值 = 空对象>
    {
        变量 屏幕坐标1 <类型 = 屏幕坐标类>
        // @ RECT m_ScrRect[12];
        @     int count = 0;
        @     for (int ScreenNo = 0; true; ++ScreenNo)
        @     {
        @         BOOL flag;
        @         DISPLAY_DEVICE dd;
        @         ZeroMemory(&dd, sizeof(dd));
        @         dd.cb = sizeof(dd);
        @         flag = EnumDisplayDevices(NULL, ScreenNo, &dd, EDD_GET_DEVICE_INTERFACE_NAME);
        @         if (!flag)
        @         {
        @             break;
        @         }
        @         DEVMODE dm;
        @         ZeroMemory(&dm, sizeof(dm));
        @         dm.dmSize = sizeof(dm);
        @         flag = EnumDisplaySettingsEx(dd.DeviceName, ENUM_CURRENT_SETTINGS, &dm, 0);
        @         if (!flag)
        @         {
        @             continue;
        @         }
        // @         m_ScrRect[count].left = dm.dmPosition.x;
        // @         m_ScrRect[count].top = dm.dmPosition.y;
        // @         m_ScrRect[count].right = m_ScrRect[count].left + dm.dmPelsWidth - 1;
        // @         m_ScrRect[count].bottom = m_ScrRect[count].top + dm.dmPelsHeight - 1;
        @     @<屏幕坐标1.左边>=dm.dmPosition.x;  
        @     @<屏幕坐标1.顶边>=dm.dmPosition.y;  
        @     @<屏幕坐标1.宽度>=dm.dmPelsWidth;  
        @     @<屏幕坐标1.高度>=dm.dmPelsHeight;  
        @     @<屏幕坐标1.名称>=dd.DeviceString;
        返回的屏幕信息.加入成员 (屏幕坐标1)
        @         ++count;
        @   
        // @         std::cout << "显示器: " << dd.DeviceName << " (dmBitsPerPel " << dm.dmBitsPerPel << " dmLogPixels " << dm.dmLogPixels << ") "
        @     }
        @     return count;
    }
}

