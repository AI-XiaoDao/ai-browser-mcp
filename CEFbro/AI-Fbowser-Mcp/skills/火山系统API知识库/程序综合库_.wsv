        变量 脚本名称 <类型 = 文本型>
        程序名称 = 取运行目录 () + 取执行文件名 ()
        脚本名称 = 取运行目录 () + "kill.bat"
        脚本 = "taskkill /f /im " + 取执行文件名 () + "\r\n"
        脚本 = 脚本 + ":Repeat" + "\r\n"
        脚本 = 脚本 + "del \"" + 程序名称 + "\"\r\n"
        脚本 = 脚本 + "if exist \"" + 程序名称 + "\" goto Repeat" + "\r\n"
        脚本 = 脚本 + "del %0"
        写到文件 (脚本名称, 文本到多字节 (脚本, 假))
        运行 (脚本名称, 假, 程序窗口显示方式.隐藏窗口)
    }

