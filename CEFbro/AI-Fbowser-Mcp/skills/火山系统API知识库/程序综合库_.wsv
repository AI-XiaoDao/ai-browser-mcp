    方法 窗口_取焦点组件句柄 <公开 静态 类型 = 变整数 注释 = "获取自身拥有输入焦点的窗口句柄" 折叠 @禁止流程检查 = 真>
    {
        @ DWORD dwThisTID = GetCurrentThreadId();
        @ HWND hWnd = GetForegroundWindow();
        @ DWORD dwNewTID = GetWindowThreadProcessId(hWnd, 0);
        @ HWND nhWnd = GetFocus();
        @ if (dwThisTID = dwNewTID)
        @ AttachThreadInput(dwNewTID, dwThisTID, true);
        @ else
        @ AttachThreadInput(dwNewTID, dwThisTID, false);
        @ return (INT_PTR)nhWnd;
    }

    方法 窗口_取焦点组件句柄2 <公开 静态 类型 = 变整数 注释 = "获取自身拥有输入焦点的窗口句柄，支持外部窗口" 折叠 @禁止流程检查 = 真>
    {
        @ HWND wnd;
        @ wnd=GetForegroundWindow();
        @ DWORD SelfThreadId=GetCurrentThreadId();
        @ DWORD ForeThreadId=GetWindowThreadProcessId(wnd,NULL);
        @ AttachThreadInput(ForeThreadId,SelfThreadId,true);
        @ wnd=GetFocus();
        @ AttachThreadInput(ForeThreadId,SelfThreadId,false);
        @ return (INT_P)wnd;
    }

