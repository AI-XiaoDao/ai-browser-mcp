类 防火墙类_ <公开 折叠 @文档 = "category = \"程序综合库.防火墙\"">
{
    方法 允许被外网访问_ <公开 类型 = 逻辑型 注释 = "例如服务端程序需要开启允许外网访问" 折叠>
    {
        变量 名称 <类型 = 文本型>
        变量 路径 <类型 = 文本型>
        路径 = 取运行目录 ()
        名称 = 取执行文件名 ()
        删除出入站规则_ (名称)
        返回 (添加出入站规则_程序 (名称, 路径 + 名称, 真, 真))
    }

    方法 禁止程序连网_ <公开 类型 = 逻辑型 折叠>
    参数 程序路径 <类型 = 文本型 注释 = "例如：C:\\\\测试.exe">
    参数 禁止连网 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 结果 <类型 = 逻辑型>
        变量 名称 <类型 = 文本型>
        开启防火墙_ ()
        名称 = 文件_取文件名 (程序路径)
        如果 (禁止连网 == 假)
        {
            结果 = 删除出入站规则_ (名称)
        }
        否则
        {
            删除出入站规则_ (名称)
            结果 = 添加出入站规则_程序 (名称, 程序路径, 假, 假)
        }
        返回 (结果)
    }

    方法 添加出入站规则_端口 <公开 类型 = 逻辑型 折叠>
    参数 规则名称 <类型 = 文本型 注释 = "默认为程序名称" @默认值 = "">
    参数 端口 <类型 = 整数 "">
    参数 端口类型 <类型 = 文本型 注释 = "请填写TCP或UDP" @默认值 = "TCP">
    参数 是否入站 <类型 = 逻辑型 注释 = "真：为入站　假：为出站" @默认值 = 真>
    参数 允许连网 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 结果 <类型 = 文本型>
        运行控制台程序 ("netsh advfirewall firewall Add rule name=\"" + 规则名称 + "\" dir=" + 选择 (是否入站 == 真, "in", "out") + " protocol=" + 端口类型 + " localport=" + 到文本 (端口) + " action=allow", 结果)
        如果真 (寻找文本 (结果, "确定") == -1)
        {
            返回 (假)
        }
        返回 (真)
    }

    方法 添加出入站规则_程序 <公开 类型 = 逻辑型 折叠>
    参数 规则名称 <类型 = 文本型 注释 = "默认为程序名称" @默认值 = "">
    参数 程序路径 <类型 = 文本型 注释 = "例如：C:\\\\测试.exe">
    参数 是否入站 <类型 = 逻辑型 注释 = "真：为入站　假：为出站" @默认值 = 真>
    参数 允许连网 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 结果 <类型 = 文本型>
        变量 名称 <类型 = 文本型>
        如果真 (规则名称 == "")
        {
            名称 = 文件_取文件名 (程序路径)
            规则名称 = 名称
        }
        运行控制台程序 ("netsh advfirewall firewall add rule name=\"" + 规则名称 + "\" dir=" + 选择 (是否入站 == 真, "in", "out") + "  program=\"" + 程序路径 + "\" action=" + 选择 (允许连网 == 真, "allow", "block"), 结果)
        如果真 (寻找文本 (结果, "确定") == -1)
        {
            返回 (假)
        }
        返回 (真)
    }

    方法 删除出入站规则_ <公开 类型 = 逻辑型 注释 = "入站和出站中同规则名称的将会全部删除" 折叠>
    参数 规则名称 <类型 = 文本型>
    {
        变量 结果 <类型 = 文本型>
        运行控制台程序 ("netsh advfirewall firewall delete rule name=\"" + 规则名称 + "\"", 结果)
        如果真 (寻找文本 (结果, "已删除") != -1)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 开关出入站规则_ <公开 类型 = 逻辑型 注释 = "开启或禁用规则" 折叠>
    参数 规则名称 <类型 = 文本型>
    参数 是否关闭 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 结果 <类型 = 文本型>
        运行控制台程序 ("netsh advfirewall firewall set rule name=\"" + 规则名称 + "\" new enable=" + 选择 (是否关闭 == 真, "no", "yes"), 结果)
        如果真 (寻找文本 (结果, "已更新") != -1)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 开启防火墙_ <公开 类型 = 逻辑型 折叠>
    {
        变量 结果 <类型 = 文本型>
        变量 结果2 <类型 = 文本型>
        运行控制台程序 ("net start mpssvc", 结果, 结果2)
        如果真 (寻找文本 (结果, "已经启动") != -1 || 寻找文本 (结果2, "已经启动") != -1)
        {
            运行控制台程序 ("netsh advfirewall set allprofiles state on", 结果)
            如果 (寻找文本 (结果, "确定") == -1)
            {
                返回 (假)
            }
        }
        返回 (真)
    }

    方法 关闭防火墙_ <公开 类型 = 逻辑型 折叠>
    {
        变量 结果 <类型 = 文本型>
        变量 结果2 <类型 = 文本型>
        运行控制台程序 ("net stop mpssvc", 结果, 结果2)
        如果 (寻找文本 (结果, "成功停止") != -1 || 寻找文本 (结果2, "没有启动") != -1)
        {
            返回 (真)
        }
        否则
        {
            运行控制台程序 ("NetSh Advfirewall set allprofiles state off", 结果)
            如果真 (寻找文本 (结果, "确定") != -1)
            {
                返回 (真)
            }
        }
        返回 (假)
    }
}

类 防火墙类2_ <公开 注释 = "" 折叠 @文档 = "category = \"程序综合库.防火墙\"">
{
    变量 FwPolicy2 <类型 = COM对象类>
    变量 INetFwRule <类型 = COM对象类>
    变量 INetFwRule_添加 <类型 = COM对象类>
    变量 INetFwRules <类型 = COM对象类>
    变量 INetFwServiceRestriction <类型 = COM对象类>
    变量 INetFwRules_服务 <类型 = COM对象类>

    方法 类_初始化 <折叠>
    {
        初始化_ ()
    }

    方法 类_清理 <折叠>
    {
        清理 ()
    }

    方法 清理 <折叠>
    {
        FwPolicy2.清除 ()
        INetFwRule.清除 ()
        INetFwRules_服务.清除 ()
        INetFwRule_添加.清除 ()
        INetFwServiceRestriction.清除 ()
    }

    方法 初始化_ <注释 = "默认已初始化，可重复执行" 折叠>
    {
        清理 ()
        FwPolicy2.创建 ("HNetCfg.FwPolicy2", )
        INetFwRule.创建 ("HNetCfg.FwRule", )
        INetFwRule_添加.创建 ("HNetCfg.FwRule", )
        INetFwRules = FwPolicy2.读无参数属性 ("Rules", COM对象类)
        INetFwServiceRestriction = FwPolicy2.读无参数属性 ("ServiceRestriction", COM对象类)
        INetFwRules_服务 = FwPolicy2.读无参数属性 ("Rules", COM对象类)
    }

    方法 还原防火墙默认状态_ <公开 折叠>
    {
        FwPolicy2.无参数及返回值方法 ("RestoreLocalFirewallDefaults")
    }

    方法 允许单播响应_ <公开 折叠>
    参数 域 <类型 = 逻辑型>
    参数 专用 <类型 = 逻辑型>
    参数 公用 <类型 = 逻辑型>
    {
        置单播响应多播和广播_ (1, 域)
        置单播响应多播和广播_ (2, 专用)
        置单播响应多播和广播_ (4, 公用)
    }

    方法 更改通知_ <公开 折叠>
    参数 家庭_阻止传入连接 <类型 = 逻辑型 注释 = "家庭或工作（专用）网络位置_阻止所有传入连接，包括位于允许程序列表中的程序">
    参数 公用_阻止传入连接 <类型 = 逻辑型 注释 = "公用网络位置_阻止所有传入连接，包括位于允许程序列表中的程序">
    参数 家庭_阻止新程序时通知我 <类型 = 逻辑型>
    参数 公用_阻止新程序时通知我 <类型 = 逻辑型>
    {
        置允许入站_ (2, 家庭_阻止传入连接)
        置允许入站_ (4, 公用_阻止传入连接)
        置交互式通知_ (2, 取反 (家庭_阻止新程序时通知我))
        置交互式通知_ (4, 取反 (公用_阻止新程序时通知我))
    }

    方法 开启防火墙_ <公开 类型 = 逻辑型 折叠>
    {
        返回 (置防火墙状态_ (1, 真) && 置防火墙状态_ (2, 真) && 置防火墙状态_ (4, 真))
    }

    方法 关闭防火墙_ <公开 类型 = 逻辑型 折叠>
    {
        返回 (置防火墙状态_ (1, 假) && 置防火墙状态_ (2, 假) && 置防火墙状态_ (4, 假))
    }

    方法 置防火墙状态_ <公开 类型 = 逻辑型 注释 = "开启或关闭" 折叠>
    参数 配置文件类型 <类型 = 整数 注释 = "1=域　2=专用　4=公共　2147483647(0x7fffffff)=所有">
    参数 是否开启 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (FwPolicy2.写属性 ("FirewallEnabled", 配置文件类型, 是否开启))
    }

    方法 取防火墙状态_ <公开 类型 = 逻辑型 注释 = "取当前状态" 折叠>
    参数 配置文件类型 <类型 = 整数 注释 = "1=域　2=专用　4=公共　2147483647(0x7fffffff)=所有">
    {
        返回 (FwPolicy2.读属性 ("FirewallEnabled", 逻辑型, 配置文件类型))
    }

    方法 关闭所有网络_ <公开 折叠>
    {
        开启防火墙_ ()
        更改通知_ (真, 真, 真, 真)
        置出站属性_ (0, 0, 0)
        置入站属性_ (0, 0, 0)
    }

    方法 开启所有网络_ <公开 折叠>
    {
        开启防火墙_ ()
        更改通知_ (假, 假, 假, 假)
        置出站属性_ (1, 1, 1)
        置入站属性_ (1, 1, 1)
    }

    方法 添加规则_ <公开 类型 = 逻辑型 注释 = "流程：添加规则　；添加规则－置规则　；添加规则－取规则－置规则" 折叠>
    参数 规则名称 <类型 = 文本型 @默认值 = "A测试">
    参数 规则描述 <类型 = 文本型 @默认值 = "">
    参数 方向 <类型 = 整数 注释 = "1、入站　2、出站" @默认值 = 1>
    参数 是否启用 <类型 = 逻辑型 @默认值 = 真>
    参数 操作 <类型 = 整数 注释 = "0、阻止连接　1、允许连接   2、安全连接" @默认值 = 1>
    参数 分组 <类型 = 文本型 注释 = "设置了分组是表示预定义规则，某些属性无法修改" @默认值 = "">
    参数 接口类型 <类型 = 文本型 注释 = "All、所有类型　Lan、局域网　RemoteAccess、远程访问　Wireless、无线　；可以用分号组合：Lan,Wireless,RemoteAccess" @默认值 = "All">
    参数 配置文件 <类型 = 整数 注释 = "1、域　2、专用　4、公用　2147483647(0x7fffffff)、所有" @默认值 = 2147483647>
    参数 协议类型 <类型 = 整数
            注释 = "256、全部　0、自定义　1、ICMPV4　2、IGMP　6、TCP　17、UDP　41、IPV6　43、IPV6-ROUTE　44、IPV6-FRAG　47、GRE　58、ICMPV6　59、IPV6-NONXT　60、IPV6-OPTS　112、VRRP　113、PGM　115、L2TP"
            @默认值 = 6>
    {
        INetFwRule_添加.写属性 ("Name", 规则名称)
        INetFwRule_添加.写属性 ("Description", 规则描述)
        INetFwRule_添加.写属性 ("Direction", 方向)
        INetFwRule_添加.写属性 ("Enabled", 是否启用)
        如果真 (文本是否为空 (分组) == 假)
        {
            INetFwRule_添加.写属性 ("Grouping", 分组)
        }
        INetFwRule_添加.写属性 ("Action", 操作)
        INetFwRule_添加.写属性 ("Profiles", 配置文件)
        INetFwRule_添加.写属性 ("Protocol", 协议类型)
        INetFwRule_添加.写属性 ("InterfaceTypes", 接口类型)
        INetFwRules.无返回值方法 ("Add", INetFwRule_添加)
        如果真 (INetFwRules.取错误 () != COM方法调用结果.异常)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 取规则_ <公开 类型 = 防火墙规则组_ 注释 = "流程：取规则－置规则" 折叠>
    参数 规则名 <类型 = 文本型>
    {
        变量 规则 <类型 = 防火墙规则组_>
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        规则.规则名称 = INetFwRule.读无参数属性 ("规则名", 文本型)
        规则.规则描述 = INetFwRule.读无参数属性 ("Description", 文本型)
        规则.应用程序名 = INetFwRule.读无参数属性 ("ApplicationName", 文本型)
        规则.服务名称 = INetFwRule.读无参数属性 ("serviceName", 文本型)
        规则.协议类型 = INetFwRule.读无参数属性 ("Protocol", 整数)
        规则.本地端口 = INetFwRule.读无参数属性 ("LocalPorts", 整数)
        规则.远程端口 = INetFwRule.读无参数属性 ("RemotePorts", 整数)
        规则.本地地址 = INetFwRule.读无参数属性 ("LocalAddresses", 文本型)
        规则.远程地址 = INetFwRule.读无参数属性 ("RemoteAddresses", 文本型)
        规则.Icmp类型和代码 = INetFwRule.读无参数属性 ("IcmpTypesAndCodes", 文本型)
        规则.方向 = INetFwRule.读无参数属性 ("Direction", 整数)
        规则.接口 = INetFwRule.读无参数属性 ("Interfaces", COM变体型)
        规则.接口类型 = INetFwRule.读无参数属性 ("InterfaceTypes", 文本型)
        规则.是否启用 = INetFwRule.读无参数属性 ("Enabled", 逻辑型)
        规则.分组 = INetFwRule.读无参数属性 ("Grouping", 文本型)
        规则.配置文件类型 = INetFwRule.读无参数属性 ("Profiles", 整数)
        规则.启用边缘遍历 = INetFwRule.读无参数属性 ("EdgeTraversal", 逻辑型)
        规则.操作 = INetFwRule.读无参数属性 ("Action", 整数)
        规则.边缘遍历选项 = INetFwRule.读无参数属性 ("EdgeTraversalOptions", 整数)
        返回 (规则)
    }

    方法 置规则_ <公开 类型 = 逻辑型 注释 = "流程：置规则　；添加规则－置规则　；添加规则－取规则－置规则" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 规则 <类型 = 防火墙规则组_>
    {
        初始化_ ()
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        如果真 (文本是否为空 (规则.规则名称) == 假)
        {
            INetFwRule.写属性 ("Name", 规则.规则名称)
        }
        INetFwRule.写属性 ("Description", 规则.规则描述)
        如果真 (文本是否为空 (规则.应用程序名) == 假)
        {
            INetFwRule.写属性 ("ApplicationName", 规则.应用程序名)
        }
        如果真 (文本是否为空 (规则.服务名称) == 假)
        {
            INetFwRule.写属性 ("serviceName", 规则.服务名称)
        }
        INetFwRule.写属性 ("Protocol", 规则.协议类型)
        如果真 (规则.本地端口 != 0)
        {
            INetFwRule.写属性 ("LocalPorts", 规则.本地端口)
        }
        如果真 (规则.远程端口 != 0)
        {
            INetFwRule.写属性 ("RemotePorts", 规则.远程端口)
        }
        INetFwRule.写属性 ("LocalAddresses", 规则.本地地址)
        INetFwRule.写属性 ("RemoteAddresses", 规则.远程地址)
        如果真 (文本是否为空 (规则.Icmp类型和代码) == 假)
        {
            INetFwRule.写属性 ("IcmpTypesAndCodes", 规则.Icmp类型和代码)
        }
        如果真 (规则.方向 == 0)
        {
            规则.方向 = 1
        }
        INetFwRule.写属性 ("Direction", 规则.方向)
        // INetFwRule.写属性 ("Interfaces", 规则.接口)
        如果真 (文本是否为空 (规则.接口类型))
        {
            规则.接口类型 = "All"
        }
        INetFwRule.写属性 ("InterfaceTypes", 规则.接口类型)
        INetFwRule.写属性 ("Enabled", 规则.是否启用)
        如果真 (文本是否为空 (规则.分组) == 假)
        {
            INetFwRule.写属性 ("Grouping", 规则.分组)
        }
        如果真 (规则.配置文件类型 == 0)
        {
            规则.配置文件类型 = 2147483647
        }
        INetFwRule.写属性 ("Profiles", 规则.配置文件类型)
        INetFwRule.写属性 ("Action", 规则.操作)
        INetFwRule.写属性 ("EdgeTraversal", 规则.启用边缘遍历)
        INetFwRule.写属性 ("EdgeTraversalOptions", 规则.边缘遍历选项)
        如果真 (INetFwRules.取错误 () != COM方法调用结果.异常)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 删除规则_ <公开 类型 = 逻辑型 折叠>
    参数 规则名 <类型 = 文本型>
    {
        INetFwRules.无返回值方法 ("Remove", 规则名)
        如果真 (INetFwRules.取错误 () != COM方法调用结果.异常)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 启用规则_ <公开 类型 = 逻辑型 折叠>
    参数 规则名 <类型 = 文本型>
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("Enabled", 真))
    }

    方法 停用规则_ <公开 类型 = 逻辑型 折叠>
    参数 规则名 <类型 = 文本型>
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("Enabled", 假))
    }

    方法 禁止程序连网_ <公开 折叠>
    参数 新建规则名 <类型 = 文本型>
    参数 应用程来源 <类型 = 文本型 注释 = "绝对路径">
    {
        变量 规则 <类型 = 防火墙规则组_>
        添加规则_ (新建规则名)
        规则 = 取规则_ (新建规则名)
        规则.规则名称 = 新建规则名
        规则.应用程序名 = 应用程来源
        规则.方向 = 1
        规则.是否启用 = 真
        规则.操作 = 0
        置规则_ (新建规则名, 规则)
        初始化_ ()
        添加规则_ (新建规则名)
        规则.方向 = 2
        置规则_ (新建规则名, 规则)
    }

    方法 修改描述_ <公开 类型 = 逻辑型 注释 = "[常规]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 新描述信息 <类型 = 文本型>
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("Description", 新描述信息))
    }

    方法 修改操作_ <公开 类型 = 逻辑型 注释 = "[常规]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 类型 <类型 = 整数 注释 = "0、阻止连接　1、允许连接   2、安全连接">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        返回 (INetFwRule.写属性 ("Action", 类型))
    }

    方法 修改程序_ <公开 注释 = "[程序和服务]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 应用程来源 <类型 = 文本型 注释 = "程序绝对路径">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
        INetFwRule.写属性 ("ApplicationName", 应用程来源)
    }

    方法 修改服务_ <公开 类型 = 逻辑型 注释 = "[程序和服务]中的设置" 折叠>
    参数 规则名 <类型 = 文本型>
    参数 名称 <类型 = 文本型 注释 = "服务名称">
    {
        INetFwRule = INetFwRules.对象型方法 ("Item", COM对象类, 规则名)
