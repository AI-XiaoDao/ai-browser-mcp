    方法 创建提示 <公开 折叠>
    参数 窗口句柄 <类型 = 变整数 注释 = "窗口句柄，非组件句柄">
    参数 最大宽度 <类型 = 整数 @默认值 = 500>
    参数 响应鼠标点击关闭 <类型 = 逻辑型 注释 = "真：当点击鼠标时关闭提示" @默认值 = 真>
    {
        @ HWND hwndParent = (HWND)@<窗口句柄>;
        @ int maxWidth = @<最大宽度>;
        @ CreateToolTip(hwndParent, maxWidth);
        如果真 (响应鼠标点击关闭)
        {
            @ OldWindowProc = SetWindowLongPtr (hwndParent, -4,(LONG_PTR)@<窗口消息>);
        }
    }

    方法 弹出提示 <公开 折叠>
    参数 提示文本 <类型 = 文本型>
    参数 横向坐标 <类型 = 整数>
    参数 纵向坐标 <类型 = 整数>
    参数 显示时长 <类型 = 整数 注释 = "填写-1则无限延时" @默认值 = 3000>
    {
        @ LPCTSTR pszText = @<提示文本>;
        @ OnButtonClick (@<横向坐标>,@<纵向坐标>, pszText);
        如果真 (显示时长 != -1)
        {
            时钟1.启动时钟_ (显示时长)
        }
    }

    方法 关闭提示 <公开 折叠>
    {
        @ HideToolTip();
    }

    方法 窗口消息 <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @输出名 = "hWnd">
    参数 消息值 <类型 = 整数 @输出名 = "uMsg">
    参数 消息参数1 <类型 = 变整数 @输出名 = "wParam">
    参数 消息参数2 <类型 = 变整数 @输出名 = "lParam">
    {
        如果真 (消息值 == 513 || 消息值 == 516 || 消息值 == 519)
        {
            @ HideToolTip();
        }
        @ return (LRESULT)::CallWindowProc ((WNDPROC)OldWindowProc, (HWND)hWnd, (UINT)uMsg, wParam, lParam);
    }

    方法 时钟类__周期事件_ <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_>
    参数 标记值 <类型 = 整数>
    参数 时钟ID <类型 = 整数>
    {
        来源对象.停止时钟_ ()
        关闭提示 ()
        返回 (0)
    }
}

