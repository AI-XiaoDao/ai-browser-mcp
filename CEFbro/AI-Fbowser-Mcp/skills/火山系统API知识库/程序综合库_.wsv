类 系统程序列表信息类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.程序安装信息\"" @全局类 = 真>
{
    变量 集过滤组 <类型 = 文本数组类>
    变量 集开启过滤 <类型 = 逻辑型>
    变量 集程序名称 <类型 = 文本型>
    变量 集程序ID <类型 = 文本型>
    变量 集提示信息 <类型 = 文本型>
    变量 集结果 <类型 = 逻辑型>
    变量 已启动 <类型 = 逻辑型>
    变量 线程 <类型 = 线程池类2_>

    方法 类_初始化 <折叠>
    {
        集过滤组.加入成员 ("NVIDIA Corporation", "Microsoft Corporation", "Intel", "Realtek")
        线程.创建_ ()
    }

    方法 卸载程序_ <公开 类型 = 逻辑型 注释 = "卸载系统中已安装的程序" 折叠>
    参数 程序名称 <类型 = 文本型 注释 = "参数一和二只需要提供一个即可。如果有多个名称相同，则会全部卸载" @默认值 = "">
    参数 程序ID <类型 = 文本型 注释 = "多个名称相同时，可以提供唯一ID，即可只卸载指定项" @默认值 = "">
    参数 返回的提示信息 <类型 = 文本型 @默认值 = "">
    {
        集程序名称 = 程序名称
        集程序ID = 程序ID
        如果真 (已启动)
        {
            返回的提示信息 = "还有程序未卸载完"
            返回 (假)
        }
        已启动 = 真
        线程.投递任务_ ()
        判断循环 (已启动)
        {
            延迟2_ (1)
        }
        处理事件_ ()
        返回的提示信息 = 集提示信息
        返回 (集结果)
    }

    方法 枚举程序列表_ <公开 类型 = 整数 注释 = "获取系统安装程序信息" 返回值注释 = "返回安装程序数量" 折叠>
    参数 返回的名称 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的发布者 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的安装时间 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的大小 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的版本 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的路径 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的ID <类型 = 文本数组类 @默认值 = 空对象>
    参数 是否开启过滤 <类型 = 逻辑型 注释 = "可过滤掉一些不显示的程序" @默认值 = 假>
    参数 过滤组 <类型 = 文本数组类 注释 = "默认过滤“NVIDIA Corporation、Microsoft Corporation、Intel、Realtek”" @默认值 = 空对象>
    {
        变量 根节点 <类型 = 文本型 值 = "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall" 编辑时信息 = "0, 713AA, 0, 0">
        变量 键名组 <类型 = 文本数组类 编辑时信息 = "0, 713AA, 0, 0">
        变量 键名组2 <类型 = 文本数组类 编辑时信息 = "0, 713AA, 0, 0">
        变量 临时发布 <类型 = 文本型>
        变量 临时名 <类型 = 文本型 编辑时信息 = "0, 713AA, 0, 0">
        变量 临时大小 <类型 = 整数 编辑时信息 = "0, 713AA, 0, 0">
        变量 临时时间 <类型 = 文本型 编辑时信息 = "0, 713AA, 0, 0">
        变量 临时路径 <类型 = 文本型 编辑时信息 = "0, 713AA, 0, 0">
        变量 是否64位 <类型 = 逻辑型 编辑时信息 = "0, 713AA, 0, 0">
        变量 总数 <类型 = 整数 编辑时信息 = "0, 713AA, 0, 0">
        变量 位数 <类型 = 整数 编辑时信息 = "0, 713AA, 0, 0">
        变量 i <类型 = 整数 编辑时信息 = "0, 713AA, 0, 0">
        变量 i2 <类型 = 整数 编辑时信息 = "0, 713AA, 0, 0">
        如果真 (过滤组.取成员数 () > 0)
        {
            集过滤组 = 过滤组
        }
        集开启过滤 = 是否开启过滤
        位数 = 选择 (系统_是否为64位系统 (), 2, 1)
        如果 (位数 == 2)
        {
            注册表枚举键名_ (3, 根节点, 键名组, 假)
            注册表枚举键名_ (3, 根节点, 键名组2, 真)
        }
        否则
        {
            注册表枚举键名_ (3, 根节点, 键名组, 假)
        }
        如果真 (位数 == 2)
        {
            循环 (, 键名组.取成员数 (), i)
            {
                总数 = 键名组2.取成员数 ()
                循环 (, 总数, i2)
                {
                    如果真 (键名组2.取成员 (总数 - i2 - 1) == 键名组.取成员 (i))
                    {
                        键名组2.删除成员 (总数 - i2 - 1)
                    }
                }
            }
        }
        是否64位 = 假
        键名组.枚举循环 ()
        {
            临时名 = 注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "DisplayName", 是否64位)
            如果真 (文本是否为空 (临时名) == 假)
            {
                临时发布 = 注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "Publisher", 是否64位)
                如果真 (查找类似名 (临时发布) == 假 || 文本是否为空 (临时发布))
                {
                    返回的名称.加入成员 (临时名)
                    返回的发布者.加入成员 (临时发布)
                    临时时间 = 注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "InstallDate", 是否64位)
                    如果 (文本是否为空 (临时时间))
                    {
                        返回的安装时间.加入成员 ("")
                    }
                    否则
                    {
                        返回的安装时间.加入成员 (时间_格式化时间 (临时时间, "yyyy/MM/dd"))
                    }
                    临时大小 = 注册表读整数_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "EstimatedSize", 是否64位)
                    如果 (临时大小 > 0)
                    {
                        返回的大小.加入成员 (文件_文件大小转单位 ((长整数)临时大小 * 1024))
                    }
                    否则
                    {
                        返回的大小.加入成员 ("")
                    }
                    返回的版本.加入成员 (注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "DisplayVersion", 是否64位))
                    临时路径 = 注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "DisplayIcon", 是否64位)
                    如果 (文本是否为空 (临时路径))
                    {
                        返回的路径.加入成员 (注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "InstallLocation", 是否64位))
                    }
                    否则
                    {
                        返回的路径.加入成员 (临时路径)
                    }
                    返回的ID.加入成员 (取文本中间_ (注册表读文本_ (3, 根节点 + "\\" + 键名组.取枚举值 (), "UninstallString", 是否64位), "{", "}", , 真))
                }
            }
        }
        是否64位 = 真
        键名组2.枚举循环 ()
        {
            临时名 = 注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "DisplayName", 是否64位)
            如果真 (文本是否为空 (临时名) == 假)
            {
                临时发布 = 注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "Publisher", 是否64位)
                如果真 (查找类似名 (临时发布) == 假 || 文本是否为空 (临时发布))
                {
                    返回的名称.加入成员 (临时名)
                    返回的发布者.加入成员 (临时发布)
                    临时时间 = 注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "InstallDate", 是否64位)
                    如果 (文本是否为空 (临时时间))
                    {
                        返回的安装时间.加入成员 ("")
                    }
                    否则
                    {
                        返回的安装时间.加入成员 (时间_格式化时间 (临时时间, "yyyy/MM/dd"))
                    }
                    临时大小 = 注册表读整数_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "EstimatedSize", 是否64位)
                    如果 (临时大小 > 0)
                    {
                        返回的大小.加入成员 (文件_文件大小转单位 ((长整数)临时大小 * 1024))
                    }
                    否则
                    {
                        返回的大小.加入成员 ("")
                    }
                    返回的版本.加入成员 (注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "DisplayVersion", 是否64位))
                    临时路径 = 注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "DisplayIcon", 是否64位)
                    如果 (文本是否为空 (临时路径))
                    {
                        返回的路径.加入成员 (注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "InstallLocation", 是否64位))
                    }
                    否则
                    {
                        返回的路径.加入成员 (临时路径)
                    }
                    返回的ID.加入成员 (取文本中间_ (注册表读文本_ (3, 根节点 + "\\" + 键名组2.取枚举值 (), "UninstallString", 是否64位), "{", "}", , 真))
                }
            }
        }
        返回 (返回的名称.取成员数 ())
    }

    方法 线程池类2__线程池事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类2_>
    参数 标记值 <类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户参数 <类型 = 长整数>
    参数 用户数据 <类型 = 变整数>
    {
        卸载程序 (集程序名称, 集程序ID)
        返回 (0)
    }

    方法 卸载程序 <折叠>
    参数 程序名称 <类型 = 文本型 注释 = "参数一和二只需要提供一个即可。如果有多个名称相同，则会全部卸载" @默认值 = "">
    参数 程序ID <类型 = 文本型 注释 = "多个名称相同时，可以提供唯一ID，即可只卸载指定项" @默认值 = "">
    {
        变量 模板1 <类型 = 文本型 值 = "wmic product where name=\"名称\" call uninstall" 编辑时信息 = "0, BBB07, 0, 0">
        变量 模板2 <类型 = 文本型 值 = "wmic product where \"identifyingnumber=\'标识号\'\" call uninstall" 编辑时信息 = "0, BBB07, 0, 0">
        变量 脚本 <类型 = 文本型>
        变量 结果 <类型 = 文本型>
        变量 结果2 <类型 = 逻辑型>
        如果 (文本是否为空 (程序名称))
        {
            子文本替换 (模板2, "标识号", 程序ID)
            脚本 = 模板2
        }
        否则
        {
            子文本替换 (模板1, "名称", 程序名称)
            脚本 = 模板1
        }
        运行控制台程序 (脚本, 结果)
        如果 (寻找文本 (结果, "成功") != -1)
        {
            结果2 = 真
            集提示信息 = "卸载成功"
        }
        否则 (寻找文本 (结果, "没有") != -1)
        {
            结果2 = 假
            集提示信息 = "程序不存在"
        }
        否则
        {
            集提示信息 = "卸载成功"
        }
        集结果 = 结果2
        已启动 = 假
    }

    方法 查找类似名 <类型 = 逻辑型 折叠>
    参数 发布名 <类型 = 文本型>
    {
        变量 结果 <类型 = 逻辑型>
        如果真 (集开启过滤 == 假)
        {
            返回 (假)
        }
        集过滤组.枚举循环 ()
        {
            如果真 (寻找文本 (发布名, 集过滤组.取枚举值 (), , 真) != -1)
            {
                结果 = 真
                跳出循环
            }
        }
        返回 (结果)
    }
}

