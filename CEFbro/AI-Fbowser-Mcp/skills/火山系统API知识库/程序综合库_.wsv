    # @end

    方法 信息框_定时 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 提示信息 <类型 = 文本型>
    参数 按钮 <类型 = 整数 @默认值 = 信息框按钮.确认钮>
    参数 窗口标题 <类型 = 文本型 @默认值 = "提示！">
    参数 倒计时 <类型 = 整数 注释 = "单位：秒" @默认值 = 5>
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ KillTimer(NULL,uIDEvent); 
        @ lpText = @<提示信息>;
        @ lpCaption = @<窗口标题>;
        @ Displaytime = @<倒计时>;
        @ uIDEvent = SetTimer(NULL,NULL,1000,(TIMERPROC)&time);
        @ return MessageBoxTimeoutW( (HWND)@<父窗口句柄>,lpText+_T("【 " )+ @an<CVolString> (Displaytime)+_T(" 】秒" ),lpCaption,@<按钮>,NULL,Displaytime*1000);
    }

    方法 信息框_ <公开 静态 类型 = 整数 折叠 @嵌入式方法 = "">
    参数 提示信息 <类型 = 文本型 @默认值 = "">
    参数 按钮 <类型 = 整数 @默认值 = 0>
    参数 窗口标题 <类型 = 文本型 @默认值 = "提示！">
    参数 窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ MessageBox ((HWND)@<窗口句柄>,@<提示信息>,@<窗口标题>,@<按钮>)
    }

    方法 信息框_通用 <公开 静态 类型 = 返回按钮类型 折叠 @嵌入式方法 = "">
    参数 提示信息 <@匹配类型 = 通用基本型 @默认值 = "">
    参数 按钮 <类型 = 整数 @默认值 = 信息框按钮.信息图标>
    参数 窗口标题 <@默认值 = "提示！" @匹配类型 = 通用基本型>
    {
        @ ::MessageBoxW(0, @an<CVolString> (@<提示信息>), @an<CVolString> (@<窗口标题>), @<按钮>)
    }

    方法 信息框_多项 <公开 静态 类型 = 整数 返回值注释 = "返回点击按钮ID，返回2表示关闭" 折叠 折叠2 @视窗.外部头文件 = "CommCtrl.h\r\nstring\r\nvector\r\niostream"
            @视窗.预定义宏 = "WINVER=0x0600,_WIN32_WINNT=0x0600" @禁止流程检查 = 真>
    参数 提示信息 <类型 = 文本型 @默认值 = "温馨提示！">
    参数 提示标题 <类型 = 文本型 @默认值 = "提示！">
    参数 提示内容 <类型 = 文本型 "">
    参数 按钮标题 <类型 = 文本型 注释 = "多个标题请用逗号间隔，标题数就是按钮数，一个标题一个按钮" @默认值 = "确定,取消,重试">
    参数 图标类型 <类型 = 整数 注释 = "0、无  1、提示  2、警告  3、错误  4、盾牌" 编辑时信息 = "5C62B, 0, 0, 0" @默认值 = 1>
    参数 起始ID <类型 = 整数 @默认值 = 1000>
    参数 是否垂直 <类型 = 逻辑型 注释 = "按钮显示方式" @默认值 = 假>
    {
        变量 按钮数量 <类型 = 整数>
        变量 结果组 <类型 = 文本数组类>
        分割文本 (按钮标题, ",", 结果组)
        按钮数量 = 结果组.取成员数 ()
        @ std::vector<std::wstring> textArray;
        结果组.枚举循环 ()
        {
            变量 临时标题 <类型 = 文本型>
            临时标题 = 结果组.取枚举值 ()
            @ textArray.push_back(@<临时标题>.GetText());
        }
        @ PCWSTR tb=0;
        @ if (@<图标类型>==0) { tb=NULL; }
        @ if (@<图标类型>==1) { tb=IDI_INFORMATION; }
        @ if (@<图标类型>==2) { tb=TD_WARNING_ICON; }
        @ if (@<图标类型>==3) { tb=TD_ERROR_ICON; }
        @ if (@<图标类型>==4) { tb=TD_SHIELD_ICON; }
        @ TASKDIALOGCONFIG config = { 0 };
        @ config.cbSize = sizeof(TASKDIALOGCONFIG);
        @ config.hwndParent = NULL;
        @ config.pszWindowTitle = @<提示信息>;
        @ config.pszMainInstruction = @<提示标题>;
        @ config.pszContent = @<提示内容>;
        @ config.pszMainIcon = tb;
        @ int numButtons  =  @<按钮数量>;
        @ TASKDIALOG_BUTTON* pButtons = new TASKDIALOG_BUTTON[numButtons];
        @ for (size_t i = 0; i < textArray.size(); ++i) {
        @ pButtons[i].nButtonID = @<起始ID> + i;
        @  pButtons[i].pszButtonText = textArray[i].c_str();
        @ }
        @ config.pButtons = pButtons;
        @ config.cButtons = @<按钮数量>;
        // @ config.pfCallback = (PFTASKDIALOGCALLBACK)&@<pfCallback>;//hWnd、Msg、wParam、lParam、lpRefData
        @ config.dwCommonButtons = 0;
        @ if(@<是否垂直>) {
        @ config.dwFlags = TDF_ALLOW_DIALOG_CANCELLATION | TDF_USE_COMMAND_LINKS;
        @ } else {
        @ config.dwFlags = TDF_ALLOW_DIALOG_CANCELLATION;
        @ }
        @ int buttonID  =  0;
        @ TaskDialogIndirect(&config, &buttonID, NULL, NULL);
        @ delete[] pButtons;
        @ return buttonID;
    }
}

