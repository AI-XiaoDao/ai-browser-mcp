    方法 窗口_取指定窗口句柄 <公开 静态 类型 = 变整数 返回值注释 = "成功返回窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口标题 <类型 = 文本型 @默认值 = "">
    参数 窗口类名 <类型 = 文本型 @默认值 = "">
    {
        @ HWND hWnd = (HWND)0;
        @ if (@<窗口类名>.GetLength () && @<窗口标题>.GetLength ())
        @ hWnd = FindWindowW(@<窗口类名>.GetText(), @<窗口标题>.GetText());
        @ else if (!@<窗口类名>.GetLength () && !@<窗口标题>.GetLength ())
        @ hWnd = FindWindowW(NULL, NULL);
        @ else if (!@<窗口类名>.GetLength ())
        @ hWnd = FindWindowW(NULL, @<窗口标题>.GetText());
        @ else if (!@<窗口标题>.GetLength ())
        @ hWnd = FindWindowW(@<窗口类名>.GetText(), NULL);
        @ return (INT_PTR)hWnd;
    }

    方法 窗口_取指定窗口句柄2 <公开 静态 类型 = 变整数 注释 = "模糊" 返回值注释 = "成功返回指定窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口标题 <类型 = 文本型 @默认值 = 空对象>
    参数 窗口类名 <类型 = 文本型 @默认值 = 空对象>
    {
        变量 hWnd <类型 = 变整数 值 = 0>
        变量 szTitle <类型 = 文本型>
        @     while (1)
        @     {
        @     @<hWnd> = (INT_P)FindWindowEx(NULL, (HWND)@<hWnd>, NULL, NULL);
        @         if (!@<hWnd>) break; 
        @         TCHAR className[256];
        @         GetClassName((HWND)@<hWnd>, className, sizeof(className) / sizeof(TCHAR));
        @         const TCHAR* partialClassName = @<窗口类名>; 
        @         if (_tcsstr(className, partialClassName))
        @         {
        szTitle = 到小写 (窗口_取窗口组件标题 (hWnd))
        如果 (寻找文本 (szTitle, 到小写 (窗口标题)) != -1)
        {
            返回 (hWnd)
        }
        @             }
        @         }
        返回 (0)
    }

    方法 窗口_取窗口组件句柄 <公开 静态 类型 = 变整数 注释 = "可通过类名或标题等来取得句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口标题 <类型 = 文本型 @默认值 = "">
    参数 窗口类名 <类型 = 文本型 @默认值 = "">
    参数 父窗口句柄 <类型 = 变整数 @默认值 = 0>
    参数 子窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ HWND hWnd = (HWND)0, Parent = (HWND)@<父窗口句柄>, ChildAfter = (HWND)@<子窗口句柄>;
        @ if (@<窗口类名>.GetLength () && @<窗口标题>.GetLength ())
        @ hWnd = FindWindowExW(Parent, ChildAfter, @<窗口类名>.GetText(), @<窗口标题>.GetText());
        @ else if (!@<窗口类名>.GetLength () && !@<窗口标题>.GetLength ())
        @ hWnd = FindWindowExW(Parent, ChildAfter, NULL, NULL);
        @ else if (!@<窗口类名>.GetLength ())
        @ hWnd = FindWindowExW(Parent, ChildAfter, NULL, @<窗口标题>.GetText());
        @ else if (!@<窗口标题>.GetLength ())
        @ hWnd = FindWindowExW(Parent, ChildAfter, @<窗口类名>.GetText(), NULL);
        @ return (INT_PTR)hWnd;
    }

