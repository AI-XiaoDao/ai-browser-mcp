类 提示信息框类_ <公开 折叠 @文档 = "category = \"程序综合库.气球提示\"">
{
    变量 句柄 <类型 = 变整数>
    变量 句柄组 <类型 = 变整数数组类>

    方法 类_清理 <折叠>
    {
        取消所有提示 ()
    }

    方法 初始化 <类型 = 变整数 折叠>
    {
        @ HWND hwndTip = CreateWindowEx(NULL,TOOLTIPS_CLASS,NULL,  WS_POPUP |TTS_BALLOON | TTS_ALWAYSTIP,CW_USEDEFAULT,CW_USEDEFAULT,CW_USEDEFAULT,CW_USEDEFAULT,NULL,NULL,GetModuleHandleA(NULL),NULL);
        @ SetWindowPos(hwndTip, HWND_TOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE);
        @ @<句柄>= (@dt<变整数>)hwndTip;
        返回 (句柄)
    }

    方法 添加提示 <公开 折叠>
    参数 控件句柄 <类型 = 变整数 注释 = "绑定该控件的句柄">
    参数 提示文本 <类型 = 文本型>
    参数 提示标题 <类型 = 文本型 @默认值 = "提示！">
    参数 提示图标 <类型 = 整数 注释 = "0、无图标 1、信息 2、警告 3、错误" @默认值 = 1>
    参数 最大宽度 <类型 = 整数 @默认值 = 500>
    {
        变量 创建句柄 <类型 = 变整数>
        创建句柄 = 初始化 ()
        句柄组.加入成员 (创建句柄)
        @ RECT rect; 
        @ TOOLINFO tti;
        @ tti.cbSize  = sizeof(TOOLINFO);
        @ tti.uFlags  = TTF_SUBCLASS;
        @ tti.uId     = (UINT_PTR)GetDlgCtrlID((HWND)@<控件句柄>);
        @ tti.hwnd    = (HWND)@<控件句柄>;
        @ tti.hinst   = NULL;
        @ GetClientRect((HWND)@<控件句柄>, &rect);
        @ rect.right = rect.left + @<最大宽度>; 
        @ rect.bottom = rect.top + 100; 
        @ tti.rect = rect;
        @ tti.lpszText = (LPWSTR)@<提示文本>.GetText();
        @ SendMessageW((HWND)@<创建句柄>, TTM_SETMAXTIPWIDTH, 0, (LPARAM)@<最大宽度>); 
        @ SendMessageW ((HWND)@<创建句柄>, TTM_SETTITLEA, @<提示图标>,(LPARAM)GetMbsText(@<提示标题>.GetText(), CVolMem(), NULL));
        @ SendMessageW((HWND)@<创建句柄>, TTM_ADDTOOL, 0, (LPARAM)&tti);
    }

    方法 添加提示2 <公开 折叠 @禁止流程检查 = 真>
    参数 控件句柄 <类型 = 变整数 注释 = "绑定该控件的句柄">
    参数 提示文本 <类型 = 文本型>
    参数 最大宽度 <类型 = 整数 @默认值 = 500>
    {
        @ HWND hwndTT = CreateWindowEx(WS_EX_TOPMOST, TOOLTIPS_CLASS, NULL,
        @                              WS_POPUP | TTS_NOPREFIX | TTS_ALWAYSTIP,
        @                              CW_USEDEFAULT, CW_USEDEFAULT, CW_USEDEFAULT, CW_USEDEFAULT,
        @                              (HWND)@<控件句柄>, NULL, GetModuleHandleW(NULL), NULL);
        @ SetWindowPos(hwndTT, HWND_TOPMOST, 0, 0, 0, 0,
        @              SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE);
        @ TOOLINFO ti = { 0 };
        @ ti.cbSize   = sizeof(TOOLINFO);
        @ ti.uFlags   = TTF_SUBCLASS;
        @ ti.hwnd     = (HWND)@<控件句柄>;
        @ ti.hinst    = GetModuleHandleW(NULL);
        @ ti.lpszText = (LPTSTR)@<提示文本>.GetText();
        @ GetClientRect((HWND)@<控件句柄>, &ti.rect);
        @ SendMessage(hwndTT, TTM_SETMAXTIPWIDTH, 0, (LPARAM)@<最大宽度>); 
        @ SendMessage(hwndTT, TTM_ADDTOOL, 0, (LPARAM)(LPTOOLINFO)&ti);
    }

    方法 取消提示 <公开 注释 = "不支持添加提示2" 折叠>
    参数 控件句柄 <类型 = 变整数>
    {
        @ TOOLINFO tti;
        @ tti.cbSize  = sizeof(TOOLINFO);
        @ tti.uFlags  =TTF_SUBCLASS;
        @ tti.uId   = (UINT_PTR)GetDlgCtrlID((HWND)@<控件句柄>);
        @ tti.hwnd=(HWND)@<控件句柄>;
        @ tti.hinst  = NULL;
        @ SendMessageW((HWND)@<句柄>, TTM_DELTOOL, 0, (LPARAM) &tti);
    }

    方法 取消所有提示 <公开 注释 = "不支持添加提示2" 折叠>
    {
        计次循环 (句柄组.取成员数 ())
        {
            句柄 = 句柄组.取成员 (取循环索引 ())
            取消提示 (句柄组.取成员 (取循环索引 ()))
            清除 ()
        }
    }

    方法 清除 <折叠>
    {
        @ DestroyWindow ((HWND)@<句柄>);
        句柄 = 0
    }
}

类 气球提示信息类_ <公开 折叠 @文档 = "category = \"程序综合库.气球提示\"">
{
    变量 时钟1 <类型 = 时钟类_>
