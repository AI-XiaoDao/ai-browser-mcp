类 全局共享变量类_ <公开 注释 = "用于在同一程序内，跨窗、跨类交互操作，包括支持DLL。实现全局变量共享传递" 折叠 折叠2 @文档 = "category = \"程序综合库.共享变量\"" @全局类 = 真>
{
    变量 变量组 <静态 类型 = 共享变量组类>
    变量 内存 <静态 类型 = 共享内存类_>
    变量 互斥 <静态 类型 = 许可锁类_>

    方法 类_清理 <折叠>
    {
        内存.释放句柄_ ()
        变量组.删除所有成员 ()
    }

    方法 全局_保存变量体 <公开 静态 注释 = "写入共享变量中，会覆盖原变量数据" 折叠>
    参数 标识 <类型 = 整数 注释 = "用于记录识别是哪个变量">
    参数 变量指针 <类型 = 变整数 注释 = "“取变量地址 (变量)” 或 “取数据指针_ (变量)”所返回的地址">
    {
        变量 数据地址 <类型 = 变整数>
        变量 共享地址 <类型 = 变整数>
        变量 变量类 <类型 = 共享变量结构类>
        变量 变量类2 <类型 = 共享变量结构类>
        变量 i <类型 = 整数>
        互斥.加锁 ()
        变量组.枚举循环 ()
        {
            如果真 (变量组.取枚举值 ().标识 == 标识)
            {
                i = 共享变量组类.取枚举索引 ()
                数据地址 = 变量组.取枚举值 ().数据地址
                共享地址 = 变量组.取枚举值 ().共享地址
                内存.释放句柄2_ (共享地址)
                变量组.删除成员 (i)
                跳出循环
            }
        }
        共享地址 = 内存.写共享数据2_ (到文本 (标识), 到字节集 (变量指针))
        变量类.标识 = 标识
        变量类.数据地址 = 数据地址
        变量类.共享地址 = 共享地址
        变量组.加入成员 (变量类)
        互斥.解锁 ()
    }

    方法 全局_读取变量体 <公开 静态 类型 = 变整数 注释 = "读取共享变量" 返回值注释 = "返回的地址再通过“读指针处对象 (地址, 变量类型)” 或 “指针到数据_ (地址, 变量类型)”还原成变量结构."
            返回值注释 = "注意：指针数据转换过来后，不要直接赋值给原变量" 折叠>
    参数 标识 <类型 = 整数 注释 = "与“保存变量体_”中的标识一致">
    {
        变量 数据块 <类型 = 字节集类>
        变量 指针 <类型 = 变整数>
        互斥.加锁 ()
        数据块 = 内存.读共享数据_ (到文本 (标识))
        指针 = 取字节集数据 (数据块, , 变整数)
        如果真 (数据块.取字节集长度 () > 0 && 指针 > 0 && 指针是否有效_ (指针))
        {
            互斥.解锁 ()
            返回 (指针)
        }
        互斥.解锁 ()
        返回 (-1)
    }

    方法 全局_释放变量体 <公开 静态 类型 = 逻辑型 折叠>
    参数 标识 <类型 = 整数 注释 = "与“保存变量体_”中的标识一致">
    {
        变量 共享地址 <类型 = 变整数>
        变量 结果 <类型 = 逻辑型>
        变量 i <类型 = 整数>
        互斥.加锁 ()
        变量组.枚举循环 ()
        {
            如果真 (变量组.取枚举值 ().标识 == 标识)
            {
                i = 共享变量组类.取枚举索引 ()
                共享地址 = 变量组.取枚举值 ().共享地址
                内存.释放句柄2_ (共享地址)
                变量组.删除成员 (i)
                结果 = 真
                跳出循环
            }
        }
        互斥.解锁 ()
        返回 (结果)
    }

    方法 全局_释放所有变量体 <公开 静态 折叠>
    {
        互斥.加锁 ()
        变量组.删除所有成员 ()
        内存.释放句柄_ ()
        互斥.解锁 ()
    }
}

类 共享变量组类 <公开 基础类 = 对象数组模板类 折叠2 @文档 = "category = \"程序综合库.共享变量.附加类\"" @模板实现类 = "共享变量结构类">

类 共享变量结构类 <折叠 @文档 = "category = \"程序综合库.共享变量.附加类\"">
{
    变量 标识 <公开 类型 = 整数>
    变量 数据地址 <公开 类型 = 变整数>
    变量 共享地址 <公开 类型 = 变整数>
}

