类 坐标句柄类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.屏幕坐标句柄\"" @全局类 = 真>
{
    方法 坐标_用户区坐标转屏幕坐标 <公开 静态 类型 = 逻辑型 注释 = "将指定客户区的坐标点转换为整个屏幕的坐标" 折叠 折叠2 @输出名 = "ClientToScreen" @视窗.输入 = "user32">
    参数 句柄 <类型 = 变整数 注释 = "该窗口句柄">
    参数 返回的坐标值 <类型 = 控件坐标值_ 注释 = "坐标数据" @视窗.输出参数 = 真>

    方法 坐标_屏幕坐标转用户区坐标 <公开 静态 类型 = 逻辑型 注释 = "将屏幕上指定点的屏幕坐标转换成用户区坐标" 折叠 折叠2 @输出名 = "ScreenToClient" @视窗.输入 = "user32">
    参数 句柄 <类型 = 变整数>
    参数 返回的坐标值 <类型 = 控件坐标值_ @视窗.输出参数 = 真>

    方法 鼠标_取鼠标位置 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 返回的坐标值 <类型 = 控件坐标值_>
    {
        @ POINT pt;
        @ BOOL bReturn = GetCursorPos(&pt);
        @ if (bReturn != 0)
        @ {
        @    @<返回的坐标值.横向位置>=pt.x;
        @    @<返回的坐标值.纵向位置>=pt.y;
        @ }
    }

    方法 窗口_取鼠标处窗口句柄 <公开 静态 类型 = 变整数 注释 = "支持外部窗口" 折叠 @禁止流程检查 = 真>
    {
        @ POINT pt;
        @ GetCursorPos(&pt);
        @ return (INT_PTR)WindowFromPoint(pt);
    }

    方法 窗口_取指定坐标处窗口句柄 <公开 静态 类型 = 变整数 注释 = "支持外部窗口" 折叠 @禁止流程检查 = 真>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    {
        @ POINT pt;
        @ pt.x = @<横坐标>;
        @ pt.y = @<纵坐标>;
        @ return (INT_PTR)WindowFromPoint(pt);
    }

    方法 窗口_取鼠标处窗口边界矩形 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "窗口_取鼠标处窗口句柄 ()">
    参数 返回的矩形值 <类型 = 矩形类>
    {
        @ RECT rc;
        @ BOOL bReturn = GetWindowRect((HWND)@<窗口句柄>,&rc);
        @ @<返回的矩形值.左边>=rc.left;
        @ @<返回的矩形值.顶边>=rc.top;
        @ @<返回的矩形值.右边>=rc.right;
        @ @<返回的矩形值.底边>=rc.bottom;
    }
}

