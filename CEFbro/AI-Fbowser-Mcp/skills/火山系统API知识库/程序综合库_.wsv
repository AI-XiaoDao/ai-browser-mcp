类 软件程序类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.程序操作\"" @全局类 = 真>
{
    方法 程序_QQ号是否存在 <公开 静态 类型 = 逻辑型 注释 = "检测指定QQ号是否已登录在电脑上，不论在线还是离线均可检测" 返回值注释 = "存在返回真" 折叠>
    参数 QQ号码 <类型 = 文本型>
    {
        变量 QQ <类型 = 文本数组类>
        变量 结果 <类型 = 逻辑型>
        QQ = 程序_取所有QQ号 ()
        QQ.枚举循环 ()
        {
            如果真 (QQ.取枚举值 () == QQ号码)
            {
                结果 = 真
                跳出循环
            }
        }
        返回 (结果)
    }

    方法 程序_取所有QQ号 <公开 静态 类型 = 文本数组类 注释 = "只要是登录在电脑的QQ，不论在线还是离线均会被取出" 折叠>
    {
        变量 信息组 <类型 = 窗口信息组_>
        变量 临时名 <类型 = 文本型>
        变量 QQ <类型 = 文本数组类>
        变量 i <类型 = 整数>
        窗口_枚举窗口2 (信息组)
        信息组.窗口标题.枚举循环 ()
        {
            临时名 = 信息组.窗口标题.取枚举值 ()
            如果真 (临时名 != "")
            {
                如果真 (取文本左边 (临时名, 2) == "QQ")
                {
                    临时名 = 取文本中间_ (临时名, "QQ_", "_")
                    如果真 (取文本长度 (临时名) > 4)
                    {
                        QQ.加入成员 (临时名)
                    }
                }
            }
        }
        如果真 (QQ.取成员数 () == 0)
        {
            循环 (500, 6000000, i)
            {
                如果 (窗口_窗口句柄是否有效 (i))
                {
                    临时名 = 窗口_取窗口组件类名 (i)
                    如果真 (取文本左边 (临时名, 11) == "NTQQOpenSdk")
                    {
                        临时名 = 取文本右边2_ (窗口_取窗口组件类名 (i), "_", , )
                        如果真 (取文本长度 (临时名) > 4)
                        {
                            QQ.加入成员 (临时名)
                        }
                    }
                }
            }
        }
        返回 (QQ)
    }

    方法 创建快捷方式_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 程序路径 <类型 = 文本型 注释 = "待创建快捷方式的程序来源，例如：“C:\\\\程序.exe”">
    参数 lnk路径 <类型 = 文本型 注释 = "即快捷方式路径，例如：取桌面路径_ () + \"程序.lnk\"">
    参数 图标路径 <类型 = 文本型 注释 = "例如：“C:\\\\图标.ico”" @默认值 = "">
    参数 备注 <类型 = 文本型 注释 = "提供对应此快捷方式的描述文本信息" @默认值 = "">
    参数 命令行 <类型 = 文本型 @默认值 = "">
    参数 起始位置 <类型 = 文本型 @默认值 = "">
    {
        变量 szDir <类型 = 文本型>
        变量 快捷键 <类型 = 短整数 值 = 0>
        变量 运行方式 <类型 = 整数 值 = 0>
        @ HRESULT hr;
        @ IShellLinkW* pSL;
        @ IPersistFile* pPF;
        @ BOOL bRes = FALSE;
        @ hr = CoInitialize(NULL);
        @ hr = CoCreateInstance(CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER, IID_IShellLinkW, (void**)&pSL);
        @ if (hr == S_OK && pSL)
        @ {
        @     hr = pSL->QueryInterface(IID_IPersistFile, (void **)&pPF);
        @     if (hr == S_OK && pPF)
        @     {
        @         hr = pSL->SetPath(@<程序路径>.GetText());
        @         if (!@<起始位置>.IsEmpty())
        @             hr = pSL->SetWorkingDirectory(@<起始位置>.GetText());
        @         else
        @         {
        szDir = 取文本左边_ (程序路径, "\\", -1)
        @             hr = pSL->SetWorkingDirectory(@<szDir>.GetText());
        @         }
        @         if (!@<命令行>.IsEmpty())
        @             hr = pSL->SetArguments(@<命令行>.GetText());
        @         if (!@<图标路径>.IsEmpty())
        @             hr = pSL->SetIconLocation(@<图标路径>.GetText(), 0);
        @         if (!@<快捷键>)
        @             hr = pSL->SetHotkey((WORD)@<快捷键>);
        @         if (!@<运行方式>)
        @             hr = pSL->SetShowCmd(SW_SHOWNORMAL);
        @         else
        @             hr = pSL->SetShowCmd(@<运行方式>);
        @         if (!@<备注>.IsEmpty())
        @             hr = pSL->SetDescription(@<备注>.GetText());
        @         hr = pPF->Save(@<lnk路径>.GetText(), FALSE);
        @         bRes = hr == S_OK;
        @         pPF->Release();
        @     }
        @     pSL->Release();
        @ }
        @ CoUninitialize();
        @ return bRes;
    }

    方法 程序_创建快捷方式 <公开 类型 = 逻辑型 折叠>
    参数 程序路径 <类型 = 文本型 注释 = "待创建快捷方式的程序来源，例如：“C:\\\\程序.exe”">
    参数 lnk路径 <类型 = 文本型 注释 = "即快捷方式路径，例如：取桌面路径_ () + \"程序.lnk\"">
    参数 图标路径 <类型 = 文本型 注释 = "例如：“C:\\\\图标.ico”" @默认值 = "">
    参数 备注 <类型 = 文本型 注释 = "提供对应此快捷方式的描述文本信息" @默认值 = "">
    参数 命令行 <类型 = 文本型 @默认值 = "">
    参数 起始位置 <类型 = 文本型 @默认值 = "">
    {
        返回 (创建快捷方式_ (程序路径, lnk路径, 图标路径, 备注, 命令行, 起始位置))
    }

    方法 执行_ <公开 静态 折叠 @嵌入式方法 = "">
    参数 文件名称 <类型 = 文本型>
    {
        @ ::ShellExecute (NULL, _T ("open"),@<文件名称>.GetText (), NULL, NULL, SW_SHOW);
    }

    方法 文件_打开文件目录 <公开 静态 注释 = "支持打开目录或文件" 折叠>
    参数 指定目录 <类型 = 文本型>
    {
        @  ShellExecute( NULL, _T("open"), (LPCTSTR)@<指定目录>, NULL, NULL, SW_SHOWNORMAL );
    }

    方法 系统_置程序兼容性 <公开 静态 类型 = 逻辑型 注释 = "相当于程序右键属性设置" 折叠>
    参数 程序路径 <类型 = 文本型 注释 = "例如：“C:\\\\程序.exe”">
    参数 兼容模式 <类型 = 整数 注释 = "兼容系统版本：0、95 1、98 2、NT4 3、2000 4、xpsp2 5、xpsp3 6、vista 7、vistasp1 8、vistasp2 9、win7 10、win8"
            @默认值 = -1>
    参数 简化颜色模式 <类型 = 整数 注释 = "0、8位 1、16位" @默认值 = -1>
    参数 用640X480分辨率运行 <类型 = 逻辑型 @默认值 = 假>
    参数 禁用全屏优化 <类型 = 逻辑型 @默认值 = 假>
    参数 管理员身份运行 <类型 = 逻辑型 @默认值 = 假>
    参数 注册此程序以重新启动 <类型 = 逻辑型 注释 = "如果程序在运行至少1分钟后崩了，然后会自动重启" @默认值 = 假>
    参数 启用此程序以使用onedrive文件 <类型 = 逻辑型 @默认值 = 假>
    参数 程序DPI <类型 = 整数
            注释 = "0、已登陆到windows系统，1、打开此程序。win10：口使用此设置修复此程序的缩放问题，而不是“设置”中的缩放问题。如果在登录到Windows之后主显示器的DPI发生更改，则程序可能看起来较模糊。Windows可以根据你在打开此程序时为主显示器设置的DPI,尝试修复该程序的缩放问题"
            @默认值 = -1>
    参数 代替高DPI缩放行为 <类型 = 整数 注释 = "0、应用程序 1、系统 2、系统增强（win7丶win8和旧版win10选0）" @默认值 = -1>
    参数 使用旧版显示器ICC颜色管理 <类型 = 逻辑型 注释 = "win11功能" @默认值 = 假>
    参数 更改所有用户的设置 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 兼容版本 <类型 = 文本型 折叠>
        变量 颜色模式 <类型 = 文本型>
        变量 DPI设置 <类型 = 文本型>
        变量 DPI缩放 <类型 = 文本型>
        变量 分辨率运行 <类型 = 文本型>
        变量 禁用优化 <类型 = 文本型>
        变量 管理员运行 <类型 = 文本型>
        变量 重新启动 <类型 = 文本型>
        变量 颜色管理 <类型 = 文本型>
        变量 使用onedrive <类型 = 文本型>
        进程_进程提权 ()
        如果真 (兼容模式 > -1)
        {
            兼容版本 = 多项选择 (兼容模式, "WIN95 ", "WIN98 ", "NT4SP5 ", "WIN2000 ", "WINXPSP2 ", "WINXPSP3 ", "VISTARTM ", "VISTASP1 ", "VISTASP2 ", "WIN7RTM ", "WIN8RTM ")
        }
        如果真 (简化颜色模式 > -1)
        {
            颜色模式 = 多项选择 (简化颜色模式, "256COLOR ", "16BITCOLOR ")
        }
        分辨率运行 = 选择 (用640X480分辨率运行, "640X480 ", "")
        禁用优化 = 选择 (禁用全屏优化, "DISABLEDXMAXIMIZEDWINDOWEDMODE ", "")
        管理员运行 = 选择 (管理员身份运行, "RUNASADMIN ", "")
        如果真 (代替高DPI缩放行为 > -1)
        {
            DPI缩放 = 多项选择 (代替高DPI缩放行为, "HIGHDPIAWARE ", "DPIUNAWARE ", "GDIDPISCALING DPIUNAWARE ")
        }
        如果真 (程序DPI > -1)
        {
            DPI设置 = 多项选择 (程序DPI, "PERPROCESSSYSTEMDPIFORCEOFF ", "PERPROCESSSYSTEMDPIFORCEON ")
        }
        使用onedrive = 选择 (启用此程序以使用onedrive文件, "PLACEHOLDERFILES ", "")
        重新启动 = 选择 (注册此程序以重新启动, "REGISTERAPPRESTART ", "")
        颜色管理 = 选择 (使用旧版显示器ICC颜色管理, "TRANSFORMLEGACYCOLORMANAGED ", "")
        如果 (更改所有用户的设置)
        {
            注册表删除键值_ (2, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, 为64位程序 ())
            返回 (注册表写文本_ (3, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, "~ " + 兼容版本 + 颜色模式 + 分辨率运行 + 禁用优化 + 管理员运行 + DPI缩放 + DPI设置 + 使用onedrive + 重新启动 + 颜色管理, 为64位程序 ()))
        }
        否则
        {
            注册表删除键值_ (3, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, 为64位程序 ())
            返回 (注册表写文本_ (2, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, "~ " + 兼容版本 + 颜色模式 + 分辨率运行 + 禁用优化 + 管理员运行 + DPI缩放 + DPI设置 + 使用onedrive + 重新启动 + 颜色管理, 为64位程序 ()))
        }
    }

    方法 系统_取程序兼容性 <公开 静态 类型 = 逻辑型 注释 = "相当于取出程序右键属性设置" 折叠>
    参数 程序路径 <类型 = 文本型 注释 = "例如：“C:\\\\程序.exe”">
    参数 返回的兼容模式 <类型 = 整数类
            注释 = "兼容系统版本：默认-1； 0、95 1、98 2、NT4 3、2000 4、xpsp2 5、xpsp3 6、vista 7、vistasp1 8、vistasp2 9、win7 10、win8" @默认值 = 空对象>
    参数 返回的简化颜色模式 <类型 = 整数类 注释 = "默认-1； 0、8位 1、16位" @默认值 = 空对象>
    参数 返回的用640X480分辨率运行 <类型 = 逻辑型类 @默认值 = 空对象>
    参数 返回的禁用全屏优化 <类型 = 逻辑型类 @默认值 = 空对象>
    参数 返回的管理员身份运行 <类型 = 逻辑型类 @默认值 = 空对象>
    参数 返回的注册此程序以重新启动 <类型 = 逻辑型类 注释 = "如果程序在运行至少1分钟后崩了，然后会自动重启" @默认值 = 空对象>
    参数 返回的启用此程序以使用onedrive文件 <类型 = 逻辑型类 @默认值 = 空对象>
    参数 返回的程序DPI <类型 = 整数类
            注释 = "默认-1； 0、已登陆到windows系统，1、打开此程序。win10：口使用此设置修复此程序的缩放问题，而不是“设置”中的缩放问题。如果在登录到Windows之后主显示器的DPI发生更改，则程序可能看起来较模糊。Windows可以根据你在打开此程序时为主显示器设置的DPI,尝试修复该程序的缩放问题"
            @默认值 = 空对象>
    参数 返回的代替高DPI缩放行为 <类型 = 整数类 注释 = "默认-1； 0、应用程序 1、系统 2、系统增强（win7丶win8和旧版win10选0）" @默认值 = 空对象>
    参数 返回的使用旧版显示器ICC颜色管理 <类型 = 逻辑型类 @默认值 = 空对象>
    {
        变量 结果 <类型 = 文本型 编辑时信息 = "0, 8BB0A, 0, 0">
        变量 兼容版本 <类型 = "文本型 []"
                值 = {"WIN95", "WIN98", "NT4SP5", "WIN2000", "WINXPSP2", "WINXPSP3", "VISTARTM", "VISTASP1", "VISTASP2", "WIN7RTM", "WIN8RTM"}
                编辑时信息 = "0, 8BB0A, 0, 0">
        变量 临时版本 <类型 = 整数 值 = -1>
        变量 颜色模式 <类型 = 整数 值 = -1 编辑时信息 = "0, 8BB0A, 0, 0">
        变量 DPI设置 <类型 = 整数 值 = -1 编辑时信息 = "0, 8BB0A, 0, 0">
        变量 DPI缩放 <类型 = 整数 值 = -1 编辑时信息 = "0, 8BB0A, 0, 0">
        进程_进程提权 ()
        结果 = 注册表读文本_ (3, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, 为64位程序 ())
        如果 (结果 == "")
        {
            结果 = 注册表读文本_ (2, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers", 程序路径, 为64位程序 ())
        }
        计次循环 (取数组成员数 (兼容版本))
        {
            如果真 (寻找文本 (结果, 兼容版本 [取循环索引 ()], , 真) != -1)
            {
                临时版本 = 取循环索引 ()
                跳出循环
            }
        }
        返回的兼容模式.值 = 临时版本
        如果 (寻找文本 (结果, "256COLOR", , 真) != -1)
        {
            颜色模式 = 0
        }
        否则 (寻找文本 (结果, "16BITCOLOR", , 真) != -1)
        {
            颜色模式 = 1
        }
        返回的简化颜色模式.值 = 颜色模式
        如果真 (寻找文本 (结果, "640X480", , 真) != -1)
        {
            返回的用640X480分辨率运行.值 = 真
        }
        如果真 (寻找文本 (结果, "DISABLEDXMAXIMIZEDWINDOWEDMODE", , 真) != -1)
        {
            返回的禁用全屏优化.值 = 真
        }
        如果真 (寻找文本 (结果, "RUNASADMIN", , 真) != -1)
        {
            返回的管理员身份运行.值 = 真
        }
        如果真 (寻找文本 (结果, "REGISTERAPPRESTART", , 真) != -1)
        {
            返回的注册此程序以重新启动.值 = 真
        }
        如果真 (寻找文本 (结果, "PLACEHOLDERFILES", , 真) != -1)
        {
            返回的启用此程序以使用onedrive文件.值 = 真
        }
        如果 (寻找文本 (结果, "PERPROCESSSYSTEMDPIFORCEOFF", , 真) != -1)
        {
            DPI设置 = 0
        }
        否则 (寻找文本 (结果, "PERPROCESSSYSTEMDPIFORCEON", , 真) != -1)
        {
            DPI设置 = 1
        }
        返回的程序DPI.值 = DPI设置
        如果 (寻找文本 (结果, "GDIDPISCALING DPIUNAWARE", , 真) != -1)
        {
            DPI缩放 = 2
        }
        否则 (寻找文本 (结果, "HIGHDPIAWARE", , 真) != -1)
        {
            DPI缩放 = 0
        }
        否则 (寻找文本 (结果, "DPIUNAWARE", , 真) != -1)
        {
            DPI缩放 = 1
        }
        返回的代替高DPI缩放行为.值 = DPI缩放
        如果真 (寻找文本 (结果, "TRANSFORMLEGACYCOLORMANAGED", , 真) != -1)
        {
            返回的使用旧版显示器ICC颜色管理.值 = 真
        }
        返回 (结果 != "")
    }

    方法 系统_以管理员身份运行 <公开 静态 类型 = 逻辑型 注释 = "以管理员身份运行指定程序" 折叠 @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 是否隐藏 <类型 = 逻辑型 @默认值 = 真>
    {
        @ SHELLEXECUTEINFOW ExecInfo;
        @ memset(&ExecInfo,0,sizeof(SHELLEXECUTEINFOW));
        @ ExecInfo.cbSize = sizeof(SHELLEXECUTEINFOW);
        @ ExecInfo.lpFile = @<文件路径>.GetText();
        @ ExecInfo.lpVerb = L"runas";
        @ ExecInfo.fMask = SEE_MASK_NO_CONSOLE;
        如果 (是否隐藏)
        {
            @ ExecInfo.nShow = SW_HIDE;
        }
        否则
        {
            @ ExecInfo.nShow = SW_SHOWDEFAULT;
        }
        @ if(ShellExecuteExW(&ExecInfo))
        @ {
        @ if(ExecInfo.hProcess)
        @ WaitForSingleObject(ExecInfo.hProcess,INFINITE);
        @ return TRUE;
        @ }
        @ return FALSE;
    }

    方法 系统_是否为管理员模式运行 <公开 静态 类型 = 逻辑型 注释 = "判断当前程序是否在管理员模式下运行" 折叠 @禁止流程检查 = 真>
    {
        @ typedef BOOL(WINAPI* IsNTAdmin)(DWORD, DWORD);
        @ BOOL hr;
        @ HINSTANCE hModule = LoadLibraryW(L"advpack.dll");
        @ if (!hModule) return false;
        @ IsNTAdmin pfnIsNTAdmin = (IsNTAdmin)GetProcAddress(hModule, "IsNTAdmin");
        @ hr = pfnIsNTAdmin(0, 0);
        @ FreeLibrary(hModule);
        @ return hr;
    }

    方法 系统_是否为管理员模式运行2 <公开 静态 类型 = 逻辑型 注释 = "判断指定程序是否在管理员模式下运行" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 @默认值 = 0>
    {
        @ BOOL isAdmin = FALSE;
        @ HANDLE hProcess;
        @ if (@<进程ID> <= 0)
        @     hProcess = GetCurrentProcess();
        @ else
        @     hProcess = OpenProcess(PROCESS_QUERY_INFORMATION, 0, @<进程ID>);
        @ if (hProcess)
        @ {
        @     HANDLE hToken;
        @     if (OpenProcessToken(hProcess, TOKEN_QUERY, &hToken))
        @     {
        @         SID_IDENTIFIER_AUTHORITY pAuthority = SECURITY_NT_AUTHORITY;
        @         PSID psidAdmin;
        @         if (AllocateAndInitializeSid(&pAuthority, 2, SECURITY_BUILTIN_DOMAIN_RID, DOMAIN_ALIAS_RID_ADMINS, 0, 0, 0, 0, 0, 0, &psidAdmin))
        @         {
        @             DWORD dwCount = 0;
        @             GetTokenInformation(hToken, TokenGroups, NULL, 0, &dwCount);
        @             TOKEN_GROUPS* pTokenGroups = (TOKEN_GROUPS*)malloc(dwCount);
        @             GetTokenInformation(hToken, TokenGroups, pTokenGroups, dwCount, &dwCount);
        @             for (DWORD i = 0; i < pTokenGroups->GroupCount; i++)
        @             {
        @                 if (EqualSid(psidAdmin, pTokenGroups->Groups[i].Sid))
        @                 {
        @                     isAdmin = ((pTokenGroups->Groups[i].Attributes & SE_GROUP_USE_FOR_DENY_ONLY) != SE_GROUP_USE_FOR_DENY_ONLY);
        @                     break;
        @                 }
        @             }
        @             free(pTokenGroups);
        @             FreeSid(psidAdmin);
        @         }
        @         CloseHandle(hToken);
        @     }
        @     CloseHandle(hProcess);
        @ }
        @ return isAdmin;
    }

    方法 程序_取程序版本信息 <公开 静态 类型 = 版本信息类_ 注释 = "返回 版本信息类_" 返回值注释 = "返回程序的版本信息,失败返回空对象" 折叠 折叠2 @视窗.外部库 = "Version.lib" @禁止流程检查 = 真>
    参数 文件来源 <类型 = 文本型 注释 = "包含完整路径文件名">
    {
        变量 版本信息 <类型 = 版本信息类_>
        @ DWORD bufSize = GetFileVersionInfoSizeW (@<文件来源>, 0);
        @ if (bufSize == 0) return @<版本信息>;
        @ BYTE* buffer = new BYTE[bufSize];
        @ ZeroMemory (buffer, bufSize);
        @ if (GetFileVersionInfoW (@<文件来源>, 0, bufSize, buffer) == 0) {
        @     if (buffer != NULL) delete[] buffer;
        @     buffer = NULL;
        @     return @<版本信息>;
        @ }
        @ struct LANGANDCODEPAGE {
        @     WORD wLanguage;
        @     WORD wCodePage;
        @ } *lpTranslate;
        @ void* data_ptr;
        @ UINT cbTranslate, data_len;
        @ if (VerQueryValueW (buffer, _T ("\\VarFileInfo\\Translation"), (LPVOID*)&lpTranslate, &cbTranslate)) {
        @     for (int i = 0; i < (cbTranslate / sizeof (struct LANGANDCODEPAGE)); i++)
        @     {
        @         WCHAR fp_key[MAX_PATH] = {0};
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\Comments"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.注释> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\CompanyName"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.公司名称> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\FileDescription"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.文件说明> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\FileVersion"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.文件版本> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\InternalName"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.内部名称> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\LegalCopyright"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.版权> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\LegalTrademarks"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.法律商标> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\OriginalFilename"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.原始文件名> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\ProductName"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.产品名称> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\ProductVersion"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.产品版本> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\PrivateBuild"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.私有版本> = (const WCHAR*)data_ptr;
        @         wsprintf (fp_key, _T ("\\StringFileInfo\\%04x%04x\\SpecialBuild"), lpTranslate[i].wLanguage, lpTranslate[i].wCodePage);
        @         if (VerQueryValueW (buffer, fp_key, &data_ptr, &data_len)) @<版本信息.特殊版本> = (const WCHAR*)data_ptr;
        @         break; 
        @     }
        @ }
        @ if (buffer != NULL) delete[] buffer;
        @ buffer = NULL;
        @ return @<版本信息>;
    }

    方法 文件_取文件时间 <公开 静态 类型 = 逻辑型 注释 = "取文件的创建、修改、访问时间" 折叠 @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 返回的文件创建时间 <类型 = 文本型 @默认值 = "">
    参数 返回的文件修改时间 <类型 = 文本型 @默认值 = "">
    参数 返回的文件访问时间 <类型 = 文本型 @默认值 = "">
    {
        变量 DateStr <类型 = 文本型>
        变量 TimeStr <类型 = 文本型>
        @ HANDLE hFile = CreateFileW(@<文件路径>.GetText(), FILE_FLAG_WRITE_THROUGH, FILE_SHARE_READ, NULL, OPEN_EXISTING, 0, NULL);
        @ if (hFile == INVALID_HANDLE_VALUE) return false;
        @ FILETIME CreationTime, LastAccessTime, LastWriteTime;
        @ BOOL bRes = GetFileTime(hFile, &CreationTime, &LastAccessTime, &LastWriteTime);
        @ FILETIME CreationFileTime, LastAccessFileTime, LastWriteFileTime;
        @ FileTimeToLocalFileTime(&CreationTime, &CreationFileTime);
        @ FileTimeToLocalFileTime(&LastAccessTime, &LastAccessFileTime);
        @ FileTimeToLocalFileTime(&LastWriteTime, &LastWriteFileTime);
        @ SYSTEMTIME CreationSystemTime, LastAccessSystemTime, LastWriteSystemTime;
        @ FileTimeToSystemTime(&CreationFileTime, &CreationSystemTime);
        @ FileTimeToSystemTime(&LastAccessFileTime, &LastAccessSystemTime);
        @ FileTimeToSystemTime(&LastWriteFileTime, &LastWriteSystemTime);
        @ TCHAR DateStr[MAX_PATH] = { 0 }, TimeStr[MAX_PATH] = { 0 };
        @ GetDateFormatW(NULL, 0, &CreationSystemTime, L"yyyy-MM-dd", DateStr, MAX_PATH);
        @ GetTimeFormatW(NULL, 0, &CreationSystemTime, L" HH:mm:ss", TimeStr, MAX_PATH);
        @ @<DateStr> = DateStr;
        @ @<TimeStr> = TimeStr;
        返回的文件创建时间 = DateStr + TimeStr
        @ GetDateFormatW(NULL, 0, &LastAccessSystemTime, L"yyyy-MM-dd", DateStr, MAX_PATH);
        @ GetTimeFormatW(NULL, 0, &LastAccessSystemTime, L" HH:mm:ss", TimeStr, MAX_PATH);
        @ @<DateStr> = DateStr;
        @ @<TimeStr> = TimeStr;
        返回的文件访问时间 = DateStr + TimeStr
        @ GetDateFormatW(NULL, 0, &LastWriteSystemTime, L"yyyy-MM-dd", DateStr, MAX_PATH);
        @ GetTimeFormatW(NULL, 0, &LastWriteSystemTime, L" HH:mm:ss", TimeStr, MAX_PATH);
        @ @<DateStr> = DateStr;
        @ @<TimeStr> = TimeStr;
        返回的文件修改时间 = DateStr + TimeStr
        @ CloseHandle(hFile);
        @ return bRes;
    }

    方法 文件_修改文件时间 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 创建时间 <类型 = 文本型 注释 = "例如：\"2024-04-01 12:00:00\"" @默认值 = "">
    参数 修改时间 <类型 = 文本型 注释 = "例如：\"2024-06-01 13:00:00\"" @默认值 = "">
    {
        @ const wchar_t* filePath = @<文件路径>;
        @ const wchar_t* creationTimeStr = @<创建时间>;
        @ const wchar_t* modifyTimeStr = @<修改时间>;
        @ HANDLE hFile = CreateFileW(
        @ filePath,
        @ FILE_WRITE_ATTRIBUTES,
        @ FILE_SHARE_READ | FILE_SHARE_WRITE,
        @ NULL,
        @ OPEN_EXISTING,
        @ FILE_ATTRIBUTE_NORMAL,
        @ NULL);
        @ if (hFile == INVALID_HANDLE_VALUE) {
        调试输出 ("无法打开文件")
        @ return false;
        @ }
        @ FILETIME ftCreation = { 0 }, ftModify = { 0 };
        @ SYSTEMTIME stLocal = { 0 }, stUTC = { 0 };
        @ if (creationTimeStr && wcslen(creationTimeStr) > 0) {
        @ if (swscanf_s(creationTimeStr, L"%hu-%hu-%hu %hu:%hu:%hu",
        @ &stLocal.wYear, &stLocal.wMonth, &stLocal.wDay,
        @ &stLocal.wHour, &stLocal.wMinute, &stLocal.wSecond) != 6) {
        @ CloseHandle(hFile);
        调试输出 ("创建时间格式错误")
        @ return false;
        @ }
        @ TzSpecificLocalTimeToSystemTime(NULL, &stLocal, &stUTC);
        @ SystemTimeToFileTime(&stUTC, &ftCreation);
        @ }
        @ if (modifyTimeStr && wcslen(modifyTimeStr) > 0) {
        @ if (swscanf_s(modifyTimeStr, L"%hu-%hu-%hu %hu:%hu:%hu",
        @ &stLocal.wYear, &stLocal.wMonth, &stLocal.wDay,
        @ &stLocal.wHour, &stLocal.wMinute, &stLocal.wSecond) != 6) {
        @ CloseHandle(hFile);
        调试输出 ("修改时间格式错误")
        @ return false;
        @ }
        @ TzSpecificLocalTimeToSystemTime(NULL, &stLocal, &stUTC);
        @ SystemTimeToFileTime(&stUTC, &ftModify);
        @ }
        @ BOOL success = SetFileTime(
        @ hFile,
        @ (creationTimeStr && wcslen(creationTimeStr) > 0) ? &ftCreation : NULL,
        @ NULL,
        @ (modifyTimeStr && wcslen(modifyTimeStr) > 0) ? &ftModify : NULL
        @ );
        @ CloseHandle(hFile);
        @ if (success) {
        @ return true;
        @ }
        @ return false;
    }

    方法 程序_禁止程序重复运行 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 软件标记 <类型 = 文本型 注释 = "禁止重复运行的独立标记" @默认值 = 空对象>
    参数 是否弹出提示 <类型 = 逻辑型 @默认值 = 假>
    参数 提示信息 <类型 = 文本型 @默认值 = "请勿重复运行该程序！">
    参数 是否显示原程序 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 句柄 <类型 = 变整数>
        如果真 (软件标记 == "")
        {
            软件标记 = "禁止重复运行程序"
        }
        @ if (OpenEventW(EVENT_ALL_ACCESS, FALSE, @<软件标记>.GetText()))
        {
            如果真 (是否弹出提示)
            {
                信息框_定时 (选择 (提示信息 == "", "请勿重复运行该程序！", 提示信息), , , 3)
            }
            句柄 = 进程_取指定进程窗口句柄_进程名 (取执行文件名 ())
            如果真 (是否显示原程序)
            {
                窗口_置窗口还原 (句柄)
                窗口_显示隐藏窗口组件 (句柄, 窗口显示命令常量.SW_SHOWNORMAL)
                窗口_窗口置顶 (句柄)
            }
            结束 ()
        }
        @ CreateEventW(NULL, FALSE, FALSE, @<软件标记>.GetText());
    }

