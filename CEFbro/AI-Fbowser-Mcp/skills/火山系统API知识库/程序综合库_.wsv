类 系统目录类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统目录\"" @全局类 = 真>
{
    方法 磁盘_枚举盘符 <公开 静态 类型 = 整数 注释 = "获取硬盘、光驱、U盘、可移动硬盘" 折叠>
    参数 获取类型 <类型 = 整数 注释 = "默认为0 ； 0、所有 1.硬盘 2、光驱 3、可移动 4、网络驱动" @默认值 = 0>
    参数 返回驱动器信息 <类型 = 文本数组类>
    {
        变量 盘符组 <类型 = 字节集数组类>
        变量 移动盘 <类型 = 文本数组类>
        变量 硬盘 <类型 = 文本数组类>
        变量 光盘 <类型 = 文本数组类>
        变量 其他 <类型 = 文本数组类>
        变量 所有盘 <类型 = 文本数组类>
        变量 所有盘符 <类型 = 字节集类>
        变量 返回值 <类型 = 整数>
        变量 i <类型 = 整数>
        所有盘符 = 取空白字节集 (256)
        返回值 = 驱动器api.GetLogicalDriveStringsA (256, 取字节集指针 (所有盘符))
        所有盘符 = 取字节集左边 (所有盘符, 返回值)
        分割字节集 (所有盘符, 创建字节集 (0), 盘符组)
        循环 (, 盘符组.取成员数 (), i)
        {
            如果 (驱动器api.GetDriveTypeA (字节集到文本 (盘符组.取成员 (i))) == 2)  // 2=移动驱动器
            {
                移动盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
                所有盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
            }
            否则 (驱动器api.GetDriveTypeA (字节集到文本 (盘符组.取成员 (i))) == 3)  // 3=硬盘
            {
                硬盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
                所有盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
            }
            否则 (驱动器api.GetDriveTypeA (字节集到文本 (盘符组.取成员 (i))) == 5)  // 5=光盘
            {
                光盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
                所有盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
            }
            否则
            {
                如果真 (取文本长度 (多字节到文本 (盘符组.取成员 (i))) > 2)
                {
                    其他.加入成员 (多字节到文本 (盘符组.取成员 (i)))
                    所有盘.加入成员 (多字节到文本 (盘符组.取成员 (i)))
                }
            }
        }

        如果 (获取类型 == 0)
        {
            返回驱动器信息 = 所有盘
        }
        否则 (获取类型 == 1)
        {
            返回驱动器信息 = 硬盘
        }
        否则 (获取类型 == 2)
        {
            返回驱动器信息 = 光盘
        }
        否则 (获取类型 == 3)
        {
            返回驱动器信息 = 移动盘
        }
        否则
        {
            返回驱动器信息 = 其他
        }
        返回 (返回驱动器信息.取成员数 ())
    }

    方法 系统_取桌面路径 <公开 静态 类型 = 文本型 折叠>
    {
        返回 (取特定目录 (特定目录类型.系统桌面))
    }

    方法 程序_取程序完整路径 <公开 静态 类型 = 文本型 注释 = "自身路径" 折叠>
    {
        返回 (取运行目录 () + 取执行文件名 ())
    }

    方法 系统_取用户名称 <公开 静态 类型 = 文本型 注释 = "当前系统帐户名称" 折叠>
    {
        返回 (读环境变量 ("USERNAME"))
    }

    方法 系统_取系统目录 <公开 静态 类型 = 文本型 注释 = "系统目录如： C:\\Windows\\" 折叠>
    {
        返回 (读环境变量 ("SystemRoot") + "\\")
    }

    方法 系统_取程序文件目录 <公开 静态 类型 = 文本型 注释 = "ProgramFiles目录。64位程序返回： C:\\Program Files\\ ；32位程序返回： C:\\Program Files (x86)\\"
            返回值注释 = "失败返回空" 折叠>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 真>
    {
        如果 (是否64位)
        {
            返回 (读环境变量 ("ProgramFiles") + "\\")
        }
        否则
        {
            返回 (读环境变量 ("ProgramFiles(x86)") + "\\")
        }
    }

    方法 系统_取系统文件目录 <公开 静态 类型 = 文本型 注释 = "即System32（64位系统中SysWOW64表示32位目录）" 返回值注释 = "失败返回空" 折叠>
    {
        返回 (读环境变量 ("SystemRoot") + "\\" + "System32" + "\\")
    }

    方法 系统_取临时文件夹目录 <公开 静态 类型 = 文本型 注释 = "Temp目录，如： C:\\Users\\ADMINI~1\\AppData\\Local\\Temp\\" 折叠>
    {
        返回 (读环境变量 ("TEMP") + "\\")
    }

    方法 系统_取当前用户目录 <公开 静态 类型 = 文本型 注释 = "当前用户目录，如： C:\\Users\\Administrator\\" 折叠>
    {
        返回 (读环境变量 ("USERPROFILE") + "\\")
    }

    方法 系统_取系统根目录 <公开 静态 类型 = 文本型 注释 = "取出当前系统安装位置，例如返回“C:\\”" 折叠>
    {
        返回 (读环境变量 ("SystemDrive") + "\\")
    }
}

