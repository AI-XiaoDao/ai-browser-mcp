类 键盘类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.键盘\"" @全局类 = 真>
{
    方法 键盘_键名转键代码 <公开 静态 类型 = 整数 折叠>
    参数 键名 <类型 = 文本型 注释 = "小键区的加上num，例如：num 7  ." 注释 = "还如win分左右，所以：左win、右win">
    {
        子文本替换 (键名, "键", "")
        <折叠> 如果 (到小写 (键名) == "左win")
        {
            返回 (91)
        }
        <折叠> 否则 (到小写 (键名) == "右win")
        {
            返回 (92)
        }
        <折叠> 否则 (到小写 (键名) == "ctrl")
        {
            返回 (按键码.Ctrl键)
        }
        <折叠> 否则 (到小写 (键名) == "shift")
        {
            返回 (按键码.Shift键)
        }
        <折叠> 否则 (到小写 (键名) == "alt")
        {
            返回 (按键码.Alt键)
        }
        <折叠> 否则 (到小写 (键名) == "break")
        {
            返回 (按键码.Break键)
        }
        <折叠> 否则 (到小写 (键名) == "tab")
        {
            返回 (按键码.Tab键)
        }
        <折叠> 否则 (到小写 (键名) == "end")
        {
            返回 (按键码.End键)
        }
        <折叠> 否则 (键名 == "回车" || 到小写 (键名) == "enter")
        {
            返回 (按键码.回车键)
        }
        <折叠> 否则 (到小写 (键名) == "pause")
        {
            返回 (按键码.Pause键)
        }
        <折叠> 否则 (到小写 (键名) == "capslock" || 到小写 (键名) == "caps lock")
        {
            返回 (按键码.CapsLock键)
        }
        <折叠> 否则 (到小写 (键名) == "numlock" || 到小写 (键名) == "num lock")
        {
            返回 (按键码.NumLock键)
        }
        <折叠> 否则 (到小写 (键名) == "scrolllock" || 到小写 (键名) == "scroll lock")
        {
            返回 (按键码.ScrollLock键)
        }
        <折叠> 否则 (到小写 (键名) == "esc")
        {
            返回 (按键码.Esc键)
        }
        <折叠> 否则 (键名 == "空格" || 到小写 (键名) == "space")
        {
            返回 (按键码.空格键)
        }
        <折叠> 否则 (到小写 (键名) == "pageup" || 到小写 (键名) == "page up")
        {
            返回 (按键码.PageUp键)
        }
        <折叠> 否则 (到小写 (键名) == "pagedown" || 到小写 (键名) == "page down")
        {
            返回 (按键码.PageDown键)
        }
        <折叠> 否则 (到小写 (键名) == "home")
        {
            返回 (按键码.Home键)
        }
        <折叠> 否则 (到小写 (键名) == "num 0")
        {
            返回 (96)
        }
        <折叠> 否则 (到小写 (键名) == "num 1")
        {
