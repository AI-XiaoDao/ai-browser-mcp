        @ HWND hwndParent = (HWND)@<父窗口句柄>;
        @ int maxWidth = @<最大宽度>; 
        @ CreateToolTip2(hwndParent, maxWidth, @<是否为气球>);
        如果真 (响应鼠标点击关闭)
        {
            @ OldWindowProc = SetWindowLongPtr (hwndParent, -4,(LONG_PTR)@<窗口消息>);
        }
    }

    方法 弹出提示 <公开 折叠>
    参数 提示文本 <类型 = 文本型>
    参数 提示标题 <类型 = 文本型 @默认值 = "提示！">
    参数 提示图标 <类型 = 整数 注释 = "0、无图标 1、信息 2、警告 3、错误" @默认值 = 1>
    参数 横向坐标 <类型 = 整数>
    参数 纵向坐标 <类型 = 整数>
    参数 显示时长 <类型 = 整数 注释 = "填写-1则无限延时" @默认值 = 3000>
    {
        @ LPCTSTR pszText = @<提示文本>;
        @ LPCTSTR pszTitle = @<提示标题>;
        @ int iconType = @<提示图标>; 
        @ ShowToolTip2(@<横向坐标>, @<纵向坐标>, pszText, pszTitle, iconType);
        如果真 (显示时长 != -1)
        {
            时钟1.启动时钟_ (显示时长)
        }
    }

    方法 关闭提示 <公开 折叠>
    {
        @ HideToolTip2();
    }

    方法 窗口消息 <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @输出名 = "hWnd">
    参数 消息值 <类型 = 整数 @输出名 = "uMsg">
    参数 消息参数1 <类型 = 变整数 @输出名 = "wParam">
    参数 消息参数2 <类型 = 变整数 @输出名 = "lParam">
    {
        如果真 (消息值 == 513 || 消息值 == 516 || 消息值 == 519)
        {
            @ HideToolTip2();
        }
        @ return (LRESULT)::CallWindowProc ((WNDPROC)OldWindowProc, (HWND)hWnd, (UINT)uMsg, wParam, lParam);
    }

    方法 时钟类__周期事件_ <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_>
    参数 标记值 <类型 = 整数>
    参数 时钟ID <类型 = 整数>
    {
        来源对象.停止时钟_ ()
        关闭提示 ()
        返回 (0)
    }
}

