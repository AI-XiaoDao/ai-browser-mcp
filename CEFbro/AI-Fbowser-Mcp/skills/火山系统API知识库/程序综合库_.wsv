        返回 (取操作系统类型 ())
    }

    方法 取系统版本3_ <公开 静态 类型 = 文本型 返回值注释 = "返回系统版本数字，例如：7、8、10、11" 折叠>
    参数 返回的系统信息 <类型 = 文本型 注释 = "此信息可能因激活的Key不同而有所差别">
    {
        变量 版本名称 <类型 = 文本型>
        变量 内部版本 <类型 = 文本型>
        变量 系统数 <类型 = 文本型>
        进程_进程提权 ()
        版本名称 = 注册表读文本_ (3, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion", "ProductName")
        如果 (寻找文本 (版本名称, "Starter", , 真) != -1)
        {
            版本名称 = 版本名称 + "(初级版)"
        }
        否则 (寻找文本 (版本名称, "Basic", , 真) != -1)
        {
            版本名称 = 版本名称 + "(家庭普通版)"
        }
        否则 (寻找文本 (版本名称, "Home Premium", , 真) != -1)
        {
            版本名称 = 版本名称 + "(家庭高级版)"
        }
        否则 (寻找文本 (版本名称, "Home", , 真) != -1)
        {
            版本名称 = 版本名称 + "(家庭版)"
        }
        否则 (寻找文本 (版本名称, "Professional", , 真) != -1)
        {
            版本名称 = 版本名称 + "(专业版)"
        }
        否则 (寻找文本 (版本名称, "Mobile Enterprise", , 真) != -1)
        {
            版本名称 = 版本名称 + "(企业移动版)"
        }
        否则 (寻找文本 (版本名称, "Enterprise", , 真) != -1)
        {
            版本名称 = 版本名称 + "(企业版)"
        }
        否则 (寻找文本 (版本名称, "Ultimate", , 真) != -1)
        {
            版本名称 = 版本名称 + "(旗舰版)"
        }
        否则 (寻找文本 (版本名称, "Education", , 真) != -1)
        {
            版本名称 = 版本名称 + "(教育版)"
        }
        否则 (寻找文本 (版本名称, "Mobile", , 真) != -1)
        {
            版本名称 = 版本名称 + "(移动版)"
        }
        否则 (寻找文本 (版本名称, "IoT Core", , 真) != -1)
        {
            版本名称 = 版本名称 + "(物联网版)"
        }
        如果 (寻找文本 (版本名称, "server", , 真) != -1)
        {
            系统数 = 匹配所有数字_ (取文本左边 (版本名称, 20))
            版本名称 = 版本名称 + "(服务器)"
        }
        否则 (寻找文本 (版本名称, "Windows 7", , 真) != -1)
        {
            系统数 = "7"
        }
        否则 (寻找文本 (版本名称, "Windows 8.1", , 真) != -1)
        {
            系统数 = "8.1"
        }
        否则 (寻找文本 (版本名称, "Windows 8", , 真) != -1)
        {
            系统数 = "8"
        }
        否则 (寻找文本 (版本名称, "Windows 10", , 真) != -1)
        {
            内部版本 = 注册表读文本_ (3, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion", "BuildLab")
            内部版本 = 取文本左边_ (内部版本, ".")
            如果 (文本到整数 (内部版本) >= 22000)
            {
                系统数 = "11"
                子文本替换 (版本名称, "Windows 10", "Windows 11", , , 假)
                返回的系统信息 = 版本名称
            }
            否则
            {
                系统数 = "10"
            }
        }
        返回的系统信息 = 版本名称
        返回 (系统数)
    }

    方法 系统_是否为64位系统 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ typedef void(WINAPI* GetNativeSystemInfo)(LPSYSTEM_INFO);
        @ HMODULE hModule = GetModuleHandleW(L"kernel32.dll");
        @ if (!hModule) return false;
        @ GetNativeSystemInfo pfnGetNativeSystemInfo = (GetNativeSystemInfo)GetProcAddress(hModule, "GetNativeSystemInfo");
        @ if (!pfnGetNativeSystemInfo) return false;
        @ SYSTEM_INFO si;
        @ pfnGetNativeSystemInfo(&si);
        @ return (si.wProcessorArchitecture == PROCESSOR_ARCHITECTURE_AMD64 || si.wProcessorArchitecture == PROCESSOR_ARCHITECTURE_IA64);
    }

    方法 系统_关闭系统 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        进程_进程提权 (, 权限常量类.关闭系统)
        @ return ExitWindowsEx(EWX_SHUTDOWN | EWX_FORCE, SHTDN_REASON_MINOR_OTHER);
    }

    方法 系统_注销系统 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        进程_进程提权 (, 权限常量类.关闭系统)
        @ return ExitWindowsEx(EWX_LOGOFF | EWX_FORCE, SHTDN_REASON_MINOR_OTHER);
    }

    方法 系统_重启系统 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        进程_进程提权 (, 权限常量类.关闭系统)
        @ return ExitWindowsEx(EWX_REBOOT | EWX_FORCE, SHTDN_REASON_MINOR_OTHER);
    }

    方法 系统_进入休眠状态 <公开 静态 类型 = 逻辑型 注释 = "成功返回真" 折叠 折叠2 @视窗.外部头文件 = "<powrprof.h>" @视窗.外部库 = "powrprof.lib" @禁止流程检查 = 真>
    {
        @ return SetSuspendState(true, false, false);
    }

    方法 系统_阻止休眠 <公开 静态 注释 = "在程序关闭时执行假参数来恢复原设置" 折叠>
    参数 是否阻止 <类型 = 逻辑型 @默认值 = 真>
    {
        @ if (@<是否阻止>==true)
        @  {
        @ SetThreadExecutionState(ES_CONTINUOUS | ES_SYSTEM_REQUIRED | ES_DISPLAY_REQUIRED);
        @ }
        @ else
        @  {
        @ SetThreadExecutionState(ES_CONTINUOUS);
        @ }
    }

    方法 字体_安装字体 <公开 静态 类型 = 整数 注释 = "安装临时字体，成功返回大于0" 折叠 @禁止流程检查 = 真>
    参数 字体名称路径 <类型 = 文本型>
    {
        @ int zts = AddFontResourceW(@<字体名称路径>.GetText());
        @ if (zts) PostMessage(HWND_BROADCAST, WM_FONTCHANGE, NULL, NULL);
        @ return zts;
    }

    方法 字体_卸载字体 <公开 静态 类型 = 逻辑型 注释 = "卸载临时字体" 折叠 @禁止流程检查 = 真>
    参数 字体名称路径 <类型 = 文本型>
    {
        @ BOOL zts = RemoveFontResourceW(@<字体名称路径>.GetText());
        @ if (zts) PostMessage(HWND_BROADCAST, WM_FONTCHANGE, NULL, NULL);
        @ return zts;
    }
}

