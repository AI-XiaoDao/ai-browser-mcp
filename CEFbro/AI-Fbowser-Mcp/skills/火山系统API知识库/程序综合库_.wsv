类 时钟类_线程 <公开 注释 = "以线程方式运行时钟，最多只能创建16个，不会等待执行完成" 折叠 折叠2 @文档 = "category = \"程序综合库.线程时钟\"" @视窗.外部头文件 = "Mmsystem.h"
        @视窗.外部库 = "winmm.lib">
{
    方法 类_初始化 <折叠>
    {
        停止时钟_ ()
    }

    方法 启动时钟_ <公开 类型 = 逻辑型 注释 = "启动一个时钟,重复启动会先销毁之前创建的时钟" 折叠 @禁止流程检查 = 真>
    参数 周期时间 <类型 = 整数 注释 = "1000毫秒 = 1秒" @默认值 = 1000>
    {
        @ if (m_nIDTimer) timeKillEvent (m_nIDTimer);
        @ m_nIDTimer = timeSetEvent (@<周期时间>, 1, @sn<current_class>::onTimeFunc, (DWORD_PTR)this, TIME_PERIODIC | TIME_CALLBACK_FUNCTION | TIME_KILL_SYNCHRONOUS);
        @ return m_nIDTimer != NULL;
    }

    方法 停止时钟_ <公开 折叠>
    {
        @ if (m_nIDTimer)
        @ {
        @     timeKillEvent (m_nIDTimer);
        @     m_nIDTimer = NULL;
        @ }
    }

    方法 是否正在运行 <公开 属性读 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ return m_nIDTimer != NULL;
    }

    方法 周期事件 <公开 定义事件 类型 = 整数 注释 = "件以线程方式运行,耗时极低" 返回值注释 = "此返回值无意义" 折叠>
    {

    }

    # ---
    # @begin
    # <> <include>
    # protected:
    #     UINT m_nIDTimer = NULL;
    # public:
    #     inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const {
    #         return ( this->m_nIDTimer == objCompare.m_nIDTimer );
    #     }
    # private:
    #     static void CALLBACK onTimeFunc (UINT uID, UINT uMsg, DWORD_PTR dwUser, DWORD_PTR dw1, DWORD_PTR dw2) {
    #         HANDLE hThread = ::CreateThread (NULL, 8192, (LPTHREAD_START_ROUTINE)ThreadProc, (LPVOID)dwUser, 0, NULL);
    #         if (hThread) { ::CloseHandle (hThread); }
    #     }
    #     static void CALLBACK ThreadProc (LPVOID lpTis) {
    #         ((@sn<current_class>*)lpTis)->@<周期事件> ();
    #     }
    # <> </include>
    # @end
    # ---
}

类 时钟类_线程2 <公开 注释 = "以线程方式运行时钟，会等待执行完成。支持设置超长等待时间" 折叠 @文档 = "category = \"程序综合库.线程时钟\"">
{
    变量 线程 <类型 = 线程类_>
    变量 周期时间 <类型 = 整数>
    变量 已运行 <类型 = 逻辑型>
    变量 停止 <类型 = 逻辑型>

    方法 类_清理 <折叠>
    {
        线程.强制结束线程_ ()
    }

    方法 启动时钟_ <公开 折叠>
    参数 时间 <类型 = 整数 注释 = "1000毫秒 = 1秒" @默认值 = 1000>
    {
        周期时间 = 时间
        停止 = 假
        如果真 (已运行 == 假)
        {
            已运行 = 真
            处理事件 ()
            线程.创建线程_ ()
        }
    }

    方法 停止时钟_ <公开 折叠>
    {
        停止 = 真
        已运行 = 假
        处理事件 ()
    }

    方法 时钟周期_ <公开 折叠>
    参数 时间 <类型 = 整数 注释 = "1000毫秒 = 1秒" @默认值 = 1000>
    {
        周期时间 = 时间
        处理事件 ()
    }

    方法 线程类__线程事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程类_>
    参数 标记值 <类型 = 整数>
    参数 线程参数 <类型 = 变整数>
    {
        变量 开始时间 <类型 = 长整数>
        开始时间 = 取启动时间 ()
        判断循环 (停止 == 假)
        {
            判断循环 (停止 == 假)
            {
                如果真 (取启动时间 () - 开始时间 > 周期时间)
                {
                    开始时间 = 取启动时间 ()
                    跳出循环
                }
                延迟2_ (1)
            }
            如果 (停止 == 假)
            {
                周期事件 ()
            }
            否则
            {
                跳出循环
            }
        }
        返回 (0)
    }

    方法 周期事件 <公开 定义事件 类型 = 整数>
}

# //=====

类 USB监视类_ <公开 折叠 @文档 = "category = \"程序综合库.USB监视\"">
{
    变量 盘组 <类型 = 文本数组类>
    变量 盘组2 <类型 = 文本数组类>
    变量 盘数 <类型 = 整数>
    变量 线程 <类型 = 线程类_>
    变量 开启 <类型 = 逻辑型>
    变量 已开 <类型 = 逻辑型>

    方法 开启监视_ <公开 折叠>
    {
        如果真 (已开 == 假)
        {
            盘组.删除所有成员 ()
            盘组2.删除所有成员 ()
            盘数 = 0
            开启 = 真
            已开 = 真
            处理事件_ ()
            线程.创建线程_ ()
        }
    }

    方法 关闭监视_ <公开 折叠>
    {
        开启 = 假
        已开 = 假
        处理事件_ ()
    }

    方法 禁用USB_ <公开 折叠>
    {
        常量 禁用 <类型 = 文本型 值 = "reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\USBSTOR\" /f /v \"Start\" /t REG_DWORD /d 4"
                编辑时信息 = "0, E4436, 0, 0">
        常量 更新 <类型 = 文本型 值 = "rundll32 user32.dll,UpdatePerUserSystemParameters">
        运行 (禁用, , 程序窗口显示方式.隐藏窗口)
        运行 (更新, , 程序窗口显示方式.隐藏窗口)
    }

    方法 启用USB_ <公开 折叠>
    {
        常量 启用 <类型 = 文本型 值 = "reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\USBSTOR\" /f /v \"Start\" /t REG_DWORD /d 3"
                编辑时信息 = "0, F6657, 0, 0">
        常量 更新 <类型 = 文本型 值 = "rundll32 user32.dll,UpdatePerUserSystemParameters">
        运行 (启用, , 程序窗口显示方式.隐藏窗口)
        运行 (更新, , 程序窗口显示方式.隐藏窗口)
    }

    方法 线程类__线程事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程类_>
    参数 标记值 <类型 = 整数>
    参数 线程参数 <类型 = 变整数>
    {
        变量 数量 <类型 = 整数>
        变量 存在 <类型 = 逻辑型>
        变量 i <类型 = 整数>
        判断循环 (开启 == 真)
        {
            如果真 (开启 == 假)
            {
                跳出循环
            }
            磁盘_枚举盘符 (0, 盘组)
            数量 = 盘组.取成员数 ()
            如果 (数量 > 盘数)
            {
                盘数 = 数量
                盘组.枚举循环 ()
                {
                    存在 = 假
                    如果 (盘组2.取成员数 () == 0)
                    {
                        插拔事件 (盘组.取枚举值 (), 真)
                    }
                    否则
                    {
                        循环 (, 盘组2.取成员数 (), i)
                        {
                            如果 (盘组.取枚举值 () == 盘组2.取成员 (i))
                            {
                                存在 = 真
                                跳出循环
                            }
                        }
                        如果 (存在 == 假)
                        {
                            插拔事件 (盘组.取枚举值 (), 真)
                        }
                    }
                }
            }
            否则
            {
                如果真 (开启 == 假)
                {
                    跳出循环
                }
                盘数 = 数量
                盘组2.枚举循环 ()
                {
                    存在 = 假
                    循环 (, 盘组.取成员数 (), i)
                    {
                        如果 (盘组2.取枚举值 () == 盘组.取成员 (i))
                        {
                            存在 = 真
                            跳出循环
                        }
                    }
                    如果 (存在 == 假)
                    {
                        插拔事件 (盘组2.取枚举值 (), 假)
                    }
                }
            }
            盘组2 = 盘组
            延迟_ (3)
        }
        返回 (0)
    }

    方法 插拔事件 <公开 定义事件 类型 = 整数 折叠>
    参数 USB盘符 <类型 = 文本型>
    参数 是否插入 <类型 = 逻辑型>
}

