类 系统类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统操作\"" @全局类 = 真>
{
    方法 系统_取系统时区 <公开 静态 类型 = 文本型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream\r\nstring\r\nsstream"
            @视窗.预定义宏 = "_WIN32_WINNT=0x0600">
    {
        @ TIME_ZONE_INFORMATION tzi;
        @ if (GetTimeZoneInformation(&tzi) == TIME_ZONE_ID_INVALID) {
        @ return L"无法获取时区信息";
        @ }
        @ std::wstring tzName = tzi.StandardName;
        @ HKEY hKey;
        @ std::wstring regPath = L"SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Time Zones\\";
        @ DYNAMIC_TIME_ZONE_INFORMATION dtzi;
        @ if (GetDynamicTimeZoneInformation(&dtzi) != TIME_ZONE_ID_INVALID) {
        @ regPath += dtzi.TimeZoneKeyName;
        @ if (RegOpenKeyEx(HKEY_LOCAL_MACHINE, regPath.c_str(), 0, KEY_READ, &hKey) == ERROR_SUCCESS) {
        @ WCHAR displayName[256] = {0};
        @ DWORD size = sizeof(displayName);
        @ if (RegQueryValueEx(hKey, L"Display", NULL, NULL, (LPBYTE)displayName, &size) == ERROR_SUCCESS) {
        @ tzName = displayName;
        @ }
        @ RegCloseKey(hKey);
        @ }
        @ }
        @ int bias = -tzi.Bias;
        @ int hours = bias / 60;
        @ int minutes = abs(bias) % 60;
        @ std::wostringstream woss;
        @ return tzName.c_str();
    }

    方法 系统_置系统时区 <公开 静态 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "windows.h\r\niostream" @视窗.预定义宏 = "_WIN32_WINNT=0x0600">
    参数 时区键名‌ <类型 = 文本型 注释 = "默认是中国标准时间." 注释 = "更多时区键名请查询百度" 注释 = "美国东部时间：Eastern Standard Time"
            注释 = "格林尼治标准时间：Greenwich Mean Time" 注释 = "日本标准时间：Japan Standard Time" 注释 = "韩国标准时间：Korea Standard Time"
            注释 = "澳大利亚东部时间：AUS Eastern Standard Time" @默认值 = "China Standard Time">
    {
        变量 临时键名‌ <类型 = 文本型>
        临时键名‌ = "tzutil /s " + "\"" + 时区键名‌ + "\""
        @ system(CU8String(@<临时键名‌>.GetText()));
        @ ShellExecuteW(NULL, L"open", L"tzutil.exe", L"/s \"China Standard Time\"",NULL, SW_HIDE);
    }

    方法 时间_置系统时间 <公开 静态 类型 = 逻辑型 注释 = "对应系统设置“日期和时间格式”中的短日期设置" 折叠 @禁止流程检查 = 真>
    参数 格式 <类型 = 文本型 注释 = "例如:\"yyyy/MM/dd\"、\"yyyy-MM-dd\"、\"yyyy.MM.dd\"、“yy/M/d”" @默认值 = "yyyy/MM/dd">
    {
        @ return SetLocaleInfoW(LOCALE_USER_DEFAULT, LOCALE_SSHORTDATE, @<格式>.GetText ());
    }

    方法 时间_置系统时间显示秒数 <公开 静态 类型 = 逻辑型 注释 = "系统时间是否增加显示秒数（支持10、11系统）" 折叠>
    参数 是否显示 <类型 = 逻辑型 @默认值 = 真>
    参数 立即生效 <类型 = 逻辑型 注释 = "立即生效会重启界面进程" @默认值 = 假>
    {
        变量 结果 <类型 = 逻辑型>
        如果 (是否显示)
        {
            结果 = 注册表写整数_ (2, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced", "ShowSecondsInSystemClock", 1, 为64位程序 ())
        }
        否则
        {
            结果 = 注册表写整数_ (2, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced", "ShowSecondsInSystemClock", 0, 为64位程序 ())
        }
        如果真 (立即生效)
        {
            如果 (取系统版本2_ () != 5)
            {
                系统_刷新系统 ()
            }
            否则
            {
                运行 ("cmd /c taskkill /F /IM explorer.exe & start explorer", , 程序窗口显示方式.隐藏窗口)
            }
        }
        返回 (结果)
    }

    方法 系统_取系统DPI <公开 静态 类型 = 整数 注释 = "取系统DPI缩放比" 折叠 @禁止流程检查 = 真>
    {
        @ HDC hDC = GetDC(NULL);
        @ int dpiA = (double)GetDeviceCaps(hDC, DESKTOPHORZRES) / GetDeviceCaps(hDC, HORZRES) * 100;
        @ int dpiB = GetDeviceCaps(hDC, LOGPIXELSX) / 96 * 100;
        @ ReleaseDC(NULL, hDC);
        @ if (dpiA == 100) return dpiB;
        @ if (dpiB == 100) return dpiA;
        @ if (dpiA == dpiB) return dpiA;
        @ return 0;
    }

    方法 系统_DPI缩放计算 <公开 静态 类型 = 小数 注释 = "当dpi发生改变时，原尺寸坐标也会相应变动，通过此命令可转换正确坐标" 折叠>
    参数 原尺寸 <类型 = 整数>
    参数 原DPI <类型 = 整数 注释 = "例如：100、125、150、175等" @默认值 = 100>
    参数 现DPI <类型 = 整数 注释 = "例如：100、125、150、175等" @默认值 = 125>
    {
        变量 结果 <类型 = 小数>
        如果 (原DPI < 现DPI)
        {
            结果 = 原尺寸 * (小数)现DPI / 原DPI
        }
        否则 (原DPI > 现DPI)
        {
            结果 = 原尺寸 / ((小数)原DPI / 现DPI)
        }
        否则
        {
            结果 = 原尺寸
        }
        返回 (结果)
    }

    方法 系统_注册DLL <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 组件路径 <类型 = 文本型>
    {
        @ WCHAR LibFileName[MAX_PATH] = { 0 };
        @ GetShortPathNameW(@<组件路径>.GetText(), LibFileName, MAX_PATH);
        @ HMODULE hDll = LoadLibraryW(LibFileName);
        @ if (!hDll) return FALSE;
        @ FARPROC pFunc = GetProcAddress(hDll, "DllRegisterServer");
        @ BOOL bRes = FALSE;
        @ if (pFunc)
        @ {
        @ bRes = CallWindowProcW((WNDPROC)pFunc, NULL, NULL, NULL, NULL);
        @ }
        @ FreeLibrary(hDll);
        @ return bRes;
    }

    方法 系统_卸载DLL <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 组件路径 <类型 = 文本型>
    {
        @ HMODULE hDll = LoadLibraryW(@<组件路径>.GetText());
        @ if (!hDll) return FALSE;
        @ FARPROC pFunc = GetProcAddress(hDll, "DllUnregisterServer");
        @ BOOL bRes = FALSE;
        @ if (pFunc)
        @ {
        @ bRes = CallWindowProcW((WNDPROC)pFunc, NULL, NULL, NULL, NULL);
        @ }
        @ FreeLibrary(hDll);
        @ return bRes;
    }

    方法 时间_取系统空闲时间 <公开 静态 类型 = 整数 注释 = "返回系统无任何操作的空余时间，单位为毫秒" 折叠 @禁止流程检查 = 真>
    {
        @ LASTINPUTINFO plii;
        @ memset(&plii, 0, sizeof(LASTINPUTINFO));
        @ plii.cbSize = sizeof(LASTINPUTINFO);
        @ GetLastInputInfo(&plii);
        @ return (INT)(GetTickCount() - plii.dwTime);
    }

    方法 系统_提升系统权限 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ HANDLE hToken;
        @ TOKEN_PRIVILEGES tkp;
        @ if (!OpenProcessToken(GetCurrentProcess(), TOKEN_ADJUST_PRIVILEGES | TOKEN_QUERY, &hToken)) return false;
        @ LookupPrivilegeValueW(NULL, SE_SHUTDOWN_NAME, &tkp.Privileges[0].Luid);
        @ tkp.PrivilegeCount = 1;
        @ tkp.Privileges[0].Attributes = SE_PRIVILEGE_ENABLED;
        @ AdjustTokenPrivileges(hToken, FALSE, &tkp, sizeof(TOKEN_PRIVILEGES), NULL, NULL);
        @ if (GetLastError() != ERROR_SUCCESS) return false;
        @ return true;
    }

    方法 系统_显示隐藏扩展名 <公开 静态 折叠>
    参数 是否显示 <类型 = 逻辑型 @默认值 = 真>
    参数 是否立即生效 <类型 = 逻辑型 @默认值 = 真>
    {
