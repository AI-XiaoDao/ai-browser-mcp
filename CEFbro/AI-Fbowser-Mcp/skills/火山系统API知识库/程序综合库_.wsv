类 系统语言标识类_ <公开 折叠 折叠2 @文档 = "category = \"程序综合库.系统语言标识\"" @全局类 = 真>
{
    变量 国家信息 <静态 类型 = 文本型
            值 = "{\"2052\":\"中文(简体,中国)\",\"1028\":\"中文(繁体,中国台湾)\",\"3076\":\"中文(繁体,中国香港)\",\"1033‬\":\"英语(美国)\",\"2057\":\"英语(英国)\",\"3081‬\":\"英语(澳大利亚)\",\"4105‬\":\"英语(加拿大)\",\"5129‬\":\"英语(新西兰)\",\"16393‬\":\"英语(印度)\",\"3084‬\":\"法语(加拿大)\",\"1036\":\"法语(法国)\",\"4108‬\":\"法语(瑞士)\",\"1031‬\":\"德语(德国)\",\"2055‬\":\"德语(瑞士)\",\"1032‬\":\"希腊语\",\"1040‬\":\"意大利语(意大利)\",\"2064\":\"意大利语(瑞士)\",\"1049‬\":\"俄语(俄罗斯)\",\"2077‬\":\"瑞典语\",\"1066‬\":\"越南语\",\"1058\":\"乌克兰语\",\"1086\":\"马来语(马来西亚)\",\"1108\":\"老挝语\"}"
            编辑时信息 = "0, 84EBC, 0, 0">

    方法 语言_判断语言类型 <公开 静态 类型 = 文本型 折叠>
    参数 文字 <类型 = 文本型>
    {
        变量 ch <类型 = 字符>
        ch = 取字符 (文字, 0)
        如果 (ch >= 0x4E00 && ch <= 0x9FFF || ch >= 0xF900 && ch <= 0xFAFF)
        {
            返回 ("中文")
        }
        否则 (ch >= 0x0041 && ch <= 0x005A || ch >= 0x0061 && ch <= 0x007A)
        {
            返回 ("英文")
        }
        否则 (ch >= 0x3040 && ch <= 0x309F || ch >= 0x30A0 && ch <= 0x30FF)
        {
            返回 ("日文")
        }
        否则 (ch >= 0xAC00 && ch <= 0xD7AF)
        {
            返回 ("韩文")
        }
        返回 ("")
    }

    方法 语言_判断语言类型2 <公开 静态 类型 = 逻辑型 折叠>
    参数 内容 <类型 = 文本型>
    参数 语言类型 <类型 = 整数 注释 = "0、中文 1、英文  2、日文 3、韩文" @默认值 = 0>
    参数 阈值 <类型 = 小数 注释 = "即达到多少值时，可以判断为是指定的语言类型。最大是1，即表示100%" @默认值 = 0.7>
    {
        变量 总长度 <类型 = 整数>
        变量 相似值 <类型 = 整数>
        变量 ch <类型 = 字符>
        变量 i <类型 = 整数>
        总长度 = 取文本长度 (内容)
        循环 (, 总长度, i)
        {
            ch = 取字符 (取文本中间 (内容, i * 1, 1), 0)
            如果 (语言类型 == 0)
            {
                如果真 (ch >= 0x4E00 && ch <= 0x9FFF || ch >= 0xF900 && ch <= 0xFAFF)
                {
                    相似值 = 相似值 + 1
                }
            }
            否则 (语言类型 == 1)
            {
                如果真 (ch >= 0x0041 && ch <= 0x005A || ch >= 0x0061 && ch <= 0x007A)
                {
                    相似值 = 相似值 + 1
                }
            }
            否则 (语言类型 == 2)
            {
                如果真 (ch >= 0x3040 && ch <= 0x309F || ch >= 0x30A0 && ch <= 0x30FF)
                {
                    相似值 = 相似值 + 1
                }
            }
            否则 (语言类型 == 3)
            {
                如果真 (ch >= 0xAC00 && ch <= 0xD7AF)
                {
                    相似值 = 相似值 + 1
                }
            }
        }
        返回 ((小数)相似值 / 总长度 >= 阈值)
    }

    方法 系统_取当前系统语言 <公开 静态 类型 = 文本型 注释 = "返回系统区域设置的语言标识符" 折叠>
    {
        变量 标识值 <类型 = 整数>
        变量 JSON <类型 = JSON对象类_>
        变量 结果 <类型 = 文本型>
        标识值 = GetSystemDefaultLangID ()
        JSON.创建自文本 (国家信息)
        结果 = JSON.取文本值 (到文本 (标识值))
        如果真 (文本是否为空 (结果))
        {
            结果 = "当前库中未匹配到信息"
        }
        返回 (结果)
    }

    方法 系统_取当前系统语言2 <公开 静态 类型 = 文本型 注释 = "返回当前用户的语言标识符" 折叠>
    {
        变量 标识值 <类型 = 整数>
        变量 JSON <类型 = JSON对象类_>
        变量 结果 <类型 = 文本型>
        标识值 = GetUserDefaultLangID ()
        JSON.创建自文本 (国家信息)
        结果 = JSON.取文本值 (到文本 (标识值))
        如果真 (文本是否为空 (结果))
        {
            结果 = "当前库中未匹配到信息"
        }
        返回 (结果)
    }

    方法 GetSystemDefaultLangID <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ return GetSystemDefaultLangID();
    }

    方法 GetUserDefaultLangID <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ return GetUserDefaultLangID();
    }
}

