                    }
                }
            }
            否则 (i > 14 && i < 20 || i > 21 && i < 30)
            {
                临时标签.标准鼠标指针 = 标准鼠标指针类型.手型
                临时标签.底图方式 = 图片放置方式.图片居中
                临时标签.背景颜色 = 全局量.边框背景颜色
                如果 (i == 15)  // 关闭
                {
                    临时标签.底图 = 全局量.关闭图标
                    临时标签.提示信息 = 全局量.关闭提示
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
                否则 (i == 16)  // 最大化
                {
                    临时标签.底图 = 全局量.最大图标
                    临时标签.提示信息 = 全局量.最大化提示
