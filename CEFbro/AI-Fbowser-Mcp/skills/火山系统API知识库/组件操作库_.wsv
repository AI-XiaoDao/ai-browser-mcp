    方法 置鼠标指针_ <公开 类型 = 逻辑型 折叠>
    参数 正常指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 关闭指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 调节按钮指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    {
        如果 (全局量.启用自定义指针)
        {
            如果 (调节按钮指针 == 空资源.空鼠标指针)
            {
                调节按钮指针 = 全局量.鼠标指针3
            }
            按钮_左调.自定义鼠标指针 = 调节按钮指针
            按钮_右调.自定义鼠标指针 = 调节按钮指针
            子夹布局组.枚举循环 ()
            {
                如果 (正常指针 == 空资源.空鼠标指针)
                {
                    正常指针 = 全局量.鼠标指针1
                }
                如果 (关闭指针 == 空资源.空鼠标指针)
                {
                    关闭指针 = 全局量.鼠标指针1
                }
                ((导航夹模板)子夹布局组.取枚举值 ()).自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).图片框_根容器.自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).标签_左图.自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).标签_右图.自定义鼠标指针 = 关闭指针
                ((导航夹模板)子夹布局组.取枚举值 ()).标签_右图2.自定义鼠标指针 = 关闭指针
                ((导航夹模板)子夹布局组.取枚举值 ()).标签_标题.自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).标签_竖条.自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).图片框_根容器.自定义鼠标指针 = 正常指针
                ((导航夹模板)子夹布局组.取枚举值 ()).图片框_下划条.自定义鼠标指针 = 正常指针
            }
            返回 (真)
        }
        返回 (假)
    }

    方法 置锁定状态_ <公开 类型 = 逻辑型 注释 = "是否锁住选择夹，不允许操作" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始，-1表示全部锁定或全部解锁">
    参数 是否锁定 <类型 = 逻辑型 注释 = "为真时则不允许关闭，但其它操作正常。本参数为真时，锁死才能生效" @默认值 = 真>
    参数 是否锁死 <类型 = 逻辑型 注释 = "为真时则不允许关闭及操作" @默认值 = 真>
    {
        如果真 (子夹索引 < -1)
        {
            返回 (假)
        }
        如果真 (子夹索引 > 子夹布局组.取成员数 () - 1)
        {
            返回 (假)
        }
        如果真 (是否锁定)
        {
            全局量.是否锁死 = 是否锁死
        }
        如果 (子夹索引 == -1)
        {
            全局量.是否锁定 = 是否锁定
            子夹布局组.枚举循环 ()
            {
                ((导航夹模板)子夹布局组.取枚举值 ()).全局是否锁定 = 是否锁定
                ((导航夹模板)子夹布局组.取枚举值 ()).全局是否锁死 = 是否锁死
            }
        }
        否则
        {
            全局量.是否锁定 = 假
            全局量.是否锁死 = 假
            ((导航夹模板)子夹布局组.取成员 (子夹索引)).全局是否锁定 = 是否锁定
            ((导航夹模板)子夹布局组.取成员 (子夹索引)).全局是否锁死 = 是否锁死
        }
        返回 (真)
    }

