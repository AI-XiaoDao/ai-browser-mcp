                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
            }
            否则 (i == 20)  // 图标
            {
                临时标签.底图方式 = 图片放置方式.图片居中
                临时标签.底图 = 全局量.窗口图标
                临时标签.移动 (窗口图标左边, 0, 全局量.窗口图标宽度, 全局量.上边框高度)
                全局量.图标左位 = 临时标签.左边 + 临时标签.宽度
            }
            否则 (i == 21)  // 标题
            {
                临时标签.标题 = 窗口标题
                临时标签.文本颜色 = 标题颜色
                如果 (标题对齐方式 == 0)
                {
                    临时标签.横向对齐方式 = 横向对齐模式.左边
                }
                否则
                {
                    临时标签.横向对齐方式 = 横向对齐模式.居中
                }
                临时标签.字体 = 标题字体名称 + "," + 到文本 (标题字体大小) + "," + 选择 (标题是否加粗, "1", "0")
            }
            否则 (i == 30)  // 警示
            {
                临时标签.标题 = "锁定中"
                临时标签.横向对齐方式 = 横向对齐模式.居中
            }
        }
        是否已创建 = 真
        匹配尺寸_ ()
    }

    方法 释放退出_ <公开 注释 = "窗口关闭时执行释放" 折叠>
    {
        是否关闭 = 真
        处理事件_ ()
        时钟1.停止时钟_ ()
        时钟2.停止时钟_ ()
        标签组.枚举循环 ()
        {
            ((标签)标签组.取枚举值 ()).销毁 ()
        }
        标签组2.枚举循环 ()
        {
            ((标签)标签组2.取枚举值 ()).销毁 ()
        }
        标签组.删除所有成员 ()
        标签组2.删除所有成员 ()
    }

    方法 置改控件提示_ <公开 注释 = "修改标题栏按钮鼠标停留提示" 折叠>
    参数 关闭提示 <类型 = 文本型 @默认值 = "关闭">
    参数 最大化提示 <类型 = 文本型 @默认值 = "最大化">
    参数 最小化提示 <类型 = 文本型 @默认值 = "最小化">
    参数 全屏提示 <类型 = 文本型 @默认值 = "全屏">
    参数 皮肤提示 <类型 = 文本型 @默认值 = "皮肤">
    参数 附加按钮1提示 <类型 = 文本型 @默认值 = "附加1">
    参数 附加按钮2提示 <类型 = 文本型 @默认值 = "附加2">
    参数 附加按钮3提示 <类型 = 文本型 @默认值 = "附加3">
    参数 附加按钮4提示 <类型 = 文本型 @默认值 = "附加4">
    参数 附加按钮5提示 <类型 = 文本型 @默认值 = "附加5">
    参数 附加按钮6提示 <类型 = 文本型 @默认值 = "附加6">
    参数 附加按钮7提示 <类型 = 文本型 @默认值 = "附加7">
    参数 附加按钮8提示 <类型 = 文本型 @默认值 = "附加7">
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        全局量.关闭提示 = 关闭提示
        全局量.最大化提示 = 最大化提示
        全局量.最小化提示 = 最小化提示
        全局量.全屏提示 = 全屏提示
        全局量.皮肤提示 = 皮肤提示
        全局量.附加提示1 = 附加按钮1提示
        全局量.附加提示2 = 附加按钮2提示
        全局量.附加提示3 = 附加按钮3提示
        全局量.附加提示4 = 附加按钮4提示
        全局量.附加提示5 = 附加按钮5提示
        全局量.附加提示6 = 附加按钮6提示
        全局量.附加提示7 = 附加按钮7提示
        全局量.附加提示8 = 附加按钮8提示
        循环 (15, 30, i)
        {
            如果真 (i > 14 && i < 20)
            {
                临时标签 = (标签)标签组.取成员 (i)
                如果 (i == 15)
                {
                    临时标签.提示信息 = 全局量.关闭提示
                }
                否则 (i == 16)
                {
                    临时标签.提示信息 = 全局量.最大化提示
                }
                否则 (i == 17)
                {
                    临时标签.提示信息 = 全局量.全屏提示
                }
                否则 (i == 18)
                {
                    临时标签.提示信息 = 全局量.最小化提示
                }
                否则 (i == 19)
                {
                    临时标签.提示信息 = 全局量.皮肤提示
                }
            }
            如果真 (i > 21)
            {
                临时标签 = (标签)标签组.取成员 (i)
                如果 (i == 22)
                {
                    临时标签.提示信息 = 全局量.附加提示1
                }
                否则 (i == 23)
                {
                    临时标签.提示信息 = 全局量.附加提示2
                }
                否则 (i == 24)
                {
                    临时标签.提示信息 = 全局量.附加提示3
                }
                否则 (i == 25)
                {
                    临时标签.提示信息 = 全局量.附加提示4
                }
                否则 (i == 26)
                {
                    临时标签.提示信息 = 全局量.附加提示5
                }
                否则 (i == 27)
                {
                    临时标签.提示信息 = 全局量.附加提示6
                }
                否则 (i == 28)
                {
                    临时标签.提示信息 = 全局量.附加提示7
                }
                否则 (i == 29)
                {
                    临时标签.提示信息 = 全局量.附加提示8
                }
            }
        }
    }

    方法 置控件图标_ <公开 注释 = "修改标题栏按钮图标及窗口图标；位图来源" 折叠>
    参数 窗口图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 关闭按钮图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 全屏按钮图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 最大化按钮图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 最小化按钮图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 皮肤按钮图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标1 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标2 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标3 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标4 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标5 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标6 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标7 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 附加按钮图标8 <类型 = 位图资源 @默认值 = 空资源.空位图>
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        如果真 (窗口图标 != 空资源.空位图)
        {
            全局量.窗口图标 = 窗口图标
        }
        如果真 (关闭按钮图标 != 空资源.空位图)
        {
            全局量.关闭图标 = 关闭按钮图标
        }
        如果真 (全屏按钮图标 != 空资源.空位图)
        {
            全局量.全屏图标 = 全屏按钮图标
        }
        如果真 (最大化按钮图标 != 空资源.空位图)
        {
            全局量.最大图标 = 最大化按钮图标
        }
        如果真 (最小化按钮图标 != 空资源.空位图)
        {
            全局量.最小图标 = 最小化按钮图标
        }
        如果真 (皮肤按钮图标 != 空资源.空位图)
        {
            全局量.皮肤图标 = 皮肤按钮图标
        }
        如果真 (附加按钮图标1 != 空资源.空位图)
        {
            全局量.附加图标1 = 附加按钮图标1
        }
        如果真 (附加按钮图标2 != 空资源.空位图)
        {
            全局量.附加图标2 = 附加按钮图标2
        }
        如果真 (附加按钮图标3 != 空资源.空位图)
        {
            全局量.附加图标3 = 附加按钮图标3
        }
        如果真 (附加按钮图标4 != 空资源.空位图)
        {
            全局量.附加图标4 = 附加按钮图标4
        }
        如果真 (附加按钮图标5 != 空资源.空位图)
        {
            全局量.附加图标5 = 附加按钮图标5
        }
        如果真 (附加按钮图标6 != 空资源.空位图)
        {
            全局量.附加图标6 = 附加按钮图标6
        }
        如果真 (附加按钮图标7 != 空资源.空位图)
        {
            全局量.附加图标7 = 附加按钮图标7
        }
        如果真 (附加按钮图标8 != 空资源.空位图)
        {
            全局量.附加图标8 = 附加按钮图标8
        }
        循环 (15, 21, i)
        {
            临时标签 = (标签)标签组.取成员 (i)
            如果 (i == 15)
            {
                临时标签.底图 = 全局量.关闭图标
            }
            否则 (i == 16)
            {
                临时标签.底图 = 全局量.最大图标
            }
            否则 (i == 17)
            {
                临时标签.底图 = 全局量.全屏图标
            }
            否则 (i == 18)
            {
                临时标签.底图 = 全局量.最小图标
            }
            否则 (i == 19)
            {
                临时标签.底图 = 全局量.皮肤图标
            }
            否则 (i == 20)
            {
                临时标签.底图 = 全局量.窗口图标
            }
        }
        循环 (22, 30, i)
        {
            临时标签 = (标签)标签组.取成员 (i)
            如果 (i == 22)
            {
                临时标签.底图 = 全局量.附加图标1
            }
            否则 (i == 23)
            {
                临时标签.底图 = 全局量.附加图标2
            }
            否则 (i == 24)
            {
                临时标签.底图 = 全局量.附加图标3
            }
            否则 (i == 25)
            {
                临时标签.底图 = 全局量.附加图标4
            }
            否则 (i == 26)
            {
                临时标签.底图 = 全局量.附加图标5
            }
            否则 (i == 27)
            {
                临时标签.底图 = 全局量.附加图标6
            }
            否则 (i == 28)
            {
                临时标签.底图 = 全局量.附加图标7
            }
            否则 (i == 29)
            {
                临时标签.底图 = 全局量.附加图标8
            }
        }
    }

