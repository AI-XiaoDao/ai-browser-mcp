        {
            滚动条1.置滚动条颜色_ (滚动条背景色, 滚动条颜色, 滚动条激活色)
        }
        否则 (设置类型 == 2)
        {
            滚动条2.置滚动条颜色_ (滚动条背景色, 滚动条颜色, 滚动条激活色)
        }
        否则
        {
            滚动条1.置滚动条颜色_ (滚动条背景色, 滚动条颜色, 滚动条激活色)
            滚动条2.置滚动条颜色_ (滚动条背景色, 滚动条颜色, 滚动条激活色)
        }
    }

