        如果 (来源对象 == 移入移出)
        {
            如果真 (是否移入 == 假)
            {
                按钮_左调.图片 = 左1
                已进入1 = 假
            }
        }
        否则 (来源对象 == 移入移出2)
        {
            如果真 (是否移入 == 假)
            {
                按钮_右调.图片 = 右1
                已进入2 = 假
            }
        }
        返回 (0)
    }

