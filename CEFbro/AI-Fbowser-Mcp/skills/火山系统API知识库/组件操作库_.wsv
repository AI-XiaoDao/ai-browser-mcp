类 导航头类_ <公开 基础类 = 组件布局器 注释 = "跟随窗口宽度：导航条.移动 (0, , 取用户区宽度 ())" 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"组件操作库.窗口导航库\""
        @视窗.布局 = "client_size = \"466, 32\"">
{
    变量 组件布局器_头区 <类型 = 组件布局器 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 408, 32\"" 可停留焦点 = 真>
    变量 图片框_头区 <类型 = 图片框 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\nparent_id = 101\r\npos = \"0, 0, 10000, 32\"" 底图方式 = 缩放图片 透明 = 真>
    变量 按钮_左调 <类型 = 按钮 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\npos = \"416, 8, 20, 20\"" 图片 = "..\\tb\\左1.png" 横向对齐方式 = 居中
            纵向对齐方式 = 居中 可视 = 假>
    变量 按钮_右调 <类型 = 按钮 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\npos = \"436, 8, 20, 20\"" 图片 = "..\\tb\\右1.png" 横向对齐方式 = 居中
            纵向对齐方式 = 居中 可视 = 假>
    变量 子夹布局组 <类型 = 对象数组类>
    变量 尺寸组 <类型 = 整数数组类>
    变量 移入移出 <类型 = 组件移入移出事件类_>
    变量 移入移出2 <类型 = 组件移入移出事件类_>
    变量 主线 <类型 = 高级主线程处理器>
    变量 已进入1 <类型 = 逻辑型>
    变量 已进入2 <类型 = 逻辑型>
    变量 原子索引 <类型 = 整数>
    变量 开启移动 <类型 = 逻辑型>
    变量 左1 <类型 = 位图资源 值 = "..\\tb\\左1.png">
    变量 左2 <类型 = 位图资源 值 = "..\\tb\\左2.png">
    变量 右1 <类型 = 位图资源 值 = "..\\tb\\右1.png">
    变量 右2 <类型 = 位图资源 值 = "..\\tb\\右2.png">
    变量 全局量 <类型 = 导航夹变量>
    变量 横位 <类型 = 整数>
    变量 纵位 <类型 = 整数>
    变量 时间点 <类型 = 长整数>

    方法 初始化选择夹_ <公开 折叠>
    参数 字体名称 <类型 = 文本型 注释 = "子夹标题字体名称" @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 注释 = "子夹标题字体大小" @默认值 = 9>
    参数 是否加粗 <类型 = 逻辑型 注释 = "子夹标题字体是否加粗" @默认值 = 假>
    参数 标题对齐方式 <类型 = 整数 注释 = "子夹标题对齐方式 0、左对齐 1、居中" @默认值 = 1>
    参数 正常标题颜色 <类型 = 整数 注释 = "子夹标题颜色" @默认值 = 颜色类.黑色>
    参数 热点标题颜色 <类型 = 整数 注释 = "子夹标题颜色" @默认值 = 颜色类.红色>
    参数 子夹正常背景颜色 <类型 = 整数 注释 = "单子夹" @默认值 = 颜色类.默认色>
    参数 子夹热点背景颜色 <类型 = 整数 注释 = "单子夹" @默认值 = 颜色类.白色>
    参数 左侧图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 图标大小 <类型 = 整数 注释 = "左侧图标大小" @默认值 = 28>
    参数 左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 15>
    参数 右图标右侧间隔 <类型 = 整数 注释 = "右侧图标距离右侧边界距离" @默认值 = 12>
    参数 图标标题间隔 <类型 = 整数 注释 = "左侧图标与子夹标题间隔" @默认值 = 5>
    参数 图标隐藏方式 <类型 = 整数 注释 = "0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏" @默认值 = 0>
    参数 隐藏下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 下划线正常颜色 <类型 = 整数 @默认值 = 颜色类.红色>
    参数 下划线热点颜色 <类型 = 整数 @默认值 = 0xD9751E>
    参数 下划线位置 <类型 = 整数 注释 = "1、顶部 2、底部" @默认值 = 2>
    参数 默认显示关闭 <类型 = 逻辑型 注释 = "子夹右侧关闭按钮" @默认值 = 假>
    参数 显示子夹间隔 <类型 = 逻辑型 注释 = "显示子夹间间隔条" @默认值 = 真>
    参数 子夹间隔颜色 <类型 = 整数 注释 = "子夹间间隔条颜色" @默认值 = 颜色类.浅灰色>
    参数 子夹头是否透明 <类型 = 逻辑型 @默认值 = 假>
    参数 启用自定义指针 <类型 = 逻辑型 注释 = "启用内置定义的鼠标指针" @默认值 = 真>
    参数 正常指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 关闭指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 调节按钮指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    {
        删除所有子夹_ ()
        全局量.字体名称 = 字体名称
        全局量.字体大小 = 字体大小
        全局量.是否加粗 = 是否加粗
        全局量.对齐方式 = 标题对齐方式
        全局量.正常标题颜色 = 正常标题颜色
        全局量.热点标题颜色 = 热点标题颜色
        全局量.子夹正常背景颜色 = 子夹正常背景颜色
        按钮_左调.背景颜色 = 子夹正常背景颜色
        按钮_右调.背景颜色 = 子夹正常背景颜色
        全局量.子夹热点背景颜色 = 子夹热点背景颜色
        本对象.底色 = 子夹正常背景颜色
        组件布局器_头区.底色 = 子夹正常背景颜色
        图片框_头区.底色 = 子夹正常背景颜色
        全局量.下划线正常颜色 = 下划线正常颜色
        全局量.下划线热点颜色 = 下划线热点颜色
        全局量.下划线位置 = 下划线位置
        如果真 (左侧图标 != 空资源.空位图)
        {
            全局量.左侧图标 = 左侧图标
        }
        全局量.图标大小 = 图标大小
        全局量.左图标左侧间隔 = 左图标左侧间隔
        全局量.右图标右侧间隔 = 右图标右侧间隔
        全局量.图标标题间隔 = 图标标题间隔
        全局量.图标隐藏方式 = 图标隐藏方式
        全局量.隐藏下划线 = 隐藏下划线
        全局量.默认显示关闭 = 默认显示关闭
        全局量.显示子夹间隔 = 显示子夹间隔
        全局量.子夹间隔颜色 = 子夹间隔颜色
        全局量.子夹头是否透明 = 子夹头是否透明
        全局量.启用自定义指针 = 启用自定义指针
        如果 (启用自定义指针)
        {
            本对象.自定义鼠标指针 = 正常指针
            如果 (正常指针 == 空资源.空鼠标指针)
            {
                全局量.临时鼠标指针1 = 全局量.鼠标指针1
            }
            否则
            {
                全局量.临时鼠标指针1 = 正常指针
            }
            如果 (关闭指针 == 空资源.空鼠标指针)
            {
                全局量.临时鼠标指针2 = 全局量.鼠标指针2
            }
            否则
            {
                全局量.临时鼠标指针2 = 关闭指针
            }
            如果 (调节按钮指针 == 空资源.空鼠标指针)
            {
                按钮_左调.自定义鼠标指针 = 全局量.鼠标指针3
                按钮_右调.自定义鼠标指针 = 全局量.鼠标指针3
            }
            否则
            {
                按钮_左调.自定义鼠标指针 = 调节按钮指针
                按钮_右调.自定义鼠标指针 = 调节按钮指针
            }
        }
    }

    方法 添加子夹_ <公开 类型 = 整数 返回值注释 = "返回子夹索引" 折叠>
    参数 子夹标题 <类型 = 文本型>
    参数 子夹图标 <类型 = 位图资源 注释 = "默认为内置图标" @默认值 = 空资源.空位图>
    参数 子夹标记 <类型 = 文本型 注释 = "定义一个标记值" @默认值 = "">
    参数 提示信息 <类型 = 文本型 注释 = "定义一个鼠标停留时的提示" @默认值 = "">
    参数 子夹宽度补充 <类型 = 整数 注释 = "额外加宽子夹宽度" @默认值 = 10>
    {
        变量 临时索引 <类型 = 整数>
        变量 文本尺寸 <类型 = 整数>
        变量 临时左边 <类型 = 整数>
        变量 正常指针 <类型 = 鼠标指针资源 值 = "..\\tb\\正常.cur">
        变量 关闭指针 <类型 = 鼠标指针资源 值 = "..\\tb\\关闭.cur">
        如果真 (全局量.当前子夹索引 > -1)
        {
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).图片框_下划条.可视 = 假
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).图片框_根容器.背景颜色 = 全局量.子夹正常背景颜色
        }
        临时索引 = 子夹布局组.加入新成员 (导航夹模板)
        ((导航夹模板)子夹布局组.取成员 (临时索引)).初始化 (全局量.是否锁定, 全局量.是否锁死, 全局量.字体名称, 全局量.字体大小, 全局量.是否加粗, 全局量.正常标题颜色, 全局量.子夹正常背景颜色, 全局量.图标隐藏方式, 全局量.左图标左侧间隔, 全局量.右图标右侧间隔, 全局量.图标大小, 全局量.图标标题间隔, 全局量.显示子夹间隔, 全局量.默认显示关闭, 全局量.下划线正常颜色, 全局量.下划线位置, 全局量.子夹间隔颜色, 临时索引, 全局量.子夹热点背景颜色, 全局量.子夹头是否透明)
        如果 (全局量.图标隐藏方式 == 0)
        {
            文本尺寸 = 文本_取文本像素宽度 (子夹标题, 全局量.字体大小, 2) + 全局量.图标大小 + 全局量.左图标左侧间隔 + 全局量.图标标题间隔 * 2 + 18
        }
        否则 (全局量.图标隐藏方式 == 1)
        {
            文本尺寸 = 文本_取文本像素宽度 (子夹标题, 全局量.字体大小, 2) + 全局量.图标标题间隔 * 2 + 18
        }
        否则 (全局量.图标隐藏方式 == 2)
        {
            文本尺寸 = 文本_取文本像素宽度 (子夹标题, 全局量.字体大小, 2) + 全局量.图标大小 + 全局量.左图标左侧间隔 + 全局量.图标标题间隔 * 2 + 18
        }
        否则
        {
            文本尺寸 = 文本_取文本像素宽度 (子夹标题, 全局量.字体大小, 2) + 全局量.图标标题间隔 * 2
        }
        文本尺寸 = 文本尺寸 + 子夹宽度补充 + 全局量.右图标右侧间隔
        全局量.子夹总宽 = 全局量.子夹总宽 + 文本尺寸
        临时左边 = 取最后子夹位置 ()
        ((导航夹模板)子夹布局组.取成员 (临时索引)).可视 = 假
        ((导航夹模板)子夹布局组.取成员 (临时索引)).创建容器组件 (图片框_头区, 3000, 0)
        ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.标题 = 子夹标题
        如果 (全局量.对齐方式 == 0)
        {
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.左边
        }
        否则
        {
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.居中
        }
        ((导航夹模板)子夹布局组.取成员 (临时索引)).左边 = 临时左边
        ((导航夹模板)子夹布局组.取成员 (临时索引)).顶边 = 0
        ((导航夹模板)子夹布局组.取成员 (临时索引)).宽度 = 文本尺寸
        ((导航夹模板)子夹布局组.取成员 (临时索引)).高度 = 本对象.高度
        ((导航夹模板)子夹布局组.取成员 (临时索引)).排版子夹 (子夹图标, 子夹标记, 临时索引, 提示信息, 全局量.左侧图标)
        如果 (全局量.启用自定义指针)
        {
            如果 (全局量.临时鼠标指针1 == 空资源.空鼠标指针)
            {
                正常指针 = 全局量.鼠标指针1
            }
            如果 (全局量.临时鼠标指针2 == 空资源.空鼠标指针)
            {
                关闭指针 = 全局量.鼠标指针2
            }
            ((导航夹模板)子夹布局组.取成员 (临时索引)).自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_根容器.自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_左图.自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_右图.自定义鼠标指针 = 关闭指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_右图2.自定义鼠标指针 = 关闭指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_竖条.自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_根容器.自定义鼠标指针 = 正常指针
            ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_下划条.自定义鼠标指针 = 正常指针
        }
        如果真 (全局量.隐藏下划线)
        {
            ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_下划条.宽度 = 0
        }
        如果真 (全局量.当前子夹索引 == -1)
        {
            全局量.当前子夹索引 = 0
        }
        原子索引 = 临时索引
        如果真 (原子索引 != 全局量.当前子夹索引)
        {
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).图片框_下划条.可视 = 假
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).图片框_下划条.背景颜色 = 全局量.下划线正常颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).图片框_根容器.背景颜色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).标签_标题.背景颜色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).标签_左图.背景颜色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).标签_右图.背景颜色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).标签_右图2.背景颜色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).底色 = 全局量.子夹正常背景颜色
            ((导航夹模板)子夹布局组.取成员 (全局量.当前子夹索引)).标签_标题.文本颜色 = 全局量.正常标题颜色
        }
        如果真 (全局量.是否跟随热点)
        {
            如果真 (全局量.隐藏下划线 == 假)
            {
                ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_下划条.可视 = 真
                ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_下划条.背景颜色 = 全局量.下划线热点颜色
            }
            ((导航夹模板)子夹布局组.取成员 (临时索引)).图片框_根容器.背景颜色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.背景颜色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_左图.背景颜色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_右图.背景颜色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_右图2.背景颜色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).底色 = 全局量.子夹热点背景颜色
            ((导航夹模板)子夹布局组.取成员 (临时索引)).标签_标题.文本颜色 = 全局量.热点标题颜色
        }
        全局量.当前子夹索引 = 临时索引
        挂接事件 ((导航夹模板)子夹布局组.取成员 (临时索引))
        如果 (全局量.子夹总宽 > 取用户区宽度 () - 按钮_左调.宽度 * 2 - 5)
        {
            图片框_头区.左边 = 取用户区宽度 () - 按钮_左调.宽度 * 2 - 5 - 全局量.子夹总宽
        }
        如果真 (全局量.子夹总宽 > 组件布局器_头区.宽度)
        {
            按钮_左调.可视 = 真
            按钮_右调.可视 = 真
        }
        重置临时索引 (临时索引)
        调整间隔条 ()
        如果真 (全局量.是否跟随热点)
        {
            调整间隔条2 (临时索引)
        }
        处理事件_ ()
        ((导航夹模板)子夹布局组.取成员 (临时索引)).可视 = 真
        返回 (临时索引)
    }

    方法 锁定界面_ <公开 注释 = "锁定整个导航不允许操作" 折叠>
    参数 是否锁定 <类型 = 逻辑型 @默认值 = 真>
    {
        全局量.全局锁定界面 = 是否锁定
    }

    方法 置子夹名称_ <公开 类型 = 逻辑型 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    参数 子夹新标题 <类型 = 文本型>
    {
        如果真 (子夹索引 < 0)
        {
            返回 (假)
        }
        如果真 (子夹索引 > 子夹布局组.取成员数 () - 1)
        {
            返回 (假)
        }
        ((导航夹模板)子夹布局组.取成员 (子夹索引)).标签_标题.标题 = 子夹新标题
        返回 (假)
    }

    方法 置子夹字体大小_ <公开 注释 = "子夹标题字体" 折叠>
    参数 字体大小 <类型 = 整数 @默认值 = 9>
    {
        如果真 (字体大小 < 0)
        {
            字体大小 = 9
        }
        全局量.字体大小 = 字体大小
        子夹布局组.枚举循环 ()
        {
            ((导航夹模板)子夹布局组.取枚举值 ()).标签_标题.字体 = 全局量.字体名称 + "," + 到文本 (全局量.字体大小)
        }
    }

    方法 置子夹字体名称_ <公开 注释 = "子夹标题字体名称" 折叠>
    参数 字体名称 <类型 = 文本型 @默认值 = "宋体">
    {
        如果真 (字体名称 == "")
        {
            字体名称 = "宋体"
        }
        全局量.字体名称 = 字体名称
        子夹布局组.枚举循环 ()
        {
            ((导航夹模板)子夹布局组.取枚举值 ()).标签_标题.字体 = 全局量.字体名称 + "," + 到文本 (全局量.字体大小)
        }
    }

    方法 置子夹字体加粗_ <公开 注释 = "子夹标题字体加粗" 折叠>
    参数 是否加粗 <类型 = 逻辑型 @默认值 = 真>
    {
        全局量.是否加粗 = 是否加粗
        子夹布局组.枚举循环 ()
        {
            ((导航夹模板)子夹布局组.取枚举值 ()).标签_标题.字体 = 全局量.字体名称 + "," + 到文本 (全局量.字体大小) + "," + 到文本 (是否加粗)
        }
    }

    方法 置子夹标题颜色_ <公开 类型 = 逻辑型 注释 = "子夹标题文字颜色" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    参数 正常标题颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 热点标题颜色 <类型 = 整数 @默认值 = 颜色类.红色>
    {
        如果真 (子夹索引 < 0)
        {
            返回 (假)
        }
        如果真 (子夹索引 > 子夹布局组.取成员数 () - 1)
        {
            返回 (假)
        }
        全局量.正常标题颜色 = 正常标题颜色
        全局量.热点标题颜色 = 热点标题颜色
        子夹布局组.枚举循环 ()
        {
            ((导航夹模板)子夹布局组.取枚举值 ()).标签_标题.文本颜色 = 正常标题颜色
        }
        返回 (真)
    }

    方法 置子夹标记_ <公开 类型 = 逻辑型 注释 = "子夹标题文字颜色" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    参数 子夹标记 <类型 = 文本型>
    {
        如果真 (子夹索引 < 0)
        {
            返回 (假)
        }
        如果真 (子夹索引 > 子夹布局组.取成员数 () - 1)
        {
            返回 (假)
        }
        ((导航夹模板)子夹布局组.取成员 (子夹索引)).定义标记 = 子夹标记
        返回 (真)
    }

    方法 置子夹提示信息_ <公开 类型 = 逻辑型 注释 = "子夹鼠标停留提示" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    参数 提示信息 <类型 = 文本型 @默认值 = "">
