    方法 置边框背景颜色_ <公开 折叠>
    参数 颜色 <类型 = 整数 注释 = "窗口上下左右边框颜色" @默认值 = 0x804000>
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        全局量.边框背景颜色 = 颜色
        图片框_底栏.背景颜色 = 颜色
        循环 (12, 标签组.取成员数 (), i)
        {
            临时标签 = (标签)标签组.取成员 (i)
            临时标签.背景颜色 = 颜色
        }
        循环 (, 标签组2.取成员数 (), i)
        {
            临时标签 = (标签)标签组2.取成员 (i)
            临时标签.背景颜色 = 颜色
        }
    }

    方法 置边框尺寸_ <公开 折叠>
    参数 上边框高度 <类型 = 整数 @默认值 = 42>
    参数 下边框高度 <类型 = 整数 @默认值 = 22>
    参数 左右边框宽度 <类型 = 整数 @默认值 = 2>
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        全局量.上边框高度 = 上边框高度
        全局量.下边框高度 = 下边框高度
        全局量.左右边框宽度 = 左右边框宽度
        如果真 (全局量.控件图标高度 > 上边框高度)
        {
            全局量.控件图标高度 = 上边框高度
        }
        临时标签 = (标签)标签组.取成员 (20)
        临时标签.高度 = 上边框高度
        如果 (i > 14 && i < 20)
        {
            临时标签 = (标签)标签组.取成员 (i)
            如果 (i == 15)
            {
                如果真 (全局量.控件是否居中)
                {
                    临时标签.顶边 = (上边框高度 - 全局量.控件图标高度) / 2
                }
            }
            否则 (i == 16)
            {
                如果真 (全局量.控件是否居中)
                {
                    临时标签.顶边 = (上边框高度 - 全局量.控件图标高度) / 2
                }
            }
            否则 (i == 17)
            {
                如果真 (全局量.控件是否居中)
                {
                    临时标签.顶边 = (上边框高度 - 全局量.控件图标高度) / 2
                }
            }
            否则 (i == 18)
            {
                如果真 (全局量.控件是否居中)
                {
                    临时标签.顶边 = (上边框高度 - 全局量.控件图标高度) / 2
                }
            }
            否则 (i == 19)
            {
                如果真 (全局量.控件是否居中)
                {
                    临时标签.顶边 = (上边框高度 - 全局量.控件图标高度) / 2
                }
            }
        }
        匹配尺寸_ ()
    }

