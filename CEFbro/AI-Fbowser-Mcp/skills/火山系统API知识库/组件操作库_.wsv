    方法 删除子夹_ <公开 类型 = 逻辑型 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    {
        变量 临时尺寸 <类型 = 整数>
        变量 子夹标题 <类型 = 文本型>
        变量 子夹标记 <类型 = 文本型>
        变量 临时左 <类型 = 整数>
        如果真 (全局量.全局锁定界面)
        {
            返回 (假)
        }
        如果真 (子夹索引 < 0)
        {
            返回 (假)
        }
        如果真 (子夹索引 > 子夹布局组.取成员数 () - 1)
        {
            返回 (假)
        }
        临时尺寸 = ((导航夹模板)子夹布局组.取成员 (子夹索引)).宽度
        如果真 (临时尺寸 == 0)
        {
            返回 (假)
        }
        如果 (((导航夹模板)子夹布局组.取成员 (子夹索引)).全局是否锁定)
        {
            返回 (假)
        }
        禁止重画 ()
        全局量.子夹总宽 = 全局量.子夹总宽 - 临时尺寸
        如果真 (全局量.子夹总宽 < 0)
        {
            全局量.子夹总宽 = 0
        }
        子夹标记 = ((导航夹模板)子夹布局组.取成员 (子夹索引)).定义标记
        子夹标题 = ((导航夹模板)子夹布局组.取成员 (子夹索引)).标签_标题.标题
        ((导航夹模板)子夹布局组.取成员 (子夹索引)).销毁 ()
        子夹布局组.删除成员 (子夹索引)
        子夹布局组.枚举循环 ()
        {
            ((导航夹模板)子夹布局组.取枚举值 ()).当前索引 = 对象数组类.取枚举索引 ()
            ((导航夹模板)子夹布局组.取枚举值 ()).左边 = 临时左
            临时左 = ((导航夹模板)子夹布局组.取枚举值 ()).左边 + ((导航夹模板)子夹布局组.取枚举值 ()).宽度
        }
        如果 (子夹索引 <= 全局量.当前子夹索引)
        {
            全局量.当前子夹索引 = 全局量.当前子夹索引 - 1
            重置临时索引 (全局量.当前子夹索引)
        }
        如果 (子夹索引 > 0)
        {
            临时尺寸 = ((导航夹模板)子夹布局组.取成员 (子夹布局组.取成员数 () - 1)).左边 + 图片框_头区.左边 + ((导航夹模板)子夹布局组.取成员 (子夹布局组.取成员数 () - 1)).宽度
            如果 (临时尺寸 < 组件布局器_头区.宽度)
            {
                调整合适位置_移动 (2)
            }
        }
        否则
        {
            图片框_头区.左边 = 0
        }
        调节区状态 ()
        调整间隔条 ()
        允许重画 ()
        如果真 (全局量.确认关闭 == 假)
        {
            子夹被关闭事件 (子夹标题, 子夹标记, 子夹索引, 假)
        }
        返回 (真)
    }

    方法 删除所有子夹_ <公开 折叠>
    {
        变量 删除组 <类型 = 整数数组类>
        变量 数量 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        如果真 (全局量.全局锁定界面)
        {
            返回
        }
        禁止重画 ()
        子夹布局组.枚举循环 ()
        {
            如果 (((导航夹模板)子夹布局组.取枚举值 ()).全局是否锁定 == 假)
            {
                删除组.加入成员 (对象数组类.取枚举索引 ())
                ((导航夹模板)子夹布局组.取枚举值 ()).销毁 ()
            }
        }
        如果 (子夹布局组.取成员数 () == 删除组.取成员数 ())
        {
            全局量.当前子夹索引 = -1
            重置临时索引 (-1)
            子夹布局组.删除所有成员 ()
            图片框_头区.左边 = 0
            按钮_左调.可视 = 假
            按钮_右调.可视 = 假
            全局量.子夹总宽 = 0
        }
        否则
        {
            全局量.当前子夹索引 = 子夹布局组.取成员数 () - 删除组.取成员数 () - 1
            重置临时索引 (全局量.当前子夹索引)
            数量 = 删除组.取成员数 ()
            循环 (, 数量, i)
            {
                i2 = 删除组.取成员 (数量 - i - 1)
                子夹布局组.删除成员 (i2)
            }
            全局量.子夹总宽 = 0
            子夹布局组.枚举循环 ()
            {
                全局量.子夹总宽 = 全局量.子夹总宽 + ((导航夹模板)子夹布局组.取枚举值 ()).宽度
            }
            调整间隔条 ()
            图片框_头区.左边 = 0
            按钮_左调.可视 = 假
            按钮_右调.可视 = 假
            调节区状态 ()
        }
        允许重画 ()
    }

