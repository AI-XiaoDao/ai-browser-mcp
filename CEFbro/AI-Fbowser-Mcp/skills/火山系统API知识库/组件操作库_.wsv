# //====

类 表格辅助类_ <公开 折叠 折叠2 @文档 = "category = \"组件操作库.表格辅助库\"" @全局类 = 真>
{
    变量 线程池 <类型 = 线程池类_>
    变量 "//临时表格2" <类型 = 表格>
    变量 临时列表2 <类型 = 超级列表框>
    变量 临时数据1 <类型 = 文本型>
    变量 临时数据2 <类型 = 文本型>
    变量 全局导出类型 <静态 类型 = 整数>
    变量 行数 <静态 类型 = 整数>
    变量 列数 <静态 类型 = 整数>

    方法 类_初始化 <折叠>
    {
        线程池.创建线程池_ (2)
    }

    方法 禁止超级列表框闪烁_ <公开 静态 折叠>
    参数 超级列表 <类型 = 超级列表框>
    {
        超级列表.发送信息 (4150, 0, 连续位或 (65536, 32, 3))
    }

    方法 禁止超级列表框闪烁2_ <公开 静态 折叠 @禁止流程检查 = 真>
    参数 超级列表 <类型 = 超级列表框>
    {
        @ SendMessage(@<超级列表>.GetWTLWndPtr ()->m_hWnd, LVM_SETEXTENDEDLISTVIEWSTYLE, LVS_EX_DOUBLEBUFFER, LVS_EX_DOUBLEBUFFER);
    }

    方法 超级列表框自适应列宽_ <公开 静态 折叠>
    参数 超级列表 <类型 = 超级列表框>
    参数 指定列 <类型 = 整数>
    {
        超级列表.发送信息 (4126, 指定列, -2)
    }

    方法 导入Excel到表格_ <公开 静态 注释 = "速度快" 折叠>
    参数 文件路径 <类型 = 文本型 注释 = "可以为Access，或Excel">
    参数 文件密码 <类型 = 文本型 注释 = "Access文件专用" @默认值 = "">
    参数 文件类型 <类型 = 整数 注释 = "1、Access　2、Excel" @默认值 = 1>
    参数 是否新版 <类型 = 逻辑型 注释 = "本参数指定Access或Excel版本,为假则使用2003以下连接方式,为真则使用2007版本连接方式." @默认值 = 真>
    参数 绑定组件 <类型 = 窗口组件 注释 = "可以为表格，也可为超级列表框">
    参数 表格名 <类型 = 文本型 注释 = "Access或Excel中的表名称" @默认值 = "">
    参数 表格列宽 <类型 = 整数数组类 注释 = "默认为70，成员数量必须与字段数量一致；\"表格\"类型专用" @默认值 = 空对象>
    参数 导入类型 <类型 = 整数 注释 = "1、表格　2、超级列表框　　暂不支持表格" @默认值 = 1>
    参数 筛选条件 <类型 = 文本型 注释 = "即用sql查询语句选取所需数据，例如：\"SELECT * FROM 商品表 WHERE 拼音码 =\'yqkl\'\" ；"
            注释 = "Excel需要这样：\"SELECT * FROM [商品表$] WHERE 拼音码 =\'yqkl\'\" ；" 注释 = "设置了本条件，“表格名”参数可以为空" 折叠2 @默认值 = "">
    {
        变量 数据库1 <类型 = 数据库类_ "">
        变量 记录集1 <类型 = 记录集类_>
        变量 字段组 <类型 = 文本数组类>
        变量 "//临时表格" <类型 = 表格>
        变量 临时列表 <类型 = 超级列表框>
        变量 数量 <类型 = 整数>
        变量 条件 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        绑定组件.禁止重画 ()
        如果真 (文件类型 > 2 || 文件类型 < 1)
        {
            文件类型 = 1
        }
        如果 (文件类型 == 1)
        {
            如果 (筛选条件 == "")
            {
                条件 = 表格名
            }
            否则
            {
                条件 = 筛选条件
            }
            数据库1.连接Access (文件路径, 文件密码, 是否新版, 假)
            记录集1.执行 (条件, 数据库1)
        }
        否则
        {
            如果 (筛选条件 == "")
            {
                条件 = "[" + 表格名 + "$]"
            }
            否则
            {
                条件 = 筛选条件
            }
            数据库1.连接Excel (文件路径, 是否新版, 假)
            记录集1.执行 (条件, 数据库1)
        }
        如果真 (记录集1.记录数量 > 0)
        {
            字段组 = 记录集1.取所有字段名 (记录集1)
            数量 = 表格列宽.取成员数 ()
            如果真 (数量 != 字段组.取成员数 ())
            {
                数量 = 0
            }
            如果真 (导入类型 > 2 || 导入类型 < 1)
            {
                导入类型 = 1
            }
            如果 (导入类型 == 1)
            {
                // 临时表格 = (表格)绑定组件
                // 临时表格.清空数据 ()
                // 临时表格.行数 = 记录集1.记录数量 + 1
                // 字段组.枚举循环 ()
                {
                    // 临时表格.置数据 (0, 字段组.取枚举索引 (), 1, 字段组.取枚举值 ())
                    // 如果 (数量 > 0)
                    {
                        // 临时表格.置列宽 (字段组.取枚举索引 (), 表格列宽.取成员 (字段组.取枚举索引 ()))
                    }
                    // 否则
                    {
                        // 临时表格.置列宽 (字段组.取枚举索引 (), 70)
                    }
                }
                // 记录集1.到首记录 ()
                // 判断循环 (记录集1.尾记录后 == 假)
                {
                    // i2 = i2 + 1
                    // 循环 (, 字段组.取成员数 (), i)
                    {
                        // 临时表格.置数据 (i2, i, 1, 记录集1.读索引文本数据 (i))
                    }
                    // 记录集1.到下一行 ()
                }
            }
            否则
            {
                临时列表 = (超级列表框)绑定组件
                临时列表.全部删除 ()
                记录集1.到首记录 ()
                判断循环 (记录集1.尾记录后 == 假)
                {
                    i2 = 临时列表.插入表项 ()
                    循环 (, 字段组.取成员数 (), i)
                    {
                        临时列表.置标题 (i2, i, 记录集1.读索引文本数据 (i))
                    }
                    记录集1.到下一行 ()
                }
            }
        }
        记录集1.关闭 ()
        数据库1.关闭 ()
        绑定组件.允许重画 ()
    }

    方法 导出到Excel_ <公开 静态 类型 = 逻辑型 注释 = "速度慢" 折叠>
    参数 绑定组件 <类型 = 窗口组件 注释 = "表格或超级列表框">
    参数 输出表名 <类型 = 文本型 注释 = "Excel中的保存表名">
    参数 导出类型 <类型 = 整数 注释 = "1、表格 2、超级列表框　　暂不支持表格" @默认值 = 2>
    {
        变量 Excel程序 <类型 = COM对象类>
        变量 Sheet对象 <类型 = COM对象类>
        变量 Cells对象 <类型 = COM对象类>
        变量 Range对象 <类型 = COM对象类>
        变量 Excel列 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        如果真 (导出类型 > 2 || 导出类型 < 1)
        {
            导出类型 = 1
        }
        如果真 (Excel程序.创建 ("Excel.Application") == 假)
        {
            返回 (假)
        }
        计次循环 (26)
        {
            Excel列.加入成员 (到文本 ((字符)(65 + 取循环索引 ())))
        }
        计次循环 (26)
        {
            i = 取循环索引 ()
            计次循环 (26)
            {
                Excel列.加入成员 (到文本 ((字符)(65 + i)) + 到文本 ((字符)(65 + 取循环索引 ())))
            }
        }
        Excel程序.写属性 ("visible", 真)
        Sheet对象 = Excel程序.读无参数对象型属性 ("Workbooks", COM对象类)
        Sheet对象 = Sheet对象.读无参数对象型属性 ("Add", COM对象类)
        Sheet对象 = Sheet对象.读无参数对象型属性 ("ActiveSheet", COM对象类)
        Sheet对象.写属性 ("Name", 输出表名)
        Cells对象 = Sheet对象.读无参数对象型属性 ("Cells", COM对象类)
        如果 (导出类型 == 1)
        {
            变量 "// 临时表格" <类型 = 表格>
            // 临时表格 = (表格)绑定组件
            // Range对象 = Cells对象.读对象型属性 ("Range", COM对象类, Excel列.取成员 (0) + "1", Excel列.取成员 (临时表格.列数 - 1) + 到文本 (临时表格.行数))
            // Range对象.写属性 ("NumberFormatLocal", "@")
            // 计次循环 (临时表格.行数)
            {
                // i2 = 取循环索引 ()
                // 计次循环 (临时表格.列数)
                {
                    // i = 取循环索引 ()
                    // Range对象 = Cells对象.读对象型属性 ("Range", COM对象类, Excel列.取成员 (i) + 到文本 (i2 + 1), Excel列.取成员 (i) + 到文本 (i2 + 1))
                    // Range对象.写属性 ("Value", 临时表格.取文本数据 (i2, i))
                }
            }
        }
        否则 (导出类型 == 2)
        {
            变量 临时列表 <类型 = 超级列表框>
            临时列表 = (超级列表框)绑定组件
            Range对象 = Cells对象.读对象型属性 ("Range", COM对象类, Excel列.取成员 (0) + "1", Excel列.取成员 (临时列表.取列数 () - 1) + 到文本 (临时列表.取表项数 () + 1))
            Range对象.写属性 ("NumberFormatLocal", "@")
            计次循环 (临时列表.取列数 ())
            {
                i = 取循环索引 ()
                Range对象 = Cells对象.读对象型属性 ("Range", COM对象类, Excel列.取成员 (i) + "1", Excel列.取成员 (i) + "1")
                Range对象.写属性 ("Value", 临时列表.取列标题 (i))
            }
            计次循环 (临时列表.取表项数 ())
            {
                i2 = 取循环索引 ()
                计次循环 (临时列表.取列数 ())
                {
                    i = 取循环索引 ()
                    Range对象 = Cells对象.读对象型属性 ("Range", COM对象类, Excel列.取成员 (i) + 到文本 (i2 + 2), Excel列.取成员 (i) + 到文本 (i2 + 2))
                    Range对象.写属性 ("Value", 临时列表.取标题 (i2, i))
                }
            }
        }
        Sheet对象.清除 ()
        Excel程序.无参数方法 ("Quit", 整数)
        Excel程序.清除 ()
        返回 (真)
    }

    方法 列名转数字_ <公开 静态 类型 = 整数 注释 = "将数字转为Excel工作中表列索引" 折叠>
    参数 列字母 <类型 = 文本型>
    {
        变量 数字 <类型 = 整数 值 = 0>
        变量 当前字符 <类型 = 文本型>
        变量 当前数字 <类型 = 整数>
        到大写 (列字母)
        计次循环 (取文本长度 (列字母))
        {
            当前字符 = 取文本中间 (列字母, 取循环索引 (), 1)
            当前数字 = (整数)取字符 (当前字符, 0) - (整数)'A' + 1
            数字 = 数字 * 26 + 当前数字
        }
        返回 (数字)
    }

    方法 数字转列名_ <公开 静态 类型 = 文本型 注释 = "将Excel工作中表列索引，转换为列字母" 折叠>
    参数 列索引 <类型 = 整数>
    {
        变量 当前字符 <类型 = 文本型>
        变量 当前数字 <类型 = 整数>
        判断循环 (列索引 > 0)
        {
            当前数字 = (整数)求余数 (列索引 - 1, 26)
            当前字符 = 到文本 ((字符)((整数)取字符 ("A", 0) + 当前数字)) + 当前字符
            列索引 = (列索引 - 1) / 26
        }
        返回 (当前字符)
    }

    方法 导出表格到Excel_ <公开 类型 = 逻辑型 注释 = "速度快" 折叠>
    参数 绑定组件 <类型 = 窗口组件 注释 = "表格或超级列表框">
    参数 输出表名 <类型 = 文本型 注释 = "Excel中的保存表名" @默认值 = "Sheet1">
    参数 导出类型 <类型 = 整数 注释 = "1、表格 2、超级列表框　　暂不支持表格" @默认值 = 2>
    参数 是否静默保存 <类型 = 逻辑型 @默认值 = 假>
    参数 文件保存位置 <类型 = 文本型 注释 = "例如：“C:\\\\表格.xlsx”。默认保存至桌面，以??.xlsx命令" @默认值 = "">
    {
        变量 Excel对象 <类型 = COM对象类>
        变量 Excel对象2 <类型 = COM对象类>
        变量 平均行数 <类型 = 整数>
        变量 尾行数 <类型 = 整数>
        置文本预分配字符数 (临时数据1, 609600)
        置文本预分配字符数 (临时数据2, 409600)
        全局导出类型 = 导出类型
        如果 (导出类型 == 1)
        {
            // 临时表格2 = (表格)绑定组件
            // 行数 = 临时表格2.行数
            // 列数 = 临时表格2.列数
        }
        否则 (导出类型 == 2)
        {
            临时列表2 = (超级列表框)绑定组件
            行数 = 临时列表2.取表项数 ()
            列数 = 临时列表2.取列数 ()
        }
        平均行数 = 行数 / 2
        尾行数 = 行数 - 平均行数
        线程池.启动线程池_ (0, 平均行数)
        线程池.启动线程池_ (1, 平均行数, 尾行数)
        判断循环 (线程池.取剩余线程数_ () > 0)
        {
            延迟_ (1)
        }
        加入文本 (临时数据1, 临时数据2)
        如果真 (Excel对象.创建 ("Excel.Application") == 假)
        {
            返回 (假)
        }
        Excel对象.写属性 ("visible", 取反 (是否静默保存))
        Excel对象2 = Excel对象.读无参数对象型属性 ("Workbooks", COM对象类)
        Excel对象2 = Excel对象2.读无参数对象型属性 ("Add", COM对象类)
        Excel对象2 = Excel对象2.读无参数对象型属性 ("ActiveSheet", COM对象类)
        Excel对象2.写属性 ("NumberFormatLocal", "@")
        Excel对象2.写属性 ("Name", 输出表名)
        置剪辑板文本 (临时数据1)
        Excel对象.对象型方法 ("Range", COM对象类, "A1", 数字转列名_ (列数) + 到文本 (行数 + 1)).写属性 ("NumberFormatLocal", "@")
        Excel对象.对象型方法 ("Range", COM对象类, "A1").无参数对象型方法 ("PasteSpecial", COM对象类)
        临时数据1 = ""
        临时数据2 = ""
        置剪辑板文本 ("")
        如果真 (是否静默保存 == 真)
        {
            如果真 (文件保存位置 == "")
            {
                文件保存位置 = 系统_取桌面路径 () + 输出表名 + ".xlsx"
            }
            Excel对象2.对象型方法 ("SaveAs", COM对象类, 文件保存位置)
            Excel对象.无参数方法 ("Quit", 整数)
        }
        Excel对象2.清除 ()
        Excel对象.清除 ()
        返回 (真)
    }

    方法 线程池类__线程池事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类_>
    参数 标记值 <类型 = 整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    参数 参数3 <类型 = 变整数>
    {
        变量 平均行数 <类型 = 整数>
        变量 尾行数 <类型 = 整数>
        变量 序 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        序 = (整数)参数1
        平均行数 = (整数)参数2
        尾行数 = (整数)参数3
        如果 (全局导出类型 == 1)
        {
            // 如果 (参数1 == 0)
            {
                // 循环 (, 平均行数, i)
                {
                    // 循环 (, 列数, i2)
                    {
                        // 加入文本 (临时数据1, 临时表格2.取文本数据 (i, i2) + "\t")
                    }
                    // 加入文本 (临时数据1, "\r\n")
                }
            }
            // 否则 (参数1 == 1)
            {
                // 循环 (, 尾行数, i)
                {
                    // 循环 (, 列数, i2)
                    {
                        // 加入文本 (临时数据2, 临时表格2.取文本数据 (i + 平均行数 * 序, i2) + "\t")
                    }
                    // 加入文本 (临时数据2, "\r\n")
                }
            }
        }
        否则
        {
            如果 (参数1 == 0)
            {
                循环 (, 临时列表2.取列数 (), i)
                {
                    加入文本 (临时数据1, 临时列表2.取列标题 (i) + "\t")
                }
                加入文本 (临时数据1, "\r\n")
                循环 (, 平均行数, i)
                {
                    循环 (, 列数, i2)
                    {
                        加入文本 (临时数据1, 临时列表2.取标题 (i, i2) + "\t")
                    }
                    加入文本 (临时数据1, "\r\n")
                }
            }
            否则 (参数1 == 1)
            {
                循环 (, 尾行数, i)
                {
                    循环 (, 列数, i2)
                    {
                        加入文本 (临时数据2, 临时列表2.取标题 (i + 平均行数 * 序, i2) + "\t")
                    }
                    加入文本 (临时数据2, "\r\n")
                }
            }
        }
        返回 (0)
    }
}

类 表格辅助类2_ <公开 折叠 折叠2 @文档 = "category = \"组件操作库.表格辅助库\"" @全局类 = 真>
{
    方法 导入Excel到表格2_ <公开 静态 注释 = "调用了libxl，速度最快" 折叠>
    参数 绑定组件 <类型 = 窗口组件 注释 = "表格或超级列表框">
    参数 导入类型 <类型 = 整数 注释 = "1、表格　2、超级列表框   暂不支持表格" @默认值 = 2>
    参数 文件来源 <类型 = 文本型 注释 = "Excel文件来源">
    参数 表格 <类型 = 文本型 注释 = "Excel中的表名称，留空则读取第一个表" @默认值 = "Sheet1">
    参数 是否包含表头 <类型 = 逻辑型 注释 = "当表数据的第一行为表头时，本参数设置为真，首行数据可当作表头导入显示" @默认值 = 假>
    参数 自动列宽 <类型 = 逻辑型 注释 = "按文件列宽自动匹配列宽。当本参数为假时，“固定列宽”设置才能生效" @默认值 = 真>
    参数 自动列宽2 <类型 = 逻辑型 注释 = "本参数为真时，将自动按内容匹配列宽。（\"自动列宽\"为真是按文件列宽）" @默认值 = 真>
    参数 固定列宽 <类型 = 整数 注释 = "当“自动列宽”为假时，本参数才能生效。默认-1本不改变列宽" @默认值 = -1>
    {
        变量 工作簿1 <类型 = XL工作簿类>
        变量 工作表1 <类型 = XL工作表类>
        变量 格式1 <类型 = XL格式类>
        变量 是否存在 <类型 = 逻辑型类>
        变量 扩展名 <类型 = 文本型>
        变量 列数 <类型 = 整数>
        变量 行数 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        绑定组件.禁止重画 ()
        扩展名 = 文件_取扩展名 (文件来源)
        如果 (到小写 (扩展名) == ".xls")
        {
            工作簿1.新建文件 (XL文件类型.XLS)
        }
        否则
        {
            工作簿1.新建文件 (XL文件类型.XLSX)
        }
        如果 (工作簿1.打开文件 (文件来源))
        {
            如果 (工作簿1.工作表数量 == 0)
            {
                调试输出 ("表格数量为0")
            }
            否则
            {
                工作表1 = 工作簿1.选择工作表2 (表格, 是否存在)
                如果真 (是否存在.值 == 假)
                {
                    如果 (工作簿1.工作表数量 == 0)
                    {
                        调试输出 ("表名不存在")
                        工作簿1.释放 ()
                        返回
                    }
                    否则
                    {
                        工作表1 = 工作簿1.选择工作表 (0)
                    }
                }
                行数 = 工作表1.结束使用行
                列数 = 工作表1.结束使用列
                如果 (导入类型 == 1)
                {
                    变量 "// 临时表格" <类型 = 表格>
                    // 临时表格 = (表格)绑定组件
                    // 临时表格.清空单元格数据 (1, 0, 1, 临时表格.列数 - 1)
                    // 如果 (是否包含表头)
                    {
                        // 临时表格.行数 = 行数
                    }
                    // 否则
                    {
                        // 临时表格.行数 = 行数 + 1
                    }
                    // 临时表格.列数 = 列数
                    // 如果真 (自动列宽2)
                    {
                        // 工作表1.置自动调整列宽区域 (工作表1.开始使用行, 工作表1.结束使用行, 工作表1.开始使用列, 工作表1.结束使用列 - 1)
                    }
                    // 计次循环 (行数)
                    {
                        // i = 取循环索引 ()
                        // 循环 (, 列数, i2)
                        {
                            // 如果 (是否包含表头)
                            {
                                // 临时表格.置数据 (i, i2, 1, 工作表1.取单元格内容 (取循环索引 (), i2))
                            }
                            // 否则
                            {
                                // 临时表格.置数据 (i + 1, i2, 1, 工作表1.取单元格内容 (取循环索引 (), i2))
                            }
                            // 如果真 (取循环索引 () == 0)
                            {
                                // 如果 (自动列宽)
                                {
                                    // 临时表格.置列宽 (i2, 工作表1.取单元格列宽像素 (i2))
                                }
                                // 否则 (固定列宽 != -1)
                                {
                                    // 临时表格.置列宽 (i2, 固定列宽)
                                }
                            }
                        }
                    }
                }
                否则
                {
                    变量 临时列表 <类型 = 超级列表框>
                    变量 id <类型 = 整数>
                    临时列表 = (超级列表框)绑定组件
                    临时列表.全部删除 ()
                    如果 (列数 > 临时列表.取列数 ())
                    {
                        id = 列数 - 临时列表.取列数 ()
                    }
                    如果真 (自动列宽2)
                    {
                        工作表1.置自动调整列宽区域 (工作表1.开始使用行, 工作表1.结束使用行, 工作表1.开始使用列, 工作表1.结束使用列 - 1)
                    }
                    循环 (, 列数, i)
                    {
                        如果真 (id > i)
                        {
                            临时列表.插入列 ()
                        }
                        如果 (自动列宽)
                        {
                            临时列表.置列宽 (i, 工作表1.取单元格列宽像素 (i))
                        }
                        否则 (固定列宽 != -1)
                        {
                            临时列表.置列宽 (i, 固定列宽)
                        }
                        如果 (是否包含表头)
                        {
                            临时列表.置列标题 (i, 工作表1.取单元格内容 (0, i))
                        }
                    }
                    如果真 (列数 < 临时列表.取列数 ())
                    {
                        变量 临时数 <类型 = 整数>
                        临时数 = 临时列表.取列数 ()
                        计次循环 (临时数 - 列数)
                        {
                            临时列表.删除列 (临时数 - 取循环索引 () - 1)
                        }
                    }
                    如果 (是否包含表头)
                    {
                        行数 = 行数 - 1
                    }
                    计次循环 (行数)
                    {
                        i = 临时列表.插入表项 ()
                        循环 (, 列数, i2)
                        {
                            如果 (是否包含表头)
                            {
                                临时列表.置标题 (i, i2, 工作表1.取单元格内容 (取循环索引 () + 1, i2))
                            }
                            否则
                            {
                                临时列表.置标题 (i, i2, 工作表1.取单元格内容 (取循环索引 (), i2))
                            }
                        }
                    }
                }
            }
        }
        否则
        {
            调试输出 ("打开失败")
        }
        工作簿1.释放 ()
        绑定组件.允许重画 ()
    }

    方法 导出到Excel2_ <公开 静态 注释 = "调用了libxl，速度最快" 折叠>
    参数 绑定组件 <类型 = 窗口组件 注释 = "表格或超级列表框">
    参数 导出类型 <类型 = 整数 注释 = "1、表格 2、超级列表框   暂不支持表格" @默认值 = 2>
    参数 表名 <类型 = 文本型 注释 = "Excel中的表名称" @默认值 = "Sheet1">
    参数 字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 @默认值 = 10>
    参数 字体颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 水平对齐 <类型 = 整数 注释 = "0、常规 1、左对齐 2、居中 3、右对齐 4、两端对齐" @默认值 = 1>
    参数 垂直对齐 <类型 = 整数 注释 = "0、靠上对齐 1、居中 2、靠下对齐 3、两端对齐" @默认值 = 1>
    参数 显示边框线 <类型 = 逻辑型 @默认值 = 假>
    参数 自动换行 <类型 = 逻辑型 @默认值 = 真>
    参数 自动列宽 <类型 = 逻辑型 注释 = "按内容自动匹配列宽。当本参数为假时，“固定列宽”设置才能生效" @默认值 = 真>
    参数 固定列宽 <类型 = 整数 注释 = "按内容设置列宽。当“自动列宽”为假时，本参数才能生效" @默认值 = 15>
    参数 文件格式 <类型 = 整数 注释 = "Exce格式  1、xls 2、xlsx" @默认值 = 2>
    参数 保存位置 <类型 = 文本型 注释 = "导出的Excel存放路径及名称。默认为桌面+\"导出表\"+随机时间名+.xlsx" @默认值 = "">
    参数 导出后打开 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 工作簿1 <类型 = XL工作簿类>
        变量 工作表1 <类型 = XL工作表类>
        变量 字体1 <类型 = XL字体类>
        变量 格式1 <类型 = XL格式类>
        变量 表项数 <类型 = 整数>
        变量 列数 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        如果 (文件格式 == 1)
        {
            工作簿1.新建文件 (XL文件类型.XLS)
        }
        否则
        {
            工作簿1.新建文件 (XL文件类型.XLSX)
        }
        工作表1 = 工作簿1.添加工作表 (表名)
        字体1 = 工作簿1.添加字体 ()
        字体1.名称 = 字体名称
        字体1.尺寸 = 字体大小
        字体1.颜色 = 字体颜色
        格式1 = 工作簿1.添加格式 ()
        格式1.字体 = 字体1
        格式1.自动换行 = 自动换行
        如果 (水平对齐 == 0)
        {
            格式1.水平对齐 = XL水平对齐.常规
        }
        否则 (水平对齐 == 1)
        {
            格式1.水平对齐 = XL水平对齐.左对齐
        }
        否则 (水平对齐 == 2)
        {
            格式1.水平对齐 = XL水平对齐.居中对齐
        }
        否则 (水平对齐 == 3)
        {
            格式1.水平对齐 = XL水平对齐.右对齐
        }
        否则 (水平对齐 == 4)
        {
            格式1.水平对齐 = XL水平对齐.两端对齐
        }
        如果 (垂直对齐 == 0)
        {
            格式1.垂直对齐 = XL垂直对齐.靠上对齐
        }
        否则 (垂直对齐 == 1)
        {
            格式1.垂直对齐 = XL垂直对齐.居中对齐
        }
        否则 (垂直对齐 == 2)
        {
            格式1.垂直对齐 = XL垂直对齐.靠下对齐
        }
        否则 (垂直对齐 == 3)
        {
            格式1.垂直对齐 = XL垂直对齐.两端对齐
        }
        如果 (显示边框线)
        {
            格式1.边框样式 = XL边框样式.细线
        }
        否则
        {
            格式1.边框样式 = XL边框样式.无
        }
        如果 (导出类型 == 1)
        {
            变量 "// 临时表格" <类型 = 表格>
            // 临时表格 = (表格)绑定组件
            // 列数 = 临时表格.列数
            // 表项数 = 临时表格.行数
            // 循环 (, 表项数, i)
            {
                // 循环 (, 列数, i2)
                {
                    // 工作表1.置单元格文本 (i, i2, 临时表格.取文本数据 (i, i2), 格式1)
                }
            }
        }
        否则
        {
            变量 临时列表 <类型 = 超级列表框>
            临时列表 = (超级列表框)绑定组件
            列数 = 临时列表.取列数 ()
            表项数 = 临时列表.取表项数 ()
            循环 (, 列数, i)
            {
                工作表1.置单元格文本 (0, i, 临时列表.取列标题 (i), 格式1)
            }
            循环 (, 表项数, i)
            {
                循环 (, 列数, i2)
                {
                    工作表1.置单元格文本 (i + 1, i2, 临时列表.取标题 (i, i2), 格式1)
                }
            }
        }
        如果 (自动列宽)
        {
            工作表1.置自动调整列宽区域 (工作表1.开始使用行, 工作表1.结束使用行, 工作表1.开始使用列, 工作表1.结束使用列 - 1)
        }
        否则
        {
            工作表1.置单元格列宽 (工作表1.开始使用列, 工作表1.结束使用列 - 1, 固定列宽)
        }
        如果 (保存位置 == "")
        {
            如果 (文件格式 == 1)
            {
                保存位置 = 系统_取桌面路径 () + "导出表" + 时间到文本 (取现行时间 ()) + ".xls"
            }
            否则
            {
                保存位置 = 系统_取桌面路径 () + "导出表" + 时间到文本 (取现行时间 ()) + ".xlsx"
            }
            如果 (工作簿1.保存文件 (保存位置) == 假)
            {
                调试输出 ("保存失败")
            }
        }
        否则
        {
            如果真 (工作簿1.保存文件 (保存位置) == 假)
            {
                调试输出 ("保存失败")
            }
        }
        工作簿1.释放 ()
        如果真 (导出后打开)
        {
            执行_ (保存位置)
        }
    }
}

类 超级列表框辅助类_ <公开 注释 = "设置超级列表框行高度" 折叠 @文档 = "category = \"组件操作库.超列辅助库.附加类\"">
{
    变量 窗口信息 <类型 = 整数>
    变量 结构 <类型 = 超列结构类>
    变量 句柄组1 <类型 = 变整数数组类>
    变量 句柄组2 <类型 = 变整数数组类>

    方法 初始化_ <公开 类型 = 变整数 折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        超列属性类.窗口属性 = 超列Api类.SetWindowLongPtrW (窗口句柄, -4, 取静态方法地址 (WndProc))
        句柄组1.加入成员 (窗口句柄)
        句柄组2.加入成员 (超列属性类.窗口属性)
        返回 (超列属性类.窗口属性)
    }

    方法 卸载_ <公开 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 绑定句柄 <类型 = 变整数 注释 = "“初始化_”时所返回的句柄">
    {
        超列Api类.SetWindowLongPtrW (窗口句柄, -4, 绑定句柄)
    }

    方法 卸载所有_ <公开 折叠>
    {
        句柄组1.枚举循环 ()
        {
            卸载_ (句柄组1.取枚举值 (), 句柄组2.取枚举值 ())
        }
        句柄组1.删除所有成员 ()
        句柄组2.删除所有成员 ()
    }

    方法 置行高_ <公开 折叠>
    参数 超级列表框 <类型 = 超级列表框>
    参数 行高度 <类型 = 整数>
    {
        超列属性类.行高 = 行高度
        结构.hwnd = 超级列表框.取窗口句柄 ()
        窗口信息 = 超列Api类.GetWindowLongA (结构.hwnd, -16)
        超列Api类.SetWindowLongPtrW (结构.hwnd, -16, 位或 (窗口信息, 1024))
        超列Api类.SendMessageA2 (结构.hwnd, 71, 0, 结构)
        超列Api类.SetWindowLongPtrW (结构.hwnd, -16, 窗口信息)
        超列Api类.SendMessageA (结构.hwnd, 4138, 0, 0)
    }

    方法 WndProc <静态 类型 = 整数 折叠>
    参数 hwnd <类型 = 变整数>
    参数 msg <类型 = 整数>
    参数 wparam <类型 = 变整数>
    参数 lparam <类型 = 变整数>
    {
        如果真 (msg == 44)
        {
            内存_写内存整数2 (lparam + 16, 超列属性类.行高)
        }
        返回 (超列Api类.CallWindowProcA (超列属性类.窗口属性, hwnd, msg, wparam, lparam))
    }
}

类 超列Api类 <折叠 @文档 = "category = \"组件操作库.超列辅助库.附加类\"">
{
    方法 SetWindowLongPtrW <公开 静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 hWnd <类型 = 变整数>
    参数 nIndex <类型 = 整数>
    参数 dwNewLong <类型 = 变整数>
    {
        @ SetWindowLongPtrW((HWND)@<hWnd>,@<nIndex>,(LONG_PTR)@<dwNewLong>)
    }

    方法 SendMessageA <公开 静态 折叠>
    参数 hWnd <类型 = 变整数>
    参数 Msg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        @ SendMessage((HWND)@<hWnd>,@<Msg>,@<wParam>,@<lParam>);
    }

    方法 SendMessageA2 <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "SendMessageA" @视窗.输入 = "user32">
    参数 hWnd <类型 = 变整数>
    参数 Msg <类型 = 整数>
    参数 wParam <类型 = 整数>
    参数 lParam <类型 = 超列结构类>

    方法 SetWindowLongA <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "SetWindowLongA" @视窗.输入 = "user32.dll">
    参数 hWnd <类型 = 变整数>
    参数 nIndex <类型 = 整数>
    参数 dwNewLong <类型 = 变整数>

    方法 CallWindowProcA <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "CallWindowProcA" @视窗.输入 = "user32">
    参数 lpPrevWndFunc <类型 = 变整数>
    参数 hWnd <类型 = 变整数>
    参数 Msg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>

    方法 GetWindowLongA <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "GetWindowLongA" @视窗.输入 = "user32">
    参数 hWnd <类型 = 变整数>
    参数 nIndex <类型 = 整数>
}

类 超列结构类 <公开 折叠 折叠2 @文档 = "category = \"组件操作库.超列辅助库.附加类\"" @视窗.结构类 = 0>
{
    变量 hwnd <公开 类型 = 变整数>
    变量 hwndInsertAfter <公开 类型 = 变整数>
    变量 x <公开 类型 = 变整数>
    变量 y <公开 类型 = 变整数>
    变量 cx <公开 类型 = 变整数>
    变量 cy <公开 类型 = 变整数>
    变量 flags <公开 类型 = 变整数>
}

