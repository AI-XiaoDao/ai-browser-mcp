<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"组件操作库\"">

类 日期框样式类_ <公开 折叠 @全局类 = 真>
{
    方法 组件_置日期框样式 <公开 静态 折叠>
    参数 日期框 <类型 = 日期框>
    参数 时间样式 <类型 = 文本型 注释 = "日期格式文本：yy,yyyy(年)； M,MM(月)； d,dd(日) ；ddd(周几)； dddd(星期几)；"
            注释 = "时间格式文本：h,hh(12小时制)； H,HH(24小时制)； m,mm(分钟)； s,ss(秒)；" 注释 = "其它格式文本：tt(上午或下午)；"
            注释 = "例如：M/d、yy/M/d、yyyy/MM/dd、yyyy年MM月dd日、yyyy年MM月dd日 ddd、yyyy年MM月dd日 dddd、h:m、yyyy/MM/dd dddd HH:mm:ss等。" 折叠2
            @默认值 = "yyyy-MM-dd HH:mm:ss">
    {
        发送消息_ (日期框.取窗口句柄 (), 4101, 0, 文本到多字节 (时间样式).取字节集指针 ())
    }
}

# //====

类 截图类_ <公开 注释 = "本类只基于WTL或WTL使用" 折叠 @文档 = "category = \"组件操作库.截图操作\"">
{
    变量 截图窗1 <类型 = 截图窗>

    方法 弹出截图 <公开 类型 = 字节集类 返回值注释 = "返回截图数据" 折叠>
    参数 坐标颜色 <类型 = 整数 注释 = "坐标值显示颜色" @默认值 = 颜色类.白色>
    参数 线框颜色 <类型 = 整数 注释 = "截图线框颜色" @默认值 = 颜色类.蓝色>
    参数 线框背景色 <类型 = 整数 注释 = "" @默认值 = 0x383838>
    参数 提示颜色 <类型 = 整数 注释 = "双击提示颜色" @默认值 = 颜色类.天蓝色>
    参数 图片格式 <类型 = 整数 注释 = "返回图片数据类型　1、PNG　2、BMP　3、JPG　4、GIF" @默认值 = 1>
    参数 保存路径 <类型 = 文本型 注释 = "例如：“C:\\\\截图.png”；留空则不会自动保存图片" @默认值 = "">
    参数 隐藏提示 <类型 = 逻辑型 注释 = "隐藏双击提示" @默认值 = 假>
    参数 初始宽度 <类型 = 整数 注释 = "初始个截图框大小" @默认值 = 0>
    参数 初始高度 <类型 = 整数 注释 = "初始个截图框大小" @默认值 = 0>
    {
        截图配置类.坐标颜色 = 坐标颜色
        截图配置类.线框颜色 = 线框颜色
        截图配置类.提示颜色 = 提示颜色
        截图配置类.线框背景色 = 线框背景色
        截图配置类.图片格式 = 图片格式
        截图配置类.保存路径 = 保存路径
        截图配置类.隐藏提示 = 隐藏提示
        截图配置类.初始宽度 = 初始宽度
        截图配置类.初始高度 = 初始高度
        截图配置类.截图数据 = 快照_ (, , , , , , 2)
        截图窗1.创建对话框 (假, 0, 0, 取屏幕宽度 (), 取屏幕高度 ())
        返回 (截图配置类.截图数据)
    }
}

类 截图窗 <基础类 = 窗口 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"组件操作库.截图操作.附加类\"" @视窗.布局 = "client_size = \"600, 420\"" 总在最前 = 真
        位置 = 最大化 窗口边框 = 无边框 可视 = 假>
{
    变量 时钟1 <类型 = 时钟 折叠 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"72, 216, 26, 26\"">
    变量 画板1 <类型 = 画板 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"112, 72, 216, 136\"">
    变量 令牌 <类型 = 变整数>
    变量 GP图形 <类型 = GP图形类>
    变量 GP缓存图形 <类型 = GP缓存图形类>
    变量 GP位图 <类型 = GP位图类>
    变量 GP纯色画刷 <类型 = GP纯色画刷类>
    变量 GP画笔 <类型 = GP画笔类>
    变量 GP字体 <类型 = GP字体类>
    变量 左键 <类型 = 逻辑型>
    变量 起点x <类型 = 小数>
    变量 起点y <类型 = 小数>
    变量 起点1x <类型 = 小数>
    变量 起点1y <类型 = 小数>
    变量 点大小hw <类型 = 整数>
    变量 矩形_点 <类型 = 数组矩形F>
    变量 矩形_外 <类型 = 矩形F>
    变量 矩形内按下 <类型 = 逻辑型>
    变量 矩形内按下2 <类型 = 逻辑型>
    变量 当前点索引 <类型 = 整数>
    变量 移动中 <类型 = 逻辑型>
    变量 允许 <类型 = 逻辑型>

    方法 截图窗_创建完毕 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 截图窗>
    参数 标记值 <类型 = 整数>
    {
        令牌 = GP初始类.初始化GDI ()
        GP图形.创建自窗口句柄 (画板1.取窗口句柄 ())
        GP位图.创建自字节集 (截图配置类.截图数据)
        GP缓存图形.创建自图像 (GP位图)
        GP纯色画刷.创建 (GP颜色.到ARGB (截图配置类.坐标颜色))
        GP画笔.创建自颜色 (GP颜色.到ARGB (截图配置类.线框颜色), 1)
        GP缓存图形.画图像 (GP位图)
        GP字体.创建自名称 ("宋体", 12, , )
        点大小hw = 8
        GP缓存图形.复制到图形 (GP图形)
        时钟1.时钟周期 = 200
        返回 (0)
    }

    方法 截图窗_将被销毁 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 截图窗>
    参数 标记值 <类型 = 整数>
    {
        连续赋值 (假, 允许, 矩形内按下, 矩形内按下2, 移动中, 左键)
        连续赋值 (0, 起点x, 起点y, 起点1x, 起点1y, 点大小hw, 当前点索引)
        矩形_点.清空 ()
        矩形_外 = 矩形F.创建 (0, 0, 0, 0)
        GP图形.销毁 ()
        GP画笔.销毁 ()
        GP位图.销毁 ()
        GP字体.销毁 ()
        GP缓存图形.销毁 ()
        GP纯色画刷.销毁 ()
        GP初始类.卸载GDI (令牌)
        返回 (0)
    }

    方法 是否在矩形内 <类型 = 逻辑型 折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 x1 <类型 = 小数>
    参数 y1 <类型 = 小数>
    参数 x2 <类型 = 小数>
    参数 y2 <类型 = 小数>
    {
        变量 临时值 <类型 = 整数>
        临时值 = 5
        如果真 (横向位置 > x1 + 临时值 && 横向位置 < x1 + x2 - 临时值 && 纵向位置 > y1 + 临时值 && 纵向位置 < y1 + y2 - 临时值)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 画角点 <折叠>
    {
        如果真 (移动中 == 真)
        {
            返回
        }
        矩形_点.清空 ()
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2, 矩形_外.顶边 - 点大小hw / 2, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2 + 矩形_外.宽度 / 2, 矩形_外.顶边 - 点大小hw / 2, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2 + 矩形_外.宽度, 矩形_外.顶边 - 点大小hw / 2, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2 + 矩形_外.宽度, 矩形_外.顶边 - 点大小hw / 2 + 矩形_外.高度 / 2, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2 + 矩形_外.宽度, 矩形_外.顶边 - 点大小hw / 2 + 矩形_外.高度, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2 + 矩形_外.宽度 / 2, 矩形_外.顶边 - 点大小hw / 2 + 矩形_外.高度, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2, 矩形_外.顶边 - 点大小hw / 2 + 矩形_外.高度, 点大小hw, 点大小hw))
        矩形_点.添加 (矩形F.创建 (矩形_外.左边 - 点大小hw / 2, 矩形_外.顶边 - 点大小hw / 2 + 矩形_外.高度 / 2, 点大小hw, 点大小hw))
        GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.线框颜色))
        矩形_点.枚举循环 ()
        {
            GP缓存图形.画矩形 (GP画笔, 矩形_点.取枚举值 ().左边, 矩形_点.取枚举值 ().顶边, 矩形_点.取枚举值 ().宽度, 矩形_点.取枚举值 ().高度)
            GP缓存图形.填充矩形 (GP纯色画刷, 矩形_点.取枚举值 ().左边, 矩形_点.取枚举值 ().顶边, 矩形_点.取枚举值 ().宽度, 矩形_点.取枚举值 ().高度)
        }
    }

    方法 是否在矩形内_点 <类型 = 整数 折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        变量 i <类型 = 整数>
        如果真 (移动中 == 真)
        {
            返回 (0)
        }
        循环 (, (整数)矩形_点.取成员数 (), i)
        {
            如果真 (横向位置 > 矩形_点.取成员 (i).左边 && 横向位置 < 矩形_点.取成员 (i).左边 + 矩形_点.取成员 (i).宽度 && 纵向位置 > 矩形_点.取成员 (i).顶边 && 纵向位置 < 矩形_点.取成员 (i).顶边 + 矩形_点.取成员 (i).宽度)
            {
                返回 (i + 1)
            }
        }
        返回 (0)
    }

    方法 画矩形 <注释 = "调整1357角" 折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        如果 (横向位置 >= 起点x && 纵向位置 <= 起点y)  // 右上
        {
            矩形_外.左边 = 起点x
            矩形_外.顶边 = 纵向位置
            矩形_外.宽度 = 横向位置 - 起点x
            矩形_外.高度 = 起点y - 纵向位置
        }
        否则 (横向位置 >= 起点x && 纵向位置 >= 起点y)  // 右下
        {
            矩形_外.左边 = 起点x
            矩形_外.顶边 = 起点y
            矩形_外.宽度 = 横向位置 - 起点x
            矩形_外.高度 = 纵向位置 - 起点y
        }
        否则 (横向位置 <= 起点x && 纵向位置 <= 起点y)  // 左上
        {
            矩形_外.左边 = 横向位置
            矩形_外.顶边 = 纵向位置
            矩形_外.宽度 = 起点x - 横向位置
            矩形_外.高度 = 起点y - 纵向位置
        }
        否则 (横向位置 <= 起点x && 纵向位置 >= 起点y)  // 左下
        {
            矩形_外.左边 = 横向位置
            矩形_外.顶边 = 起点y
            矩形_外.宽度 = 起点x - 横向位置
            矩形_外.高度 = 纵向位置 - 起点y
        }
        GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.坐标颜色))
        GP缓存图形.画图像 (GP位图)
        GP缓存图形.画矩形 (GP画笔, 矩形_外.左边, 矩形_外.顶边, 矩形_外.宽度, 矩形_外.高度)
        画角点 ()
        画坐标提示 ()
        GP缓存图形.复制到图形 (GP图形)
    }

    方法 画坐标提示 <折叠>
    {
        变量 提示内容 <类型 = 文本型>
        变量 临时文本 <类型 = 文本型>
        变量 画笔 <类型 = GP画笔类>
        变量 画刷 <类型 = GP画刷类>
        临时文本 = ","
        GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.坐标颜色))
        提示内容 = 到文本 (矩形_外.左边) + 临时文本 + 到文本 (矩形_外.顶边) + 临时文本 + 到文本 (矩形_外.宽度) + 临时文本 + 到文本 (矩形_外.高度)
        画笔.创建自颜色 (GP颜色.到ARGB (截图配置类.线框背景色), 3)
        画笔.取画刷 (画刷)
        GP缓存图形.填充矩形 (画刷, 矩形_外.左边, 矩形_外.顶边 - GP字体.取高度 () - 点大小hw - 5, 105, GP字体.取高度 () + 5)
        GP缓存图形.画文本 (提示内容, GP字体, GP纯色画刷, 矩形F.创建 (矩形_外.左边 + 2, 矩形_外.顶边 - GP字体.取高度 () - 点大小hw, 105, 矩形_外.高度))
    }

    方法 画双击提示 <折叠>
    {
        如果真 (截图配置类.隐藏提示 == 假)
        {
            GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.提示颜色))
            GP缓存图形.画文本 ("双击完成", GP字体, GP纯色画刷, 矩形F.创建 (矩形_外.左边 + 10, 矩形_外.顶边 + 矩形_外.高度 - 20, 矩形_外.宽度, 矩形_外.高度))

        }
    }

    方法 画矩形_1 <折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 点索引 <类型 = 整数>
    {
        如果 (纵向位置 < 起点y && 点索引 != 4 && 点索引 != 8)
        {
            矩形_外.顶边 = 纵向位置
            矩形_外.高度 = 起点y - 纵向位置
        }
        否则 (纵向位置 > 起点y && 点索引 != 4 && 点索引 != 8)
        {
            矩形_外.顶边 = 起点y
            矩形_外.高度 = 纵向位置 - 起点y
        }
        否则 (横向位置 > 起点x && 点索引 != 2 && 点索引 != 6)
        {
            矩形_外.左边 = 起点x
            矩形_外.宽度 = 横向位置 - 起点x
        }
        否则 (横向位置 < 起点x && 点索引 != 2 && 点索引 != 6)
        {
            矩形_外.左边 = 横向位置
            矩形_外.宽度 = 起点x - 横向位置
        }
        GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.坐标颜色))
        GP缓存图形.画图像 (GP位图)
        GP缓存图形.画矩形 (GP画笔, 矩形_外.左边, 矩形_外.顶边, 矩形_外.宽度, 矩形_外.高度)
        画角点 ()
        画坐标提示 ()
        GP缓存图形.复制到图形 (GP图形)
    }

    方法 点角判断 <类型 = 逻辑型 注释 = "1左上、3右上、5右下、6左下" 折叠>
    参数 当前索引 <类型 = 整数>
    参数 点索引 <类型 = 整数数组类>
    {
        点索引.枚举循环 ()
        {
            如果真 (当前索引 == 点索引.取枚举值 ())
            {
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 画移动矩形 <折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        移动中 = 真
        GP纯色画刷.置颜色 (GP颜色.到ARGB (截图配置类.坐标颜色))
        GP缓存图形.画图像 (GP位图)
        GP缓存图形.画矩形 (GP画笔, 横向位置 - 起点1x, 纵向位置 - 起点1y, 矩形_外.宽度, 矩形_外.高度)
        // 画角点 ()
        画坐标提示 ()
        GP缓存图形.复制到图形 (GP图形)
    }

    方法 截图窗_尺寸被改变 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 截图窗>
    参数 标记值 <类型 = 整数>
    {
        移动 (0, 0)
        画板1.移动 (0, 0, 取屏幕宽度 (), 取屏幕高度 ())
        返回 (0)
    }

    方法 时钟_周期事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟>
    参数 标记值 <类型 = 整数>
    {
        时钟1.时钟周期 = 0
        允许 = 真
        返回 (0)
    }

    方法 画板_绘画 <接收事件 类型 = 整数 注释 = "当画板中的全部或一部分区域需要被重新绘制时即产生此事件." 注释 = "用户程序在响应此事件期间在画板上所进行的任何绘制操作均被限制在\"重画区\"参数所指定的区域内." 折叠 折叠2>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 重画区 <类型 = 矩形类 注释 = "提供目前画板中需要更新的矩形区域,使用画板的现行绘画单位,相对画板用户区的左上角." 注释 = "用作在绘制过程中跳过不需要绘制的部分以提高速度,一般情况下可以不处理.">
    {
        GP缓存图形.复制到图形 (GP图形)
        可视 = 真
        返回 (0)
    }

    方法 画板_鼠标左键被按下 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (截图配置类.初始宽度 > 0 && 截图配置类.初始高度 > 0)
        {
            起点x = 取鼠标水平位置 () - 12
            起点y = 取鼠标垂直位置 () - 12
            画矩形 (横向位置 + 截图配置类.初始宽度 - 12, 纵向位置 + 截图配置类.初始高度 - 12)
            连续赋值 (0, 截图配置类.初始宽度, 截图配置类.初始高度)
        }
        移动中 = 假
        左键 = 真
        如果 (是否在矩形内 (横向位置, 纵向位置, 矩形_外.左边, 矩形_外.顶边, 矩形_外.宽度, 矩形_外.高度))
        {
            矩形内按下 = 真
            矩形内按下2 = 真
            起点1x = 横向位置 - 矩形_外.左边
            起点1y = 纵向位置 - 矩形_外.顶边
        }
        否则
        {
            当前点索引 = 是否在矩形内_点 (横向位置, 纵向位置)
            矩形内按下2 = 假
            如果 (当前点索引 == 1)
            {
                起点x = 矩形_外.左边 + 矩形_外.宽度
                起点y = 矩形_外.顶边 + 矩形_外.高度
            }
            否则 (当前点索引 == 2)
            {
                起点x = 矩形_外.左边
                起点y = 矩形_外.顶边 + 矩形_外.高度
            }
            否则 (当前点索引 == 3)
            {
                起点x = 矩形_外.左边
                起点y = 矩形_外.顶边 + 矩形_外.高度
            }
            否则 (当前点索引 == 4)
            {
                起点x = 矩形_外.左边
                起点y = 矩形_外.顶边
            }
            否则 (当前点索引 == 5)
            {
                起点x = 矩形_外.左边
                起点y = 矩形_外.顶边
            }
            否则 (当前点索引 == 6)
            {
                起点x = 矩形_外.左边
                起点y = 矩形_外.顶边
            }
            否则 (当前点索引 == 7)
            {
                起点x = 矩形_外.左边 + 矩形_外.宽度
                起点y = 矩形_外.顶边
            }
            否则 (当前点索引 == 8)
            {
                起点x = 矩形_外.左边 + 矩形_外.宽度
                起点y = 矩形_外.顶边
            }
            否则
            {
                起点x = 横向位置
                起点y = 纵向位置
            }
        }
        返回 (0)
    }

    方法 画板_鼠标左键被放开 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        移动中 = 假
        画角点 ()
        左键 = 假
        矩形内按下 = 假
        矩形内按下2 = 真
        当前点索引 = 0
        画双击提示 ()
        GP缓存图形.复制到图形 (GP图形)
        返回 (0)
    }

    方法 画板_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        变量 i <类型 = 整数>
        标题 = 到文本 (横向位置) + " , " + 到文本 (纵向位置)
        如果真 (左键 && 矩形内按下 == 假 && 当前点索引 == 0)
        {
            画矩形 (横向位置, 纵向位置)
        }
        如果真 (左键 && 矩形内按下 == 真)
        {
            画移动矩形 (横向位置, 纵向位置)
            矩形_外.左边 = 横向位置 - 起点1x
            矩形_外.顶边 = 纵向位置 - 起点1y
        }
        i = 是否在矩形内_点 (横向位置, 纵向位置)
        如果真 (允许 == 真)
        {
            如果 (i > 0)
            {
                如果 (i == 1)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北西箭头型
                }
                否则 (i == 2)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北南箭头型
                }
                否则 (i == 3)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北东箭头型
                }
                否则 (i == 4)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.西东箭头型
                }
                否则 (i == 5)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北西箭头型
                }
                否则 (i == 6)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北南箭头型
                }
                否则 (i == 7)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.北东箭头型
                }
                否则 (i == 8)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.西东箭头型
                }
                否则
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                }
            }
            否则
            {
                如果 (是否在矩形内 (横向位置, 纵向位置, 矩形_外.左边, 矩形_外.顶边, 矩形_外.宽度, 矩形_外.高度) && 矩形内按下 == 真)
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.手型
                }
                否则
                {
                    画板1.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                }
            }
        }
        如果真 (当前点索引 > 0)
        {
            如果 (点角判断 (当前点索引, 创建数组类_ (整数数组类, 1, 3, 5, 7)))
            {
                画矩形 (横向位置, 纵向位置)
            }
            否则
            {
                画矩形_1 (横向位置, 纵向位置, 当前点索引)
            }
        }
        返回 (0)
    }

    方法 画板_鼠标右键被放开 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        销毁 ()
        返回 (0)
    }

    方法 画板_被双击 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        变量 GP位图2 <类型 = GP位图类>
        GP位图.克隆位图 (矩形_外, GP像素格式._32bppARGB, GP位图2)
        如果 (截图配置类.图片格式 == 1)
        {
            GP位图2.保存到字节集 (截图配置类.截图数据, GP图像格式.PNG)
        }
        否则 (截图配置类.图片格式 == 2)
        {
            GP位图2.保存到字节集 (截图配置类.截图数据, GP图像格式.BMP)
        }
        否则 (截图配置类.图片格式 == 3)
        {
            GP位图2.保存到字节集 (截图配置类.截图数据, GP图像格式.JPEG)
        }
        否则
        {
            GP位图2.保存到字节集 (截图配置类.截图数据, GP图像格式.GIF)
        }
        如果真 (截图配置类.保存路径 != "")
        {
            写到文件 (截图配置类.保存路径, 截图配置类.截图数据)
        }
        剪辑板_置剪辑板图片2 (截图配置类.截图数据)
        销毁 ()
        返回 (0)
    }
}

类 截图配置类 <折叠 @文档 = "category = \"组件操作库.截图操作.附加类\"">
{
    变量 坐标颜色 <公开 静态 类型 = 整数 值 = 颜色类.白色>
    变量 线框颜色 <公开 静态 类型 = 整数 值 = 颜色类.蓝色>
    变量 提示颜色 <公开 静态 类型 = 整数 值 = 颜色类.天蓝色>
    变量 线框背景色 <公开 静态 类型 = 整数 值 = 0x383838>
    变量 图片格式 <公开 静态 类型 = 整数 值 = 1>
    变量 保存路径 <公开 静态 类型 = 文本型>
    变量 截图数据 <公开 静态 类型 = 字节集类>
    变量 隐藏提示 <公开 静态 类型 = 逻辑型>
    变量 初始宽度 <公开 静态 类型 = 整数>
    变量 初始高度 <公开 静态 类型 = 整数>
}

# //====

类 窗口边框类_ <公开 基础类 = 组件布局器 注释 = "使用步骤:" 注释 = "1、在窗口创建完毕事件下执行“创建边框_”" 注释 = "2、在窗口尺寸被改变事件下执行“匹配尺寸_”" 折叠 折叠2 隐藏值属性 = "1"
        @文档 = "category = \"组件操作库.窗口边框库\"" @视窗.布局 = "client_size = \"45, 30\"">
{
    变量 动态 <类型 = 边框动态标签类_ 折叠>
    变量 动态2 <类型 = 边框动态图片框类_>
    变量 标签组 <类型 = 对象数组类>
    变量 标签组2 <类型 = 对象数组类>
    变量 图片框_底栏 <类型 = 图片框>
    变量 句柄 <类型 = 变整数>
    变量 全局量 <类型 = 边框全局量变量>
    变量 移入移出 <类型 = 组件移入移出事件类_>
    变量 全局容器 <类型 = 窗口 注释 = "本对象">
    变量 时钟1 <类型 = 时钟类_>
    变量 时钟2 <类型 = 时钟类_>
    变量 记忆位 <类型 = 整数>
    变量 是否调整 <类型 = 逻辑型>
    变量 是否关闭 <类型 = 逻辑型>
    变量 是否已创建 <类型 = 逻辑型>
    变量 集全屏最大化 <类型 = 整数>

    方法 创建边框_ <公开 折叠>
    参数 容器 <类型 = 窗口 注释 = "本对象">
    参数 窗口标题 <类型 = 文本型 @默认值 = "我的窗口">
    参数 标题颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 标题字体名称 <类型 = 文本型 @默认值 = "微软雅黑">
    参数 标题字体大小 <类型 = 整数 @默认值 = 12>
    参数 标题是否加粗 <类型 = 逻辑型 @默认值 = 假>
    参数 标题对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中" @默认值 = 0>
    参数 窗口图标左边 <类型 = 整数 注释 = "窗口标题栏左侧图标距离左侧间隔" @默认值 = 12>
    参数 窗口图标宽度 <类型 = 整数 注释 = "窗口标题栏左侧图标。高度则跟随上标题栏的高度" @默认值 = 22>
    参数 控件图标宽度 <类型 = 整数 注释 = "窗口标题栏右侧图标" @默认值 = 27>
    参数 控件图标高度 <类型 = 整数 注释 = "宽高，不可大于上边框高度。窗口标题栏右侧图标" @默认值 = 25>
    参数 控件是否居中 <类型 = 逻辑型 注释 = "窗口标题栏右侧图标是否居中显示" @默认值 = 假>
    参数 上边框高度 <类型 = 整数 @默认值 = 42>
    参数 下边框高度 <类型 = 整数 @默认值 = 30>
    参数 左右边框宽度 <类型 = 整数 @默认值 = 2>
    参数 边框背景颜色 <类型 = 整数 注释 = "窗口上下左右边框颜色" @默认值 = 0x804000>
    参数 控件热点背景颜色 <类型 = 整数 注释 = "窗口标题栏右侧按钮" @默认值 = 0xAB5501>
    参数 控件按下背景颜色 <类型 = 整数 注释 = "窗口标题栏右侧按钮，除关闭外" @默认值 = 0x7B3702>
    参数 控件关闭背景颜色 <类型 = 整数 注释 = "窗口标题栏右侧关闭按钮" @默认值 = 0x0000FE>
    参数 控件按下关闭背景颜色 <类型 = 整数 注释 = "窗口标题栏右侧关闭按钮" @默认值 = 0x00008C>
    参数 隐藏全屏按钮 <类型 = 逻辑型 @默认值 = 假>
    参数 隐藏最大化按钮 <类型 = 逻辑型 @默认值 = 假>
    参数 隐藏最小化按钮 <类型 = 逻辑型 @默认值 = 假>
    参数 隐藏皮肤按钮 <类型 = 逻辑型 @默认值 = 假>
    参数 窗口大小是否可调节 <类型 = 逻辑型 @默认值 = 真>
    参数 双击是否最大化 <类型 = 逻辑型 注释 = "双击标题栏时是否允许最大化" @默认值 = 假>
    参数 窗口圆角度数 <类型 = 整数 @默认值 = 5>
    参数 窗口图标 <类型 = 位图资源 注释 = "窗口标题栏左侧图标" @默认值 = 空资源.空位图>
    参数 关闭按钮图标 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 全屏按钮图标 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 最大化按钮图标 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 最小化按钮图标 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 皮肤按钮图标 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 隐藏附加按钮1 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮2 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮3 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮4 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮5 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮6 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮7 <类型 = 逻辑型 @默认值 = 真>
    参数 隐藏附加按钮8 <类型 = 逻辑型 @默认值 = 真>
    参数 附加按钮图标1 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标2 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标3 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标4 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标5 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标6 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标7 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 附加按钮图标8 <类型 = 位图资源 注释 = "窗口标题栏右侧图标" @默认值 = 空资源.空位图>
    参数 默认全屏最大化 <类型 = 整数 注释 = "0、不改变 1、最大化 2、全屏" @默认值 = 0>
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        是否关闭 = 假
        标签组.枚举循环 ()
        {
            临时标签 = (标签)标签组.取枚举值 ()
            临时标签.销毁 ()
        }
        标签组2.枚举循环 ()
        {
            临时标签 = (标签)标签组2.取枚举值 ()
            临时标签.销毁 ()
        }
        标签组.删除所有成员 ()
        标签组2.删除所有成员 ()
        全局量.重置为空对象 ()
        句柄 = 容器.取窗口句柄 ()
        全局量.原始矩形 = 组件位置_ (句柄)
        记忆位 = 容器.左边
        容器.左边 = -5000
        全局容器 = 容器
        是否调整 = 真
        窗口_圆角化窗口组件 (句柄, 窗口圆角度数, 窗口圆角度数)
        全局量.窗口圆角 = 窗口圆角度数
        全局量.上边框高度 = 上边框高度
        全局量.下边框高度 = 下边框高度
        全局量.左右边框宽度 = 左右边框宽度
        全局量.控件热点背景颜色 = 控件热点背景颜色
        全局量.控件按下背景颜色 = 控件按下背景颜色
        全局量.控件关闭背景颜色 = 控件关闭背景颜色
        全局量.控件按下关闭背景颜色 = 控件按下关闭背景颜色
        全局量.隐藏全屏按钮 = 隐藏全屏按钮
        全局量.隐藏最大化按钮 = 隐藏最大化按钮
        全局量.隐藏最小化按钮 = 隐藏最小化按钮
        全局量.隐藏皮肤按钮 = 隐藏皮肤按钮
        全局量.窗口大小是否可调节 = 窗口大小是否可调节
        全局量.双击最大化 = 双击是否最大化
        全局量.边框背景颜色 = 边框背景颜色
        全局量.窗口图标宽度 = 窗口图标宽度
        全局量.控件图标宽度 = 控件图标宽度
        全局量.控件图标高度 = 控件图标高度
        全局量.控件是否居中 = 控件是否居中
        全局量.隐藏附加按钮1 = 隐藏附加按钮1
        全局量.隐藏附加按钮2 = 隐藏附加按钮2
        全局量.隐藏附加按钮3 = 隐藏附加按钮3
        全局量.隐藏附加按钮4 = 隐藏附加按钮4
        全局量.隐藏附加按钮5 = 隐藏附加按钮5
        全局量.隐藏附加按钮6 = 隐藏附加按钮6
        全局量.隐藏附加按钮7 = 隐藏附加按钮7
        全局量.隐藏附加按钮8 = 隐藏附加按钮8
        如果真 (控件图标高度 > 上边框高度)
        {
            全局量.控件图标高度 = 上边框高度
        }
        如果真 (窗口图标 != 空资源.空位图)
        {
            全局量.窗口图标 = 窗口图标
        }
        如果真 (关闭按钮图标 != 空资源.空位图)
        {
            全局量.关闭图标 = 关闭按钮图标
        }
