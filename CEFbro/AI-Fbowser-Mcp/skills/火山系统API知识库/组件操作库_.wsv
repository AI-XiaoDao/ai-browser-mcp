    方法 获取标签索引 <类型 = 整数 折叠>
    参数 标签索引 <类型 = 整数>
    {
        变量 i <类型 = 整数>
        标签组2.枚举循环 ()
        {
            如果真 (((标签)标签组2.取枚举值 ()).标题 != "|")
            {
                i = i + 1
                如果真 (i > 标签索引)
                {
                    i = 对象数组类.取枚举索引 ()
                    跳出循环
                }
            }
        }
        返回 (i)
    }

    方法 获取标签索引2 <类型 = 整数 折叠>
    参数 内容 <类型 = 文本型>
    {
        变量 i <类型 = 整数>
        标签组2.枚举循环 ()
        {
            如果真 (((标签)标签组2.取枚举值 ()).标题 != "|")
            {
                如果 (((标签)标签组2.取枚举值 ()).标题 == 内容)
                {
                    跳出循环
                }
                i = i + 1
            }
        }
        返回 (i)
    }

    方法 恢复默认 <折叠>
    {
        变量 临时标签 <类型 = 标签>
        变量 i <类型 = 整数>
        循环 (15, 20, i)
        {
            临时标签 = (标签)标签组.取成员 (i)
            如果真 (临时标签.背景颜色 != 全局量.边框背景颜色)
            {
                临时标签.背景颜色 = 全局量.边框背景颜色
            }
        }
        循环 (22, 30, i)
        {
            临时标签 = (标签)标签组.取成员 (i)
            如果真 (临时标签.背景颜色 != 全局量.边框背景颜色)
            {
                临时标签.背景颜色 = 全局量.边框背景颜色
            }
        }
    }

    方法 窗口组件_组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 窗口组件>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        窗口_置窗口点击属性 (句柄, 消息值, 消息参数1, 消息参数2)
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        如果 (消息值 == 0x0008)
        {
            恢复默认 ()
        }
        返回 (0)
    }

    方法 组件移入移出事件类__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    {
        如果真 (是否关闭)
        {
            返回 (0)
        }
        如果真 (是否移入 == 假)
        {
            恢复默认 ()
        }
        控件触发事件 (组件序号, 是否移入)
        返回 (0)
    }

    方法 控件触发事件 <公开 定义事件 类型 = 整数 注释 = "标题栏按钮" 折叠>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">

    方法 时钟类__周期事件_ <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_>
    参数 标记值 <类型 = 整数>
    参数 时钟ID <类型 = 整数>
    {
        如果 (来源对象 == 时钟1)
        {
            全局容器.移动 (全局容器.左边 + 2, 全局容器.顶边 + 2, 全局容器.宽度 - 3, 全局容器.高度 - 5)
            全局容器.移动 (全局容器.左边 - 2, 全局容器.顶边 - 2, 全局容器.宽度 + 3, 全局容器.高度 + 3)
            全局容器.左边 = 记忆位
            如果真 (集全屏最大化 == 1)
            {
                窗口_置窗口最大化2 (句柄, 真)
            }
            如果真 (集全屏最大化 == 2)
            {
                窗口_置窗口最大化 (句柄)
            }
            集全屏最大化 = 0
            时钟1.停止时钟_ ()
        }
        否则 (来源对象 == 时钟2)
        {
            全局容器.移动 (全局容器.左边 + 2, 全局容器.顶边 + 2, 全局容器.宽度 - 3, 全局容器.高度 - 5)
            全局容器.移动 (全局容器.左边 - 2, 全局容器.顶边 - 2, 全局容器.宽度 + 3, 全局容器.高度 + 3)
            如果真 (集全屏最大化 == 1)
            {
                窗口_置窗口最大化2 (句柄, 真)
            }
            如果真 (集全屏最大化 == 2)
            {
                窗口_置窗口最大化 (句柄)
            }
            集全屏最大化 = 0
            时钟2.停止时钟_ ()
        }
        返回 (0)
    }
}

