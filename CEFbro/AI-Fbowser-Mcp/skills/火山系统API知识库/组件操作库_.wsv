        否则
        {
            图片框_头区.移动 (, 0, , 取用户区高度 ())
        }
        按钮_左调.移动 (组件布局器_头区.宽度 + 5, (组件布局器_头区.高度 - 按钮_左调.高度) / 2)
        按钮_右调.移动 (按钮_左调.左边 + 按钮_左调.宽度, 按钮_左调.顶边, )
        调节区状态 ()
