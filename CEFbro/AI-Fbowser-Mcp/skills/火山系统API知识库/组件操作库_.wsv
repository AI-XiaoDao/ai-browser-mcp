    方法 显示隐藏滚动条_ <公开 注释 = "将本命令放入“窗口组件_鼠标位置被移动，我的主窗口_鼠标位置被移动”事件下调用" 折叠>
    参数 是否显示 <类型 = 逻辑型 @默认值 = 真>
    参数 是否有焦点 <类型 = 逻辑型 注释 = "当显示滚动条时，使其焦点在容器上，离开后将归还原焦点" @默认值 = 真>
    {
        变量 句柄 <静态 类型 = 变整数>
        如果 (是否显示 == 真)
        {
            如果真 (句柄 == 0 && 是否有焦点 == 真)
            {
                句柄 = 窗口_取焦点组件句柄 ()
                本对象.获取焦点 ()
            }
            如果 (隐藏类型 == 1)
            {
                滚动条1.可视 = 假
                滚动条2.可视 = 真
            }
            否则 (隐藏类型 == 2)
            {
                滚动条1.可视 = 真
                滚动条2.可视 = 假
            }
            否则
            {
                滚动条1.可视 = 真
                滚动条2.可视 = 真
            }
        }
        否则
        {
            滚动条1.可视 = 假
            滚动条2.可视 = 假
            如果真 (句柄 > 0 && 是否有焦点 == 真)
            {
                窗口_置窗口组件焦点2 (句柄)
                句柄 = 0
            }
        }
    }

    方法 开启滚动_ <公开 注释 = "将本命令放入“窗口组件_滚轮被滚动”事件下调用;" 注释 = "或用“鼠键钩子类_”中的鼠标滚轮事件" 折叠 折叠2>
    参数 滚动距离 <类型 = 整数 注释 = "判断滚动方向，下滚：<0　上滚：>0">
    参数 滚动面值 <类型 = 整数 注释 = "鼠标滚轮滚动距离，本参数为比例值，非绝对值" @默认值 = 7>
    参数 设置类型 <类型 = 整数 注释 = "1、纵向　2、横向　3、纵向＋横向" @默认值 = 1>
    {
        如果真 (窗口_取焦点组件句柄 () > 0)
        {
            如果 (设置类型 == 1)
            {
                滚动条1.开启滚动_ (滚动距离, 滚动面值)
            }
            否则 (设置类型 == 2)
            {
                滚动条2.开启滚动_ (滚动距离, 滚动面值)
            }
            否则
            {
                滚动条1.开启滚动_ (滚动距离, 滚动面值)
                滚动条2.开启滚动_ (滚动距离, 滚动面值)
            }
        }
    }

