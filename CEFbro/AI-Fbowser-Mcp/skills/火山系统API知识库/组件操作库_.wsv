    方法 自适应滚动条_ <公开 注释 = "图片浏览命令" 折叠>
    {
        横向滚动条1.移动 (前台画板.左边, 前台画板.高度 + 前台画板.顶边 + 1, 前台画板.宽度)
        纵向滚动条1.移动 (前台画板.宽度 + 前台画板.左边, 前台画板.顶边, , 前台画板.高度)
        显示图片 ()
    }

    方法 到图片左_ <公开 注释 = "图片浏览命令" 折叠>
    {
        横向滚动条1.位置 = 0
        移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
    }

    方法 到图片首_ <公开 注释 = "图片浏览命令" 折叠>
    {
        纵向滚动条1.位置 = 0
        移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
    }

    方法 到图片中_ <公开 注释 = "图片浏览命令" 折叠>
    {
        纵向滚动条1.位置 = 纵向滚动条1.最大位置 / 2
        移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
    }

    方法 到图片尾_ <公开 注释 = "图片浏览命令" 折叠>
    {
        纵向滚动条1.位置 = 纵向滚动条1.最大位置
        移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
    }

    方法 取显示图片_ <公开 类型 = 字节集类 注释 = "取当前显示区图片" 折叠>
    {
        变量 临时图 <类型 = 位图对象类>
        变量 临时图2 <类型 = 字节集类>
        取图片 (临时图)
        临时图.取图片数据 (临时图2)
        返回 (临时图2)
    }

    方法 停止轮播_ <公开 注释 = "轮播图命令" 折叠>
    {
        如果真 (轮播总宽度 > 0)
        {
            手动停止 = 真
            是否已停止 = 真
            处理事件 ()
            时钟1.停止时钟_ ()
        }
    }

    方法 启动轮播_ <公开 注释 = "轮播图命令" 折叠>
    参数 轮播周期 <类型 = 整数>
    参数 移动距离 <类型 = 整数 注释 = "通过修改本值来改变轮播速度，值越大速度越快" @默认值 = 7>
    {
        如果真 (轮播总宽度 > 0)
        {
            手动停止 = 假
            是否已停止 = 假
            集轮播周期 = 轮播周期
            置轮播速度_ (移动距离)
            时钟1.启动时钟_ (轮播周期)
        }
    }

    方法 置轮播周期_ <公开 注释 = "轮播图命令" 折叠>
    参数 轮播周期 <类型 = 整数 注释 = "图片停留时间；不为0时，则自动轮播;" 注释 = "单位：毫秒，1000毫秒 = 1秒" 折叠2>
    {
        集轮播周期 = 轮播周期
    }

    方法 置轮播速度_ <公开 注释 = "轮播图命令" 折叠>
    参数 移动距离 <类型 = 整数 注释 = "通过修改本值来改变轮播速度，值越大速度越快" @默认值 = 7>
    {
        如果真 (移动距离 < 1)
        {
            移动距离 = 1
        }
        如果 (移动距离 > 分段宽度)
        {
            全局移动距离 = 分段宽度
        }
        否则
        {
            全局移动距离 = 移动距离
        }
    }

    方法 切换轮播图_ <公开 注释 = "轮播图命令" 折叠>
    参数 图序 <类型 = 整数 注释 = "从0开始">
    {
        变量 i <类型 = 整数>
        如果真 (轮播总宽度 > 0)
        {
            如果真 (图序 < 0 || 图序 > 分段数量 - 1)
            {
                图序 = 0
            }
            如果真 (图序 > 分段数量 - 1)
            {
                图序 = 分段数量 - 1
            }
            如果真 (集轮播周期 > 0)
            {
                立即停止 = 真
                处理事件 ()
                是否已停止 = 真
                处理事件 ()
                时钟1.停止时钟_ ()
            }
            如果 (图序 == 0)
            {
                横向滚动条1.位置 = 分段宽度 / 2
                循环 (, 分段宽度 / 全局移动距离 / 2, i)
                {
                    横向滚动条1.位置 = 横向滚动条1.位置 - 全局移动距离
                    移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                    // 延迟_ (轮播速度值)
                }
                横向滚动条1.位置 = 0
                移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                置浮点颜色 (图序)
                如果真 (当前页面序 != 图序)
                {
                    当前页面序 = 图序
                    轮播图切换事件 (图序)
                }
            }
            否则 (图序 == 分段数量 - 1)
            {
                横向滚动条1.位置 = 轮播总宽度 - 分段宽度 - 分段宽度 / 2
                循环 (, 分段宽度 / 全局移动距离 / 2, i)
                {
                    横向滚动条1.位置 = 横向滚动条1.位置 + 全局移动距离
                    移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                    // 延迟_ (轮播速度值)
                }
                横向滚动条1.位置 = 轮播总宽度 - 分段宽度
                移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                轮播图切换事件 (图序)
                置浮点颜色 (图序)
            }
            否则
            {
                横向滚动条1.位置 = (图序 + 1) * 分段宽度 - 分段宽度 / 2
                处理轮播 ()
            }
            如果真 (集轮播周期 > 0)
            {
                是否已停止 = 假
                时钟1.启动时钟_ (集轮播周期)
            }
        }
    }

