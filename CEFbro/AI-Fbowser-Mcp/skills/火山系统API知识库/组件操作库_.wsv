    }

    方法 按钮_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 按钮_左调)
        {
            移入移出.监视组件_ (来源对象, 横向位置, 纵向位置)
            如果真 (已进入1 == 假)
            {
                按钮_左调.图片 = 左2
                按钮_右调.图片 = 右1
                已进入2 = 假
                已进入1 = 真
            }
        }
        否则 (来源对象 == 按钮_右调)
        {
            移入移出2.监视组件_ (来源对象, 横向位置, 纵向位置)
            如果真 (已进入2 == 假)
            {
                按钮_右调.图片 = 右2
                按钮_左调.图片 = 左1
                已进入1 = 假
                已进入2 = 真
            }
        }
        返回 (0)
    }

