    方法 置入状态标签_ <公开 注释 = "在窗口底部栏中添加文字" 折叠>
    参数 标题 <类型 = 文本型>
    参数 宽度 <类型 = 整数>
    参数 标题颜色 <类型 = 整数 @默认值 = 颜色类.浅灰色>
    参数 是否加间隔条 <类型 = 逻辑型 @默认值 = 假>
    参数 间隔条颜色 <类型 = 整数 @默认值 = 0xA25100>
    参数 标题字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 标题字体大小 <类型 = 整数 @默认值 = 9>
    参数 标题是否加粗 <类型 = 逻辑型 @默认值 = 假>
    参数 标题起始距离 <类型 = 整数 注释 = "首个标题距离左侧边界距离" @默认值 = 5>
    参数 标题与间隔条距离 <类型 = 整数 注释 = "右侧标题与左侧间隔条距离" @默认值 = 5>
    参数 提示内容 <类型 = 文本型 @默认值 = "">
    {
        变量 临时标签 <类型 = 标签>
        变量 原左侧 <类型 = 整数>
        如果 (标签组2.取成员数 () == 0)
        {
            原左侧 = 标题起始距离
        }
        否则
        {
            原左侧 = 5
        }
        如果真 (标签组2.取成员数 () > 0)
        {
            临时标签 = (标签)标签组2.取成员 (标签组2.取成员数 () - 1)
            原左侧 = 原左侧 + 临时标签.左边 + 临时标签.宽度 + 标题与间隔条距离
        }
        标签组2.加入成员 (动态.创建标签 (图片框_底栏, 原左侧, 0, 宽度, 全局量.下边框高度))
        临时标签 = (标签)标签组2.取成员 (标签组2.取成员数 () - 1)
        挂接事件 ((标签)标签组2.取成员 (标签组2.取成员数 () - 1), 标签组2.取成员数 () + 31)
        临时标签.标题 = 标题
        临时标签.背景颜色 = 全局量.边框背景颜色
        临时标签.文本颜色 = 标题颜色
        临时标签.字体 = 标题字体名称 + "," + 到文本 (标题字体大小) + "," + 选择 (标题是否加粗, "1", "0")
        临时标签.提示信息 = 提示内容
        临时标签.可视 = 真
        如果真 (是否加间隔条)
        {
            标签组2.加入成员 (动态.创建标签 (图片框_底栏, 临时标签.左边 + 临时标签.宽度, 2, 7, 全局量.下边框高度 - 4))
            临时标签 = (标签)标签组2.取成员 (标签组2.取成员数 () - 1)
            挂接事件 ((标签)标签组2.取成员 (标签组2.取成员数 () - 1), 标签组2.取成员数 () + 31)
            临时标签.标题 = "|"
            临时标签.背景颜色 = 全局量.边框背景颜色
            临时标签.文本颜色 = 间隔条颜色
            临时标签.横向对齐方式 = 横向对齐模式.居中
            临时标签.字体 = "宋体, " + 到文本 (标题字体大小) + ", 0, 0, 0, 0, 0"
            临时标签.可视 = 真
        }
    }

