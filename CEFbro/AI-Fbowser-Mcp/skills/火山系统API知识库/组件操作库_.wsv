    方法 置原始位置_ <公开 注释 = "预置原始位置坐标，当窗口默认就是最大化时，点击最大化不会缩小窗口，通过本命令可改变此情况." 注释 = "本命令放在创建边框之后" 折叠 折叠2>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        变量 矩形坐标 <类型 = 矩形类 注释 = "赋值：左边、右边、顶边、底边">
        矩形坐标.左边 = 左边
        矩形坐标.顶边 = 顶边
        矩形坐标.右边 = 左边 + 宽度
        矩形坐标.底边 = 高度 + 顶边
        全局量.原始矩形 = 矩形坐标
    }

    方法 清空状态标签_ <公开 注释 = "清空所有状态标签" 折叠>
    {
        变量 临时标签 <类型 = 标签>
        标签组2.枚举循环 ()
        {
            临时标签 = (标签)标签组2.取枚举值 ()
            临时标签.销毁 ()
        }
        标签组2.删除所有成员 ()
    }

    方法 匹配尺寸_ <公开 注释 = "将本命令放在“我的主窗口_尺寸被改变”事件下" 折叠>
    参数 左间隔 <类型 = 整数 注释 = "调整标题栏控件按钮" @默认值 = 0>
    参数 顶间隔 <类型 = 整数 注释 = "调整标题栏控件按钮" @默认值 = 0>
    参数 主附间隔 <类型 = 整数 注释 = "调整标题栏控件按钮，主控件与附控件之间间隔" @默认值 = 0>
    {
        变量 临时标签 <类型 = 标签>
        变量 临时左 <类型 = 整数>
        变量 用区宽度 <类型 = 整数>
        变量 用区高度 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (是否已创建 == 假)
        {
            返回
        }
        窗口_圆角化窗口组件 (句柄, 全局量.窗口圆角, 全局量.窗口圆角)
        标签组.枚举循环 ()
        {
            临时标签 = (标签)标签组.取枚举值 ()
            i = 对象数组类.取枚举索引 ()
            如果 (i < 12)
            {
                如果真 (临时标签.透明 == 假)
                {
                    临时标签.透明 = 真
                }
            }
            否则 (i > 11 && i < 30)
            {
                如果真 (临时标签.背景颜色 != 全局量.边框背景颜色)
                {
                    临时标签.背景颜色 = 全局量.边框背景颜色
                    临时标签.底图方式 = 图片放置方式.图片居中
                }
            }
            临时标签.调整层次 (组件层次.顶层)
            用区宽度 = 取用户区宽度_ (句柄)
            用区高度 = 取用户区高度_ (句柄)
            如果 (i == 0)  // 上左
            {
                临时标签.移动 (0, 0, 10, 3)
            }
            否则 (i == 1)  // 上中
            {
                临时标签.移动 (10, 0, 用区宽度 - 20, 3)
            }
            否则 (i == 2)  // 上右
            {
                临时标签.移动 (用区宽度 - 10, 0, 10, 3)
            }
            否则 (i == 3)  // 下左
            {
                临时标签.移动 (0, 用区高度 - 3, 10, 3)
            }
            否则 (i == 4)  // 下中
            {
                临时标签.移动 (10, 用区高度 - 3, 用区宽度 - 20, 3)
            }
            否则 (i == 5)  // 下右
            {
                临时标签.移动 (用区宽度 - 10, 用区高度 - 3, 10, 3)
            }
            否则 (i == 6)  // 左上
            {
                临时标签.移动 (0, 0, 3, 10)
            }
            否则 (i == 7)  // 左中
            {
                临时标签.移动 (0, 10, 3, 用区高度 - 20)
            }
            否则 (i == 8)  // 左下
            {
                临时标签.移动 (0, 用区高度 - 10, 3, 10)
            }
            否则 (i == 9)  // 右上
            {
                临时标签.移动 (用区宽度 - 3, 0, 3, 10)
            }
            否则 (i == 10)  // 右中
            {
                临时标签.移动 (用区宽度 - 3, 10, 3, 用区高度 - 20)
            }
            否则 (i == 11)  // 右下
            {
                临时标签.移动 (用区宽度 - 3, 用区高度 - 10, 3, 10)
            }
            否则 (i == 12)  // 上栏
            {
                临时标签.移动 (0, 0, 用区宽度, 全局量.上边框高度)
            }
            否则 (i == 13)  // 左栏
            {
                临时标签.移动 (0, 全局量.上边框高度, 全局量.左右边框宽度, 用区高度 - 全局量.上边框高度 - 全局量.下边框高度)
            }
            否则 (i == 14)  // 右栏
            {
