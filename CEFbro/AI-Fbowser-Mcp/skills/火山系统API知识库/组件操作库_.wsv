    {
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        返回 (0)
    }
}

类 滚动容器类_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"组件操作库.滚动容器库.附加类\"" @视窗.布局 = "client_size = \"500, 350\"">
{
    变量 滚动条1 <类型 = 纵向滚动条类_ 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"488, 0, 10, 184\"">
    变量 滚动条2 <类型 = 横向滚动条类_ 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"0, 336, 368, 10\"">
    变量 容器面板 <类型 = 组件布局器 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\npos = \"8, 8, 464, 304\"">
    变量 宽高值 <类型 = 整数>
    变量 布局面板 <类型 = 组件布局器>
    变量 隐藏类型 <类型 = 整数>
    变量 浮动 <类型 = 逻辑型>
    变量 句柄组 <类型 = 变整数数组类>
    变量 置焦点 <类型 = 逻辑型>

    方法 类_初始化 <折叠>
    {
        滚动条1.可视 = 假
        滚动条2.可视 = 假
    }

    方法 初始化滚动容器_ <公开 类型 = 变整数数组类 注释 = "将组件布局器页面绑定到滚动容器内"
            返回值注释 = "将返回5个成员句柄；　1.纵向滚动条　2、纵向容器　3.横向滚动条　4、横向容器　5.本容器　；可用于无事件触发时，绑定“挂接事件类_”" 折叠>
    参数 绑定布局器 <类型 = 组件布局器 注释 = "将布局器页面加入滚动容器内">
    参数 布局器总宽度 <类型 = 整数 注释 = "给出布局器页面的总宽度" @默认值 = -1>
    参数 布局器总高度 <类型 = 整数 注释 = "给出布局器页面的总高度" @默认值 = -1>
    参数 滚动条宽高 <类型 = 整数 注释 = "滚动条宽度或高度" @默认值 = 10>
    参数 圆角度数 <类型 = 整数 @默认值 = 5>
    参数 开启鼠标滚轮事件 <类型 = 逻辑型 注释 = "并将“开启滚动_”命令放入“窗口组件_滚轮被滚动”事件下调用" @默认值 = 真>
    参数 滚动面值 <类型 = 整数 注释 = "鼠标滚轮滚动距离，本参数为比例值，非绝对值" @默认值 = 7>
    参数 标准鼠标指针 <类型 = 整数 注释 = "1、箭头　2、手型　；为空则默认为自定义指针类型" @默认值 = 0>
    参数 滚动条背景色 <类型 = 整数 注释 = "如果组件设置了颜色，将跟随组件颜色" @默认值 = 0xCBC5C1>
    参数 滚动条颜色 <类型 = 整数 @默认值 = 0x8D8989>
    参数 滚动条激活色 <类型 = 整数 @默认值 = 0x605C5C>
    参数 无滚动时样式 <类型 = 整数 注释 = "1、显示　2、半隐藏　3、全隐藏" @默认值 = 1>
    参数 隐藏滚动条 <类型 = 整数 注释 = "-1、显示　1、隐藏纵向　2、隐藏横向　3、全部隐藏" @默认值 = -1>
    参数 滚动条是否浮动 <类型 = 逻辑型 注释 = "真：滚动条浮动在容器上方，会遮挡一部分容器； 假：与容器区隔开，不遮挡" @默认值 = 真>
    参数 是否有焦点 <类型 = 逻辑型 注释 = "当显示滚动条时，使其焦点在容器上，离开后将归还原焦点" @默认值 = 真>
    {
        变量 临时句柄 <类型 = 变整数数组类>
        如果真 (本对象.宽度 == 0)
        {
            调试输出 ("请在：设计器－布局内容－选择滚动容器－然后左侧调整该布局器大小", 64, "温馨提示！")
            结束 ()
        }
        如果 (隐藏滚动条 == 1)
        {
            滚动条1.可视 = 假
            滚动条2.可视 = 真
        }
        否则 (隐藏滚动条 == 2)
        {
            滚动条1.可视 = 真
            滚动条2.可视 = 假
        }
        否则 (隐藏滚动条 == 3)
        {
            滚动条1.可视 = 假
            滚动条2.可视 = 假
        }
        否则
        {
            滚动条1.可视 = 真
            滚动条2.可视 = 真
        }
        隐藏类型 = 隐藏滚动条
        如果 (布局器总高度 == -1 || 布局器总宽度 == -1)
        {
            信息框 ("所指定的绑定布局器页面，还未设置尺寸！", 64, "提示！")
            结束 ()
        }
        否则
        {
            绑定布局器.移动 (0, 0, 布局器总宽度, 布局器总高度)
        }
        宽高值 = 滚动条宽高
        如果 (滚动条是否浮动 == 真)
        {
            容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度)
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度)
        }
        否则
        {
            如果 (隐藏滚动条 == 3)
            {
                容器面板.移动 (0, 0, 本对象.宽度 + 1, 本对象.高度 + 1)
            }
            否则 (隐藏滚动条 == 1)
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 滚动条宽高 + 1, 本对象.高度 + 1)
            }
            否则 (隐藏滚动条 == 2)
            {
                容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度 + 1 - 滚动条宽高 + 1)
            }
            否则
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 滚动条宽高 + 1, 本对象.高度 - 滚动条宽高 + 1)
            }
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度 - 滚动条宽高)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度 - 滚动条宽高)
        }
        绑定布局器.置父窗口 (容器面板)
        绑定布局器.可视 = 真
        临时句柄 = 滚动条1.初始化滚动条_ (容器面板.高度, 布局器总高度, 滚动条宽高, 圆角度数, 开启鼠标滚轮事件, 滚动面值, 标准鼠标指针, 滚动条背景色, 滚动条颜色, 滚动条激活色, 无滚动时样式)
        句柄组.删除所有成员 ()
        句柄组.添加数组 (临时句柄)
        临时句柄 = 滚动条2.初始化滚动条_ (容器面板.宽度, 布局器总宽度, 滚动条宽高, 圆角度数, 开启鼠标滚轮事件, 滚动面值, 标准鼠标指针, 滚动条背景色, 滚动条颜色, 滚动条激活色, 无滚动时样式)
        句柄组.添加数组 (临时句柄)
        布局面板 = 绑定布局器
        浮动 = 滚动条是否浮动
        // 本对象.底色 = 滚动条背景色
        // 容器面板.底色 = 滚动条背景色
        句柄组.加入成员 (本对象.取窗口句柄 ())
        置焦点 = 是否有焦点
        返回 (句柄组)
    }

    方法 重置滚动条_ <公开 注释 = "当需滚动的内容宽度发生改变时，需要重置滚动条范围" 折叠>
    参数 展示区总宽度 <类型 = 整数 注释 = "包括隐藏部份(显示区＋隐藏区)">
    参数 展示区总高度 <类型 = 整数 注释 = "包括隐藏部份(显示区＋隐藏区)">
    参数 设置类型 <类型 = 整数 注释 = "-1、纵向＋横向　1、纵向　2、横向" @默认值 = -1>
    参数 展示区总容器 <类型 = 组件布局器 注释 = "即需提供展示区总高度的组件，包括隐藏部份(显示区＋隐藏区)的组件;" 注释 = "本参数为空，则按当前滚动条位置来重置。不为空则精确按照当前容器位置来重置" 折叠2 @默认值 = 空对象>
    {
        布局面板.移动 (布局面板.左边, 布局面板.顶边, 展示区总宽度, 展示区总高度)
        如果 (浮动 == 真)
        {
            容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度)
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度)
        }
        否则
        {
            如果 (隐藏类型 == 3)
            {
                容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度)
            }
            否则 (隐藏类型 == 1)
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 宽高值, 本对象.高度)
            }
            否则 (隐藏类型 == 2)
            {
                容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度 - 宽高值)
            }
            否则
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 宽高值, 本对象.高度 - 宽高值)
            }
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度 - 宽高值)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度 - 宽高值)
        }
        滚动条1.重置滚动条_ (容器面板.高度, 展示区总高度, 展示区总容器)
        滚动条2.重置滚动条_ (容器面板.宽度, 展示区总宽度, 展示区总容器)
    }

    方法 置滚动条颜色_ <公开 折叠>
    参数 滚动条背景色 <类型 = 整数 @默认值 = 0xCBC5C1>
    参数 滚动条颜色 <类型 = 整数 @默认值 = 0x8D8989>
    参数 滚动条激活色 <类型 = 整数 @默认值 = 0x605C5C>
