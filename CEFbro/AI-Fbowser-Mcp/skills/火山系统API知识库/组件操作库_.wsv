    方法 时钟类_线程2_周期事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_线程2>
    参数 标记值 <类型 = 整数>
    {
        如果 (鼠标按下 == 真)
        {
            如果真 (无滚动样式 > 0)
            {
                返回 (0)
            }
            如果 (图片框左边 - 原横坐标 + 取鼠标水平位置 () > 0 && 图片框左边 - 原横坐标 + 取鼠标水平位置 () < 本对象.宽度 - 图片框_滚动条.宽度)
            {
                图片框_滚动条.左边 = 图片框左边 - 原横坐标 + 取鼠标水平位置 ()
            }
            否则 (图片框_滚动条.左边 > 0 && 图片框_滚动条.左边 < 差值)
            {
                图片框_滚动条.左边 = 0
            }
            调整位置 (图片框左边 - 原横坐标 + 取鼠标水平位置 ())
        }
        否则
        {
            时钟1.停止时钟_ ()
        }
        返回 (0)
    }

