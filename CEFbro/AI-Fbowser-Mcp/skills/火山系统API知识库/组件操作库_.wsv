    参数 展示区总高度 <类型 = 整数 注释 = "包括隐藏部份(显示区＋隐藏区)">
    参数 展示区总容器 <类型 = 组件布局器 注释 = "即需提供展示区总高度的组件，包括隐藏部份(显示区＋隐藏区)的组件;" 注释 = "本参数为空，则按当前滚动条位置来重置。不为空则精确按照当前容器位置来重置" @默认值 = 空对象>
    参数 固定滑块高度 <类型 = 整数 注释 = "默认为动态计算，当设置固定值后，滑块高度将被固定" @默认值 = -1>
    {
        变量 滑块条高度 <类型 = 小数>
        如果真 (展示区总高度 < 展示区高度)
        {
            展示区总高度 = 展示区高度
        }
        滚动条属性.展示区高度 = 展示区高度
        滚动条属性.展示区总高度 = 展示区总高度
        滚动条属性.位置 = 图片框_滚动条.顶边
        差值 = 展示区总高度 - 展示区高度
        如果 (差值 > 10)
        {
            差值 = 10
        }
        图片框_滚动条.可视 = 真
        本对象.可视 = 真
        无滚动样式 = 0
        如果真 (差值 < 1)
        {
            如果 (无滚动样式 == 1)
            {
                滑块条高度 = 100
            }
            否则 (无滚动样式 == 2)
            {
                图片框_滚动条.可视 = 假
            }
            否则
            {
                本对象.可视 = 假
            }
        }
        滑块条高度 = (小数)展示区高度 / 展示区总高度 * 展示区高度
        如果真 (滑块条高度 < 30)
        {
            滑块条高度 = 30
        }
        如果真 (固定滑块高度 > -1)
        {
            滑块条高度 = 固定滑块高度
        }
        滚动条属性.滑块条高度 = (整数)滑块条高度
        图片框_滚动条.高度 = (整数)滑块条高度
        置滚动条尺寸_ (滚动宽值, 度数)
        滚动条属性.最大顶边 = 展示区总高度 - 展示区高度
        如果 (展示区总容器.是否为空对象 () == 真)
        {
            调整位置 (滚动条属性.位置)
        }
        否则
        {
            变量 比例值 <类型 = 小数>
            变量 滑块位置 <类型 = 整数>
            比例值 = (小数)(展示区总高度 - 展示区高度) / (展示区高度 - 滚动条属性.滑块条高度)
            滑块位置 = (整数)四舍五入 ((小数)展示区总容器.顶边 / 比例值)
            滚动条属性.位置 = 滑块位置
            图片框_滚动条.顶边 = 位取反 (滑块位置 - 1)
        }
    }

