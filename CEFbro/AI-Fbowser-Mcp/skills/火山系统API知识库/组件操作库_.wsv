    方法 组件移入移出事件类__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    {
        如果真 (全局是否锁定 && 全局是否锁死)
        {
            返回 (0)
        }
        如果 (是否移入 != 临时记忆)
        {
            临时记忆 = 是否移入
            如果 (是否移入)
            {
                如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
                {
                    标签_右图.可视 = 真
                }
                图片框_下划条.可视 = 真
                子夹区移动事件 ()
            }
            否则
            {
                如果真 (全局默认显示关闭 == 假)
                {
                    标签_右图.可视 = 假
                }
                标签_右图2.可视 = 假
                如果 (全局当前子夹索引 != 当前索引 || 图片框_根容器.背景颜色 != 全局子夹热点背景颜色)
                {
                    图片框_下划条.可视 = 假
                }
                子夹区移动事件 ()
            }
        }
        返回 (0)
    }

