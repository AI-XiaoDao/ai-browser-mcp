    方法 处理轮播 <折叠>
    {
        如果 (轮播总宽度 > 0)
        {
            变量 当前区间半值 <类型 = 整数>
            变量 滚动差值 <类型 = 整数>
            变量 界限 <类型 = 整数>
            变量 方向 <类型 = 整数>
            变量 i <类型 = 整数>
            循环 (, 分段数量, i)
            {
                如果 (分段区间值.取成员 (i) > 横向滚动条1.位置)
                {
                    当前区间半值 = 分段宽度 * i + 分段宽度 / 2
                    如果 (横向滚动条1.位置 > 当前区间半值)
                    {
                        滚动差值 = 分段宽度 * i + 分段宽度 - 横向滚动条1.位置
                        界限 = i + 1
                        方向 = 1
                    }
                    否则
                    {
                        滚动差值 = 横向滚动条1.位置 - 分段宽度 * i
                        界限 = i
                        方向 = -1
                    }
                    跳出循环
                }
            }
            如果 (方向 < 0)
            {
                循环 (, 滚动差值 / 全局移动距离, i)
                {
                    横向滚动条1.位置 = 横向滚动条1.位置 - 全局移动距离
                    移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                    // 延迟_ (轮播速度值)
                }
            }
            否则
            {
                循环 (, 滚动差值 / 全局移动距离, i)
                {
                    横向滚动条1.位置 = 横向滚动条1.位置 + 全局移动距离
                    移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
                    // 延迟_ (轮播速度值)
                }
            }
            横向滚动条1.位置 = 界限 * 分段宽度
            移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
            如果真 (当前页面序 != 界限)
            {
                当前页面序 = 界限
                轮播图切换事件 (界限)
            }
            置浮点颜色 (界限)
            如果真 (集轮播周期 > 0)
            {
                是否已停止 = 假
                立即停止 = 假
                时钟1.启动时钟_ (集轮播周期)
            }
        }
    }

    方法 显示图片 <折叠>
    参数 是否居中 <类型 = 逻辑型 @默认值 = 真>
    {
        如果 (轮播总宽度 > 0)
        {
            后台画板.移动 (, , 轮播总宽度, (整数)临时高)
            后台画板.画图片 (图片资源, 0, 0, 轮播总宽度, (整数)临时高, )
        }
        否则
        {
            后台画板.移动 (, , (整数)临时宽, (整数)临时高)
            后台画板.画图片 (图片资源, 0, 0, (整数)临时宽, (整数)临时高, )
        }
        如果 (后台画板.宽度 == 前台画板.宽度)
        {
            横向滚动条1.可视 = 假
            横条状态 = 假
            画出左侧坐标 = 0
        }
        否则
        {
            如果真 (后台画板.宽度 < 前台画板.宽度)
            {
                画出左侧坐标 = (前台画板.宽度 - 后台画板.宽度) / 2
                如果 (画出左侧坐标 < 1)
                {
                    画出左侧坐标 = 0
                }
                否则
                {
                    前台画板.清除 (, , 画出左侧坐标, 前台画板.高度)
                    前台画板.清除 (前台画板.宽度 - 画出左侧坐标, , 画出左侧坐标, 前台画板.高度)
                }
                横向滚动条1.可视 = 假
                横条状态 = 假
            }
            如果真 (后台画板.宽度 > 前台画板.宽度)
            {
                如果真 (滚动条状态 == 真)
                {
                    横向滚动条1.可视 = 真
                }
                横条状态 = 真
                横向滚动条1.最大位置 = 后台画板.宽度 - 前台画板.宽度
                如果真 (是否居中)
                {
                    横向滚动条1.位置 = 横向滚动条1.最大位置 / 2
                }
                画出左侧坐标 = 0
            }
        }
        如果 (后台画板.高度 == 前台画板.高度)
        {
            画出顶部坐标 = 0
            纵条状态 = 假
            纵向滚动条1.可视 = 假
        }
        否则
        {
            如果真 (后台画板.高度 < 前台画板.高度)
            {
                画出顶部坐标 = (前台画板.高度 - 后台画板.高度) / 2
                如果 (画出顶部坐标 < 1)
                {
                    画出顶部坐标 = 0
                }
                否则
                {
                    前台画板.清除 (, , 前台画板.宽度, 画出顶部坐标)
                    前台画板.清除 (, 前台画板.高度 - 画出顶部坐标, 前台画板.宽度, 画出顶部坐标)
                }
                纵条状态 = 假
                纵向滚动条1.可视 = 假
            }
            如果真 (后台画板.高度 > 前台画板.高度)
            {
                如果真 (滚动条状态 == 真)
                {
                    纵向滚动条1.可视 = 真
                }
                纵条状态 = 真
                纵向滚动条1.最大位置 = 后台画板.高度 - 前台画板.高度
                如果真 (是否居中)
                {
                    纵向滚动条1.位置 = 纵向滚动条1.最大位置 / 2
                }
                画出顶部坐标 = 0
            }
        }
        如果 (横条状态 == 真)
        {
            左侧坐标 = 横向滚动条1.位置
        }
        否则
        {
            左侧坐标 = 0
        }
        如果 (纵条状态 == 真)
        {
            顶部坐标 = 纵向滚动条1.位置
        }
        否则
        {
            顶部坐标 = 0
        }
        后台画板.复制 (左侧坐标, 顶部坐标, , , 前台画板, 画出左侧坐标, 画出顶部坐标, )
    }

