    {
        如果 (鼠标按下 == 真)
        {
            如果真 (无滚动样式 > 0)
            {
                返回 (0)
            }
            如果 (图片框顶边 - 原纵坐标 + 取鼠标垂直位置 () > 0 && 图片框顶边 - 原纵坐标 + 取鼠标垂直位置 () < 本对象.高度 - 图片框_滚动条.高度)
            {
                图片框_滚动条.顶边 = 图片框顶边 - 原纵坐标 + 取鼠标垂直位置 ()
            }
            否则 (图片框_滚动条.顶边 > 0 && 图片框_滚动条.顶边 < 差值)
            {
                图片框_滚动条.顶边 = 0
            }
            调整位置 (图片框顶边 - 原纵坐标 + 取鼠标垂直位置 ())
        }
        否则
        {
            时钟1.停止时钟_ ()
        }
        返回 (0)
    }

