    参数 取类型 <类型 = 整数 注释 = "-1、纵向＋横向　1、纵向　2、横向" @默认值 = -1>
    {
        如果 (取类型 == 1)
        {
            返回纵向位置 = 滚动条1.取滚动条位置_ ()
        }
        否则 (取类型 == 2)
        {
            返回横向位置 = 滚动条2.取滚动条位置_ ()
        }
        否则
        {
            返回纵向位置 = 滚动条1.取滚动条位置_ ()
