    变量 动态横向 <类型 = 动态横向滚动条类_>
    变量 动态纵向 <类型 = 动态纵向滚动条类_>
    变量 前台画板 <类型 = 画板>
    变量 横条状态 <类型 = 逻辑型>
    变量 纵条状态 <类型 = 逻辑型>
    变量 滚动条状态 <类型 = 逻辑型>
    变量 父窗口对象 <类型 = 窗口容器组件>
    变量 轮播总宽度 <类型 = 整数>
    变量 动态浮点 <类型 = 动态图片框类_>
    变量 临时浮点 <类型 = "图片框 [12]">
    变量 分段宽度 <类型 = 整数>
    变量 分段数量 <类型 = 整数>
    变量 集浮点激活色 <类型 = 整数>
    变量 集浮点通常色 <类型 = 整数>
    变量 分段区间值 <类型 = 整数数组类>
    变量 区域左边 <类型 = 整数>
    变量 区域顶边 <类型 = 整数>
    变量 区域宽度 <类型 = 整数>
    变量 区域高度 <类型 = 整数>
    变量 当前页面序 <类型 = 整数>
    变量 滚轮功能 <类型 = 整数>
    变量 鼠标缩放尺寸 <类型 = 整数>
    变量 底部画板 <类型 = 动态画板类_>
    变量 时钟1 <类型 = 时钟类_线程2>
    变量 时钟2 <类型 = 时钟类_线程2>
    变量 集轮播周期 <类型 = 整数>
    变量 是否已停止 <类型 = 逻辑型>
    变量 立即停止 <类型 = 逻辑型>
    变量 手动停止 <类型 = 逻辑型>
    变量 原横坐标 <类型 = 整数>
    变量 原横坐标2 <类型 = 整数>
    变量 全局移动距离 <类型 = 整数>
    变量 初始值 <类型 = 整数>

    方法 初始化浏览框_ <公开 注释 = "图片浏览命令，可重复执行本命令来实现重加载" 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 显示滚动条 <类型 = 逻辑型 @默认值 = 真>
    参数 开启鼠标滚轮功能 <类型 = 整数 注释 = "0、关闭　1、开启缩放　2、开启滚动　3、智能选择模式(当只有高度超出屏幕时，使用滚动，宽度超出使用缩放)" @默认值 = 0>
    参数 滚轮调整尺寸 <类型 = 整数 注释 = "缩放或滚动的尺寸比例" @默认值 = 50>
    {
        后台画板 = 动态创建.创建画板 (父窗口, 本对象.左边, 本对象.顶边, 本对象.宽度, 本对象.高度)
        横向滚动条1 = 动态横向.创建横向滚动条 (父窗口, 本对象.左边, 本对象.高度 + 本对象.顶边 + 1, 本对象.宽度)
        纵向滚动条1 = 动态纵向.创建纵向滚动条 (父窗口, 本对象.宽度 + 本对象.左边, 本对象.顶边, , 本对象.高度)
        横向滚动条1.最小位置 = 0
        纵向滚动条1.最小位置 = 0
        挂接事件 (横向滚动条1)
        挂接事件 (纵向滚动条1)
        横向滚动条1.可视 = 假
        纵向滚动条1.可视 = 假
        后台画板.可视 = 假
        后台画板.自动重画 = 真
        本对象.自动重画 = 真
        如果真 (开启鼠标滚轮功能 < 0 || 开启鼠标滚轮功能 > 3)
        {
            开启鼠标滚轮功能 = 1
        }
        滚轮功能 = 开启鼠标滚轮功能
        鼠标缩放尺寸 = 滚轮调整尺寸
        滚动条状态 = 显示滚动条
        后台画板.画板背景色 = 本对象.画板背景色
        前台画板 = 本对象
        父窗口对象 = 父窗口
        区域左边 = 本对象.左边
        区域顶边 = 本对象.顶边
        区域宽度 = 本对象.宽度
        区域高度 = 本对象.高度
        如果真 (初始值 == 0)
        {
            初始值 = 本对象.高度
        }
        如果真 (初始值 > 0)
        {
            区域高度 = 初始值
        }
    }

    方法 置鼠标滚轮功能_ <注释 = "图片浏览命令" 折叠>
    参数 开启鼠标滚轮功能 <类型 = 整数 注释 = "0、关闭　1、开启缩放　2、开启滚动　3、智能选择模式(当只有高度超出屏幕时，使用滚动，宽度超出使用缩放)" @默认值 = 1>
    参数 滚轮调整尺寸 <类型 = 整数 @默认值 = 50>
    {
        如果真 (开启鼠标滚轮功能 < 0 || 开启鼠标滚轮功能 > 3)
        {
            开启鼠标滚轮功能 = 1
        }
        滚轮功能 = 开启鼠标滚轮功能
        鼠标缩放尺寸 = 滚轮调整尺寸
    }

    方法 同宽显示_ <公开 注释 = "图片浏览命令" 折叠>
    {
        图片尺寸 = 图片资源.取图片尺寸 ()
        临时宽 = 图片尺寸.宽度
        临时高 = 图片尺寸.高度
        如果真 (临时宽 > 前台画板.宽度)
        {
            临时高 = 四舍五入 ((小数)(前台画板.宽度 * 临时高 / 临时宽), )
            临时宽 = 前台画板.宽度
        }
        显示图片 ()
    }

    方法 缩略显示_ <公开 注释 = "图片浏览命令" 折叠>
    {
        如果真 (临时宽 > 前台画板.宽度)
        {
            临时高 = 四舍五入 ((小数)(前台画板.宽度 / 临时宽 * 临时高 - 10), )
            临时宽 = 前台画板.宽度
        }
        如果真 (临时高 > 前台画板.高度)
        {
            临时宽 = 四舍五入 ((小数)(前台画板.高度 / 临时高 * 临时宽), )
            临时高 = 前台画板.高度 - 10
        }
        显示图片 ()
    }

    方法 实际大小_ <公开 注释 = "图片浏览命令" 折叠>
    {
        图片尺寸 = 图片资源.取图片尺寸 ()
        临时宽 = 图片尺寸.宽度
        临时高 = 图片尺寸.高度
        显示图片 ()
    }

    方法 缩放图片_ <公开 注释 = "图片浏览命令" 折叠>
    参数 类型 <类型 = 整数 注释 = "1、放大 2、缩小" @默认值 = 1>
    参数 缩放尺寸 <类型 = 整数 注释 = "每次缩放的尺寸" @默认值 = 50>
    参数 是否居中 <类型 = 逻辑型 注释 = "真：始终按居中  假：按当前中心点缩放" @默认值 = 假>
    {
        临时宽 = 图片尺寸.宽度
        临时高 = 图片尺寸.高度
        如果 (类型 == 1)
        {
            如果 (后台画板.宽度 < 4000)
            {
                临时宽 = 后台画板.宽度 + 缩放尺寸
            }
            否则
            {
                返回
            }
        }
        否则
        {
            如果 (后台画板.宽度 > 120)
            {
                临时宽 = 后台画板.宽度 - 缩放尺寸
            }
            否则
            {
                返回
            }
        }
        临时高 = 四舍五入 ((小数)(临时宽 * 后台画板.高度 / 后台画板.宽度), )
        显示图片 (是否居中)
    }

    方法 加载图片_ <公开 注释 = "单张图片;" 注释 = "图片浏览命令" 折叠 折叠2>
    参数 图片来源 <类型 = 文本型>
    {
        轮播总宽度 = 0
        图片资源 = 载入位图文件 (图片来源)
        图片尺寸 = 图片资源.取图片尺寸 ()
        临时宽 = 图片尺寸.宽度
        临时高 = 图片尺寸.高度
        缩略显示_ ()
    }

    方法 加载图片2_ <公开 注释 = "单张图片;" 注释 = "图片浏览命令" 折叠 折叠2>
    参数 图片来源 <类型 = 字节集类>
    {
        轮播总宽度 = 0
        图片资源 = 载入位图数据 (图片来源)
        图片尺寸 = 图片资源.取图片尺寸 ()
        临时宽 = 图片尺寸.宽度
        临时高 = 图片尺寸.高度
        缩略显示_ ()
    }

    方法 加载轮播图_ <公开 注释 = "轮播图命令" 折叠>
    参数 图片来源 <类型 = 文本数组类 注释 = "图片尺寸要一致">
    参数 浮点位置 <类型 = 整数 注释 = "1、图内左侧 2、图内居中 3、图内右侧 4、图外底部左 5、图外底部中 6、隐藏浮点;" 注释 = "当参数为4或5时，显示区高度将缩小25，也就是组件实际高度应为：图片高度＋25" 折叠2
            @默认值 = 4>
    参数 浮点样式 <类型 = 整数 注释 = "1、圆角 2、正方" @默认值 = 1>
    参数 浮点激活颜色 <类型 = 整数 @默认值 = 颜色类.天蓝色>
    参数 浮点通常颜色 <类型 = 整数 @默认值 = 颜色类.浅灰色>
    参数 底部颜色 <类型 = 整数 注释 = "浮点位置为4或5时，本参数生效" @默认值 = 颜色类.黑色>
    参数 圆角显示 <类型 = 逻辑型 @默认值 = 假>
    参数 轮播周期 <类型 = 整数 注释 = "图片停留时间；不为0时，则自动轮播;" 注释 = "单位：毫秒，1000毫秒 = 1秒" 折叠2 @默认值 = 2000>
    参数 移动距离 <类型 = 整数 注释 = "通过修改本值来改变轮播速度，值越大速度越快" @默认值 = 7>
    {
        变量 动态画板 <类型 = 动态画板类_>
        变量 临时画板 <类型 = 画板>
        变量 临时资源 <类型 = 位图对象类>
        变量 i <类型 = 整数>
        临时画板.清除 ()
        前台画板.清除 ()
        循环 (, 分段区间值.取成员数 (), i)
        {
            临时浮点 [i].销毁 ()
        }
        分段区间值.删除所有成员 ()
        如果真 (圆角显示 == 真)
        {
            窗口_圆角化窗口组件 (前台画板.取窗口句柄 (), 3, 3)
        }
        临时画板 = 动态画板.创建画板 (父窗口对象, 0, 0, 0, 0)
        临时画板.画板背景色 = 颜色类.黄色
        临时画板.可视 = 假
        临时画板.自动重画 = 真
        临时画板.画板背景色 = 颜色类.黄色
        如果真 (图片来源.取成员数 () == 0)
        {
            信息框_ ("请加载图片！", 64, "提示！")
            返回
        }
        临时资源 = 载入位图文件 (图片来源.取成员 (0))
        图片尺寸 = 临时资源.取图片尺寸 ()
        临时宽 = 图片尺寸.宽度 * 取屏幕DPI ()
        临时高 = 图片尺寸.高度 * 取屏幕DPI ()
        分段宽度 = (整数)临时宽
        置轮播速度_ (移动距离)
        轮播总宽度 = 图片来源.取成员数 () * (整数)临时宽
        如果真 (图片来源.取成员数 () > 20)
        {
            信息框_ ("最多支持20张图片。", 64, "提示！")
            返回
        }
        如果真 (轮播总宽度 > 32722)
        {
            信息框_ ("已超出了所支持的最大尺寸32722，请减小尺寸。", 64, "提示！")
            返回
        }
        临时画板.移动 (, , 轮播总宽度, (整数)临时高)
        分段数量 = 图片来源.取成员数 ()
        循环 (, 分段数量, i)
        {
            临时画板.画图片 (载入位图文件 (图片来源.取成员 (i)), (整数)临时宽 * i, 0, (整数)临时宽, (整数)临时高)
            分段区间值.加入成员 ((i + 1) * 分段宽度)
        }
        临时画板.取图片 (临时资源)
        图片资源 = 临时资源
        变量 临时间隔值 <类型 = 整数>
        变量 左侧基数值 <类型 = 整数>
        临时间隔值 = 分段数量 * 9 + 分段数量 * 7
        如果 (浮点位置 == 1)
        {
            左侧基数值 = 区域左边 + 20
        }
        否则 (浮点位置 == 2)
        {
            左侧基数值 = 区域左边 + (区域宽度 - 临时间隔值) / 2
        }
        否则 (浮点位置 == 3)
        {
            左侧基数值 = 区域宽度 - 临时间隔值 - 10
        }
        否则 (浮点位置 == 4)
        {
            左侧基数值 = 区域左边 + 20
        }
        否则 (浮点位置 == 5)
        {
            左侧基数值 = 区域左边 + (区域宽度 - 临时间隔值) / 2
        }
        如果真 (浮点位置 == 4 || 浮点位置 == 5)
        {
            前台画板.高度 = 区域高度 - 25
            临时画板 = 底部画板.创建画板 (父窗口对象, 区域左边, 区域顶边 + 区域高度 - 30, 区域宽度, 25)
            临时画板.画板背景色 = 底部颜色
            如果真 (圆角显示 == 真)
            {
                窗口_圆角化窗口组件 (临时画板.取窗口句柄 (), 3, 3)
            }
        }
        循环 (, 分段数量, i)
        {
            临时浮点 [i] = 动态浮点.创建图片框 (父窗口对象, 左侧基数值 + i * 16, 区域顶边 + 区域高度 - 20, 9, 9)
            临时浮点 [i].调整层次 (组件层次.顶层)
            临时浮点 [i].标准鼠标指针 = 标准鼠标指针类型.手型
            如果真 (浮点位置 == 6)
            {
                临时浮点 [i].可视 = 假
            }
            挂接事件 (临时浮点 [i], i)
            如果真 (浮点样式 == 1)
            {
                窗口_圆角化窗口组件 (临时浮点 [i].取窗口句柄 (), 5, 5)
            }
            如果 (i == 0)
            {
                临时浮点 [i].背景颜色 = 浮点激活颜色
                集浮点激活色 = 浮点激活颜色
            }
            否则
            {
                临时浮点 [i].背景颜色 = 浮点通常颜色
                集浮点通常色 = 浮点通常颜色
            }
        }
        显示图片 ()
        横向滚动条1.位置 = 0
        纵向滚动条1.位置 = 0
        移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
        集轮播周期 = 轮播周期
        时钟1.启动时钟_ (轮播周期)
    }

    方法 加载轮播图2_ <公开 注释 = "轮播图命令" 折叠>
