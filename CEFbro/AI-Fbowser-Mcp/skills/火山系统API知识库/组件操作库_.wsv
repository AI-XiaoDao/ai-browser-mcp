                {
                    临时标签.底图 = 全局量.附加图标1
                    临时标签.提示信息 = 全局量.附加提示1
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
                否则 (i == 23)
                {
                    临时标签.底图 = 全局量.附加图标2
                    临时标签.提示信息 = 全局量.附加提示2
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
                否则 (i == 24)
                {
                    临时标签.底图 = 全局量.附加图标3
                    临时标签.提示信息 = 全局量.附加提示3
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
                否则 (i == 25)
                {
                    临时标签.底图 = 全局量.附加图标4
                    临时标签.提示信息 = 全局量.附加提示4
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
                否则 (i == 26)
                {
                    临时标签.底图 = 全局量.附加图标5
                    临时标签.提示信息 = 全局量.附加提示5
                    如果真 (控件是否居中)
                    {
                        临时标签.顶边 = (上边框高度 - 控件图标高度) / 2
                    }
                }
