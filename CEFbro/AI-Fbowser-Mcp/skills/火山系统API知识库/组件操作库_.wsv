    {
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        返回 (0)
    }
}

类 横向滚动条类_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"组件操作库.滚动条库\"" @视窗.布局 = "client_size = \"350, 10\"">
{
    变量 图片框_滚动条 <类型 = 图片框 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 100, 10\"" 底色 = 0xCBC5C1>
    变量 标签_底板 <类型 = 标签 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"144, 0, 136, 16\"">
    变量 时钟1 <类型 = 时钟类_线程2>
    变量 图片框左边 <类型 = 整数>
    变量 原横坐标 <类型 = 整数>
    变量 原纵坐标 <类型 = 整数>
    变量 鼠标按下 <类型 = 逻辑型>
    变量 度数 <类型 = 整数 值 = 5 "">
    变量 滚动高值 <类型 = 整数>
    变量 正常颜色 <类型 = 整数 值 = 0x8D8989>
    变量 激活颜色 <类型 = 整数 值 = 0x605C5C>
    变量 滚动条属性 <类型 = 滚动条属性>
    变量 滚轮 <类型 = 逻辑型>
    变量 滚动值 <类型 = 整数 值 = 7>
    变量 差值 <类型 = 整数 值 = 7>
    变量 无滚动样式 <类型 = 整数>
    变量 句柄组 <类型 = 变整数数组类>
    变量 展示宽度 <类型 = 整数>

    方法 获取焦点_ <公开 折叠>
    {
        图片框_滚动条.获取焦点 ()
    }

    方法 初始化滚动条_ <公开 类型 = 变整数数组类 返回值注释 = "将返回2个成员句柄；1.滚动条　2.本容器　；可用于无事件触发时，绑定“挂接事件类_”" 折叠>
    参数 展示区宽度 <类型 = 整数 注释 = "当前可视区宽度，不包括隐藏部分，即滑块条滑动区域">
    参数 展示区总宽度 <类型 = 整数 注释 = "包括隐藏部份(显示区＋隐藏区)">
    参数 滚动条高度 <类型 = 整数 注释 = "默认为组件拖动大小" @默认值 = -1>
    参数 圆角度数 <类型 = 整数 @默认值 = 5>
    参数 开启鼠标滚轮事件 <类型 = 逻辑型 注释 = "并将“开启滚动_”命令放入“窗口组件_滚轮被滚动”事件下调用" @默认值 = 真>
    参数 滚动面值 <类型 = 整数 注释 = "鼠标滚轮滚动距离，本参数为比例值，非绝对值" @默认值 = 7>
    参数 标准鼠标指针 <类型 = 整数 注释 = "1、箭头　2、手型　；为空则默认为自定义指针类型" @默认值 = 0>
    参数 滚动条背景色 <类型 = 整数 注释 = "如果组件设置了颜色，将跟随组件颜色" @默认值 = 0xCBC5C1>
    参数 滚动条颜色 <类型 = 整数 @默认值 = 0x8D8989>
    参数 滚动条激活色 <类型 = 整数 @默认值 = 0x605C5C>
    参数 无滚动时样式 <类型 = 整数 注释 = "1、显示　2、半隐藏　3、全隐藏" @默认值 = 1>
    参数 固定滑块宽度 <类型 = 整数 注释 = "默认为动态计算，当设置固定值后，滑块宽度将被固定" @默认值 = -1>
    {
        变量 滑块条宽度 <类型 = 小数>
        变量 鼠标资源 <类型 = 鼠标指针资源 值 = "..\\tb\\关闭.cur">
        如果真 (本对象.宽度 == 0)
        {
            调试输出 ("请在：设计器－布局内容－选择横向滚动条－然后左侧调整该布局器大小", 64, "温馨提示！")
            结束 ()
        }
        滚动条属性.展示区宽度 = 展示区宽度
        滚动条属性.展示区总宽度 = 展示区总宽度
        滚动条属性.位置2 = 0
        滚动值 = 滚动面值
        滚轮 = 开启鼠标滚轮事件
        差值 = 展示区总宽度 - 展示区宽度
        如果 (差值 > 10)
        {
            差值 = 10
        }
        滑块条宽度 = (小数)展示区宽度 / 展示区总宽度 * 展示区宽度
        如果真 (滑块条宽度 < 30)
        {
            滑块条宽度 = 30
        }
        图片框_滚动条.可视 = 真
        无滚动样式 = 0
        展示宽度 = 展示区宽度
        如果真 (差值 < 1)
        {
            无滚动样式 = 无滚动时样式
            如果 (无滚动样式 == 1)
            {
                滑块条宽度 = 100
            }
            否则 (无滚动样式 == 2)
            {
                图片框_滚动条.可视 = 假
            }
            否则
            {
                本对象.可视 = 假
            }
        }
        如果真 (固定滑块宽度 > -1)
        {
            滑块条宽度 = 固定滑块宽度
        }
        滚动条属性.滑块条宽度 = (整数)滑块条宽度
        图片框_滚动条.宽度 = (整数)滑块条宽度
        如果 (滚动条高度 == -1)
        {
            滚动条高度 = 本对象.高度
        }
        度数 = 圆角度数
        滚动高值 = 滚动条高度
        置滚动条尺寸_ (滚动条高度, 圆角度数)
        滚动条属性.最大右边 = 展示区总宽度 - 展示区宽度
        如果 (本对象.底色 != -16777216)
        {
            如果 (滚动条背景色 != 13354433)
            否则
            {
                滚动条背景色 = 本对象.底色
            }
        }
        置滚动条颜色_ (滚动条背景色, 滚动条颜色, 滚动条激活色)
        本对象.底色 = 滚动条背景色
        标签_底板.背景颜色 = 滚动条背景色
        如果 (标准鼠标指针 == 1)
        {
            图片框_滚动条.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
        }
        否则 (标准鼠标指针 == 2)
        {
            图片框_滚动条.标准鼠标指针 = 标准鼠标指针类型.手型
        }
        否则
        {
            图片框_滚动条.自定义鼠标指针 = 鼠标资源
        }
        句柄组.删除所有成员 ()
        句柄组.加入成员 (图片框_滚动条.取窗口句柄 ())
        句柄组.加入成员 (标签_底板.取窗口句柄 ())
        返回 (句柄组)
    }

    方法 重置滚动条_ <公开 注释 = "当需滚动的内容宽度发生改变时，需要重置滚动条范围" 折叠>
    参数 展示区宽度 <类型 = 整数 注释 = "当前可视区高度，不包括隐藏部分，即滑块条滑动区域">
    参数 展示区总宽度 <类型 = 整数 注释 = "包括隐藏部份(显示区＋隐藏区)">
    参数 展示区总容器 <类型 = 组件布局器 注释 = "即需提供展示区总高度的组件，包括隐藏部份(显示区＋隐藏区)的组件;" 注释 = "本参数为空，则按当前滚动条位置来重置。不为空则精确按照当前容器位置来重置" @默认值 = 空对象>
    参数 固定滑块宽度 <类型 = 整数 注释 = "默认为动态计算，当设置固定值后，滑块宽度将被固定" @默认值 = -1>
    {
        变量 滑块条宽度 <类型 = 小数>
        如果真 (展示区总宽度 < 展示区宽度)
        {
            展示区总宽度 = 展示区宽度
        }
        滚动条属性.展示区宽度 = 展示区宽度
        滚动条属性.展示区总宽度 = 展示区总宽度
        滚动条属性.位置2 = 图片框_滚动条.左边
        差值 = 展示区总宽度 - 展示区宽度
        如果 (差值 > 10)
        {
            差值 = 10
        }
        图片框_滚动条.可视 = 真
        本对象.可视 = 真
        无滚动样式 = 0
        如果真 (差值 < 1)
        {
            如果 (无滚动样式 == 1)
            {
                滑块条宽度 = 100
            }
            否则 (无滚动样式 == 2)
            {
                图片框_滚动条.可视 = 假
            }
            否则
            {
                本对象.可视 = 假
            }
        }
        滑块条宽度 = (小数)展示区宽度 / 展示区总宽度 * 展示区宽度
        如果真 (滑块条宽度 < 30)
        {
            滑块条宽度 = 30
        }
        如果真 (固定滑块宽度 > -1)
        {
            滑块条宽度 = 固定滑块宽度
        }
        滚动条属性.滑块条宽度 = (整数)滑块条宽度
        图片框_滚动条.宽度 = (整数)滑块条宽度
        置滚动条尺寸_ (滚动高值, 度数)
        滚动条属性.最大右边 = 展示区总宽度 - 展示区宽度
        如果 (展示区总容器.是否为空对象 () == 真)
        {
            调整位置 (滚动条属性.位置2)
        }
        否则
        {
            变量 比例值 <类型 = 小数>
            变量 滑块位置 <类型 = 整数>
            比例值 = (小数)(展示区总宽度 - 展示区宽度) / (展示区宽度 - 滚动条属性.滑块条宽度)
            滑块位置 = (整数)四舍五入 ((小数)展示区总容器.左边 / 比例值)
            滚动条属性.位置2 = 滑块位置
            图片框_滚动条.左边 = 位取反 (滑块位置 - 1)
        }
    }

    方法 置滚动条颜色_ <公开 折叠>
    参数 滚动条背景色 <类型 = 整数 @默认值 = 0xCBC5C1>
    参数 滚动条颜色 <类型 = 整数 @默认值 = 0x8D8989>
    参数 滚动条激活色 <类型 = 整数 @默认值 = 0x605C5C>
    {
        本对象.底色 = 滚动条背景色
        标签_底板.背景颜色 = 滚动条背景色
        图片框_滚动条.底色 = 滚动条颜色
        正常颜色 = 滚动条颜色
        激活颜色 = 滚动条激活色
    }

