        返回 (0)
    }

    方法 画板_滚轮被滚动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 滚动距离 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (滚轮功能 == 0)
        {
            返回 (0)
        }
        如果 (滚轮功能 == 1)
        {
            调用缩放 (滚动距离)
        }
        否则 (滚轮功能 == 2)
        {
            调用滚动 (滚动距离)
        }
        否则 (滚轮功能 == 3)
        {
            如果真 (临时宽 > 前台画板.宽度)
            {
                临时宽 = 前台画板.宽度
            }
            如果 (临时宽 <= 前台画板.宽度 && 临时高 > 前台画板.高度)
            {
                如果 (临时宽 < 前台画板.宽度)
                {
                    调用缩放 (滚动距离)
                }
                否则
                {
                    调用滚动 (滚动距离)
                }
            }
            否则
            {
                调用缩放 (滚动距离)
            }
        }
        返回 (0)
    }

    方法 调用缩放
    参数 滚动距离 <类型 = 整数>
    {
        如果 (滚动距离 > 0)
        {
            缩放图片_ (1, 鼠标缩放尺寸)
        }
        否则 (滚动距离 < 0)
        {
            缩放图片_ (2, 鼠标缩放尺寸)
        }
    }

    方法 调用滚动 <折叠>
    参数 滚动距离 <类型 = 整数>
    {
        如果 (滚动距离 > 0)
        {
            如果 (纵向滚动条1.位置 - 鼠标缩放尺寸 >= 0)
            {
                纵向滚动条1.位置 = 纵向滚动条1.位置 - 鼠标缩放尺寸
            }
            否则
            {
                纵向滚动条1.位置 = 0
            }
            移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
        }
        否则 (滚动距离 < 0)
        {
            如果 (纵向滚动条1.位置 - 鼠标缩放尺寸 <= 纵向滚动条1.最大位置)
            {
                纵向滚动条1.位置 = 纵向滚动条1.位置 + 鼠标缩放尺寸
            }
            否则
            {
                纵向滚动条1.位置 = 纵向滚动条1.最大位置
            }
            移动图片位置 (横向滚动条1.位置, 纵向滚动条1.位置)
        }
    }
}

