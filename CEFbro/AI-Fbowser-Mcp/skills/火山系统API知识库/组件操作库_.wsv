    参数 位置 <类型 = 整数>

    方法 滚动容器类__尺寸被改变 <接收事件 类型 = 整数 注释 = "当本组件的尺寸被改变后发送此事件" 折叠>
    参数 来源对象 <类型 = 滚动容器类_>
    参数 标记值 <类型 = 整数>
    {
        如果 (浮动 == 真)
        {
            容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度)
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度 - 宽高值)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度 - 宽高值)
        }
        否则
        {
            如果 (隐藏类型 == 3)
            {
                容器面板.移动 (0, 0, 本对象.宽度 + 1, 本对象.高度 + 1)
            }
            否则 (隐藏类型 == 1)
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 宽高值 + 1, 本对象.高度 + 1)
            }
            否则 (隐藏类型 == 2)
            {
                容器面板.移动 (0, 0, 本对象.宽度, 本对象.高度 + 1 - 宽高值 + 1)
            }
            否则
            {
                容器面板.移动 (0, 0, 本对象.宽度 - 宽高值 + 1, 本对象.高度 - 宽高值 + 1)
            }
            滚动条1.移动 (本对象.宽度 - 滚动条1.宽度 + 1, , , 本对象.高度 - 宽高值)
            滚动条2.移动 (, 本对象.高度 - 滚动条2.高度 + 1, 本对象.宽度 - 宽高值)
        }
        返回 (0)
    }

