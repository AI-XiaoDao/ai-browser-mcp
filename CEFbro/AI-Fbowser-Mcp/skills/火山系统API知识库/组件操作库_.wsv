                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
                }
                否则 (i == 8)  // 左下
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.北东箭头型
                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
                }
                否则 (i == 9)  // 右上
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.北东箭头型
                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
                }
                否则 (i == 10)  // 右中
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.西东箭头型
                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
                }
                否则 (i == 11)  // 右下
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.北西箭头型
                    }
                    否则
                    {
