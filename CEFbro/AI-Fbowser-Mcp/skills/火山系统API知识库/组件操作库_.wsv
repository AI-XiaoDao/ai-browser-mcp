    {
        本对象.获取焦点 ()
    }

    方法 调整位置 <折叠>
    参数 位值 <类型 = 整数>
    {
        变量 结果值 <类型 = 整数>
        变量 记忆值 <静态 类型 = 整数>
        如果真 (无滚动样式 > 0)
        {
            返回
        }
        结果值 = (整数)四舍五入 ((小数)(滚动条属性.展示区总高度 - 滚动条属性.展示区高度) / (滚动条属性.展示区高度 - 滚动条属性.滑块条高度) * 位值)
        滚动条属性.位置 = (整数)结果值
        如果真 (滚动条属性.位置 < 0)
        {
            滚动条属性.位置 = 0
            图片框_滚动条.顶边 = 0
        }
        如果真 (滚动条属性.位置 >= 滚动条属性.最大顶边)
        {
            滚动条属性.位置 = 滚动条属性.最大顶边
            图片框_滚动条.顶边 = 滚动条属性.展示区高度 - 滚动条属性.滑块条高度
        }
        如果真 (记忆值 != 滚动条属性.位置)
        {
            记忆值 = 滚动条属性.位置
            纵向改变事件 (位取反 (滚动条属性.位置 - 1))
        }
    }

    方法 显示隐藏滚动条_ <公开 注释 = "将本命令放入“窗口组件_鼠标位置被移动，我的主窗口_鼠标位置被移动”事件下调用" 折叠>
    参数 是否显示 <类型 = 逻辑型 @默认值 = 真>
    参数 是否有焦点 <类型 = 逻辑型 注释 = "当显示滚动条时，使其焦点在容器上，离开后将归还原焦点" @默认值 = 真>
    {
        变量 句柄 <静态 类型 = 变整数>
        如果 (是否显示 == 真)
        {
            如果真 (句柄 == 0 && 是否有焦点 == 真)
            {
                句柄 = 窗口_取焦点组件句柄 ()
                本对象.获取焦点 ()
            }
            本对象.可视 = 真
        }
        否则
        {
            本对象.可视 = 假
            如果真 (句柄 > 0 && 是否有焦点 == 真)
            {
                窗口_置窗口组件焦点2 (句柄)
                句柄 = 0
            }
        }
    }

    方法 开启滚动_ <公开 注释 = "将本命令放入“窗口组件_滚轮被滚动”事件下调用;" 注释 = "或用“鼠键钩子类_”中的鼠标滚轮事件" 折叠 折叠2>
    参数 滚动距离 <类型 = 整数 注释 = "判断滚动方向，下滚：<0　上滚：>0">
    参数 滚动面值 <类型 = 整数 注释 = "鼠标滚轮滚动距离，本参数为比例值，非绝对值" @默认值 = 7>
    {
        变量 位值 <类型 = 整数>
        如果真 (滚轮 == 真)
        {
            如果真 (窗口_取焦点组件句柄 () > 0)
            {
                如果真 (无滚动样式 > 0)
                {
                    返回
                }
                如果真 (滚动面值 != 7)
                {
                    滚动值 = 滚动面值
                }
                如果 (滚动距离 > 0)  // 上
                {
                    如果 (图片框_滚动条.顶边 - 滚动值 > 0)
                    {
                        位值 = 图片框_滚动条.顶边 - 滚动值
                    }
                    否则
                    {
                        位值 = 0
                    }
                }
                否则
                {
                    如果 (图片框_滚动条.顶边 + 滚动值 < 滚动条属性.展示区高度 - 滚动条属性.滑块条高度)
                    {
                        位值 = 图片框_滚动条.顶边 + 滚动值
                    }
                    否则
                    {
                        位值 = 滚动条属性.展示区高度 - 滚动条属性.滑块条高度
                    }
                }
                图片框_滚动条.顶边 = 位值
            }
        }
        调整位置 (位值)
    }

