        图片框_底栏 = 动态2.创建图片框 (容器, 0, 0, 0, 0)
        图片框_底栏.背景颜色 = 边框背景颜色
        挂接事件 (图片框_底栏)
        循环 (, 31, i)
        {
            标签组.加入成员 (动态.创建标签 (容器, 0, 0, 0, 0))
            挂接事件 ((标签)标签组.取成员 (标签组.取成员数 () - 1), i + 1)
            临时标签 = (标签)标签组.取成员 (i)
            如果 (i < 12)
            {
                如果 (i == 0)  // 上左
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.北西箭头型
                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
                }
                否则 (i == 1)  // 上中
                {
                    如果 (窗口大小是否可调节)
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.北南箭头型
                    }
                    否则
                    {
                        临时标签.标准鼠标指针 = 标准鼠标指针类型.标准箭头型
                    }
