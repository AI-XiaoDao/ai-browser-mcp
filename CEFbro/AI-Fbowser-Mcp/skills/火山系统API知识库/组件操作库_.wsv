    方法 内部关闭子夹 <折叠>
    参数 子夹标题 <类型 = 文本型>
    参数 子夹标记 <类型 = 文本型>
    参数 子夹索引 <类型 = 整数>
    {
        变量 临时左 <类型 = 整数>
        变量 临时宽 <类型 = 整数>
        如果 (全局量.允许关闭)
        {
            主线.投递通知 (子夹索引)
        }
        否则
        {
            临时左 = ((导航夹模板)子夹布局组.取成员 (子夹索引)).左边 + 图片框_头区.左边
            临时宽 = 临时左 + ((导航夹模板)子夹布局组.取成员 (子夹索引)).宽度
            如果 (临时左 < 0 || 临时宽 > 组件布局器_头区.宽度)
            {
                处理单击 (0, 子夹标题, 子夹标记, 子夹索引)
            }
            否则
            {
                如果 (横位 - 取鼠标水平位置 () < 4 && 横位 - 取鼠标水平位置 () > -3)
                {
                    如果 (纵位 - 取鼠标垂直位置 () < 4 && 纵位 - 取鼠标垂直位置 () > -3)
                    {
                        如果 (取启动时间 () - 时间点 < 330)
                        {
                            返回
                        }
                    }
                }
                横位 = 取鼠标水平位置 ()
                纵位 = 取鼠标垂直位置 ()
                时间点 = 取启动时间 ()
                主线.投递通知 (子夹索引)
            }
        }
    }

