    方法 调整间隔条 <折叠>
    {
        如果真 (子夹布局组.取成员数 () > 0)
        {
            子夹布局组.枚举循环 ()
            {
                如果真 (((导航夹模板)子夹布局组.取枚举值 ()).标签_竖条.宽度 != 1)
                {
                    ((导航夹模板)子夹布局组.取枚举值 ()).标签_竖条.宽度 = 1
                }
            }
            ((导航夹模板)子夹布局组.取成员 (子夹布局组.取成员数 () - 1)).标签_竖条.宽度 = 0
        }
    }

    方法 调整间隔条2 <折叠>
    参数 索引 <类型 = 整数>
    {
        ((导航夹模板)子夹布局组.取成员 (索引)).标签_竖条.宽度 = 0
        如果 (索引 - 1 > -1)
        {
            ((导航夹模板)子夹布局组.取成员 (索引 - 1)).标签_竖条.宽度 = 0
        }
    }

    方法 调整合适位置_移动 <折叠>
    参数 方向 <类型 = 整数 注释 = "1、左 2、右">
    {
        变量 临时左 <类型 = 整数>
        变量 临时左2 <类型 = 整数>
        变量 临时左3 <类型 = 整数>
        如果真 (子夹布局组.取成员数 () > 0)
        {
            临时左 = 图片框_头区.左边
            如果 (方向 == 1)
            {
                临时左 = 临时左 + 组件布局器_头区.宽度
                如果真 (临时左 > 0)
                {
                    临时左 = 0
                }
                图片框_头区.左边 = 临时左
            }
            否则
            {
                临时左 = 临时左 - 组件布局器_头区.宽度
                临时左2 = 全局量.子夹总宽
                临时左3 = 临时左2
                临时左2 = 临时左2 - 组件布局器_头区.宽度
                如果真 (取整数绝对值 (临时左) > 临时左2)
                {
                    临时左 = 组件布局器_头区.宽度 - 临时左3
                }
                如果真 (临时左 > 0)
                {
                    临时左 = 0
                }
                如果真 (图片框_头区.左边 != 临时左)
                {
                    图片框_头区.左边 = 临时左
                }
            }
        }
    }

    方法 调整合适位置_校正 <折叠>
    参数 子夹序 <类型 = 整数>
    {
        变量 临时左 <类型 = 整数>
        变量 临时宽 <类型 = 整数>
        临时左 = ((导航夹模板)子夹布局组.取成员 (子夹序)).左边
        临时左 = 临时左 + 图片框_头区.左边
        临时宽 = 临时左 + ((导航夹模板)子夹布局组.取成员 (子夹序)).宽度
        如果 (临时左 < 0)
        {
            如果真 (图片框_头区.左边 != 图片框_头区.左边 - 临时左)
            {
                如果 (图片框_头区.左边 - 临时左 > 0)
                {
                    图片框_头区.左边 = 0
                }
                否则
                {
                    图片框_头区.左边 = 图片框_头区.左边 - 临时左
                }
            }
        }
        否则
        {
            如果 (临时宽 > 组件布局器_头区.宽度)
            {
                临时左 = 临时宽 - 组件布局器_头区.宽度
                如果真 (图片框_头区.左边 != 图片框_头区.左边 - 临时左)
                {
                    如果 (图片框_头区.左边 - 临时左 > 0)
                    {
                        图片框_头区.左边 = 0
                    }
                    否则
                    {
                        图片框_头区.左边 = 图片框_头区.左边 - 临时左
                    }
                }
            }
        }
    }

    方法 取最后子夹位置 <类型 = 整数 折叠>
    {
        变量 数量 <类型 = 整数>
        变量 临时宽 <类型 = 整数>
        变量 i <类型 = 整数>
        数量 = 子夹布局组.取成员数 ()
        循环 (, 数量, i)
        {
            临时宽 = ((导航夹模板)子夹布局组.取成员 (数量 - i - 1)).宽度
            如果真 (临时宽 > 0)
            {
                临时宽 = 临时宽 + ((导航夹模板)子夹布局组.取成员 (数量 - i - 1)).左边
                跳出循环
            }
        }
        返回 (临时宽)
    }

    方法 高级主线程处理器_接收到通知 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 高级主线程处理器>
    参数 标记值 <类型 = 整数>
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    参数 参数对象 <类型 = 对象包装类>
    {
        删除子夹_ ((整数)通知码)
        返回 (0)
    }

    方法 窗口组件_组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 窗口组件>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        返回 (0)
    }
}

类 导航夹模板 <基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"组件操作库.窗口导航库.附加类\"" @视窗.布局 = "client_size = \"295, 89\"">
{
    变量 图片框_根容器 <公开 类型 = 图片框 折叠 编辑时信息 = "0, 6AAA4, 0, 0" 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 200, 40\"">
    变量 图片框_下划条 <公开 类型 = 图片框 折叠2 编辑时信息 = "0, 6AAA4, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 102\r\nparent_id = 101\r\npos = \"68, 38, 120, 2\"" 背景颜色 = 0xD9751E 可视 = 假>
    变量 标签_左图 <公开 类型 = 标签 折叠2 编辑时信息 = "0, 6AAA4, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 103\r\nparent_id = 101\r\npos = \"0, 2, 28, 28\"" 底图方式 = 图片居中>
    变量 标签_右图 <公开 类型 = 标签 折叠2 编辑时信息 = "0, 6AAA4, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 104\r\nparent_id = 101\r\npos = \"168, 8, 11, 11\"" 底图 = "..\\tb\\关闭1.png" 底图方式 = 图片居中 可视 = 假>
    变量 标签_标题 <公开 类型 = 标签 折叠2 编辑时信息 = "0, 6AAA4, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 105\r\nparent_id = 101\r\npos = \"48, 8, 80, 24\"" 标题 = "选择夹" 横向对齐方式 = 居中>
    变量 标签_右图2 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 106\r\nparent_id = 101\r\npos = \"160, 8, 11, 11\""
            底图 = "..\\tb\\关闭2.png" 底图方式 = 图片居中 可视 = 假>
    变量 标签_竖条 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 107\r\nparent_id = 101\r\npos = \"193, 12, 1, 24\"" 标题 = "|"
            文本颜色 = 0xC0C0C0 横向对齐方式 = 居中>
    变量 定义标记 <公开 类型 = 文本型 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 当前索引 <公开 类型 = 整数>
    变量 全局变量 <类型 = 导航夹变量 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 全局是否关闭区 <类型 = 逻辑型 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 移入移出 <类型 = 组件移入移出事件类_ 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 临时记忆 <类型 = 逻辑型>
    变量 临时记忆2 <类型 = 逻辑型 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 是否图2 <类型 = 逻辑型>
    变量 右侧图1 <类型 = 位图资源 值 = "..\\tb\\关闭1.png" 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 右侧图2 <类型 = 位图资源 值 = "..\\tb\\关闭2.png" 编辑时信息 = "0, 6AAA4, 0, 0">
    变量 全局是否锁定 <公开 类型 = 逻辑型>
    变量 全局是否锁死 <公开 类型 = 逻辑型>
    变量 全局字体名称 <类型 = 文本型>
    变量 全局字体大小 <类型 = 整数>
    变量 全局字体加粗 <类型 = 逻辑型>
    变量 全局正常标题颜色 <类型 = 整数>
    变量 全局子夹正常背景颜色 <类型 = 整数>
    变量 全局图标隐藏方式 <类型 = 整数>
    变量 全局左图标左侧间隔 <类型 = 整数>
    变量 全局右图标右侧间隔 <类型 = 整数>
    变量 全局图标大小 <类型 = 整数>
    变量 全局图标标题间隔 <类型 = 整数>
    变量 全局默认显示关闭 <类型 = 逻辑型>
    变量 全局下划线正常颜色 <类型 = 整数>
    变量 全局下划线位置 <类型 = 整数>
    变量 全局子夹间隔颜色 <类型 = 整数>
    变量 全局显示子夹间隔 <类型 = 逻辑型>
    变量 全局当前子夹索引 <类型 = 整数>
    变量 全局子夹热点背景颜色 <公开 类型 = 整数>

    方法 重置临时索引 <公开 折叠>
    参数 当前子夹索引 <类型 = 整数>
    {
        全局当前子夹索引 = 当前子夹索引
    }

    方法 初始化 <公开 折叠>
    参数 是否锁定 <类型 = 逻辑型>
    参数 是否锁死 <类型 = 逻辑型>
    参数 字体名称 <类型 = 文本型>
    参数 字体大小 <类型 = 整数>
    参数 是否加粗 <类型 = 逻辑型>
    参数 正常标题颜色 <类型 = 整数>
    参数 子夹正常背景颜色 <类型 = 整数>
    参数 图标隐藏方式 <类型 = 整数>
    参数 左图标左侧间隔 <类型 = 整数>
    参数 右图标右侧间隔 <类型 = 整数>
    参数 图标大小 <类型 = 整数>
    参数 图标标题间隔 <类型 = 整数>
    参数 显示子夹间隔 <类型 = 逻辑型>
    参数 默认显示关闭 <类型 = 逻辑型>
    参数 下划线正常颜色 <类型 = 整数>
    参数 下划线位置 <类型 = 整数>
    参数 子夹间隔颜色 <类型 = 整数>
    参数 当前子夹索引 <类型 = 整数>
    参数 子夹热点背景颜色 <类型 = 整数>
    参数 子夹头是否透明 <类型 = 逻辑型>
    {
        全局是否锁定 = 是否锁定
        全局是否锁死 = 是否锁死
        全局字体名称 = 字体名称
        全局字体大小 = 字体大小
        全局字体加粗 = 是否加粗
        全局正常标题颜色 = 正常标题颜色
        全局子夹正常背景颜色 = 子夹正常背景颜色
        全局图标隐藏方式 = 图标隐藏方式
        全局左图标左侧间隔 = 左图标左侧间隔
        全局右图标右侧间隔 = 右图标右侧间隔
        全局图标大小 = 图标大小
        全局图标标题间隔 = 图标标题间隔
        全局显示子夹间隔 = 显示子夹间隔
        全局默认显示关闭 = 默认显示关闭
        全局下划线正常颜色 = 下划线正常颜色
        全局下划线位置 = 下划线位置
        全局子夹间隔颜色 = 子夹间隔颜色
        全局当前子夹索引 = 当前子夹索引
        全局子夹热点背景颜色 = 子夹热点背景颜色
        本对象.透明 = 子夹头是否透明
        图片框_根容器.透明 = 子夹头是否透明
    }

    方法 排版子夹 <公开 折叠>
    参数 子夹图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 子夹标记 <类型 = 文本型 @默认值 = "">
    参数 子夹索引 <类型 = 整数 @默认值 = -1>
    参数 提示信息 <类型 = 文本型 注释 = "定义一个鼠标停留时的提示" @默认值 = "">
    参数 默认图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    {
        标签_标题.字体 = 全局字体名称 + "," + 到文本 (全局字体大小) + "," + 到文本 (全局字体加粗)
        标签_标题.文本颜色 = 全局正常标题颜色
        图片框_根容器.背景颜色 = 全局子夹正常背景颜色
        定义标记 = 子夹标记
        当前索引 = 子夹索引
        如果 (子夹图标 != 空资源.空位图)
        {
            标签_左图.底图 = 子夹图标
        }
        否则
        {
            标签_左图.底图 = 默认图标
        }
        图片框_根容器.移动 (0, 0, 取用户区宽度 (), 取用户区高度 ())
        如果 (全局图标隐藏方式 != 0)
        {
            如果 (全局图标隐藏方式 == 1)
            {
                标签_左图.移动 (, , 0, 0)
                标签_右图.移动 (取用户区宽度 () - 标签_右图.宽度 - 全局右图标右侧间隔, (取用户区高度 () - 标签_右图.高度) / 2, , )
                标签_右图2.移动 (标签_右图.左边, 标签_右图.顶边, , )
                标签_标题.移动 (0, 0, 取用户区宽度 () - 标签_右图.宽度 - 全局右图标右侧间隔 - 全局图标标题间隔, 取用户区高度 ())
            }
            否则 (全局图标隐藏方式 == 2)
            {
                标签_左图.移动 (, , 全局图标大小, 全局图标大小)
                标签_左图.移动 (全局左图标左侧间隔, (取用户区高度 () - 标签_左图.高度) / 2, , )
                标签_右图.移动 (, , 0, 0)
                标签_右图2.移动 (, , 0, 0)
                标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 全局图标标题间隔, 0, 取用户区宽度 () - 标签_左图.左边 - 标签_左图.宽度 - 全局左图标左侧间隔 - 全局图标标题间隔, 取用户区高度 ())
            }
            否则
            {
                标签_左图.移动 (, , 0, 0)
                标签_右图.移动 (, , 0, 0)
                标签_右图2.移动 (, , 0, 0)
                标签_标题.移动 (0, 0, 取用户区宽度 (), 取用户区高度 ())
            }
        }
        否则
        {
            标签_左图.移动 (, , 全局图标大小, 全局图标大小)
            标签_左图.移动 (全局左图标左侧间隔, (取用户区高度 () - 标签_左图.高度) / 2, , )
            标签_右图.移动 (取用户区宽度 () - 标签_右图.宽度 - 全局右图标右侧间隔, (取用户区高度 () - 标签_右图.高度) / 2, , )
            标签_右图2.移动 (标签_右图.左边, 标签_右图.顶边, , )
            标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 全局图标标题间隔, 0, 取用户区宽度 () - 标签_左图.左边 - 标签_左图.宽度 - 标签_右图.宽度 - 全局右图标右侧间隔 - 全局图标标题间隔 * 2, 取用户区高度 ())

        }
        如果真 (全局显示子夹间隔)
        {
            标签_竖条.高度 = 图片框_根容器.高度 / 2
            标签_竖条.移动 (图片框_根容器.宽度 - 1, (图片框_根容器.高度 - 标签_竖条.高度) / 2, , )
            标签_竖条.可视 = 真
        }
        如果真 (全局默认显示关闭)
        {
            标签_右图.可视 = 真
        }
        如果 (全局下划线位置 == 2)
        {
            图片框_下划条.移动 (0, 图片框_根容器.高度 - 2, 图片框_根容器.宽度)
        }
        否则
        {
            图片框_下划条.移动 (0, 0, 图片框_根容器.宽度)
        }
        图片框_下划条.背景颜色 = 全局下划线正常颜色
        标签_竖条.文本颜色 = 全局子夹间隔颜色
        标签_竖条.背景颜色 = 全局子夹间隔颜色
        本对象.底色 = 全局子夹正常背景颜色
        置提示信息 (提示信息)
    }

    方法 置提示信息 <公开 折叠>
    参数 提示信息 <类型 = 文本型>
    {
        标签_标题.提示信息 = 提示信息
        标签_左图.提示信息 = 提示信息
        标签_右图.提示信息 = 提示信息
        标签_右图2.提示信息 = 提示信息
        图片框_下划条.提示信息 = 提示信息
        图片框_根容器.提示信息 = 提示信息
    }

    方法 标签_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 标签>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (全局是否锁定 && 全局是否锁死)
        {
            返回 (0)
        }
        如果 (来源对象 == 标签_左图)
        {
            标签_右图2.可视 = 假
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                标签_右图.可视 = 真
            }
            如果真 (临时记忆2 != 假)
            {
                临时记忆2 = 假
            }
            鼠标位置移动 (标签_左图.左边 + 横向位置, 标签_左图.顶边 + 纵向位置)
        }
        否则 (来源对象 == 标签_右图)
        {
            如果真 (全局是否锁定 && 全局是否锁死)
            {
                返回 (0)
            }
            如果真 (临时记忆2 != 真)
            {
                临时记忆2 = 真
                标签_右图2.可视 = 真
                标签_右图.可视 = 假
            }
            如果真 (标签_右图2.可视 == 假)
            {
                标签_右图2.可视 = 真
                标签_右图.可视 = 假
            }
            鼠标位置移动 (标签_右图.左边 + 横向位置, 标签_右图.顶边 + 纵向位置, 真)
        }
        否则 (来源对象 == 标签_右图2)
        {
            鼠标位置移动 (标签_右图2.左边 + 横向位置, 标签_右图2.顶边 + 纵向位置, 真)
        }
        否则 (来源对象 == 标签_标题)
        {
            标签_右图2.可视 = 假
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                标签_右图.可视 = 真
            }
            如果真 (临时记忆2 != 假)
            {
                临时记忆2 = 假
            }
            鼠标位置移动 (标签_标题.左边 + 横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_竖条)
        {
            标签_右图2.可视 = 假
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                标签_右图.可视 = 真
            }
            如果真 (临时记忆2 != 假)
            {
                临时记忆2 = 假
            }
            鼠标位置移动 (标签_竖条.左边 + 横向位置, 纵向位置)
        }
        返回 (0)
    }

    方法 图片框_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 图片框>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (全局是否锁定 && 全局是否锁死)
        {
            返回 (0)
        }
        如果 (来源对象 == 图片框_根容器)
        {
            标签_右图2.可视 = 假
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                标签_右图.可视 = 真
            }
            鼠标位置移动 (横向位置, 纵向位置)
        }
        否则 (来源对象 == 图片框_下划条)
        {
            标签_右图2.可视 = 假
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                标签_右图.可视 = 真
            }
            鼠标位置移动 (横向位置, 图片框_根容器.高度 - 2 + 纵向位置)
        }
        返回 (0)
    }

    方法 标签_鼠标左键被按下 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 标签>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (全局是否锁定 && 全局是否锁死)
        {
            返回 (0)
        }
        如果 (来源对象 == 标签_标题)
        {
            子夹被单击事件 (0, 标签_标题.标题, 定义标记, 当前索引, 全局当前子夹索引)
        }
        否则 (来源对象 == 标签_左图 || 来源对象 == 标签_竖条)
        {
            子夹被单击事件 (0, 标签_标题.标题, 定义标记, 当前索引, 全局当前子夹索引)
        }
        否则 (来源对象 == 标签_右图 || 来源对象 == 标签_右图2)
        {
            如果真 (全局是否锁定 == 假 && 全局是否锁死 == 假)
            {
                子夹被关闭事件 (标签_标题.标题, 定义标记, 当前索引)
            }
        }
        返回 (0)
    }

