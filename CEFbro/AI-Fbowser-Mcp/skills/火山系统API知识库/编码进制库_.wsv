# //=====

类 编码转换类_ <公开 折叠 折叠2 @文档 = "category = \"编码进制库.编码转换\"" @全局类 = 真>
{
    方法 多字节到文本_ <公开 静态 类型 = 文本型 折叠>
    参数 多字节集数据 <类型 = 字节集类>
    {
        返回 (转Ascii到Unicode_ (多字节集数据))
    }

    方法 文本到多字节_ <公开 静态 类型 = 字节集类 折叠>
    参数 待转数据 <类型 = 文本型>
    参数 是否包含结束零字符 <类型 = 逻辑型 @默认值 = 假>
    {
        返回 (转Unicode到Ascii_ (待转数据, 是否包含结束零字符))
    }

    方法 转Ascii到Unicode_ <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 Ascii数据 <类型 = 字节集类>
    {
        变量 Str <类型 = 变整数>
        变量 Len <类型 = 整数>
        变量 Buffer <类型 = 文本型>
        Str = 取字节集指针 (Ascii数据)
        Len = 取字节集长度 (Ascii数据)
        @ int Size = MultiByteToWideChar(CP_ACP,0,(LPCSTR)@<Str>,-1,0,0);
        @ Size++;
        @ LPWSTR Buffer = new TCHAR[Size]();
        @ MultiByteToWideChar(CP_ACP,0,(LPCSTR)@<Str>,@<Len>,Buffer,Size);
        @ @<Buffer> = Buffer;
        @ delete[] Buffer;
        @ return @<Buffer>.GetText();
    }

    方法 转Ascii到Unicode2_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 Ascii数据 <类型 = 变整数>
    {
        @  int textlen = 0;
        @  wchar_t * result;
        @  textlen = MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<Ascii数据>,-1,NULL,0 );  
        @  result = (wchar_t *)malloc((textlen+1)*sizeof(wchar_t));
        @  result[textlen] = L'\0';
        @  MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<Ascii数据>,-1,result,textlen);  
        @  @an<CVolString> str = result;
        @  free (result);
        @ return str;
    }

    方法 转Unicode到Ascii_ <公开 静态 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 Unicode数据 <类型 = 文本型>
    参数 是否包含结束零字符 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 lpBuffer <类型 = 变整数>
        变量 Size <类型 = 整数>
        变量 ByteStr <类型 = 字节集类>
        lpBuffer = 取文本指针 (Unicode数据)
        @ @<Size> = WideCharToMultiByte(CP_ACP,0,(LPCWSTR)@<lpBuffer>,-1,0,0,0,0);
        分配字节集 (ByteStr, 选择 (是否包含结束零字符, Size, Size - 1))
        @ WideCharToMultiByte(CP_ACP,0,(LPCWSTR)@<lpBuffer>,-1,(LPSTR)@<ByteStr>.GetPtr(),@<Size>,0,0);
        返回 (ByteStr)
    }

