类 进制转换类_ <公开 折叠 折叠2 @文档 = "category = \"编码进制库.进制转换\"" @全局类 = 真>
{
    方法 文本到二进制文本_ <公开 静态 类型 = 文本型 注释 = "将文本数据转换到二进制文本" 折叠>
    参数 数据 <类型 = 文本型>
    参数 是否分隔 <类型 = 逻辑型 注释 = "是否每隔1个字节插入一个空格" @默认值 = 真>
    {
        返回 (字节集到二进制文本_ (文本到多字节_ (数据, 假), 是否分隔))
    }

    方法 字节集到二进制文本_ <公开 静态 类型 = 文本型 注释 = "将字节集数据转换到二进制文本" 折叠>
    参数 数据 <类型 = 字节集类>
    参数 是否分隔 <类型 = 逻辑型 注释 = "是否每隔1个字节插入一个空格" @默认值 = 真>
    {
        变量 二进数据 <类型 = 文本型>
        变量 数据长度 <类型 = 整数>
        数据长度 = 数据.取字节集长度 ()
        置文本预分配字符数 (二进数据, 数据长度 * 8 + 选择 (是否分隔, 数据长度, 0))
        计次循环 (数据长度)
        {
            变量 值 <类型 = 字节>
            值 = 数据.取字节集数据 (取循环索引 (), 字节)
            逆向计次循环 (8)
            {
                加入字符 (二进数据, (字符)选择 (位与 (1, 位右移 (值, 取循环索引 ())) == 1, '1', '0'))
            }
            如果 (是否分隔 && 取循环索引 () < 数据长度 - 1)
            {
                加入字符 (二进数据, ' ')
            }
        }
        返回 (二进数据)
    }

    方法 二进制文本到文本_ <公开 静态 类型 = 文本型 注释 = "将二进制文本转换到文本数据" 折叠>
    参数 文本 <类型 = 文本型>
    {
        返回 (多字节到文本_ (二进制文本到字节集_ (文本)))
    }

    方法 二进制文本到字节集_ <公开 静态 类型 = 字节集类 注释 = "将二进制文本转换到字节集数据" 折叠>
    参数 文本 <类型 = 文本型>
    {
        变量 长度 <类型 = 整数>
        变量 临时 <类型 = 整数>
        变量 初值 <类型 = 整数>
        变量 串值 <类型 = 整数>
        变量 索引 <类型 = 整数>
        变量 二进数据 <类型 = 字节集类>
        变量 i <类型 = 整数>
        变量 ii <类型 = 整数>
        长度 = 取文本长度 (文本)
        临时 = 取代码_ (文本, 8)
        二进数据.重分配字节集 (长度 / 4)
        初值 = 128
        循环 (, 长度, i)
        {
            临时 = 取代码_ (文本, i)
            如果真 (临时 != 32)
            {
                如果真 (临时 == 49)
                {
                    串值 = 位或 (串值, 初值)
                }
                初值 = 位右移 (初值, 1)
                索引 = 索引 + 1
            }
            如果真 (索引 == 8)
            {
                二进数据.置字节集值 (ii, (字节)串值)
                初值 = 128
                串值 = 0
                索引 = 0
                ii = ii + 1
            }
        }
        返回 (二进数据.取字节集左边 (ii))
    }

    方法 整数到二进制文本_ <公开 静态 类型 = 文本型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<string>\r\n<bitset>">
    参数 整数值 <类型 = 整数 注释 = "例如将7转成0111" "">
    {
        @ std::string binary = std::bitset<32>(@<整数值>).to_string();
        @ int index = 0;
        @ for (int i = 0; i < binary.size(); i++) {
        @     if (binary[i] == '1') {
        @         index = i;
        @         break;
        @     }
        @ }
        @ std::string result = binary.substr(index);
        @  size_t paddingSize = (4 - (result.size() % 4)) % 4;
        @  std::string padding(paddingSize, '0');
        @  result = padding + result;  
        @  return CVolString(result.c_str());  
    }

    方法 任意进制到任意进制_ <公开 静态 类型 = 文本型 注释 = "2-128进制间的任意转换" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "string">
    参数 待转数值 <类型 = 文本型>
    参数 原进制 <类型 = 整数 注释 = "该数值原本进制">
    参数 目标进制 <类型 = 整数 注释 = "转换后的进制">
    参数 是否有符号 <类型 = 逻辑型 @默认值 = 假>
    {
        @ using namespace std;
        @     const string BASE128_CHARS = 
        @         "0123456789"
        @         "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        @         "abcdefghijklmnopqrstuvwxyz"
        @         "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
        @         "\x01\x02\x03\x04\x05\x06\x07\x08\x0B\x0C\x0D\x0E\x0F"
        @         "\x10\x11\x12\x13\x14\x15\x16\x17\x18\x19\x1A\x1B\x1C\x1D\x1E\x1F"
        @         "\x7F";
        @     string number =std::string (CU8String (@<待转数值>).GetText ());
        @     int fromBase = @<原进制>;
        @     int toBase = @<目标进制>;
        @     bool signedConversion = @<是否有符号>;
        @     bool isNegative = false;
        @     if (signedConversion && !number.empty() && number[0] == '-') {
        @         isNegative = true;
        @         number.erase(0, 1);
        @     }
        @     if (fromBase < 2 || fromBase > 128 || toBase < 2 || toBase > 128) {
        @         return "";
        @     }
        @     bool isValid = true;
        @     for (char c : number) {
        @         size_t pos = BASE128_CHARS.find(c);
        @         if (pos == string::npos || static_cast<int>(pos) >= fromBase) {
        @             isValid = false;
        @             break;
        @         }
        @     }
        @     if (!isValid || number.empty()) {
        @         return "";
        @     }
        @     string decimal = "0";
        @     for (char c : number) {
        @         int digit = static_cast<int>(BASE128_CHARS.find(c));
        @         string product;
        @         int carry = 0;
        @         for (int i = decimal.size() - 1; i >= 0; i--) {
        @             int val = (decimal[i] - '0') * fromBase + carry;
        @             product.push_back((val % 10) + '0');
        @             carry = val / 10;
        @         }
        @         while (carry > 0) {
        @             product.push_back((carry % 10) + '0');
        @             carry /= 10;
        @         }
        @         reverse(product.begin(), product.end());
        @         string sum;
        @         carry = digit;
        @         for (int i = product.size() - 1; i >= 0; i--) {
        @             int val = (product[i] - '0') + carry;
        @             sum.push_back((val % 10) + '0');
        @             carry = val / 10;
        @         }
        @         if (carry > 0) {
        @             sum.push_back(carry + '0');
        @         }
        @         reverse(sum.begin(), sum.end());
        @         decimal = sum;
        @     }
        @     if (signedConversion && isNegative && decimal != "0") {
        @         decimal = "-" + decimal;
        @     }
        @     string result;
        @     if (signedConversion && !decimal.empty() && decimal[0] == '-') {
        @         result = "-";
        @         decimal.erase(0, 1);
        @     }
        @     if (decimal != "0") {
        @         string tempDecimal = decimal;
        @         while (tempDecimal != "0") {
        @             string quotient;
        @             int remainder = 0;
        @             for (char digit : tempDecimal) {
        @                 int current = remainder * 10 + (digit - '0');
        @                 if (!quotient.empty() || current >= toBase) {
        @                     quotient.push_back(current / toBase + '0');
        @                 }
        @                 remainder = current % toBase;
        @             }
        @             if (quotient.empty()) {
        @                 quotient = "0";
        @             }
        @             result.push_back(BASE128_CHARS[remainder]);
        @             tempDecimal = quotient;
        @         }
        @         reverse(result.begin() + (signedConversion && result[0] == '-' ? 1 : 0), result.end());
        @     } else {
        @         result = "0";
        @     }
        @ return result.c_str();
    }

