    }

    方法 转URL解码_字节集 <公开 静态 类型 = 字节集类 注释 = "对URL编码数据进行解码" 折叠 @禁止流程检查 = 真>
    参数 待转数据 <类型 = 字节集类 注释 = "提供所欲进行解码的数据">
    {
        @ size_t DestLen = piv::encoding::GuessUrlDecodeBound(@<待转数据>.GetPtr(),
        @                                                     static_cast<size_t>(@<待转数据>.GetSize()));
        @ if (DestLen < @<待转数据>.GetSize()) {
        @     @an<CVolMem> decode;
        @     piv::encoding::UrlDecode(@<待转数据>.GetPtr(), static_cast<size_t>(@<待转数据>.GetSize()),
        @                              decode.Alloc(static_cast<INT_P>(DestLen), TRUE), DestLen);
        @     return decode;
        @ }
        @ return @<待转数据>;
    }

    方法 编码_转URL解码_字节集 <公开 静态 类型 = 字节集类 注释 = "对URL编码数据进行解码" 折叠>
    参数 待转数据 <类型 = 字节集类 注释 = "提供所欲进行解码的数据">
    {
        返回 (转URL解码_字节集 (待转数据))
    }

    方法 转URL解码_文本 <公开 静态 类型 = 文本型 注释 = "对URL编码数据进行解码" 折叠 @禁止流程检查 = 真>
    参数 待转数据 <类型 = 文本型 注释 = "提供所欲进行解码的文本" 编辑时信息 = "1392F, 0, 0, 0">
    参数 是否UTF8 <类型 = 逻辑型 注释 = "URL编码文本是否为UTF-8格式,否则为多字节." 编辑时信息 = "1392F, 0, 0, 0" @默认值 = 真>
    {
        @ size_t DestLen;
        @ if (@<是否UTF8>) {
        @     PivW2U urlstr {@<待转数据>.GetText()};
        @     DestLen = piv::encoding::GuessUrlDecodeBound(reinterpret_cast<BYTE *>(urlstr.data()), urlstr.size_bytes());
        @     if (DestLen < static_cast<size_t>(urlstr.size_bytes())) {
        @         @an<CVolMem> buffer;
        @         piv::encoding::UrlDecode(reinterpret_cast<BYTE *>(urlstr.data()), urlstr.size_bytes(),
        @                                  reinterpret_cast<BYTE *>(buffer.Alloc(static_cast<INT_P>(DestLen), TRUE)), DestLen);
        @         return *PivU2Ws {reinterpret_cast<const char *>(buffer.GetPtr()), DestLen};
        @     }
        @ } else {
        @     PivW2A urlstr {@<待转数据>.GetText()};
        @     DestLen = piv::encoding::GuessUrlDecodeBound(reinterpret_cast<BYTE *>(urlstr.data()), urlstr.size_bytes());
        @     if (DestLen < static_cast<size_t>(urlstr.size_bytes())) {
        @         @an<CVolMem> buffer;
        @         piv::encoding::UrlDecode(reinterpret_cast<BYTE *>(urlstr.data()), urlstr.size_bytes(),
        @                                  reinterpret_cast<BYTE *>(buffer.Alloc(static_cast<INT_P>(DestLen), TRUE)), DestLen);
        @         return *PivA2Ws {reinterpret_cast<const char *>(buffer.GetPtr()), DestLen};
        @     }
        @ }
        @ return @<待转数据>;
    }

