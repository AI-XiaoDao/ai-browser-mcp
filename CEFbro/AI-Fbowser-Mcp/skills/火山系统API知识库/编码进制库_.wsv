类 编码判断类_ <公开 注释 = "1、如果2个字节是0xFF 0xFE,则以Unicode（LE）的方式读取" 注释 = "2、如果2个字节是0xFE 0xFF,则以Unicode BE的方式读取"
        注释 = "3、如果前2个字节是0xEF 0xBB，那么判断第3个字节是不是0xBF，如果是的话就以UTF-8的方式进行读取。" 注释 = "4、判断是否符合UTF-8的编码规范，如果符合就以UTF-8的方式进行读取"
        注释 = "5、如果以上都不是，则以ANSI的方式进行读取。" 折叠 折叠2 @文档 = "category = \"编码进制库.编码判断\"" @全局类 = 真>
{
    方法 取编码类型_字节集 <公开 静态 类型 = 文本型 折叠>
    参数 文本数据 <类型 = 字节集类>
    {
        变量 单个无符号字节 <类型 = "整数 [2]">
        如果真 (文本数据.字节集是否为空 () == 真)
        {
            返回 ("")
        }
        如果 (取字节集长度 (文本数据) >= 2)
        {
            单个无符号字节 [0] = 无符号字节到整数 (文本数据.取字节集数据 (0, 字节))
            单个无符号字节 [1] = 无符号字节到整数 (文本数据.取字节集数据 (1, 字节))
        }
        如果 (单个无符号字节 [0] >= 239)
        {
            如果 (单个无符号字节 [0] == 239 && 单个无符号字节 [1] == 187)
            {
                返回 ("UTF8_BOM")
            }
            否则 (单个无符号字节 [0] == 254 && 单个无符号字节 [1] == 255)
            {
                返回 ("UTF_16_BE")
            }
            否则 (单个无符号字节 [0] == 255 && 单个无符号字节 [1] == 254)
            {
                返回 ("UTF_16_LE")
            }
            否则 (是否符合UTF8规范_ (文本数据))
            {
                返回 ("UTF_8")
            }
            否则
            {
                返回 ("ASCII")
            }
        }
        否则 (是否符合UTF8规范_ (文本数据))
        {
            返回 ("UTF_8")
        }
        返回 ("ASCII")
    }

    方法 取编码类型_文件 <公开 静态 类型 = 文本型 折叠>
    参数 文件路径 <类型 = 文本型 注释 = "例如：“C:\\\\测试.txt”">
    {
        返回 (取编码类型_字节集 (读入文件 (文件路径)))
    }

    方法 是否符合UTF8规范_ <公开 静态 类型 = 逻辑型 折叠>
    参数 文本数据 <类型 = 字节集类>
    {
        变量 数据长度 <类型 = 整数>
        变量 字符占用长度 <类型 = 整数 值 = 0>
        变量 单个无符号字节 <类型 = 整数>
        变量 全部字符符合ASCII <类型 = 逻辑型 值 = 真>
        数据长度 = 取字节集长度 (文本数据)
        计次循环 (数据长度)
        {
            单个无符号字节 = 无符号字节到整数 (文本数据.取字节集数据 (取循环索引 (), 字节))
            如果 (位与 (单个无符号字节, 128) != 0)
            {
                全部字符符合ASCII = 假
            }
            如果 (字符占用长度 == 0)
            {
                如果 (单个无符号字节 >= 128)
                {
                    如果 (单个无符号字节 >= 252 && 单个无符号字节 <= 253)
                    {
                        字符占用长度 = 6
                    }
                    否则 (单个无符号字节 >= 248)
                    {
                        字符占用长度 = 5
                    }
                    否则 (单个无符号字节 >= 240)
                    {
                        字符占用长度 = 4
                    }
                    否则 (单个无符号字节 >= 224)
                    {
                        字符占用长度 = 3
                    }
                    否则 (单个无符号字节 >= 192)
                    {
                        字符占用长度 = 2
                    }
                    否则
                    {
                        返回 (假)
                    }
                    字符占用长度 = 字符占用长度 - 1
                }
            }
            否则 (位与 (单个无符号字节, 192) != 128)
            {
                返回 (假)
            }
            否则
            {
                字符占用长度 = 字符占用长度 - 1
            }
        }
        如果 (字符占用长度 > 0)
        {
            返回 (假)
        }
        如果 (全部字符符合ASCII)
        {
            返回 (假)
        }
        返回 (真)
    }
}

