    方法 十六进制转十进制2_ <公开 静态 类型 = 变整数 注释 = "无符号转换" 折叠 @禁止流程检查 = 真>
    参数 十六进制 <类型 = 文本型>
    {
        @ return (INT64) Hex2UP (@<十六进制>.GetText ());
    }

    方法 十六进制转十进制3_ <公开 静态 类型 = 变整数 注释 = "有符号转换" 折叠 @禁止流程检查 = 真>
    参数 十六进制 <类型 = 文本型>
    {
        @ return (INT32) Hex2UP (@<十六进制>.GetText ());
    }

    方法 十进制转三十六进制_ <公开 静态 类型 = 文本型 折叠>
    参数 十进制数据 <类型 = 长整数>
    {
        变量 剩余十进制数 <类型 = 长整数>
        变量 余数 <类型 = 整数>
        变量 三十六进制数 <类型 = 文本型>
        变量 str <类型 = 文本型>
        str = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        剩余十进制数 = 十进制数据
        循环判断首 ()
        {
            余数 = (整数)(剩余十进制数 % 36)
            剩余十进制数 = 剩余十进制数 / 36
            三十六进制数 = 取文本中间 (str, 余数, 1) + 三十六进制数
        }
        循环判断尾 (剩余十进制数 >= 36)
        三十六进制数 = 取文本中间 (str, (整数)剩余十进制数, 1) + 三十六进制数
        返回 (三十六进制数)
    }

    方法 三十六进制转十进制_ <公开 静态 类型 = 长整数 折叠>
    参数 三十六进制数据 <类型 = 文本型>
    {
        变量 文本长度 <类型 = 整数>
        变量 此次字符 <类型 = 文本型>
        变量 十进制和 <类型 = 长整数>
        变量 str <类型 = 文本型>
        变量 szTmp <类型 = 文本型>
        变量 nPos <类型 = 整数>
        str = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        文本长度 = 取文本长度 (三十六进制数据)
        计次循环 (文本长度)
        {
            此次字符 = 取文本中间 (三十六进制数据, 文本长度 - 取循环索引 () - 1, 1)
            szTmp = 到大写 (取文本左边 (此次字符, 1))
            nPos = 寻找文本 (str, szTmp, , 假) + 1
            十进制和 = 十进制和 + 选择 (nPos == -1 || nPos == 1, 0, nPos - 1) * (长整数)求次方 (36, 取循环索引 ())
        }
        返回 (十进制和)
    }

    方法 十六进制字符到数值_ <公开 静态 类型 = 字符 注释 = "将一个十六进制字符转换到10进制数值," 注释 = "如果指定字符不是十六进制,则返回原值." 注释 = "例: \'0\'->0, \'f\'->16" 折叠 折叠2
            @禁止流程检查 = 真>
    参数 字符值 <类型 = 字符>
    {
        @ if (@<字符值> >= '0' && @<字符值> <= '9')
        @     return @<字符值> - '0';
        @ if (@<字符值> >= 'a' && @<字符值> <= 'f')
        @     return @<字符值> - 'a' + 10;
        @ if (@<字符值> >= 'A' && @<字符值> <= 'F')
        @     return @<字符值> - 'A' + 10;
        @ return @<字符值>;
    }
}

