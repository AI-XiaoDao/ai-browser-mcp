    方法 解析有道云笔记_ <公开 静态 类型 = 文本型 注释 = "直接返回笔记内容" 折叠>
    参数 解析网址 <类型 = 文本型 注释 = "例如：https://note.youdao.com/s/5TCWtv0J">
    参数 是否换行 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 网络 <类型 = 网络访问类_ 编辑时信息 = "0, B1106, 0, 0">
        变量 头数据 <类型 = 文本型>
        变量 头数据2 <类型 = 文本数组类>
        变量 数据包 <类型 = 文本型>
        变量 id值 <类型 = 文本型>
        变量 JSON <类型 = JSON对象类_>
        变量 模版 <类型 = 文本型
                值 = "https://note.youdao.com/yws/api/note/###?sev=j1&editorType=1&unloginId=ebf5d5aa-3c03-1df4-1767-98654ecf14ab&editorVersion=new-json-editor&sec=v1">
        变量 组合包 <类型 = 文本型>
        变量 成员数 <类型 = 整数>
        网络.网页访问_B (解析网址, 2, , , , , -1, , 头数据)
        分割文本 (头数据, "\n", 头数据2)
        如果真 (头数据2.取成员数 () > 0)
        {
            头数据2.枚举循环 ()
            {
                id值 = 删全部空_ (取文本右边2_ (头数据2.取枚举值 (), "id="))
                如果真 (id值 != "")
                {
                    跳出循环
                }
            }
            如果 (取文本长度 (id值) < 7)
            {
                返回 ("ID错误")
            }
            否则
            {
                子文本替换 (模版, "###", id值, , , )
                数据包 = 网络.网页访问_T (模版)
                如果真 (JSON.创建自文本 (数据包) == 真)
                {
                    数据包 = JSON.取文本值 ("content")
                    如果真 (JSON.创建自文本 (数据包))
                    {
                        数据包 = JSON.取文本值 ("/5")
                        如果真 (JSON.创建自文本 (数据包))
                        {
                            成员数 = JSON.成员数
                            如果 (成员数 > 1)
                            {
                                计次循环 (成员数)
                                {
                                    数据包 = JSON.取文本值 ("/" + 到文本 (取循环索引 ()) + "/5/0/7/0/8")
                                    如果 (取循环索引 () + 1 < 成员数)
                                    {
                                        如果真 (文本是否为空 (数据包) == 假)
                                        {
                                            如果 (是否换行)
                                            {
                                                加入文本 (组合包, 数据包 + "\r\n")
                                            }
                                            否则
                                            {
                                                加入文本 (组合包, 数据包)
                                            }
                                        }
                                    }
                                    否则
                                    {
                                        加入文本 (组合包, 数据包)
                                    }
                                }
                            }
                            否则
                            {
                                数据包 = JSON.取文本值 ("/0/5")
                                如果真 (JSON.创建自文本 (数据包))
                                {
                                    成员数 = JSON.成员数
                                    计次循环 (成员数)
                                    {
                                        数据包 = JSON.取文本值 ("/" + 到文本 (取循环索引 ()) + "/7/0/8")
                                        如果 (取循环索引 () + 1 < 成员数)
                                        {
                                            如果真 (文本是否为空 (数据包) == 假)
                                            {
                                                如果 (是否换行)
                                                {
                                                    加入文本 (组合包, 数据包 + "\r\n")
                                                }
                                                否则
                                                {
                                                    加入文本 (组合包, 数据包)
                                                }
                                            }
                                            数据包 = JSON.取文本值 ("/" + 到文本 (取循环索引 ()) + "/5/0/7/0/8")
                                            如果真 (文本是否为空 (数据包) == 假)
                                            {
                                                如果 (是否换行)
                                                {
                                                    加入文本 (组合包, 数据包 + "\r\n")
                                                }
                                                否则
                                                {
                                                    加入文本 (组合包, 数据包)
                                                }
                                            }
                                        }
                                        否则
                                        {
                                            加入文本 (组合包, 数据包)
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        返回 (组合包)
    }

    方法 解析有道云直链_ <公开 静态 类型 = 文本型 折叠>
    参数 解析网址 <类型 = 文本型 注释 = "例如：https://note.youdao.com/s/90r6Ndxk">
    参数 是否为视频 <类型 = 逻辑型 注释 = "真：解析视频直播" @默认值 = 假>
    {
        变量 网络 <类型 = 网络访问类_ 编辑时信息 = "0, B1106, 0, 0">
        变量 头数据 <类型 = 文本型>
        变量 头数据2 <类型 = 文本数组类 编辑时信息 = "0, B1106, 0, 0">
        变量 数据包 <类型 = 文本型>
        变量 id值 <类型 = 文本型 编辑时信息 = "0, B1106, 0, 0">
        变量 P值 <类型 = 文本型>
        变量 前网址 <类型 = 文本型 值 = "https://note.youdao.com/yws/public/note/" 编辑时信息 = "0, B1106, 0, 0">
        变量 前网址2 <类型 = 文本型 值 = "https://note.youdao.com/yws/api/personal/file">
        变量 后网址 <类型 = 文本型 值 = "?editorType=0&cstk=cGtjFpHb">
        变量 后网址2 <类型 = 文本型 值 = "?method=download&shareKey=">
        变量 后网址3 <类型 = 文本型 值 = "?method=download&inline=true&shareKey=">
        变量 JSON <类型 = JSON对象类_>
        网络.网页访问_B (解析网址, 2, , , , , -1, , 头数据)
        分割文本 (头数据, "\n", 头数据2)
        如果真 (头数据2.取成员数 () > 0)
        {
            头数据2.枚举循环 ()
            {
                id值 = 删全部空_ (取文本右边2_ (头数据2.取枚举值 (), "id="))
                如果真 (id值 != "")
                {
                    跳出循环
                }
            }
            如果 (取文本长度 (id值) < 7)
            {
                返回 ("")
            }
            否则
            {
                数据包 = 网络.网页访问_T (前网址 + id值 + 后网址)
                如果 (取文本长度 (数据包) < 12)
                {
                    返回 ("")
                }
                否则
                {
                    JSON.创建自文本 (数据包)
                    如果 (JSON.成员数 > 0)
                    {
                        P值 = JSON.取文本值 ("p")
                        如果 (取文本长度 (P值) > 7)
                        {
                            如果 (是否为视频 == 假)
                            {
                                返回 (前网址2 + P值 + 后网址2 + id值)
                            }
                            否则
                            {
                                返回 (前网址2 + P值 + 后网址3 + id值)
                            }
                        }
                        否则
                        {
                            返回 ("")
                        }
                    }
                    否则
                    {
                        返回 ("")
                    }
                }
            }
        }
        返回 ("")
    }

    方法 解析微云笔记_ <公开 静态 类型 = 文本型 注释 = "主要用于服务器变更后解决程序无法更新问题。笔记内容可以为IP地址或下载链接" 折叠>
    参数 解析网址 <类型 = 文本型 注释 = "例如：https://share.weiyun.com/s8plMmDT">
    参数 数据地址标记 <类型 = 文本型 注释 = "即微云笔记中需取的数据段前后所标记的标记数据." 注释 = "例如：###a192.168.1.88b###，前后的###即是地址标记" @默认值 = "###">
    参数 前标记 <类型 = 文本型 注释 = "例如###a192.168.1.88b###的前标记是a">
    参数 后标记 <类型 = 文本型 注释 = "例如###a192.168.1.88b###的后标记是b">
    参数 是否包含前后标记 <类型 = 逻辑型 注释 = "即所取笔记内容是否包含“前标记”、“后标记”参数数据" @默认值 = 假>
    {
        变量 网络 <类型 = 网络访问类_>
        变量 数据包 <类型 = 文本型>
        变量 数据组 <类型 = 文本数组类>
        变量 结果 <类型 = 文本型>
        数据包 = 网络.网页访问_T (解析网址, , , , , , )
        数据组 = 取文本中间_批量 (数据包, 数据地址标记, 数据地址标记, , )
        数据组.枚举循环 ()
        {
            数据包 = 数据组.取枚举值 ()
            如果 (取文本左边 (数据包, 取文本长度 (前标记)) == 前标记 && 取文本右边 (数据包, 取文本长度 (后标记)) == 后标记)
            {
                如果 (是否包含前后标记)
                {
                    结果 = 数据包
                }
                否则
                {
                    结果 = 取文本中间_ (数据包, 前标记, 后标记, , , , )
                }
                跳出循环
            }
        }
        返回 (结果)
    }
}

