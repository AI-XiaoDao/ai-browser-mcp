类 代理IP类_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.代理设置\"" @全局类 = 真>
{
    方法 置代理IP_ <公开 静态 类型 = 逻辑型 折叠 折叠2 @视窗.外部头文件 = "<wininet.h>" @视窗.外部库 = "Wininet.lib" @禁止流程检查 = 真>
    参数 代理IP <类型 = 文本型 注释 = "例如：“121.235.194.23:31015”，如需取消代理则将本参数留空即可" @默认值 = "">
    {
        注册表写整数_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings", "ProxyEnable", 选择 (代理IP == "", 0, 1))
        注册表写文本_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings", "ProxyServer", 代理IP)
        @  BOOL rebool=InternetSetOptionW(0,39,0,0);
        @ return rebool;
    }
}

