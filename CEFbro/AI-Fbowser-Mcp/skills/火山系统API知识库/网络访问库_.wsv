    方法 网页访问_T <公开 类型 = 文本型 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 注释 = "提交字节集数据" @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 @默认值 = "">
    参数 提交Cookies <类型 = 文本型 @默认值 = "">
    参数 禁止重定向 <类型 = 逻辑型 @默认值 = 假>
    参数 代理地址 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 是否补全协议头 <类型 = 逻辑型 @默认值 = 真>
    参数 返回内容转码方式 <类型 = 整数 注释 = "1、UTF8到文本　2、多字节到文本　3、多字节到文本 (Utf8到多字节()))" @默认值 = 1>
    {
        变量 临时文本 <类型 = 文本型>
        如果 (返回内容转码方式 == 1)
        {
            加入文本 (临时文本, UTF8到文本_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 禁止重定向, 代理地址, 代理密码, 是否补全协议头)))
        }
        否则 (返回内容转码方式 == 2)
        {
            加入文本 (临时文本, 多字节到文本_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 禁止重定向, 代理地址, 代理密码, 是否补全协议头)))
        }
        否则 (返回内容转码方式 == 3)
        {
            加入文本 (临时文本, 多字节到文本_ (UTF8到多字节_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 禁止重定向, 代理地址, 代理密码, 是否补全协议头))))
        }
        返回 (临时文本)
    }

