类 网址IP处理类_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.IP域名操作\"" @全局类 = 真>
{
    方法 域名转IP地址_ <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 域名 <类型 = 文本型>
    {
        变量 cp <类型 = 字节集类>
        变量 h_addr_list <类型 = 文本型>
        变量 临时域名 <类型 = 文本型>
        临时域名 = 到小写 (域名)
        子文本替换 (临时域名, "http://", "")
        子文本替换 (临时域名, "https://", "")
        @ WSADATA WSAData;
        @ if (!WSAStartup(MAKEWORD(1, 1), &WSAData))
        @ {
        cp = 文本到多字节 (临时域名)
        @ hostent* host = gethostbyname((LPCSTR)@<cp>.GetPtr());
        @ if (host)
        @ {
        @ @<h_addr_list>.SetValueText(inet_ntoa(*(struct in_addr*)host->h_addr_list[0]));
        @ }
        @ WSACleanup();
        @ }
        @ return @<h_addr_list>.GetText();
    }

    方法 取网址域名_ <公开 静态 类型 = 文本型 注释 = "网站地址取域名，支持http:// 或 https://" 折叠>
    参数 网络地址 <类型 = 文本型 "">
    {
        变量 临时网络地址 <类型 = 文本型>
        变量 位置 <类型 = 整数>
        变量 URL <类型 = 文本型>
        临时网络地址 = 网络地址
        如果真 (文本是否为空 (临时网络地址))
        {
            返回 ("")
        }
        如果 (文本比较 (取文本左边 (临时网络地址, 7), "http://", 假) != 0 && 文本比较 (取文本左边 (临时网络地址, 8), "https://", 假) != 0)
        {
            位置 = 寻找文本 (临时网络地址, "/", , 真)
            如果 (位置 > 0)
            {
                URL = 取文本左边 (临时网络地址, 位置 - 1)
            }
            否则
            {
                URL = 临时网络地址
            }
        }
        否则
        {
            位置 = 寻找文本 (临时网络地址, "/", 8, 真)
            如果 (位置 > 0)
            {
                如果 (寻找文本 (临时网络地址, "https://", , ) != -1)
                {
                    URL = 取文本中间 (临时网络地址, 8, 位置 - 8)
                }
                否则
                {
                    URL = 取文本中间 (临时网络地址, 7, 位置 - 7)
                }
            }
            否则
            {
                如果 (寻找文本 (临时网络地址, "https://", , ) != -1)
                {
                    文本替换 (临时网络地址, 0, 8, "")
                }
                否则
                {
                    文本替换 (临时网络地址, 0, 7, "")
                }
                URL = 临时网络地址
            }
        }
        如果真 (URL == "")
        {
            返回 ("")
        }
        位置 = 寻找文本 (URL, ":", 1, 真)
        如果真 (位置 > 0)
        {
            URL = 取文本左边 (URL, 位置)
        }
        返回 (URL)
    }

    方法 取网址端口_ <公开 静态 类型 = 整数 注释 = "网站地址取端口号，支持80或443" 折叠>
    参数 网络地址 <类型 = 文本型>
    {
        变量 临时网络地址 <类型 = 文本型>
        变量 结果 <类型 = 文本型>
        临时网络地址 = 网络地址
        如果真 (文本是否为空 (临时网络地址))
        {
            返回 (0)
        }
        如果真 (寻找文本 (临时网络地址, "http", , 真) == -1)
        {
            临时网络地址 = "http" + 临时网络地址
        }
        临时网络地址 = 临时网络地址 + "/"
        结果 = 取文本中间_ (临时网络地址, ":", "/", 6)
        如果 (文本是否为空 (结果))
        {
            返回 (选择 (寻找文本 (临时网络地址, "http://", , 真) != -1, 80, 443))
        }
        否则
        {
            返回 (文本到整数 (结果))
        }
    }

    方法 取网址地址_ <公开 静态 类型 = 文本型 注释 = "网站地址取不包含域名的网页地址 如 /a/abc.php" 折叠>
    参数 网络地址 <类型 = 文本型>
    {
        变量 位置 <类型 = 整数>
        变量 name <类型 = 文本型>
        如果真 (文本是否为空 (网络地址))
        {
            返回 ("")
        }
        name = 取网址域名_ (网络地址)
        位置 = 寻找文本 (网络地址, "/", 寻找文本 (网络地址, name, 1, 真), 真)
        如果 (位置 > 0)
        {
            返回 (取文本右边 (网络地址, 取文本长度 (网络地址) - 位置))
        }
        否则
        {
            返回 ("/")
        }
    }

    方法 修改IP网关_ <公开 静态 折叠>
    参数 IP地址 <类型 = 文本型 注释 = "例如：192.168.1.8" @默认值 = "">
    参数 子网掩码 <类型 = 文本型 注释 = "例如：255.255.255.0" @默认值 = "">
    参数 默认网关 <类型 = 文本型 注释 = "例如：192.168.1.1" @默认值 = "">
    参数 首选DNS <类型 = 文本型 注释 = "例如：114.114.114.114" @默认值 = "">
    参数 备用DNS <类型 = 文本型 注释 = "例如：8.8.8.8" @默认值 = "">
    参数 本地连接名称 <类型 = 文本型 注释 = "本地网络名称，留空则为：本地连接" @默认值 = "本地连接">
    {
        如果真 (IP地址 != "" || 子网掩码 != "" || 默认网关 != "")
        {
            运行 ("netsh interface ip set address " + 本地连接名称 + " static " + IP地址 + " " + 子网掩码 + " " + 默认网关 + " 1", 真, 程序窗口显示方式.隐藏窗口)
        }
        如果真 (首选DNS != "")
        {
            运行 ("netsh interface ip set dns " + 本地连接名称 + " static " + 首选DNS, 真, 程序窗口显示方式.隐藏窗口)
        }
        如果真 (备用DNS != "")
        {
            运行 ("netsh interface ip add dns " + 本地连接名称 + " addr=" + 备用DNS + " 2", 真, 程序窗口显示方式.隐藏窗口)
        }
    }

    方法 修改IP网关_自动 <公开 静态 折叠>
    参数 本地连接名称 <类型 = 文本型 注释 = "本地网络名称，留空则为：本地连接" @默认值 = "本地连接">
    {
        运行 ("netsh interface ip set address " + 本地连接名称 + " dhcp", 真, 程序窗口显示方式.隐藏窗口)
        运行 ("netsh interface ip set dns " + 本地连接名称 + " dhcp", 真, 程序窗口显示方式.隐藏窗口)
    }

    方法 取外网IP_ <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        变量 网络 <类型 = 网络访问类_ 编辑时信息 = "0, E1103, 0, 0">
        变量 结果 <类型 = 文本型 编辑时信息 = "0, E1103, 0, 0">
        变量 JSON <类型 = JSON对象类_ 编辑时信息 = "0, E1103, 0, 0">
        如果 (JSON.创建自文本 (网络.网页访问_T ("https://2025.ipchaxun.com/")))
        {
            如果 (JSON.取文本值 ("ret") == "ok")
            {
                结果 = JSON.取文本值 ("ip")
            }
        }
        如果真 (结果 == "")
        {
            结果 = 网络.网页访问_T ("http://ddns.oray.com/checkip")
            结果 = 取文本右边_ (结果, ": ")
        }
        如果真 (结果 == "")
        {
            结果 = 网络.网页访问_T ("https://ipv4.gdt.qq.com/get_client_ip", , , , , , )
            如果 (寻找文本 (结果, ".") == -1 || 寻找文本 (结果, ".", 4) == -1)
            {
                结果 = ""
            }
        }
        返回 (结果)
    }

    方法 取内网IP_ <公开 静态 类型 = 文本型 注释 = "单网卡" 折叠 @禁止流程检查 = 真>
    {
        变量 运行结果 <类型 = 文本型>
        运行控制台程序 ("ipconfig", 运行结果)
        运行结果 = 删首尾空 (取文本右边2_ (取文本中间_ (运行结果, "IPv4 地址", "子网掩码"), ":"))
        如果真 (取文本长度 (运行结果) < 8 || 取文本长度 (运行结果) > 15)
        {
            运行结果 = ""
        }
        返回 (运行结果)
    }

    方法 取内网IP2_ <公开 静态 类型 = 文本数组类 注释 = "多网卡" 折叠 @禁止流程检查 = 真>
    {
        变量 运行结果 <类型 = 文本型>
        变量 数据包 <类型 = 文本数组类>
        变量 结果组 <类型 = 文本数组类>
        变量 结果组2 <类型 = 文本数组类>
        变量 结果组3 <类型 = 文本数组类>
        变量 结果 <类型 = 整数>
        运行控制台程序 ("ipconfig", 运行结果)
        分割文本 (运行结果, "\r\n", 结果组, 真, 真)
        结果组.枚举循环 ()
        {
            结果 = 寻找文本 (结果组.取枚举值 (), "IPv4 地址", , 真)
            如果真 (结果 != -1)
            {
                分割文本 (结果组.取枚举值 (), ":", 结果组2, 真, 真)
                如果真 (结果组2.取成员数 () == 2)
                {
                    结果组3.加入成员 (结果组2.取成员 (1))
                }
            }
        }
        返回 (结果组3)
    }
}

