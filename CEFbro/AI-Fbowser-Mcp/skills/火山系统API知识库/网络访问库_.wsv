类 URL参数解析类_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.URL解析\"" @全局类 = 真>
{
    方法 URL_取URL参数 <公开 静态 类型 = 整数 返回值注释 = "返回得到的数量，参数二中指定了名称将不会返回数量" 折叠>
    参数 URL <类型 = 文本型 注释 = "带请求参数的URL，如：“http://www.baidu.com/lky?id=123&name=nhy”;" 注释 = "也可直接是参数体内容，如：“id=123&name=nhy”">
    参数 指定参数名 <类型 = 文本型 注释 = "指定了参数名，将从参数三中返回参数值。如果留空则从参数四和五中返回所有数据" @默认值 = "">
    参数 返回的参数值 <类型 = 文本型 注释 = "参数二不留将从本参数中返回参数值" @默认值 = "">
    参数 返回的参数名组 <类型 = 文本数组类 注释 = "参数二留空将从本参数中返回所有数据" @默认值 = 空对象>
    参数 返回的参数值组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 临时网址 <类型 = 文本型>
        变量 最后位置 <类型 = 整数>
        变量 参数文本 <类型 = 文本型>
        变量 参数名 <类型 = 文本型>
        变量 参数值 <类型 = 文本型>
        变量 返回位置1 <类型 = 整数>
        变量 起始位置1 <类型 = 整数>
        变量 返回位置2 <类型 = 整数>
        变量 返回位置3 <类型 = 整数>
        临时网址 = URL
        最后位置 = 寻找文本 (临时网址, "?", , 假)
        如果 (最后位置 == -1)
        {
            最后位置 = 0
            临时网址 = "?" + 临时网址
        }
        否则
        {
            最后位置 = 倒找文本 (临时网址, "/", 最后位置, 假)
        }
        参数文本 = 取文本右边 (临时网址, 取文本长度 (临时网址) - 最后位置)
        子文本替换 (参数文本, "?", "&", , 1, 假)
        判断循环 (真)
        {
            返回位置1 = 寻找文本 (参数文本, "&", 起始位置1, 假)
            如果真 (返回位置1 == -1)
            {
                跳出循环
            }
            返回位置2 = 寻找文本 (参数文本, "=", 返回位置1, 假)
            如果真 (返回位置2 == -1)
            {
                跳出循环
            }
            参数名 = 取文本中间 (参数文本, 返回位置1 + 1, 返回位置2 - 返回位置1 - 1)
            返回的参数名组.加入成员 (参数名)
            返回位置3 = 寻找文本 (参数文本, "&", 返回位置2, 假)
            如果 (返回位置3 == -1)
            {
                参数值 = 取文本右边 (参数文本, 取文本长度 (参数文本) - 返回位置2 - 1)
            }
            否则
            {
                参数值 = 取文本中间 (参数文本, 返回位置2 + 1, 返回位置3 - 返回位置2 - 1)
            }
            如果真 (指定参数名 == 参数名)
            {
                返回的参数值 = 参数值
                返回的参数名组.删除所有成员 ()
                返回的参数值组.删除所有成员 ()
                跳出循环
            }
            返回的参数值组.加入成员 (参数值)
            起始位置1 = 返回位置2
        }
        返回 (返回的参数名组.取成员数 ())
    }

    方法 URL_取URL请求头值 <公开 静态 类型 = 文本型 折叠>
    参数 请求头内容组 <类型 = 文本型>
    参数 头名称 <类型 = 文本型 注释 = "例如：“Referer:”或“Referer”，可不区分大小写和不添加:">
    {
        如果真 (取文本右边 (头名称, 1) != ":")
        {
            头名称 = 头名称 + ":"
        }
        加入文本 (请求头内容组, "\r\n")
        返回 (删首尾空 (取文本中间_ (请求头内容组, 头名称, "\r\n")))
    }
}

# //=====

类 网络文件大小类_ <公开 折叠 @全局类 = 真>
{
    方法 网络_取网络文件大小 <公开 静态 类型 = 文本型 注释 = "winhttp方式" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\nwinhttp.h\r\niostream\r\nstring" @视窗.外部库 = "winhttp.lib">
    参数 URL <类型 = 文本型>
    {
        @     const std::wstring url = @<URL>;
        @     HINTERNET hSession = nullptr, hConnect = nullptr, hRequest = nullptr;
        @     std::wstring fileSize = L"Unknown";
        @     URL_COMPONENTS urlComp;
        @     ZeroMemory(&urlComp, sizeof(urlComp));
        @     urlComp.dwStructSize = sizeof(urlComp);
        @     wchar_t hostName[256] = {0};
        @     wchar_t urlPath[1024] = {0};
        @     urlComp.lpszHostName = hostName;
        @     urlComp.dwHostNameLength = sizeof(hostName)/sizeof(wchar_t);
        @     urlComp.lpszUrlPath = urlPath;
        @     urlComp.dwUrlPathLength = sizeof(urlPath)/sizeof(wchar_t);
        @     if (!WinHttpCrackUrl(url.c_str(), url.length(), 0, &urlComp)) {
        @         return L"解析URL失败";
        @     }
        @     hSession = WinHttpOpen(L"FileSizeChecker/1.0", 
        @                          WINHTTP_ACCESS_TYPE_DEFAULT_PROXY,
        @                          WINHTTP_NO_PROXY_NAME, 
        @                          WINHTTP_NO_PROXY_BYPASS, 0);
        @     if (!hSession) {
        @         return L"创建WinHTTP会话失败";
        @     }
        @     hConnect = WinHttpConnect(hSession, hostName, urlComp.nPort, 0);
        @     if (!hConnect) {
        @         WinHttpCloseHandle(hSession);
        @         return L"连接到主机时失败";
        @     }
        @     hRequest = WinHttpOpenRequest(hConnect, L"HEAD", urlPath, 
        @                                 nullptr, WINHTTP_NO_REFERER, 
        @                                 WINHTTP_DEFAULT_ACCEPT_TYPES, 
        @                                 (urlComp.nScheme == INTERNET_SCHEME_HTTPS) ? WINHTTP_FLAG_SECURE : 0);
        @     if (!hRequest) {
        @         WinHttpCloseHandle(hConnect);
        @         WinHttpCloseHandle(hSession);
        @         return L"创建请求时失败";
        @     }
        @     if (!WinHttpSendRequest(hRequest, 
        @                           WINHTTP_NO_ADDITIONAL_HEADERS, 0,
        @                           WINHTTP_NO_REQUEST_DATA, 0, 
        @                           0, 0)) {
        @         WinHttpCloseHandle(hRequest);
        @         WinHttpCloseHandle(hConnect);
        @         WinHttpCloseHandle(hSession);
        @         return L"发送请求时失败";
        @     }
        @     if (!WinHttpReceiveResponse(hRequest, nullptr)) {
        @         WinHttpCloseHandle(hRequest);
        @         WinHttpCloseHandle(hConnect);
        @         WinHttpCloseHandle(hSession);
        @         return L"接收响应时出错";
        @     }
        @     wchar_t contentLength[64] = {0};
        @     DWORD contentLengthSize = sizeof(contentLength);
        @     if (WinHttpQueryHeaders(hRequest, 
        @                            WINHTTP_QUERY_CONTENT_LENGTH,
        @                            WINHTTP_HEADER_NAME_BY_INDEX,
        @                            &contentLength, 
        @                            &contentLengthSize,
        @                            WINHTTP_NO_HEADER_INDEX)) {
        @         fileSize = contentLength;
        @ return @an<CVolString> (fileSize.c_str());
        @     } else {
        @     WinHttpCloseHandle(hRequest);
        @     WinHttpCloseHandle(hConnect);
        @     WinHttpCloseHandle(hSession);
        @     return L"Content-Length标头不可用";
        @     }
        @     WinHttpCloseHandle(hRequest);
        @     WinHttpCloseHandle(hConnect);
        @     WinHttpCloseHandle(hSession);
        @ return "";
    }

    方法 网络_取网络文件大小2 <公开 静态 类型 = 文本型 注释 = "winInet方式" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\nwininet.h\r\niostream\r\nstring" @视窗.外部库 = "wininet.lib">
    参数 URL <类型 = 文本型>
    {
        @     const std::wstring url = @<URL>;
        @     HINTERNET hInternet = nullptr, hConnect = nullptr, hRequest = nullptr;
        @     std::wstring fileSize = L"Unknown";
        @     URL_COMPONENTS urlComp;
        @     ZeroMemory(&urlComp, sizeof(urlComp));
        @     urlComp.dwStructSize = sizeof(urlComp);
        @     wchar_t hostName[256] = {0};
        @     wchar_t urlPath[1024] = {0};
        @     urlComp.lpszHostName = hostName;
        @     urlComp.dwHostNameLength = sizeof(hostName)/sizeof(wchar_t);
        @     urlComp.lpszUrlPath = urlPath;
        @     urlComp.dwUrlPathLength = sizeof(urlPath)/sizeof(wchar_t);
        @     if (!InternetCrackUrlW(url.c_str(), url.length(), 0, &urlComp)) {
        @         return L"解析URL失败";
        @     }
        @     hInternet = InternetOpenW(L"FileSizeChecker/1.0", 
        @                             INTERNET_OPEN_TYPE_PRECONFIG,
        @                             NULL, 
        @                             NULL, 
        @                             0);
        @     if (!hInternet) {
        @         return L"创建WinINet会话失败";
        @     }
        @     hConnect = InternetConnectW(hInternet, 
        @                               hostName, 
        @                               urlComp.nPort,
        @                               NULL, 
        @                               NULL, 
        @                               INTERNET_SERVICE_HTTP,
        @                               0, 
        @                               0);
        @     if (!hConnect) {
        @         InternetCloseHandle(hInternet);
        @         return L"连接到主机失败";
        @     }
        @     hRequest = HttpOpenRequestW(hConnect, 
        @                               L"HEAD", 
        @                               urlPath,
        @                               NULL, 
        @                               NULL, 
        @                               NULL,
        @                               (urlComp.nScheme == INTERNET_SCHEME_HTTPS) ? INTERNET_FLAG_SECURE : 0, 
        @                               0);
        @     if (!hRequest) {
        @         InternetCloseHandle(hConnect);
        @         InternetCloseHandle(hInternet);
        @         return L"创建请求失败";
        @     }
        @     if (!HttpSendRequestW(hRequest, NULL, 0, NULL, 0)) {
        @         InternetCloseHandle(hRequest);
        @         InternetCloseHandle(hConnect);
        @         InternetCloseHandle(hInternet);
        @         return L"发送请求失败";
        @     }
        @     wchar_t contentLength[64] = {0};
        @     DWORD contentLengthSize = sizeof(contentLength);
        @     DWORD index = 0;
        @     if (HttpQueryInfoW(hRequest, 
        @                       HTTP_QUERY_CONTENT_LENGTH,
        @                       &contentLength, 
        @                       &contentLengthSize,
        @                       &index)) {
        @         fileSize = contentLength;
        @         return @an<CVolString> (fileSize.c_str());
        @     } else {
        @         DWORD error = GetLastError();
        @         if (error == ERROR_HTTP_HEADER_NOT_FOUND) {
        @             InternetCloseHandle(hRequest);
        @             InternetCloseHandle(hConnect);
        @             InternetCloseHandle(hInternet);
        @             return L"Content-Length标头不可用.";
        @         } else {
        @             InternetCloseHandle(hRequest);
        @             InternetCloseHandle(hConnect);
        @             InternetCloseHandle(hInternet);
        @             return L"查询标头失败";
        @         }
        @     }
        @     InternetCloseHandle(hRequest);
        @     InternetCloseHandle(hConnect);
        @     InternetCloseHandle(hInternet);
        @ return "";
    }
}

