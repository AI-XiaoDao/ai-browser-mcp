<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"网络访问库\"">

类 SSL缓存类_ <公开 折叠 折叠2 @文档 = "category = \"SSL缓存\"" @全局类 = 真>
{
    方法 开启使用SSL及TLS_ <公开 静态 注释 = "开启Internet中所有的SSL及TLS" 折叠>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        注册表写整数_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings", "SecureProtocols", 2728, 是否64位, 4)
    }

    方法 网络_开启使用SSL及TLS <公开 静态 注释 = "开启Internet中所有的SSL及TLS" 折叠>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        开启使用SSL及TLS_ (是否64位)
    }

    方法 开启SSL缓存_ <公开 静态 折叠>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        注册表写整数_ (2, "Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings", "DisableCachingOfSSLPages", 0, 是否64位, 4)
    }

    方法 网络_开启SSL缓存 <公开 静态 折叠>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        开启SSL缓存_ (是否64位)
    }
}

