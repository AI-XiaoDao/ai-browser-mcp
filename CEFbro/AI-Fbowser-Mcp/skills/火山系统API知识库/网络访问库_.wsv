类 网络访问类_COM版 <公开 注释 = "基于WinHttp com版" 折叠 折叠2 @文档 = "category = \"网络访问库.网络访问库.WinHttp\"" @全局类 = 真>
{
    变量 HTTPREQUEST_PROXYSETTING_DEFAULT <类型 = 整数 值 = 0 注释 = "默认代理设置。 等效于 HTTPREQUEST_PROXYSETTING_PRECONFIG。">
    变量 HTTPREQUEST_PROXYSETTING_PRECONFIG <类型 = 整数 值 = 0
            注释 = "指示应从注册表获取代理设置。 这假定 Proxycfg.exe 已运行。 如果未运行Proxycfg.exe并指定 HTTPREQUEST_PROXYSETTING_PRECONFIG ，则行为等效于 HTTPREQUEST_PROXYSETTING_DIRECT。">
    变量 HTTPREQUEST_PROXYSETTING_DIRECT <类型 = 整数 值 = 1 注释 = "指示应直接访问所有 HTTP 和 HTTPS 服务器。 如果没有代理服务器，请使用此命令。">
    变量 HTTPREQUEST_PROXYSETTING_PROXY <类型 = 整数 值 = 2
            注释 = "指定 HTTPREQUEST_PROXYSETTING_PROXY 时， varProxyServer 应设置为代理服务器字符串， varBypassList 应设置为域绕过列表字符串。 此代理配置仅适用于 WinHttpRequest 对象的当前实例。">

    方法 网页访问_B <公开 类型 = 字节集类 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 注释 = "自动UTF8编码" @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 注释 = "提交字节集数据" @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 注释 = "多个请用换行符隔开" @默认值 = "">
    参数 提交Cookies <类型 = 文本型 注释 = "设置提交时的cookie" @默认值 = "">
    参数 返回Cookies <类型 = 文本型 @默认值 = 空对象>
    参数 返回协议头 <类型 = 文本型 @默认值 = 空对象>
    参数 返回状态代码 <类型 = 文本型 @默认值 = 空对象>
    参数 禁止重定向 <类型 = 逻辑型 注释 = "默认不禁止网页重定向" @默认值 = 假>
    参数 代理标识 <类型 = 整数 @默认值 = 0>
    参数 代理地址 <类型 = 文本型 @默认值 = "">
    参数 代理用户名 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位：毫秒；1000毫秒=1秒；默认为15秒" @默认值 = 15000>
    参数 是否补全协议头 <类型 = 逻辑型 注释 = "当附件协议头为空时自动添加必要的UA协议头 默认为真，假将不再添加非传入协议头" @默认值 = 真>
    {
        变量 空字节集 <类型 = 字节集类>
        变量 WinHttp <类型 = COM对象类>
        变量 方式 <类型 = 文本型>
        变量 数据组1 <类型 = 文本数组类>
        变量 数据组2 <类型 = 文本数组类>
        变量 局_变体 <类型 = COM变体型>
        变量 返回数据 <类型 = 字节集类>
        变量 Cook <类型 = 文本型>
        变量 执行结果 <类型 = 逻辑型>
        @ CoInitialize(NULL);
        方式 = 选择 (访问方式 < 0 || 访问方式 > 7, "GET", 多项选择 (访问方式, "GET", "POST", "HEAD", "PUT", "DELETE", "OPTIONS", "TRACE", "CONNECT"))
        如果真 (寻找文本 (请求网址, "http://", , 真) == -1 && 寻找文本 (请求网址, "https://", , 真) == -1)
        {
            请求网址 = "http://" + 请求网址
        }
        如果真 (WinHttp.创建 ("WinHttp.WinHttpRequest.5.1") == 假)
        {
            返回 (空字节集)
        }
        如果真 (代理地址 != "")
        {
            执行结果 = WinHttp.无返回值方法 ("SetProxy", HTTPREQUEST_PROXYSETTING_PROXY, 代理地址)
            如果真 (代理用户名 != "")
            {
                如果真 (代理标识 == 0)
                {
                    代理标识 = 1
                }
                执行结果 = WinHttp.无返回值方法 ("SetCredentials", 代理用户名, 代理密码, 代理标识)
            }
        }
        执行结果 = WinHttp.无返回值方法 ("SetTimeouts", 超时时间, 超时时间, 超时时间, 超时时间)
        如果真 (到小写 (取文本左边 (请求网址, 4)) != "http")
        {
            请求网址 = "http://" + 请求网址
        }
        执行结果 = WinHttp.无返回值方法 ("Open", 方式, 请求网址, 假)
        如果真 (禁止重定向)
        {
            执行结果 = WinHttp.写属性 ("Option", 6, 0)
        }
        执行结果 = WinHttp.写属性 ("Option", 4, 13056)
        如果真 (是否补全协议头 == 真)
        {
            如果真 (寻找文本 (附加协议头, "Accept:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nAccept: */*"
            }
            如果真 (寻找文本 (附加协议头, "Referer:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nReferer:" + 请求网址
            }
            如果真 (寻找文本 (附加协议头, "Accept-Language:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nAccept-Language: zh-cn"
            }
            如果真 (寻找文本 (附加协议头, "User-Agent:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nUser-Agent: Mozilla/4.0 (compatible; MSIE 9.0; Windows NT 6.1)"
            }
            如果真 (访问方式 == 1)
            {
                如果真 (寻找文本 (附加协议头, "Content-Type:", , 真) == -1)
                {
                    附加协议头 = 附加协议头 + "\r\nContent-Type: application/x-www-form-urlencoded"
                }
            }
        }
        如果真 (取反 (提交Cookies == ""))
        {
            如果真 (取文本长度 (提交Cookies) > 0)
            {
                如果真 (寻找文本 (提交Cookies, "Cookie:", , 真) != -1)
                {
                    子文本替换 (提交Cookies, "Cookie:", "", , , 假)
                }
            }
            执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", "Cookie", 提交Cookies)
        }
        如果 (寻找文本 (附加协议头, "\r\n", , 假) == -1)
        {
            执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", 内部_协议头取名 (附加协议头), 内部_协议头取值 (附加协议头))
        }
        否则
        {
            分割文本 (附加协议头, "\r\n", 数据组1)
            计次循环 (数据组1.取成员数 ())
            {
                如果真 (数据组1.取成员 (取循环索引 ()) != "")
                {
                    如果真 (内部_协议头取名 (数据组1.取成员 (取循环索引 ())) == "Connection")
                    {
                        如果真 (内部_协议头取值 (数据组1.取成员 (取循环索引 ())) == "keep - alive")
                        {
                            到循环尾
                        }
                    }
                    执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", 内部_协议头取名 (数据组1.取成员 (取循环索引 ())), 内部_协议头取值 (数据组1.取成员 (取循环索引 ())))
                }
            }
        }

        如果 (提交字节集 == 空对象)
        {
            局_变体.置字节集 (文本到UTF8 (提交信息, 假))
        }
        否则
        {
            局_变体.置字节集 (提交字节集)
        }
        执行结果 = WinHttp.无返回值方法 ("Send", 局_变体)
        局_变体 = WinHttp.读无参数属性 ("ResponseBody", COM变体型)
        执行结果 = 局_变体.取字节集 (返回数据)
        返回协议头 = WinHttp.读无参数属性 ("GetAllResponseHeaders", 文本型)
        返回状态代码 = 到文本 (WinHttp.读无参数属性 ("Status", 整数))
        WinHttp.读无参数属性 ("StatusText", 文本型)
        分割文本 (返回协议头, "\r\n", 数据组2)
        返回Cookies = ""
        计次循环 (数据组2.取成员数 ())
        {
            Cook = 数据组2.取成员 (取循环索引 ())
            如果真 (取文本左边 (Cook, 寻找文本 (Cook, ":")) == "Set-Cookie")
            {
                如果 (寻找文本 (Cook, ";", , 假) != -1)
                {
                    返回Cookies = 返回Cookies + 删首尾空 (取文本中间_ (Cook, "Set-Cookie:", ";")) + "; "
                }
                否则
                {
                    子文本替换 (Cook, "Set-Cookie:", "")
                    返回Cookies = 返回Cookies + 删首尾空 (Cook) + "; "
                }
            }
        }
        如果真 (取文本左边 (返回Cookies, 2) == "; ")
        {
            返回Cookies = 取文本左边 (返回Cookies, 取文本长度 (返回Cookies) - 2)
        }
        返回Cookies = 返回Cookies
        WinHttp.清除 ()
        @ CoUninitialize();
        返回 (返回数据)
    }

    方法 网页访问_T <公开 类型 = 文本型 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 注释 = "自动UTF8编码" @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 注释 = "提交字节集数据" @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 注释 = "多个请用换行符隔开" @默认值 = "">
    参数 提交Cookies <类型 = 文本型 注释 = "设置提交时的cookie" @默认值 = "">
    参数 返回Cookies <类型 = 文本型 @默认值 = 空对象>
    参数 返回协议头 <类型 = 文本型 @默认值 = 空对象>
    参数 返回状态代码 <类型 = 文本型 @默认值 = 空对象>
    参数 禁止重定向 <类型 = 逻辑型 注释 = "默认不禁止网页重定向" @默认值 = 假>
    参数 代理标识 <类型 = 整数 @默认值 = 0>
    参数 代理地址 <类型 = 文本型 @默认值 = "">
    参数 代理用户名 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位：毫秒；1000毫秒=1秒；默认为15秒" @默认值 = 15000>
    参数 是否补全协议头 <类型 = 逻辑型 注释 = "当附件协议头为空时自动添加必要的UA协议头 默认为真，假将不再添加非传入协议头" @默认值 = 真>
    参数 返回内容转码方式 <类型 = 整数 注释 = "1、UTF8到文本　2、多字节到文本　3、多字节到文本 (Utf8到多字节()))" @默认值 = 1>
    {
        变量 临时文本 <类型 = 文本型>
        如果 (返回内容转码方式 == 1)
        {
            加入文本 (临时文本, UTF8到文本_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 返回Cookies, 返回协议头, 返回状态代码, 禁止重定向, 代理标识, 代理地址, 代理用户名, 代理密码, 超时时间, 是否补全协议头), ))
        }
        否则 (返回内容转码方式 == 2)
        {
            加入文本 (临时文本, 多字节到文本_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 返回Cookies, 返回协议头, 返回状态代码, 禁止重定向, 代理标识, 代理地址, 代理用户名, 代理密码, 超时时间, 是否补全协议头)))
        }
        否则 (返回内容转码方式 == 3)
        {
            加入文本 (临时文本, 多字节到文本_ (UTF8到多字节_ (网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookies, 返回Cookies, 返回协议头, 返回状态代码, 禁止重定向, 代理标识, 代理地址, 代理用户名, 代理密码, 超时时间, 是否补全协议头), , )))

        }
        返回 (临时文本)
    }

    方法 网页_处理协议头 <公开 类型 = 文本型 折叠>
    参数 参_原始协议头 <类型 = 文本型>
    {
        变量 局_原始 <类型 = 文本数组类>
        变量 局_原始位置 <类型 = 整数>
        变量 局_中间 <类型 = 文本型>
        变量 局_7 <类型 = 文本型>
        变量 局_分割 <类型 = 文本数组类>
        变量 局_11 <类型 = 文本型>
        变量 局_6 <类型 = 文本型>
        变量 局_原始计次 <类型 = 整数>
        变量 局_分割数 <类型 = 整数>
        变量 局_分割数计次 <类型 = 整数>
        分割文本 (参_原始协议头, "\r\n", 局_原始, 假, 假)
        计次循环 (局_原始.取成员数 ())
        {
            局_原始计次 = 取循环索引 ()
            局_原始位置 = 寻找文本 (局_原始.取成员 (局_原始计次), ":", , 假)
            如果真 (局_原始位置 == -1)
            {
                到循环尾
            }
            局_中间 = 取文本中间 (局_原始.取成员 (局_原始计次), 0, 局_原始位置)  // -1
            如果 (寻找文本 (局_中间, "-", , 假) != -1)
            {
                局_7 = ""
                局_分割数 = 分割文本 (局_中间, "-", 局_分割, 假, 假)
                计次循环 (局_分割数)
                {
                    局_分割数计次 = 取循环索引 ()
                    如果 (局_分割数 == 局_分割数计次 + 1)
                    {
                        局_7 = 局_7 + 首字母改大写 (局_分割.取成员 (取循环索引 ()))
                    }
                    否则
                    {
                        局_7 = 局_7 + 首字母改大写 (局_分割.取成员 (取循环索引 ())) + "-"
                    }
                }
                局_中间 = 局_7
            }
            否则
            {
                局_中间 = 首字母改大写 (局_中间)
            }
            局_11 = 取文本右边 (局_原始.取成员 (局_原始计次), 取文本长度 (局_原始.取成员 (局_原始计次)) - 取文本长度 (局_中间))
            如果真 (取代码_ (取文本左边 (局_11, 1), 0) == 32)
            {
                局_11 = 取文本右边 (局_11, 取文本长度 (局_11) - 1)
            }
            局_6 = 局_6 + 局_中间 + 局_11 + "\r\n"
        }
        局_6 = 取文本左边 (局_6, 取文本长度 (局_6) - 取文本长度 ("\r\n"))  // 2个长度
        返回 (局_6)
    }

