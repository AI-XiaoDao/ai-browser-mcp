    方法 取重定向地址_ <公开 类型 = 文本型 注释 = "获取现有URL重向跳转后的地址" 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 补充协议头 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 url对象 <类型 = COM对象类>
        变量 Location <类型 = COM变体型>
        变量 ret <类型 = 文本型>
        如果真 (url对象.创建 ("WinHttp.WinHttpRequest.5.1"))
        {
            url对象.写属性 ("Option", 6, 0)
            url对象.方法 ("SetTimeouts", COM对象类, 5000, 5000, 10000, 5000)
            url对象.方法 ("Open", COM对象类, "HEAD", 请求网址, 假)
            如果真 (补充协议头)
            {
                url对象.方法 ("setRequestHeader", COM对象类, "User-Agent", "Mozilla/4.0 (compatible; MSIE 6.0; Windows NT 5.1; SV1)")
                url对象.方法 ("setRequestHeader", COM对象类, "Accept-Language", "zh-cn")
                url对象.方法 ("setRequestHeader", COM对象类, "Connection", "Keep-Alive")
                url对象.方法 ("setRequestHeader", COM对象类, "Accept", "image/gif, image/x-xbitmap, image/jpeg, imagepeg, application/x-shockwave-flash, application/x-silverlight, */*")
            }
            url对象.无参数方法 ("Send", COM对象类)
            Location = url对象.读属性 ("GetResponseHeader", COM变体型, "Location")
            ret = Location.取值 (文本型)
            url对象.清除 ()
            返回 (ret)
        }
        返回 ("")
    }
}

类 网络访问类_WinInet版 <公开 注释 = "基于WinInet版" 折叠 @文档 = "category = \"网络访问库.网络访问库.WinInet\"">
{
    方法 网页访问_B <公开 类型 = 字节集类 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 注释 = "提交字节集数据" @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 @默认值 = "">
    参数 提交Cookies <类型 = 文本型 @默认值 = "">
    参数 禁止重定向 <类型 = 逻辑型 @默认值 = 假>
    参数 代理地址 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 是否补全协议头 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 Internet连接句柄 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 Internet句柄 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 HTTP请求句柄 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 User_Agent <类型 = 文本型
                值 = "Mozilla/5.0 (Windows NT 10.0; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/50.0.2661.102 Safari/537.36"
                编辑时信息 = "0, BCCC1, 0, 0">
        变量 HTTPS <类型 = 逻辑型 编辑时信息 = "0, BCCC1, 0, 0">
        变量 数据缓存 <类型 = 字节集类 编辑时信息 = "0, BCCC1, 0, 0">
        变量 访问数据 <类型 = 字节集类 编辑时信息 = "0, BCCC1, 0, 0">
        变量 整数地址 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 请求标记 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 域名 <类型 = 文本型 编辑时信息 = "0, BCCC1, 0, 0">
        变量 端口 <类型 = 整数 编辑时信息 = "0, BCCC1, 0, 0">
        变量 地址 <类型 = 文本型 编辑时信息 = "0, BCCC1, 0, 0">
        变量 协议头数据 <类型 = 字节集类 编辑时信息 = "0, BCCC1, 0, 0">
        变量 提交信息数据 <类型 = 字节集类 编辑时信息 = "0, BCCC1, 0, 0">
        变量 方式 <类型 = 文本型 编辑时信息 = "0, BCCC1, 0, 0">
        变量 空字节 <类型 = 字节集类 编辑时信息 = "0, BCCC1, 0, 0">
        变量 句柄 <类型 = 变整数 编辑时信息 = "0, BCCC1, 0, 0">
        方式 = 选择 (访问方式 < 0 || 访问方式 > 7, "GET", 多项选择 (访问方式, "GET", "POST", "HEAD", "PUT", "DELETE", "OPTIONS", "TRACE", "CONNECT"))
        如果真 (寻找文本 (请求网址, "http://", , 真) == -1 && 寻找文本 (请求网址, "https://", , 真) == -1)
        {
            请求网址 = "http://" + 请求网址
        }
        如果真 (到小写 (取文本左边 (请求网址, 8)) == "https://")
        {
            HTTPS = 真
        }
        如果 (代理地址 == "")
        {
            Internet句柄 = 网络访问api.InternetOpen (User_Agent, 1, "", "", 0)
        }
        否则
        {
            如果 (HTTPS)
            {
                Internet句柄 = 网络访问api.InternetOpen (User_Agent, 3, 代理地址, 代理密码, 0)
            }
            否则
            {
                Internet句柄 = 网络访问api.InternetOpen (User_Agent, 3, "http == " + 代理地址, 代理密码, 0)
            }
        }
        如果真 (Internet句柄 == 0)
        {
            返回 (空字节)
        }
        端口 = 取网址端口_ (请求网址)
        域名 = 取网址域名_ (请求网址)
        Internet连接句柄 = 网络访问api.InternetConnect (Internet句柄, 域名, 端口, "", "", 3, 0, 0)
        如果真 (Internet连接句柄 == 0)
        {
            网络访问api.InternetCloseHandle (Internet句柄)
            返回 (空字节)
        }
        如果 (端口 == 443)
        {
            请求标记 = -2139095024
        }
        否则
        {
            请求标记 = -2147483632
        }
        如果真 (提交Cookies != "")
        {
            请求标记 = 位或 (请求标记, 524288)
        }
        如果真 (禁止重定向 == 真)
        {
