类 网络下载类_ <公开 折叠 @文档 = "category = \"网络访问库.网络文件下载\"">
{
    变量 下载 <类型 = 网络下载处理>
    变量 全局附加标记 <类型 = 整数>
    变量 全局保存路径 <类型 = 文本型>
    变量 全局文件名称 <类型 = 文本型>

    方法 下载网络文件_ <公开 类型 = 变整数 注释 = "如果有些电脑上下载失败，可以尝试执行“开启使用SSL及TLS_”、“开启SSL缓存_”." 注释 = "不支带Cookie的下载" 返回值注释 = "成功返回0" 折叠 折叠2>
    参数 下载地址 <类型 = 文本型 注释 = "例如：https://dldir1.qq.com/qqfile/qq/PCQQ9.7.6/QQ9.7.6.28989.exe">
    参数 详细保存路径 <类型 = 文本型 注释 = "默认保存到桌面，名称为test.rar ；路径+文件名" @默认值 = "">
    参数 附加标记 <类型 = 整数 注释 = "此标记将在下载事件中回显，用于判断文件" @默认值 = 0>
    {
        变量 是否清理缓存 <类型 = 逻辑型 值 = 真>
        变量 临时路径 <类型 = 文本型>
        变量 结果 <类型 = 变整数>
        清理缓存文件_ (下载地址)
        全局附加标记 = 0
        连续赋值 ("", 全局保存路径, 全局文件名称)
        如果真 (是否清理缓存 == 真)
        {
            下载.清理缓存文件 (下载地址)
        }
        临时路径 = 详细保存路径
        如果真 (临时路径 == "")
        {
            详细保存路径 = 取特定目录 (特定目录类型.系统桌面) + "test.rar"
        }
        创建目录 (取文本左边2_ (详细保存路径, "\\"))
        全局附加标记 = 附加标记
        全局保存路径 = 详细保存路径
        全局文件名称 = 取文本右边2_ (详细保存路径, "\\")
        结果 = 下载.下载网络文件 (下载地址, 详细保存路径, 下载)
        如果真 (结果 < 0)
        {
            回调事件 (0, 0, 0, "", "", -1, 全局保存路径, 全局附加标记)
            清理缓存文件_ (下载地址)
        }
        返回 (结果)
    }

    方法 清理缓存文件_ <公开 类型 = 逻辑型 折叠>
    参数 szURL <类型 = 文本型>
    {
        返回 (下载.清理缓存文件 (szURL))
    }

    方法 网络下载处理_下载回调 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 网络下载处理>
    参数 标记值 <类型 = 整数>
    参数 已下大小 <类型 = 长整数>
    参数 文件总大小 <类型 = 长整数>
    参数 状态码 <类型 = 整数>
    参数 文件链接 <类型 = 文本型>
    {
        变量 进度 <类型 = 小数>
        变量 状态 <类型 = 整数>
        进度 = 四舍五入 ((小数)已下大小 / 文件总大小 * 100, 2)
        如果 (已下大小 == 文件总大小 && 状态码 == 6)
        {
            状态 = 2
        }
        否则
        {
            状态 = 1
        }
        回调事件 (已下大小, 文件总大小, 进度, 文件链接, 全局文件名称, 状态, 全局保存路径, 全局附加标记)
        返回 (0)
    }

    方法 回调事件 <公开 定义事件 类型 = 整数 折叠>
    参数 已下大小 <类型 = 长整数>
    参数 文件总大小 <类型 = 长整数>
    参数 当前进度 <类型 = 小数 注释 = "百分比进度">
    参数 文件链接 <类型 = 文本型>
    参数 文件名称 <类型 = 文本型>
    参数 下载状态 <类型 = 整数 注释 = "-1、下载失败　1、下载中　2、下载成功">
    参数 保存路径 <类型 = 文本型>
    参数 附加标记 <类型 = 整数>
}

