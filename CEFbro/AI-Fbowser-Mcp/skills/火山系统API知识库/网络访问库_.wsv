类 网络判断类_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.网络判断\"" @全局类 = 真>
{
    方法 判断网络状态_ <公开 静态 类型 = 逻辑型 返回值注释 = "返回“真”表示有网络，可上网" 折叠 折叠2 @视窗.外部头文件 = "IP\\Internal.h" @视窗.外部源文件 = "IP\\internal.cpp"
            @禁止流程检查 = 真>
    参数 返回信息 <类型 = 文本型 注释 = "1、局域网　2、拨号上网　3、代理上网　4、RAS　5、被非Internal连接占用　6、可以联网但不可用　7、无网" @默认值 = "">
    {
        变量 类型 <类型 = 整数>
        @ Internal_S Inter;
        @ int lx= Inter.Internal_style();
        @ @<类型>=(@dt<整数>)lx;
        如果 (类型 == 1)
        {
            返回信息 = "局域网"
        }
        否则 (类型 == 2)
        {
            返回信息 = "拨号上网"
        }
        否则 (类型 == 3)
        {
            返回信息 = "代理上网"
        }
        否则 (类型 == 4)
        {
            返回信息 = "RAS"
        }
        否则 (类型 == 5)
        {
            返回信息 = "被非Internal连接占用"
        }
        否则 (类型 == 6)
        {
            返回信息 = "可以联网但不可用"
        }
        否则 (类型 == 7)
        {
            返回信息 = "无网"
        }
        返回 (类型 < 5)
    }
}

类 网络判断类2_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.网络判断\"" @全局类 = 真>
{
    方法 判断网络状态2_ <公开 静态 类型 = 逻辑型 注释 = "返回“真”表示有网络，可上网">
    {
        返回 (网络判断api.InternetGetConnectedState ())
    }
}

类 网络判断api <折叠 @文档 = "category = \"网络访问库.网络判断.附加类\"">
{
    方法 InternetGetConnectedState <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "InternetGetConnectedState" @视窗.输入 = "wininet.dll">
    参数 标志 <类型 = 变整数 @默认值 = 0>
    参数 返回值 <类型 = 变整数 @默认值 = 0>
}

