类 HTTP读文件类_ <公开 折叠 折叠2 @文档 = "category = \"网络访问库.HTTP读取\"" @全局类 = 真>
{
    变量 网络 <静态 类型 = 网络访问类_>

    方法 HTTP读文件_B <公开 静态 类型 = 字节集类 折叠>
    参数 请求网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容">
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT　8、PATCH" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 注释 = "本方法会根据提交信息的类型自动添加\"Content-Type\"协议头,无需你手动添加" @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 注释 = "本方法会根据提交信息的类型自动添加\"Content-Type\"协议头,无需你手动添加" @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 注释 = "提供本次请求所欲使用的附加协议头,每个协议之间请用\"\\r\\n\"换行" @默认值 = 空对象>
    参数 提交Cookie <类型 = 文本型 @默认值 = "">
    参数 重定向次数 <类型 = 整数 注释 = "欲遵循网站重定向的最大次数，0为禁止重定向" @默认值 = -1>
    参数 返回的Cookies <类型 = 文本型 @默认值 = "">
    参数 返回的协议头 <类型 = 文本型 @默认值 = "">
    参数 代理地址 <类型 = 文本型 注释 = "设置当前一次网页访问使用的代理地址列表,非空时将代理模式临时改为\"命名代理\";"
            注释 = "无论代理是什么协议,都一律填http/https，例如Socoks5的代理也是填： \"http://127.0.0.1:7890\";"
            注释 = "可以用分号支持多个代理服务器，也可以对不同的协议使用不同的代理，例如：\"http=http://127.0.0.1:7890;https=http://192.168.1.1:8080\"" @默认值 = "">
    参数 代理账号 <类型 = 文本型 注释 = "提供代理服务器所需的用户名(可空)，仅在代理模式为\"命名代理\"时可用" @默认值 = "">
    参数 代理密码 <类型 = 文本型 注释 = "提供代理服务器所需的用户密码(可空)，仅在代理模式为\"命名代理\"时可用" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位：毫秒；1000毫秒=1秒；默认为15秒，-1为不限制" @默认值 = 15000>
    参数 忽略SSL错误 <类型 = 逻辑型 注释 = "是否忽略任何SSL验证相关错误，即不验证证书也不验证服务器(如使用了代理将会被一同忽略)" @默认值 = 真>
    参数 内容编码 <类型 = 文本型 注释 = "指定所欲请求服务器使用的内容编码(压缩)方式，即\"Accept-Encoding\"协议内容;"
            注释 = "本参数只对Windows 8及更高版本的系统有效，旧系统不支持WinHTTP的自动解压缩;" 注释 = "提供空文本时自动设置为\"Accept-Encoding: gzip, deflate\"，提供空对象则禁用压缩;"
            注释 = "WinHTTP自动解压缩后，会将响应头的Content-Length、Content-Encoding删除掉" @默认值 = "">
    参数 返回的结果 <类型 = 网页访问响应类_ @默认值 = 空对象>
    {
        返回 (网络.网页访问_B (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookie, 重定向次数, 返回的Cookies, 返回的协议头, 代理地址, 代理账号, 代理密码, 超时时间, 忽略SSL错误, 内容编码, 返回的结果))
    }

    方法 HTTP读文件_T <公开 静态 类型 = 文本型 折叠>
    参数 请求网址 <类型 = 文本型 注释 = "提供所欲访问的网址内容">
    参数 访问方式 <类型 = 整数 注释 = "0、GET　1、POST　2、HEAD　3、PUT　4、DELETE　5、OPTIONS　6、TRACE　7、CONNECT　8、PATCH" @默认值 = 0>
    参数 提交信息 <类型 = 文本型 注释 = "本方法会根据提交信息的类型自动添加\"Content-Type\"协议头,无需你手动添加" @默认值 = "">
    参数 提交字节集 <类型 = 字节集类 @默认值 = 空对象>
    参数 附加协议头 <类型 = 文本型 注释 = "提供本次请求所欲使用的附加协议头,每个协议之间请用\"\\r\\n\"换行" @默认值 = 空对象>
    参数 提交Cookie <类型 = 文本型 @默认值 = "">
    参数 重定向次数 <类型 = 整数 注释 = "欲遵循网站重定向的最大次数，0为禁止重定向" @默认值 = -1>
    参数 返回的Cookies <类型 = 文本型 @默认值 = "">
    参数 返回的协议头 <类型 = 文本型 @默认值 = "">
    参数 代理地址 <类型 = 文本型 注释 = "设置当前一次网页访问使用的代理地址列表,非空时将代理模式临时改为\"命名代理\";"
            注释 = "无论代理是什么协议,都一律填http/https,例如Socoks5的代理也是填: \"http://127.0.0.1:7890\";" 注释 = "可以用分号支持多个代理服务器,也可以对不同的协议使用不同的代理,例如:"
            注释 = "\"http=http://127.0.0.1:7890;https=http://192.168.1.1:8080\"" @默认值 = "">
    参数 代理账号 <类型 = 文本型 注释 = "提供代理服务器所需的用户名(可空)，仅在代理模式为\"命名代理\"时可用" @默认值 = "">
    参数 代理密码 <类型 = 文本型 注释 = "提供代理服务器所需的用户密码(可空)，仅在代理模式为\"命名代理\"时可用" @默认值 = "">
    参数 超时时间 <类型 = 整数 注释 = "单位：毫秒；1000毫秒=1秒；默认为15秒，-1为不限制" @默认值 = 15000>
    参数 忽略SSL错误 <类型 = 逻辑型 注释 = "是否忽略任何SSL验证相关错误，即不验证证书也不验证服务器(如使用了代理将会被一同忽略)" @默认值 = 真>
    参数 内容编码 <类型 = 文本型 注释 = "指定所欲请求服务器使用的内容编码(压缩)方式,即\"Accept-Encoding\"协议内容;"
            注释 = "本参数只对Windows 8及更高版本的系统有效，旧系统不支持WinHTTP的自动解压缩;" 注释 = "提供空文本时自动设置为\"Accept-Encoding: gzip, deflate\"，提供空对象则禁用压缩;"
            注释 = "WinHTTP自动解压缩后，会将响应头的Content-Length、Content-Encoding删除掉" @默认值 = "">
    参数 返回的结果 <类型 = 网页访问响应类_ @默认值 = 空对象>
    参数 返回内容转码方式 <类型 = 整数 注释 = "1、UTF8到文本　2、多字节到文本　3、多字节到文本 (Utf8到多字节()))" @默认值 = 1>
    {
        返回 (网络.网页访问_T (请求网址, 访问方式, 提交信息, 提交字节集, 附加协议头, 提交Cookie, 重定向次数, 返回的Cookies, 返回的协议头, 代理地址, 代理账号, 代理密码, 超时时间, 忽略SSL错误, 内容编码, 返回的结果, 返回内容转码方式))
    }
}

