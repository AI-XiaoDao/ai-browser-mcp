    方法 lua_register <公开 静态 注释 = "lua_register" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 lua函数名 <类型 = 文本型 注释 = "自定义接口名称" @输出名 = "Functionname">
    参数 本地函数 <类型 = 变整数 注释 = "方法名地址,32位程序需要把本地函数的调用约定改为__cdecl" @输出名 = "function">
    {
        @        @an<CVolMem> memBuf;
        @        INT_P npResultTextLength;
        @        const CHAR* ps = GetMbsText (Functionname.GetText (), memBuf, &npResultTextLength);
        @        CVolMem set =  @an<CVolMem> (ps, (npResultTextLength + (TRUE ? 1 : LUA_OPADD)) * sizeof (CHAR));
        @        lua_register((lua_State*)L, (const char*)set.GetPtr(),(lua_CFunction) function);
    }

