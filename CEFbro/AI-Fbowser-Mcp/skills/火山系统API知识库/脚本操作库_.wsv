    方法 luaL_loadbufferx <公开 静态 类型 = 整数 注释 = "luaL_loadbufferx" 返回值注释 = "非0失败" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "解释器指针" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "L">
    参数 lua代码 <类型 = 文本型 注释 = "lua代码" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "buff">
    参数 名称 <类型 = 文本型 注释 = "模块名称" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "name">
    参数 模式 <类型 = 文本型 注释 = "执行模式" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "mode">
    参数 长度 <类型 = 整数 注释 = "留空默认是第一个参数转字节集的长度" @输出名 = "sz" @默认值 = -1>
    {
        @      @an<CVolMem> memBuf;
        @      INT_P npResultTextLength;
        @      const CHAR* ps = GetMbsText (buff.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set1 =  @an<CVolMem> (ps, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      const CHAR* ps1 = GetMbsText (name.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set2 =  @an<CVolMem> (ps1, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      const CHAR* ps2 = GetMbsText (mode.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set3 =  @an<CVolMem> (ps2, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      if (sz == -1)
        @          {
        @              return luaL_loadbufferx((lua_State *)L,(const char *)set1.GetPtr (),set1.GetSize (),(const char *)set2.GetPtr (),(const char *)set3.GetPtr ());
        @          }
        @          else
        @          {
        @             return luaL_loadbufferx((lua_State *)L,(const char *)set1.GetPtr (),sz,(const char *)set2.GetPtr (),(const char *)set3.GetPtr ());
        @          }




    }

    方法 脚本_负载缓冲器 <公开 静态 类型 = 整数 注释 = "luaL_loadbufferx" 返回值注释 = "非0失败" 折叠 编辑时信息 = "6D896, 0, 0, 0" @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "解释器指针" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "L">
    参数 lua代码 <类型 = 文本型 注释 = "lua代码" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "buff">
    参数 名称 <类型 = 文本型 注释 = "模块名称" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "name">
    参数 模式 <类型 = 文本型 注释 = "执行模式" 编辑时信息 = "6D896, 0, 0, 0" @输出名 = "mode">
    参数 长度 <类型 = 整数 注释 = "留空默认是第一个参数转字节集的长度" @输出名 = "sz" @默认值 = -1>
    {
        @      @an<CVolMem> memBuf;
        @      INT_P npResultTextLength;
        @      const CHAR* ps = GetMbsText (buff.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set1 =  @an<CVolMem> (ps, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      const CHAR* ps1 = GetMbsText (name.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set2 =  @an<CVolMem> (ps1, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      const CHAR* ps2 = GetMbsText (mode.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set3 =  @an<CVolMem> (ps2, (npResultTextLength + (false ? 1 : 0)) * sizeof (CHAR));
        @      if (sz == -1)
        @          {
        @              return luaL_loadbufferx((lua_State *)L,(const char *)set1.GetPtr (),set1.GetSize (),(const char *)set2.GetPtr (),(const char *)set3.GetPtr ());
        @          }
        @          else
        @          {
        @             return luaL_loadbufferx((lua_State *)L,(const char *)set1.GetPtr (),sz,(const char *)set2.GetPtr (),(const char *)set3.GetPtr ());
        @          }




    }

    方法 脚本_加载代码并执行 <公开 静态 类型 = 逻辑型 折叠>
    参数 参_L <类型 = 变整数>
    参数 参_代码 <类型 = 文本型>
    参数 参_名称 <类型 = 文本型>
    {
        如果 (脚本_负载缓冲器 (参_L, 参_代码, 参_名称, "t") == 0)
        {
            如果 (脚本_执行函数2 (参_L) == 0)
            {
                返回 (真)
            }
            信息框_ (脚本_取栈顶文本 (参_L), , "执行 - " + 参_名称)
            返回 (假)
        }
        否则
        {
            信息框_ (脚本_取栈顶文本 (参_L), , "加载 - " + 参_名称)
            返回 (假)
        }
    }
}

