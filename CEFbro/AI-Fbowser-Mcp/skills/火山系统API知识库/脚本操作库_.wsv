    常量 文件是否存在 <公开 类型 = 文本型
            值 = "function 文件是否存在 (文件路径) \r\n \r\n        local f = io.open(文件路径,\"r\")\r\n               if(f == nil )then\r\n                return false\r\n              end\r\n       f:close()\r\n  return true\r\n\r\nend\r\n">

