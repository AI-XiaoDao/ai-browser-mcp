    参数 返回值个数 <类型 = 整数 注释 = "返回值的数量" 折叠2 @输出名 = "nresults" @默认值 = LUA_OPADD>
    参数 错误处理函数 <类型 = 变整数 注释 = "" 注释 = "0表示无，表示错误处理函数在栈中的索引" 折叠2 @输出名 = "errfunc" @默认值 = LUA_OPADD>
    {
        @   return lua_pcall((lua_State*)L,nargs,nresults,(int)errfunc );



