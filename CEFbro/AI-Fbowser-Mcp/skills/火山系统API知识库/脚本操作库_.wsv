    方法 lua_typename <公开 静态 类型 = 文本型 注释 = "lua_typename"
            返回值注释 = "number：实数，string：字符串，nil 全局变量，boolean：false 和nil为假 ，其它都为真；function 函数，table：数组，userdata：类，thread：线程" 折叠
            @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 栈索引 <类型 = 整数 注释 = "参数必须是脚本_取栈值类型返回值之一" 折叠2 @输出名 = "Indexes" @默认值 = LUA_TNONE>
    {
        // number 实数 ,可以是整数,浮点数,Lua 默认只有一种 number 类型 -- double(双精度)类型(默认类型可以修改 luaconf.h 里的定义)
        // string 字符串,一旦赋值不能被修改,可以通过方法string.gsub()来修改
        // nil 全局变量没被赋值默认为nil,删除变量就赋值为 nil
        // boolean(bool) false 和nil为假 ,其它都为真
        // function 函数
        // table 数组、容器
        // userdata (类,其它语言转换过来就变成userdata类型)
        // thread 线程
        @     CVolMem name;INT_P i = NULL;INT_P lName;
        @     const char* text = lua_typename((lua_State*)L, Indexes);
        @     i = strlen(text);name.Alloc ((i + LUA_OPSUB), TRUE);
        @     lName = (INT_P)name.GetPtr ();strcpy((char*)lName,text);
        @     CVolMem memBuf (name);memBuf.AddDWord (NULL);
        @     return CVolString ((const CHAR*)memBuf.GetPtr ());

    }

