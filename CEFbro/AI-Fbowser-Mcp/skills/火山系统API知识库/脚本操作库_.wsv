    方法 脚本_写日志文件 <公开 静态 类型 = 逻辑型 折叠>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 日志内容 <类型 = 文本型>
    参数 日志文件路径 <类型 = 文本型 折叠2 @输出名 = "path" @默认值 = 空对象>
    {
        如果真 (日志文件路径 == 取运行目录 () || 日志文件路径 == 空对象)
        {
            日志文件路径 = 日志文件路径 + "日志信息.lua"
        }
        脚本_执行文本 (解释器指针, 脚本常量类.写到文件)  // 先执行lua字串
        脚本_加载全局变量 (解释器指针, "写到文件")  // 加载lua函数名,同样lua调用火山方法也是一样的,先注册函数
        脚本_压入栈顶文本 (解释器指针, 日志文件路径)  // 压入第二个参数
        脚本_压入栈顶文本 (解释器指针, 日志内容)  // 压入第一个参数,这个按顺序压入参数,不能写反了,否则栈位置不对
        脚本_执行函数2 (解释器指针, 2, 1, )  // 执行函数
        计次循环 (脚本_取栈顶元素个数 (解释器指针))
        {
            脚本_清空栈 (解释器指针, -(取循环索引 () + 1))
        }
        返回 (脚本_取栈顶逻辑 (解释器指针, -1))  // 取函数返回值
    }

