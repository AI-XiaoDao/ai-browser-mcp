    方法 luaL_loadfile <公开 静态 类型 = 整数 注释 = "luaL_loadfile" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 脚本文件 <类型 = 文本型 注释 = "编码为ANSI" @输出名 = "text">
    {
        @      @an<CVolMem> memBuf;
        @      INT_P npResultTextLength;
        @      const CHAR* ps = GetMbsText (text.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set =  @an<CVolMem> (ps, (npResultTextLength + (true ? 1 : 0)) * sizeof (CHAR));
        @      return luaL_loadfile((lua_State*)L, (const char *)set.GetPtr());


    }

