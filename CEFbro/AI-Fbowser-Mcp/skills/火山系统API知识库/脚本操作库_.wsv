类 LUA脚本 <公开 基础类 = 脚本常量类 注释 = "当前版本：5.4.8" 注释 = "本静态库是2019编译" 折叠 折叠2 @视窗.需求VS版本 = "16-" @全局类 = 真 @禁止创建对象 = 真
        "@视窗.外部库.x64-debug" = "lua\\lua548_static_64debug.lib" "@视窗.外部库.x64-release" = "lua\\lua548_static_64release.lib"
        "@视窗.外部库.win32-debug" = "lua\\lua548_static_32debug.lib" "@视窗.外部库.win32-release" = "lua\\lua548_static_32release.lib"
        @视窗.外部头文件 = "lua\\lua.hpp" @输出名 = "Lua" @视窗.附加编译参数 = "cpp:/EHa">
{

    #
    #
    # LUA脚本开发的优势
    #
    # 1 免编译
    # 告别频繁的编译、发布、漫长的打开程序等待，而且每次打开程序要注册，加载资源。有了脚本，您一个启动按钮就可以搞定。
    #
    # 2 速度快
    # LUA不同于其它脚本，如PYTHON、V8、PHP等。这些都是可独立闯江湖的语言，拥有强大的功能包。但缺点也十分明显。代码包十分臃肿、速度慢。兼容性差。产品定位比较单一。
    # 而LUA天生用来于其它语言交互，LUA可以通过栈堆与C语言高效互访。这是一出生就带来的天赋技能。LUA的支持库非常小巧。WIN32下。只需要一个100多KB的DLL就可以搞定。因此LUA安装非常方便、的速度非常快。可以媲美VC、DELPHI,你甚至感觉不到它是脚本。这是其它脚本语言无法做到的。
    #
    # 3 功能强大
    # 不要以为LUA是脚本语言，就认为LUA功能很差。LUA并不是一门主打语言，而是寄生于强大语言的脚本语言。产品定位和功能取决于宿主语言。（宿主语言可以是 VC、DELPHI、VB、PB、易语言、火山视窗）因此，我们可以通过宿主语言为LUA定制功能。用什么就加什么，比如多线程和读COM组件的功能。这种灵活的定制也是LUA高效的原因。
    #
    # 4 简单易学
    # 此库封装的是标准的LUA5.4.6语法。支持全中文，不用花大量时间学习陌生的语言。即使没学过LUA也不要紧。LUA是一门及其容易上手的语言。再也不用花大量时间去研究VC、DELPHI、VB。需要什么LUA没有的功能。只要引擎封装成LUA语法就可以搞定。LUA已成为游戏界的新宠。众所周知，天龙八部、剑网3、魔兽世界、愤怒的小鸟很早就采用了LUA。著名的游戏框架，COCOS2D也已经支持LUA。
    #

    方法 脚本函数 <静态 类型 = 整数 注释 = "提供脚本函数的模板方法，32位必须设置前缀文本，64位可以忽略此操作" 编辑时信息 = "7EAA2, 0, 0, 0" @视窗.前缀文本 = "@__cdecl">
    参数 必须参数 <类型 = 变整数 注释 = "必须参数就是解释器指针，多指针调用传递该参数即可" 编辑时信息 = "7EAA2, 0, 0, 0">
    {
        返回 (0)
    }

    方法 脚本函数2 <静态 类型 = 整数 注释 = "提供脚本函数的模板方法，此方法32位不需要设置前缀文本，由于不带参数，多指针调用会比较呆板">
    {
        返回 (0)
    }

    方法 lua_setfield <公开 静态 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 @输出名 = "L">
    参数 索引 <类型 = 整数 @输出名 = "Indexes">
    参数 名称 <类型 = 文本型 @输出名 = "name">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const CHAR* ps = GetMbsText (name.GetText (), memBuf, &npResultTextLength);
        @ CVolMem set = @an<CVolMem> (ps, (npResultTextLength + (true ? 1 : 0)) * sizeof (CHAR));
        @ lua_setfield((lua_State*)L, Indexes, (const char*)set.GetPtr());
    }

    方法 脚本_设置表字段 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 @输出名 = "L">
    参数 索引 <类型 = 整数 @输出名 = "Indexes">
    参数 名称 <类型 = 文本型 @输出名 = "name">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const CHAR* ps = GetMbsText (name.GetText (), memBuf, &npResultTextLength);
        @ CVolMem set = @an<CVolMem> (ps, (npResultTextLength + (true ? 1 : 0)) * sizeof (CHAR));
        @ lua_setfield((lua_State*)L, Indexes, (const char*)set.GetPtr());
    }

    方法 lua_rawseti <公开 静态 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 @输出名 = "L">
    参数 索引 <类型 = 整数 @输出名 = "index">
    参数 成员索引 <类型 = 整数 @输出名 = "key">
    {
        @ lua_rawseti((lua_State*)L, index,key);
    }

    方法 脚本_压入栈顶字节集 <公开 静态 类型 = 变整数 注释 = "lua_pushstring" 返回值注释 = "返回指针" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 欲压入的字节集 <类型 = 字节集类 注释 = "提供所欲压入的UTF8编码数据，0结束" @输出名 = "value">
    {
        @     return (INT_P)lua_pushstring( (lua_State*)L,(const char *)value.GetPtr ());

    }

    方法 脚本_取栈顶字节集 <公开 静态 类型 = 字节集类 注释 = "lua_tostring" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 栈位置 <类型 = 整数 折叠2 @默认值 = LUA_TNONE @输出名 = "position">
    参数 数据尺寸 <类型 = 整数 注释 = "提供所欲加入数据的尺寸(单位字节),默认0结束" 折叠2 @默认值 = 0 @输出名 = "Datasize">
    {
        变量 ret <类型 = 字节集类 值 = 空对象>
        @     const char* address = lua_tostring((lua_State*)L,(LUA_INTEGER)position);
        @     if (Datasize == NULL)
        @     {
        @           CVolMem ByTe;
        @           int i = NULL;
        @           do
        @           {
        @               i++;
        @               ByTe = CVolMem ((void*)address, i);
        @           }
        @           while (ByTe.GetBinRight (1) != CVolMem ().AddManyBytes (NUM_CHARS_OF_TEXT ("n"), NULL));
        @          try{
        @           return CVolMem ((void*)address, i);
        @          }
        @          catch (...)
        @           {
        @           return ret;
        @           }
        @     }
        @     else
        @     {
        @          try{
        @          return CVolMem ((void*)address, Datasize);
        @          }
        @          catch (...)
        @           {
        @             return ret;
        @           }
        @     }


    }

