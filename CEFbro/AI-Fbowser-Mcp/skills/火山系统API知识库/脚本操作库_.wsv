<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"脚本操作库\"">

类 JS脚本类_ <公开 注释 = "微软ChakraCore" 折叠 折叠2 @文档 = "category = \"脚本操作库.JS脚本\"" @视窗.头文件搜寻目录 = "JavaScript\\include"
        @视窗.库文件搜寻目录 = "JavaScript\\$(p)" @视窗.外部头文件 = "ChakraCore.h" @视窗.外部库 = "ChakraCore.lib"
        @视窗.附属文件 = "JavaScript\\$(p)\\ChakraCore.dll" @输出名 = "JavaScript">
{

    # @begin
    #      JsRuntimeHandle runtime;
    #      JsContextRef context;
    #      unsigned currentSourceContext = 0;
    # @end

    方法 Eval_ <公开 类型 = 变整数 注释 = "运行JS代码" 折叠 @禁止流程检查 = 真>
    参数 表达式 <类型 = 文本型>
    参数 URL <类型 = 文本型>
    {
        @ JsValueRef result;
        @ JsRunScript(@<表达式>,currentSourceContext++,@<URL>,&result);
        @ bool bIsExcep;
        @ JsHasException(&bIsExcep);
        @ if (bIsExcep) return 0;
        @ if(!result) return 0;
        @ return (INT_P)result;
    }

    方法 AddCode_ <公开 类型 = 逻辑型 注释 = "执行指定的代码文本" 返回值注释 = "返回真为执行正常，返回假为出错," 返回值注释 = "错误信息 用 取错误() 取出" 折叠 @禁止流程检查 = 真>
    参数 脚本代码 <类型 = 文本型>
    参数 URL <类型 = 文本型>
    {
        @ JsValueRef result;
        // @ JsValueRef resultError;
        @ JsRunScript(@<脚本代码>,currentSourceContext++,@<URL>,&result);
        @ bool bIsExcep;
        @ JsHasException(&bIsExcep);
        @ return !bIsExcep;
    }

    方法 初始化_ <公开 折叠>
    {
        @     JsCreateRuntime(JsRuntimeAttributeNone, nullptr, &runtime);
        @     JsEnableRuntimeExecution(runtime);
        @     JsCreateContext(runtime, &context);
        @     // Now set the current execution context.
        @     JsSetCurrentContext(context);
    }

    方法 运行函数_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 表达式 <类型 = 文本型>
    参数 URL <类型 = 文本型>
    {
        @ JsValueRef result;
        @ JsRunScript(@<表达式>.GetText(),currentSourceContext++,@<URL>,&result);
        @ bool bIsExcep;
        @ JsHasException(&bIsExcep);
        @ if (bIsExcep) return L"";
        @ if(!result) return L"";
        @ JsValueRef resultJSString;
        @ JsConvertValueToString(result, &resultJSString);
        @ const wchar_t *resultWC;
        @ size_t stringLength;
        @ JsStringToPointer(resultJSString, &resultWC, &stringLength);
        @ return resultWC;
    }

    方法 取文本_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 返回的结果指针 <类型 = 变整数 注释 = "返回的结果，取变量地址 ()">
    {
        如果真 (返回的结果指针 <= 0)
        {
            返回 ("")
        }
        @ JsValueRef resultJSString;
        @ JsConvertValueToString((JsValueRef)@<返回的结果指针>, &resultJSString);
        @ const wchar_t *resultWC;
        @ size_t stringLength;
        @ JsStringToPointer(resultJSString, &resultWC, &stringLength);
        @ return resultWC;
    }

    方法 取类型_ <公开 类型 = 整数 返回值注释 = "0.Undefined 1.Null 2.Number 3.String 4.Boolen 5.Objec 6.Function"
            返回值注释 = "7.Error 8.Array 9.Symbol 10.ArrayBuffer 11.TypedArray 12.JsDataView" 折叠 @禁止流程检查 = 真>
    参数 返回的结果指针 <类型 = 变整数 注释 = "返回的结果，取变量地址 ()">
    {
        如果真 (返回的结果指针 <= 0)
        {
            返回 (0)
        }
        @ JsValueType resultJSString;
        @ JsGetValueType((JsValueRef)@<返回的结果指针>, &resultJSString);
        @ return (int)resultJSString;
    }

    方法 取整数_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 返回的结果指针 <类型 = 变整数 注释 = "返回的结果，取变量地址 ()">
    {
        如果真 (返回的结果指针 <= 0)
        {
            返回 (0)
        }
        @ JsValueRef resultJSString;
        @ JsConvertValueToNumber((JsValueRef)@<返回的结果指针>, &resultJSString);
        @ int bRes;
        @ JsNumberToInt(resultJSString,&bRes);
        @ return bRes;
    }

    方法 取数值_ <公开 类型 = 小数 折叠 @禁止流程检查 = 真>
    参数 返回的结果指针 <类型 = 变整数 注释 = "返回的结果，取变量地址 ()">
    {
        如果真 (返回的结果指针 <= 0)
        {
            返回 (-1)
        }
        @ JsValueRef resultJSString;
        @ JsConvertValueToNumber((JsValueRef)@<返回的结果指针>, &resultJSString);
        @ double bRes;
        @ JsNumberToDouble(resultJSString,&bRes);
        @ return bRes;
    }

    方法 取逻辑_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 返回的结果指针 <类型 = 变整数 注释 = "返回的结果，取变量地址 ()">
    {
        如果真 (返回的结果指针 < 1)
        {
            返回 (假)
        }
        @ JsValueRef resultJSString;
        @ JsConvertValueToBoolean((JsValueRef)@<返回的结果指针>, &resultJSString);
        @ bool bRes;
        @ JsBooleanToBool(resultJSString,&bRes);
        @ return bRes;
    }

    方法 取错误_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @ JsValueRef resultError;
        @ JsGetAndClearExceptionWithMetadata(&resultError);
        @ if(!resultError) return L"";
        @ const char *content ="exception";
        @ JsValueRef pStr;
        @ JsCreateString(content,strlen(content),&pStr);
        @ if(!pStr) return L"创建错误字符失败";
        @ JsValueRef pRes;
        @ JsObjectGetProperty(resultError,pStr,&pRes);
        @ if(!pRes) return L"读取错误指针失败";
        @ JsValueRef resultJSString;
        @ JsConvertValueToString(pRes, &resultJSString);
        @ if(!resultJSString) return L"读取错误文本失败";
        @ const wchar_t *resultWC;
        @ size_t stringLength;
        @ JsStringToPointer(resultJSString, &resultWC, &stringLength);
        @ return resultWC;
    }

    方法 清除_ <公开 折叠 @禁止流程检查 = 真>
    {
        @   JsRelease(context,0);
        @   JsSetCurrentContext(JS_INVALID_REFERENCE);
        @   JsDisposeRuntime(runtime);
        @   runtime = NULL ;
        @   context = NULL ;
        @   currentSourceContext = 0;
    }
}

# //==========

类 JS脚本类2_ <公开 折叠 折叠2 @文档 = "category = \"脚本操作库.JS脚本\"" @视窗.需求目标平台 = @"32位平台">
{
    变量 脚本对象 <类型 = COM对象类>

    方法 类_初始化 <折叠>
    {
        COM初始化类.初始化COM ()
        脚本对象.创建 ("ScriptControl", )
        脚本对象.写属性 ("Language", "JScript")
    }

    方法 类_清理 <折叠>
    {
        脚本对象.清除 ()
        COM初始化类.清理COM ()
    }

    方法 执行 <公开 类型 = 逻辑型 注释 = "执行指定的代码文本" 返回值注释 = "返回真为执行正常，返回假为出错，错误信息可以从“取错误”命令中取得" 折叠>
    参数 脚本代码 <类型 = 文本型>
    {
        变量 脚本代码_变体型 <类型 = COM变体型>
        脚本对象.方法 ("ExecuteStatement", COM对象类, 脚本代码)
        返回 (脚本对象.取错误 () == COM方法调用结果.成功)
    }

    方法 计算表达式 <公开 类型 = 文本型 注释 = "计算表达式并返回结果" 折叠>
    参数 表达式 <类型 = 文本型>
    {
        返回 (脚本对象.方法 ("Eval", 文本型, 表达式))
    }

    方法 清除 <公开 折叠>
    {
        脚本对象.无参数方法 ("Reset", COM对象类)
    }

    方法 取错误 <公开 类型 = COM方法调用结果 注释 = "返回错误信息" 折叠>
    {
        返回 (脚本对象.取错误 ())
    }

    方法 取脚本对象 <公开 类型 = COM对象类 折叠>
    {
        返回 (脚本对象)
    }

    方法 运行 <公开 类型 = 文本型 注释 = "在添加的代码中运行指定的过程，如有返回值返回相应文本，否则返回空文本。" 返回值注释 = "在添加的代码中运行指定的过程，如有返回值返回相应文本，否则返回空文本" 折叠>
    参数 过程或函数名 <类型 = 文本型>
    参数 参数1 <类型 = 文本型 @默认值 = "">
    参数 参数2 <类型 = 文本型 @默认值 = "">
    参数 参数3 <类型 = 文本型 @默认值 = "">
    参数 参数4 <类型 = 文本型 @默认值 = "">
    参数 参数5 <类型 = 文本型 @默认值 = "">
    参数 参数6 <类型 = 文本型 @默认值 = "">
    {
        如果 (文本_是否为空文本 (参数1) == 假 && 文本_是否为空文本 (参数2) == 假 && 文本_是否为空文本 (参数3) == 假 && 文本_是否为空文本 (参数4) == 假 && 文本_是否为空文本 (参数5) == 假 && 文本_是否为空文本 (参数6) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6))
        }
        否则 (文本_是否为空文本 (参数1) == 假 && 文本_是否为空文本 (参数2) == 假 && 文本_是否为空文本 (参数3) == 假 && 文本_是否为空文本 (参数4) == 假 && 文本_是否为空文本 (参数5) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1, 参数2, 参数3, 参数4, 参数5))
        }
        否则 (文本_是否为空文本 (参数1) == 假 && 文本_是否为空文本 (参数2) == 假 && 文本_是否为空文本 (参数3) == 假 && 文本_是否为空文本 (参数4) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1, 参数2, 参数3, 参数4))
        }
        否则 (文本_是否为空文本 (参数1) == 假 && 文本_是否为空文本 (参数2) == 假 && 文本_是否为空文本 (参数3) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1, 参数2, 参数3))
        }
        否则 (文本_是否为空文本 (参数1) == 假 && 文本_是否为空文本 (参数2) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1, 参数2))
        }
        否则 (文本_是否为空文本 (参数1) == 假)
        {
            返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名, 参数1))
        }
        返回 (脚本对象.方法 ("Run", 文本型, 过程或函数名))
    }

    方法 属性_语言 <公开 类型 = 文本型 注释 = "设置或返回正在使用的脚本语言名称" 折叠>
    参数 新语言属性 <类型 = 整数 注释 = "默认为为 JScript   0. JScript   1. VBScript" @默认值 = 0>
    {
        如果 (新语言属性 == 0)
        {
            脚本对象.写属性 ("Language", "JScript")
        }
        否则 (新语言属性 == 1)
        {
            脚本对象.写属性 ("Language", "vbs")
        }
        返回 (脚本对象.读无参数属性 ("Language", 文本型))
    }

    方法 属性_超时 <公开 类型 = 整数 注释 = "设置或返回时间（毫秒），此时间后用户可选择中止脚本代码的执行或允许代码继续执行。" 折叠>
    参数 新超时属性值 <类型 = 整数 注释 = "默认为-1，执行无超时" @默认值 = -1>
    {
        脚本对象.写属性 ("Timeout", 新超时属性值)
        返回 (脚本对象.读无参数属性 ("Timeout", 整数))
    }

    方法 属性_状态 <公开 类型 = 整数 折叠>
    参数 新状态值 <类型 = 整数 注释 = "参数值为以下值之一： 0、Initialized； 1、Connected" @默认值 = 0>
    {
        如果 (新状态值 != 0)
        {
            脚本对象.写属性 ("State", 新状态值)
        }
        返回 (脚本对象.读无参数属性 ("State", 整数))
    }

    方法 属性_是否使用图形界面 <公开 类型 = 逻辑型 折叠>
    参数 新是否使用图形界面属性 <类型 = 逻辑型 @默认值 = 假>
    {
        如果真 (新是否使用图形界面属性 == 假)
        {
            脚本对象.写属性 ("AllowUI", 新是否使用图形界面属性)
        }
        返回 (脚本对象.读无参数属性 ("AllowUI", 逻辑型))
    }

    方法 属性_图形界面父窗口句柄 <公开 类型 = 变整数 折叠>
    参数 新父窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        如果真 (新父窗口句柄 != 0)
        {
            脚本对象.写属性 ("SitehWnd", 新父窗口句柄)
        }
        返回 (脚本对象.读无参数属性 ("SitehWnd", 变整数))
    }

    方法 添加代码 <公开 折叠>
    参数 代码文本 <类型 = 文本型>
    {
        脚本对象.方法 ("AddCode", COM对象类, 代码文本)
    }
}

