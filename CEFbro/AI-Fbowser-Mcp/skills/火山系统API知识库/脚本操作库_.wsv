    方法 luaL_取错误信息 <公开 静态 类型 = 整数 注释 = "luaL_loadstring"
            返回值注释 = "0：没有错误，1：运行错误，2：文件错误，3：预编译时句法错误，4：内存分配错误，5：LUA_ERRERR，其他：未知返回类型。" 折叠 @禁止流程检查 = 真>
    参数 解释器指针 <类型 = 变整数 注释 = "lua解释器指针" @输出名 = "L">
    参数 lua代码 <类型 = 文本型 注释 = "lua文本代码" @输出名 = "code">
    {
        @      @an<CVolMem> memBuf;
        @      INT_P npResultTextLength;
        @      const CHAR* ps = GetMbsText (code.GetText (), memBuf, &npResultTextLength);
        @      CVolMem set =  @an<CVolMem> (ps, (npResultTextLength + (true ? 1 : 0)) * sizeof (CHAR));
        @      return luaL_loadstring((lua_State*)L, (const char*)set.GetPtr());
    }

