    方法 添加菜单列表_ <公开 类型 = 逻辑型 注释 = "子项留空即可只添加父项。添加前请先执行“初始化卷帘_”" 折叠>
    参数 父项名称 <类型 = 文本型>
    参数 父项标记 <类型 = 文本型 @默认值 = "">
    参数 子项名称组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 子项标记组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 父项左侧图标 <类型 = 位图资源 注释 = "每次可不同，默认为内置图" @默认值 = 空资源.空位图>
    参数 父项正常右侧图标 <类型 = 位图资源 注释 = "展开前，第一次添加时设置即可，全局通用，默认为内置图" @默认值 = 空资源.空位图>
    参数 父项热点右侧图标 <类型 = 位图资源 注释 = "展开后，第一次添加时设置即可，全局通用，默认为内置图" @默认值 = 空资源.空位图>
    参数 是否显示过程 <类型 = 逻辑型 注释 = "假是隐藏创建过程，在结束后执行“结束添加列表_”命令即可显示" @默认值 = 真>
    {
        变量 父项左侧图标2 <类型 = 位图资源>
        变量 父项正常右侧图标2 <类型 = 位图资源>
        变量 父索引 <类型 = 整数>
        变量 临时索引 <类型 = 整数>
        变量 临时索引2 <类型 = 整数>
        变量 已有高度 <类型 = 整数>
        变量 临时高 <类型 = 整数>
        如果真 (全局量.是否整体锁定)
        {
            返回 (假)
        }
        如果真 (是否已初始化 == 假)
        {
            调试输出 ("有先执行[初始化卷帘_]命令")
            返回 (假)
        }
        组件布局器_列表区2.可视 = 是否显示过程
        处理事件_ ()
        如果 (父项左侧图标 == 空资源.空位图)
        {
            父项左侧图标2 = 全局量.父项左侧图标
        }
        否则
        {
            父项左侧图标2 = 父项左侧图标
        }
        如果 (父项正常右侧图标 == 空资源.空位图)
        {
            父项正常右侧图标2 = 全局量.父项正常右侧图标
        }
        否则
        {
            父项正常右侧图标2 = 父项正常右侧图标
        }
        如果真 (父项热点右侧图标 != 空资源.空位图)
        {
            全局量.父项热点右侧图标 = 父项热点右侧图标
        }
        判断循环 (子项名称组.取成员数 () != 子项标记组.取成员数 ())
        {
            子项标记组.加入成员 ("")
        }
        卷帘布局组.枚举循环 ()
        {
            临时高 = ((父卷帘模板类)卷帘布局组.取枚举值 ()).高度
            如果真 (临时高 > 全局量.父项高度)
            {
                已有高度 = 临时高 - 全局量.父项高度
            }
        }
        临时索引 = 卷帘布局组.加入新成员 (父卷帘模板类, )
        父索引 = 临时索引
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).可视 = 假
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).创建容器组件 (组件布局器_列表区2, 500, 0)
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).移动 (0, 临时索引 * 全局量.父项高度 + 已有高度, 本对象.宽度, 全局量.父项高度)
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).排序布局 (全局量.父项高度, 全局量.父标题左侧间隔, 全局量.图标隐藏方式, 全局量.父项左图标左侧间隔, 全局量.父项右图标右侧间隔, 全局量.父项提醒图标右侧间隔, 临时索引, 父项标记)
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.标题 = 父项名称
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.文本颜色 = 全局量.父标题颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.字体 = 全局量.父项字体名称 + "," + 到文本 (全局量.父项字体大小)
        如果 (全局量.父项标题对齐方式 == 0)
        {
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.左边
        }
        否则 (全局量.父项标题对齐方式 == 1)
        {
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.居中
        }
        否则 (全局量.父项标题对齐方式 == 2)
        {
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.右边
        }
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.调整层次 (组件层次.顶层)
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).底色 = 全局量.子项正常背景颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_左图.底图 = 父项左侧图标2
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图.底图 = 父项正常右侧图标2
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图2.底图 = 全局量.热点提醒图标
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).组件布局器_根容器.底色 = 全局量.父项正常背景颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.背景颜色 = 全局量.父项正常背景颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图.背景颜色 = 全局量.父项正常背景颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图2.背景颜色 = 全局量.父项正常背景颜色
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.标准鼠标指针 = 全局量.鼠标指针类型
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_左图.标准鼠标指针 = 全局量.鼠标指针类型
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_左图2.标准鼠标指针 = 全局量.鼠标指针类型
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图.标准鼠标指针 = 全局量.鼠标指针类型
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_右图2.标准鼠标指针 = 全局量.鼠标指针类型
        ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_横条.标准鼠标指针 = 全局量.鼠标指针类型
        如果 (全局量.父项横向间隔颜色 > -1)
        {
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_横条.底图 = 空资源.空位图
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_横条.背景颜色 = 全局量.父项横向间隔颜色
        }
        否则
        {
            ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_横条.底图 = 全局量.父项横向间隔图标
        }
        如果 (全局量.是否启用左右间隔色)
        {
