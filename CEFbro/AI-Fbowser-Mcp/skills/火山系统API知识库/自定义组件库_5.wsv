    {
        // 组合框1.类型 = 所欲设置的类型
        组合类型 = 所欲设置的类型
        如果 (所欲设置的类型 == 组合框类型.不可编辑下拉式)
        {
            编辑框1.输入方式 = 编辑框输入方式.只读方式
        }
        否则
        {
            编辑框1.输入方式 = 编辑框输入方式.通常方式
        }
    }

