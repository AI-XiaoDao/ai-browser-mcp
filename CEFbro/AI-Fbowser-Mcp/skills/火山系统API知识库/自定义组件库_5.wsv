类 选择框类_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"自定义组件库.选择框\"" @视窗.布局 = "client_size = \"80, 32\"" 可停留焦点 = 真
        底色 = 0x00FFFF>
{
    变量 显示画板 <类型 = GP缓存图形类>
    变量 后台图像 <类型 = GP位图类>
    变量 绘制画板 <类型 = GP图形类>
    变量 程_窗口句柄 <类型 = 变整数>
    变量 程_父窗口宽 <类型 = 整数>
    变量 程_父窗口高 <类型 = 整数>
    变量 按钮区范围 <类型 = 选择框_尺寸>
    变量 出入 <类型 = 组件移入移出事件类2_>
    变量 令牌 <类型 = 变整数>
    变量 变量类 <类型 = 选择框变量类>
    变量 公用方法 <类型 = 公用方法>
    变量 矩形组 <类型 = 矩形F>
    变量 鼠标被按下 <类型 = 逻辑型>
    变量 样式类型 <类型 = 选择框显示样式 值 = 选择框显示样式.方形>

    方法 取组件句柄 <公开 类型 = 变整数 折叠>
    {
        返回 (取窗口句柄 ())
    }

    方法 置选择框状态 <公开 折叠>
    参数 是否选中 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时记忆 <类型 = 逻辑型>
        临时记忆 = 变量类.禁止取消
        变量类.禁止取消 = 假
        变量类.已打开 = 是否选中
        变量类.禁止取消 = 临时记忆
        刷新选择框 ()
    }

    方法 初始化配色 <公开 注释 = "透明度：0到255之间的整数. 0、完全透明　255、 完全不透明." 注释 = "默认－1则不会改变原设置。在“创建选择框”之前执行本配色" 折叠 折叠2>
    参数 背景色 <类型 = 整数 注释 = "默认：0xF0F0F0；当有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" @默认值 = -1>
    参数 正常内框起点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色　。样式1时有效" @默认值 = -1>
    参数 正常内框起点透明度 <类型 = 整数 注释 = "默认：255　。样式1时有效" @默认值 = -1>
    参数 正常内框终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色　。样式1时有效" @默认值 = -1>
    参数 正常内框终点透明度 <类型 = 整数 注释 = "默认：255　。样式1时有效" @默认值 = -1>
    参数 外框色 <类型 = 整数 注释 = "默认：0xF79924" @默认值 = -1>
    参数 外框透明度 <类型 = 整数 注释 = "默认：200" @默认值 = -1>
    参数 热点内框起点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点内框起点透明度 <类型 = 整数 注释 = "默认：90" @默认值 = -1>
    参数 热点内框终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点内框终点透明度 <类型 = 整数 注释 = "默认：255" @默认值 = -1>
    {
        如果真 (背景色 != -1)
        {
            变量类.背景色 = 背景色
        }
        如果真 (正常内框起点色 != -1)
        {
            变量类.正常内框起点色 = 正常内框起点色
        }
        如果真 (正常内框起点透明度 != -1)
        {
            变量类.正常内框起点透明度 = 正常内框起点透明度
        }
        如果真 (正常内框终点色 != -1)
        {
            变量类.正常内框终点色 = 正常内框终点色
        }
        如果真 (正常内框终点透明度 != -1)
        {
            变量类.正常内框终点透明度 = 正常内框终点透明度
        }
        如果真 (外框色 != -1)
        {
            变量类.外框色 = 外框色
        }
        如果真 (外框透明度 != -1)
        {
            变量类.外框透明度 = 外框透明度
        }
        如果真 (热点内框起点色 != -1)
        {
            变量类.热点内框起点色 = 热点内框起点色
        }
        如果真 (热点内框起点透明度 != -1)
        {
            变量类.热点内框起点透明度 = 热点内框起点透明度
        }
        如果真 (热点内框终点色 != -1)
        {
            变量类.热点内框终点色 = 热点内框终点色
        }
        如果真 (热点内框终点透明度 != -1)
        {
            变量类.热点内框终点透明度 = 热点内框终点透明度
        }
    }

    方法 修改配色 <公开 注释 = "透明度：0到255之间的整数. 0、完全透明　255、 完全不透明." 注释 = "默认－1则不会改变原设置。在“创建选择框”之后执行本配色进行重设置" 折叠 折叠2>
    参数 背景色 <类型 = 整数 注释 = "默认：0xF0F0F0；当有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" @默认值 = -1>
    参数 正常内框起点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色　。样式1时有效" @默认值 = -1>
    参数 正常内框起点透明度 <类型 = 整数 注释 = "默认：255　。样式1时有效" @默认值 = -1>
    参数 正常内框终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色　。样式1时有效" @默认值 = -1>
    参数 正常内框终点透明度 <类型 = 整数 注释 = "默认：255　。样式1时有效" @默认值 = -1>
    参数 外框色 <类型 = 整数 注释 = "默认：0xF79924" @默认值 = -1>
    参数 外框透明度 <类型 = 整数 注释 = "默认：200" @默认值 = -1>
    参数 热点内框起点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点内框起点透明度 <类型 = 整数 注释 = "默认：90" @默认值 = -1>
    参数 热点内框终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点内框终点透明度 <类型 = 整数 注释 = "默认：255" @默认值 = -1>
    {
        初始化配色 (背景色, 正常内框起点色, 正常内框起点透明度, 正常内框终点色, 正常内框终点透明度, 外框色, 外框透明度, 热点内框起点色, 热点内框起点透明度, 热点内框终点色, 热点内框终点透明度)
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        刷新选择框 ()
    }

    方法 创建选择框 <公开 折叠>
    参数 绑定容器 <类型 = 窗口容器组件>
    参数 标题名 <类型 = 文本型 @默认值 = "选择框">
    参数 标题颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 字体名称 <类型 = 文本型 @默认值 = "微软雅黑">
    参数 字体大小 <类型 = 整数 @默认值 = 14>
    参数 是否选中 <类型 = 逻辑型 注释 = "初始显示选择框状态是否选中" @默认值 = 假>
    参数 样式 <类型 = 整数 注释 = "1、方形　2、圆形" @默认值 = 1>
    参数 圆角度数 <类型 = 小数 注释 = "当样式为方形时本参数才会生效" @默认值 = 6>
    参数 禁止取消 <类型 = 逻辑型 注释 = "当样式为圆形时本参数才会生效." 注释 = "为真时，只能通过“置选择框状态”命令来取消已被选中的" @默认值 = 真>
    参数 标记值 <类型 = 整数 @默认值 = 0>
    {
        创建组件 (绑定容器, 0, 0, 绑定容器.宽度, 绑定容器.高度, )
        令牌 = GP初始类.初始化 ()
        初始处理 ()
        变量类.标题名 = 标题名
        变量类.标题颜色 = 标题颜色
        变量类.宽度 = 绑定容器.宽度
        变量类.高度 = 绑定容器.高度
        变量类.字体名称 = 字体名称
        变量类.字体大小 = 字体大小
        变量类.是否选中 = 是否选中
        变量类.样式 = 样式
        变量类.圆角度数 = 圆角度数
        变量类.禁止取消 = 禁止取消
        变量类.标记值 = 标记值
        程_窗口句柄 = 取窗口句柄 ()
        显示画板.创建 (1, 1, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        后台图像.创建自像素格式 (1, 1)
        绘制画板.创建自图像 (后台图像)
        刷新设置 ()
    }

