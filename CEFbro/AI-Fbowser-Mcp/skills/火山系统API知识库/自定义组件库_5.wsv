类 高级组合框 <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1, 2" @文档 = "category = \"自定义组件库.高级组合框\"" @视窗.布局 = "client_size = \"192, 82\""
        @视窗.窗口组件 = "icon=\"tb/zhk.bmp\"\r\ndefault_size = \"120, 24\"\r\ncategory = \"仰望模块扩展组件\"">
{
    变量 动态 <类型 = 动态组合框模板>
    变量 编辑框1 <类型 = 编辑框 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"64, 0, 104, 24\"" 组件边框 = 无边框>
    变量 标签1 <类型 = 标签 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"0, 0, 56, 24\"">
    变量 组合框1 <类型 = 组合框 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\npos = \"56, 40, 100, 24\"">
    变量 标签2 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\npos = \"25, 49, 56, 24\"" 背景颜色 = 0xFFFFFF>
    变量 间距 <类型 = 整数 值 = 5>
    变量 差值 <类型 = 整数 值 = 19>
