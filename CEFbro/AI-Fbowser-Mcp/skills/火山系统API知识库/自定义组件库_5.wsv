    方法 图标选择 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 所欲设置的图标 <类型 = 按钮图标类>
    {
        变量 局部样式 <类型 = 文本型>
        局部样式 = (文本型)所欲设置的图标
        如果 (所欲设置的图标 == 按钮图标类.帮助 || 局部样式 == "帮助")
        {
            变量类.图标 = 取出资源文件_ (变量类.帮助)
        }
        否则 (所欲设置的图标 == 按钮图标类.保存 || 局部样式 == "保存")
        {
            变量类.图标 = 取出资源文件_ (变量类.保存)
        }
        否则 (所欲设置的图标 == 按钮图标类.查询 || 局部样式 == "查询")
        {
            变量类.图标 = 取出资源文件_ (变量类.查询)
        }
        否则 (所欲设置的图标 == 按钮图标类.查询2 || 局部样式 == "查询2")
        {
            变量类.图标 = 取出资源文件_ (变量类.查询2)
        }
        否则 (所欲设置的图标 == 按钮图标类.窗口 || 局部样式 == "窗口")
        {
            变量类.图标 = 取出资源文件_ (变量类.窗口)
        }
        否则 (所欲设置的图标 == 按钮图标类.打印 || 局部样式 == "打印")
        {
            变量类.图标 = 取出资源文件_ (变量类.打印)
        }
        否则 (所欲设置的图标 == 按钮图标类.清除 || 局部样式 == "清除")
        {
            变量类.图标 = 取出资源文件_ (变量类.清除)
        }
        否则 (所欲设置的图标 == 按钮图标类.确定 || 局部样式 == "确定")
        {
            变量类.图标 = 取出资源文件_ (变量类.确定)
        }
        否则 (所欲设置的图标 == 按钮图标类.取消 || 局部样式 == "取消")
        {
            变量类.图标 = 取出资源文件_ (变量类.取消)
        }
        否则 (所欲设置的图标 == 按钮图标类.日历 || 局部样式 == "日历")
        {
            变量类.图标 = 取出资源文件_ (变量类.日历)
        }
        否则 (所欲设置的图标 == 按钮图标类.删除 || 局部样式 == "删除")
        {
            变量类.图标 = 取出资源文件_ (变量类.删除)
        }
        否则 (所欲设置的图标 == 按钮图标类.时间 || 局部样式 == "时间")
        {
            变量类.图标 = 取出资源文件_ (变量类.时间)
        }
        否则 (所欲设置的图标 == 按钮图标类.首页 || 局部样式 == "首页")
        {
            变量类.图标 = 取出资源文件_ (变量类.首页)
        }
        否则 (所欲设置的图标 == 按钮图标类.图片 || 局部样式 == "图片")
        {
            变量类.图标 = 取出资源文件_ (变量类.图片)
        }
        否则 (所欲设置的图标 == 按钮图标类.文件 || 局部样式 == "文件")
        {
            变量类.图标 = 取出资源文件_ (变量类.文件)
        }
        否则 (所欲设置的图标 == 按钮图标类.修改 || 局部样式 == "修改")
        {
            变量类.图标 = 取出资源文件_ (变量类.修改)
        }
        否则 (所欲设置的图标 == 按钮图标类.加号 || 局部样式 == "加号")
        {
            变量类.图标 = 取出资源文件_ (变量类.加号)
        }
        否则 (所欲设置的图标 == 按钮图标类.减号 || 局部样式 == "减号")
        {
            变量类.图标 = 取出资源文件_ (变量类.减号)
        }
        否则
        {
            变量类.图标 = 取空白字节集 (0)
        }
    }

