    参数 滑块正常边框透明度1 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 滑块正常边框色2 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 滑块正常边框透明度2 <类型 = 整数 注释 = "默认：120" @默认值 = -1>
    参数 滑块热点起点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 滑块热点起点透明度 <类型 = 整数 注释 = "默认：120" @默认值 = -1>
    参数 滑块热点边框色1 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
    参数 滑块热点边框透明度1 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 滑块热点边框色2 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 滑块热点边框透明度2 <类型 = 整数 注释 = "默认：120" @默认值 = -1>
    {
        如果真 (滑块正常起点色 != -1)
        {
            变量类.滑块正常起点色 = 滑块正常起点色
        }
        如果真 (滑块正常起点透明度 != -1)
        {
            变量类.滑块正常起点透明度 = 滑块正常起点透明度
        }
        如果真 (滑块正常终点色 != -1)
        {
            变量类.滑块正常终点色 = 滑块正常终点色
        }
        如果真 (滑块正常终点透明度 != -1)
        {
            变量类.滑块正常终点透明度 = 滑块正常终点透明度
        }
        如果真 (滑块正常边框色1 != -1)
        {
            变量类.滑块正常边框色1 = 滑块正常边框色1
        }
        如果真 (滑块正常边框透明度1 != -1)
        {
            变量类.滑块正常边框透明度1 = 滑块正常边框透明度1
        }
        如果真 (滑块正常边框色2 != -1)
        {
            变量类.滑块正常边框色2 = 滑块正常边框色2
        }
        如果真 (滑块正常边框透明度2 != -1)
        {
            变量类.滑块正常边框透明度2 = 滑块正常边框透明度2
        }
        如果真 (滑块热点起点色 != -1)
        {
            变量类.滑块热点起点色 = 滑块热点起点色
        }
        如果真 (滑块热点起点透明度 != -1)
        {
            变量类.滑块热点起点透明度 = 滑块热点起点透明度
        }
        如果真 (滑块热点边框色1 != -1)
        {
            变量类.滑块热点边框色1 = 滑块热点边框色1
        }
        如果真 (滑块热点边框透明度1 != -1)
        {
            变量类.滑块热点边框透明度1 = 滑块热点边框透明度1
        }
        如果真 (滑块热点边框色2 != -1)
        {
            变量类.滑块热点边框色2 = 滑块热点边框色2
        }
        如果真 (滑块热点边框透明度2 != -1)
        {
            变量类.滑块热点边框透明度2 = 滑块热点边框透明度2
        }
    }

