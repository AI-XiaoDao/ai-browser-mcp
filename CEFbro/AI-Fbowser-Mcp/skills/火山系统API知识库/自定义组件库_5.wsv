        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_PRESSED_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置禁止图片_字节 <公开 折叠>
    参数 所欲设置的位图数据 <类型 = 字节集类>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_DISABLED_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置正常图片_路径 <公开 折叠>
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_NORMAL_BITMAP, (HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置点燃图片_路径 <公开 折叠>
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_HIGHLIGHT_BITMAP, (HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置按下图片_路径 <公开 折叠>
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_PRESSED_BITMAP, (HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }

    方法 置禁止图片_路径 <公开 折叠>
    参数 所欲设置的位图文件名 <类型 = 文本型>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_DISABLED_BITMAP, (HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲设置的位图文件名>));
    }
}

