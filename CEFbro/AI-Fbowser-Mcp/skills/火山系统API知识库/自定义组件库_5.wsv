    方法 删除父项_ <公开 类型 = 逻辑型 注释 = "删除父项后，整个子项也被删除" 折叠>
    参数 父项索引 <类型 = 整数 注释 = "从0开始">
    {
        变量 数量 <类型 = 整数>
        变量 父数 <类型 = 整数>
        变量 临时高 <类型 = 整数>
        变量 起始索引 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (全局量.是否整体锁定)
        {
            返回 (假)
        }
        如果真 (父项索引 > -1 && 父项索引 + 1 <= 卷帘布局组.取成员数 ())
        {
            展开所有父项_ (假)
            禁止重画 ()
            ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).销毁 ()
            卷帘布局组.删除成员 (父项索引)
            重置固定索引 (父项索引)
            数量 = 卷帘布局组2.取成员数 ()
            循环 (, 数量, i)
            {
                如果真 (((子卷帘模板类)卷帘布局组2.取成员 (数量 - i - 1)).当前父项索引 == 父项索引)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (数量 - i - 1)).销毁 ()
                    卷帘布局组2.删除成员 (数量 - i - 1)
                }
            }
            卷帘布局组.枚举循环 ()
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).当前索引 = 对象数组类.取枚举索引 ()
            }
            计次循环 (父项索引)
            {
                起始索引 = 起始索引 + 全局量.子项组数 [取循环索引 ()]
            }
            循环 (起始索引, 卷帘布局组2.取成员数 (), i)
            {
                父数 = ((子卷帘模板类)卷帘布局组2.取成员 (i)).当前父项索引
                如果真 (父数 - 1 > -1)
                {
                    父数 = 父数 - 1
                }
                ((子卷帘模板类)卷帘布局组2.取成员 (i)).当前父项索引 = 父数
            }
            卷帘布局组.枚举循环 ()
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).顶边 = 临时高
                临时高 = ((父卷帘模板类)卷帘布局组.取枚举值 ()).顶边 + ((父卷帘模板类)卷帘布局组.取枚举值 ()).高度
            }
            ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).销毁 ()
            卷帘布局组3.删除成员 (父项索引)
            重置触点索引 ()
            允许重画 ()
            临时高 = 取卷帘总高度 ()
            纵向.重置滚动条_ (本对象.高度 - 全局量.父项高度 - 10, 临时高, )
            返回 (真)
        }
        返回 (假)
    }

