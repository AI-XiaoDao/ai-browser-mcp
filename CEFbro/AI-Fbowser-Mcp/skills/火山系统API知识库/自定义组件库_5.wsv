        {
            返回 (假)
        }
        结果 = 导航.交换子夹_ (原索引, 现索引)
        如果真 (结果)
        {
            窗口组.交换成员 (原索引, 现索引)
            窗口组.枚举循环 ()
            {
                夹信息 = 窗口组.取枚举值 ()
                夹信息.子夹索引 = 高级选择夹信息组.取枚举索引 ()
                窗口组.置成员值 (高级选择夹信息组.取枚举索引 (), 夹信息)
            }
        }
        返回 (结果)
    }

    方法 到首子夹_ <公开 注释 = "跳到首子夹_页面" 折叠>
    {
