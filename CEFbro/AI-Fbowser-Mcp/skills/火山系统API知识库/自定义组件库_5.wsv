        变量 真实子索引 <类型 = 整数>
        如果真 (全局量.是否整体锁定)
        {
            返回 (假)
        }
        如果真 (父项索引 > -1 && 父项索引 + 1 <= 卷帘布局组.取成员数 ())
        {
            父项名称 = ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).标签_标题.标题
            父项标记 = ((父卷帘模板类)卷帘布局组.取成员 (临时索引)).当前标记
            判断循环 (子项名称组.取成员数 () != 子项标记组.取成员数 ())
            {
                子项标记组.加入成员 ("")
            }
            原子数量 = 全局量.子项组数 [父项索引]
            如果 (原子数量 > 0)
            {
                真实子索引 = 取子项真实索引 (父项索引, 原子数量 - 1)
                原高度 = 原子数量 * 全局量.子项高度
            }
            否则
            {
                如果 (父项索引 > 0)
                {
                    真实子索引 = 取子项真实索引 (父项索引 - 1, 全局量.子项组数 [父项索引 - 1] - 1)
                }
                否则
                {
                    真实子索引 = 取子项真实索引 (0, 0)
                }
                原高度 = 0
            }
            全局量.子项组数 [父项索引] = 原子数量 + 子项名称组.取成员数 ()
            子项名称组.枚举循环 ()
            {
                临时索引 = 真实子索引 + 子项名称组.取枚举索引 () + 1
                卷帘布局组2.插入新成员 (临时索引, 子卷帘模板类)
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).可视 = 假
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).创建容器组件 ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引), 500, 0)
                如果 (全局量.是否允许前后间隔)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).移动 (0, 原高度 + 子项名称组.取枚举索引 () * 全局量.子项高度 + 5, 本对象.宽度, 全局量.子项高度)
                }
                否则
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).移动 (0, 原高度 + 子项名称组.取枚举索引 () * 全局量.子项高度, 本对象.宽度, 全局量.子项高度)
                }
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).排序布局 (全局量.子项高度, 全局量.子标题左侧间隔, 全局量.图标隐藏方式, 全局量.子项左图标左侧间隔, 全局量.子项提醒图标右侧间隔, 父项索引, 父项名称, 父项标记, 原子数量 + 子项名称组.取枚举索引 (), 子项标记组.取成员 (子项名称组.取枚举索引 ()))
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.标题 = 子项名称组.取枚举值 ()
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.文本颜色 = 全局量.子标题颜色
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.背景颜色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.字体 = 全局量.子项字体名称 + "," + 到文本 (全局量.子项字体大小)
                如果 (全局量.子项标题对齐方式 == 0)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.左边
                }
                否则 (全局量.子项标题对齐方式 == 1)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.居中
                }
                否则 (全局量.子项标题对齐方式 == 2)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.横向对齐方式 = 横向对齐模式.右边
                }
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.调整层次 (组件层次.顶层)
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).底色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).组件布局器_根容器.底色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_左图.背景颜色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_标题.标准鼠标指针 = 全局量.鼠标指针类型
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_左图.标准鼠标指针 = 全局量.鼠标指针类型
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).标签_右图.标准鼠标指针 = 全局量.鼠标指针类型
                处理事件_ ()
                ((子卷帘模板类)卷帘布局组2.取成员 (临时索引)).可视 = 真
                挂接事件 ((子卷帘模板类)卷帘布局组2.取成员 (临时索引))
            }
            如果 (父项索引 > 0)
            {
                临时高 = ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).顶边 + ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).高度
            }
            否则
            {
                临时高 = ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).高度
            }
            ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).移动 (0, 临时高, 本对象.宽度, 全局量.子项组数 [父项索引] * 全局量.子项高度 + 15)
            如果真 (((父卷帘模板类)卷帘布局组.取成员 (父项索引)).高度 > 全局量.父项高度)
            {
                如果 (全局量.是否允许前后间隔)
                {
                    子项总高 = 全局量.父项高度 + 全局量.子项高度 * 全局量.子项组数 [父项索引] + 5
                }
                否则
                {
                    子项总高 = 全局量.父项高度 + 全局量.子项高度 * 全局量.子项组数 [父项索引]
                }
                ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).高度 = 子项总高
                卷帘布局组.枚举循环 ()
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).顶边 = 临时高
                    临时高 = ((父卷帘模板类)卷帘布局组.取枚举值 ()).顶边 + ((父卷帘模板类)卷帘布局组.取枚举值 ()).高度
                }
            }
            父项顶边重排 ()
            重置滚动条位置 ()
            ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_右图.可视 = 真
            返回 (真)
        }
        返回 (假)
    }

    方法 展开所有父项_ <公开 注释 = "展开或收缩所有父项" 折叠>
    参数 是否展开 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 临时高 <类型 = 整数>
        变量 是否开 <类型 = 逻辑型>
        变量 i <类型 = 整数>
        如果真 (全局量.是否整体锁定)
        {
            返回
        }
        组件布局器_列表区2.可视 = 假
        如果 (是否展开)
        {
            卷帘布局组3.枚举循环 ()
            {
                i = 对象数组类.取枚举索引 ()
                如果 (i > 0)
                {
                    临时高 = ((父卷帘模板类)卷帘布局组.取成员 (i)).顶边 + ((父卷帘模板类)卷帘布局组.取成员 (i)).高度
                }
                否则
                {
                    临时高 = ((父卷帘模板类)卷帘布局组.取成员 (i)).高度
                }
                ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).移动 (0, 临时高, 本对象.宽度, 全局量.子项组数 [i] * 全局量.子项高度 + 15)
                ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).可视 = 真
                ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).标记 = "1"
                ((父卷帘模板类)卷帘布局组.取成员 (i)).标签_右图.底图 = 全局量.父项热点右侧图标
                是否开 = 真
            }
        }
        否则
        {
            卷帘布局组3.枚举循环 ()
            {
                i = 对象数组类.取枚举索引 ()
                ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).可视 = 假
                ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).标记 = "0"
                ((父卷帘模板类)卷帘布局组.取成员 (i)).标签_右图.底图 = 全局量.父项正常右侧图标
                是否开 = 假
            }
        }
        组件布局器_列表区2.可视 = 真
        父项顶边重排 ()
        重置滚动条位置 ()
        父项菜单收展事件 (-1, "", 是否开)
    }

    方法 匹配卷帘宽度_ <公开 注释 = "当卷帘体宽度发生改变后，重置正确尺寸" 折叠>
    {
        变量 i <类型 = 整数>
        循环 (, 取父项总数_ (), i)
        {
            ((父卷帘模板类)卷帘布局组.取成员 (i)).宽度 = 本对象.宽度
            ((父卷帘模板类)卷帘布局组.取成员 (i)).排序布局 (全局量.父项高度, 全局量.父标题左侧间隔, 全局量.图标隐藏方式, 全局量.父项左图标左侧间隔, 全局量.父项右图标右侧间隔, 全局量.父项提醒图标右侧间隔, , , 真)
            ((子卷帘承载模板类)卷帘布局组3.取成员 (i)).宽度 = 本对象.宽度
        }
        循环 (, 取子项总数_ (), i)
        {
            ((子卷帘模板类)卷帘布局组2.取成员 (i)).宽度 = 本对象.宽度
            ((子卷帘模板类)卷帘布局组2.取成员 (i)).排序布局 (全局量.子项高度, 全局量.子标题左侧间隔, 全局量.图标隐藏方式, 全局量.子项左图标左侧间隔, 全局量.子项提醒图标右侧间隔, , , , , , 真)
        }
    }

