    方法 置风格 <公开 折叠>
    参数 样式 <类型 = 整数 注释 = "0、天蓝色　1、黑灰色" @默认值 = 0>
    {
        如果 (样式 == 0)
        {
            修改配色_滑块 (颜色类.白色, 200, 颜色类.天蓝色, 150, 颜色类.黑色, 60, 颜色类.白色, 120, 颜色类.天蓝色, 120, 颜色类.黑色, 60, 颜色类.白色, 120)
            修改配色_滑块槽 (颜色类.银白色, 255, 颜色类.天蓝色, 40, 颜色类.白色, 255)
            修改配色_箭头 (颜色类.白色, 250, 颜色类.天蓝色, 255, 颜色类.黑色, 60, 颜色类.白色, 150)
        }
        否则
        {
            修改配色_滑块 (颜色类.白色, 100, 颜色类.灰色, 255, 颜色类.黑色, 60, 颜色类.白色, 120, 颜色类.深灰色, 120, 颜色类.黑色, 60, 颜色类.白色, 100)
            修改配色_滑块槽 (颜色类.银白色, 255, 颜色类.浅灰色, 40, 颜色类.白色, 255)
            修改配色_箭头 (颜色类.白色, 250, 颜色类.灰色, 255, 颜色类.黑色, 60, 颜色类.白色, 150)
        }
        绘制画板.清除 (GP颜色.到ARGB (变量类.滑块槽主背景色, 变量类.滑块槽主背景透明度))
        刷新滚动条 ()
    }

