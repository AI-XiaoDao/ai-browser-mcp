    方法 导航头类__子夹被关闭事件 <接收事件 类型 = 整数 注释 = "子夹右侧关闭按钮" 折叠>
    参数 来源对象 <类型 = 导航头类_>
    参数 标记值 <类型 = 整数>
    参数 子夹标题 <类型 = 文本型>
    参数 子夹标记 <类型 = 文本型>
    参数 子夹索引 <类型 = 整数>
    参数 询问关闭 <类型 = 逻辑型>
    {
        如果真 (全局量.全局锁定界面)
        {
            返回 (0)
        }
        如果 (询问关闭)
        {
            子夹被关闭事件 (子夹标题, 子夹标记, 子夹索引, 真)
        }
        否则
        {
            内部关闭子夹 (子夹标题, 子夹标记, 子夹索引)
        }
        返回 (0)
    }

    方法 内部关闭子夹 <折叠>
    参数 子夹标题 <类型 = 文本型>
    参数 子夹标记 <类型 = 文本型>
    参数 子夹索引 <类型 = 整数>
    {
        标签_隐藏条.可视 = 假
        如果真 (全局量.是否解除 == 假)
        {
            公用删除窗口 (子夹索引)
        }
        如果真 (全局量.确认关闭 == 假)
        {
            子夹被关闭事件 (子夹标题, 子夹标记, 子夹索引, 假)
        }
        重定位热点窗口 (子夹索引)
    }

    方法 公用删除窗口 <折叠>
    参数 子夹索引 <类型 = 整数>
    参数 是否删除窗口 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        变量 索引 <类型 = 整数>
        变量 结果 <类型 = 逻辑型>
        变量 i <类型 = 整数>
        互斥.加锁 ()
        窗口组.枚举循环 ()
        {
            如果真 (窗口组.取枚举值 ().子夹索引 == 子夹索引 && 窗口组.取枚举值 ().是否锁定 == 假)
            {
                结果 = 真
                如果真 (是否删除窗口)
                {
                    窗口_销毁窗口组件 (窗口组.取枚举值 ().窗口句柄)
                }
                如果真 (窗口组.取枚举值 ().是否DLL && 窗口组.取枚举值 ().动态句柄 > 0)
                {
                    动态DLL.动态释放DLL_ (窗口组.取枚举值 ().动态句柄)
                }
                索引 = 高级选择夹信息组.取枚举索引 ()
                窗口组.删除成员 (索引)
                跳出循环
            }
        }
        如果真 (结果)
        {
            循环 (索引, 窗口组.取成员数 (), i)
            {
                夹信息 = 窗口组.取成员 (i)
                夹信息.子夹索引 = 夹信息.子夹索引 - 1
                窗口组.置成员值 (i, 夹信息)
            }
        }
        互斥.解锁 ()
    }

    方法 公用删除所有窗口 <折叠>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        变量 结果 <类型 = 逻辑型>
        变量 数量 <类型 = 整数>
        变量 i <类型 = 整数>
        互斥.加锁 ()
        数量 = 窗口组.取成员数 ()
        循环 (, 数量, i)
        {
            如果真 (窗口组.取成员 (数量 - i - 1).是否锁定 == 假)
            {
                结果 = 真
                窗口_销毁窗口组件 (窗口组.取成员 (数量 - i - 1).窗口句柄)
                如果真 (窗口组.取成员 (数量 - i - 1).是否DLL && 窗口组.取成员 (数量 - i - 1).动态句柄 > 0)
                {
                    动态DLL.动态释放DLL_ (窗口组.取成员 (数量 - i - 1).动态句柄)
                    动态DLL.动态释放DLL_ (窗口组.取成员 (数量 - i - 1).动态句柄)
                }
                窗口组.删除成员 (数量 - i - 1)
            }
        }
        如果真 (结果)
        {
            循环 (, 窗口组.取成员数 (), i)
            {
                夹信息 = 窗口组.取成员 (i)
                夹信息.子夹索引 = 夹信息.子夹索引 - 1
                窗口组.置成员值 (i, 夹信息)
            }
        }
        互斥.解锁 ()
    }

    方法 重定位热点窗口 <折叠>
    参数 子夹索引 <类型 = 整数>
    {
        变量 临时数 <类型 = 整数>
        如果真 (全局量.是否停止定位)
        {
            返回
        }
        临时数 = 导航.取子夹数目_ () - 1
        如果 (子夹索引 - 1 > -1)
        {
            跳转子夹_ (子夹索引 - 1)
        }
        否则 (子夹索引 < 临时数 && 子夹索引 > -1)
        {
            跳转子夹_ (子夹索引)
        }
        否则 (临时数 == 1 || 窗口组.取成员数 () == 1)
        {
            跳转子夹_ (0)
        }
    }

