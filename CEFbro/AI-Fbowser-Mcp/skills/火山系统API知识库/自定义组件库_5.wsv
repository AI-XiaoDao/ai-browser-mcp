    变量 标签_标题 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\nparent_id = 101\r\npos = \"0, 16, 80, 24\"" 纵向对齐方式 = 居中
            字体 = "宋体, 12, 0, 0, 0, 0, 0" 背景颜色 = 0x3D241F>
    变量 标签_右图 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\nparent_id = 101\r\npos = \"144, 16, 24, 24\"" 底图 = "tb\\菜单头2.png"
            底图方式 = 图片居中 标准鼠标指针 = 手型 背景颜色 = 0x3D241F>
