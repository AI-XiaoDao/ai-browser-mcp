    方法 编辑框_字符输入 <接收事件 类型 = 整数 注释 = "  当用户输入一个字符后发生此事件,字符键包括任何可打印的键盘字符及回车(Enter)" 注释 = "和退格(BackSpace)键."
            返回值注释 = "  本事件的处理方法返回值如果小于0,表明事件已经得到处理且不再需要后续处理,如果" 返回值注释 = "大于0,则将该值作为新的替代字符代码继续进行后续处理.如果等于0,则使用原字符值继"
            返回值注释 = "续进行后续处理." 折叠 折叠2>
    参数 来源对象 <类型 = 编辑框>
    参数 标记值 <类型 = 整数>
    参数 字符代码 <类型 = 字符 注释 = "提供所输入的字符">
    {
        如果 (来源对象 == 编辑框1)
        {
            如果真 (来源对象.是否允许多行 == 假)
            {
                如果真 (字符代码 == 13)
                {
                    返回 (-1)
                }
            }
            返回 (字符输入事件 (字符代码))
        }
        返回 (0)
    }

    方法 字符输入事件 <公开 定义事件 类型 = 整数 折叠>
    参数 字符代码 <类型 = 整数 注释 = "提供所输入的字符">
}

类 动态编辑框模板 <折叠 @文档 = "category = \"自定义组件库.附加类\"">
{
    变量 动态编辑框 <类型 = 对象数组类>
    变量 参考编辑框 <类型 = 编辑框>
    变量 编辑框标记 <类型 = 整数类>

    方法 创建编辑框 <公开 类型 = 编辑框 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 内容 <类型 = 文本型 @默认值 = "">
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 80>
    参数 高度 <类型 = 整数 @默认值 = 24>
    参数 允许多行 <类型 = 逻辑型 @默认值 = 假>
    参数 滚动条 <类型 = 滚动条类型 @默认值 = 滚动条类型.无>
    参数 调节器方式 <类型 = 编辑框调节器方式 @默认值 = 编辑框调节器方式.无调节器>
    参数 对齐方式 <类型 = 横向对齐模式 @默认值 = 横向对齐模式.左边>
    参数 输入方式 <类型 = 编辑框输入方式 @默认值 = 编辑框输入方式.通常方式>
    参数 最大允许长度 <类型 = 整数 @默认值 = 0>
    {
        动态编辑框.加入并返回新成员2 (编辑框, 0, 编辑框标记)
        参考编辑框 = (编辑框)动态编辑框.取成员 (编辑框标记.值)
        参考编辑框.内容 = 内容
        参考编辑框.滚动条 = 滚动条
        参考编辑框.是否允许多行 = 允许多行
        参考编辑框.调节器方式 = 调节器方式
        参考编辑框.对齐方式 = 对齐方式
        参考编辑框.输入方式 = 输入方式
        参考编辑框.最大允许长度 = 最大允许长度
        参考编辑框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考编辑框)
    }
}

# //选择夹=====

类 高级选择夹 <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1, 2" @文档 = "category = \"自定义组件库.高级选择夹\"" @视窗.布局 = "client_size = \"520, 220\""
        @视窗.窗口组件 = "icon=\"@70\"\r\ndefault_size = \"520, 220\"\r\ncategory = \"仰望模块扩展组件\"\r\ndefault_event=\"子夹被单击事件\"">
{
    变量 导航 <类型 = 导航头类_ 折叠 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 432, 32\"">
    变量 组件布局器_窗体区 <类型 = 组件布局器 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"0, 48, 120, 100\"">
    变量 标签_间隔条2 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\npos = \"8, 40, 80, 1\"" 背景颜色 = 0xC0C0C0>
    变量 标签_间隔条1 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\npos = \"176, 56, 80, 1\"" 背景颜色 = 0xC0C0C0>
    变量 标签_隐藏条 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 105\r\npos = \"263, 116, 80, 1\"" 背景颜色 = 0xFFFFFF 可视 = 假>
    变量 全局量 <类型 = 高级选择夹变量>
    变量 动态DLL <类型 = 动态链接库类_>
    变量 布局组 <类型 = 对象数组类>
    变量 线程 <类型 = 线程池类2_>
    变量 线程2 <类型 = 线程池类2_>
    变量 互斥 <类型 = 互斥锁类>
    变量 窗口组 <类型 = 高级选择夹信息组>
    变量 主线 <类型 = 高级主线程处理器>
    变量 钩子 <类型 = 钩子类_>
    变量 标签组 <类型 = 对象数组类>
    变量 动态 <类型 = 动态标签类2_>
    变量 对象组 <类型 = 对象数组类>
    变量 添加中 <类型 = 逻辑型>

    方法 类_初始化 <折叠>
    {
        窗口组.删除所有成员 ()
        线程.创建_ (1)
        线程2.创建_ (1)
    }

    方法 类_清理 <折叠>
    {
        全局量.已启动 = 假
    }

    方法 允许退出_ <公开 注释 = "本程序需要彻底关闭退出程序时，先执行本命令" 折叠>
    {
        全局量.已启动 = 假
    }

    方法 初始化选择夹_ <公开 折叠>
    参数 子夹头高度 <类型 = 整数 注释 = "当为0时，将隐藏子夹头" @默认值 = 32>
    参数 字体名称 <类型 = 文本型 注释 = "子夹标题字体名称" @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 注释 = "子夹标题字体大小" @默认值 = 9>
    参数 是否加粗 <类型 = 逻辑型 注释 = "子夹标题字体是否加粗" @默认值 = 假>
    参数 标题间隔符 <类型 = 文本型 注释 = "此参数不为空时，即父窗口原标题＋子窗口标题，形式显示" @默认值 = "  》》">
    参数 标题对齐方式 <类型 = 整数 注释 = "子夹标题对齐方式 0、左对齐 1、居中" @默认值 = 1>
    参数 正常标题颜色 <类型 = 整数 注释 = "子夹标题颜色" @默认值 = 颜色类.黑色>
    参数 热点标题颜色 <类型 = 整数 注释 = "子夹标题颜色" @默认值 = 颜色类.红色>
    参数 子夹正常背景颜色 <类型 = 整数 注释 = "单子夹" @默认值 = 颜色类.默认色>
    参数 子夹热点背景颜色 <类型 = 整数 注释 = "单子夹" @默认值 = 颜色类.白色>
    参数 窗体区背景颜色 <类型 = 整数 @默认值 = 颜色类.默认色>
    参数 隐藏下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 下划线正常颜色 <类型 = 整数 @默认值 = 颜色类.红色>
    参数 下划线热点颜色 <类型 = 整数 @默认值 = 0xD9751E>
    参数 下划线位置 <类型 = 整数 注释 = "1、顶部 2、底部" @默认值 = 2>
    参数 左侧图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 图标大小 <类型 = 整数 注释 = "左侧图标大小" @默认值 = 28>
    参数 左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 15>
    参数 右图标右侧间隔 <类型 = 整数 注释 = "右侧图标距离右侧边界距离" @默认值 = 12>
    参数 图标标题间隔 <类型 = 整数 注释 = "左侧图标与子夹标题间隔" @默认值 = 5>
    参数 图标隐藏方式 <类型 = 整数 注释 = "设置子夹上的图标及右侧关闭按钮  0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏" @默认值 = 0>
    参数 默认显示关闭 <类型 = 逻辑型 注释 = "子夹右侧关闭按钮" @默认值 = 假>
    参数 显示子夹间隔 <类型 = 逻辑型 注释 = "显示子夹间间隔条" @默认值 = 真>
    参数 子夹间隔颜色 <类型 = 整数 注释 = "子夹间间隔条颜色" @默认值 = 颜色类.浅灰色>
    参数 启用自定义指针 <类型 = 逻辑型 注释 = "启用内置定义的鼠标指针" @默认值 = 真>
    参数 正常指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 关闭指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 调节按钮指针 <类型 = 鼠标指针资源 注释 = "默认为内置指针" @默认值 = 空资源.空鼠标指针>
    参数 头部位置 <类型 = 整数 注释 = "1、顶部 2、底部" @默认值 = 1>
    参数 子夹头区范围间隔色 <类型 = 整数 注释 = "设置子夹头区上下间隔横线颜色" @默认值 = 颜色类.浅灰色>
    参数 隐藏范围间隔类型 <类型 = 整数 注释 = "0、不隐藏 1、隐藏上线 2、隐藏下线 3、全部隐藏" @默认值 = 1>
    参数 子窗口跟随主窗大小 <类型 = 逻辑型 注释 = "全局性设置，如需某个不跟随，请在添加窗口时的参数里调整" @默认值 = 真>
    参数 背景图片 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 背景图显示方式 <类型 = 整数 注释 = "0、图片居左上　1、图片平铺　2、图片居中　3、缩放图片" @默认值 = 3>
    参数 子夹头是否透明 <类型 = 逻辑型 @默认值 = 假>
    {
        全局量.重置为空对象 ()
        布局组.删除所有成员 ()
        钩子.注册鼠标钩子_ (取窗口句柄 (), 假)
        全局量.已启动 = 假
        窗口组.删除所有成员 ()
        标签_间隔条1.背景颜色 = 子夹头区范围间隔色
        标签_间隔条2.背景颜色 = 子夹头区范围间隔色
        组件布局器_窗体区.底色 = 窗体区背景颜色
        全局量.子夹头区范围间隔色 = 子夹头区范围间隔色
        全局量.子夹头高度 = 子夹头高度
        全局量.子夹头记忆高度 = 子夹头高度
        导航.高度 = 子夹头高度
        如果真 (子夹头高度 < 1)
        {
            标签_间隔条1.高度 = 1
            标签_间隔条2.高度 = 1
            全局量.子夹头记忆高度 = 32
            标签_间隔条1.可视 = 假
            标签_间隔条2.可视 = 假
        }
        全局量.头部位置 = 头部位置
        全局量.标题间隔符 = 标题间隔符
        全局量.主窗标题 = 窗口_取窗口组件标题 (取父窗口句柄 ())
        全局量.子窗口跟随主窗大小 = 子窗口跟随主窗大小
        全局量.隐藏范围间隔类型 = 隐藏范围间隔类型
        全局量.子夹热点背景颜色 = 子夹热点背景颜色
        如果真 (背景图片 != 空资源.空位图)
        {
            置背景图_窗体_位图 (背景图片, 背景图显示方式)
        }
        导航.初始化选择夹_ (字体名称, 字体大小, 是否加粗, 标题对齐方式, 正常标题颜色, 热点标题颜色, 子夹正常背景颜色, 子夹热点背景颜色, 左侧图标, 图标大小, 左图标左侧间隔, 右图标右侧间隔, 图标标题间隔, 图标隐藏方式, 隐藏下划线, 下划线正常颜色, 下划线热点颜色, 下划线位置, 默认显示关闭, 显示子夹间隔, 子夹间隔颜色, 子夹头是否透明, 启用自定义指针, 正常指针, 关闭指针, 调节按钮指针)
        公用尺寸变化 ()
    }

    方法 解除窗口_ <公开 类型 = 逻辑型 注释 = "将窗口独立出来显示，如需合并，请执行“合并窗口_”命令" 折叠>
    参数 窗口 <类型 = 窗口>
    参数 边框类型 <类型 = 窗口边框类型 @默认值 = 窗口边框类型.普通可调边框>
    {
        变量 子夹索引 <类型 = 整数>
        变量 结果 <类型 = 逻辑型>
        如果真 (全局量.全局锁定界面)
        {
            返回 (假)
        }
        如果真 (窗口_窗口是否存在 (窗口.取窗口句柄 ()))
        {
            互斥.加锁 ()
            子夹索引 = 取窗口索引_ (窗口.取窗口句柄 ())
            窗口.位置 = 窗口位置类型.通常
            窗口_嵌入窗口4 (0, 窗口.取窗口句柄 (), , , , , )
            窗口.窗口边框 = 边框类型
            全局量.是否解除 = 真
            处理事件_ ()
            结果 = 导航.删除子夹_ (子夹索引)
            互斥.解锁 ()
            如果真 (结果)
            {
                公用删除窗口 (子夹索引, 假)
            }
            组件布局器_窗体区.重画 ()
            窗口组.枚举循环 ()
            {
                窗口_显示隐藏窗口组件 (窗口组.取枚举值 ().窗口句柄, 窗口显示命令常量.SW_HIDE)
                窗口_显示隐藏窗口组件 (窗口组.取枚举值 ().窗口句柄, 窗口显示命令常量.SW_SHOWNORMAL)
            }
            全局量.是否解除 = 假
            处理事件_ ()
            返回 (真)
        }
        返回 (假)
    }

    方法 合并窗口_ <公开 类型 = 整数 注释 = "将窗口从独立显示状态合并入选择夹，如需独立，请执行“解除窗口_”命令" 返回值注释 = "返回子夹索引" 折叠>
    参数 窗口 <类型 = 窗口>
    参数 子夹标题 <类型 = 文本型 注释 = "默认为窗口标题" @默认值 = "">
    参数 子夹图标 <类型 = 位图资源 注释 = "默认为内置图标" @默认值 = 空资源.空位图>
    参数 子夹标记 <类型 = 文本型 注释 = "定义一个标记值" @默认值 = "">
    参数 提示信息 <类型 = 文本型 注释 = "定义一个鼠标停留时的提示" @默认值 = "">
    参数 是否显示边框 <类型 = 逻辑型 注释 = "是否显示窗口边框" @默认值 = 假>
    参数 是否可滚动 <类型 = 逻辑型 注释 = "当窗口中内容过多，超出选择夹有效显示范围，以滚动条方式拖动显示" @默认值 = 真>
    参数 是否跟随主窗大小 <类型 = 逻辑型 注释 = "当主窗口大小发现改变时，本窗口是否跟随变动" @默认值 = 真>
    参数 子夹宽度补充 <类型 = 整数 注释 = "额外加宽子夹宽度" @默认值 = 10>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        变量 返回的索引 <类型 = 整数类>
        变量 索引 <类型 = 整数>
        变量 左位 <类型 = 整数类>
        变量 顶位 <类型 = 整数类>
        如果真 (全局量.全局锁定界面)
        {
            返回 (-1)
        }
        标签_隐藏条.可视 = 假
        如果真 (窗口是否已存在 (窗口.取窗口句柄 (), 返回的索引))
        {
            重定位遮挡 (返回的索引.值)
            返回 (-1)
        }
        如果真 (窗口_窗口是否存在 (窗口.取窗口句柄 ()))
        {
            互斥.加锁 ()
            导航.置重画_ (真)
            窗口.位置 = 窗口位置类型.通常
            如果真 (全局量.是否层叠)
            {
                取层叠坐标 (左位, 顶位)
            }
            窗口_嵌入窗口4 (组件布局器_窗体区.取窗口句柄 (), 窗口.取窗口句柄 (), 左位.值, 顶位.值, 组件布局器_窗体区.宽度, 组件布局器_窗体区.高度, 是否显示边框)
            全局量.当前焦点句柄 = 窗口.取窗口句柄 ()
            窗口.调整层次 (组件层次.顶层)
            如果 (子夹标题 == "")
            {
                子夹标题 = 窗口_取窗口组件标题 (窗口.取窗口句柄 ())
            }
            索引 = 导航.添加子夹_ (子夹标题, 子夹图标, 子夹标记, 提示信息, 子夹宽度补充)
            夹信息.窗口句柄 = 窗口.取窗口句柄 ()
            夹信息.窗口名称 = 子夹标题
            夹信息.子夹标记 = 子夹标记
            夹信息.子夹索引 = 索引
            夹信息.是否窗口 = 真
            夹信息.是否跟随大小 = 是否跟随主窗大小
            窗口组.加入成员 (夹信息)
            如果 (是否显示边框)
            {
                窗口.窗口边框 = 窗口边框类型.普通可调边框
            }
            否则
            {
                窗口.窗口边框 = 窗口边框类型.无边框
            }
            如果 (全局量.已启动 == 假)
            {
                全局量.已启动 = 真
                线程.投递任务_ ()
            }
            导航.跳转子夹_ (索引)
            如果真 (全局量.标题间隔符 != "")
            {
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
            }
            窗口_置窗口组件焦点2 (窗口.取窗口句柄 ())
            重定位遮挡 (索引)
            导航.置重画_ (假)
            处理事件_ ()
            互斥.解锁 ()
            返回 (索引)
        }
        返回 (-1)
    }

    方法 并列窗口_ <公开 类型 = 逻辑型 注释 = "将两个窗口设置为横向或纵向同时显示" 折叠>
    参数 子夹索引1 <类型 = 整数 注释 = "从0开始">
    参数 子夹索引2 <类型 = 整数 注释 = "从0开始">
    参数 是否横向 <类型 = 逻辑型 注释 = "真：横向 假：纵向" @默认值 = 真>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        变量 临时高 <类型 = 整数>
        如果真 (全局量.全局锁定界面)
        {
            返回 (假)
        }
        如果真 (子夹索引1 < 0 || 子夹索引1 < 0)
        {
            返回 (假)
        }
        如果真 (子夹索引1 > 窗口组.取成员数 () - 1 || 子夹索引2 > 窗口组.取成员数 () - 1)
        {
            返回 (假)
        }
        窗口组.枚举循环 ()
        {
            夹信息 = 窗口组.取枚举值 ()
            夹信息.是否并列 = 假
            窗口组.置成员值 (高级选择夹信息组.取枚举索引 (), 夹信息)
        }
        夹信息 = 窗口组.取成员 (子夹索引1)
        夹信息.是否并列 = 真
        窗口组.置成员值 (子夹索引1, 夹信息)
        夹信息 = 窗口组.取成员 (子夹索引2)
        夹信息.是否并列 = 真
        窗口组.置成员值 (子夹索引2, 夹信息)
        全局量.是否横向 = 是否横向
        全局量.子夹索引1 = 子夹索引1
        全局量.子夹索引2 = 子夹索引2
        如果 (全局量.子夹头记忆高度 < 1)
        {
            临时高 = 0
        }
        否则
        {
            临时高 = 全局量.子夹头高度
        }
        如果 (是否横向)
        {
            窗口_置窗口组件位置大小_MFC (窗口组.取成员 (子夹索引1).窗口句柄, 0, 0, 取用户区宽度 (), (取用户区高度 () - 临时高) / 2)
            窗口_置窗口组件位置大小_MFC (窗口组.取成员 (子夹索引2).窗口句柄, 0, (取用户区高度 () - 临时高) / 2, 取用户区宽度 (), (取用户区高度 () - 临时高) / 2)
        }
        否则
        {
            窗口_置窗口组件位置大小_MFC (窗口组.取成员 (子夹索引1).窗口句柄, 0, 0, 取用户区宽度 () / 2, 取用户区高度 () - 临时高)
            窗口_置窗口组件位置大小_MFC (窗口组.取成员 (子夹索引2).窗口句柄, 取用户区宽度 () / 2, 0, 取用户区宽度 () / 2, 取用户区高度 () - 临时高)
        }
        全局量.当前焦点句柄 = 窗口组.取成员 (子夹索引2).窗口句柄
        调整层次_ (窗口组.取成员 (子夹索引1).窗口句柄)
        调整层次_ (窗口组.取成员 (子夹索引2).窗口句柄)
        处理事件_ ()
        返回 (真)
    }

    方法 层叠窗口_ <公开 注释 = "将所有窗口层叠显示，每个窗口顶边相差30，左边相差15" 折叠>
    {
        变量 句柄 <类型 = 变整数>
        变量 i <类型 = 整数>
        如果真 (全局量.全局锁定界面)
        {
            返回
        }
        窗口组.枚举循环 ()
        {
            i = 高级选择夹信息组.取枚举索引 ()
            句柄 = 窗口组.取枚举值 ().窗口句柄
            调整层次_ (句柄, )
            窗口_置窗口组件位置大小_MFC (句柄, 15 * (i + 1 - 1), 30 * (i + 1 - 1))
            全局量.当前焦点句柄 = 句柄
        }
    }

    方法 取消并列窗口_ <公开 折叠>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
