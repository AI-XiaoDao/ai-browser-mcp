类 头像框_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"自定义组件库.头像框\"" @视窗.布局 = "client_size = \"120, 120\"" 可停留焦点 = 真>
{
    变量 范围内 <类型 = 逻辑型>
    变量 变量类 <类型 = 头像变量类>
    变量 令牌 <类型 = 变整数>
    变量 出入 <类型 = 组件移入移出事件类2_>

    方法 类_初始化 <折叠>
    {
        令牌 = GP初始类.初始化 ()
    }

    方法 类_清理 <折叠>
    {
        GP初始类.卸载 (令牌)
    }

    方法 背景色 <公开 属性读 类型 = 整数 折叠>
    {
        返回 (变量类.背景色)
    }

    方法 背景色 <公开 属性写 注释 = "当按钮有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" 折叠 @视窗.设置时机 = 组件创建前>
    参数 背景色 <类型 = 整数 注释 = "默认：颜色类.银白色" @默认值 = -1>
    {
        如果真 (背景色 != -1)
        {
            变量类.背景色 = 背景色
            底色 = 背景色
        }
    }

    方法 正常边框颜色 <公开 属性读 类型 = 整数 折叠>
    {
        返回 (变量类.正常边框颜色)
    }

    方法 正常边框颜色 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 边框颜色 <类型 = 整数>
    {
        变量类.正常边框颜色 = 边框颜色
    }

    方法 热点边框颜色 <公开 属性读 类型 = 整数 折叠>
    {
        返回 (变量类.热点边框颜色)
    }

    方法 热点边框颜色 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 边框颜色 <类型 = 整数>
    {
        变量类.热点边框颜色 = 边框颜色
    }

    方法 按下边框颜色 <公开 属性读 类型 = 整数 折叠>
    {
        返回 (变量类.按下边框颜色)
    }

    方法 按下边框颜色 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 边框颜色 <类型 = 整数>
    {
        变量类.按下边框颜色 = 边框颜色
    }

    方法 按下头像亮度 <公开 属性读 类型 = 小数 折叠>
    {
        返回 (变量类.按下头像亮度)
    }

    方法 按下头像亮度 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 头像亮度 <类型 = 小数 注释 = "-1 到 1 之间">
    {
        变量类.按下头像亮度 = 头像亮度
    }

    方法 组件提示信息 <公开 属性写 注释 = "设置当鼠标移动到本组件上时所显示的提示文本信息" 折叠>
    参数 提示文本内容 <类型 = 文本型 注释 = "提供具体的提示文本内容,为空文本清除已有提示文本.">
    {
        本对象.提示信息 = 提示文本内容
    }

    方法 创建头像框 <公开 注释 = "可重复调用本命令生成" 折叠>
    参数 图片数据 <类型 = 字节集类 注释 = "本参数与下一个参数，只需要提供一个数据即可" @默认值 = 空对象>
    参数 图片来源 <类型 = 文本型 注释 = "本参数与上一个参数，只需要提供一个数据即可" @默认值 = "">
    参数 背景色 <类型 = 整数 注释 = "默认：颜色类.银白色　。当按钮有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" @默认值 = -1>
    参数 正常边框颜色 <类型 = 整数 @默认值 = 颜色类.深灰色>
    参数 热点边框颜色 <类型 = 整数 @默认值 = 0xFE4D4D>
    参数 按下边框颜色 <类型 = 整数 @默认值 = 0xFE4D4D>
    参数 按下头像亮度 <类型 = 小数 注释 = "-1 到 1 之间" @默认值 = 0.2>
    {
        变量类.图片数据 = 图片数据
        变量类.图片来源 = 图片来源
        变量类.按下头像亮度 = 按下头像亮度
        变量类.正常边框颜色 = 正常边框颜色
        变量类.热点边框颜色 = 热点边框颜色
        变量类.按下边框颜色 = 按下边框颜色
        背景色 = 背景色
        置底图数据 (绘制头像 (变量类.图片数据, 变量类.图片来源, 变量类.正常边框颜色))
    }

    方法 修改边框色 <公开 注释 = "默认－1则不会改变原设置" 折叠>
    参数 正常边框颜色 <类型 = 整数 注释 = "默认：颜色类.深灰色" @默认值 = -1>
    参数 热点边框颜色 <类型 = 整数 注释 = "默认：0xFE4D4D" @默认值 = -1>
    参数 按下边框颜色 <类型 = 整数 注释 = "默认：0xFE4D4D" @默认值 = -1>
    参数 按下头像亮度 <类型 = 小数 注释 = "-1 到 1 之间" @默认值 = 0.2>
    {
        如果真 (正常边框颜色 != -1)
        {
            变量类.正常边框颜色 = 正常边框颜色
        }
        如果真 (热点边框颜色 != -1)
        {
            变量类.热点边框颜色 = 热点边框颜色
        }
        如果真 (按下边框颜色 != -1)
        {
            变量类.按下边框颜色 = 按下边框颜色
        }
        变量类.按下头像亮度 = 按下头像亮度
        置底图数据 (绘制头像 (变量类.图片数据, 变量类.图片来源, 变量类.正常边框颜色))
    }

