        处理事件_ ()
        添加中 = 假
        互斥.解锁 ()
        子夹被改变事件 (临时索引, 索引)
        返回 (索引)
    }

    方法 添加子夹_路径DLL <公开 类型 = 整数 注释 = "本方法使用动态式加载路径DLL窗口，对接要求如下：;" 注释 = "DLL部份:用以下方式创建并返回句柄;"
            注释 = "取程序 ().窗口1.创建子窗口 (取程序 ().窗口1);" 注释 = "返回 (取程序 ().窗口1.取窗口句柄 ());" 返回值注释 = "返回子夹索引" 折叠 折叠2>
    参数 DLL文件路径 <类型 = 文本型>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    参数 DLL参数数量 <类型 = 整数 注释 = "0、无参数 1、一个参数 2、两个参数" @默认值 = 0>
    参数 附加参数1 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第一个参数接收此指针" @默认值 = 0>
    参数 附加参数2 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第二个参数接收此指针" @默认值 = 0>
    参数 子夹标题 <类型 = 文本型 注释 = "默认为窗口标题" @默认值 = "">
    参数 子夹图标 <类型 = 位图资源 注释 = "默认为内置图标" @默认值 = 空资源.空位图>
    参数 子夹标记 <类型 = 文本型 注释 = "定义一个标记值" @默认值 = "">
    参数 提示信息 <类型 = 文本型 注释 = "定义一个鼠标停留时的提示" @默认值 = "">
    参数 是否显示边框 <类型 = 逻辑型 注释 = "是否显示窗口边框" @默认值 = 假>
    参数 是否可滚动 <类型 = 逻辑型 注释 = "当窗口中内容过多，超出选择夹有效显示范围，以滚动条方式拖动显示" @默认值 = 假>
    参数 是否跟随主窗大小 <类型 = 逻辑型 注释 = "当主窗口大小发现改变时，本窗口是否跟随变动" @默认值 = 真>
    参数 子夹宽度补充 <类型 = 整数 注释 = "额外加宽子夹宽度" @默认值 = 10>
    {
        变量 DLL句柄 <类型 = 变整数类>
        变量 DLL窗口句柄 <类型 = 变整数类>
        变量 返回的索引 <类型 = 整数类>
        变量 临时索引 <类型 = 整数>
        变量 索引 <类型 = 整数>
        如果真 (添加中)
        {
            调试输出 ("当前还有窗口正在添加中")
            返回 (-1)
        }
        添加中 = 真
        互斥.加锁 ()
        添加中 = 真
        临时索引 = 导航.取活动子夹索引_ ()
        导航.置重画_ (真)
        标签_隐藏条.可视 = 假
        动态DLL.动态加载窗口2_ (DLL文件路径, DLL函数输出名, DLL参数数量, 附加参数1, 附加参数2, DLL句柄, DLL窗口句柄)
        全局量.当前焦点句柄 = DLL窗口句柄.值
        如果真 (窗口是否已存在 (DLL窗口句柄.值, 返回的索引))
        {
            如果真 (返回的索引.值 == -1)
            {
                返回的索引.值 = 0
            }
            调整层次_ (DLL窗口句柄.值)
            导航.跳转子夹_ (返回的索引.值, 真)
            如果 (子夹标题 == "")
            {
                子夹标题 = 窗口_取窗口组件标题 (DLL窗口句柄.值)
            }
            如果真 (全局量.标题间隔符 != "")
            {
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
            }
            重定位遮挡 (返回的索引.值)
            导航.置重画_ (假)
            处理事件_ ()
            添加中 = 假
            互斥.解锁 ()
            返回 (-1)
        }
        全局量.动态句柄 = DLL句柄.值
        互斥.解锁 ()
        添加中 = 假
        索引 = 添加子夹_DLL (DLL窗口句柄.值, 子夹标题, 子夹图标, 子夹标记, 提示信息, 是否显示边框, 是否跟随主窗大小, 子夹宽度补充)
        重定位遮挡 (索引)
        处理事件_ ()
        子夹被改变事件 (临时索引, 索引)
        返回 (索引)
    }

