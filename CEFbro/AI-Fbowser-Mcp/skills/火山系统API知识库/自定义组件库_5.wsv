    方法 初始处理 <折叠>
    {
        显示画板.销毁 ()
        绘制画板.销毁 ()
        后台图像.销毁 ()
    }

    方法 选择框类__组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 选择框类_>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        出入.监视组件_ (本对象, 消息值)
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        分支判断 (消息值)
        {
            分支 (20)  // WM_ERASEBKGND
            {
                @ SetBkMode((HDC)@<消息参数1>,1);
                返回 (1)
            }
            分支 (15)  // WM_PAINT
            {
                绘制选择框 ()
                变量 ret <类型 = 整数>
                @ LRESULT dwp=DefWindowProc((HWND)@<窗口句柄>,@<消息值>,(WPARAM)@<消息参数1>,(LPARAM)@<消息参数2>);
                @ @<ret>=(int)dwp;
                返回 (ret)
            }
        }
        返回 (0)
    }

    方法 刷新设置 <折叠>
    {
        变量 rect <类型 = 矩形类>
        程_窗口句柄 = 取窗口句柄 ()
        @ RECT rec;
        @ GetClientRect((HWND)@<程_窗口句柄>,&rec);
        @ @<rect.设置>(rec.left,rec.top,rec.right,rec.bottom);
        程_父窗口宽 = rect.宽度
        程_父窗口高 = rect.高度
        显示画板.销毁 ()
        显示画板.创建 (程_父窗口宽, 程_父窗口高, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        绘制画板.销毁 ()
        后台图像.销毁 ()
        后台图像.创建自像素格式 (程_父窗口宽, 程_父窗口高, )
        绘制画板.创建自图像 (后台图像)
        按钮区范围.左边 = 0
        按钮区范围.顶边 = 0
        按钮区范围.宽度 = 程_父窗口宽
        按钮区范围.高度 = 程_父窗口高
        变量类.宽度 = 按钮区范围.宽度
        变量类.高度 = 按钮区范围.高度
    }

    方法 选择框类__将被销毁 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 选择框类_>
    参数 标记值 <类型 = 整数>
    {
        初始处理 ()
        程_窗口句柄 = 0
        GP初始类.卸载 (令牌)
        返回 (0)
    }

    方法 选择框类__尺寸被改变 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 选择框类_>
    参数 标记值 <类型 = 整数>
    {
        刷新设置 ()
        返回 (0)
    }

    方法 绘制选择框 <折叠>
    参数 按钮区 <类型 = 逻辑型 注释 = "鼠标离开按钮区范围恢复原色" @默认值 = 假>
    参数 左键单击 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 位图 <类型 = GP位图类>
        变量 左上角 <类型 = 坐标F>
        变量 左下角 <类型 = 坐标F>
        变量 相对父窗口 <类型 = 矩形类>
        变量 渐变画刷 <类型 = GP线性渐变画刷类>
        变量 路径 <类型 = GP路径类>
        变量 画笔 <类型 = GP画笔类>
        变量 画刷 <类型 = GP纯色画刷类>
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        左上角.X = 按钮区范围.左边
        左上角.Y = 按钮区范围.顶边
        左下角.X = 按钮区范围.左边
        左下角.Y = 按钮区范围.顶边 + 按钮区范围.高度
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置文本渲染模式 (GP文本渲染模式.抗锯齿和hinting技术)
        如果真 (变量类.是否选中)
        {
            变量类.是否选中 = 假
            变量类.已打开 = 真
        }
        如果 (左键单击)
        {
            变量类.已打开 = 取反 (变量类.已打开)
        }
        // 绘制框体
        画刷.创建 (GP颜色.到ARGB (颜色类.白色))
        路径.创建 ()
        如果 (变量类.样式 == 1)
        {
            路径.添加圆角矩形 (1.5, 1.5, 变量类.高度 - 8, 变量类.高度 - 8, 变量类.圆角度数, 变量类.圆角度数)
        }
        否则
        {
            路径.添加椭圆 (1.5, 1.5, 变量类.高度 - 8, 变量类.高度 - 8)
        }
        绘制画板.填充路径 (画刷, 路径)

        // 外框
        画笔.创建自颜色 (GP颜色.到ARGB (变量类.外框色, 变量类.外框透明度), 2)
        绘制画板.画路径 (画笔, 路径)
        路径.创建 ()
        如果 (变量类.样式 == 1)
        {
            路径.添加圆角矩形 (1.5, 1.5, 变量类.高度 - 8, 变量类.高度 - 8, 变量类.圆角度数, 变量类.圆角度数)
        }
        否则
        {
            路径.添加椭圆 (1.5, 1.5, 变量类.高度 - 8, 变量类.高度 - 8)
        }
        绘制画板.画路径 (画笔, 路径)

        // 绘制内框
        变量 内大小 <类型 = 小数>
        路径.创建 ()
        如果 (按钮区 == 真)
        {
            如果 (变量类.已打开)
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点内框起点色, 变量类.热点内框起点透明度), GP颜色.到ARGB (变量类.热点内框终点色, 变量类.热点内框终点透明度))
            }
            否则
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (颜色类.浅灰色, 255), GP颜色.到ARGB (颜色类.白色, 200))
            }
        }
        否则
        {
            如果 (变量类.已打开)
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常内框起点色, 变量类.正常内框起点透明度), GP颜色.到ARGB (变量类.正常内框终点色, 变量类.正常内框终点透明度))
            }
            否则
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (颜色类.白色, 255), GP颜色.到ARGB (颜色类.白色, 255))
            }
        }
        内大小 = 变量类.高度 - 8 - 1.5 - 1.5 - 4
        如果 (变量类.已打开)
        {
            变量类.选择框状态 = 假
        }
        否则
        {
            变量类.选择框状态 = 真
        }
        如果 (变量类.样式 == 1)
        {
            路径.添加圆角矩形 (5, 5, 内大小, 内大小, 变量类.圆角度数, 变量类.圆角度数)
        }
        否则
        {
            路径.添加椭圆 (5, 5, 内大小, 内大小)
        }
        如果真 (变量类.禁止取消 && 变量类.选择框状态 && 左键单击 && 变量类.样式 == 2)
        {
            变量类.选择框状态 = 真
            变量类.已打开 = 真
            渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常内框起点色, 变量类.正常内框起点透明度), GP颜色.到ARGB (变量类.正常内框终点色, 变量类.正常内框终点透明度))

        }
        绘制画板.填充路径 (渐变画刷, 路径)

        // 画标题
        变量 测量矩形 <类型 = 矩形F>
        变量 字体类 <类型 = GP字体类>
        变量 文本格式 <类型 = GP文本格式类>
        画刷.创建 (GP颜色.到ARGB (变量类.标题颜色))
        如果 (变量类.字体加粗 == 真 && 变量类.字体斜体 == 真)
        {
            字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗倾斜)
        }
        否则 (变量类.字体加粗 == 真)
        {
            字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗)
        }
        否则 (变量类.字体斜体 == 真)
        {
            字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.倾斜)
        }
        否则
        {
            字体类.创建自名称 (变量类.字体名称, 变量类.字体大小)
        }
        绘制画板.测量文本矩形 (变量类.标题名, 字体类, 空对象, , 测量矩形)
        测量矩形.左边 = 变量类.高度 - 8 - 1.5 + 5
        测量矩形.顶边 = (变量类.高度 - 1.5 - 测量矩形.高度) / 2 + 变量类.校正值
        文本格式.创建格式 (GP文本格式标志.显示格式控制符)
        绘制画板.画文本 (变量类.标题名, 字体类, 画刷, 测量矩形, 文本格式)
        绘制画板.重置剪辑区 ()
        显示画板.画图像 (后台图像)
        变量 设备场景 <类型 = 变整数>
        @ HWND hwnd=(HWND)@<程_窗口句柄>;
        @ HDC hdc=GetDC(hwnd);
        @ @<设备场景>=(INT_P)hdc;
        显示画板.复制 (设备场景, , )
        @ ReleaseDC(hwnd, hdc);
        位图.销毁 ()
        渐变画刷.销毁 ()
        路径.销毁 ()
        画笔.销毁 ()
        画刷.销毁 ()
        字体类.销毁 ()
        文本格式.销毁 ()
    }

    方法 刷新选择框 <公开 注释 = "设置后调用此命令，立即刷新生效" 折叠>
    {
        刷新设置 ()
        @ InvalidateRect((HWND)@<程_窗口句柄>,0,0);
    }

    方法 组件移入移出事件类2__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类2_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    参数 是否悬停 <类型 = 逻辑型 注释 = "鼠标是否停留在组件上，到达设置的时间时触发为真">
    {
        如果真 (是否悬停 == 假)
        {
            如果真 (是否移入 == 假)
            {
                鼠标被按下 = 假
            }
            绘制选择框 (是否移入, 鼠标被按下)
            选择框移入移出事件 (是否移入)
        }
        返回 (0)
    }

