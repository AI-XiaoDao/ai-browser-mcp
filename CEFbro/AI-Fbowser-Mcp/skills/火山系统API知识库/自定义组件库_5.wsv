类 高级纵向滚动条 <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1, 2" @文档 = "category = \"自定义组件库.高级纵向滚动条\"" @视窗.布局 = "client_size = \"26, 200\""
