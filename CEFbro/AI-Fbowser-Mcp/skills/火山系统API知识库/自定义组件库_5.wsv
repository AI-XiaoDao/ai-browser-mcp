    变量 图标组2 <类型 = 卷帘图标组>
    变量 标签_右图2 <类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\nparent_id = 101\r\npos = \"144, 16, 24, 24\"" 可视 = 假
            背景颜色 = 0x3D241F>
