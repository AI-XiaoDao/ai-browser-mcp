    方法 置标题颜色_ <公开 折叠>
    参数 父标题颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 父标题触发颜色 <类型 = 整数 注释 = "鼠标经过" @默认值 = 0xFF9933>
    参数 父标题热点颜色 <类型 = 整数 注释 = "选中后" @默认值 = 颜色类.黑色>
    参数 子标题颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 子标题触发颜色 <类型 = 整数 注释 = "鼠标经过" @默认值 = 0xFF9933>
    参数 子标题热点颜色 <类型 = 整数 注释 = "选中后" @默认值 = 颜色类.黑色>
    {
        全局量.父标题颜色 = 父标题颜色
        全局量.父标题触发颜色 = 父标题触发颜色
        全局量.父标题热点颜色 = 父标题热点颜色
        全局量.子标题颜色 = 子标题颜色
        全局量.子标题触发颜色 = 子标题触发颜色
        全局量.子标题热点颜色 = 子标题热点颜色
        卷帘布局组.枚举循环 ()
        {
            ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.文本颜色 = 父标题颜色
        }
        卷帘布局组2.枚举循环 ()
        {
            ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.文本颜色 = 子标题颜色
        }
    }

    方法 置标题字体_ <公开 折叠>
    参数 父项字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 父项字体大小 <类型 = 整数 @默认值 = 11>
    参数 子项字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 子项字体大小 <类型 = 整数 @默认值 = 11>
    {
        全局量.父项字体名称 = 父项字体名称
        全局量.父项字体大小 = 父项字体大小
        全局量.子项字体名称 = 子项字体名称
        全局量.子项字体大小 = 子项字体大小
        卷帘布局组.枚举循环 ()
        {
            ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.字体 = 父项字体名称 + "," + 到文本 (父项字体大小)
        }
        卷帘布局组2.枚举循环 ()
        {
            ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.字体 = 子项字体名称 + "," + 到文本 (子项字体大小)
        }
    }

    方法 置标题对齐方式_ <公开 折叠>
    参数 父项标题对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　2、右对齐" @默认值 = 0>
    参数 子项标题对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　2、右对齐" @默认值 = 0>
    {
        全局量.父项标题对齐方式 = 父项标题对齐方式
        全局量.子项标题对齐方式 = 子项标题对齐方式
        卷帘布局组.枚举循环 ()
        {
            如果 (父项标题对齐方式 == 0)
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.左边
            }
            否则 (父项标题对齐方式 == 1)
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.居中
            }
            否则 (父项标题对齐方式 == 2)
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.右边
            }
        }
        卷帘布局组2.枚举循环 ()
        {
            如果 (子项标题对齐方式 == 0)
            {
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.左边
            }
            否则 (子项标题对齐方式 == 1)
            {
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.居中
            }
            否则 (子项标题对齐方式 == 2)
            {
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.横向对齐方式 = 横向对齐模式.右边
            }
        }
    }

    方法 置选项背景颜色_ <公开 折叠>
    参数 父项正常背景颜色 <类型 = 整数 @默认值 = 0x3D241F>
    参数 父项热点背景颜色 <类型 = 整数 @默认值 = 0xFDA735>
    参数 子项正常背景颜色 <类型 = 整数 @默认值 = 0x3D241F>
    参数 子项热点背景颜色 <类型 = 整数 @默认值 = 0xFDA735>
    参数 左侧区正常间隔颜色 <类型 = 整数 注释 = "左侧图标区背景颜色" @默认值 = 0x5D4A3D>
    {
        变量 临时子索引 <类型 = 整数>
        全局量.父项正常背景颜色 = 父项正常背景颜色
        本对象.底色 = 父项正常背景颜色
        组件布局器_列表区.底色 = 父项正常背景颜色
        组件布局器_列表区2.底色 = 父项正常背景颜色
        全局量.父项热点背景颜色 = 父项热点背景颜色
        全局量.子项正常背景颜色 = 子项正常背景颜色
        全局量.子项热点背景颜色 = 子项热点背景颜色
        全局量.左侧区正常间隔颜色 = 左侧区正常间隔颜色
        卷帘布局组.枚举循环 ()
        {
            如果 (对象数组类.取枚举索引 () == 全局量.当前父索引)
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).底色 = 全局量.父项热点背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).组件布局器_根容器.底色 = 全局量.父项热点背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.背景颜色 = 全局量.父项热点背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图.背景颜色 = 全局量.父项热点背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图2.背景颜色 = 全局量.父项热点背景颜色
                如果 (全局量.是否启用左右间隔色)
                {
                    如果 (全局量.间隔区色是否独立显示)
                    {
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.左侧区正常间隔颜色
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.左侧区正常间隔颜色
                    }
                    否则
                    {
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.父项热点背景颜色
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.父项热点背景颜色
                    }
                }
                否则
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.父项热点背景颜色
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.父项热点背景颜色
                }
            }
            否则
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).底色 = 全局量.父项正常背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).组件布局器_根容器.底色 = 全局量.父项正常背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.背景颜色 = 全局量.父项正常背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图.背景颜色 = 全局量.父项正常背景颜色
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图2.背景颜色 = 全局量.父项正常背景颜色
                如果 (全局量.是否启用左右间隔色)
                {
                    如果 (全局量.间隔区色是否独立显示)
                    {
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.左侧区正常间隔颜色
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.左侧区正常间隔颜色
                    }
                    否则
                    {
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.父项正常背景颜色
                        ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.父项正常背景颜色
                    }
                }
                否则
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 全局量.父项正常背景颜色
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 全局量.父项正常背景颜色
                }
            }
        }
        如果真 (全局量.当前父索引 > -1)
        {
            临时子索引 = 取子项真实索引 (全局量.当前父索引, 全局量.当前子索引)
        }
        卷帘布局组2.枚举循环 ()
        {
            如果 (对象数组类.取枚举索引 () == 临时子索引)
            {
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).底色 = 全局量.子项热点背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).组件布局器_根容器.底色 = 全局量.子项热点背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_左图.背景颜色 = 全局量.子项热点背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.背景颜色 = 全局量.子项热点背景颜色
            }
            否则
            {
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).底色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).组件布局器_根容器.底色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_左图.背景颜色 = 全局量.子项正常背景颜色
                ((子卷帘模板类)卷帘布局组2.取枚举值 ()).标签_标题.背景颜色 = 全局量.子项正常背景颜色
            }
        }
        卷帘布局组3.枚举循环 ()
        {
            ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).底色 = 子项正常背景颜色
        }
    }

    方法 取消选项热点色_ <公开 注释 = "父项收缩后本有热点色，通过本命令可取消热点色" 折叠>
    参数 是否取消 <类型 = 逻辑型 @默认值 = 真>
    {
        全局量.是否恢复原色 = 是否取消
    }

    方法 置父项左侧图背景色_ <公开 类型 = 逻辑型 注释 = "只修改左侧的图标区背景色，并非整个父项区" 折叠>
    参数 父项索引 <类型 = 整数 注释 = "默认-1为修改当前选择项，-2为修改所有不一致的父项，否则为修改指定项" @默认值 = -1>
    参数 颜色 <类型 = 整数 注释 = "默认为左侧区正常间隔颜色" @默认值 = 0x5D4A3D>
    {
        如果 (父项索引 == -1)
        {
            如果 (全局量.原父点击索引 <= 卷帘布局组.取成员数 () - 1 && 全局量.原父点击索引 > -1 && 卷帘布局组.取成员数 () > 0)
            {
                如果真 (((父卷帘模板类)卷帘布局组.取成员 (全局量.原父点击索引)).标签_左图2.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (全局量.原父点击索引)).标签_左图2.背景颜色 = 颜色
                }
                如果真 (((父卷帘模板类)卷帘布局组.取成员 (全局量.原父点击索引)).标签_左图.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (全局量.原父点击索引)).标签_左图.背景颜色 = 颜色
                }
                返回 (真)
            }
        }
        否则 (父项索引 == -2)
        {
            卷帘布局组.枚举循环 ()
            {
                如果真 (((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图2.背景颜色 = 颜色
                }
                如果真 (((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.背景颜色 = 颜色
                }
            }
            返回 (真)
        }
        否则
        {
            如果 (父项索引 <= 卷帘布局组.取成员数 () - 1 && 卷帘布局组.取成员数 () > 0)
            {
                如果真 (((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_左图2.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_左图2.背景颜色 = 颜色
                }
                如果真 (((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_左图.背景颜色 != 颜色)
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_左图.背景颜色 = 颜色
                }
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 置图标标题间隔_ <公开 折叠>
    参数 父标题左侧间隔 <类型 = 整数 注释 = "标题与左侧图标间距，默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 0>
    参数 父项左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 10>
    参数 父项右图标右侧间隔 <类型 = 整数 注释 = "右侧图标距离右侧边界距离" @默认值 = 12>
    参数 父项提醒图标右侧间隔 <类型 = 整数 注释 = "默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 3>
    参数 子标题左侧间隔 <类型 = 整数 注释 = "标题与左侧图标间距，默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 5>
    参数 子项左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 30>
    参数 子项提醒图标右侧间隔 <类型 = 整数 注释 = "默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 0>
    {
        全局量.父标题左侧间隔 = 父标题左侧间隔
        全局量.父项左图标左侧间隔 = 父项左图标左侧间隔
        全局量.父项右图标右侧间隔 = 父项右图标右侧间隔
        全局量.父项提醒图标右侧间隔 = 父项提醒图标右侧间隔
        全局量.子标题左侧间隔 = 子标题左侧间隔
        全局量.子项左图标左侧间隔 = 子项左图标左侧间隔
        全局量.子项提醒图标右侧间隔 = 子项提醒图标右侧间隔
        卷帘布局组.枚举循环 ()
        {
            ((父卷帘模板类)卷帘布局组.取枚举值 ()).排序布局 (全局量.父项高度, 父标题左侧间隔, 全局量.图标隐藏方式, 父项左图标左侧间隔, 父项右图标右侧间隔, 父项提醒图标右侧间隔, -1, "")

        }
        卷帘布局组2.枚举循环 ()
        {
            ((子卷帘模板类)卷帘布局组2.取枚举值 ()).排序布局 (全局量.子项高度, 子标题左侧间隔, 全局量.图标隐藏方式, 子项左图标左侧间隔, 子项提醒图标右侧间隔, -1, "", "", -1, "")

        }
    }

    方法 置图标隐藏方式_ <公开 折叠>
    参数 图标隐藏方式 <类型 = 整数 注释 = "0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏" @默认值 = 0>
    {
        全局量.图标隐藏方式 = 图标隐藏方式
        卷帘布局组.枚举循环 ()
        {
            ((父卷帘模板类)卷帘布局组.取枚举值 ()).排序布局 (全局量.父项高度, 全局量.父标题左侧间隔, 图标隐藏方式, 全局量.父项左图标左侧间隔, 全局量.父项右图标右侧间隔, 全局量.父项提醒图标右侧间隔, -1, "")

        }
        卷帘布局组2.枚举循环 ()
        {
            ((子卷帘模板类)卷帘布局组2.取枚举值 ()).排序布局 (全局量.子项高度, 全局量.子标题左侧间隔, 图标隐藏方式, 全局量.子项左图标左侧间隔, 全局量.子项提醒图标右侧间隔, -1, "", "", -1, "")

        }
    }

    方法 置自动隐藏父项右侧图标_ <公开 注释 = "无子夹时自动处理隐藏父项右侧图标" 折叠>
    参数 是否自动隐藏 <类型 = 逻辑型 注释 = "当设置为真时，如果该父项下无子项时则隐藏图标，否则显示" @默认值 = 真>
    {
        全局量.是否自动隐藏父右图 = 是否自动隐藏
        卷帘布局组.枚举循环 ()
        {
            如果 (全局量.子项组数 [对象数组类.取枚举索引 ()] > 0)
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图.可视 = 真
            }
            否则
            {
                ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_右图.可视 = 假
            }
        }
    }

    方法 置选项图标_ <公开 类型 = 逻辑型 注释 = "位图来源" 折叠>
    参数 父项索引 <类型 = 整数 注释 = "-1为修改所有图标" @默认值 = -1>
    参数 子项索引 <类型 = 整数 注释 = "-1为修改所有图标，如果修改指定子项，需要提供父索引" @默认值 = -1>
    参数 父项左侧图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
