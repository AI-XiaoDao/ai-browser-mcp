    方法 置子夹头区范围间隔色_ <公开 注释 = "设置子夹头区上下间隔横线" 折叠>
    参数 颜色 <类型 = 整数>
    参数 隐藏类型 <类型 = 整数 注释 = "0、不隐藏 1、隐藏上线 2、隐藏下线 3、全部隐藏" @默认值 = 0>
    {
        标签_间隔条1.背景颜色 = 颜色
        标签_间隔条2.背景颜色 = 颜色
        全局量.隐藏范围间隔类型 = 隐藏类型
        全局量.子夹头区范围间隔色 = 颜色
        如果 (隐藏类型 == 0)
        {
            标签_间隔条1.高度 = 1
            标签_间隔条2.高度 = 1
        }
        否则 (隐藏类型 == 3)
        {
            标签_间隔条1.高度 = 0
            标签_间隔条2.高度 = 0
        }
        否则 (隐藏类型 == 1)
        {
            标签_间隔条1.高度 = 0
            标签_间隔条2.高度 = 1
        }
        否则 (隐藏类型 == 2)
        {
            标签_间隔条1.高度 = 1
            标签_间隔条2.高度 = 0
        }
        公用尺寸变化 ()
    }

