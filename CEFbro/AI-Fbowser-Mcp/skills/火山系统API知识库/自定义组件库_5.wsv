    方法 清空卷帘列表_ <公开 注释 = "删除所有父项子项信息" 折叠>
    参数 是否隐藏过程 <类型 = 逻辑型 注释 = "为真时，先暂时隐藏操作过程" @默认值 = 假>
    {
        如果真 (是否隐藏过程)
        {
            组件布局器_列表区2.可视 = 假
            处理事件_ ()
        }
        是否临时锁定 = 真
        如果真 (全局量.是否整体锁定)
        {
            返回
        }
        组件布局器_列表区2.可视 = 假
        卷帘布局组.枚举循环 ()
        {
            ((父卷帘模板类)卷帘布局组.取枚举值 ()).销毁 ()
        }
        卷帘布局组2.枚举循环 ()
        {
            ((子卷帘模板类)卷帘布局组2.取枚举值 ()).销毁 ()
        }
        卷帘布局组3.枚举循环 ()
        {
            ((子卷帘承载模板类)卷帘布局组3.取枚举值 ()).销毁 ()
        }
        卷帘布局组.删除所有成员 ()
        卷帘布局组2.删除所有成员 ()
        卷帘布局组3.删除所有成员 ()
        全局量.父项提醒图标右侧间隔 = 3
        连续赋值 (-1, 全局量.原父触发索引, 全局量.原子触发索引, 全局量.原父点击索引, 全局量.原子点击索引)
        组件布局器_列表区2.可视 = 真
        组件布局器_列表区2.高度 = 本对象.高度 - 全局量.导航头高度
        是否等高 = 真
        纵向.可视 = 假
        计次循环 (100)
        {
            全局量.子项组数 [取循环索引 ()] = 0
        }
        是否临时锁定 = 假
    }

    方法 缩略显示_ <公开 折叠>
    参数 列表缩略宽度 <类型 = 整数 @默认值 = 52>
    参数 是否缩略 <类型 = 逻辑型 注释 = "真：缩略显示 假：恢复" @默认值 = 真>
    {
        如果真 (全局量.是否整体锁定)
        {
            返回
        }
        全局量.列表缩略宽度 = 列表缩略宽度
        如果 (是否缩略)
        {
            如果真 (本对象.宽度 != 列表缩略宽度)
            {
                如果真 (全局量.列表原始宽度 == 0)
                {
                    全局量.列表原始宽度 = 本对象.宽度
                }
                本对象.移动 (, , 列表缩略宽度)
                标签_右图.左边 = (列表缩略宽度 - 标签_右图.宽度) / 2
                卷帘布局组.枚举循环 ()
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).宽度 = 列表缩略宽度
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.左边 = (列表缩略宽度 - 全局量.父项高度) / 2
                }
                标签_标题.可视 = 假
                全局量.是否已缩略 = 真
            }
        }
        否则
        {
            如果真 (本对象.宽度 != 全局量.列表原始宽度)
            {
                标签_右图.左边 = 本对象.宽度 - 全局量.导航头高度 - 全局量.导航头右图右侧间隔
                卷帘布局组.枚举循环 ()
                {
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).宽度 = 全局量.列表原始宽度
                    ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_左图.左边 = 全局量.父项左图标左侧间隔
                }
                本对象.移动 (, , 全局量.列表原始宽度)
                标签_标题.可视 = 真
                全局量.是否已缩略 = 假
            }
        }
    }

