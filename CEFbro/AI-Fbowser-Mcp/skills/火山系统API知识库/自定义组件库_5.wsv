    方法 删除子项_ <公开 类型 = 逻辑型 折叠>
    参数 父项索引 <类型 = 整数 注释 = "从0开始">
    参数 子项索引 <类型 = 整数 注释 = "从0开始">
    {
        变量 真实子索引 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (全局量.是否整体锁定)
        {
            返回 (假)
        }
        真实子索引 = 取子项真实索引 (父项索引, 子项索引)
        如果真 (父项索引 > -1 && 父项索引 + 1 <= 卷帘布局组.取成员数 () && 真实子索引 > -1)
        {
            ((子卷帘模板类)卷帘布局组2.取成员 (真实子索引)).销毁 ()
            卷帘布局组2.删除成员 (真实子索引)
            全局量.子项组数 [父项索引] = 全局量.子项组数 [父项索引] - 1
            如果真 (全局量.子项组数 [父项索引] <= 0)
            {
                全局量.子项组数 [父项索引] = 0
                ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).可视 = 假
                ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).标记 = "0"
            }
            真实子索引 = 取子项真实索引 (父项索引, 0)
            循环 (, 全局量.子项组数 [父项索引], i)
            {
                如果 (全局量.是否允许前后间隔)
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (真实子索引 + i)).顶边 = 全局量.子项高度 * i + 5
                }
                否则
                {
                    ((子卷帘模板类)卷帘布局组2.取成员 (真实子索引 + i)).顶边 = 全局量.子项高度 * i
                }
                ((子卷帘模板类)卷帘布局组2.取成员 (真实子索引 + i)).当前索引 = i
            }
            如果 (全局量.是否允许前后间隔)
            {
                ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).高度 = 全局量.子项组数 [父项索引] * 全局量.子项高度 + 15
            }
            否则
            {
                ((子卷帘承载模板类)卷帘布局组3.取成员 (父项索引)).高度 = 全局量.子项组数 [父项索引] * 全局量.子项高度
            }
            父项顶边重排 ()
            重置触点索引 ()
            重置滚动条位置 ()
            如果真 (全局量.是否自动隐藏父右图)
            {
                如果 (全局量.子项组数 [父项索引] > 0)
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_右图.可视 = 真
                }
                否则
                {
                    ((父卷帘模板类)卷帘布局组.取成员 (父项索引)).标签_右图.可视 = 假
                }
            }
            返回 (真)
        }
        返回 (假)
    }

