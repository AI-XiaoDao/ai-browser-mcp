        {
            如果真 (窗口组.取枚举值 ().窗口名称 == 子夹标题)
            {
                子夹索引 = 窗口组.取枚举值 ().子夹索引
                跳出循环
            }
        }
        结果 = 导航.删除子夹_ (子夹索引)
        如果真 (结果)
        {
            如果真 (窗口组.取成员数 () == 0)
            {
                全局量.记忆序 = -1
                标签_隐藏条.可视 = 假
                全局量.当前焦点句柄 = 0
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题)
            }
        }
        导航.置重画_ (假)
        返回 (结果)
    }

    方法 删除所有子夹_ <公开 注释 = "同时关闭窗口" 折叠>
    {
        如果真 (全局量.全局锁定界面)
        {
            返回
        }
        全局量.记忆序 = -1
        标签_隐藏条.可视 = 假
        全局量.是否停止定位 = 真
        全局量.当前焦点句柄 = 0
        导航.删除所有子夹_ ()
        公用删除所有窗口 ()
        如果真 (窗口组.取成员数 () > 0)
        {
            跳转子夹_ (窗口组.取成员数 () - 1)
        }
        全局量.是否停止定位 = 假
        窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题)
    }

    方法 交换子夹_ <公开 类型 = 逻辑型 注释 = "交换两个子夹的位置，包括索引" 折叠>
