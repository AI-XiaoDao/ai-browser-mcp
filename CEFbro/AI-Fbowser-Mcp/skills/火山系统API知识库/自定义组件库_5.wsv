    方法 修改标题_ <公开 类型 = 逻辑型 注释 = "修改“写入标题_”所产生的标题" 折叠>
    参数 目标句柄 <类型 = 变整数 注释 = "“写入标题_”时所返回的句柄">
    参数 标题 <类型 = 文本型 @默认值 = "">
    参数 字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 @默认值 = 9>
    参数 标题颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 是否加粗 <类型 = 逻辑型 @默认值 = 假>
    参数 是否斜体 <类型 = 逻辑型 @默认值 = 假>
    参数 是否有下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    {
        变量 临时标签 <类型 = 标签>
        变量 结果 <类型 = 逻辑型>
        标签组.枚举循环 ()
        {
            临时标签 = (标签)标签组.取枚举值 ()
            如果真 (临时标签.取窗口句柄 () == 目标句柄)
            {
                结果 = 真
                临时标签.字体 = 字体名称 + "," + 到文本 (字体大小) + "," + 到文本 (是否加粗) + "," + 到文本 (是否斜体) + "," + 到文本 (是否有下划线)
                临时标签.标题 = 标题
                临时标签.重画标签 ()
                临时标签.文本颜色 = 标题颜色
                临时标签.顶边 = 顶边位置
                临时标签.左边 = 左边位置
                跳出循环
            }
        }
        返回 (结果)
    }

