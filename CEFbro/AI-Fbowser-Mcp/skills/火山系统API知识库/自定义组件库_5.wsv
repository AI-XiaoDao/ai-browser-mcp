    方法 子夹被改变事件 <公开 定义事件 类型 = 整数 折叠>
    参数 原子夹索引 <类型 = 整数>
    参数 现子夹索引 <类型 = 整数>

    方法 重定位遮挡 <折叠>
    参数 索引 <类型 = 整数 @默认值 = -1>
    {
        变量 宽值 <类型 = 整数类>
        变量 左值 <类型 = 整数类>
        变量 结果 <类型 = 逻辑型>
        标签_隐藏条.可视 = 假
        如果真 (窗口组.取成员数 () == 0 || 全局量.热点区状态 == 假)
        {
            返回
        }
        如果 (索引 == -1)
        {
            导航.取活动子夹坐标_ (左值, 宽值, )
        }
        否则
        {
            导航.取子夹坐标_ (索引, 左值, 宽值, )
        }
        如果 (全局量.头部位置 == 1)
        {
            标签_隐藏条.移动 (左值.值, 导航.顶边 + 导航.高度, 宽值.值, )
            如果真 (全局量.隐藏范围间隔类型 > 1)
            {
                结果 = 真
            }
        }
        否则
        {
            标签_隐藏条.移动 (左值.值, 组件布局器_窗体区.高度, 宽值.值, )
            如果真 (全局量.隐藏范围间隔类型 == 1 || 全局量.隐藏范围间隔类型 == 3)
            {
                结果 = 真
            }
        }
        标签_隐藏条.背景颜色 = 全局量.子夹热点背景颜色
        如果真 (全局量.子夹头高度 > 0 && 结果 == 假)
        {
            标签_隐藏条.可视 = 真
        }
        标签_隐藏条.调整层次 (组件层次.顶层)
    }

    方法 线程池类2__线程池事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类2_>
    参数 标记值 <类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户参数 <类型 = 长整数>
    参数 用户数据 <类型 = 变整数>
    {
        判断循环 (真)
        {
            如果真 (全局量.已启动 == 假)
            {
                跳出循环
            }
            互斥.加锁 ()
            窗口组.枚举循环 ()
            {
                如果真 (全局量.已启动 == 假)
                {
                    跳出循环
                }
                如果真 (窗口_窗口是否存在 (窗口组.取枚举值 ().窗口句柄) == 假)
                {
                    如果真 (窗口组.取枚举值 ().是否DLL && 窗口组.取枚举值 ().动态句柄 > 0)
                    {
                        动态DLL.动态释放DLL_ (窗口组.取枚举值 ().动态句柄)
                        动态DLL.动态释放DLL_ (窗口组.取枚举值 ().动态句柄)
                    }
                    子夹被关闭事件 (窗口组.取枚举值 ().窗口名称, 窗口组.取枚举值 ().子夹标记, 窗口组.取枚举值 ().子夹索引, 假)
                    如果真 (全局量.已启动 == 假)
                    {
                        跳出循环
                    }
                    主线.投递通知 (窗口组.取枚举值 ().子夹索引)
                    窗口组.删除成员 (高级选择夹信息组.取枚举索引 ())
                }
            }
            互斥.解锁 ()
            如果真 (窗口组.取成员数 () == 0)
            {
                全局量.已启动 = 假
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题)
                跳出循环
            }
            延迟2_ (5)
        }
        返回 (0)
    }

    方法 高级主线程处理器_接收到通知 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 高级主线程处理器>
    参数 标记值 <类型 = 整数>
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    参数 参数对象 <类型 = 对象包装类>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        导航.删除子夹_ ((整数)通知码)
        窗口组.枚举循环 ()
        {
            夹信息 = 窗口组.取枚举值 ()
            夹信息.子夹索引 = 高级选择夹信息组.取枚举索引 ()
            窗口组.置成员值 (夹信息.子夹索引, 夹信息)
        }
        返回 (0)
    }

    方法 导航头类__子夹位置调整事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 导航头类_>
    参数 标记值 <类型 = 整数>
    参数 方向 <类型 = 整数 注释 = "1、左　2、右">
    {
        重定位遮挡 ()
        返回 (0)
    }

    方法 钩子类__鼠标松开事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 钩子类_>
    参数 标记值 <类型 = 整数>
    参数 放开按键 <类型 = 整数 注释 = "1左键，2右键，3中建">
    {
        变量 临时句柄 <类型 = 变整数>
        变量 临时句柄2 <类型 = 变整数>
        如果 (放开按键 == 1)
        {
            临时句柄 = 取父窗口句柄_ (窗口_取鼠标处窗口句柄 ())
            临时句柄2 = 窗口_取鼠标处窗口句柄 ()
            窗口组.枚举循环 ()
            {
                如果真 (窗口组.取枚举值 ().窗口句柄 == 临时句柄 || 窗口组.取枚举值 ().窗口句柄 == 临时句柄2)
                {
                    如果真 (全局量.记忆序 != 窗口组.取枚举值 ().子夹索引)
                    {
                        全局量.记忆序 = 窗口组.取枚举值 ().子夹索引
                        跳转子夹_ (窗口组.取枚举值 ().子夹索引)
                    }
                    跳出循环
                }
            }
        }
        返回 (0)
    }

