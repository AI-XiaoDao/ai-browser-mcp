    方法 定位菜单项_ <公开 类型 = 逻辑型 注释 = "1.如果是定位父项，只需要提供父项索引、父项标记或父项项名称即可，子项信息均可为空." 注释 = "2.如果是通过索引定位子项，需要同时提供父项索引和子项索引."
            注释 = "3.如果是通过标记定位子项，只需要提供子项标记即可." 注释 = "3.如果是通过子项名称定位子项，只需要提供子项名称即可" 折叠 折叠2>
    参数 父项索引 <类型 = 整数 注释 = "从0开始" @默认值 = -1>
    参数 父项标记 <类型 = 文本型 @默认值 = "">
    参数 父项名称 <类型 = 文本型 @默认值 = "">
    参数 子项索引 <类型 = 整数 注释 = "从0开始" @默认值 = -1>
    参数 子项标记 <类型 = 文本型 @默认值 = "">
    参数 子项名称 <类型 = 文本型 @默认值 = "">
    参数 是否触发点击 <类型 = 逻辑型 注释 = "定位的同时是否触发点击项事件" @默认值 = 假>
    参数 是否可收缩 <类型 = 逻辑型 注释 = "如果未展开的执行展开，已展开的则执行收缩" @默认值 = 假>
    {
        变量 父定位索引 <类型 = 整数>
        变量 子定位索引 <类型 = 整数>
        变量 父索引 <类型 = 整数类>
        变量 结果 <类型 = 逻辑型>
        如果真 (全局量.是否整体锁定)
        {
            返回 (假)
        }
        如果真 (文本是否为空 (父项名称) == 假)
        {
            父项索引 = 取父项索引2_ (父项名称)
        }
        如果真 (文本是否为空 (子项名称) == 假)
        {
            子项索引 = 取子项索引2_ (子项名称, 父索引)
            父项索引 = 父索引.值
        }
        如果 (父项索引 > -1 && 子项索引 > -1)
        {
            如果真 (父项索引 > 卷帘布局组.取成员数 () - 1 || 子项索引 - 1 > 卷帘布局组2.取成员数 () - 1)
            {
                返回 (假)
            }
            如果 (子项索引 + 1 > 全局量.子项组数 [父项索引])
            {
                返回 (假)
            }
            否则
            {
                跳转父子项 (父项索引, 子项索引, , , , , 是否触发点击, 是否可收缩)
                返回 (真)
            }
        }
        否则 (父项索引 > -1 || 父项标记 != "")
        {
            如果 (父项索引 > -1)
            {
                如果真 (父项索引 > 卷帘布局组.取成员数 () - 1)
                {
                    返回 (假)
                }
                父定位索引 = 父项索引
                结果 = 真
            }
            否则
            {
                如果真 (父项标记 == "")
                {
                    返回 (假)
                }
                卷帘布局组.枚举循环 ()
                {
                    如果真 (((父卷帘模板类)卷帘布局组.取枚举值 ()).当前标记 == 父项标记)
                    {
                        父定位索引 = 对象数组类.取枚举索引 ()
                        结果 = 真
                        跳出循环
                    }
                }
            }
            如果真 (结果)
            {
                跳转父子项 (父定位索引, , , , , , 是否触发点击, 是否可收缩)
                返回 (真)
            }
        }
        否则 (子项标记 != "")
        {
            卷帘布局组2.枚举循环 ()
            {
                如果真 (((子卷帘模板类)卷帘布局组2.取枚举值 ()).当前标记 == 子项标记)
                {
                    父定位索引 = ((子卷帘模板类)卷帘布局组2.取枚举值 ()).当前父项索引
