        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_HIGHLIGHT_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置按下图片_字节 <公开 折叠>
