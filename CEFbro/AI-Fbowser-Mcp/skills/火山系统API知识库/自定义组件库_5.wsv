    方法 刷新调位 <折叠>
    参数 显示方式 <类型 = 整数>
    {
        如果 (显示方式 == 0)
        {
            组件布局器_窗体区.底图方式 = 图片放置方式.图片居左上
        }
        否则 (显示方式 == 1)
        {
            组件布局器_窗体区.底图方式 = 图片放置方式.图片平铺
        }
        否则 (显示方式 == 2)
        {
            组件布局器_窗体区.底图方式 = 图片放置方式.图片居中
        }
        否则 (显示方式 == 3)
        {
            组件布局器_窗体区.底图方式 = 图片放置方式.缩放图片
        }
        窗口组.枚举循环 ()
        {
            窗口_刷新窗口 (窗口组.取枚举值 ().窗口句柄)
        }
    }

