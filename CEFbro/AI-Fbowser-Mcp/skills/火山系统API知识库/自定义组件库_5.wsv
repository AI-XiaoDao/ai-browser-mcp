    方法 置锁定状态_ <公开 类型 = 逻辑型 注释 = "是否锁住选择夹，不允许操作，是否锁定窗口，不允许通过关闭按钮来关闭" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始，-1表示全部锁定或全部解锁">
    参数 是否锁定 <类型 = 逻辑型 注释 = "为真时则不允许关闭，但其它操作正常。本参数为真时，锁死才能生效" @默认值 = 真>
    参数 是否锁死 <类型 = 逻辑型 注释 = "为真时则不允许关闭及操作" @默认值 = 假>
    {
        变量 结果 <类型 = 逻辑型>
        变量 夹信息 <类型 = 高级选择夹信息类>
        结果 = 导航.置锁定状态_ (子夹索引, 是否锁定, 是否锁死)
        如果真 (结果)
        {
            如果 (子夹索引 == -1)
            {
                窗口组.枚举循环 ()
                {
                    夹信息 = 窗口组.取枚举值 ()
                    夹信息.是否锁定 = 是否锁定
                    窗口组.置成员值 (高级选择夹信息组.取枚举索引 (), 夹信息)
                    窗口_禁止关闭窗口 (窗口组.取枚举值 ().窗口句柄, 是否锁定)
                }
            }
            否则
            {
                夹信息 = 窗口组.取成员 (子夹索引)
                夹信息.是否锁定 = 是否锁定
                窗口组.置成员值 (子夹索引, 夹信息)
                窗口_禁止关闭窗口 (窗口组.取成员 (子夹索引).窗口句柄, 是否锁死)
            }
        }
        返回 (结果)
    }

