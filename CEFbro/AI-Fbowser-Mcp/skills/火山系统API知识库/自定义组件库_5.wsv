    方法 类_清理 <折叠>
    {
        是否已初始化 = 假
    }

    方法 初始化卷帘_ <公开 折叠>
    参数 导航头高度 <类型 = 整数 注释 = "当高度为0时，可隐藏头部区" @默认值 = 52>
    参数 导航头标题 <类型 = 文本型 @默认值 = "我的桌面菜单">
    参数 导航头标题颜色 <类型 = 整数 @默认值 = 0xFF9933>
    参数 导航头背景颜色 <类型 = 整数 @默认值 = 0x3D241F>
    参数 导航头字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 导航头字体大小 <类型 = 整数 @默认值 = 12>
    参数 导航头标题左侧间隔 <类型 = 整数 @默认值 = 12>
    参数 导航头右图右侧间隔 <类型 = 整数 注释 = "默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 0>
    参数 导航头右图位置 <类型 = 整数 注释 = "0、右侧 1、左侧   。当“是否启用左右间隔色”设置为真时，本参数将自动改为左侧" @默认值 = 0>
    参数 导航头右图左侧间隔 <类型 = 整数 注释 = "当“是否启用左右间隔色”为真时生效" @默认值 = 10>
    参数 父项高度 <类型 = 整数 @默认值 = 48>
    参数 父标题颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 父标题触发颜色 <类型 = 整数 注释 = "鼠标经过" @默认值 = 0xFF9933>
    参数 父标题热点颜色 <类型 = 整数 注释 = "选中后" @默认值 = 颜色类.黑色>
    参数 父项字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 父项字体大小 <类型 = 整数 @默认值 = 11>
    参数 父项标题对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　2、右对齐" @默认值 = 0>
    参数 父项正常背景颜色 <类型 = 整数 @默认值 = 0x3D241F>
    参数 父项热点背景颜色 <类型 = 整数 @默认值 = 0xFDA735>
    参数 父标题左侧间隔 <类型 = 整数 注释 = "标题与左侧图标间距，默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 0>
    参数 父项左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 10>
    参数 父项右图标右侧间隔 <类型 = 整数 注释 = "右侧图标距离右侧边界距离" @默认值 = 12>
    参数 父项提醒图标右侧间隔 <类型 = 整数 注释 = "默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 3>
    参数 子项高度 <类型 = 整数 @默认值 = 32>
    参数 子标题颜色 <类型 = 整数 @默认值 = 颜色类.白色>
    参数 子标题触发颜色 <类型 = 整数 注释 = "鼠标经过" @默认值 = 0xFF9933>
    参数 子标题热点颜色 <类型 = 整数 注释 = "选中后" @默认值 = 颜色类.黑色>
    参数 子项字体名称 <类型 = 文本型 @默认值 = "宋体">
    参数 子项字体大小 <类型 = 整数 @默认值 = 11>
    参数 子项标题对齐方式 <类型 = 整数 注释 = "0、左对齐　1、居中　2、右对齐" @默认值 = 0>
    参数 子项正常背景颜色 <类型 = 整数 @默认值 = 0x3D241F>
    参数 子项热点背景颜色 <类型 = 整数 @默认值 = 颜色类.深青色>
    参数 子标题左侧间隔 <类型 = 整数 注释 = "标题与左侧图标间距，默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 5>
    参数 子项左图标左侧间隔 <类型 = 整数 注释 = "左侧图标距离左侧边界距离" @默认值 = 30>
    参数 子项提醒图标右侧间隔 <类型 = 整数 注释 = "默认已存在图标空余区间隔，所以本参数可负数" @默认值 = 0>
    参数 是否启用左右间隔色 <类型 = 逻辑型 注释 = "左侧图标区与非左侧图标区进行区分。当设置为真时“导航头右图位置”将位于左侧" @默认值 = 假>
    参数 左侧区正常间隔颜色 <类型 = 整数 注释 = "左侧图标区背景颜色" @默认值 = 0x5D4A3D>
    参数 左侧区热点间隔颜色 <类型 = 整数 注释 = "左侧图标区背景颜色" @默认值 = 0x608C00>
    参数 间隔区色是否独立显示 <类型 = 逻辑型 注释 = "当“是否启用左右间隔色”为真时，左侧区是否独立显示或统一热点显示" @默认值 = 真>
    参数 是否允许多项展开 <类型 = 逻辑型 注释 = "每次只允许一个父项展开或不限制" @默认值 = 假>
    参数 是否允许前后间隔 <类型 = 逻辑型 注释 = "父项展开后，内部子项的头尾是否加入空间隔" @默认值 = 真>
    参数 图标隐藏方式 <类型 = 整数 注释 = "0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏" @默认值 = 0>
    参数 滚动条滑块高度 <类型 = 整数 注释 = "默认为动态计算，当设置固定值后，滑块高度将被固定" @默认值 = -1>
    参数 父项左侧图标 <类型 = 位图资源 @默认值 = 空资源.空位图>
    参数 父项正常右侧图标 <类型 = 位图资源 注释 = "展开前" @默认值 = 空资源.空位图>
    参数 父项热点右侧图标 <类型 = 位图资源 注释 = "展开后" @默认值 = 空资源.空位图>
    参数 父项横向间隔图标 <类型 = 位图资源 注释 = "父项之间的间隔" @默认值 = 空资源.空位图>
    参数 父项横向间隔颜色 <类型 = 整数 注释 = "设置了间隔色，间隔图标则会失效" @默认值 = -1>
    参数 热点提醒图标 <类型 = 位图资源 注释 = "父项子项提醒图标" @默认值 = 空资源.空位图>
