        底色 = 0x3D241F>
{
    变量 组件布局器_根容器 <公开 类型 = 组件布局器 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 144, 28\"" 底色 = 0x1F000000 标准鼠标指针 = 手型>
    变量 标签_右图 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\nparent_id = 101\r\npos = \"100, 2, 40, 24\"" 底图方式 = 图片居中 可视 = 假
            标准鼠标指针 = 手型>
    变量 标签_左图 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\nparent_id = 101\r\npos = \"12, 2, 40, 24\"" 底图方式 = 图片居中
            标准鼠标指针 = 手型>
    变量 标签_标题 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\nparent_id = 101\r\npos = \"52, 2, 40, 24\"" 底图方式 = 图片居中
            标准鼠标指针 = 手型>
    变量 移入移出 <类型 = 组件移入移出事件类_>
    变量 当前父项索引 <公开 类型 = 整数>
    变量 当前父项名称 <公开 类型 = 文本型>
    变量 当前父项标记 <公开 类型 = 文本型>
    变量 当前子标题触发颜色 <公开 类型 = 整数>
    变量 当前索引 <公开 类型 = 整数>
    变量 当前标记 <公开 类型 = 文本型>

    方法 排序布局 <公开 折叠>
    参数 子项高度 <类型 = 整数>
    参数 子标题左侧间隔 <类型 = 整数>
    参数 图标隐藏方式 <类型 = 整数 注释 = "0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏">
    参数 子项左图标左侧间隔 <类型 = 整数>
    参数 子项提醒图标右侧间隔 <类型 = 整数>
    参数 父索引 <类型 = 整数 @默认值 = -1>
    参数 父名称 <类型 = 文本型 @默认值 = "">
    参数 父标记 <类型 = 文本型 @默认值 = "">
    参数 子索引 <类型 = 整数 @默认值 = -1>
    参数 子标记 <类型 = 文本型 @默认值 = "">
    参数 越过父索引和标记 <类型 = 逻辑型 @默认值 = 假>
    {
        组件布局器_根容器.移动 (0, 0, 本对象.宽度, 子项高度)
        标签_左图.移动 (子项左图标左侧间隔, 0, 子项高度, 子项高度)
        标签_右图.移动 (0, 0, 子项高度, 子项高度)
        标签_右图.移动 (本对象.宽度 - 标签_右图.高度 - 子项提醒图标右侧间隔, 0, , )
        如果 (图标隐藏方式 == 0)
        {
            标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 子标题左侧间隔, 0, 本对象.宽度 - 标签_左图.左边 - 标签_左图.高度 * 2 - 子标题左侧间隔 - 子项提醒图标右侧间隔, 子项高度)
        }
        否则 (图标隐藏方式 == 2)
        {
            标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 子标题左侧间隔, 0, 本对象.宽度 - 标签_左图.左边 - 标签_左图.高度 - 子标题左侧间隔 - 子项提醒图标右侧间隔, 子项高度)
        }
        否则 (图标隐藏方式 == 1 || 图标隐藏方式 == 3)
        {
            标签_左图.可视 = 假
            标签_标题.移动 (子标题左侧间隔, 0, 本对象.宽度 - 子标题左侧间隔, 子项高度)
        }
        如果真 (越过父索引和标记 == 假)
        {
            当前父项索引 = 父索引
            当前父项名称 = 父名称
            当前父项标记 = 父标记
            如果真 (子索引 > -1)
            {
                当前索引 = 子索引
            }
            当前标记 = 子标记
        }
    }

    方法 组件移入移出事件类__鼠标事件 <接收事件 类型 = 整数 折叠>
