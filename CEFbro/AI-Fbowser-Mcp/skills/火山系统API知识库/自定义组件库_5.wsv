                }
                如果真 (结果)
                {
                    全局量.父锁定索引.加入成员 (父项索引)
                }
            }
            如果真 (父项索引 > -1 && 子项索引 > -1)
            {
                变量 真实子索引 <类型 = 整数>
                真实子索引 = 取子项真实索引 (父项索引, 子项索引)
                如果真 (真实子索引 > -1)
                {
                    全局量.子锁定索引.枚举循环 ()
                    {
                        如果 (全局量.子锁定索引.取枚举值 () == 真实子索引)
                        {
                            结果 = 假
                            跳出循环
                        }
                    }
                }
                如果真 (结果)
                {
                    全局量.子锁定索引.加入成员 (真实子索引)
                }
            }
        }
        否则
        {
            如果真 (父项索引 > -1 && 子项索引 == -1)
            {
                全局量.父锁定索引.枚举循环 ()
                {
                    如果 (全局量.父锁定索引.取枚举值 () == 父项索引)
                    {
                        结果2 = 全局量.父锁定索引.取枚举索引 ()
                        跳出循环
                    }
                }
                如果真 (结果2 > -1)
                {
                    全局量.父锁定索引.删除成员 (结果2)
                }
            }
            如果真 (父项索引 > -1 && 子项索引 > -1)
            {
                变量 真实子索引 <类型 = 整数>
                真实子索引 = 取子项真实索引 (父项索引, 子项索引)
                如果真 (真实子索引 > -1)
                {
                    全局量.子锁定索引.枚举循环 ()
                    {
                        如果 (全局量.子锁定索引.取枚举值 () == 真实子索引)
                        {
                            结果2 = 全局量.子锁定索引.取枚举索引 ()
                            跳出循环
                        }
                    }
                }
                如果真 (结果2 > -1)
                {
                    全局量.子锁定索引.删除成员 (结果2)
                }
            }
        }
        返回 (结果 || 结果2 > -1)
    }

