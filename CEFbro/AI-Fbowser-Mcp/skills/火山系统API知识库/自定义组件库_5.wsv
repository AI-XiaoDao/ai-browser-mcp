    方法 子夹是否存在_ <公开 类型 = 逻辑型 注释 = "判断某子夹窗口是否存在" 折叠>
    参数 窗口来源 <类型 = 窗口 注释 = "提供了此参数，参数二不需要提供" @默认值 = 空对象>
    参数 窗口标题 <类型 = 文本型 注释 = "提供了此参数，参数一不需要提供" @默认值 = "">
    {
        变量 结果 <类型 = 逻辑型>
        窗口组.枚举循环 ()
        {
            如果 (窗口标题 == "")
            {
                如果 (窗口组.取枚举值 ().窗口句柄 == 窗口来源.取窗口句柄 ())
                {
                    结果 = 真
                    跳出循环
                }
            }
            否则
            {
                如果 (窗口组.取枚举值 ().窗口名称 == 窗口标题)
                {
                    结果 = 真
                    跳出循环
                }
            }
        }
        返回 (结果)
    }

    方法 取窗口索引_ <公开 类型 = 整数 注释 = "窗口在子夹中的索引序号" 返回值注释 = "存在则返回大于-1的索引" 折叠>
