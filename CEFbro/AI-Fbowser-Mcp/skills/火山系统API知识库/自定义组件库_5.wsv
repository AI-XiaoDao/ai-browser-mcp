    方法 失去焦点事件 <公开 定义事件 类型 = 整数 注释 = "  当本组件失去输入焦点后发送此事件." 注释 = "  所谓\"输入焦点\",即当前用户按键操作所对应的目标组件. 譬如: 用户正在编辑框中输入文本,"
            注释 = "那么此编辑框就具有输入焦点,因为它将获得目前用户所进行的所有按键操作. 所谓\"获得\"或者" 注释 = "\"失去\"输入焦点,即当前用户按键操作所对应的目标对象发生转移. 譬如: 用户现在正在编辑框1"
            注释 = "中输入文本,突然使用鼠标或其它方法切换到了编辑框2上去继续输入,那么此时编辑框1就\"失去\"" 注释 = "了输入焦点,编辑框2就\"获得\"了输入焦点,因为在此以后用户所进行的所有按键操作都将被"
            注释 = "编辑框2所获得." 折叠2>

    方法 标签_鼠标左键被放开 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 标签>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 标签2 || 来源对象 == 标签1)
        {
            如果 (编辑框1.输入方式 == 编辑框输入方式.只读方式 && 已弹出 == 假)
            {
                已弹出 = 真
                组合框1.发送信息 (335, 1, 0)
            }
            否则
            {
                已弹出 = 假
            }
        }
        返回 (0)
    }
}

类 动态组合框模板 <折叠 @文档 = "category = \"自定义组件库.附加类\"">
{
    变量 参考组合框 <类型 = 组合框>

    方法 创建组合框 <公开 类型 = 组合框 折叠>
    参数 父窗口 <类型 = 窗口容器组件>
    参数 左边位置 <类型 = 整数 @默认值 = 10>
    参数 顶边位置 <类型 = 整数 @默认值 = 10>
    参数 宽度 <类型 = 整数 @默认值 = 100>
    参数 高度 <类型 = 整数 @默认值 = 24>
    参数 类型 <类型 = 组合框类型 @默认值 = 组合框类型.可编辑下拉式>
    参数 列表项目 <类型 = 文本型 @默认值 = "">
    参数 行间隔 <类型 = 整数>
    参数 字体 <类型 = 文本型>
    {
        参考组合框.类型 = 类型
        参考组合框.字体 = 字体
        参考组合框.行间距 = 行间隔
        参考组合框.列表项目 = 列表项目
        参考组合框.创建组件 (父窗口, 左边位置, 顶边位置, 宽度, 高度)
        返回 (参考组合框)
    }
}

