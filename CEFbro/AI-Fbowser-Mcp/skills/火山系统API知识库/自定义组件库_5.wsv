    方法 跳转子夹_ <公开 类型 = 逻辑型 注释 = "直接跳到指定子夹处显示" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    参数 是否强制跳转 <类型 = 逻辑型 注释 = "当处于锁定状态时是否强制跳转" @默认值 = 假>
    {
        变量 结果 <类型 = 逻辑型>
        如果真 (全局量.全局锁定界面 && 是否强制跳转 == 假)
        {
            返回 (假)
        }
        重定位遮挡 (子夹索引)
        结果 = 导航.跳转子夹_ (子夹索引, 是否强制跳转)
        如果真 (结果)
        {
            调整层次_ (窗口组.取成员 (子夹索引).窗口句柄)
            如果真 (全局量.当前焦点句柄 != 窗口组.取成员 (子夹索引).窗口句柄)
            {
                窗口_置窗口组件焦点2 (窗口组.取成员 (子夹索引).窗口句柄)
            }
            全局量.当前焦点句柄 = 窗口组.取成员 (子夹索引).窗口句柄
            如果真 (全局量.标题间隔符 != "")
            {
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 导航.取子夹名称_ (子夹索引))
            }
        }
        返回 (结果)
    }

