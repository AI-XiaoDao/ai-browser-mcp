            窗口_置窗口组件位置大小_MFC (窗口组.取枚举值 ().窗口句柄, 0, 0, 取用户区宽度 (), 取用户区高度 ())
        }
    }

    方法 添加子夹_窗口 <公开 类型 = 整数 返回值注释 = "返回子夹索引" 折叠>
    参数 窗口 <类型 = 窗口 注释 = "待加载的窗口">
    参数 子夹标题 <类型 = 文本型 注释 = "默认为窗口标题" @默认值 = "">
    参数 子夹图标 <类型 = 位图资源 注释 = "默认为内置图标" @默认值 = 空资源.空位图>
    参数 子夹标记 <类型 = 文本型 注释 = "定义一个标记值" @默认值 = "">
    参数 提示信息 <类型 = 文本型 注释 = "定义一个鼠标停留时的提示" @默认值 = "">
    参数 是否显示边框 <类型 = 逻辑型 注释 = "是否显示窗口边框" @默认值 = 假>
    参数 是否可调节大小 <类型 = 逻辑型 注释 = "窗口大小是否可调节" @默认值 = 假>
    参数 是否按原窗口显示 <类型 = 逻辑型 注释 = "真：不改变原窗口大小，并居中显示" @默认值 = 假>
    参数 是否跟随主窗大小 <类型 = 逻辑型 注释 = "当主窗口大小发现改变时，本窗口是否跟随变动" @默认值 = 真>
    参数 子夹宽度补充 <类型 = 整数 注释 = "额外加宽子夹宽度" @默认值 = 10>
    {
        变量 夹信息 <类型 = 高级选择夹信息类>
        变量 返回的索引 <类型 = 整数类>
        变量 临时索引 <类型 = 整数>
        变量 索引 <类型 = 整数>
        变量 左位 <类型 = 整数类>
        变量 顶位 <类型 = 整数类>
        如果真 (添加中)
        {
            调试输出 ("当前还有窗口正在添加中")
            返回 (-1)
        }
        互斥.加锁 ()
        添加中 = 真
        临时索引 = 导航.取活动子夹索引_ ()
        标签_隐藏条.可视 = 假
        如果真 (窗口_窗口是否存在 (窗口.取窗口句柄 ()) && 窗口是否已存在 (窗口.取窗口句柄 ()) == 假)
        {
            添加中 = 假
            互斥.解锁 ()
            返回 (-1)
        }
        导航.置重画_ (真)
        如果 (是否显示边框)
        {
            如果 (是否可调节大小)
            {
                窗口.窗口边框 = 窗口边框类型.普通可调边框
            }
            否则
            {
                窗口.窗口边框 = 窗口边框类型.普通固定边框
            }
        }
        否则
        {
            窗口.窗口边框 = 窗口边框类型.无边框
        }
        如果真 (全局量.是否层叠)
        {
            取层叠坐标 (左位, 顶位)
        }
        如果 (是否按原窗口显示)
        {
            窗口_嵌入窗口 (组件布局器_窗体区.取窗口句柄 (), 窗口, 左位.值, 顶位.值, , , 是否显示边框)
            窗口.移动 ((组件布局器_窗体区.宽度 - 窗口.宽度) / 2, (组件布局器_窗体区.高度 - 窗口.高度) / 2)
        }
        否则
        {
            窗口_嵌入窗口 (组件布局器_窗体区.取窗口句柄 (), 窗口, 左位.值, 顶位.值, 组件布局器_窗体区.宽度, 组件布局器_窗体区.高度, 是否显示边框)
        }
        窗口.调整层次 (组件层次.顶层)
        如果 (子夹标题 == "")
        {
            子夹标题 = 窗口_取窗口组件标题 (窗口.取窗口句柄 ())
        }
        如果真 (窗口是否已存在 (窗口.取窗口句柄 (), 返回的索引))
        {
            如果真 (返回的索引.值 == -1)
            {
                返回的索引.值 = 0
            }
            导航.跳转子夹_ (返回的索引.值, 真)
            如果真 (全局量.标题间隔符 != "")
            {
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
            }
            重定位遮挡 (返回的索引.值)
            导航.置重画_ (假)
            处理事件_ ()
            添加中 = 假
            互斥.解锁 ()
            返回 (-1)
        }
        如果真 (返回的索引.值 == -1)
        {
            返回的索引.值 = 窗口组.取成员数 ()
        }
        索引 = 导航.添加子夹_ (子夹标题, 子夹图标, 子夹标记, 提示信息, 子夹宽度补充)
        夹信息.窗口句柄 = 窗口.取窗口句柄 ()
        夹信息.窗口名称 = 子夹标题
        夹信息.子夹标记 = 子夹标记
        夹信息.子夹索引 = 索引
        夹信息.是否窗口 = 真
        夹信息.是否跟随大小 = 是否跟随主窗大小
        窗口组.加入成员 (夹信息)
        如果 (全局量.已启动 == 假)
        {
            全局量.已启动 = 真
            线程.投递任务_ ()
        }
        如果真 (全局量.标题间隔符 != "")
        {
            窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
        }
        窗口_置窗口组件焦点2 (窗口.取窗口句柄 ())
        全局量.当前焦点句柄 = 窗口.取窗口句柄 ()
        重定位遮挡 (返回的索引.值)
        导航.置重画_ (假)
        处理事件_ ()
        添加中 = 假
        互斥.解锁 ()
        子夹被改变事件 (临时索引, 索引)
        返回 (索引)
    }

    方法 添加子夹_布局器 <公开 类型 = 整数 返回值注释 = "返回子夹索引" 折叠>
