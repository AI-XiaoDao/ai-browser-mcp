        {
            改变值 = 1
        }
        程_页改变值 = 改变值
    }

    方法 开始滚动 <公开 注释 = "添加在滚轮被滚动事件下调用" 折叠>
    参数 滚动距离 <类型 = 整数 注释 = ">0向前滚动,<0向后滚动">
    {
        生成滚动条动作 (选择 (滚动距离 > 0, 0, 1), (整数)滚动条常量.滚动条_鼠标滚动)
    }

    方法 生成滚动条动作 <类型 = 逻辑型 折叠>
    参数 lParam <类型 = 整数>
    参数 鼠标位置 <类型 = 整数 @默认值 = -1>
    {
        变量 每份宽 <类型 = 小数 注释 = "1% 的宽度(滚动条是100份)">
        变量 滚动槽宽 <类型 = 整数>
        变量 局_鼠标 <类型 = 整数>
        如果真 (滑块范围.宽度 == 1)
        {
            返回 (假)
        }
        如果 (鼠标位置 == -1)
        {
            局_鼠标 = 判断鼠标位置 (公用方法.取低位_ (lParam), 公用方法.取高位_ (lParam))
        }
        否则
        {
            局_鼠标 = 鼠标位置
        }
        如果 (局_鼠标 == (整数)滚动条常量.滚动条_滑块内)
        {
            滚动槽宽 = 滚动条范围.宽度 - 2 * 15 - 滑块范围.宽度
            每份宽 = (程_最大位置 - 程_最小位置 + 1) / (小数)滚动槽宽
            滑块范围.左边 = 公用方法.取低位_ (lParam) - 鼠标滑块X
            如果真 (滑块范围.左边 < 15)
            {
                滑块范围.左边 = 15
            }
            如果真 (滑块范围.左边 > 滚动条范围.宽度 - 滑块范围.宽度 - 15)
            {
                滑块范围.左边 = 滚动条范围.宽度 - 滑块范围.宽度 - 15
            }
            程_当前位置 = (整数)((滑块范围.左边 - 15) * 每份宽)
            如果真 (程_当前位置 < 程_最小位置)
            {
                程_当前位置 = 程_最小位置
            }
            如果真 (程_当前位置 > 程_最大位置)
            {
                程_当前位置 = 程_最大位置
            }
            鼠标位置X = 公用方法.取低位_ (lParam)
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_左上箭头内)
        {
            程_当前位置 = 程_当前位置 - 程_行改变值
            如果真 (程_当前位置 < 程_最小位置)
            {
                程_当前位置 = 程_最小位置
            }
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_右下箭头内)
        {
            程_当前位置 = 程_当前位置 + 程_行改变值
            如果真 (程_当前位置 > 程_最大位置)
            {
                程_当前位置 = 程_最大位置
            }
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_滚动槽内)
        {
            如果 (lParam == 0)
            {
                程_当前位置 = 程_当前位置 - 程_页改变值
                如果真 (程_当前位置 < 程_最小位置)
                {
                    程_当前位置 = 程_最小位置
                }
            }
            否则
            {
                程_当前位置 = 程_当前位置 + 程_页改变值
                如果真 (程_当前位置 > 程_最大位置)
                {
                    程_当前位置 = 程_最大位置
                }
            }
        }
        刷新滑块坐标 ()
        绘制滚动条 ()
        如果真 (局_鼠标 != 0 && 滑块范围.宽度 > 1)
        {
            如果真 (记忆位 != 程_当前位置)
            {
                位置被改变事件 (程_当前位置)
            }
            记忆位 = 程_当前位置
        }
        如果 (程_当前位置 == 程_最小位置 || 程_当前位置 == 程_最大位置)
        {
            返回 (假)
        }
        否则
        {
            返回 (真)
        }
    }

    方法 取滚动条范围 <类型 = 滚动条_尺寸 折叠>
    {
        返回 (滚动条范围)
    }

    方法 判断鼠标位置 <类型 = 整数 注释 = "返回：滚动条_ 开头的常量,如果返回0，则不在滚动区。" 折叠>
    参数 横向位置 <类型 = 整数 注释 = "位置相对于窗口">
    参数 纵向位置 <类型 = 整数 注释 = "位置相对于窗口">
    {
        如果 (横向位置 >= 滑块范围.左边 && 横向位置 <= 滑块范围.左边 + 滑块范围.宽度 && 纵向位置 >= 滑块范围.顶边 && 纵向位置 <= 滑块范围.顶边 + 滑块范围.高度)
        {
            返回 ((整数)滚动条常量.滚动条_滑块内)
        }
        否则 (横向位置 >= 向左箭头范围.左边 && 横向位置 <= 向左箭头范围.左边 + 向左箭头范围.宽度 && 纵向位置 >= 向左箭头范围.顶边 && 纵向位置 <= 向左箭头范围.顶边 + 向左箭头范围.高度)
        {
            返回 ((整数)滚动条常量.滚动条_左上箭头内)
        }
        否则 (横向位置 >= 向右箭头范围.左边 && 横向位置 <= 向右箭头范围.左边 + 向右箭头范围.宽度 && 纵向位置 >= 向右箭头范围.顶边 && 纵向位置 <= 向右箭头范围.顶边 + 向右箭头范围.高度)
        {
            返回 ((整数)滚动条常量.滚动条_右下箭头内)
        }
        否则 (横向位置 >= 滚动条范围.左边 && 横向位置 <= 滚动条范围.左边 + 滚动条范围.宽度 && 纵向位置 >= 滚动条范围.顶边 && 纵向位置 <= 滚动条范围.顶边 + 滚动条范围.高度)
        {
            返回 ((整数)滚动条常量.滚动条_滚动槽内)
        }
        否则
        {
            返回 (0)
        }
    }

    方法 位置被改变事件 <公开 定义事件 类型 = 整数 折叠>
    参数 当前位置 <类型 = 整数>

    方法 置滑块长度 <公开 属性写 折叠>
    参数 长度 <类型 = 整数 注释 = "设置0将会隐藏滑块">
    {
        如果 (长度 > 0)
        {
            滑块范围.宽度 = 长度
        }
        否则
        {
            滑块范围.宽度 = 1
        }
    }

    方法 置滑块长度 <公开 属性读 类型 = 整数 折叠>
    {
        返回 (滑块范围.宽度)
    }

    方法 置滚动条宽度 <折叠>
    参数 宽度 <类型 = 整数>
    {
        滚动条范围.宽度 = 宽度
    }

    方法 组件移入移出事件类2__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类2_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    参数 是否悬停 <类型 = 逻辑型 注释 = "鼠标是否停留在组件上，到达设置的时间时触发为真">
    {
        如果真 (是否悬停 == 假)
        {
            如果真 (是否移入 == 假 && 鼠标左键按下 == 假)
            {
                程_热点鼠标位 = 0
                绘制滚动条 (真)
            }
        }
        返回 (0)
    }
}

