    参数 滚动距离 <类型 = 整数 注释 = ">0向前滚动,<0向后滚动">
    {
        滚动条1.开始滚动 (滚动距离)
    }

    方法 滚动条样式 <公开 属性读 类型 = 滚动条样式类型 折叠>
    {
        返回 (样式类型)
    }

    方法 滚动条样式 <公开 属性写 折叠 @视窗.设置时机 = 组件创建后>
    参数 所欲设置的样式类型 <类型 = 滚动条样式类型>
    {
        常量 天蓝色 <类型 = 文本型 值 = "天蓝色">
        常量 黑灰色 <类型 = 文本型 值 = "黑灰色">
        变量 局部样式 <类型 = 文本型>
        样式类型 = 所欲设置的样式类型
        局部样式 = (文本型)所欲设置的样式类型
        如果 (所欲设置的样式类型 == 滚动条样式类型.天蓝色 || 局部样式 == "天蓝色")
        {
            格式样式 = 天蓝色
            滚动条1.置风格 (0)
        }
        否则 (所欲设置的样式类型 == 滚动条样式类型.黑灰色 || 局部样式 == "黑灰色")
        {
            格式样式 = 黑灰色
            滚动条1.置风格 (1)
        }
    }

    方法 置风格 <公开 折叠>
    参数 样式 <类型 = 整数 注释 = "0、天蓝色　1、黑灰色" @默认值 = 0>
    {
        滚动条1.置风格 (样式)
    }

