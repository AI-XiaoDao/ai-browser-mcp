    方法 导入JSON配置信息_ <公开 类型 = 逻辑型 注释 = "通过json配置信息来创建卷帘列表，导入前会先清空之前的信息。添加前请先执行“初始化卷帘_”" 折叠>
    参数 JSON配置 <类型 = 文本型>
    参数 是否自定义图标 <类型 = 逻辑型 注释 = "为真时，将使用“加入图标_”命令所导入的图标信息，按照顺序加载" @默认值 = 假>
    参数 父项正常右侧图标 <类型 = 位图资源 注释 = "展开前" @默认值 = 空资源.空位图>
    参数 父项热点右侧图标 <类型 = 位图资源 注释 = "展开后" @默认值 = 空资源.空位图>
    {
        变量 JSON对象 <类型 = JSON对象类_>
        变量 JSON数组 <类型 = JSON数组类_>
        变量 名称组 <类型 = 文本数组类>
        变量 父名组 <类型 = 文本数组类>
        变量 子名组 <类型 = 文本数组类>
        变量 子标记名组 <类型 = 文本数组类>
        变量 父标记组 <类型 = 文本数组类>
        变量 子标记组 <类型 = 文本数组类>
        变量 临时图 <类型 = 卷帘图标类>
        变量 临时名 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果真 (是否已初始化 == 假)
        {
            调试输出 ("有先执行[初始化卷帘_]命令")
            返回 (假)
        }
        如果真 (卷帘布局组.取成员数 () > 0)
        {
            清空卷帘列表_ ()
        }
        结果 = JSON对象.创建自文本 (JSON配置)
        JSON对象.取所有键名 (名称组)
        名称组.枚举循环 ()
        {
            临时名 = 名称组.取枚举值 ()
            如果 (取文本右边 (临时名, 2) == "标记")
            {
                子标记名组.加入成员 (临时名)
            }
            否则
            {
                父名组.加入成员 (临时名)
            }
        }
        如果真 (JSON数组.创建自文本 (JSON对象.取文本值 ("父项总标记")) == 假)
        {
            返回 (假)
        }
        计次循环 (JSON数组.成员数)
        {
            父标记组.加入成员 (JSON数组.取文本值 (取循环索引 ()))
        }
        如果真 (父项正常右侧图标 != 空资源.空位图)
        {
            全局量.父项正常右侧图标 = 父项正常右侧图标
        }
        如果真 (父项热点右侧图标 != 空资源.空位图)
        {
            全局量.父项热点右侧图标 = 父项热点右侧图标
        }
        组件布局器_列表区2.可视 = 假
        处理事件_ ()
        父名组.枚举循环 ()
        {
            JSON数组.创建自文本 (JSON对象.取文本值 (父名组.取枚举值 ()))
            子名组.删除所有成员 ()
            计次循环 (JSON数组.成员数)
            {
                子名组.加入成员 (JSON数组.取文本值 (取循环索引 ()))
            }
            JSON数组.创建自文本 (JSON对象.取文本值 (子标记名组.取成员 (父名组.取枚举索引 ())))
            子标记组.删除所有成员 ()
            计次循环 (JSON数组.成员数)
            {
                子标记组.加入成员 (JSON数组.取文本值 (取循环索引 ()))
            }
            如果真 (是否自定义图标 && 图标组.取成员数 () >= 父名组.取成员数 ())
            {
                临时图 = 图标组.取成员 (父名组.取枚举索引 ())
            }
            添加菜单列表_ (父名组.取枚举值 (), 父标记组.取成员 (父名组.取枚举索引 ()), 子名组, 子标记组, 临时图.图标, 全局量.父项正常右侧图标, 全局量.父项热点右侧图标)
        }
        处理事件_ ()
        组件布局器_列表区2.可视 = 真
        返回 (结果)
    }

    方法 取JSON配置信息_ <公开 类型 = 文本型 注释 = "将当前列表信息导出成json配置，不含图标数据" 折叠>
    {
        变量 JSON对象 <类型 = JSON对象类_>
        变量 JSON数组 <类型 = JSON数组类_>
        变量 JSON数组2 <类型 = JSON数组类_>
        变量 JSON数组3 <类型 = JSON数组类_>
        变量 临时标题 <类型 = 文本型>
        变量 临时标题2 <类型 = 文本型>
        变量 临时标记 <类型 = 文本型>
        变量 临时标记2 <类型 = 文本型>
        变量 父索引 <类型 = 整数>
        变量 i <类型 = 整数>
        卷帘布局组.枚举循环 ()
        {
            父索引 = 对象数组类.取枚举索引 ()
            临时标题 = ((父卷帘模板类)卷帘布局组.取枚举值 ()).标签_标题.标题
            临时标记 = ((父卷帘模板类)卷帘布局组.取枚举值 ()).当前标记
            JSON数组3.置入文本值 (临时标记, )
            JSON数组.清空 ()
            JSON数组2.清空 ()
            循环 (, 卷帘布局组2.取成员数 (), i)
            {
                如果真 (((子卷帘模板类)卷帘布局组2.取成员 (i)).当前父项索引 == 父索引)
                {
                    临时标题2 = ((子卷帘模板类)卷帘布局组2.取成员 (i)).标签_标题.标题
                    临时标记2 = ((子卷帘模板类)卷帘布局组2.取成员 (i)).当前标记
                    JSON数组.置入文本值 (临时标题2, )
                    JSON数组2.置入文本值 (临时标记2, )
                }
            }
            JSON对象.置入数组值 (临时标题, JSON数组)
            JSON对象.置入数组值 (临时标题 + "标记", JSON数组2)
        }
        JSON对象.置入数组值 ("父项总标记", JSON数组3)
        返回 (JSON对象.到可读文本 ())
    }

