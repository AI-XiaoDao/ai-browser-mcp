    方法 取子项真实索引 <类型 = 整数 返回值注释 = "返回-1表示不存在" 折叠>
    参数 父索引 <类型 = 整数>
    参数 子索引 <类型 = 整数>
    {
        变量 总数 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (父索引 < 0 || 父索引 + 1 > 卷帘布局组.取成员数 () || 子索引 < 0 || 子索引 > 卷帘布局组2.取成员数 ())
        {
            返回 (-1)
        }
        循环 (, 父索引, i)
        {
            总数 = 总数 + 全局量.子项组数 [i]
        }
        总数 = 总数 + 子索引
        如果 (卷帘布局组2.取成员数 () > 0)
        {
            如果真 (总数 > 卷帘布局组2.取成员数 () - 1)
            {
                返回 (-1)
            }
            如果真 (((子卷帘模板类)卷帘布局组2.取成员 (总数)).当前父项索引 != 父索引 && 全局量.子项组数 [父索引] == 0)
            {
                返回 (-1)
            }
        }
        返回 (总数)
    }

