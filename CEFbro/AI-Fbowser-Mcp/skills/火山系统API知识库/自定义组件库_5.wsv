类 高级卷帘式菜单 <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1, 2" @文档 = "category = \"自定义组件库.高级卷帘式菜单\"" @视窗.布局 = "client_size = \"230, 320\""
        @视窗.窗口组件 = "icon=\"tb/gjjl.bmp\"\r\ndefault_size = \"230, 320\"\r\ncategory = \"仰望模块扩展组件\"\r\ndefault_event=\"子父菜单点击事件\""
        底色 = 0x3D241F>
{
