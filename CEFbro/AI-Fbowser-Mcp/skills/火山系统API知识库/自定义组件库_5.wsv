    方法 取所有窗口信息_ <公开 类型 = 整数 返回值注释 = "返回窗口总数" 折叠>
    参数 返回的窗口名称 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的窗口句柄 <类型 = 变整数数组类 @默认值 = 空对象>
    参数 返回的窗口类型 <类型 = 整数数组类 注释 = "1、常规窗口 2、布局器窗口 3、常规DLL窗口 4、动态DLL窗口" @默认值 = 空对象>
    参数 返回的子夹索引 <类型 = 整数数组类 @默认值 = 空对象>
    参数 返回的子夹标记 <类型 = 文本数组类 @默认值 = 空对象>
    {
        窗口组.枚举循环 ()
        {
            返回的窗口名称.加入成员 (窗口组.取枚举值 ().窗口名称)
            返回的窗口句柄.加入成员 (窗口组.取枚举值 ().窗口句柄)
            返回的子夹索引.加入成员 (窗口组.取枚举值 ().子夹索引)
            返回的子夹标记.加入成员 (窗口组.取枚举值 ().子夹标记)
            如果 (窗口组.取枚举值 ().是否DLL)
            {
                如果 (窗口组.取枚举值 ().动态句柄 > 0)
                {
                    返回的窗口类型.加入成员 (4)
                }
                否则
                {
                    返回的窗口类型.加入成员 (3)
                }
            }
            否则 (窗口组.取枚举值 ().是否窗口)
            {
                返回的窗口类型.加入成员 (1)
            }
            否则
            {
                返回的窗口类型.加入成员 (2)
            }
        }
        返回 (窗口组.取成员数 ())
    }

    方法 取活动窗口信息_ <公开 类型 = 变整数 注释 = "取当前活动窗口信息" 返回值注释 = "返回窗口句柄" 折叠>
    参数 返回的窗口名称 <类型 = 文本型 @默认值 = "">
    参数 返回的窗口句柄 <类型 = 变整数 @默认值 = -1>
    参数 返回的窗口类型 <类型 = 整数 注释 = "1、常规窗口 2、布局器窗口 3、常规DLL窗口 4、动态DLL窗口" @默认值 = -1>
    参数 返回的子夹索引 <类型 = 整数 @默认值 = -1>
    参数 返回的子夹标记 <类型 = 文本型 @默认值 = "">
    {
        如果真 (取活动子夹索引_ () == -1)
        {
            返回 (-1)
        }
        返回的窗口名称 = 窗口组.取成员 (取活动子夹索引_ ()).窗口名称
        返回的窗口句柄 = 窗口组.取成员 (取活动子夹索引_ ()).窗口句柄
        如果 (窗口组.取成员 (取活动子夹索引_ ()).是否DLL)
        {
            如果 (窗口组.取成员 (取活动子夹索引_ ()).动态句柄 > 0)
            {
                返回的窗口类型 = 4
            }
            否则
            {
                返回的窗口类型 = 3
            }
        }
        否则 (窗口组.取成员 (取活动子夹索引_ ()).是否窗口)
        {
            返回的窗口类型 = 1
        }
        否则
        {
            返回的窗口类型 = 2
        }
        返回的子夹索引 = 窗口组.取成员 (取活动子夹索引_ ()).子夹索引
        返回的子夹标记 = 窗口组.取成员 (取活动子夹索引_ ()).子夹标记
        返回 (窗口组.取成员 (取活动子夹索引_ ()).窗口句柄)
    }

