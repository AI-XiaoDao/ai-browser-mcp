    方法 隐藏标签 <公开 属性写 折叠>
    参数 是否隐藏 <类型 = 逻辑型>
    {
        如果 (是否隐藏 == 假)
        {
            标签1.可视 = 真
            变量 字体信息 <类型 = 字体信息组_>
            字体信息 = 字体_取字体信息 (字体数据)
            标签1.宽度 = 文本_取文本像素尺寸2 (标签1.标题, 字体信息.字体名称, 字体信息.字体尺寸, 字体信息.是否加粗, 字体信息.是否斜体)
            组合框1.移动 (标签1.宽度, , 本对象.宽度 - 标签1.宽度, )
        }
        否则
        {
            标签1.宽度 = 0
            标签1.可视 = 假
            组合框1.移动 (0, 0, 本对象.宽度, )
        }
        组合框1.发送信息 (339, -1, 本对象.高度 - 6)
        编辑框1.移动 (组合框1.左边 + 1, 1, 组合框1.宽度 - 差值, 本对象.高度 - 6)
        标签2.移动 (组合框1.左边 + 1, 1, 组合框1.宽度 - 差值, 本对象.高度 - 2)
    }

