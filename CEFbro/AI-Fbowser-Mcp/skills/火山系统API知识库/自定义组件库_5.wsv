    参数 滑块正常终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 滑块正常终点透明度 <类型 = 整数 注释 = "默认：150" @默认值 = -1>
    参数 滑块正常边框色1 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
