    方法 创建滚动条 <公开 折叠>
    参数 绑定容器 <类型 = 窗口容器组件>
    参数 最小位置 <类型 = 整数 @默认值 = 1>
    参数 最大位置 <类型 = 整数 @默认值 = 100>
    参数 行改变值 <类型 = 整数 @默认值 = 1>
    参数 页改变值 <类型 = 整数 @默认值 = 10>
    参数 当前位置 <类型 = 整数 @默认值 = 1>
    参数 滚到鼠标处 <类型 = 逻辑型 注释 = "当设置为真时，页改变值参数将失效" @默认值 = 真>
    参数 初始滑块长度 <类型 = 整数 @默认值 = 60>
    参数 上调节图 <类型 = 视窗文件资源 注释 = "默认则使用内置图标" @默认值 = 空资源.空文件>
    参数 下调节图 <类型 = 视窗文件资源 注释 = "默认则使用内置图标" @默认值 = 空资源.空文件>
    {
        创建组件 (绑定容器, 0, 0, 绑定容器.宽度, 绑定容器.高度, )
        令牌 = GP初始类.初始化 ()
        初始处理 ()
        程_最小位置 = 最小位置
        程_最大位置 = 最大位置
        程_行改变值 = 行改变值
        程_页改变值 = 页改变值
        程_当前位置 = 当前位置
        程_滚到鼠标处 = 滚到鼠标处
        置滑块长度 = 初始滑块长度
        程_窗口句柄 = 取窗口句柄 ()
        如果真 (上调节图 != 空资源.空文件)
        {
            图片1 = 上调节图
        }
        如果真 (下调节图 != 空资源.空文件)
        {
            图片2 = 上调节图
        }
        图片_向上 = 取出资源文件_ (图片1)
        图片_向下 = 取出资源文件_ (图片2)
        显示画板.创建 (1, 1, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.滑块槽主背景色, 变量类.滑块槽主背景透明度))
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        后台图像.创建自像素格式 (1, 1)
        绘制画板.创建自图像 (后台图像)
        刷新位置 ()
        刷新滑块坐标 ()
    }

    方法 初始处理 <折叠>
    {
        显示画板.销毁 ()
        绘制画板.销毁 ()
        后台图像.销毁 ()
        记忆位 = 0
        时钟1.时钟周期 = 0
        鼠标左键按下 = 假
        连续赋值 (0, 鼠标位置Y, 鼠标滑块Y, 程_鼠标在哪, 程_滑块中)
    }

    方法 纵向滚动条类2__组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        出入.监视组件_ (本对象, 消息值)
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        分支判断 (消息值)
        {
            分支 (20)  // WM_ERASEBKGND
            {
                @ SetBkMode((HDC)@<消息参数1>,1);
                返回 (1)
            }
            分支 (15)  // WM_PAINT
            {
                绘制滚动条 ()
                变量 ret <类型 = 整数>
                @ LRESULT dwp=DefWindowProc((HWND)@<窗口句柄>,@<消息值>,(WPARAM)@<消息参数1>,(LPARAM)@<消息参数2>);
                @ @<ret>=(int)dwp;
                返回 (ret)
            }
            分支 (675)  // WM_MOUSELEAVE
            {
                鼠标左键按下 = 假
                绘制热点 (0)
            }
            分支 (512)  // WM_MOUSEMOVE
            {
                程_鼠标位置 = (整数)消息参数2
            }
        }
        返回 (0)
    }

    方法 刷新位置 <折叠>
    {
        变量 rect <类型 = 矩形类>
        程_窗口句柄 = 取窗口句柄 ()
        @ RECT rec;
        @ GetClientRect((HWND)@<程_窗口句柄>,&rec);
        @ @<rect.设置>(rec.left,rec.top,rec.right,rec.bottom);
        程_父窗口宽 = rect.宽度
        程_父窗口高 = rect.高度
        显示画板.销毁 ()
        显示画板.创建 (程_父窗口宽, 程_父窗口高, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.滑块槽主背景色, 变量类.滑块槽主背景透明度))
        绘制画板.销毁 ()
        后台图像.销毁 ()
        后台图像.创建自像素格式 (程_父窗口宽, 程_父窗口高, )
        绘制画板.创建自图像 (后台图像)
        如果真 (程_当前位置 > 程_最大位置)
        {
            程_当前位置 = 程_最大位置
        }
        滚动条范围.左边 = 0
        滚动条范围.顶边 = 0
        滚动条范围.宽度 = 程_父窗口宽
        滚动条范围.高度 = 程_父窗口高
        向上箭头范围.左边 = 滚动条范围.左边 + 1
        向上箭头范围.顶边 = 滚动条范围.顶边
        向上箭头范围.宽度 = 滚动条范围.宽度 - 2
        向上箭头范围.高度 = 15
        向下箭头范围.左边 = 滚动条范围.左边 + 1
        向下箭头范围.顶边 = 滚动条范围.顶边 + 滚动条范围.高度 - 16
        向下箭头范围.宽度 = 滚动条范围.宽度 - 2
        向下箭头范围.高度 = 15
        滑块范围.左边 = 滚动条范围.左边 + 1
        滑块范围.宽度 = 滚动条范围.宽度 - 2
    }

    方法 刷新滑块坐标 <折叠>
    {
        变量 滚动槽 <类型 = 整数>
        如果真 (滑块范围.高度 < 1)
        {
            滑块范围.高度 = 1
        }
        滚动槽 = 滚动条范围.高度 - 2 * 15 - 滑块范围.高度
        滑块范围.顶边 = 向上箭头范围.顶边 + 向上箭头范围.高度 + 取整 ((程_当前位置 - 1) * 滚动槽 / (小数)(程_最大位置 - 程_最小位置))
        如果真 (滑块范围.顶边 < 向上箭头范围.顶边 + 向上箭头范围.高度)
        {
            滑块范围.顶边 = 向上箭头范围.顶边 + 向上箭头范围.高度
        }
        如果真 (滑块范围.顶边 > 向下箭头范围.顶边 - 滑块范围.高度)
        {
            滑块范围.顶边 = 向下箭头范围.顶边 - 滑块范围.高度
        }
    }

    方法 纵向滚动条类2__将被销毁 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    {
        初始处理 ()
        程_窗口句柄 = 0
        GP初始类.卸载 (令牌)
        返回 (0)
    }

    方法 纵向滚动条类2__鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果真 (程_鼠标在哪 == (整数)滚动条常量.滚动条_滑块内 && 鼠标左键按下)
        {
            生成滚动条动作 (合并整数 (横向位置, 纵向位置), (整数)滚动条常量.滚动条_滑块内)
        }
        绘制热点 (判断鼠标位置 (横向位置, 纵向位置))
        返回 (0)
    }

    方法 纵向滚动条类2__鼠标左键被按下 <接收事件 类型 = 整数 注释 = "绘制热点" 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        事件_鼠标左键被按下 (横向位置, 纵向位置)
        返回 (0)
    }

    方法 事件_鼠标左键被按下 <注释 = "非独立滚动条时寄生控件调用" 折叠>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        鼠标左键按下 = 真
        程_鼠标在哪 = 判断鼠标位置 (横向位置, 纵向位置)
        如果 (程_鼠标在哪 == (整数)滚动条常量.滚动条_滑块内)
        {
            鼠标位置Y = 纵向位置  // 滑块将要拖动
            鼠标滑块Y = 鼠标位置Y - 滑块范围.顶边
            @ SetCapture((HWND)@<程_窗口句柄>);
        }
        否则 (程_鼠标在哪 == (整数)滚动条常量.滚动条_滚动槽内)
        {
            如果真 (程_滚到鼠标处 == 真)
            {
                鼠标滑块Y = 滑块范围.高度 / 2
                生成滚动条动作 (合并整数 (横向位置, 纵向位置), (整数)滚动条常量.滚动条_滑块内)
            }
            如果 (纵向位置 < 滑块范围.顶边)
            {
                程_滑块中 = 0
            }
            否则
            {
                程_滑块中 = 1
            }
            如果真 (程_滚到鼠标处 == 真)
            {
                返回
            }
        }
        如果 (鼠标左键按下 && (程_鼠标在哪 == (整数)滚动条常量.滚动条_左上箭头内 || 程_鼠标在哪 == (整数)滚动条常量.滚动条_右下箭头内))
        {
            时钟1.时钟周期 = 200
            生成滚动条动作 (程_鼠标位置, 程_鼠标在哪)
        }
        否则 (鼠标左键按下 && 程_鼠标在哪 == (整数)滚动条常量.滚动条_滚动槽内)
        {
            生成滚动条动作 (程_滑块中, 程_鼠标在哪)
        }
    }

    方法 纵向滚动条类2__鼠标左键被放开 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        时钟1.时钟周期 = 0
        鼠标左键按下 = 假
        程_鼠标在哪 = 0
        绘制滚动条 (真)
        @ ReleaseCapture();
        返回 (0)
    }

    方法 纵向滚动条类2__尺寸被改变 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 纵向滚动条类2_>
    参数 标记值 <类型 = 整数>
    {
        刷新位置 ()
        刷新滑块坐标 ()
        如果真 (滑块范围.高度 > 1)
        {
            位置被改变事件 (程_当前位置)
        }
        返回 (0)
    }

    方法 时钟_周期事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟>
    参数 标记值 <类型 = 整数>
    {
        如果 (鼠标左键按下 && (程_鼠标在哪 == (整数)滚动条常量.滚动条_左上箭头内 || 程_鼠标在哪 == (整数)滚动条常量.滚动条_右下箭头内))
        {
            生成滚动条动作 (程_鼠标位置, 程_鼠标在哪)
        }
        否则 (鼠标左键按下 && 程_鼠标在哪 == (整数)滚动条常量.滚动条_滚动槽内)
        {
            生成滚动条动作 (程_滑块中, 程_鼠标在哪)
        }
        返回 (0)
    }

    方法 绘制热点 <折叠>
    参数 鼠标位置 <类型 = 整数>
    {
        如果真 (鼠标左键按下 == 真)
        {
            返回
        }
        如果真 (鼠标位置 != 程_画热点 || 鼠标位置 != (整数)滚动条常量.滚动条_滚动槽内)
        {
            程_热点鼠标位 = 鼠标位置
            绘制滚动条 ()
            程_画热点 = 鼠标位置
        }
    }

    方法 绘制滚动条 <折叠>
    参数 离开滚动区 <类型 = 逻辑型 注释 = "鼠标离开滚动条范围恢复原色" @默认值 = 假>
    {
        变量 位图 <类型 = GP位图类>
        变量 左上角 <类型 = 坐标F>
        变量 左下角 <类型 = 坐标F>
        变量 图宽 <类型 = 整数>
        变量 图高 <类型 = 整数>
        变量 图左上X <类型 = 整数>
        变量 图左上Y <类型 = 整数>
        变量 渐变画刷 <类型 = GP线性渐变画刷类>
        变量 纯色画刷 <类型 = GP纯色画刷类>
        变量 路径 <类型 = GP路径类>
        变量 画笔 <类型 = GP画笔类>
        变量 逻辑值 <类型 = 逻辑型>
        如果真 (滚动条范围.宽度 <= 0)
        {
            返回
        }
        绘制画板.清除 (GP颜色.到ARGB (变量类.滑块槽主背景色, 变量类.滑块槽主背景透明度))
        左上角.X = 滚动条范围.左边
        左上角.Y = 滚动条范围.顶边
        左下角.X = 滚动条范围.左边 + 滚动条范围.宽度
        左下角.Y = 滚动条范围.顶边
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.滑块槽副背景起点色, 变量类.滑块槽副背景起点透明度), GP颜色.到ARGB (变量类.滑块槽副背景终点色, 变量类.滑块槽副背景终点透明度))  // 滑块槽
        绘制画板.填充矩形 (渐变画刷, 左上角.X, 左上角.Y, 滚动条范围.宽度, 滚动条范围.高度)
        // 绘制滚动条滑块
        如果 (滑块范围.高度 > 1)
        {
            如果 (离开滚动区 == 假)
            {
                如果 (程_热点鼠标位 == (整数)滚动条常量.滚动条_滑块内)
                {
                    左上角.X = 滑块范围.左边 - 1
                    左上角.Y = 滑块范围.顶边
                    左下角.X = 左上角.X + 滑块范围.宽度 + 1
                    左下角.Y = 左上角.Y
                    纯色画刷.创建 (GP颜色.到ARGB (变量类.滑块热点起点色, 变量类.滑块热点起点透明度))  // 滑块 在块内
                    逻辑值 = 假
                }
                否则
                {
                    渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.滑块正常起点色, 变量类.滑块正常起点透明度), GP颜色.到ARGB (变量类.滑块正常终点色, 变量类.滑块正常终点透明度))  // 滑块 不在块内
                    逻辑值 = 真
                }
            }
            否则
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.滑块正常起点色, 变量类.滑块正常起点透明度), GP颜色.到ARGB (变量类.滑块正常终点色, 变量类.滑块正常终点透明度))  // 滑块 不在块内
                逻辑值 = 真
            }
            路径.创建 ()
            路径.添加圆角矩形 (滑块范围.左边, 滑块范围.顶边, 滑块范围.宽度 - 1, 滑块范围.高度 - 1, 5, 5)
            如果 (逻辑值)
            {
                绘制画板.填充路径 (渐变画刷, 路径)
            }
            否则
            {
                绘制画板.填充路径 (纯色画刷, 路径)
            }
            如果 (程_热点鼠标位 == (整数)滚动条常量.滚动条_滑块内)
            {
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.滑块热点边框色1, 变量类.滑块热点边框透明度1), )  // 滑块外框
                绘制画板.画路径 (画笔, 路径)
                路径.创建 ()
                路径.添加圆角矩形 (滑块范围.左边 + 1, 滑块范围.顶边 + 1, 滑块范围.宽度 - 2, 滑块范围.高度 - 3, 3, 3)
                画笔.置颜色 (GP颜色.到ARGB (变量类.滑块热点边框色2, 变量类.滑块热点边框透明度2))  // 滑块外框
            }
            否则
            {
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.滑块正常边框色1, 变量类.滑块正常边框透明度1), )  // 滑块外框
                绘制画板.画路径 (画笔, 路径)
                路径.创建 ()
                路径.添加圆角矩形 (滑块范围.左边 + 1, 滑块范围.顶边 + 1, 滑块范围.宽度 - 2, 滑块范围.高度 - 3, 3, 3)
                画笔.置颜色 (GP颜色.到ARGB (变量类.滑块正常边框色2, 变量类.滑块正常边框透明度2))  // 滑块外框
            }
            绘制画板.画路径 (画笔, 路径)
        }
        否则
        {
            画笔.创建自颜色 (GP颜色.到ARGB (变量类.滑块正常边框色1, 变量类.滑块正常边框透明度1), )  // 滑块外框
            绘制画板.画路径 (画笔, 路径)
            路径.创建 ()
            路径.添加圆角矩形 (滑块范围.左边 + 1, 滑块范围.顶边 + 1, 滑块范围.宽度 - 2, 滑块范围.高度 - 3, 3, 3)
            画笔.置颜色 (GP颜色.到ARGB (变量类.滑块正常边框色2, 变量类.滑块正常边框透明度2))  // 滑块外框
            绘制画板.画路径 (画笔, 路径)
        }
        // 绘制向上箭头
        路径.创建 ()
        路径.添加圆角矩形 (向上箭头范围.左边, 向上箭头范围.顶边, 向上箭头范围.宽度 - 1, 向上箭头范围.高度 - 1, 4, 4)
        如果真 (程_热点鼠标位 == (整数)滚动条常量.滚动条_左上箭头内)
        {
            左上角.X = 向上箭头范围.左边
            左上角.Y = 向上箭头范围.顶边
            左下角.X = 左上角.X
            左下角.Y = 左上角.Y + 向上箭头范围.高度
            渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.箭头热点起点色, 变量类.箭头热点起点透明度), GP颜色.到ARGB (变量类.箭头热点终点色, 变量类.箭头热点终点透明度))
            绘制画板.填充路径 (渐变画刷, 路径)
        }
        画笔.置颜色 (GP颜色.到ARGB (变量类.箭头边框色1, 变量类.箭头边框透明度1))
        绘制画板.画路径 (画笔, 路径)
        路径.创建 ()
        路径.添加圆角矩形 (向上箭头范围.左边 + 1, 向上箭头范围.顶边 + 1, 向上箭头范围.宽度 - 3, 向上箭头范围.高度 - 3, 3, 3)
        画笔.置颜色 (GP颜色.到ARGB (变量类.箭头边框色2, 变量类.箭头边框透明度2))
        绘制画板.画路径 (画笔, 路径)
        位图.创建自字节集 (图片_向上)
        图宽 = 位图.取宽度 ()
        图高 = 位图.取高度 ()
        图左上X = 向上箭头范围.左边 + (向上箭头范围.宽度 - 图宽) / 2
        图左上Y = 向上箭头范围.顶边 + (向上箭头范围.高度 - 图高) / 2
        绘制画板.画图像矩形 (位图, 图左上X, 图左上Y, 图宽, 图高)
        // 绘制向下箭头
        路径.创建 ()
        路径.添加圆角矩形 (向下箭头范围.左边, 向下箭头范围.顶边, 向下箭头范围.宽度 - 1, 向下箭头范围.高度 - 1, 4, 4)
        如果真 (程_热点鼠标位 == (整数)滚动条常量.滚动条_右下箭头内)
        {
            左上角.X = 向下箭头范围.左边
            左上角.Y = 向下箭头范围.顶边
            左下角.X = 左上角.X
            左下角.Y = 左上角.Y + 向下箭头范围.高度
            渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.箭头热点起点色, 变量类.箭头热点起点透明度), GP颜色.到ARGB (变量类.箭头热点终点色, 变量类.箭头热点终点透明度))
            绘制画板.填充路径 (渐变画刷, 路径)
        }
        画笔.置颜色 (GP颜色.到ARGB (变量类.箭头边框色1, 变量类.箭头边框透明度1))
        绘制画板.画路径 (画笔, 路径)
        路径.创建 ()
        路径.添加圆角矩形 (向下箭头范围.左边 + 1, 向下箭头范围.顶边 + 1, 向下箭头范围.宽度 - 3, 向下箭头范围.高度 - 3, 3, 3)
        画笔.置颜色 (GP颜色.到ARGB (变量类.箭头边框色2, 变量类.箭头边框透明度2))
        绘制画板.画路径 (画笔, 路径)
        位图.创建自字节集 (图片_向下)
        图宽 = 位图.取宽度 ()
        图高 = 位图.取高度 ()
        图左上X = 向下箭头范围.左边 + (向下箭头范围.宽度 - 图宽) / 2
        图左上Y = 向下箭头范围.顶边 + (向下箭头范围.高度 - 图高) / 2
        绘制画板.画图像矩形 (位图, 图左上X, 图左上Y, 图宽, 图高)
        绘制画板.重置剪辑区 ()
        显示画板.画图像 (后台图像)
        变量 设备场景 <类型 = 变整数>
        @ HWND hwnd=(HWND)@<程_窗口句柄>;
        @ HDC hdc=GetDC(hwnd);
        @ @<设备场景>=(INT_P)hdc;
        显示画板.复制 (设备场景, , )
        @ ReleaseDC(hwnd, hdc);
        位图.销毁 ()
        渐变画刷.销毁 ()
        纯色画刷.销毁 ()
        路径.销毁 ()
        画笔.销毁 ()
    }

    方法 相对某窗口客户区 <类型 = 矩形类 注释 = "得到相对于某窗口客户区左上角的位置" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 相对某窗口 <类型 = 变整数 @默认值 = 0>
    {
        变量 rec <类型 = 矩形类>
        @ HWND win,wnd=(HWND)@<窗口句柄>;
        如果 (相对某窗口 == 0)
        {
            @ win=GetAncestor(wnd,2);
        }
        否则
        {
            @ win=(HWND)@<相对某窗口>;
        }
        @ POINT point;
        @ RECT rect;
        @ ClientToScreen(win,&point);
        @ GetWindowRect(wnd,&rect);
        @ if(win==wnd) OffsetRect(&rect,-rect.left,-rect.top);
        @ else OffsetRect(&rect,-point.x,-point.y);
        @ @<rec.设置>(rect.left,rect.top,rect.right,rect.bottom);
        返回 (rec)
    }

