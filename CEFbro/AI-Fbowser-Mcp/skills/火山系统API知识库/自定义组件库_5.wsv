    }

    方法 置正常图片_字节 <公开 折叠>
    参数 所欲设置的位图数据 <类型 = 字节集类>
    {
        @ ((CVWnd_PicButton*)GetMfcWndPtr ())->TakeOverBitmap (VWPB_NORMAL_BITMAP, (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲设置的位图数据>));
    }

    方法 置点燃图片_字节 <公开 折叠>
