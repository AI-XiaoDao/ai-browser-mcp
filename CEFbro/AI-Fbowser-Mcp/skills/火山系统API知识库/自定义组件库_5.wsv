类 按钮类_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"自定义组件库.按钮\"" @视窗.布局 = "client_size = \"80, 32\"" 可停留焦点 = 真>
{
    变量 显示画板 <类型 = GP缓存图形类 折叠>
    变量 后台图像 <类型 = GP位图类>
    变量 绘制画板 <类型 = GP图形类>
    变量 程_窗口句柄 <类型 = 变整数>
    变量 程_父窗口宽 <类型 = 整数>
    变量 程_父窗口高 <类型 = 整数>
    变量 按钮区范围 <类型 = 按钮_尺寸>
    变量 出入 <类型 = 组件移入移出事件类2_>
    变量 令牌 <类型 = 变整数>
    变量 变量类 <类型 = 按钮变量类>
    变量 公用方法 <类型 = 公用方法>
    变量 矩形组 <类型 = 矩形F>
    变量 样式类型 <类型 = 按钮排列样式 值 = 按钮排列样式.左右型>
    变量 鼠标被按下 <类型 = 逻辑型>
    变量 全局横向位置 <类型 = 整数>
    变量 全局纵向位置 <类型 = 整数>

    方法 取组件句柄 <公开 类型 = 变整数 折叠>
    {
        返回 (取窗口句柄 ())
    }

    方法 初始化配色 <公开 注释 = "透明度：0到255之间的整数. 0、完全透明　255、 完全不透明." 注释 = "默认－1则不会改变原设置。在“创建按钮”之前执行本配色" 折叠 折叠2>
    参数 背景色 <类型 = 整数 注释 = "默认：颜色类.银白色；当按钮有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" @默认值 = -1>
    参数 正常起点色 <类型 = 整数 注释 = "默认：颜色类.白色　" @默认值 = -1>
    参数 正常起点透明度 <类型 = 整数 注释 = "默认：200" @默认值 = -1>
    参数 正常终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 正常终点透明度 <类型 = 整数 注释 = "默认：150" @默认值 = -1>
    参数 正常边框色 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
    参数 正常边框透明度 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 热点起点色 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 热点起点透明度 <类型 = 整数 注释 = "默认：170" @默认值 = -1>
    参数 热点终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点终点透明度 <类型 = 整数 注释 = "默认：220" @默认值 = -1>
    参数 热点边框色 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
    参数 热点边框透明度 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 按下起点色 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 按下起点透明度 <类型 = 整数 注释 = "默认：130" @默认值 = -1>
    参数 按下终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 按下终点透明度 <类型 = 整数 注释 = "默认：250" @默认值 = -1>
    参数 按下边框色 <类型 = 整数 注释 = "默认：颜色类.红褐色" @默认值 = -1>
    参数 按下边框透明度 <类型 = 整数 注释 = "默认：55" @默认值 = -1>
    {
        如果真 (背景色 != -1)
        {
            变量类.背景色 = 背景色
        }
        如果真 (正常起点色 != -1)
        {
            变量类.正常起点色 = 正常起点色
        }
        如果真 (正常起点透明度 != -1)
        {
            变量类.正常起点透明度 = 正常起点透明度
        }
        如果真 (正常终点色 != -1)
        {
            变量类.正常终点色 = 正常终点色
        }
        如果真 (正常终点透明度 != -1)
        {
            变量类.正常终点透明度 = 正常终点透明度
        }
        如果真 (正常边框色 != -1)
        {
            变量类.正常边框色 = 正常边框色
        }
        如果真 (正常边框透明度 != -1)
        {
            变量类.正常边框透明度 = 正常边框透明度
        }
        如果真 (热点起点色 != -1)
        {
            变量类.热点起点色 = 热点起点色
        }
        如果真 (热点起点透明度 != -1)
        {
            变量类.热点起点透明度 = 热点起点透明度
        }
        如果真 (热点终点色 != -1)
        {
            变量类.热点终点色 = 热点终点色
        }
        如果真 (热点终点透明度 != -1)
        {
            变量类.热点终点透明度 = 热点终点透明度
        }
        如果真 (热点边框色 != -1)
        {
            变量类.热点边框色 = 热点边框色
        }
        如果真 (热点边框透明度 != -1)
        {
            变量类.热点边框透明度 = 热点边框透明度
        }
        如果真 (按下起点色 != -1)
        {
            变量类.按下起点色 = 按下起点色
        }
        如果真 (按下起点透明度 != -1)
        {
            变量类.按下起点透明度 = 按下起点透明度
        }
        如果真 (按下终点色 != -1)
        {
            变量类.按下终点色 = 按下终点色
        }
        如果真 (按下终点透明度 != -1)
        {
            变量类.按下终点透明度 = 按下终点透明度
        }
        如果真 (按下边框色 != -1)
        {
            变量类.按下边框色 = 按下边框色
        }
        如果真 (按下边框透明度 != -1)
        {
            变量类.按下边框透明度 = 按下边框透明度
        }
    }

    方法 修改配色 <公开 注释 = "透明度：0到255之间的整数. 0、完全透明　255、 完全不透明." 注释 = "默认－1则不会改变原设置。在“创建按钮”之后执行本配色进行重设置" 折叠 折叠2>
    参数 背景色 <类型 = 整数 注释 = "默认：颜色类.银白色；当按钮有圆角时，窗口背景色不同时会出现边角，可设置本参数同色化" @默认值 = -1>
    参数 正常起点色 <类型 = 整数 注释 = "默认：颜色类.白色　" @默认值 = -1>
    参数 正常起点透明度 <类型 = 整数 注释 = "默认：200" @默认值 = -1>
    参数 正常终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 正常终点透明度 <类型 = 整数 注释 = "默认：150" @默认值 = -1>
    参数 正常边框色 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
    参数 正常边框透明度 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 热点起点色 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 热点起点透明度 <类型 = 整数 注释 = "默认：170" @默认值 = -1>
    参数 热点终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 热点终点透明度 <类型 = 整数 注释 = "默认：220" @默认值 = -1>
    参数 热点边框色 <类型 = 整数 注释 = "默认：颜色类.黑色" @默认值 = -1>
    参数 热点边框透明度 <类型 = 整数 注释 = "默认：60" @默认值 = -1>
    参数 按下起点色 <类型 = 整数 注释 = "默认：颜色类.白色" @默认值 = -1>
    参数 按下起点透明度 <类型 = 整数 注释 = "默认：130" @默认值 = -1>
    参数 按下终点色 <类型 = 整数 注释 = "默认：颜色类.天蓝色" @默认值 = -1>
    参数 按下终点透明度 <类型 = 整数 注释 = "默认：250" @默认值 = -1>
    参数 按下边框色 <类型 = 整数 注释 = "默认：颜色类.红褐色" @默认值 = -1>
    参数 按下边框透明度 <类型 = 整数 注释 = "默认：120" @默认值 = -1>
    {
        初始化配色 (背景色, 正常起点色, 正常起点透明度, 正常终点色, 正常终点透明度, 正常边框色, 正常边框透明度, 热点起点色, 热点起点透明度, 热点终点色, 热点终点透明度, 热点边框色, 热点边框透明度, 按下起点色, 按下起点透明度, 按下终点色, 按下终点透明度, 按下边框色, 按下边框透明度)
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        刷新按钮 ()
    }

    方法 修改图标 <公开 注释 = "图标尺寸应控制在按钮所能展示的尺寸之内" 折叠>
    参数 图标 <类型 = 字节集类 注释 = "留空则不会修改原图标" @默认值 = 空对象>
    参数 图标宽度 <类型 = 整数 注释 = "默认不修改原大小" @默认值 = -1>
    参数 图标高度 <类型 = 整数 注释 = "默认不修改原大小" @默认值 = -1>
    参数 标题与图标间距 <类型 = 整数 注释 = "标题与图标之间的距离" @默认值 = 5>
    参数 样式 <类型 = 整数 注释 = "1、图标左＋标题右　2、图标上＋标题下" @默认值 = 1>
    {
        如果真 (图标.取字节集长度 () > 0)
        {
            变量类.图标 = 图标
        }
        如果真 (图标宽度 != -1)
        {
            变量类.图标宽度 = 图标宽度
        }
        如果真 (图标高度 != -1)
        {
            变量类.图标高度 = 图标高度
        }
        变量类.标题与图标间距 = 标题与图标间距
        变量类.样式 = 样式
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        刷新按钮 ()
    }

    方法 创建按钮 <公开 折叠>
    参数 绑定容器 <类型 = 窗口容器组件>
    参数 标题 <类型 = 文本型>
    参数 字体名称 <类型 = 文本型 @默认值 = "微软雅黑">
    参数 字体大小 <类型 = 整数 @默认值 = 12>
    参数 标题颜色 <类型 = 整数 @默认值 = 颜色类.黑色>
    参数 图标 <类型 = 字节集类 注释 = "留空则不会有图标" @默认值 = 空对象>
    参数 图标宽度 <类型 = 整数 @默认值 = 20>
    参数 图标高度 <类型 = 整数 @默认值 = 20>
    参数 标题与图标间距 <类型 = 整数 注释 = "标题与图标之间的距离" @默认值 = 5>
    参数 样式 <类型 = 整数 注释 = "1、图标左＋标题右　2、图标上＋标题下" @默认值 = 1>
    参数 圆角度数 <类型 = 小数 注释 = "按钮圆角度数" @默认值 = 3>
    参数 显示边框 <类型 = 逻辑型 @默认值 = 真>
    参数 标记值 <类型 = 整数 @默认值 = 0>
    {
        创建组件 (绑定容器, 0, 0, 绑定容器.宽度, 绑定容器.高度, )
        令牌 = GP初始类.初始化 ()
        初始处理 ()
        变量类.标题 = 标题
        变量类.宽度 = 绑定容器.宽度
        变量类.高度 = 绑定容器.高度
        变量类.圆角度数 = 圆角度数
        变量类.字体名称 = 字体名称
        变量类.字体大小 = 字体大小
        变量类.标题颜色 = 标题颜色
        变量类.标题与图标间距 = 标题与图标间距
        变量类.样式 = 样式
        变量类.显示边框 = 显示边框
        变量类.标记值 = 标记值
        如果真 (图标.取字节集长度 () > 0)
        {
            变量类.图标 = 图标
        }
        如果真 (图标宽度 != -1)
        {
            变量类.图标宽度 = 图标宽度
        }
        如果真 (图标高度 != -1)
        {
            变量类.图标高度 = 图标高度
        }
        程_窗口句柄 = 取窗口句柄 ()
        显示画板.创建 (1, 1, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置文本渲染模式 (GP文本渲染模式.抗锯齿和hinting技术)
        后台图像.创建自像素格式 (1, 1)
        绘制画板.创建自图像 (后台图像)
        刷新设置 ()
    }

    方法 圆角度数 <公开 属性读 类型 = 小数 折叠>
    {
        返回 (变量类.圆角度数)
    }

    方法 圆角度数 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
