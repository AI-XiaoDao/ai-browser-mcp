类 父卷帘模板类 <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"自定义组件库.附加类\"" @视窗.布局 = "client_size = \"245, 77\""
        底色 = 0x3D241F>
{
    变量 组件布局器_根容器 <公开 类型 = 组件布局器 折叠2 编辑时信息 = "A1107, 0, 0, 0" 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"0, 0, 144, 35\""
            底色 = 0x3D241F 标准鼠标指针 = 手型>
    变量 标签_右图2 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\nparent_id = 101\r\npos = \"120, 8, 24, 24\"" 底图方式 = 图片居中 可视 = 假
            标准鼠标指针 = 手型>
    变量 标签_横条 <公开 类型 = 标签 折叠2 编辑时信息 = "A1107, 0, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 103\r\nparent_id = 101\r\npos = \"0, 3, 80, 1\"" 底图 = "tb\\横条.png" 底图方式 = 缩放图片 标准鼠标指针 = 手型>
    变量 标签_左图 <公开 类型 = 标签 折叠2 编辑时信息 = "A1107, 0, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 104\r\nparent_id = 101\r\npos = \"16, 8, 40, 24\"" 底图方式 = 图片居中 标准鼠标指针 = 手型>
    变量 标签_右图 <公开 类型 = 标签 折叠2 编辑时信息 = "A1107, 0, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 105\r\nparent_id = 101\r\npos = \"88, 10, 24, 24\"" 底图方式 = 图片居中 标准鼠标指针 = 手型>
    变量 标签_标题 <公开 类型 = 标签 折叠2 编辑时信息 = "A1107, 0, 0, 0" 隐藏值属性 = "0"
            @视窗.布局 = "id = 106\r\nparent_id = 101\r\npos = \"40, 10, 40, 24\"" 底图方式 = 图片居中 标准鼠标指针 = 手型>
    变量 标签_左图2 <公开 类型 = 标签 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 107\r\nparent_id = 101\r\npos = \"3, 12, 40, 24\"" 底图方式 = 图片居中
            背景颜色 = 0x5D4A3D 标准鼠标指针 = 手型>
    变量 移入移出 <类型 = 组件移入移出事件类_>
    变量 当前父标题触发颜色 <公开 类型 = 整数>
    变量 当前父标题热点颜色 <公开 类型 = 整数>
    变量 当前索引 <公开 类型 = 整数>
    变量 当前标记 <公开 类型 = 文本型>
    变量 双击打开 <公开 类型 = 逻辑型>

    方法 排序布局 <公开>
    参数 父项高度 <类型 = 整数>
    参数 父标题左侧间隔 <类型 = 整数>
    参数 图标隐藏方式 <类型 = 整数 注释 = "0、全显 1、隐藏左图 2、隐藏右图 3、全部隐藏">
    参数 父项左图标左侧间隔 <类型 = 整数>
    参数 父项右图标右侧间隔 <类型 = 整数>
    参数 父项提醒图标右侧间隔 <类型 = 整数>
    参数 父索引 <类型 = 整数 @默认值 = -1>
    参数 父标记 <类型 = 文本型 @默认值 = "">
    参数 越过父索引和标记 <类型 = 逻辑型 @默认值 = 假>
    {
        组件布局器_根容器.移动 (0, 0, 本对象.宽度, 父项高度)
        标签_横条.移动 (0, 0, 本对象.宽度, )
        标签_左图.移动 (0, 0, 父项高度, 父项高度)
        标签_左图2.移动 (0, 0, 父项高度, 父项高度)
        标签_右图.移动 (0, 0, 父项高度, 父项高度)
        标签_右图2.移动 (本对象.宽度 - 标签_右图2.宽度 - 父项提醒图标右侧间隔, (父项高度 - 标签_右图2.高度) / 2, , )
        如果 (图标隐藏方式 == 0)
        {
            标签_左图.移动 (父项左图标左侧间隔, , , )
            标签_右图.移动 (本对象.宽度 - 标签_左图.高度 - 父项右图标右侧间隔, , , )
            标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 父标题左侧间隔, 1, 本对象.宽度 - 标签_左图.左边 - 标签_左图.高度 * 2 - 父标题左侧间隔 - 父项右图标右侧间隔, 父项高度 - 1)
        }
        否则 (图标隐藏方式 == 1)
        {
            标签_左图.可视 = 假
            标签_左图2.可视 = 假
            标签_右图.移动 (本对象.宽度 - 标签_右图.高度 - 父项右图标右侧间隔, , , )
            标签_标题.移动 (父标题左侧间隔, 1, 本对象.宽度 - 标签_左图.高度 * 2 - 父标题左侧间隔 - 父项右图标右侧间隔, 父项高度 - 1)
        }
        否则 (图标隐藏方式 == 2)
        {
            标签_右图.可视 = 假
            标签_左图.移动 (父项左图标左侧间隔, , , )
            标签_标题.移动 (标签_左图.左边 + 标签_左图.宽度 + 父标题左侧间隔, 1, 本对象.宽度 - 标签_左图.左边 - 标签_左图.高度 - 父标题左侧间隔 - 父项提醒图标右侧间隔, 父项高度 - 1)
        }
        否则
        {
            标签_左图.可视 = 假
            标签_左图2.可视 = 假
            标签_右图.可视 = 假
            标签_标题.移动 (父标题左侧间隔, 1, 本对象.宽度 - 父项右图标右侧间隔, 父项高度 - 1)
        }
        如果真 (越过父索引和标记 == 假)
        {
            如果真 (父索引 > -1)
            {
                当前索引 = 父索引
            }
            当前标记 = 父标记
        }
    }

    方法 组件布局器_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件布局器>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 组件布局器_根容器)
        {
            鼠标位置移动 (横向位置, 纵向位置)
        }
        返回 (0)
    }

    方法 标签_鼠标位置被移动 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 标签>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 标签_横条)
        {
            鼠标位置移动 (横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_左图)
        {
            鼠标位置移动 (标签_左图.左边 + 横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_左图2)
        {
            鼠标位置移动 (横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_右图)
        {
            鼠标位置移动 (标签_右图.左边 + 横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_右图2)
        {
            鼠标位置移动 (标签_右图2.左边 + 横向位置, 纵向位置)
        }
        否则 (来源对象 == 标签_标题)
        {
            鼠标位置移动 (标签_标题.左边 + 横向位置, 纵向位置)
        }
        返回 (0)
    }

