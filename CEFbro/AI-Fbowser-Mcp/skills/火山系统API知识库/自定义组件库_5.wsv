    方法 显示样式 <公开 属性读 类型 = 开关显示样式 折叠>
    {
        返回 (样式类型)
    }

    方法 显示样式 <公开 属性写 折叠 @视窗.设置时机 = 组件创建前>
    参数 所欲设置的样式 <类型 = 开关显示样式>
    {
        常量 单显型 <类型 = 文本型 值 = "单显型">
        常量 双显型 <类型 = 文本型 值 = "双显型">
        变量 局部样式 <类型 = 文本型>
        样式类型 = 所欲设置的样式
        局部样式 = (文本型)所欲设置的样式
        如果 (所欲设置的样式 == 开关显示样式.单显型 || 局部样式 == "单显型")
        {
            变量类.样式 = 1
        }
        否则 (所欲设置的样式 == 开关显示样式.双显型 || 局部样式 == "双显型")
        {
            变量类.样式 = 2
        }
        否则 (所欲设置的样式 == 开关显示样式.双显型 || 局部样式 == "双显型2")
        {
            变量类.样式 = 3
        }
    }

    方法 组件提示信息 <公开 属性写 注释 = "设置当鼠标移动到本组件上时所显示的提示文本信息" 折叠>
    参数 提示文本内容 <类型 = 文本型 注释 = "提供具体的提示文本内容,为空文本清除已有提示文本.">
    {
        本对象.提示信息 = 提示文本内容
    }

    方法 初始处理 <折叠>
    {
        显示画板.销毁 ()
        绘制画板.销毁 ()
        后台图像.销毁 ()
    }

    方法 开关按钮类__组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 开关按钮类_>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        出入.监视组件_ (本对象, 消息值)
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        如果真 (消息值 == 0x0008)  // WM_KILLFOCUS
        {
            鼠标被按下 = 假
            绘制开关 (假, 假)
            按钮区移入移出事件 (假)
            返回 (0)
        }
        分支判断 (消息值)
        {
            分支 (20)  // WM_ERASEBKGND
            {
                @ SetBkMode((HDC)@<消息参数1>,1);
                返回 (1)
            }
            分支 (15)  // WM_PAINT
            {
                绘制开关 ()
                变量 ret <类型 = 整数>
                @ LRESULT dwp=DefWindowProc((HWND)@<窗口句柄>,@<消息值>,(WPARAM)@<消息参数1>,(LPARAM)@<消息参数2>);
                @ @<ret>=(int)dwp;
                返回 (ret)
            }
        }
        返回 (0)
    }

    方法 刷新设置 <折叠>
    {
        变量 rect <类型 = 矩形类>
        程_窗口句柄 = 取窗口句柄 ()
        @ RECT rec;
        @ GetClientRect((HWND)@<程_窗口句柄>,&rec);
        @ @<rect.设置>(rec.left,rec.top,rec.right,rec.bottom);
        程_父窗口宽 = rect.宽度
        程_父窗口高 = rect.高度
        显示画板.销毁 ()
        显示画板.创建 (程_父窗口宽, 程_父窗口高, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        绘制画板.销毁 ()
        后台图像.销毁 ()
        后台图像.创建自像素格式 (程_父窗口宽, 程_父窗口高, )
        绘制画板.创建自图像 (后台图像)
        按钮区范围.左边 = 0
        按钮区范围.顶边 = 0
        按钮区范围.宽度 = 程_父窗口宽
        按钮区范围.高度 = 程_父窗口高
        变量类.宽度 = 按钮区范围.宽度
        变量类.高度 = 按钮区范围.高度
    }

    方法 开关按钮类__将被销毁 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 开关按钮类_>
    参数 标记值 <类型 = 整数>
    {
        初始处理 ()
        程_窗口句柄 = 0
        GP初始类.卸载 (令牌)
        返回 (0)
    }

    方法 开关按钮类__尺寸被改变 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 开关按钮类_>
    参数 标记值 <类型 = 整数>
    {
        刷新设置 ()
        返回 (0)
    }

    方法 绘制开关 <折叠>
    参数 按钮区 <类型 = 逻辑型 注释 = "鼠标离开按钮区范围恢复原色" @默认值 = 假>
    参数 左键单击 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 位图 <类型 = GP位图类>
        变量 左上角 <类型 = 坐标F>
        变量 左下角 <类型 = 坐标F>
        变量 相对父窗口 <类型 = 矩形类>
        变量 渐变画刷 <类型 = GP线性渐变画刷类>
        变量 路径 <类型 = GP路径类>
        变量 画笔 <类型 = GP画笔类>
        变量 画刷 <类型 = GP纯色画刷类>
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        左上角.X = 按钮区范围.左边
        左上角.Y = 按钮区范围.顶边
        左下角.X = 按钮区范围.左边
        左下角.Y = 按钮区范围.顶边 + 按钮区范围.高度
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置文本渲染模式 (GP文本渲染模式.抗锯齿和hinting技术)
        如果真 (变量类.是否打开)
        {
            变量类.是否打开 = 假
            变量类.已打开 = 真
        }
        如果 (左键单击)
        {
            变量类.已打开 = 取反 (变量类.已打开)
        }
        // 绘制框体
        如果 (按钮区 == 真)
        {
            如果 (左键单击)
            {
                如果 (变量类.已打开)
                {
                    如果 (变量类.样式 == 1)
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点开起点色, 变量类.热点开起点透明度 + 70), GP颜色.到ARGB (变量类.热点开终点色, 变量类.热点开终点透明度))
                    }
                    否则
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点关起点色, 变量类.热点关起点透明度 + 70), GP颜色.到ARGB (变量类.热点关终点色, 变量类.热点关终点透明度))
                    }
                }
                否则
                {
                    如果 (变量类.样式 == 1)
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点关起点色, 变量类.热点关起点透明度 + 70), GP颜色.到ARGB (变量类.热点关终点色, 变量类.热点关终点透明度))
                    }
                    否则
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点关起点色, 变量类.热点关起点透明度 + 70), GP颜色.到ARGB (变量类.热点关终点色, 变量类.热点关终点透明度))
                    }
                }
            }
            否则
            {
                如果 (变量类.已打开)
                {
                    如果 (变量类.样式 == 1)
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点开起点色, 变量类.热点开起点透明度), GP颜色.到ARGB (变量类.热点开终点色, 变量类.热点开终点透明度))
                    }
                    否则
                    {
                        渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点关起点色, 变量类.热点关起点透明度), GP颜色.到ARGB (变量类.热点关终点色, 变量类.热点关终点透明度))
                    }
                }
                否则
                {
                    渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点关起点色, 变量类.热点关起点透明度), GP颜色.到ARGB (变量类.热点关终点色, 变量类.热点关终点透明度))
                }
            }
        }
        否则
        {
            如果 (变量类.已打开)
            {
                如果 (变量类.样式 == 1)
                {
                    渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常开起点色, 变量类.正常开起点透明度), GP颜色.到ARGB (变量类.正常开终点色, 变量类.正常开终点透明度))
                }
                否则
                {
                    渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常关起点色, 变量类.正常关起点透明度), GP颜色.到ARGB (变量类.正常关终点色, 变量类.正常关终点透明度))
                }
            }
            否则
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常关起点色, 变量类.正常关起点透明度), GP颜色.到ARGB (变量类.正常关终点色, 变量类.正常关终点透明度))

            }
        }
        路径.创建 ()
        路径.添加圆角矩形 (0, 0, 变量类.宽度 - 1, 变量类.高度 - 1, 变量类.圆角度数, 变量类.圆角度数)
        绘制画板.填充路径 (渐变画刷, 路径)

        // 外边框
        画笔.创建自颜色 (GP颜色.到ARGB (变量类.外边框色, 变量类.外边框透明度), 1)  // 框体外框
        绘制画板.画路径 (画笔, 路径)
        路径.创建 ()
        路径.添加圆角矩形 (0, 0, 变量类.宽度 - 1, 变量类.高度 - 1, 变量类.圆角度数, 变量类.圆角度数)
        绘制画板.画路径 (画笔, 路径)

        // 绘制圆按钮
        变量 圆大小 <类型 = 小数>
        变量 圆大小2 <类型 = 小数>
        变量 圆左侧 <类型 = 小数>
        圆大小 = 变量类.高度 - 6
        圆大小2 = (变量类.宽度 - 4) / 2
        路径.创建 ()
        如果 (变量类.样式 == 1)
        {
            如果 (变量类.已打开)
            {
                圆左侧 = 变量类.宽度 - 圆大小 - 4
                路径.添加椭圆 (圆左侧, (变量类.高度 - 圆大小) / 2 - 0.7, 圆大小, 圆大小)
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.开关开颜色))
                变量类.开关状态 = 假
            }
            否则
            {
                圆左侧 = 3
                路径.添加椭圆 (圆左侧, (变量类.高度 - 圆大小) / 2 - 0.7, 圆大小, 圆大小)
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.开关关颜色))
                变量类.开关状态 = 真
            }
            画笔.取画刷 (画刷)
            绘制画板.填充路径 (画刷, 路径)
        }
        否则
        {
            如果 (变量类.已打开)
            {
                圆左侧 = 变量类.宽度 - 圆大小2 - 3
                路径.添加圆角矩形 (圆左侧, 2, 圆大小2, 变量类.高度 - 5, 变量类.圆角度数 - 变量类.圆角差值, 变量类.圆角度数 - 变量类.圆角差值)
                如果 (变量类.样式 == 2)
                {
                    画笔.创建自颜色 (GP颜色.到ARGB (变量类.开关关颜色))
                }
                否则 (变量类.样式 == 3)
                {
                    画笔.创建自颜色 (GP颜色.到ARGB (变量类.开关开颜色))
                }
                变量类.开关状态 = 假
            }
            否则
            {
                圆左侧 = 2
                路径.添加圆角矩形 (2, 2, 圆大小2, 变量类.高度 - 5, 变量类.圆角度数 - 变量类.圆角差值, 变量类.圆角度数 - 变量类.圆角差值)
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.开关关颜色))
                变量类.开关状态 = 真
            }
            画笔.取画刷 (画刷)
            绘制画板.填充路径 (画刷, 路径)
        }

        // 画标题
        变量 测量矩形 <类型 = 矩形F>
        变量 字体类 <类型 = GP字体类>
        变量 文本格式 <类型 = GP文本格式类>
        变量类.字体加粗 = 真
        <折叠> 如果 (变量类.样式 == 1)
        {
            如果 (变量类.已打开)
            {
                画刷.创建 (GP颜色.到ARGB (变量类.打开标题颜色))
            }
            否则
            {
                画刷.创建 (GP颜色.到ARGB (变量类.关闭标题颜色))
            }
            如果 (变量类.字体加粗 == 真 && 变量类.字体斜体 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗倾斜)
            }
            否则 (变量类.字体加粗 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗)
            }
            否则 (变量类.字体斜体 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.倾斜)
            }
            否则
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小)
            }
            如果 (变量类.已打开)
            {
                绘制画板.测量文本矩形 (变量类.打开标题名, 字体类, 空对象, , 测量矩形)
                测量矩形.左边 = (圆左侧 - 测量矩形.宽度) / 2
            }
            否则
            {
                绘制画板.测量文本矩形 (变量类.关闭标题名, 字体类, 空对象, , 测量矩形)
                测量矩形.左边 = 圆左侧 + 圆大小 + (变量类.宽度 - 圆左侧 - 圆大小 - 测量矩形.宽度) / 2
            }
            测量矩形.顶边 = (变量类.高度 - 测量矩形.高度) / 2 + 变量类.校正值
            文本格式.创建格式 (GP文本格式标志.显示格式控制符)
            如果 (变量类.已打开)
            {
                绘制画板.画文本 (变量类.打开标题名, 字体类, 画刷, 测量矩形, 文本格式)
            }
            否则
            {
                绘制画板.画文本 (变量类.关闭标题名, 字体类, 画刷, 测量矩形, 文本格式)
            }
        }
        <折叠> 否则 (变量类.样式 == 2)
        {
            如果 (变量类.字体加粗 == 真 && 变量类.字体斜体 == 真)
            {
