    {
        变量 结果 <类型 = 整数 值 = -1>
        窗口组.枚举循环 ()
        {
            如果真 (窗口组.取枚举值 ().窗口句柄 == 窗口句柄)
            {
                结果 = 窗口组.取枚举值 ().子夹索引
                跳出循环
            }
        }
        返回 (结果)
    }

    方法 删除子夹_ <公开 类型 = 逻辑型 注释 = "同时关闭窗口" 折叠>
    参数 子夹索引 <类型 = 整数 注释 = "从0开始">
    {
        变量 结果 <类型 = 逻辑型>
        如果真 (全局量.全局锁定界面)
        {
            返回 (假)
        }
        结果 = 导航.删除子夹_ (子夹索引)
        如果真 (结果)
        {
            如果真 (窗口组.取成员数 () == 0)
            {
                全局量.记忆序 = -1
                标签_隐藏条.可视 = 假
                全局量.当前焦点句柄 = 0
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题)
            }
        }
        导航.置重画_ (假)
        返回 (结果)
    }

