    方法 生成滚动条动作 <类型 = 逻辑型 折叠>
    参数 lParam <类型 = 整数>
    参数 鼠标位置 <类型 = 整数 @默认值 = -1>
    {
        变量 每份宽 <类型 = 小数 注释 = "1% 的宽度(滚动条是100份)">
        变量 滚动槽高 <类型 = 整数>
        变量 局_鼠标 <类型 = 整数>
        如果真 (滑块范围.高度 == 1)
        {
            返回 (假)
        }
        如果 (鼠标位置 == -1)
        {
            局_鼠标 = 判断鼠标位置 (公用方法.取低位_ (lParam), 公用方法.取高位_ (lParam))
        }
        否则
        {
            局_鼠标 = 鼠标位置
        }
        如果 (局_鼠标 == (整数)滚动条常量.滚动条_滑块内)
        {
            滚动槽高 = 滚动条范围.高度 - 2 * 15 - 滑块范围.高度
            每份宽 = (程_最大位置 - 程_最小位置 + 1) / (小数)滚动槽高
            滑块范围.顶边 = 公用方法.取高位_ (lParam) - 鼠标滑块Y
            如果真 (滑块范围.顶边 < 15)
            {
                滑块范围.顶边 = 15
            }
            如果真 (滑块范围.顶边 > 滚动条范围.高度 - 滑块范围.高度 - 15)
            {
                滑块范围.顶边 = 滚动条范围.高度 - 滑块范围.高度 - 15
            }
            程_当前位置 = (整数)((滑块范围.顶边 - 15) * 每份宽)
            如果真 (程_当前位置 < 程_最小位置)
            {
                程_当前位置 = 程_最小位置
            }
            如果真 (程_当前位置 > 程_最大位置)
            {
                程_当前位置 = 程_最大位置
            }
            鼠标位置Y = 公用方法.取高位_ (lParam)
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_左上箭头内)
        {
            程_当前位置 = 程_当前位置 - 程_行改变值
            如果真 (程_当前位置 < 程_最小位置)
            {
                程_当前位置 = 程_最小位置
            }
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_右下箭头内)
        {
            程_当前位置 = 程_当前位置 + 程_行改变值
            如果真 (程_当前位置 > 程_最大位置)
            {
                程_当前位置 = 程_最大位置
            }
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_滚动槽内)
        {
            如果 (lParam == 0)
            {
                程_当前位置 = 程_当前位置 - 程_页改变值
                如果真 (程_当前位置 < 程_最小位置)
                {
                    程_当前位置 = 程_最小位置
                }
            }
            否则
            {
                程_当前位置 = 程_当前位置 + 程_页改变值
                如果真 (程_当前位置 > 程_最大位置)
                {
                    程_当前位置 = 程_最大位置
                }
            }
        }
        否则 (局_鼠标 == (整数)滚动条常量.滚动条_鼠标滚动)
        {
            如果 (lParam == 0)
            {
                程_当前位置 = 程_当前位置 - 选择 (程_页改变值 / 10 < 1, 1, 程_页改变值 / 10)
                如果真 (程_当前位置 < 程_最小位置)
                {
                    程_当前位置 = 程_最小位置
                }
            }
            否则
            {
                程_当前位置 = 程_当前位置 + 选择 (程_页改变值 / 10 < 1, 1, 程_页改变值 / 10)
                如果真 (程_当前位置 > 程_最大位置)
                {
                    程_当前位置 = 程_最大位置
                }
            }
        }
        刷新滑块坐标 ()
        绘制滚动条 ()
        如果真 (局_鼠标 != 0 && 滑块范围.高度 > 1)
        {
            如果真 (记忆位 != 程_当前位置)
            {
                位置被改变事件 (程_当前位置)
            }
            记忆位 = 程_当前位置
        }
        如果 (程_当前位置 == 程_最小位置 || 程_当前位置 == 程_最大位置)
        {
            返回 (假)
        }
        否则
        {
            返回 (真)
        }
    }

    方法 取滚动条范围 <类型 = 滚动条_尺寸 折叠>
    {
