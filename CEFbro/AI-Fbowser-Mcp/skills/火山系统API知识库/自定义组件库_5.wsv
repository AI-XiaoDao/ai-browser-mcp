    方法 公用尺寸变化 <折叠>
    {
        如果 (全局量.头部位置 == 1)
        {
            如果 (全局量.子夹头高度 < 1)
            {
                标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 0)
                标签_间隔条2.移动 (0, 0, 取用户区宽度 (), 0)
                导航.移动 (0, 0, 取用户区宽度 (), 0)
                组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 ())
            }
            否则
            {
                如果 (全局量.隐藏范围间隔类型 == 0)
                {
                    标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 1)
                    标签_间隔条2.移动 (0, 全局量.子夹头高度 + 1, 取用户区宽度 (), 1)
                    导航.移动 (0, 1, 取用户区宽度 (), 全局量.子夹头高度)
                    组件布局器_窗体区.移动 (0, 全局量.子夹头高度 + 2, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 2)
                }
                否则 (全局量.隐藏范围间隔类型 == 3)
                {
                    标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 0)
                    标签_间隔条2.移动 (0, 全局量.子夹头高度 + 1, 取用户区宽度 (), 0)
                    导航.移动 (0, 0, 取用户区宽度 (), 全局量.子夹头高度)
                    组件布局器_窗体区.移动 (0, 全局量.子夹头高度, 取用户区宽度 (), 取用户区高度 ())
                }
                否则 (全局量.隐藏范围间隔类型 == 1)
                {
                    标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 0)
                    标签_间隔条2.移动 (0, 全局量.子夹头高度, 取用户区宽度 (), 1)
                    导航.移动 (0, 0, 取用户区宽度 (), 全局量.子夹头高度)
                    组件布局器_窗体区.移动 (0, 全局量.子夹头高度 + 1, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 1)
                }
                否则 (全局量.隐藏范围间隔类型 == 2)
                {
                    标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 1)
                    标签_间隔条2.移动 (0, 全局量.子夹头高度 + 1, 取用户区宽度 (), 0)
                    导航.移动 (0, 1, 取用户区宽度 (), 全局量.子夹头高度)
                    组件布局器_窗体区.移动 (0, 全局量.子夹头高度 + 1, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 1)
                }
            }
        }
        否则
        {
            如果 (全局量.子夹头高度 < 1)
            {
                标签_间隔条1.移动 (0, 0, 取用户区宽度 (), 0)
                标签_间隔条2.移动 (0, 0, 取用户区宽度 (), 0)
                导航.移动 (0, 0, 取用户区宽度 (), 0)
                组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 ())
            }
            否则
            {
                如果 (全局量.隐藏范围间隔类型 == 0)
                {
                    组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 2)
                    导航.移动 (0, 组件布局器_窗体区.高度 + 1, 取用户区宽度 (), 全局量.子夹头高度)
                    标签_间隔条1.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 1)
                    标签_间隔条2.移动 (0, 导航.顶边 + 导航.高度, 取用户区宽度 (), 1)
                }
                否则 (全局量.隐藏范围间隔类型 == 3)
                {
                    组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度)
                    导航.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 全局量.子夹头高度)
                    标签_间隔条1.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 0)
                    标签_间隔条2.移动 (0, 导航.顶边 + 导航.高度, 取用户区宽度 (), 0)
                }
                否则 (全局量.隐藏范围间隔类型 == 1)
                {
                    组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 1)
                    导航.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 全局量.子夹头高度)
                    标签_间隔条1.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 0)
                    标签_间隔条2.移动 (0, 导航.顶边 + 导航.高度, 取用户区宽度 (), 1)
                }
                否则 (全局量.隐藏范围间隔类型 == 2)
                {
                    组件布局器_窗体区.移动 (0, 0, 取用户区宽度 (), 取用户区高度 () - 全局量.子夹头高度 - 1)
                    导航.移动 (0, 组件布局器_窗体区.高度 + 1, 取用户区宽度 (), 全局量.子夹头高度)
                    标签_间隔条1.移动 (0, 组件布局器_窗体区.高度, 取用户区宽度 (), 1)
                    标签_间隔条2.移动 (0, 导航.顶边 + 导航.高度, 取用户区宽度 (), 0)
                }
            }
        }
    }

