    方法 组件移入移出事件类2__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类2_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    参数 是否悬停 <类型 = 逻辑型 注释 = "鼠标是否停留在组件上，到达设置的时间时触发为真">
    {
        如果真 (是否悬停 == 假)
        {
            如果真 (是否移入 == 假 && 鼠标左键按下 == 假)
            {
                程_热点鼠标位 = 0
                绘制滚动条 (真)
            }
        }
        返回 (0)
    }
}

类 横向滚动条类2_ <公开 基础类 = 组件布局器 折叠 折叠2 隐藏值属性 = "1" @文档 = "category = \"自定义组件库.横向滚动条2\"" @视窗.布局 = "client_size = \"600, 26\""
        可停留焦点 = 真 透明 = 真>
{
    变量 时钟1 <类型 = 时钟 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"-71, 8, 26, 26\"">
