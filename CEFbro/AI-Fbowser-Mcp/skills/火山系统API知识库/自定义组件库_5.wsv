类 公用方法 <折叠 @文档 = "category = \"自定义组件库.附加类\"">
{
    方法 取低位_ <公开 类型 = 短整数 折叠>
    参数 数值 <类型 = 整数>
    {
        返回 ((短整数)位与 (数值, 65535))
    }

    方法 取高位_ <公开 类型 = 短整数 折叠>
    参数 数值 <类型 = 整数>
    {
        返回 ((短整数)位右移 (数值, 16))
    }

    方法 颜色叠加运算 <公开 类型 = 整数 注释 = "返回叠加后的RGB颜色，RGB颜色叠加，可画出类似半透明的效果" 折叠>
    参数 背景色 <类型 = 整数 注释 = "RGB颜色">
    参数 叠加颜色 <类型 = 整数 注释 = "RGB颜色">
    参数 叠加透明度 <类型 = 整数 注释 = "0到255，0表示叠加色完全透明，255表示叠加色完全覆盖背景色。">
    {
        变量 颜色1 <类型 = 字节集类>
        变量 颜色2 <类型 = 字节集类>
        变量 R <类型 = 整数>
        变量 G <类型 = 整数>
        变量 B <类型 = 整数>
        颜色1 = 到字节集 (背景色)
        颜色2 = 到字节集 (叠加颜色)
        R = 无符号字节到整数 (颜色1.取字节集数据 (0, 字节)) + (无符号字节到整数 (颜色2.取字节集数据 (0, 字节)) - 无符号字节到整数 (颜色1.取字节集数据 (0, 字节))) * 叠加透明度 / 255
        G = 无符号字节到整数 (颜色1.取字节集数据 (1, 字节)) + (无符号字节到整数 (颜色2.取字节集数据 (1, 字节)) - 无符号字节到整数 (颜色1.取字节集数据 (1, 字节))) * 叠加透明度 / 255
        B = 无符号字节到整数 (颜色1.取字节集数据 (2, 字节)) + (无符号字节到整数 (颜色2.取字节集数据 (2, 字节)) - 无符号字节到整数 (颜色1.取字节集数据 (2, 字节))) * 叠加透明度 / 255
        返回 (取颜色值 (R, G, B))
    }
}

