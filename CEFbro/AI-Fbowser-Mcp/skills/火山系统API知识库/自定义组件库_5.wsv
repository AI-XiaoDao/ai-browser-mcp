    方法 初始处理 <折叠>
    {
        显示画板.销毁 ()
        绘制画板.销毁 ()
        后台图像.销毁 ()
    }

    方法 按钮类__组件消息过滤 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 按钮类_>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        出入.监视组件_ (本对象, 消息值)
        如果真 (消息值 == 0x0087)  // WM_GETDLGCODE
        {
            返回 (1)
        }
        如果真 (消息值 == 0x0008)  // WM_KILLFOCUS
        {
            鼠标被按下 = 假
            绘制按钮 (假, 假)
            按钮区移入移出事件 (假)
            返回 (0)
        }
        分支判断 (消息值)
        {
            分支 (20)  // WM_ERASEBKGND
            {
                @ SetBkMode((HDC)@<消息参数1>,1);
                返回 (1)
            }
            分支 (15)  // WM_PAINT
            {
                绘制按钮 ()
                变量 ret <类型 = 整数>
                @ LRESULT dwp=DefWindowProc((HWND)@<窗口句柄>,@<消息值>,(WPARAM)@<消息参数1>,(LPARAM)@<消息参数2>);
                @ @<ret>=(int)dwp;
                返回 (ret)
            }
        }
        如果真 (消息值 == 0x0200)
        {
            如果真 (鼠标被按下)
            {
                返回 (0)
            }
            鼠标位置移动事件 (全局横向位置, 全局纵向位置)
            绘制按钮 (真, 鼠标被按下)
        }
        返回 (0)
    }

    方法 刷新设置 <折叠>
    {
        变量 rect <类型 = 矩形类>
        程_窗口句柄 = 取窗口句柄 ()
        @ RECT rec;
        @ GetClientRect((HWND)@<程_窗口句柄>,&rec);
        @ @<rect.设置>(rec.left,rec.top,rec.right,rec.bottom);
        程_父窗口宽 = rect.宽度
        程_父窗口高 = rect.高度
        显示画板.销毁 ()
        显示画板.创建 (程_父窗口宽, 程_父窗口高, )
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        绘制画板.销毁 ()
        后台图像.销毁 ()
        后台图像.创建自像素格式 (程_父窗口宽, 程_父窗口高, )
        绘制画板.创建自图像 (后台图像)
        按钮区范围.左边 = 0
        按钮区范围.顶边 = 0
        按钮区范围.宽度 = 程_父窗口宽
        按钮区范围.高度 = 程_父窗口高
        变量类.宽度 = 按钮区范围.宽度
        变量类.高度 = 按钮区范围.高度
    }

    方法 按钮类__将被销毁 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 按钮类_>
    参数 标记值 <类型 = 整数>
    {
        初始处理 ()
        程_窗口句柄 = 0
        GP初始类.卸载 (令牌)
        返回 (0)
    }

    方法 按钮类__尺寸被改变 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 按钮类_>
    参数 标记值 <类型 = 整数>
    {
        刷新设置 ()
        返回 (0)
    }

    方法 绘制按钮 <折叠>
    参数 按钮区 <类型 = 逻辑型 注释 = "鼠标离开按钮区范围恢复原色" @默认值 = 假>
    参数 左键单击 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 位图 <类型 = GP位图类>
        变量 左上角 <类型 = 坐标F>
        变量 左下角 <类型 = 坐标F>
        变量 图宽 <类型 = 整数>
        变量 图高 <类型 = 整数>
        变量 图X <类型 = 小数>
        变量 图Y <类型 = 小数>
        变量 相对父窗口 <类型 = 矩形类>
        变量 渐变画刷 <类型 = GP线性渐变画刷类>
        变量 路径 <类型 = GP路径类>
        变量 画笔 <类型 = GP画笔类>
        变量 文本格式 <类型 = GP文本格式类>
        变量 画刷 <类型 = GP纯色画刷类>
        变量 字体类 <类型 = GP字体类>
        变量 测量矩形 <类型 = 矩形F>
        绘制画板.清除 (GP颜色.到ARGB (变量类.背景色, ))
        左上角.X = 按钮区范围.左边
        左上角.Y = 按钮区范围.顶边
        左下角.X = 按钮区范围.左边
        左下角.Y = 按钮区范围.顶边 + 按钮区范围.高度
        显示画板.置平滑模式 (GP平滑模式.抗锯齿)
        显示画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置平滑模式 (GP平滑模式.抗锯齿)
        绘制画板.置算法模式 (GP算法模式.高质量双线性)
        绘制画板.置文本渲染模式 (GP文本渲染模式.抗锯齿和hinting技术)
        // 绘制按钮
        如果 (按钮区 == 真)
        {
            如果 (左键单击 == 假)
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.热点起点色, 变量类.热点起点透明度), GP颜色.到ARGB (变量类.热点终点色, 变量类.热点终点透明度))  // 按钮区外
            }
            否则
            {
                渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.按下起点色, 变量类.按下起点透明度), GP颜色.到ARGB (变量类.按下终点色, 变量类.按下终点透明度))  // 按钮区外
            }
        }
        否则
        {
            渐变画刷.创建 (左上角, 左下角, GP颜色.到ARGB (变量类.正常起点色, 变量类.正常起点透明度), GP颜色.到ARGB (变量类.正常终点色, 变量类.正常终点透明度))  // 按钮区外
        }
        路径.创建 ()
        路径.添加圆角矩形 (0, 0, 变量类.宽度 - 1, 变量类.高度 - 1, 变量类.圆角度数, 变量类.圆角度数)
        绘制画板.填充路径 (渐变画刷, 路径)
        如果真 (变量类.显示边框 == 真)
        {
            如果 (按钮区 == 真)
            {
                如果 (左键单击 == 假)
                {
                    画笔.创建自颜色 (GP颜色.到ARGB (变量类.热点边框色, 变量类.热点边框透明度), 1)  // 按钮外框
                }
                否则
                {
                    画笔.创建自颜色 (GP颜色.到ARGB (变量类.按下边框色, 变量类.按下边框透明度), 1)  // 按钮外框
                }
                绘制画板.画路径 (画笔, 路径)
                路径.创建 ()
                路径.添加圆角矩形 (0, 0, 变量类.宽度 - 1, 变量类.高度 - 1, 变量类.圆角度数, 变量类.圆角度数)
            }
            否则
            {
                画笔.创建自颜色 (GP颜色.到ARGB (变量类.正常边框色, 变量类.正常边框透明度))  // 按钮外框
                绘制画板.画路径 (画笔, 路径)
                路径.创建 ()
                路径.添加圆角矩形 (0, 0, 变量类.宽度 - 1, 变量类.高度 - 1, 变量类.圆角度数, 变量类.圆角度数)
            }
            绘制画板.画路径 (画笔, 路径)
        }

        // 画图标
        如果真 (变量类.图标.取字节集长度 () > 0)
        {
            位图.创建自字节集 (变量类.图标)
            图宽 = 变量类.图标宽度
            图高 = 变量类.图标高度
        }

        // 画标题
        如果 (变量类.隐藏标题 == 假)
        {
            画刷.创建 (GP颜色.到ARGB (变量类.标题颜色))
            如果 (变量类.字体加粗 == 真 && 变量类.字体斜体 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗倾斜)
            }
            否则 (变量类.字体加粗 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.加粗)
            }
            否则 (变量类.字体斜体 == 真)
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小, GP字体风格.倾斜)
            }
            否则
            {
                字体类.创建自名称 (变量类.字体名称, 变量类.字体大小)
            }
            绘制画板.测量文本矩形 (变量类.标题, 字体类, 空对象, , 测量矩形)
            如果 (变量类.样式 == 1)
            {
                如果 (变量类.图标.取字节集长度 () > 0)
                {
                    图X = (变量类.宽度 - 图宽 - 测量矩形.宽度 - (小数)变量类.标题与图标间距 / 2) / 2
                    图Y = (变量类.高度 - 图高) / 2
                    测量矩形.左边 = 图宽 + 图X + (小数)变量类.标题与图标间距 / 2
                }
                否则
                {
                    测量矩形.左边 = (变量类.宽度 - 测量矩形.宽度) / 2
                }
                测量矩形.顶边 = (变量类.高度 - 测量矩形.高度) / 2 + 变量类.校正值
            }
            否则
            {
                如果 (变量类.图标.取字节集长度 () > 0)
                {
                    图X = (变量类.宽度 - 图宽) / 2
                    图Y = (变量类.高度 - 图高 - 测量矩形.高度 - (小数)变量类.标题与图标间距 / 2) / 2
                    测量矩形.左边 = (变量类.宽度 - 测量矩形.宽度) / 2
                    测量矩形.顶边 = 图高 + 图Y + (小数)变量类.标题与图标间距 / 2 + 变量类.校正值
                }
                否则
                {
                    测量矩形.左边 = (变量类.宽度 - 测量矩形.宽度) / 2
                    测量矩形.顶边 = (变量类.高度 - 测量矩形.高度) / 2 + 变量类.校正值
                }
            }
            文本格式.创建格式 (GP文本格式标志.显示格式控制符)
            文本格式.置对齐 (GP文本对齐.居中)
            绘制画板.画文本 (变量类.标题, 字体类, 画刷, 测量矩形, 文本格式)
            如果真 (变量类.图标.取字节集长度 () > 0)
            {
                绘制画板.画图像矩形 (位图, 图X, 图Y, 图宽, 图高)
            }
        }
        否则
        {
            绘制画板.画图像矩形 (位图, (变量类.宽度 - 图宽) / 2, (变量类.高度 - 图高) / 2, 图宽, 图高)
        }
        绘制画板.重置剪辑区 ()
        显示画板.画图像 (后台图像)
        变量 设备场景 <类型 = 变整数>
        @ HWND hwnd=(HWND)@<程_窗口句柄>;
        @ HDC hdc=GetDC(hwnd);
        @ @<设备场景>=(INT_P)hdc;
        显示画板.复制 (设备场景, , )
        @ ReleaseDC(hwnd, hdc);
        位图.销毁 ()
        渐变画刷.销毁 ()
        路径.销毁 ()
        画笔.销毁 ()
        画刷.销毁 ()
        字体类.销毁 ()
        文本格式.销毁 ()
    }

    方法 刷新按钮 <公开 注释 = "设置按钮后调用此命令，立即刷新生效" 折叠>
    {
        刷新设置 ()
        @ InvalidateRect((HWND)@<程_窗口句柄>,0,0);
    }

    方法 组件移入移出事件类2__鼠标事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 组件移入移出事件类2_>
    参数 标记值 <类型 = 整数>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    参数 是否悬停 <类型 = 逻辑型 注释 = "鼠标是否停留在组件上，到达设置的时间时触发为真">
    {
        如果真 (是否悬停 == 假)
        {
            如果真 (是否移入 == 假)
            {
                鼠标被按下 = 假
            }
            绘制按钮 (是否移入, 鼠标被按下)
            按钮区移入移出事件 (是否移入)
        }
        返回 (0)
    }

