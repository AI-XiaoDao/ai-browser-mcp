    }

    方法 日期 <公开 属性写 注释 = "  设置本组件的当前日期文本." 注释 = "  注意: 在某些组件中(譬如标签,按钮,选择框,单选框,分组框等),\'&\'字符本身不会被显示,"
            注释 = "而会导致其后方紧接的一个字符以下划线方式显示,表示Alt加该字符为此组件的快捷访问键." 注释 = "这种情况下如果需要显示\'&\'字符本身,需要使用连续两个该字符,即\"&&\"." 折叠 折叠2
            @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的标题 <类型 = 文本型 注释 = "提供所欲设置的标题文本">
    {
        日期框1.今天 = 到时间 (所欲设置的标题)
        日期值 = 日期框1.今天
        存放内容 = 所欲设置的标题
        组件_置日期框样式 (日期框1, 格式样式)
    }

    方法 日期样式 <公开 属性读 类型 = 日期样式类型 注释 = "返回日期框的样式类型" 折叠>
    {
        返回 (样式类型)
    }

    方法 日期样式 <公开 属性写 注释 = "短时间1：HH:mm:ss  ;" 注释 = "短时间2：HH:mm:ss dddd  ;" 注释 = "短日1：yyyy年MM月  ;" 注释 = "短日2：yyyy-MM  ;"
            注释 = "短日3：yyyy/MM  ;" 注释 = "短日期1：yyyy年MM月dd日  ;" 注释 = "短日期2：yyyy-MM-dd  ;" 注释 = "短日期3：yyyy/MM/dd  ;"
            注释 = "长日期1：yyyy-MM-dd HH:mm:ss  ;" 注释 = "长日期2：yyyy/MM/dd HH:mm:ss  ;" 注释 = "长日期3：yyyy/MM/dd HH:mm:ss dddd  ;"
            注释 = "长日期4：yyyy-MM-dd HH:mm:ss dddd  ;" 注释 = "长日期5：yyyy年MM月dd日 HH:mm:ss  ;" 注释 = "长日期6：yyyy年MM月dd日 HH时mm分ss秒  ;"
            注释 = "长日期7：yyyy年MM月dd日 HH:mm:ss dddd  ;" 注释 = "长日期8：yyyy年MM月dd日 HH时mm分ss秒 dddd" 折叠 折叠2 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的样式类型 <类型 = 日期样式类型>
    {
        常量 短时间1 <类型 = 文本型 值 = "HH:mm:ss">
        常量 短时间2 <类型 = 文本型 值 = "HH:mm:ss dddd">
        常量 短日1 <类型 = 文本型 值 = "yyyy年MM月">
        常量 短日2 <类型 = 文本型 值 = "yyyy-MM">
        常量 短日3 <类型 = 文本型 值 = "yyyy/MM">
        常量 短日期1 <类型 = 文本型 值 = "yyyy年MM月dd日">
        常量 短日期2 <类型 = 文本型 值 = "yyyy-MM-dd">
        常量 短日期3 <类型 = 文本型 值 = "yyyy/MM/dd">
        常量 长日期1 <类型 = 文本型 值 = "yyyy-MM-dd HH:mm:ss">
        常量 长日期2 <类型 = 文本型 值 = "yyyy/MM/dd HH:mm:ss">
        常量 长日期3 <类型 = 文本型 值 = "yyyy/MM/dd HH:mm:ss dddd">
        常量 长日期4 <类型 = 文本型 值 = "yyyy-MM-dd HH:mm:ss dddd">
        常量 长日期5 <类型 = 文本型 值 = "yyyy年MM月dd日 HH:mm:ss">
        常量 长日期6 <类型 = 文本型 值 = "yyyy年MM月dd日 HH时mm分ss秒">
        常量 长日期7 <类型 = 文本型 值 = "yyyy年MM月dd日 HH:mm:ss dddd">
        常量 长日期8 <类型 = 文本型 值 = "yyyy年MM月dd日 HH时mm分ss秒 dddd">
        变量 局部样式 <类型 = 文本型>
        样式类型 = 所欲设置的样式类型
        局部样式 = (文本型)所欲设置的样式类型
        如果 (所欲设置的样式类型 == 日期样式类型.短时间1 || 局部样式 == "短时间1")
        {
            格式样式 = 短时间1
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短时间2 || 局部样式 == "短时间2")
        {
            格式样式 = 短时间2
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日1 || 局部样式 == "短日1")
        {
            格式样式 = 短日1
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日2 || 局部样式 == "短日2")
        {
            格式样式 = 短日2
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日3 || 局部样式 == "短日3")
        {
            格式样式 = 短日3
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日期1 || 局部样式 == "短日期1")
        {
            格式样式 = 短日期1
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日期2 || 局部样式 == "短日期2")
        {
            格式样式 = 短日期2
        }
        否则 (所欲设置的样式类型 == 日期样式类型.短日期3 || 局部样式 == "短日期3")
        {
            格式样式 = 短日期3
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期1 || 局部样式 == "长日期1")
        {
            格式样式 = 长日期1
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期2 || 局部样式 == "长日期2")
        {
            格式样式 = 长日期2
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期3 || 局部样式 == "长日期3")
        {
            格式样式 = 长日期3
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期4 || 局部样式 == "长日期4")
        {
            格式样式 = 长日期4
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期5 || 局部样式 == "长日期5")
        {
            格式样式 = 长日期5
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期6 || 局部样式 == "长日期6")
        {
            格式样式 = 长日期6
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期7 || 局部样式 == "长日期7")
        {
            格式样式 = 长日期7
        }
        否则 (所欲设置的样式类型 == 日期样式类型.长日期8 || 局部样式 == "长日期8")
        {
            格式样式 = 长日期8
        }
        组件_置日期框样式 (日期框1, 格式样式)
    }

