        }
        如果真 (窗口是否已存在 (布局器.取窗口句柄 (), 返回的索引))
        {
            如果真 (返回的索引.值 == -1)
            {
                返回的索引.值 = 0
            }
            布局组.删除成员 (布局组.取成员数 () - 1)
            导航.跳转子夹_ (返回的索引.值, 真)
            如果真 (全局量.标题间隔符 != "")
            {
                窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
            }
            重定位遮挡 (返回的索引.值)
            导航.置重画_ (假)
            处理事件_ ()
            添加中 = 假
            互斥.解锁 ()
            返回 (-1)
        }
        索引 = 导航.添加子夹_ (子夹标题, 子夹图标, 子夹标记, 提示信息, 子夹宽度补充)
        夹信息.窗口句柄 = 布局器.取窗口句柄 ()
        夹信息.窗口名称 = 子夹标题
        夹信息.子夹标记 = 子夹标记
        夹信息.子夹索引 = 索引
        夹信息.是否跟随大小 = 是否跟随主窗大小
        窗口组.加入成员 (夹信息)
        如果 (全局量.已启动 == 假)
        {
            全局量.已启动 = 真
            线程.投递任务_ ()
        }
        如果真 (全局量.标题间隔符 != "")
        {
            窗口_置窗口组件标题 (取父窗口句柄 (), 全局量.主窗标题 + 全局量.标题间隔符 + 子夹标题)
        }
        窗口_置窗口组件焦点2 (布局器.取窗口句柄 ())
        重定位遮挡 (索引)
        导航.置重画_ (假)
        处理事件_ ()
        添加中 = 假
        互斥.解锁 ()
        子夹被改变事件 (临时索引, 索引)
        返回 (索引)
    }

