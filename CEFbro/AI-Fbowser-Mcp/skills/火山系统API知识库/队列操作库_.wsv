        @     return tmp;
        @ }

    }

    方法 弹出小数2_ <公开 类型 = 单精度小数 注释 = "单精度" 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @     if (ifloat.empty()) 
