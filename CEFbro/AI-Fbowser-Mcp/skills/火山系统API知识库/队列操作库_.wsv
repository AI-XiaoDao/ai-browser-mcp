    方法 线程类__线程事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程类_>
    参数 标记值 <类型 = 整数>
    参数 线程参数 <类型 = 变整数>
    {
        变量 类型 <类型 = 整数>
        变量 对象类内容 <类型 = 对象类>
        变量 对象数组类内容 <类型 = 对象数组类>
        变量 COM对象类内容 <类型 = COM对象类>
        变量 整数内容 <类型 = 整数>
        变量 小数内容 <类型 = 小数>
        变量 小数内容2 <类型 = 单精度小数>
        变量 变整数内容 <类型 = 变整数>
        变量 文本型内容 <类型 = 文本型>
        变量 字节集类内容 <类型 = 字节集类>
        判断循环 (线程状态 == 假)
        {
            如果真 (取对象类队列数_ () > 0)
            {
                类型 = 1
                对象类内容 = 弹出对象类_ ()
                队列事件_对象类 (对象类内容)
            }
            如果真 (取对象数组队列数_ () > 0)
            {
                类型 = 2
                对象数组类内容 = 弹出对象数组类_ ()
                队列事件_对象数组 (对象数组类内容)
            }
            如果真 (取COM对象队列数_ () > 0)
            {
                类型 = 3
                COM对象类内容 = 弹出COM对象类_ ()
                队列事件_COM对象 (COM对象类内容)
            }
            如果真 (取整数队列数_ () > 0)
            {
                类型 = 4
                整数内容 = 弹出整数_ ()
                队列事件_整数 (整数内容)
            }
            如果真 (取小数队列数_ () > 0)
            {
                类型 = 5
                小数内容 = 弹出小数_ ()
                队列事件_小数 (小数内容)
            }
            如果真 (取小数队列数2_ () > 0)
            {
                类型 = 6
                小数内容2 = 弹出小数2_ ()
                队列事件_小数2 (小数内容2)
            }
            如果真 (取变整数队列数_ () > 0)
            {
                类型 = 7
                变整数内容 = 弹出变整数_ ()
                队列事件_变整数 (变整数内容)
            }
            如果真 (取文本队列数_ () > 0)
            {
                类型 = 8
                文本型内容 = 弹出文本_ ()
                队列事件_文本 (文本型内容)
            }
            如果真 (取字节集队列数_ () > 0)
            {
                类型 = 9
                字节集类内容 = 弹出字节集_ ()
                队列事件_字节集 (字节集类内容)
            }
            队列事件_综合 (类型, 对象类内容, 对象数组类内容, COM对象类内容, 整数内容, 小数内容, 小数内容2, 变整数内容, 文本型内容, 字节集类内容)
            延迟_ (1)
        }
        返回 (0)
    }

    方法 队列事件_对象类 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 对象类>

    方法 队列事件_对象数组 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 对象数组类>

    方法 队列事件_COM对象 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = COM对象类>

    方法 队列事件_整数 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 整数>

    方法 队列事件_小数 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 小数>

    方法 队列事件_小数2 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 单精度小数>

    方法 队列事件_变整数 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 变整数>

    方法 队列事件_文本 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 文本型>

    方法 队列事件_字节集 <公开 定义事件 类型 = 整数 折叠>
    参数 事件内容 <类型 = 字节集类>

    方法 队列事件_综合 <公开 定义事件 类型 = 整数 折叠>
    参数 消息类型 <类型 = 整数 注释 = "1.对象类 2.对象数组 3.com对象 4.整数 5.双精度小数 6.单精度小数 7.变整数 8.文本 9.字节集">
    参数 对象类内容 <类型 = 对象类>
    参数 对象数组类内容 <类型 = 对象数组类>
    参数 COM对象类内容 <类型 = COM对象类>
    参数 整数内容 <类型 = 整数>
    参数 小数内容 <类型 = 小数>
    参数 小数内容2 <类型 = 单精度小数>
    参数 变整数内容 <类型 = 变整数>
    参数 文本型内容 <类型 = 文本型>
    参数 字节集类内容 <类型 = 字节集类>
}

