        @     return tmp;
        @ }

    }

    方法 弹出变整数_ <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @     if (iCVoBzs.empty()) 
        @     {
        @        return -1; 
        @     }
        @     @dt<变整数> tmp = iCVoBzs.front();
        @     iCVoBzs.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iCVoBzs.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return -1; 
        @     }
        @     @dt<变整数> tmp = iCVoBzs.front();
        @     iCVoBzs.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }


    }

    方法 弹出文本_ <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @     if (iCS.empty()) 
        @     {
        @        return -1; 
        @     }
        @     CWString tmp = iCS.front();
        @     iCS.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iCS.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return -1; 
        @     }
        @     CWString tmp = iCS.front();
        @     iCS.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }


    }

    方法 弹出字节集_ <公开 类型 = 字节集类 返回值注释 = "失败返回空字节集" 折叠 @禁止流程检查 = 真>
    {
        变量 空字节 <类型 = 字节集类>
        @ if(IFCRITICAL_SECTION==true){
        @     if (iCVolMem.empty()) 
        @     {
        @        return @<空字节>; 
        @     }
        @     @an<CVolMem> tmp = iCVolMem.front();
        @     iCVolMem.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iCVolMem.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return @<空字节>; 
        @     }
        @     @an<CVolMem> tmp = iCVolMem.front();
        @     iCVolMem.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }


    }

    方法 弹出COM对象类_ <公开 类型 = COM对象类 返回值注释 = "失败返回空对象" 折叠 @禁止流程检查 = 真>
    {
        变量 对象 <类型 = COM对象类>
        @ if(IFCRITICAL_SECTION==true){
        @     if (iCVolComObject.empty()) 
        @     {
        @        return @<对象>; 
        @     }
        @     @dt<COM对象类> tmp = iCVolComObject.front();
        @     iCVolComObject.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iCVolComObject.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return @<对象>; 
        @     }
        @     @dt<COM对象类> tmp = iCVolComObject.front();
        @     iCVolComObject.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }


    }

    方法 取对象类队列数_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {

        @ if(IFCRITICAL_SECTION==true){
        @ @dt<整数> a;
        @ a=(@dt<整数>)iCVolObject.size();
        @ return a;
        @ }
        @ else{
        @ @dt<整数> a;
        @ EnterCriticalSection(&m_CriticalSection);
        @ a=(@dt<整数>)iCVolObject.size();
        @ LeaveCriticalSection(&m_CriticalSection);
        @ return a;
        @ }

    }

    方法 取对象数组队列数_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @ @dt<整数> a;
        @ a=(@dt<整数>)iCVolObjectArray.size();
        @ return a;
        @ }
        @ else{
        @ @dt<整数> a;
        @ EnterCriticalSection(&m_CriticalSection);
        @ a=(@dt<整数>)iCVolObjectArray.size();
        @ LeaveCriticalSection(&m_CriticalSection);
        @ return a;
        @ }

    }

