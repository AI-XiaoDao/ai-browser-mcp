<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# ================================================================
# MCP回调类 — JS异步/字符串/截图/Cookie/DevTools/文件对话框/PDF/任务/VIP/URL/清理缓存/下载图片
# 被 MCP_Server.wsv 和 main.wsv 引用
# ================================================================
类 类_MCP_JS异步回调 <公开 基础类 = 类_FBrowser_JS回调>
{
    变量 任务ID <公开 类型 = 文本型>
    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 返回结果 <类型 = 类_FBrowser_列表值>
    {
        变量 结果文本 <类型 = 文本型>
        变量 返回值类型 <类型 = 整数 值 = JS返回值类型.无效>
        如果 (返回结果.是否有效 ())
        {
            返回值类型 = 返回结果.取整数值 (1)
            // JS返回值类型: 无效=-1 空值=0 整数值=1 文本值=2 逻辑值=3 双精度小数=4 时间文本=5 数组=6 数组缓存=7 方法=8 类=9
            如果 (返回值类型 == JS返回值类型.文本值)
            {
                结果文本 = 返回结果.取文本值 (2)
            }
            否则 (返回值类型 == JS返回值类型.逻辑值)
            {
                结果文本 = 到文本 (返回结果.取逻辑值 (2))
            }
            否则 (返回值类型 == JS返回值类型.整数值)
            {
                结果文本 = 到文本 (返回结果.取整数值 (2))
            }
            否则 (返回值类型 == JS返回值类型.双精度小数值)
            {
                结果文本 = 到文本 (返回结果.取双精度小数值 (2))
            }
            否则 (返回值类型 == JS返回值类型.空值)
            {
                结果文本 = "null"
            }
            否则 (返回值类型 == JS返回值类型.无效)
            {
                // V8无法序列化此返回值 (如DOM对象/函数/循环引用)
                // 尝试提取文本描述替代报错
                结果文本 = 返回结果.取文本值 (1)
                如果 (结果文本 == "")
                {
                    结果文本 = "[无法序列化的值] 建议使用 JSON.stringify() 包裹返回值, 或改用 execute_js"
                }
            }
            否则 (返回值类型 == JS返回值类型.时间文本值)
            {
                结果文本 = 返回结果.取文本值 (2)
            }
            否则 (返回值类型 == JS返回值类型.数组值 || 返回值类型 == JS返回值类型.数组缓存值)
            {
                结果文本 = "[array]"
            }
            否则 (返回值类型 == JS返回值类型.方法值 || 返回值类型 == JS返回值类型.类值)
            {
                结果文本 = "[function]"
            }
            否则
            {
                // 未知的返回值类型 (未来CEF版本可能新增) — 尝试文本提取
                结果文本 = 返回结果.取文本值 (1)
                如果 (结果文本 == "")
                {
                    结果文本 = "[未知类型:" + 到文本 (返回值类型) + "] 请联系开发者更新回调处理"
                }
            }
        }
        否则
        {
            结果文本 = "JS回调未返回有效结果 | 可能原因: 执行超时/V8环境不可用/跨域限制"
        }
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        如果 (返回值类型 == JS返回值类型.无效)
        {
            包装对象.加入逻辑值成员 ("success", 假)
            包装对象.加入文本成员 ("error", 结果文本)
        }
        否则
        {
            变量 语义失败 <类型 = 逻辑型 值 = 假>
            如果 (MCP命令服务器.JS消息是否表示失败 (结果文本, ""))
            {
                语义失败 = 真
            }
            如果 (语义失败)
            {
                包装对象.加入逻辑值成员 ("success", 假)
                包装对象.加入文本成员 ("error", 结果文本)
            }
            否则
            {
                包装对象.加入逻辑值成员 ("success", 真)
                包装对象.加入文本成员 ("message", 结果文本)
            }
        }
        MCP命令服务器.存储异步结果 (任务ID, 包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    #
}
# 元素存在后点击回调: browser_dom_click 原生链路 (存在检查→点击)
类 类_MCP_存在后点击回调 <公开 基础类 = 类_FBrowser_JS回调>
{
    变量 任务ID <公开 类型 = 文本型>
    变量 浏览器ID <公开 类型 = 整数>
    变量 选择器文本 <公开 类型 = 文本型>
    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 返回结果 <类型 = 类_FBrowser_列表值>
    {
        变量 存在 <类型 = 逻辑型 值 = 假>
        如果 (返回结果.是否有效 ())
        {
            变量 返回值类型 <类型 = 整数>
            返回值类型 = 返回结果.取整数值 (1)
            如果 (返回值类型 == JS返回值类型.逻辑值)
            {
                存在 = 返回结果.取逻辑值 (2)
            }
        }
        如果 (存在)
        {
            变量 bb <类型 = 类_FBrowser_浏览器>
            bb = FBrowser_浏览器_通过ID取浏览器 (浏览器ID)
            如果 (bb.是否为空 () == 假)
            {
                变量 ff <类型 = 类_FBrowser_填表框架>
                ff = bb.取主填表框架 ()
                如果 (ff.是否有效 ())
                {
                    ff.点击元素 (选择器文本, 0)
                }
            }
        }
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        包装对象.加入逻辑值成员 ("success", 存在)
        如果 (存在)
        {
            包装对象.加入文本成员 ("message", "已点击(原生): " + 选择器文本)
        }
        否则
        {
            包装对象.加入文本成员 ("error", "element not found: " + 选择器文本)
        }
        MCP命令服务器.存储异步结果 (任务ID, 包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    #
}
类 类_MCP_字符串异步回调 <公开 基础类 = 类_FBrowser_字符串回调>
{
    变量 任务ID <公开 类型 = 文本型>
    变量 最大字符数 <公开 类型 = 整数 值 = 262144 注释 = "与 MCP_常量.截断_源码默认字节 保持同步">
    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 文本 <类型 = 文本型>
    {
        变量 输出文本 <类型 = 文本型>
        输出文本 = 文本
        变量 原始长度 <类型 = 整数>
        原始长度 = 取文本长度 (文本)
        // 防止大源码撑爆mcp_result响应导致curl传输失败
        如果 (原始长度 > 最大字符数)
        {
            输出文本 = 取文本左边 (文本, 最大字符数) + "...\n\n[MCP: 源码已截断, 原始大小=" + 到文本 (原始长度) + " 字节, 截断至=" + 到文本 (最大字符数) + "]"
            调试输出 ("[MCP] 源码截断:", 原始长度, "->", 最大字符数)
        }
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        包装对象.加入逻辑值成员 ("success", 真)
        包装对象.加入文本成员 ("message", 输出文本)
        如果 (原始长度 > 最大字符数)
        {
            包装对象.加入整数成员 ("truncated", 原始长度)
            包装对象.加入整数成员 ("truncated_to", 最大字符数)
        }
        MCP命令服务器.存储异步结果 (任务ID, 包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    #
}
# ================================================================
# 步回调类
