<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# MCP_响应构建 — JSON响应辅助方法 (从 MCP_Server.wsv 抽取, 供委托桩调用)
类 MCP_响应构建 <公开 @全局类 = 真>
{
    # ── 核心响应包装 (被命令成功/失败等桩调用) ──
    方法 命令成功 <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 命令失败 <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 假)
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 响应_需要刷新 <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息 + " | " + MCP_常量.提示_需要刷新)
        对象.加入逻辑值成员 ("needs_reload", 真)
        对象.加入文本成员 ("_hint", "设置将在下次刷新/导航后生效")
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 命令成功_原始JSON <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 JSON片段 <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (构建带数据字段JSON (命令ID, 是否成功, JSON片段))
    }

    方法 构建标准成功JSON <静态 类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建标准失败JSON <静态 类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 假)
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建简单错误JSON <静态 类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建异步提交JSON <静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("_async", 真)
        对象.加入文本成员 ("task_id", 任务ID)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建命令嵌套JSON <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 嵌套键名 <类型 = 文本型>
    参数 嵌套JSON片段 <类型 = 文本型>
    {
        变量 头对象 <类型 = YYJSON对象类>
        头对象.创建自文本 ("{}")
        头对象.加入文本成员 ("id", 命令ID)
        头对象.加入逻辑值成员 ("success", 是否成功)
        变量 头JSON <类型 = 文本型>
        头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
        如果 (是否为合法JSON文档 (嵌套JSON片段))
        {
            返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"" + 嵌套键名 + "\":" + 嵌套JSON片段 + "}")
        }
        变量 完整 <类型 = YYJSON对象类>
        完整.创建自文本 ("{}")
        完整.加入文本成员 ("id", 命令ID)
        完整.加入逻辑值成员 ("success", 是否成功)
        完整.加入文本成员 (嵌套键名, 嵌套JSON片段)
        返回 (完整.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建带数据字段JSON <静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 数据片段 <类型 = 文本型>
    {
        返回 (构建命令嵌套JSON (命令ID, 是否成功, "data", 数据片段))
    }

    # ── JSON 辅助方法 ──
    方法 是否为合法JSON文档 <静态 类型 = 逻辑型>
    参数 文本 <类型 = 文本型>
    {
        如果 (文本 == "")
        {
            返回 (假)
        }
        变量 对象 <类型 = YYJSON只读对象类>
        如果 (对象.创建自文本 (文本))
        {
            返回 (真)
        }
        如果 (是否以 (文本, "["))
        {
            变量 包装 <类型 = 文本型>
            包装 = "{\"_a\":" + 文本 + "}"
            返回 (对象.创建自文本 (包装))
        }
        返回 (假)
    }

    方法 提取JSON对象体内 <静态 类型 = 文本型>
    参数 对象JSON <类型 = 文本型>
    {
        变量 长度 <类型 = 整数>
        长度 = 取文本长度 (对象JSON)
        如果 (长度 < 2 || 取文本左边 (对象JSON, 1) != "{")
        {
            返回 (对象JSON)
        }
        返回 (取文本右边 (取文本左边 (对象JSON, 长度 - 1), 长度 - 2))
    }

    方法 JSON转义文本 <静态 类型 = 文本型 注释 = "转义文本以便安全嵌入JSON双引号字符串">
    参数 源文本 <类型 = 文本型>
    {
        常量 JESC_BSLASH <类型 = 文本型 值 = "\\">
        常量 JESC_DQUOTE <类型 = 文本型 值 = "\"">
        常量 JESC_NEWLINE <类型 = 文本型 值 = "\n">
        常量 JESC_CR <类型 = 文本型 值 = "\r">
        常量 JREP_BSLASH <类型 = 文本型 值 = "\\\\">
        常量 JREP_DQUOTE <类型 = 文本型 值 = "\\\"">
        常量 JREP_NEWLINE <类型 = 文本型 值 = "\\n">
        常量 JREP_CR <类型 = 文本型 值 = "\\r">
        变量 结果 <类型 = 文本型>
        结果 = 源文本
        子文本替换 (结果, JESC_BSLASH, JREP_BSLASH, , , 假)
        子文本替换 (结果, JESC_DQUOTE, JREP_DQUOTE, , , 假)
        子文本替换 (结果, JESC_NEWLINE, JREP_NEWLINE, , , 假)
        子文本替换 (结果, JESC_CR, JREP_CR, , , 假)
        返回 (结果)
    }

    # ── 简单键值 JSON ──
    方法 构建简单JSON <静态 类型 = 文本型>
    参数 键名 <类型 = 文本型>
    参数 键值 <类型 = 文本型>
    {
        如果 (键名 == "network_logs" && 是否以 (键值, "["))
        {
            变量 头对象 <类型 = YYJSON对象类>
            头对象.创建自文本 ("{}")
            头对象.加入逻辑值成员 ("success", 真)
            变量 头JSON <类型 = 文本型>
            头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
            返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"network_logs\":" + 键值 + "}")
        }
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 (键名, 键值)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建双键JSON <静态 类型 = 文本型>
    参数 键名1 <类型 = 文本型>
    参数 键值1 <类型 = 文本型>
    参数 键名2 <类型 = 文本型>
    参数 键值2 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 (键名1, 键值1)
        对象.加入文本成员 (键名2, 键值2)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建逻辑值JSON <静态 类型 = 文本型>
    参数 键名 <类型 = 文本型>
    参数 键值 <类型 = 逻辑型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入逻辑值成员 (键名, 键值)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建整数值JSON <静态 类型 = 文本型>
    参数 键名 <类型 = 文本型>
    参数 键值 <类型 = 整数>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入整数成员 (键名, 键值)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    # ── API元信息 / CDP 兼容 ──
    方法 构建API元信息JSON <静态 类型 = 文本型>
    {
        变量 信息JSON <类型 = YYJSON对象类>
        信息JSON.创建自文本 ("{}")
        信息JSON.加入文本成员 ("server", MCP_常量.MCP_服务器名)
        信息JSON.加入文本成员 ("version", MCP_常量.MCP_版本号)
        信息JSON.加入整数成员 ("browsers", FBrowser_浏览器_取数量 ())
        信息JSON.加入文本成员 ("protocol", "JSON-RPC 2.0")
        信息JSON.加入文本成员 ("mcp_ws", MCP命令服务器.取MCP_WS地址 ())
        信息JSON.加入文本成员 ("mcp_http_post", MCP命令服务器.取MCP_HTTP地址 () + "/mcp")
        信息JSON.加入文本成员 ("mcp_http_post_alt", MCP命令服务器.取MCP_HTTP地址 () + "/")
        信息JSON.加入文本成员 ("health", "/health")
        信息JSON.加入文本成员 ("tools", "/tools/list")
        信息JSON.加入文本成员 ("json_list", "/json/list")
        信息JSON.加入文本成员 ("json_version", "/json/version")
        信息JSON.加入文本成员 ("welcome", "/")
        信息JSON.加入文本成员 ("docs", "/docs/")
        信息JSON.加入文本成员 ("cdp_note", "CDP 请使用 MCP 工具 browser_cdp_call / browser_cdp_event")
        信息JSON.加入文本成员 ("bridge_script", "mcp_bridge.js")
        信息JSON.加入文本成员 ("check_command", "node mcp_bridge.js --check")
        信息JSON.加入文本成员 ("usage_step1", "启动 AI-Fbowser-Mcp.exe")
        返回 (信息JSON.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建JSON版本响应 <静态 类型 = 文本型>
    {
        变量 版本JSON <类型 = YYJSON对象类>
        版本JSON.创建自文本 ("{}")
        版本JSON.加入文本成员 ("Browser", "FBrowser CEF")
        版本JSON.加入文本成员 ("Protocol-Version", MCP_常量.MCP_协议版本)
        版本JSON.加入文本成员 ("MCP-Version", MCP_常量.MCP_版本号)
        返回 (版本JSON.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建JSON列表响应 <静态 类型 = 文本型>
    {
        // 使用字符串拼接方式, 兼容 YYJSON 嵌套限制 (见 MCP_Server.wsv 原实现)
        变量 ID清单 <类型 = 类_FBrowser_列表值>
        ID清单 = FBrowser_浏览器_取ID清单 ()
        变量 json文本 <类型 = 文本型>
        json文本 = "["
        变量 first <类型 = 逻辑型 值 = 真>
        计次循环 (ID清单.取大小 ())
        {
            变量 bid <类型 = 整数>
            bid = ID清单.取整数值 (取循环索引 ())
            变量 bb <类型 = 类_FBrowser_浏览器>
            bb = FBrowser_浏览器_通过ID取浏览器 (bid)
            如果 (bb.是否为空 () == 假 && bb.是否已关闭 () == 假)
            {
                如果 (first)
                {
                    first = 假
                }
                否则
                {
                    json文本 = json文本 + ","
                }
                变量 项 <类型 = YYJSON对象类>
                项.创建自文本 ("{}")
                项.加入整数成员 ("id", bid)
                项.加入文本成员 ("url", bb.取主框架 ().取地址 ())
                json文本 = json文本 + 项.到可读文本 (YYJSON格式化选项.压缩)
            }
        }
        json文本 = json文本 + "]"
        返回 (json文本)
    }

    方法 构建任务查询结果JSON <静态 类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 消息 <类型 = 文本型>
    参数 原始数据JSON <类型 = 文本型>
    参数 任务ID <类型 = 文本型 @默认值 = "">
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 是否成功)
        对象.加入文本成员 ("message", 消息)
        对象.加入文本成员 ("data", 原始数据JSON)
        如果 (任务ID != "")
        {
            对象.加入文本成员 ("task_id", 任务ID)
        }
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 构建Base64图片异步JSON <静态 类型 = 文本型>
    参数 字节数据 <类型 = 字节集类>
    参数 mime类型 <类型 = 文本型>
    参数 原始字节数 <类型 = 整数 @默认值 = 0>
    {
        变量 实际大小 <类型 = 整数>
        实际大小 = 原始字节数
        如果 (实际大小 <= 0)
        {
            实际大小 = 取字节集长度 (字节数据)
        }
        如果 (实际大小 > MCP_常量.截图异步最大字节)
        {
            返回 (构建标准失败JSON ("图片过大(" + 到文本 (实际大小) + "字节), 上限=" + 到文本 (MCP_常量.截图异步最大字节)))
        }
        变量 字节指针 <类型 = 变整数>
        变量 字节长度 <类型 = 整数>
        字节指针 = 取字节集指针 (字节数据)
        字节长度 = 取字节集长度 (字节数据)
        变量 base64数据 <类型 = 文本型>
        @ // 二进制安全Base64: 直接对字节编码, 避免 字节集→文本→UTF8 双重转换损坏PNG/JPEG数据
        @ {
        @     const unsigned char* p = (const unsigned char*)(INT_P)@<字节指针>;
        @     INT_P n = @<字节长度>;
        @     static const char T[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
        @     std::string out;
        @     out.reserve(((n + 2) / 3) * 4);
        @     for (INT_P i = 0; i < n; i += 3) {
        @         unsigned v = (unsigned)p[i] << 16;
        @         if (i + 1 < n) v |= (unsigned)p[i+1] << 8;
        @         if (i + 2 < n) v |= (unsigned)p[i+2];
        @         out += T[(v >> 18) & 63];
        @         out += T[(v >> 12) & 63];
        @         out += (i + 1 < n) ? T[(v >> 6) & 63] : '=';
        @         out += (i + 2 < n) ? T[v & 63] : '=';
        @     }
        @     @<base64数据> = CVolString(out.c_str());
        @ }
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        包装对象.加入逻辑值成员 ("success", 真)
        包装对象.加入文本成员 ("message", "data:" + mime类型 + ";base64," + base64数据)
        包装对象.加入文本成员 ("mimeType", mime类型)
        包装对象.加入整数成员 ("data_size", 实际大小)
        返回 (包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
}
