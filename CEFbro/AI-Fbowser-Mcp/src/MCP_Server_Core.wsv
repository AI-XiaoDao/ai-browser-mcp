                    如果 (取字节集长度 (consoleFileBytes) > 0)
                    {
                        expression = UTF8到文本 (consoleFileBytes)
                    }
                    否则
                    {
                        返回 (MCP_响应构建.命令失败 (命令ID, "文件读取失败: " + expression))
                    }
                }
            }
            如果 (expression != "")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    // 直接传入表达式, FBrowser V8 引擎原生执行
                    变量 异步ID <类型 = 文本型>
                    异步ID = MCP命令服务器.生成异步任务ID ()
                    MCP命令服务器.提交异步JS任务 (browser, expression, 异步ID)
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步ID, "表达式已提交, 通过mcp_result查询", 150))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "缺少参数: 请提供 expression(JS表达式), 例如: document.title"))
        }
        // === 指纹 ===
        否则 (方法名 == "browser_fingerprint")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    如果 (action == "clear")
                    {
                        vip_ctrl.清理数据 ()
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "指纹已清除"))
                    }
                    否则 (action == "count")
                    {
                        返回 (MCP_响应构建.构建简单JSON ("count", vip_ctrl.指纹_取调用计数 ()))
                    }
                    否则 (action == "canvas_random")
                    {
                        变量 minN <类型 = 整数>
                        minN = MCP命令服务器.yyjson取整数 (参数JSON, "min")
                        变量 maxN <类型 = 整数>
                        maxN = MCP命令服务器.yyjson取整数 (参数JSON, "max")
                        如果 (minN == 0)
                        {
                            minN = 5
                        }
                        如果 (maxN == 0)
                        {
                            maxN = 50
                        }
                        vip_ctrl.指纹_虚拟Canvas_随机 (minN, maxN, MCP命令服务器.yyjson取整数 (参数JSON, "seed"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "Canvas指纹已随机化"))
                    }
                    否则 (action == "webgl_random")
                    {
                        变量 minN <类型 = 整数>
                        minN = MCP命令服务器.yyjson取整数 (参数JSON, "min")
                        变量 maxN <类型 = 整数>
                        maxN = MCP命令服务器.yyjson取整数 (参数JSON, "max")
                        如果 (minN == 0)
                        {
                            minN = 3
                        }
                        如果 (maxN == 0)
                        {
                            maxN = 30
                        }
                        vip_ctrl.指纹_虚拟WebGL_随机 (minN, maxN, MCP命令服务器.yyjson取整数 (参数JSON, "seed"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "WebGL指纹已随机化"))
                    }
                    否则 (action == "audio_random")
                    {
                        变量 minN <类型 = 整数>
                        minN = MCP命令服务器.yyjson取整数 (参数JSON, "min")
                        变量 maxN <类型 = 整数>
                        maxN = MCP命令服务器.yyjson取整数 (参数JSON, "max")
                        如果 (minN == 0)
                        {
                            minN = 100
                        }
                        如果 (maxN == 0)
                        {
                            maxN = 500
                        }
                        vip_ctrl.指纹_虚拟Audio_随机 (minN, maxN, MCP命令服务器.yyjson取整数 (参数JSON, "seed"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "Audio指纹已随机化"))
                    }
                    否则 (action == "audio_param")
                    {
                        变量 sampleRate <类型 = 整数>
                        sampleRate = MCP命令服务器.yyjson取整数 (参数JSON, "sample_rate")
                        变量 channels <类型 = 整数>
                        channels = MCP命令服务器.yyjson取整数 (参数JSON, "channels")
                        变量 framesPerBuffer <类型 = 整数>
                        framesPerBuffer = MCP命令服务器.yyjson取整数 (参数JSON, "frames_per_buffer")
                        如果 (sampleRate == 0 && channels == 0 && framesPerBuffer == 0)
                        {
                            返回 (MCP_响应构建.命令失败 (命令ID, "audio_param 需要 sample_rate/channels/frames_per_buffer 至少一项"))
                        }
                        变量 配置JSON <类型 = 文本型>
                        配置JSON = "{"
                        变量 首字段 <类型 = 逻辑型 值 = 真>
                        如果 (sampleRate > 0)
                        {
                            配置JSON = 配置JSON + "\"sample_rate\":" + 到文本 (sampleRate)
                            首字段 = 假
                        }
                        如果 (channels > 0)
                        {
                            如果 (首字段 == 假)
                            {
                                配置JSON = 配置JSON + ","
                            }
                            配置JSON = 配置JSON + "\"channels\":" + 到文本 (channels)
                            首字段 = 假
                        }
                        如果 (framesPerBuffer > 0)
                        {
                            如果 (首字段 == 假)
                            {
                                配置JSON = 配置JSON + ","
                            }
                            配置JSON = 配置JSON + "\"frames_per_buffer\":" + 到文本 (framesPerBuffer)
                        }
                        配置JSON = 配置JSON + "}"
                        MCP命令服务器.音频指纹配置 = 配置JSON
                        MCP命令服务器.是否Hook音频 = 真
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "音频参数Hook已启用(事件通道), 刷新后生效: " + 配置JSON))
                    }
                    否则 (action == "webrtc")
                    {
                        vip_ctrl.指纹_虚拟WebrtcIP (MCP命令服务器.yyjson取文本 (参数JSON, "public_ip"), MCP命令服务器.yyjson取文本 (参数JSON, "local_ip"), MCP命令服务器.yyjson取文本 (参数JSON, "host"), MCP命令服务器.yyjson取逻辑 (参数JSON, "disable"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "WebRTC已设置"))
                    }
                    否则 (action == "geolocation")
                    {
                        变量 lat <类型 = 小数>
                        lat = MCP命令服务器.yyjson取小数 (参数JSON, "latitude")
                        变量 lng <类型 = 小数>
                        lng = MCP命令服务器.yyjson取小数 (参数JSON, "longitude")
                        vip_ctrl.指纹_虚拟定位 (lng, lat, 10, -10000, -1, -1, -1)
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "定位已设置"))
                    }
                    否则 (action == "timezone")
                    {
                        vip_ctrl.指纹_虚拟Date时区 (MCP命令服务器.yyjson取整数 (参数JSON, "offset_h"), MCP命令服务器.yyjson取整数 (参数JSON, "offset_m"), MCP命令服务器.yyjson取文本 (参数JSON, "name"), MCP命令服务器.yyjson取文本 (参数JSON, "iana"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "时区已设置"))
                    }
                    否则 (action == "ssl")
                    {
                        变量 tls_min_int <类型 = 整数>
                        变量 tls_max_int <类型 = 整数>
                        变量 tls_min_enum <类型 = TLS版本>
                        变量 tls_max_enum <类型 = TLS版本>
                        tls_min_int = MCP命令服务器.yyjson取整数 (参数JSON, "tls_min")
                        tls_max_int = MCP命令服务器.yyjson取整数 (参数JSON, "tls_max")
                        // 整数→TLS版本枚举映射 (使用 MCP_服务器工具 统一方法)
                        tls_min_enum = MCP_服务器工具.整数到TLS版本 (tls_min_int)
                        tls_max_enum = MCP_服务器工具.整数到TLS版本 (tls_max_int)
                        vip_ctrl.指纹_设置SSL加密套件 (tls_min_enum, tls_max_enum, MCP命令服务器.yyjson取文本 (参数JSON, "ciphers"))
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "SSL加密套件已设置"))
                    }
                    否则 (action == "set_batch")
                    {
                        变量 config_text <类型 = 文本型>
                        config_text = MCP命令服务器.yyjson取JSON文本 (参数JSON, "config")
                        变量 配置解析 <类型 = YYJSON只读对象类>
                        如果 (config_text != "" && 配置解析.创建自文本 (config_text))
                        {
                            变量 appliedCount <类型 = 整数 值 = 0>
                            变量 val <类型 = 文本型>
                            val = MCP命令服务器.yyjson取文本 (配置解析, "user_agent")
                            如果 (val != "")
                            {
                                变量 ua <类型 = 类_FBrowserVIP_UA数据>
                                ua.创建 ()
                                ua.置UserAgent (val)
                                vip_ctrl.指纹_虚拟UserAgent (ua)
                                appliedCount = appliedCount + 1
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "vendor")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Vendor (val)
                                appliedCount = appliedCount + 1
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "product")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Product (val)
                                appliedCount = appliedCount + 1
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "languages")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Languages (val)
                                appliedCount = appliedCount + 1
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "webgl_vendor")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Webglvendor (val)
                                appliedCount = appliedCount + 1
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "webgl_renderer")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Webglrenderer (val)
                                appliedCount = appliedCount + 1
                            }
                            变量 intVal <类型 = 整数>
                            intVal = MCP命令服务器.yyjson取整数 (配置解析, "hardware_concurrency")
                            如果 (intVal > 0)
                            {
                                vip_ctrl.指纹_虚拟HardwareConcurrency (intVal)
                                appliedCount = appliedCount + 1
                            }
                            intVal = MCP命令服务器.yyjson取整数 (配置解析, "device_memory")
                            如果 (intVal > 0)
                            {
                                vip_ctrl.指纹_虚拟DeviceMemory (intVal)
                                appliedCount = appliedCount + 1
                            }
                            vip_ctrl.指纹_虚拟Webdriver (MCP命令服务器.yyjson取逻辑 (配置解析, "webdriver"))
                            appliedCount = appliedCount + 1
                            变量 w <类型 = 整数>
                            w = MCP命令服务器.yyjson取整数 (配置解析, "width")
                            变量 h <类型 = 整数>
                            h = MCP命令服务器.yyjson取整数 (配置解析, "height")
                            如果 (w > 0 && h > 0)
                            {
                                vip_ctrl.指纹_虚拟屏幕分辨率 (h, w)
                                appliedCount = appliedCount + 1
                            }
                            w = MCP命令服务器.yyjson取整数 (配置解析, "avail_width")
                            h = MCP命令服务器.yyjson取整数 (配置解析, "avail_height")
                            如果 (w > 0 && h > 0)
                            {
                                vip_ctrl.指纹_虚拟屏幕可用高度和宽度 (h, w)
                                appliedCount = appliedCount + 1
                            }
                            如果 (appliedCount == 0)
                            {
                                返回 (MCP_响应构建.命令失败 (命令ID, "config未包含任何可识别的指纹字段 | 支持: user_agent/vendor/product/languages/webgl_vendor/webgl_renderer/hardware_concurrency/device_memory/webdriver/width/height/avail_width/avail_height"))
                            }
                            返回 (MCP_响应构建.响应_需要刷新 (命令ID, "指纹批量设置完成(" + 到文本 (appliedCount) + "项)"))
                        }
                        返回 (MCP_响应构建.命令失败 (命令ID, "config JSON无效"))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + action + " | 支持: clear/count/canvas_random/webgl_random/audio_random/audio_param/webrtc/geolocation/timezone/ssl/set_batch"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 拦截 (双通道: VIP API + 事件Hook toggle) ===
        否则 (方法名 == "browser_intercept")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            // -- 无需浏览器实例的操作 --
            如果 (action == "clear")
            {
                // 清除所有浏览器的VIP过滤器 (遍历, 不依赖取主浏览器)
                MCP命令服务器.浏览器数组锁.加锁 ()
                变量 clearCount <类型 = 整数>
                clearCount = 浏览器容器.浏览器数组.取成员数 ()
                计次循环 (clearCount)
                {
                    变量 clearB <类型 = 类_FBrowser_浏览器>
                    clearB = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 取循环索引 (), 类_FBrowser_浏览器)
                    如果 (clearB.是否为空 () == 假 && clearB.是否已关闭 () == 假)
                    {
                        变量 clearVip <类型 = 类_FBrowserVIP_控制器>
                        clearVip = clearB.取VIP控制器 ()
                        如果 (clearVip.是否为空 () == 假)
                        {
                            clearVip.过滤器_取消全部修改内容 ()
                            clearVip.过滤器_取消全部替换资源 ()
                        }
                    }
                }
                MCP命令服务器.浏览器数组锁.解锁 ()
                // 清除所有事件Hook规则和开关
                MCP命令服务器.是否缓存响应 = 假
                MCP命令服务器.是否Hook资源 = 假
                MCP命令服务器.是否Hook导航 = 假
                MCP命令服务器.是否Hook音频 = 假
                MCP命令服务器.是否Hook弹窗 = 假
                MCP命令服务器.资源替换规则 = ""
                MCP命令服务器.导航拦截规则 = ""
                MCP命令服务器.音频指纹配置 = ""
                MCP命令服务器.弹窗配置 = ""
                返回 (MCP_响应构建.命令成功 (命令ID, "所有拦截规则已清除(VIP+事件Hook双通道)"))
            }
            否则 (action == "ws_hook")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                    vip_ctrl = browser.取VIP控制器 ()
                    如果 (vip_ctrl.是否为空 () == 假)
                    {
                        vip_ctrl.WebSocket_启用拦截 ()
                        返回 (MCP_响应构建.命令成功 (命令ID, "WebSocket拦截已启用"))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            否则 (action == "cache")
            {
                MCP命令服务器.是否缓存响应 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "响应缓存已启用 (SQLite → response_cache表)"))
            }
            否则 (action == "uncache")
            {
                MCP命令服务器.是否缓存响应 = 假
                返回 (MCP_响应构建.命令成功 (命令ID, "响应缓存已禁用"))
            }
            否则 (action == "popup_config")
            {
                // 事件Hook通道: 自定义弹窗属性 (无需VIP, 无需浏览器实例)
                变量 弹窗宽度 <类型 = 整数>
                弹窗宽度 = MCP命令服务器.yyjson取整数 (参数JSON, "width")
                变量 弹窗高度 <类型 = 整数>
                弹窗高度 = MCP命令服务器.yyjson取整数 (参数JSON, "height")
                变量 弹窗X <类型 = 整数>
                弹窗X = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                变量 弹窗Y <类型 = 整数>
                弹窗Y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                如果 (弹窗宽度 <= 0 || 弹窗高度 <= 0)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "popup_config 需要 width/height > 0"))
                }
                MCP命令服务器.是否Hook弹窗 = 真
                MCP命令服务器.弹窗配置 = "{\"width\":" + 到文本 (弹窗宽度) + ",\"height\":" + 到文本 (弹窗高度) + ",\"x\":" + 到文本 (弹窗X) + ",\"y\":" + 到文本 (弹窗Y) + "}"
                返回 (MCP_响应构建.命令成功 (命令ID, "弹窗配置已设置: " + 到文本 (弹窗宽度) + "x" + 到文本 (弹窗高度)))
            }
            否则 (action == "popup_disable")
            {
                MCP命令服务器.是否Hook弹窗 = 假
                MCP命令服务器.弹窗配置 = ""
                返回 (MCP_响应构建.命令成功 (命令ID, "弹窗配置已禁用"))
            }
            // -- 需要浏览器实例的双通道操作 --
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                变量 url <类型 = 文本型>
                url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
                如果 (url == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "参数 url 不能为空"))
                }
                变量 匹配模式 <类型 = 整数>
                匹配模式 = MCP命令服务器.解析匹配模式 (MCP命令服务器.yyjson取文本 (参数JSON, "match_mode"))
                // -- 导航拦截 (事件Hook通道, 无需VIP) --
                如果 (action == "navigate_block" || action == "navigate_redirect")
                {
                    变量 原始action <类型 = 文本型>
                    原始action = action  // 保存原始值, 子文本替换会原地修改action
                    变量 规则动作 <类型 = 文本型>
                    规则动作 = action
                    子文本替换 (规则动作, "navigate_", "", , , 假)
                    变量 新行 <类型 = 文本型>
                    新行 = 规则动作 + "|" + url
                    如果 (原始action == "navigate_redirect")
                    {
                        变量 重定向目标 <类型 = 文本型>
                        重定向目标 = MCP命令服务器.yyjson取文本 (参数JSON, "target")
                        如果 (重定向目标 == "")
                        {
                            返回 (MCP_响应构建.命令失败 (命令ID, "navigate_redirect 需要 target 参数指定重定向目标URL"))
                        }
                        新行 = 新行 + "|" + 重定向目标
                    }
                    MCP命令服务器.追加导航拦截规则 (新行)
                    MCP命令服务器.是否Hook导航 = 真
                    返回 (MCP_响应构建.命令成功 (命令ID, "导航拦截规则已添加(VIP可选): " + url))
                }
                // -- 资源拦截 (事件Hook通道 + VIP双保险) --
                // 先尝试VIP API (如果可用), 然后无条件存储事件Hook规则作fallback
                如果 (action == "modify")
                {
                    变量 search_text <类型 = 文本型>
                    search_text = MCP命令服务器.yyjson取文本 (参数JSON, "search_text")
                    变量 replace_text <类型 = 文本型>
                    replace_text = MCP命令服务器.yyjson取文本 (参数JSON, "replace_text")
                    如果 (search_text != "" && replace_text != "")
                    {
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            vip_ctrl.过滤器_修改内容 (匹配模式, url, VIP过滤器.修改全部匹配数据, search_text, replace_text)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, search_text, replace_text, "", "")
                        返回 (MCP_响应构建.命令成功 (命令ID, "内容修改已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "modify需要search_text和replace_text"))
                }
                否则 (action == "replace_data")
                {
                    变量 replace_data_text <类型 = 文本型>
                    replace_data_text = MCP命令服务器.yyjson取文本 (参数JSON, "replace_text")
                    如果 (replace_data_text != "")
                    {
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            变量 替换字节集 <类型 = 字节集类>
                            替换字节集 = 文本到UTF8 (replace_data_text, 假)
                            vip_ctrl.过滤器_替换资源_数据 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , 替换字节集)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, "", replace_data_text, "", "")
                        返回 (MCP_响应构建.命令成功 (命令ID, "资源替换已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "replace_data需要replace_text"))
                }
                否则 (action == "replace_file")
                {
                    变量 file_path <类型 = 文本型>
                    file_path = MCP命令服务器.yyjson取文本 (参数JSON, "file_path")
                    如果 (file_path != "")
                    {
                        如果 (MCP命令服务器.验证安全路径 (file_path, 假) == 假)
                        {
                            返回 (MCP_响应构建.命令失败 (命令ID, "file_path 不合法 | 路径遍历或非法字符: " + file_path))
                        }
                        // 防御性检查: 拒绝不存在的文件和超大文件
                        如果 (文件是否存在 (file_path) == 假)
                        {
                            返回 (MCP_响应构建.命令失败 (命令ID, "替换文件不存在: " + file_path))
                        }
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            vip_ctrl.过滤器_替换资源_文件 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , file_path)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, "", "", file_path, "")
                        返回 (MCP_响应构建.命令成功 (命令ID, "本地文件替换已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + file_path))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "replace_file需要file_path"))
                }
                否则 (action == "block")
                {
                    如果 (vip_ctrl.是否为空 () == 假)
                    {
                        变量 空字节集 <类型 = 字节集类>
                        空字节集 = 取空白字节集 (0)
                        vip_ctrl.过滤器_替换资源_数据 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , 空字节集)
                    }
                    MCP命令服务器.是否Hook资源 = 真
                    MCP命令服务器.添加资源替换规则 (action, url, "", "", "", "")
                    返回 (MCP_响应构建.命令成功 (命令ID, "资源已屏蔽" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + action + " | 支持: modify/replace_data/replace_file/block/navigate_block/navigate_redirect/popup_config/popup_disable/cache/uncache/clear/ws_hook"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 截图 ===
        否则 (方法名 == "browser_screenshot")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    变量 fmt <类型 = 文本型>
                    fmt = MCP命令服务器.yyjson取文本 (参数JSON, "format")
                    如果 (fmt == "")
                    {
                        fmt = "png"
                    }
                    如果 (fmt != "png" && fmt != "jpeg" && fmt != "webp")
                    {
                        返回 (MCP_响应构建.命令失败 (命令ID, "不支持的截图格式: " + fmt + " | 仅支持 png/jpeg/webp"))
                    }
                    变量 截图大小 <类型 = FBrowser_截图边框数据>
                    截图大小.横坐标 = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                    截图大小.纵坐标 = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                    截图大小.宽度 = MCP命令服务器.yyjson取整数 (参数JSON, "width")
                    截图大小.高度 = MCP命令服务器.yyjson取整数 (参数JSON, "height")
                    如果 (截图大小.宽度 <= 0)
                    {
                        截图大小.宽度 = 1920
                    }
                    如果 (截图大小.高度 <= 0)
                    {
                        截图大小.高度 = 1080
                    }
                    截图大小.缩放 = MCP命令服务器.yyjson取整数 (参数JSON, "scale")
                    如果 (截图大小.缩放 <= 0)
                    {
                        截图大小.缩放 = 1
                    }
                    // 全部异步: 生成task_id, 回调触发时存储结果
                    变量 异步截图ID <类型 = 文本型>
                    异步截图ID = MCP命令服务器.生成异步任务ID ()
                    变量 截图回调 <类型 = 类_FBrowser_事件智能指针>
                    截图回调.创建 (类_MCP_截图异步回调)
                    截图回调.取执行类 (类_MCP_截图异步回调).任务ID = 异步截图ID
                    截图回调.取执行类 (类_MCP_截图异步回调).图片格式 = fmt
                    vip_ctrl.高级_网页截图 (fmt, 80, 截图大小, 假, 假, 截图回调)
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步截图ID, "截图已提交, 通过mcp_result查询", 800))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 等待(AI自动化) ===
        否则 (方法名 == "browser_wait")
        {
            变量 what <类型 = 文本型>
            what = MCP命令服务器.yyjson取文本 (参数JSON, "what")
            变量 value <类型 = 文本型>
            value = MCP命令服务器.yyjson取文本 (参数JSON, "value")
            变量 maxMs <类型 = 整数>
            maxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (maxMs == 0)
            {
                maxMs = 10000
            }
            如果 (maxMs > 300000)
            {
                maxMs = 300000  // 最多等5分钟, 防永久阻塞(本地桌面放宽)
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                如果 (what == "timeout")
                {
                    变量 异步超时ID <类型 = 文本型>
                    异步超时ID = MCP命令服务器.生成异步任务ID ()
                    // 将等待规格存储为异步任务, 客户端通过mcp_result轮询
                    变量 超时存储 <类型 = YYJSON对象类>
                    超时存储.创建自文本 ("{}")
                    超时存储.加入逻辑值成员 ("_waiting", 真)
                    超时存储.加入文本成员 ("what", "timeout")
                    超时存储.加入整数成员 ("max_ms", maxMs)
                    超时存储.加入长整数成员 ("start_time", 取启动时间 ())
                    超时存储.加入整数成员 ("_poll_count", 0)
                    MCP命令服务器.存储异步结果 (异步超时ID, 超时存储.到可读文本 (YYJSON格式化选项.压缩))
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步超时ID, "等待已提交, 通过mcp_result轮询结果"))
                }
                如果 (what != "selector" && what != "text" && what != "load_end" && what != "load_start" && what != "navigate" && what != "network_idle" && what != "url_contains")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "未知what: " + what + " | 支持: selector/text/timeout/load_end/load_start/navigate/network_idle/url_contains"))
                }
                // load_end/load_start/network_idle 不需要 value; navigate 无 value 时等同 load_end
                如果 (what != "load_end" && what != "load_start" && what != "navigate" && what != "network_idle" && value == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "value 不能为空: what=" + what + " 需要指定等待目标值"))
                }
                如果 (what == "navigate" && value == "")
                {
                    what = "load_end"
                }
                // === 异步轮询模式: 生成task_id, 每次mcp_result做一次检查, 避免阻塞MCP线程 ===
                变量 异步等待ID <类型 = 文本型>
                异步等待ID = MCP命令服务器.生成异步任务ID ()
                变量 checkCode <类型 = 文本型>
                如果 (what == "selector")
                {
                    checkCode = "(function(){var el=document.querySelector('" + MCP命令服务器.简单转义JS (value) + "');return JSON.stringify({found:!!el,text:el?el.innerText.substring(0,500):null,tag:el?el.tagName:null})})()"
                }
                否则 (what == "text")
                {
                    checkCode = "(function(){if(!document.body)return JSON.stringify({found:false,error:'document.body not ready'});var idx=document.body.innerText.indexOf('" + MCP命令服务器.简单转义JS (value) + "');return JSON.stringify({found:idx>=0,position:idx})})()"
                }
                否则 (what == "load_end")
                {
                    // 原生: CEF OnLoadEnd 事件缓存, 非JS document.readyState
                    checkCode = ""
                }
                否则 (what == "load_start")
                {
                    // 原生: CEF OnLoadStart 事件缓存, 非JS document.readyState
                    checkCode = ""
                }
                否则 (what == "navigate")
                {
                    checkCode = "(function(){var t='" + MCP命令服务器.简单转义JS (value) + "';var h=window.location.href;var f=(h===t||(t.length>0&&h.indexOf(t)===0));return JSON.stringify({found:f,url:h,target:t})})()"
                }
                否则 (what == "url_contains")
                {
                    checkCode = "(function(){var t='" + MCP命令服务器.简单转义JS (value) + "';return JSON.stringify({found:window.location.href.indexOf(t)!==-1,url:window.location.href})})()"
                }
                否则 (what == "network_idle")
                {
                    // 服务端检查: 活动URL请求数是否为0 + 最后释放时间
                    // check_code 留空, 由 mcp_result 轮询时做服务端判断
                    checkCode = ""
                }
                // 存储等待上下文, 客户端通过mcp_result轮询 — 每次轮询触发一次JS条件检查
                变量 等待存储 <类型 = YYJSON对象类>
                等待存储.创建自文本 ("{}")
                等待存储.加入逻辑值成员 ("_waiting", 真)
                等待存储.加入文本成员 ("what", what)
                等待存储.加入文本成员 ("value", value)
                等待存储.加入文本成员 ("check_code", checkCode)
                等待存储.加入整数成员 ("max_ms", maxMs)
                等待存储.加入长整数成员 ("start_time", 取启动时间 ())
                等待存储.加入整数成员 ("_poll_count", 0)
                等待存储.加入整数成员 ("_browser_id", browser.取ID ())
                如果 (what == "load_start")
                {
                    等待存储.加入整数成员 ("_load_phase", 0)
                }
                MCP命令服务器.存储异步结果 (异步等待ID, 等待存储.到可读文本 (YYJSON格式化选项.压缩))
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步等待ID, "等待已提交(what=" + what + " value=" + value + "), 请用mcp_result轮询, 每次轮询做一次条件检查"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 一站式爬虫: navigate→wait→extract (异步状态机) ===
        否则 (方法名 == "browser_scrape")
        {
            变量 sUrl <类型 = 文本型>
            sUrl = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (sUrl == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "url " + MCP_常量.错误_缺少参数))
            }
            如果 (MCP命令服务器.验证URL安全 (sUrl) == 假)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_不支持的URL协议))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 ())
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            变量 sFrame <类型 = 类_FBrowser_框架>
            sFrame = MCP命令服务器.取安全主框架 (browser)
            如果 (sFrame.是否为空 () == 假 && sFrame.是否有效 ())
            {
                sFrame.载入地址 (sUrl)
            }
            否则
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            变量 sTaskID <类型 = 文本型>
            sTaskID = MCP命令服务器.生成异步任务ID ()
            变量 sMaxMs <类型 = 整数>
            sMaxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (sMaxMs <= 0)
            {
                sMaxMs = 30000
            }
            变量 sStore <类型 = YYJSON对象类>
            sStore.创建自文本 ("{}")
            sStore.加入逻辑值成员 ("_waiting", 真)
            sStore.加入文本成员 ("what", "scrape")
            sStore.加入整数成员 ("max_ms", sMaxMs)
            sStore.加入长整数成员 ("start_time", 取启动时间 ())
            sStore.加入整数成员 ("_phase", 0)
            sStore.加入整数成员 ("_browser_id", browser.取ID ())
            变量 sWait <类型 = 文本型>
            sWait = MCP命令服务器.yyjson取文本 (参数JSON, "wait_selector")
            变量 sExtract <类型 = 文本型>
            sExtract = MCP命令服务器.yyjson取文本 (参数JSON, "extract_selector")
            如果 (sWait != "")
            {
                sStore.加入文本成员 ("wait_selector", sWait)
            }
            如果 (sExtract != "")
            {
                sStore.加入文本成员 ("extract_selector", sExtract)
            }
            否则
            {
                sStore.加入文本成员 ("extract_selector", "")
            }
            MCP命令服务器.存储异步结果 (sTaskID, sStore.到可读文本 (YYJSON格式化选项.压缩))
            返回 (MCP命令服务器.命令成功_异步 (命令ID, sTaskID, "爬虫任务已提交: " + sUrl + " | 通过mcp_result轮询"))
        }
        // === 数据提取: 链接/图片/表格 结构化JSON ===
        否则 (方法名 == "browser_extract")
        {
            变量 extractBrowser <类型 = 类_FBrowser_浏览器>
            extractBrowser = MCP命令服务器.取主浏览器 ()
            如果 (extractBrowser.是否为空 ())
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            变量 extractType <类型 = 文本型>
            extractType = MCP命令服务器.yyjson取文本 (参数JSON, "type")
            变量 extractLimit <类型 = 整数>
            extractLimit = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
            如果 (extractLimit <= 0)
            {
                extractLimit = 100
            }
            如果 (extractType == "links")
            {
                变量 linksJS <类型 = 文本型>
                linksJS = "(function(){var r=[];var as=document.querySelectorAll('a[href]');for(var i=0;i<Math.min(as.length," + 到文本 (extractLimit) + ");i++){var a=as[i];r.push({href:a.href,text:a.innerText.trim().substring(0,200)})}return JSON.stringify(r)})()"
                变量 linksResult <类型 = 文本型>
                linksResult = MCP命令服务器.提交异步JS任务 (extractBrowser, linksJS)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, linksResult, "links", "链接提取已提交"))
            }
            否则 (extractType == "images")
            {
                变量 imagesJS <类型 = 文本型>
                imagesJS = "(function(){var r=[];var imgs=document.querySelectorAll('img[src]');for(var i=0;i<Math.min(imgs.length," + 到文本 (extractLimit) + ");i++){var img=imgs[i];r.push({src:img.src,alt:img.alt||'',width:img.naturalWidth,height:img.naturalHeight})}return JSON.stringify(r)})()"
                变量 imagesResult <类型 = 文本型>
                imagesResult = MCP命令服务器.提交异步JS任务 (extractBrowser, imagesJS)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, imagesResult, "images", "图片提取已提交"))
            }
            否则 (extractType == "tables")
            {
                // v2.8增强: 自动检测<thead>提取列名, 输出{headers:[],data:[[],...]} 结构化JSON
                变量 tablesJS <类型 = 文本型>
                tablesJS = "(function(){var r=[];var ts=document.querySelectorAll('table');for(var i=0;i<Math.min(ts.length," + 到文本 (extractLimit) + ");i++){var table=ts[i];var headers=[];var thead=table.querySelector('thead');if(thead){var ths=thead.querySelectorAll('th');for(var h=0;h<Math.min(ths.length,50);h++){headers.push(ths[h].innerText.trim().substring(0,200))}}if(headers.length===0){var firstRow=table.querySelector('tr');if(firstRow){var fcs=firstRow.querySelectorAll('th,td');for(var h=0;h<Math.min(fcs.length,50);h++){headers.push(fcs[h].innerText.trim().substring(0,200))}}}var rows=table.querySelectorAll('tr');var tdata=[];var startRow=headers.length>0?1:0;for(var j=startRow;j<Math.min(rows.length,200);j++){var cells=rows[j].querySelectorAll('td,th');var row=[];for(var k=0;k<Math.min(cells.length,50);k++){row.push(cells[k].innerText.trim().substring(0,500))}if(row.length>0)tdata.push(row)}r.push({table_index:i,headers:headers,columns:headers.length,rows:tdata.length,data:tdata})}return JSON.stringify(r)})()"
                变量 tablesResult <类型 = 文本型>
                tablesResult = MCP命令服务器.提交异步JS任务 (extractBrowser, tablesJS)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, tablesResult, "tables", "表格提取已提交"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知type: " + extractType + " | 支持: links/images/tables"))
        }
        // === 注入(AI自动化) ===
        否则 (方法名 == "browser_inject")
        {
            变量 injectType <类型 = 文本型>
            injectType = MCP命令服务器.yyjson取文本 (参数JSON, "type")
            变量 code <类型 = 文本型>
            code = MCP命令服务器.yyjson取文本 (参数JSON, "code")
            变量 persist <类型 = 逻辑型>
            persist = MCP命令服务器.yyjson取逻辑 (参数JSON, "persist")
            如果 (injectType != "" && code != "")
            {
                如果 (persist && injectType == "js")
                {
                    // 持久js模式: 存入持久V8扩展列表, 由 渲染_即将创建V8环境 → V8环境.执行JS代码 自动注入
                    变量 注入标识 <类型 = 文本型>
                    注入标识 = MCP命令服务器.yyjson取文本 (参数JSON, "inject_id")
                    如果 (注入标识 == "")
                    {
                        注入标识 = "mcp_inject_js_" + 到文本 (取启动时间 ())
                    }
                    // 转义code中的|防止分隔符冲突, 解析侧(MCP_BrowserEvents)会反向还原
                    变量 安全code_js <类型 = 文本型>
                    安全code_js = code
                    子文本替换 (安全code_js, "{PIPE}", "{PIPE_ESC}", , , 假)
                    子文本替换 (安全code_js, "|", "{PIPE}", , , 假)
                    MCP命令服务器.加入持久V8扩展 (注入标识, 安全code_js, "js")
                    返回 (MCP_响应构建.响应_需要刷新 (命令ID, "V8 JS持久注入已排队 | 将在新页面/新iframe加载时自动生效"))
                }
                如果 (persist && injectType == "handler")
                {
                    // 持久handler模式: 存入持久V8扩展列表, 由 渲染_即将初始化WebKit → FBrowser_V8_注册JS扩展 自动注入
                    变量 注入标识 <类型 = 文本型>
                    注入标识 = MCP命令服务器.yyjson取文本 (参数JSON, "inject_id")
                    如果 (注入标识 == "")
                    {
                        注入标识 = "mcp_inject_handler_" + 到文本 (取启动时间 ())
                    }
                    // 转义code中的|防止分隔符冲突, 解析侧(MCP_BrowserEvents)会反向还原
                    变量 安全code_handler <类型 = 文本型>
                    安全code_handler = code
                    子文本替换 (安全code_handler, "{PIPE}", "{PIPE_ESC}", , , 假)
                    子文本替换 (安全code_handler, "|", "{PIPE}", , , 假)
                    MCP命令服务器.加入持久V8扩展 (注入标识, 安全code_handler, "handler")
                    返回 (MCP_响应构建.响应_需要刷新 (命令ID, "V8 Handler持久注入已排队 | 将在新页面时自动注册 | 需要刷新/browser_reload"))
                }
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 injectFrame <类型 = 类_FBrowser_框架>
                    injectFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (injectFrame.是否为空 () == 假 && injectFrame.是否有效 ())
                    {
                        如果 (injectType == "js")
                        {
                            // 事件驱动: 使用 执行JS代码_带返回值 + 回调, 报告注入成功/失败
                            变量 注入JS_ID <类型 = 文本型>
                            注入JS_ID = MCP命令服务器.生成异步任务ID ()
                            变量 注入JS回调 <类型 = 类_FBrowser_事件智能指针>
                            注入JS回调.创建 (类_MCP_JS异步回调)
                            注入JS回调.取执行类 (类_MCP_JS异步回调).任务ID = 注入JS_ID
                            injectFrame.执行JS代码_带返回值 (code, "", 0, 注入JS回调)
                            返回 (MCP命令服务器.命令成功_异步 (命令ID, 注入JS_ID, "JS注入已提交, 通过mcp_result查询"))
                        }
                        否则 (injectType == "css")
                        {
                            // CSS无原生API, 需通过JS注入style标签 (事件驱动回调)
                            变量 cssCode <类型 = 文本型>
                            cssCode = "try{var s=document.createElement('style');s.textContent='" + MCP命令服务器.简单转义JS (code) + "';document.head.appendChild(s);'injected'}catch(e){'Error: '+e.message}"
                            变量 注入CSS_ID <类型 = 文本型>
                            注入CSS_ID = MCP命令服务器.生成异步任务ID ()
                            变量 注入CSS回调 <类型 = 类_FBrowser_事件智能指针>
                            注入CSS回调.创建 (类_MCP_JS异步回调)
                            注入CSS回调.取执行类 (类_MCP_JS异步回调).任务ID = 注入CSS_ID
                            injectFrame.执行JS代码_带返回值 (cssCode, "", 0, 注入CSS回调)
                            返回 (MCP命令服务器.命令成功_异步 (命令ID, 注入CSS_ID, "CSS注入已提交, 通过mcp_result查询"))
                        }
                        否则
                        {
                            返回 (MCP_响应构建.命令失败 (命令ID, "未知type: " + injectType + ",支持: js/css"))
                        }
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "参数 type/code 不能为空"))
        }
        // === 网络日志 ===
        否则 (方法名 == "browser_network")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (action == "")
            {
                action = "list"
            }
            如果 (action == "enable" || action == "network_enable")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 假
                返回 (MCP_响应构建.命令成功 (命令ID, "网络日志已启用(基础模式)"))
            }
            如果 (action == "detail_enable" || action == "network_detail_enable")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "网络日志已启用(详细模式)"))
            }
            如果 (action == "disable" || action == "network_disable")
            {
                MCP命令服务器.是否记录网络 = 假
                MCP命令服务器.是否详细记录网络 = 假
                返回 (MCP_响应构建.命令成功 (命令ID, "网络日志已禁用"))
            }
            如果 (action == "clear" || action == "network_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='network' OR log_type='network_detail'")
                返回 (MCP_响应构建.命令成功 (命令ID, "已清空"))
            }
            如果 (action == "list" || action == "get" || action == "network_get")
            {
                // 首次使用自动启用网络日志 (auto_enable:false 可跳过)
                如果 (MCP命令服务器.是否记录网络 == 假)
                {
                    变量 应自动启用 <类型 = 逻辑型 值 = 真>
                    如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "auto_enable") == 假 && MCP命令服务器.yyjson取文本 (参数JSON, "auto_enable") != "")
                    {
                        应自动启用 = 假
                    }
                    如果 (应自动启用)
                    {
                        MCP命令服务器.是否记录网络 = 真
                    }
                }
                变量 限制 <类型 = 整数>
                限制 = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
                如果 (限制 <= 0)
                {
                    限制 = 500
                }
                如果 (限制 > 1000)
                {
                    限制 = 1000
                }
                变量 日志数组 <类型 = 文本型>
                日志数组 = MCP命令服务器.查询网络日志 (限制)
                变量 头对象 <类型 = YYJSON对象类>
                头对象.创建自文本 ("{}")
                头对象.加入逻辑值成员 ("network_enabled", MCP命令服务器.是否记录网络)
                头对象.加入逻辑值成员 ("network_detail", MCP命令服务器.是否详细记录网络)
                如果 (日志数组 == "[]" || 日志数组 == "")
                {
                    如果 (MCP命令服务器.是否记录网络 == 假)
                    {
                        头对象.加入文本成员 ("hint", "网络日志未启用; 请 action=enable 或 config enable_network_log=true, navigate 后再 list")
                    }
                    否则
                    {
                        头对象.加入文本成员 ("hint", "尚无记录; 仅记录 enable 之后的新请求, 磁盘缓存命中可能无 req/res")
                    }
                }
                变量 头JSON <类型 = 文本型>
                头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
                变量 内层JSON <类型 = 文本型>
                内层JSON = 取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"network_logs\":" + 日志数组 + "}"
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 内层JSON))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + action + " | 支持: list/get/enable/disable/clear/detail_enable (别名 network_*)"))
        }
        // === 自动化重试机制 (v2.8) ===
        否则 (方法名 == "browser_retry")
        {
            变量 retTool <类型 = 文本型>
            retTool = MCP命令服务器.yyjson取文本 (参数JSON, "tool")
            如果 (retTool == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "retry 需要 tool 参数: 要重试的MCP工具名"))
            }
            变量 retArgs <类型 = YYJSON只读对象类>
            retArgs = MCP命令服务器.yyjson取对象成员 (参数JSON, "args")
            如果 (retArgs.是否为空 ())
            {
                变量 空retArgs <类型 = YYJSON只读对象类>
                空retArgs.创建自文本 ("{}")
                retArgs = 空retArgs
            }
            变量 retMaxRetries <类型 = 整数>
            retMaxRetries = MCP命令服务器.yyjson取整数 (参数JSON, "max_retries")
            如果 (retMaxRetries <= 0 || retMaxRetries > 10)
            {
                retMaxRetries = 3
            }
            变量 retBackoffMs <类型 = 整数>
            retBackoffMs = MCP命令服务器.yyjson取整数 (参数JSON, "backoff_ms")
            如果 (retBackoffMs <= 0)
            {
                retBackoffMs = 1000
            }
            如果 (retBackoffMs > 30000)
            {
                retBackoffMs = 30000
            }
            变量 retMaxTotalMs <类型 = 整数>
            retMaxTotalMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_total_ms")
            如果 (retMaxTotalMs <= 0)
            {
                retMaxTotalMs = 60000
            }
            变量 retStartTime <类型 = 长整数>
            retStartTime = 取启动时间 ()
            变量 retSuccess <类型 = 逻辑型 值 = 假>
            变量 retFinalResult <类型 = 文本型>
            retFinalResult = ""
            变量 retAttempt <类型 = 整数 值 = 0>
            判断循环 (retAttempt < retMaxRetries && retSuccess == 假)
            {
                如果 (取启动时间 () - retStartTime > retMaxTotalMs)
                {
                    跳出循环
                }
                retAttempt = retAttempt + 1
                MCP命令服务器.MCP执行锁.解锁 ()
                retFinalResult = MCP命令服务器.执行浏览器命令 (命令ID + "_r" + 到文本 (retAttempt), retTool, retArgs)
                MCP命令服务器.MCP执行锁.加锁 ()
                变量 retParsed <类型 = YYJSON只读对象类>
                如果 (retParsed.创建自文本 (retFinalResult))
                {
                    如果 (retParsed.取逻辑值 ("success"))
                    {
                        retSuccess = 真
                        跳出循环
                    }
                }
                如果 (retAttempt < retMaxRetries && retSuccess == 假)
                {
                    变量 retDelay <类型 = 整数>
                    retDelay = retBackoffMs
                    如果 (retAttempt > 1)
                    {
                        retDelay = retBackoffMs * retAttempt  // 线性退避
                    }
                    如果 (retDelay > retMaxTotalMs - (整数)(取启动时间 () - retStartTime))
                    {
                        retDelay = retMaxTotalMs - (整数)(取启动时间 () - retStartTime)
                    }
                    如果 (retDelay > 0)
                    {
                        MCP命令服务器.MCP可中断延时 (retDelay)
                    }
                }
            }
            如果 (retSuccess)
            {
                返回 (retFinalResult)
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "重试" + 到文本 (retAttempt) + "次后仍失败 | tool=" + retTool + " | 最后错误已输出"))
        }
        // === Canvas指纹噪点注入 (v2.8 反检测, JS实现, 不需VIP) ===
        否则 (方法名 == "browser_canvas_noise")
        {
            变量 cnAction <类型 = 文本型>
            cnAction = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (cnAction == "")
            {
                cnAction = "inject"
            }
            变量 cnBrowser <类型 = 类_FBrowser_浏览器>
            cnBrowser = MCP命令服务器.取主浏览器 ()
            如果 (cnBrowser.是否为空 () == 假 && cnBrowser.是否已关闭 () == 假)
            {
                变量 cnFrame <类型 = 类_FBrowser_框架>
                cnFrame = MCP命令服务器.取安全主框架 (cnBrowser)
                如果 (cnFrame.是否为空 () == 假 && cnFrame.是否有效 ())
                {
                    如果 (cnAction == "inject" || cnAction == "enable")
                    {
                        变量 cnNoiseLevel <类型 = 整数>
                        cnNoiseLevel = MCP命令服务器.yyjson取整数 (参数JSON, "level")
                        如果 (cnNoiseLevel <= 0 || cnNoiseLevel > 5)
                        {
                            cnNoiseLevel = 1
                        }
                        // JS层Canvas噪声注入: 修改toDataURL/toBlob/getImageData, 对每个像素添加±level的噪声
                        // 兼容所有Canvas2D指纹检测, 不依赖VIP内核API
                        变量 cnCode <类型 = 文本型>
                        cnCode = "(function(){var L=" + 到文本 (cnNoiseLevel) + ";"
                        cnCode = cnCode + "if(window.__MCP_CANVAS_NOISED__)return'Canvas noise already active(level='+window.__MCP_CANVAS_NOISE_LVL__+')';"
                        cnCode = cnCode + "var origToDataURL=HTMLCanvasElement.prototype.toDataURL;"
                        cnCode = cnCode + "var origToBlob=HTMLCanvasElement.prototype.toBlob;"
                        cnCode = cnCode + "var origGetImageData=CanvasRenderingContext2D.prototype.getImageData;"
                        cnCode = cnCode + "var addNoise=function(imgData,level){var d=imgData.data;if(!d)return imgData;"
                        cnCode = cnCode + "for(var i=0;i<d.length;i+=4){"
                        cnCode = cnCode + "var r=Math.floor(Math.random()*level*2-level);"
                        cnCode = cnCode + "d[i]=Math.min(255,Math.max(0,d[i]+r));"
                        cnCode = cnCode + "d[i+1]=Math.min(255,Math.max(0,d[i+1]+r));"
                        cnCode = cnCode + "d[i+2]=Math.min(255,Math.max(0,d[i+2]+r));"
                        cnCode = cnCode + "}return imgData;};"
                        // 核心: getImageData → 加噪 → 返回加噪后的数据
                        cnCode = cnCode + "CanvasRenderingContext2D.prototype.getImageData=function(x,y,w,h){"
                        cnCode = cnCode + "var imgData=origGetImageData.call(this,x,y,w,h);"
                        cnCode = cnCode + "return addNoise(imgData,L);};"
                        // 对toDataURL/toBlob也注入噪声: 临时替换getImageData, 完成后恢复
                        cnCode = cnCode + "HTMLCanvasElement.prototype.toDataURL=function(){"
                        cnCode = cnCode + "var ctx=this.getContext('2d');if(!ctx)return origToDataURL.apply(this,arguments);"
                        cnCode = cnCode + "var imgData=ctx.getImageData(0,0,this.width,this.height);"
                        cnCode = cnCode + "ctx.putImageData(addNoise(imgData,L),0,0);"
                        cnCode = cnCode + "return origToDataURL.apply(this,arguments);};"
                        cnCode = cnCode + "HTMLCanvasElement.prototype.toBlob=function(cb){"
                        cnCode = cnCode + "var ctx=this.getContext('2d');if(!ctx)return origToBlob.apply(this,arguments);"
                        cnCode = cnCode + "var imgData=ctx.getImageData(0,0,this.width,this.height);"
                        cnCode = cnCode + "ctx.putImageData(addNoise(imgData,L),0,0);"
                        cnCode = cnCode + "return origToBlob.apply(this,arguments);};"
                        cnCode = cnCode + "window.__MCP_CANVAS_NOISED__=true;"
                        cnCode = cnCode + "window.__MCP_CANVAS_NOISE_LVL__=L;"
                        cnCode = cnCode + "return'Canvas noise injected(level='+L+')';"
                        cnCode = cnCode + "})()"
                        变量 cnResult <类型 = 文本型>
                        cnResult = MCP命令服务器.提交异步JS任务 (cnBrowser, cnCode)
                        返回 (MCP命令服务器.包装异步提交结果 (命令ID, cnResult, "message", "Canvas噪声已注入(level=" + 到文本 (cnNoiseLevel) + ") | 通过mcp_result查询"))
                    }
                    否则 (cnAction == "remove" || cnAction == "disable")
                    {
                        变量 cnRemoveCode <类型 = 文本型>
                        cnRemoveCode = "(function(){delete HTMLCanvasElement.prototype.toDataURL;delete HTMLCanvasElement.prototype.toBlob;delete CanvasRenderingContext2D.prototype.getImageData;delete window.__MCP_CANVAS_NOISED__;return'Canvas noise removed'})()"
                        MCP命令服务器.提交异步JS任务 (cnBrowser, cnRemoveCode)
                        返回 (MCP_响应构建.命令成功 (命令ID, "Canvas噪声已移除 | 刷新页面恢复默认"))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + cnAction + " | 支持: inject/enable/remove/disable"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 网络日志 HAR 导出 (v2.8) ===
        否则 (方法名 == "browser_network_export")
        {
            变量 neFormat <类型 = 文本型>
            neFormat = MCP命令服务器.yyjson取文本 (参数JSON, "format")
            如果 (neFormat == "")
            {
                neFormat = "json"
            }
            变量 neLimit <类型 = 整数>
            neLimit = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
            如果 (neLimit <= 0 || neLimit > 50000)
            {
                neLimit = 2000
            }
            变量 neResult <类型 = 文本型>
            neResult = MCP命令服务器.查询事件日志 ("network", "", 0, neLimit)
            如果 (neFormat == "har")
            {
                // 构建 HAR 格式 (HTTP Archive 1.2)
                变量 neEntries <类型 = YYJSON数组类>
                neEntries.创建自文本数据 (MCP命令服务器.取空文本数组 ())
                变量 neLines <类型 = 文本数组类>
                分割文本 (neResult, "\n", neLines, 真, 假)
                变量 neCount <类型 = 整数>
                neCount = neLines.取成员数 ()
                计次循环 (neCount)
                {
                    变量 neJson <类型 = YYJSON只读对象类>
                    如果 (neJson.创建自文本 (neLines.取成员 (取循环索引 ())))
                    {
                        变量 neEntry <类型 = YYJSON对象类>
                        neEntry.创建自文本 ("{}")
                        neEntry.加入文本成员 ("startedDateTime", MCP命令服务器.yyjson取文本 (neJson, "timestamp"))
                        neEntry.加入文本成员 ("time", "0")
                        变量 neReqObj <类型 = YYJSON对象类>
                        neReqObj.创建自文本 ("{}")
                        neReqObj.加入文本成员 ("method", MCP命令服务器.yyjson取文本 (neJson, "method"))
                        neReqObj.加入文本成员 ("url", MCP命令服务器.yyjson取文本 (neJson, "url"))
                        neEntry.加入成员 ("request", neReqObj)
                        变量 neRespObj <类型 = YYJSON对象类>
                        neRespObj.创建自文本 ("{}")
                        neRespObj.加入整数成员 ("status", MCP命令服务器.yyjson取整数 (neJson, "status"))
                        neRespObj.加入文本成员 ("statusText", "OK")
                        neRespObj.加入文本成员 ("mimeType", MCP命令服务器.yyjson取文本 (neJson, "mime"))
                        neRespObj.加入整数成员 ("content_size", MCP命令服务器.yyjson取整数 (neJson, "content_length"))
                        neEntry.加入成员 ("response", neRespObj)
                        neEntry.加入文本成员 ("serverIPAddress", "")
                        neEntry.加入文本成员 ("cache", "{}")
                        neEntry.加入文本成员 ("timings", "{\"send\":0,\"wait\":0,\"receive\":0}")
                        neEntries.加入成员 (neEntry)
                    }
                }
                变量 neHarObj <类型 = YYJSON对象类>
                neHarObj.创建自文本 ("{}")
                变量 neHarLog <类型 = YYJSON对象类>
                neHarLog.创建自文本 ("{}")
                neHarLog.加入文本成员 ("version", "1.2")
                变量 neHarCreator <类型 = YYJSON对象类>
                neHarCreator.创建自文本 ("{}")
                neHarCreator.加入文本成员 ("name", "AI浏览器 MCP Server")
                neHarCreator.加入文本成员 ("version", MCP_常量.MCP_版本号)
                neHarLog.加入成员 ("creator", neHarCreator)
                neHarLog.加入数组成员 ("entries", neEntries)
                neHarObj.加入成员 ("log", neHarLog)
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, neHarObj.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则
            {
                // JSON 格式: 返回原始条目数组
                返回 (MCP_响应构建.构建简单JSON ("network_logs", neResult))
            }
        }
        // === 权限API伪装 (v2.8 反检测) ===
        否则 (方法名 == "browser_permission_spoof")
        {
            变量 psAction <类型 = 文本型>
            psAction = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (psAction == "")
            {
                psAction = "apply"
            }
            变量 psBrowser <类型 = 类_FBrowser_浏览器>
            psBrowser = MCP命令服务器.取主浏览器 ()
            如果 (psBrowser.是否为空 () == 假 && psBrowser.是否已关闭 () == 假)
            {
                变量 psFrame <类型 = 类_FBrowser_框架>
                psFrame = MCP命令服务器.取安全主框架 (psBrowser)
                如果 (psFrame.是否为空 () == 假 && psFrame.是否有效 ())
                {
                    如果 (psAction == "apply" || psAction == "spoof")
                    {
                        变量 psState <类型 = 文本型>
                        psState = MCP命令服务器.yyjson取文本 (参数JSON, "state")
                        如果 (psState == "")
                        {
                            psState = "granted"
                        }
                        变量 psPerms <类型 = 文本型>
                        psPerms = MCP命令服务器.yyjson取文本 (参数JSON, "permissions")
                        如果 (psPerms == "")
                        {
                            psPerms = "geolocation,notifications,camera,microphone,midi,clipboard-read,clipboard-write"
                        }
                        // 通过 JS 注入覆盖 Permissions API
                        变量 psCode <类型 = 文本型>
                        psCode = "(function(){"
                        psCode = psCode + "var state='" + psState + "';"
                        子文本替换 (psPerms, ",", "','", , , 假)
                        psCode = psCode + "var perms=['" + psPerms + "'];"
                        psCode = psCode + "if(navigator.permissions&&navigator.permissions.query){"
                        psCode = psCode + "var origQuery=navigator.permissions.query.bind(navigator.permissions);"
                        psCode = psCode + "navigator.permissions.query=function(desc){"
                        psCode = psCode + "if(perms.indexOf(desc.name)!==-1){"
                        psCode = psCode + "return Promise.resolve({state:state,onchange:null});"
                        psCode = psCode + "}return origQuery(desc);"
                        psCode = psCode + "}}"
                        // 同时覆盖 MediaDevices API
                        psCode = psCode + "if(navigator.mediaDevices&&navigator.mediaDevices.enumerateDevices){"
                        psCode = psCode + "var origEnum=navigator.mediaDevices.enumerateDevices.bind(navigator.mediaDevices);"
                        psCode = psCode + "navigator.mediaDevices.enumerateDevices=function(){"
                        psCode = psCode + "if(state==='denied')return Promise.resolve([]);"
                        psCode = psCode + "return origEnum();}"
                        psCode = psCode + "}"
                        psCode = psCode + "return 'Permissions API 已伪装: ' + perms.join(',') + ' → ' + state;"
                        psCode = psCode + "})()"
                        变量 psResult <类型 = 文本型>
                        psResult = MCP命令服务器.提交异步JS任务 (psBrowser, psCode)
                        返回 (MCP命令服务器.包装异步提交结果 (命令ID, psResult, "message", "权限API伪装已注入 | 权限:" + psPerms + " → " + psState + " | 通过mcp_result查询"))
                    }
                    否则 (psAction == "reset" || psAction == "remove")
                    {
                        变量 psResetCode <类型 = 文本型>
                        psResetCode = "(function(){delete navigator.permissions.query;delete navigator.mediaDevices.enumerateDevices;return '权限伪装已移除, 刷新后恢复默认'})()"
                        MCP命令服务器.提交异步JS任务 (psBrowser, psResetCode)
                        返回 (MCP_响应构建.命令成功 (命令ID, "权限伪装已尝试移除 | 建议刷新页面恢复默认"))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + psAction + " | 支持: apply/spoof/reset/remove"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 收集 ===
        否则 (方法名 == "browser_collect")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (action == "network_enable" || action == "network_detail_enable" || action == "network_disable" || action == "network_get" || action == "network_clear" || action == "list" || action == "get" || action == "enable" || action == "disable" || action == "clear" || action == "detail_enable")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_network", 参数JSON))
            }
            否则 (action == "cache_enable")
            {
                MCP命令服务器.是否缓存响应 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "响应缓存已启用 (SQLite)"))
            }
            否则 (action == "cache_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM response_cache")
                返回 (MCP_响应构建.命令成功 (命令ID, "响应缓存已清空 (SQLite, 缓存仍启用)"))
            }
            否则 (action == "console_enable")
            {
                MCP命令服务器.是否记录控制台 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "控制台日志已启用"))
            }
            // === 场景预备: 逆向分析 ===
            否则 (action == "reverse_prepare")
            {
                如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "clear") != 假)
                {
                    MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='network' OR log_type='network_detail'")
                }
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                MCP命令服务器.是否记录控制台 = 真
                变量 指南 <类型 = YYJSON对象类>
                指南.创建自文本 ("{}")
                指南.加入文本成员 ("scenario", "reverse_analyze")
                指南.加入文本成员 ("tip", "navigate 后 browser_network list + browser_evaluate 扫描 script")
                指南.加入文本成员 ("script", "node mcp_bridge.js --call browser_collect '{\"action\":\"reverse_prepare\"}'")
                指南.加入文本成员 ("workflow", "workflow_run name=reverse_analyze")
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 指南.到可读文本 (YYJSON格式化选项.压缩)))
            }
            // === 场景预备: 断点调试 ===
            否则 (action == "debug_prepare")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                变量 指南1 <类型 = YYJSON对象类>
                指南1.创建自文本 ("{}")
                指南1.加入文本成员 ("scenario", "debugger")
                指南1.加入文本成员 ("tip", "VIP: debugger_flow 一键 | 或 enable→breakpoint→navigate→wait_paused→inspect→resume")
                指南1.加入文本成员 ("script", "browser_debugger_flow 或 mcp_bridge.js --call browser_debugger_flow")
                指南1.加入文本成员 ("workflow", "workflow_run name=debugger_full")
                指南1.加入文本成员 ("next_tools", "browser_debugger_flow {url,breakpoint,expressions} | wait_paused → inspect / script_source → resume")
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 指南1.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (action == "debug_wait_paused")
            {
                变量 wMs <类型 = 整数>
                wMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
                如果 (wMs == 0)
                {
                    wMs = 30000
                }
                变量 rawW <类型 = 文本型>
                rawW = MCP命令服务器.等待CDP事件 ("Debugger.paused", wMs)
                如果 (rawW == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "等待 Debugger.paused 超时"))
                }
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, MCP命令服务器.解析Debugger暂停摘要 (rawW)))
            }
            否则 (action == "debug_inspect")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_inspect", 参数JSON))
            }
            否则 (action == "debug_resume")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_resume", 参数JSON))
            }
            否则 (action == "debug_flow")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_flow", 参数JSON))
            }
            否则 (action == "debug_script_source")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_script_source", 参数JSON))
            }
            // === 场景预备: 自动化 ===
            否则 (action == "automation_prepare")
            {
                变量 指南2 <类型 = YYJSON对象类>
                指南2.创建自文本 ("{}")
                指南2.加入文本成员 ("scenario", "automation")
                指南2.加入文本成员 ("tip", "fill_* / dom_* / wait / batch / screenshot 组合使用")
                指南2.加入文本成员 ("script", "workflow_run name=automation_form 或 mcp_bridge.js --call")
                指南2.加入文本成员 ("workflow", "workflow_run name=automation_form")
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 指南2.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (action == "console_disable")
            {
                MCP命令服务器.是否记录控制台 = 假
                返回 (MCP_响应构建.命令成功 (命令ID, "控制台日志已禁用"))
            }
            否则 (action == "console_get")
            {
                如果 (MCP命令服务器.是否记录控制台 == 假)
                {
                    MCP命令服务器.是否记录控制台 = 真
                }
                返回 (MCP_响应构建.构建简单JSON ("console_logs", MCP命令服务器.查询事件日志 ("console", "", 0, 500)))
            }
            否则 (action == "console_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='console'")
                返回 (MCP_响应构建.命令成功 (命令ID, "已清空"))
            }
            // === v2.2 浏览器事件监控 ===
            否则 (action == "event_load_enable")
            {
                MCP命令服务器.是否监控载入事件 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "载入事件监控已启用 (load_start/load_end/load_error/navigate/popup/loading_state_change)"))
            }
            否则 (action == "event_title_enable")
            {
                MCP命令服务器.是否监控标题改变 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "标题改变监控已启用"))
            }
            否则 (action == "event_progress_enable")
            {
                MCP命令服务器.是否监控加载进度 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "加载进度监控已启用 (0/25/50/75/100里程碑)"))
            }
            否则 (action == "event_resource_enable")
            {
                MCP命令服务器.是否监控资源事件 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "资源事件监控已启用 (主框架request/response/redirect)"))
            }
            否则 (action == "event_dialog_enable")
            {
                MCP命令服务器.是否监控对话框 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "JS对话框监控已启用 (alert/confirm/prompt/before_unload/file_dialog)"))
            }
            否则 (action == "event_fullscreen_enable")
            {
                MCP命令服务器.是否监控全屏 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "全屏事件监控已启用"))
            }
            否则 (action == "event_lifecycle_enable")
            {
                MCP命令服务器.是否监控生命周期 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "生命周期事件监控已启用 (browser_created/closing/url_changed/do_close)"))
            }
            否则 (action == "event_favicon_enable")
            {
                MCP命令服务器.是否监控图标 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "网页图标事件监控已启用"))
            }
            否则 (action == "event_find_enable")
            {
                MCP命令服务器.是否监控查找 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "页内查找事件监控已启用"))
            }
            否则 (action == "event_frame_enable")
            {
                MCP命令服务器.是否监控框架 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "框架生命周期事件监控已启用"))
            }
            否则 (action == "event_download_enable")
            {
                MCP命令服务器.是否监控下载事件 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "下载事件监控已启用 (download_request/start/progress)"))
            }
            否则 (action == "event_focus_enable")
            {
                MCP命令服务器.是否监控键盘焦点 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "键盘/焦点事件监控已启用"))
            }
            否则 (action == "event_all_enable")
            {
                MCP命令服务器.是否监控载入事件 = 真
                MCP命令服务器.是否监控标题改变 = 真
                MCP命令服务器.是否监控加载进度 = 真
                MCP命令服务器.是否监控对话框 = 真
                MCP命令服务器.是否监控全屏 = 真
                MCP命令服务器.是否监控图标 = 真
                MCP命令服务器.是否监控查找 = 真
                MCP命令服务器.是否监控框架 = 真
                MCP命令服务器.是否监控下载事件 = 真
                MCP命令服务器.是否监控生命周期 = 真
                MCP命令服务器.是否监控应用事件 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "全部事件监控已启用(含应用事件, 已排除 resource/keyboard 高频噪音) | event_log 上限 " + 到文本 (MCP_常量.事件日志最大条目) + " 条"))
            }
            否则 (action == "event_app_enable")
            {
                MCP命令服务器.是否监控应用事件 = 真
                返回 (MCP_响应构建.命令成功 (命令ID, "应用事件监控已启用 (v8/异常/焦点/渲染载入/IPC)"))
            }
            否则 (action == "event_all_disable")
            {
                MCP命令服务器.是否监控载入事件 = 假
                MCP命令服务器.是否监控标题改变 = 假
                MCP命令服务器.是否监控加载进度 = 假
                MCP命令服务器.是否监控资源事件 = 假
                MCP命令服务器.是否监控对话框 = 假
                MCP命令服务器.是否监控全屏 = 假
                MCP命令服务器.是否监控图标 = 假
                MCP命令服务器.是否监控查找 = 假
                MCP命令服务器.是否监控框架 = 假
                MCP命令服务器.是否监控下载事件 = 假
                MCP命令服务器.是否监控键盘焦点 = 假
                MCP命令服务器.是否监控生命周期 = 假
                MCP命令服务器.是否监控应用事件 = 假
                返回 (MCP_响应构建.命令成功 (命令ID, "全部浏览器事件监控已禁用"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + action + " | 支持: network_enable/detail_enable/disable/get/clear, cache_set_dir/clear, console_enable/get/clear, event_*_enable/all_enable/all_disable"))
        }
        // === 浏览器完整状态 ===
        如果 (方法名 == "browser_status")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 状态对象 <类型 = YYJSON对象类>
                状态对象.创建自文本 ("{}")
                状态对象.加入逻辑值成员 ("is_popup", browser.是否为弹窗 ())
                状态对象.加入逻辑值成员 ("has_document", browser.是否有文档 ())
                状态对象.加入逻辑值成员 ("can_go_back", browser.可否后退 ())
                状态对象.加入逻辑值成员 ("can_go_forward", browser.可否前进 ())
                状态对象.加入逻辑值成员 ("is_loading", browser.是否读取中 ())
                状态对象.加入逻辑值成员 ("is_muted", browser.是否页面静音 ())
                状态对象.加入整数成员 ("browser_id", browser.取ID ())
                状态对象.加入整数成员 ("zoom_level_pct", 取整 (四舍五入 (browser.取缩放级别 () * 100, 0)))
                变量 statusUrlFrame <类型 = 类_FBrowser_框架>
                statusUrlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (statusUrlFrame.是否为空 () == 假)
                {
                    状态对象.加入文本成员 ("url", statusUrlFrame.取地址 ())
                }
                否则
                {
                    状态对象.加入文本成员 ("url", "")
                }
                状态对象.加入文本成员 ("window_title", browser.取窗口标题 ())
                状态对象.加入文本成员 ("user_flag", browser.取用户标识 ())
                变量 hwnd <类型 = 变整数>
                hwnd = browser.取窗口句柄 ()
                状态对象.加入文本成员 ("hwnd", 到文本 (hwnd))
                状态对象.加入逻辑值成员 ("is_closed", browser.是否已关闭 ())
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 状态对象.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 尝试关闭 (已禁用) ===
        否则 (方法名 == "browser_close_try")
        {
            返回 (MCP_响应构建.命令失败 (命令ID, "⛔ 远程关闭浏览器已禁用 | 浏览器生命周期由GUI管理"))
        }
        // === 源码视图 ===
        否则 (方法名 == "browser_view_source")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 viewSrcFrame <类型 = 类_FBrowser_框架>
                viewSrcFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (viewSrcFrame.是否为空 () == 假 && viewSrcFrame.是否有效 ())
                {
                    viewSrcFrame.源码视图 ()
                    返回 (MCP_响应构建.命令成功 (命令ID, "源码视图已打开"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 焦点框架 ===
        否则 (方法名 == "browser_get_focused_frame")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 focusFrame <类型 = 类_FBrowser_框架>
                focusFrame = browser.取当前焦点框架 ()
                如果 (focusFrame.是否为空 () == 假)
                {
                    变量 框架信息 <类型 = YYJSON对象类>
                    框架信息.创建自文本 ("{}")
                    框架信息.加入文本成员 ("url", focusFrame.取地址 ())
                    框架信息.加入文本成员 ("name", focusFrame.取框架名 ())
                    框架信息.加入文本成员 ("frame_id", focusFrame.取框架ID ())
                    框架信息.加入逻辑值成员 ("is_main", focusFrame.是否为主框架 ())
                    框架信息.加入逻辑值成员 ("is_focused", 真)
                    框架信息.加入逻辑值成员 ("is_valid", focusFrame.是否有效 ())
                    返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 框架信息.到可读文本 (YYJSON格式化选项.压缩)))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, "没有焦点框架"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 下载图片 ===
        否则 (方法名 == "browser_download_image")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "参数 url 不能为空"))
            }
            变量 urlLower <类型 = 文本型>
            urlLower = 到小写 (url)
            如果 (MCP命令服务器.是否以 (urlLower, "http://") == 假 && MCP命令服务器.是否以 (urlLower, "https://") == 假)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "仅支持http/https URL"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 异步下载ID <类型 = 文本型>
                异步下载ID = MCP命令服务器.生成异步任务ID ()
                变量 下载回调 <类型 = 类_FBrowser_事件智能指针>
                下载回调.创建 (类_MCP_下载图片回调)
                下载回调.取执行类 (类_MCP_下载图片回调).任务ID = 异步下载ID
                browser.下载图片 (url, 假, 0, 假, 下载回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步下载ID, "图片下载已提交, 通过mcp_result查询"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 元数据 ===
        否则 (方法名 == "browser_meta")
        {
            变量 元数据对象 <类型 = YYJSON对象类>
            元数据对象.创建自文本 ("{}")
            元数据对象.加入文本成员 ("machine_code", FBrowserVIP注册.VIP注册_取机器码 ())
            元数据对象.加入文本成员 ("start_date", FBrowserVIP注册.VIP注册_取开始时间 ())
            元数据对象.加入文本成员 ("end_date", FBrowserVIP注册.VIP注册_取到期时间 ())
            元数据对象.加入文本成员 ("features", FBrowserVIP注册.VIP注册_取注册功能 ())
            元数据对象.加入文本成员 ("license_version", FBrowserVIP注册.VIP注册_取注册版本 ())
            元数据对象.加入文本成员 ("license_type", FBrowserVIP注册.VIP注册_取注册码类型 ())
            元数据对象.加入整数成员 ("browser_count", FBrowser_浏览器_取数量 ())
            元数据对象.加入文本成员 ("fbro_version", FBrowser_取版本号 ())
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 元数据对象.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 任务结果查询 ===
        否则 (方法名 == "mcp.result" || 方法名 == "mcp_result")
        {
            变量 request_id <类型 = 文本型>
            request_id = MCP命令服务器.yyjson取文本 (参数JSON, "request_id")
            变量 consume <类型 = 逻辑型>
            consume = MCP命令服务器.yyjson取逻辑 (参数JSON, "consume")
            变量 实际任务ID <类型 = 文本型>
            实际任务ID = request_id
            如果 (request_id != "")
            {
                变量 存储结果 <类型 = 文本型>
                存储结果 = MCP命令服务器.查询任务结果 (request_id)
                如果 (存储结果 == "")
                {
                    // 兼容: 客户端传入 task_id 而非 JSON-RPC request id
                    存储结果 = MCP命令服务器.查询异步结果 (request_id)
                }
                如果 (存储结果 != "")
                {
                    变量 结果解析 <类型 = YYJSON只读对象类>
                    如果 (结果解析.创建自文本 (存储结果))
                    {
                        // 异步 stub 含 task_id 时, 自动跟随到真实结果
                        如果 (结果解析.取逻辑值 ("_async") && 结果解析.取逻辑值 ("_waiting") == 假)
                        {
                            变量 linkedTaskID <类型 = 文本型>
                            linkedTaskID = MCP命令服务器.yyjson取文本 (结果解析, "task_id")
                            如果 (linkedTaskID != "" && linkedTaskID != request_id)
                            {
                                变量 真实结果 <类型 = 文本型>
                                真实结果 = MCP命令服务器.查询异步结果 (linkedTaskID)
                                如果 (真实结果 != "")
                                {
                                    存储结果 = 真实结果
                                    实际任务ID = linkedTaskID
                                    结果解析.创建自文本 (存储结果)
                                }
                            }
                        }
                        // ================================================================
                        //  等待轮询状态机 (browser_wait 的客户端侧推进引擎)

                        //  每次 mcp_result 调用推进一个状态:
                        //  ┌─ 已超时(max_ms) ──→ what=timeout → 成功完成
                        //  │                  ──→ what=selector/text/navigate → 失败(超时)
                        //  │
                        //  └─ 未超时:
                        //       ├─ what=timeout → 返回 "等待中..."
                        //       └─ what=selector/text:
                        //            ├─ 阶段1 (无 _check_task_id) → 提交JS检查
                        //            └─ 阶段2 (有 _check_task_id) → 查询JS结果
                        //                 ├─ found=true  → 成功
                        //                 └─ found=false → 重置,下一轮重试
                        // ================================================================
                        如果 (结果解析.取逻辑值 ("_waiting"))
                        {
                            变量 waitWhat <类型 = 文本型>
                            waitWhat = MCP命令服务器.yyjson取文本 (结果解析, "what")
                            变量 waitStartTime <类型 = 长整数>
                            waitStartTime = MCP命令服务器.yyjson取长整数 (结果解析, "start_time")
                            变量 waitMaxMs <类型 = 整数>
                            waitMaxMs = MCP命令服务器.yyjson取整数 (结果解析, "max_ms")
                            // _poll_count 仅作诊断; 超时以 max_ms 为准 (避免高频轮询早于 max_ms 误中止)
                            变量 pollCount <类型 = 整数>
                            pollCount = MCP命令服务器.yyjson取整数 (结果解析, "_poll_count")
                            pollCount = pollCount + 1
                            // 更新_poll_count到存储
                            变量 更新计数存储 <类型 = YYJSON对象类>
                            更新计数存储.创建自文本 (存储结果)
                            更新计数存储.加入整数成员 ("_poll_count", pollCount)
                            MCP命令服务器.存储异步结果 (request_id, 更新计数存储.到可读文本 (YYJSON格式化选项.压缩))
                            // 检查超时
                            如果 (取启动时间 () - waitStartTime >= waitMaxMs)
                            {
                                MCP命令服务器.清理等待检查子任务 (存储结果)
                                // timeout类型: 等待时间到达 = 成功完成
                                如果 (waitWhat == "timeout")
                                {
                                    变量 超时成功 <类型 = YYJSON对象类>
                                    超时成功.创建自文本 ("{}")
                                    超时成功.加入逻辑值成员 ("success", 真)
                                    超时成功.加入文本成员 ("message", "等待完成: timeout " + 到文本 (waitMaxMs) + "ms 已到达")
                                    MCP命令服务器.存储异步结果 (request_id, 超时成功.到可读文本 (YYJSON格式化选项.压缩))
                                    返回 (超时成功.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                // selector/text类型: 超时未匹配 = 失败
                                变量 超时结果 <类型 = YYJSON对象类>
                                超时结果.创建自文本 ("{}")
                                超时结果.加入逻辑值成员 ("success", 假)
                                超时结果.加入文本成员 ("error", "等待超时(" + 到文本 (waitMaxMs) + "ms): " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value"))
                                // 更新存储结果, 清除_waiting标记
                                MCP命令服务器.存储异步结果 (request_id, 超时结果.到可读文本 (YYJSON格式化选项.压缩))
                                返回 (超时结果.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            如果 (waitWhat == "timeout")
                            {
                                // timeout类型: 继续等待, 不更新状态
                                变量 继续等待 <类型 = YYJSON对象类>
                                继续等待.创建自文本 ("{}")
                                继续等待.加入逻辑值成员 ("success", 真)
                                继续等待.加入文本成员 ("message", "等待中... 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                继续等待.加入逻辑值成员 ("_waiting", 真)
                                继续等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                继续等待.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                返回 (继续等待.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则 (waitWhat == "network_idle")
                            {
                                // 服务端检查: 活动网络请求数==0 且最后释放后已过 idle_ms
                                变量 idleMs <类型 = 整数>
                                idleMs = MCP命令服务器.yyjson取整数 (结果解析, "idle_ms")
                                如果 (idleMs <= 0)
                                {
                                    idleMs = 2000
                                }
                                变量 最后释放 <类型 = 长整数>
                                变量 当前活动数 <类型 = 整数>
                                MCP命令服务器.异步缓存锁.加锁 ()
                                最后释放 = MCP命令服务器.最后URL请求槽释放时间
                                当前活动数 = MCP命令服务器.活动URL请求数
                                MCP命令服务器.异步缓存锁.解锁 ()
                                如果 (当前活动数 == 0 && (最后释放 == 0 || 取启动时间 () - 最后释放 >= idleMs))
                                {
                                    变量 idle成功 <类型 = YYJSON对象类>
                                    idle成功.创建自文本 ("{}")
                                    idle成功.加入逻辑值成员 ("success", 真)
                                    idle成功.加入文本成员 ("message", "网络已空闲: " + 到文本 (取启动时间 () - 最后释放) + "ms 无活动请求")
                                    MCP命令服务器.存储异步结果 (request_id, idle成功.到可读文本 (YYJSON格式化选项.压缩))
                                    MCP命令服务器.清理等待检查子任务 (存储结果)
                                    返回 (idle成功.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                // 未空闲: 返回等待中状态
                                变量 idle等待 <类型 = YYJSON对象类>
                                idle等待.创建自文本 ("{}")
                                idle等待.加入逻辑值成员 ("success", 真)
                                idle等待.加入逻辑值成员 ("_waiting", 真)
                                idle等待.加入文本成员 ("message", "等待网络空闲... 活跃请求:" + 到文本 (当前活动数) + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s")
                                idle等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                返回 (idle等待.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则 (waitWhat == "load_end" || waitWhat == "load_start")
                            {
                                // 事件驱动(browser_navigate/reload wait_for_load): 由 解析等待任务 在 OnLoadEnd/OnLoadStart 回调中解析
                                // 此状态机仅保活+超时, 不自作主张判断 页面加载中 标志 (避免导航尚未开始/旧页面残留状态导致的假阳性)
                                变量 是否事件驱动 <类型 = 逻辑型>
                                是否事件驱动 = MCP命令服务器.yyjson取逻辑 (结果解析, "_event_driven")
                                如果 (是否事件驱动)
                                {
                                    变量 ev等待 <类型 = YYJSON对象类>
                                    ev等待.创建自文本 ("{}")
                                    ev等待.加入逻辑值成员 ("success", 真)
                                    ev等待.加入逻辑值成员 ("_waiting", 真)
                                    ev等待.加入文本成员 ("message", "等待OnLoadEnd事件触发... 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                    ev等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                    ev等待.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                    返回 (ev等待.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                // 原生: CEF事件缓存 页面加载中 标志, 非JS document.readyState (poll-driven like browser_wait)
                                变量 期望加载 <类型 = 逻辑型>
                                期望加载 = waitWhat == "load_start"
                                变量 当前加载 <类型 = 逻辑型>
                                当前加载 = 浏览器容器.页面加载中
                                如果 (当前加载 == 期望加载)
                                {
                                    变量 load成功 <类型 = YYJSON对象类>
                                    load成功.创建自文本 ("{}")
                                    load成功.加入逻辑值成员 ("success", 真)
                                    load成功.加入文本成员 ("message", "页面状态满足: " + waitWhat)
                                    MCP命令服务器.存储异步结果 (request_id, load成功.到可读文本 (YYJSON格式化选项.压缩))
                                    MCP命令服务器.清理等待检查子任务 (存储结果)
                                    返回 (load成功.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                变量 load等待 <类型 = YYJSON对象类>
                                load等待.创建自文本 ("{}")
                                load等待.加入逻辑值成员 ("success", 真)
                                load等待.加入逻辑值成员 ("_waiting", 真)
                                load等待.加入文本成员 ("message", "等待" + waitWhat + "... 当前加载=" + 到文本 (当前加载) + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s")
                                load等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                返回 (load等待.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则 (waitWhat == "js_exec")
                            {
                                // JS异步执行预占位: 等待CEF回调完成, 超时时走前面通用超时路径
                                变量 jsWaitMsg <类型 = YYJSON对象类>
                                jsWaitMsg.创建自文本 ("{}")
                                jsWaitMsg.加入逻辑值成员 ("success", 真)
                                jsWaitMsg.加入逻辑值成员 ("_waiting", 真)
                                jsWaitMsg.加入文本成员 ("message", MCP命令服务器.yyjson取文本 (结果解析, "message"))
                                jsWaitMsg.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                jsWaitMsg.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                返回 (jsWaitMsg.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则 (waitWhat == "scrape")
                            {
                                // 爬虫状态机: phase 0(等load)→1(等selector)→2(提取)→完成
                                // 浏览器已关闭时立即终止
                                变量 scrapeBrowser <类型 = 类_FBrowser_浏览器>
                                scrapeBrowser = MCP命令服务器.取主浏览器 ()
                                如果 (scrapeBrowser.是否为空 () || scrapeBrowser.是否已关闭 ())
                                {
                                    变量 sFail <类型 = YYJSON对象类>
                                    sFail.创建自文本 ("{}")
                                    sFail.加入逻辑值成员 ("success", 假)
                                    sFail.加入文本成员 ("error", "爬虫中断: 浏览器已关闭")
                                    MCP命令服务器.存储异步结果 (request_id, sFail.到可读文本 (YYJSON格式化选项.压缩))
                                    MCP命令服务器.清理等待检查子任务 (存储结果)
                                    返回 (sFail.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                变量 scrapePhase <类型 = 整数>
                                scrapePhase = MCP命令服务器.yyjson取整数 (结果解析, "_phase")
                                变量 scrapeWaitSel <类型 = 文本型>
                                scrapeWaitSel = MCP命令服务器.yyjson取文本 (结果解析, "wait_selector")
                                变量 scrapeExtSel <类型 = 文本型>
                                scrapeExtSel = MCP命令服务器.yyjson取文本 (结果解析, "extract_selector")
                                如果 (scrapePhase == 0)
                                {
                                    // Phase 0: 等待页面加载完成
                                    如果 (浏览器容器.页面加载中 == 假)
                                    {
                                        scrapePhase = 1
                                        变量 sUpd <类型 = YYJSON对象类>
                                        sUpd.创建自文本 (存储结果)
                                        sUpd.加入整数成员 ("_phase", scrapePhase)
                                        MCP命令服务器.存储异步结果 (request_id, sUpd.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                }
                                如果 (scrapePhase == 1)
                                {
                                    // Phase 1: 等待selector (如指定) 或直接进入phase 2
                                    如果 (scrapeWaitSel != "")
                                    {
                                        变量 sCheckID <类型 = 文本型>
                                        sCheckID = MCP命令服务器.yyjson取文本 (结果解析, "_check_task_id")
                                        如果 (sCheckID == "")
                                        {
                                            变量 sCode <类型 = 文本型>
                                            sCode = "(function(){var el=document.querySelector('" + MCP命令服务器.简单转义JS (scrapeWaitSel) + "');return JSON.stringify({found:!!el})})()"
                                            变量 sBrowser <类型 = 类_FBrowser_浏览器>
                                            sBrowser = MCP命令服务器.取主浏览器 ()
                                            如果 (sBrowser.是否为空 () == 假)
                                            {
                                                变量 sSubmit <类型 = 文本型>
                                                sSubmit = MCP命令服务器.提交异步JS任务 (sBrowser, sCode)
                                                变量 sSubParse <类型 = YYJSON只读对象类>
                                                如果 (sSubParse.创建自文本 (sSubmit))
                                                {
                                                    sCheckID = sSubParse.取文本 ("task_id")
                                                    如果 (sCheckID != "")
                                                    {
                                                        变量 sUpd2 <类型 = YYJSON对象类>
                                                        sUpd2.创建自文本 (存储结果)
                                                        sUpd2.加入文本成员 ("_check_task_id", sCheckID)
                                                        MCP命令服务器.存储异步结果 (request_id, sUpd2.到可读文本 (YYJSON格式化选项.压缩))
                                                    }
                                                }
                                            }
                                        }
                                        否则
                                        {
                                            变量 sCheckResult <类型 = 文本型>
                                            sCheckResult = MCP命令服务器.查询异步结果 (sCheckID)
                                            如果 (sCheckResult != "")
                                            {
                                                变量 sChkParse <类型 = YYJSON只读对象类>
                                                如果 (sChkParse.创建自文本 (sCheckResult) && sChkParse.取逻辑值 ("found"))
                                                {
                                                    scrapePhase = 2
                                                    变量 sUpd3 <类型 = YYJSON对象类>
                                                    sUpd3.创建自文本 (存储结果)
                                                    sUpd3.加入整数成员 ("_phase", 2)
                                                    sUpd3.加入文本成员 ("_check_task_id", "")
                                                    MCP命令服务器.存储异步结果 (request_id, sUpd3.到可读文本 (YYJSON格式化选项.压缩))
                                                }
                                                否则
                                                {
                                                    // JS回调返回但found为false: 清除check_id, 下次轮询重新提交
                                                    变量 sUpd3b <类型 = YYJSON对象类>
                                                    sUpd3b.创建自文本 (存储结果)
                                                    sUpd3b.加入文本成员 ("_check_task_id", "")
                                                    MCP命令服务器.存储异步结果 (request_id, sUpd3b.到可读文本 (YYJSON格式化选项.压缩))
                                                }
                                            }
                                            // sCheckResult为空时保持_check_task_id, 等待JS回调完成
                                        }
                                    }
                                    否则
                                    {
                                        scrapePhase = 2
                                    }
                                }
                                如果 (scrapePhase == 2)
                                {
                                    // Phase 2: 提交提取任务 → 进入phase 3等待结果
                                    变量 sBrowser <类型 = 类_FBrowser_浏览器>
                                    sBrowser = MCP命令服务器.取主浏览器 ()
                                    如果 (sBrowser.是否为空 () == 假)
                                    {
                                        变量 sExtID <类型 = 文本型>
                                        sExtID = MCP命令服务器.生成异步任务ID ()
                                        如果 (scrapeExtSel != "" && scrapeExtSel != "body")
                                        {
                                            变量 sFF <类型 = 类_FBrowser_填表框架>
                                            sFF = sBrowser.取主填表框架 ()
                                            如果 (sFF.是否有效 ())
                                            {
                                                变量 sExtCB <类型 = 类_FBrowser_事件智能指针>
                                                sExtCB.创建 (类_MCP_JS异步回调)
                                                sExtCB.取执行类 (类_MCP_JS异步回调).任务ID = sExtID
                                                sFF.取元素内容 (scrapeExtSel, 0, sExtCB)
                                            }
                                            否则
                                            {
                                                // 填表框架无效: 立即存储失败结果, 跳过phase 3等待
                                                MCP命令服务器.存储异步结果 (sExtID, MCP_响应构建.构建标准失败JSON ("填表框架无效, 无法提取元素: " + scrapeExtSel))
                                            }
                                        }
                                        否则
                                        {
                                            MCP命令服务器.提交异步取文本任务 (sBrowser, sExtID)
                                        }
                                        变量 sUpd4 <类型 = YYJSON对象类>
                                        sUpd4.创建自文本 (存储结果)
                                        sUpd4.加入整数成员 ("_phase", 3)
                                        sUpd4.加入文本成员 ("_extract_task_id", sExtID)
                                        MCP命令服务器.存储异步结果 (request_id, sUpd4.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                }
                                如果 (scrapePhase == 3)
                                {
                                    // Phase 3: 查询提取结果 → 完成
                                    变量 sExtTaskID <类型 = 文本型>
                                    sExtTaskID = MCP命令服务器.yyjson取文本 (结果解析, "_extract_task_id")
                                    变量 sExtResult <类型 = 文本型>
                                    sExtResult = MCP命令服务器.查询异步结果 (sExtTaskID)
                                    如果 (sExtResult != "")
                                    {
                                        变量 sFinal <类型 = YYJSON对象类>
                                        sFinal.创建自文本 ("{}")
                                        sFinal.加入逻辑值成员 ("success", 真)
                                        变量 sMsg <类型 = 文本型>
                                        变量 sParse <类型 = YYJSON只读对象类>
                                        如果 (sParse.创建自文本 (sExtResult))
                                        {
                                            sMsg = MCP命令服务器.yyjson取文本 (sParse, "message")
                                        }
                                        如果 (sMsg == "")
                                        {
                                            sMsg = sExtResult
                                        }
                                        sFinal.加入文本成员 ("text", 取文本左边 (sMsg, 262144))
                                        MCP命令服务器.存储异步结果 (request_id, sFinal.到可读文本 (YYJSON格式化选项.压缩))
                                        MCP命令服务器.清理等待检查子任务 (存储结果)
                                        返回 (sFinal.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                }
                                // 未完成: 返回等待中
                                变量 sWaitResp <类型 = YYJSON对象类>
                                sWaitResp.创建自文本 ("{}")
                                sWaitResp.加入逻辑值成员 ("success", 真)
                                sWaitResp.加入逻辑值成员 ("_waiting", 真)
                                sWaitResp.加入文本成员 ("message", "爬虫中(phase=" + 到文本 (scrapePhase) + ") 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s")
                                sWaitResp.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                返回 (sWaitResp.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则
                            {
                                // selector/text/navigate/url_contains类型: 两阶段异步检查
                                // 阶段1: 未提交检查 → 提交JS并存储check_task_id, 等待下一轮轮询
                                // 阶段2: 已有检查 → 查询异步缓存获取实际JS执行结果
                                变量 checkTaskID <类型 = 文本型>
                                checkTaskID = MCP命令服务器.yyjson取文本 (结果解析, "_check_task_id")
                                如果 (checkTaskID == "")
                                {
                                    // 阶段1: 提交新的JS条件检查
                                    变量 browser <类型 = 类_FBrowser_浏览器>
                                    browser = MCP命令服务器.取主浏览器 ()
                                    如果 (browser.是否为空 ())
                                    {
                                        MCP命令服务器.清理等待检查子任务 (存储结果)
                                        变量 浏览器不可用 <类型 = YYJSON对象类>
                                        浏览器不可用.创建自文本 ("{}")
                                        浏览器不可用.加入逻辑值成员 ("success", 假)
                                        浏览器不可用.加入文本成员 ("error", "等待中断: 浏览器已不可用")
                                        MCP命令服务器.存储异步结果 (request_id, 浏览器不可用.到可读文本 (YYJSON格式化选项.压缩))
                                        返回 (浏览器不可用.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                    变量 checkCode <类型 = 文本型>
                                    checkCode = MCP命令服务器.yyjson取文本 (结果解析, "check_code")
                                    如果 (checkCode != "")
                                    {
                                        变量 rawSubmit <类型 = 文本型>
                                        rawSubmit = MCP命令服务器.提交异步JS任务 (browser, checkCode)
                                        变量 submit解析 <类型 = YYJSON只读对象类>
                                        如果 (submit解析.创建自文本 (rawSubmit))
                                        {
                                            checkTaskID = submit解析.取文本 ("task_id")
                                            如果 (checkTaskID != "")
                                            {
                                                变量 更新等待存储 <类型 = YYJSON对象类>
                                                更新等待存储.创建自文本 (存储结果)
                                                更新等待存储.加入文本成员 ("_check_task_id", checkTaskID)
                                                更新等待存储.加入整数成员 ("_poll_count", pollCount)
                                                MCP命令服务器.存储异步结果 (request_id, 更新等待存储.到可读文本 (YYJSON格式化选项.压缩))
                                            }
                                        }
                                    }
                                    变量 等待提交 <类型 = YYJSON对象类>
                                    等待提交.创建自文本 ("{}")
                                    等待提交.加入逻辑值成员 ("success", 真)
                                    等待提交.加入逻辑值成员 ("_waiting", 真)
                                    等待提交.加入文本成员 ("message", "等待中... " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value") + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                    等待提交.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                    等待提交.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                    返回 (等待提交.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                否则
                                {
                                    // 阶段2: 查询异步JS执行结果
                                    变量 checkResultJSON <类型 = 文本型>
                                    checkResultJSON = MCP命令服务器.查询异步结果 (checkTaskID, 真)
                                    如果 (checkResultJSON != "")
                                    {
                                        // JS结果已到达, 解析found字段
                                        变量 check解析 <类型 = YYJSON只读对象类>
                                        如果 (check解析.创建自文本 (checkResultJSON))
                                        {
                                            变量 checkMsg <类型 = 文本型>
                                            checkMsg = MCP命令服务器.yyjson取文本 (check解析, "message")
                                            变量 foundMatch <类型 = 逻辑型 值 = 假>
                                            // message 是 JS 回调包装的 JSON: {"found":true,...}
                                            如果 (checkMsg != "")
                                            {
                                                变量 innerParse <类型 = YYJSON只读对象类>
                                                如果 (innerParse.创建自文本 (checkMsg) && innerParse.取逻辑值 ("found"))
                                                {
                                                    foundMatch = 真
                                                }
                                            }
                                            如果 (foundMatch)
                                            {
                                                如果 (waitWhat == "load_start")
                                                {
                                                    变量 loadPhase <类型 = 整数>
                                                    loadPhase = MCP命令服务器.yyjson取整数 (结果解析, "_load_phase")
                                                    如果 (loadPhase == 0)
                                                    {
                                                        MCP命令服务器.清理等待检查子任务 (存储结果)
                                                        变量 阶段切换 <类型 = YYJSON对象类>
                                                        阶段切换.创建自文本 (存储结果)
                                                        阶段切换.加入整数成员 ("_load_phase", 1)
                                                        阶段切换.加入文本成员 ("check_code", "(function(){return JSON.stringify({found:document.readyState==='complete',readyState:document.readyState})})()")
                                                        阶段切换.删除成员 ("_check_task_id")
                                                        阶段切换.加入整数成员 ("_poll_count", pollCount)
                                                        MCP命令服务器.存储异步结果 (request_id, 阶段切换.到可读文本 (YYJSON格式化选项.压缩))
                                                        变量 阶段等待 <类型 = YYJSON对象类>
                                                        阶段等待.创建自文本 ("{}")
                                                        阶段等待.加入逻辑值成员 ("success", 真)
                                                        阶段等待.加入逻辑值成员 ("_waiting", 真)
                                                        阶段等待.加入文本成员 ("message", "load_start: 已检测到 loading, 等待 load_end... 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                                        阶段等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                                        阶段等待.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                                        返回 (阶段等待.到可读文本 (YYJSON格式化选项.压缩))
                                                    }
                                                }
                                                MCP命令服务器.清理等待检查子任务 (存储结果)
                                                变量 找到结果 <类型 = YYJSON对象类>
                                                找到结果.创建自文本 ("{}")
                                                找到结果.加入逻辑值成员 ("success", 真)
                                                找到结果.加入文本成员 ("message", "等待完成: " + waitWhat + " 匹配成功 (" + 到文本 (取启动时间 () - waitStartTime) + "ms)")
                                                找到结果.加入文本成员 ("result", checkMsg)
                                                MCP命令服务器.存储异步结果 (request_id, 找到结果.到可读文本 (YYJSON格式化选项.压缩))
                                                返回 (找到结果.到可读文本 (YYJSON格式化选项.压缩))
                                            }
                                        }
                                        // 条件未满足: 清除check_task_id, 下一轮重新提交检查
                                        变量 重置等待 <类型 = YYJSON对象类>
                                        重置等待.创建自文本 (存储结果)
                                        重置等待.删除成员 ("_check_task_id")
                                        重置等待.加入整数成员 ("_poll_count", pollCount)
                                        MCP命令服务器.存储异步结果 (request_id, 重置等待.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                    // 检查结果尚未到达: 继续等待
                                    变量 等待结果 <类型 = YYJSON对象类>
                                    等待结果.创建自文本 ("{}")
                                    等待结果.加入逻辑值成员 ("success", 真)
                                    等待结果.加入逻辑值成员 ("_waiting", 真)
                                    等待结果.加入文本成员 ("message", "等待中... " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value") + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                    等待结果.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                    等待结果.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                    返回 (等待结果.到可读文本 (YYJSON格式化选项.压缩))
                                }
                            }
                        }
                        变量 是否成功 <类型 = 逻辑型>
                        是否成功 = 结果解析.取逻辑值 ("success")
                        变量 msg <类型 = 文本型>
                        如果 (是否成功 == 假)
                        {
                            msg = MCP命令服务器.yyjson取文本 (结果解析, "error")
                            如果 (msg != "")
                            {
                                msg = "[任务" + request_id + "] " + msg
                            }
                            否则
                            {
                                msg = "[任务" + request_id + "] 任务执行失败"
                            }
                        }
                        否则
                        {
                            msg = MCP命令服务器.yyjson取文本 (结果解析, "message")
                            如果 (msg == "")
                            {
                                msg = "success"
                            }
                        }
                        变量 原始数据JSON <类型 = 文本型>
                        原始数据JSON = MCP命令服务器.yyjson取JSON文本 (结果解析, "data")
                        如果 (原始数据JSON == "" && 是否成功)
                        {
                            变量 msgContent <类型 = 文本型>
                            msgContent = MCP命令服务器.yyjson取文本 (结果解析, "message")
                            变量 msgParse <类型 = YYJSON只读对象类>
                            如果 (msgContent != "" && msgParse.创建自文本 (msgContent))
                            {
                                原始数据JSON = msgContent
                            }
                        }
                        变量 响应JSON <类型 = 文本型>
                        响应JSON = MCP_响应构建.构建任务查询结果JSON (是否成功, msg, 原始数据JSON, 实际任务ID)
                        如果 (consume && 结果解析.取逻辑值 ("_waiting") == 假)
                        {
                            MCP命令服务器.删除异步结果 (实际任务ID)
                            如果 (实际任务ID != request_id)
                            {
                                MCP命令服务器.删除异步结果 (request_id)
                            }
                        }
                        返回 (响应JSON)
                    }
                }
                返回 (MCP_响应构建.命令失败 (命令ID, "未找到任务结果: " + request_id + " | 可能原因: ①任务仍在执行(2-5秒后重试) ②request_id拼写错误 ③任务已过期被清理 | 💡大多数工具已默认sync-wait(直接返回结果), 无需手动mcp_result轮询"))
            }
            返回 (MCP_响应构建.命令失败 ("", "参数 request_id 不能为空 | 异步任务请使用 task_id (tools/call 返回的 task_xxx)"))
        }
        // === MCP状态 ===
        否则 (方法名 == "mcp.status" || 方法名 == "mcp_status")
        {
            变量 状态对象 <类型 = YYJSON对象类>
            状态对象.创建自文本 ("{}")
            状态对象.加入文本成员 ("server", MCP_常量.MCP_服务器名)
            状态对象.加入文本成员 ("version", MCP_常量.MCP_版本号)
            状态对象.加入整数成员 ("port", MCP命令服务器.服务器端口)
            状态对象.加入整数成员 ("browser_count", FBrowser_浏览器_取数量 ())
            状态对象.加入文本成员 ("status", "running")
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 状态对象.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 帮助 ===
        否则 (方法名 == "mcp.help" || 方法名 == "mcp_help")
        {
            变量 帮助文本 <类型 = 文本型>
            帮助文本 = "=== AI浏览器 MCP v" + MCP_常量.MCP_版本号 + " 工具列表 ===\r\n\r\n"
            帮助文本 = 帮助文本 + "【导航】navigate(url) get_url get_title back forward reload stop\r\n"
            帮助文本 = 帮助文本 + "【内容】get_source get_text(selector?) extract(type:links/images/tables)\r\n"
            帮助文本 = 帮助文本 + "【DOM-原生】dom_query(selector,attribute?) dom_click(selector) dom_set_value(selector,value) dom_get_html dom_rect(selector) dom_inner_html(selector) dom_set_html(selector,html) dom_checked(selector) dom_selected(selector) dom_select(selector,index)\r\n"
            帮助文本 = 帮助文本 + "【填表-原生】fill_set_value fill_click fill_focus fill_scroll fill_exists fill_attr_get fill_attr_set fill_trigger fill_select\r\n"
            帮助文本 = 帮助文本 + "【JS执行】evaluate(code) execute_js(code) console_eval(expression) inject(type:js/css,code,persist?)\r\n"
            帮助文本 = 帮助文本 + "【自动化】wait(what:selector/text/timeout/load_end/load_start/navigate/network_idle/url_contains,value?,max_ms?) scrape(url,wait_selector?,extract_selector?,max_ms?)\r\n"
            帮助文本 = 帮助文本 + "【爬虫】browser_extract(type:links/images/tables,limit?) browser_scrape(url,extract_selector,wait_selector?,max_ms?)\r\n"
            帮助文本 = 帮助文本 + "【抓包】network(action:enable/detail_enable/list/clear) network_body(url) collect(action:console_enable/console_get/network_enable)\r\n"
            帮助文本 = 帮助文本 + "【逆向】cdp_call(method,params?,max_ms?) debugger_flow(url,breakpoint,expressions?,resume?) debugger_auto(url,breakpoint,max_ms?) cdp_event debugger_wait_paused debugger_inspect\r\n"
            帮助文本 = 帮助文本 + "【拦截】intercept(action:modify/replace_data/replace_file/block/navigate_block/navigate_redirect/cache/clear)\r\n"
            帮助文本 = 帮助文本 + "【Cookie】get_cookies set_cookie(name,value,domain?) delete_cookies(confirm)\r\n"
            帮助文本 = 帮助文本 + "【代理】set_proxy(address,username?,password?) clear_proxy\r\n"
            帮助文本 = 帮助文本 + "【指纹-VIP】fingerprint(action:canvas_random/webgl_random/audio_random/ua/webrtc/geolocation/timezone/ssl/set_batch)\r\n"
            帮助文本 = 帮助文本 + "【交互】mouse_click(x,y) mouse_move(x,y) mouse_wheel(x,y,delta_x,delta_y) key_event(key_code,type) touch_press/release/move\r\n"
            帮助文本 = 帮助文本 + "【编辑】edit_undo redo cut copy paste delete select_all find(text) stop_find\r\n"
            帮助文本 = 帮助文本 + "【截图】screenshot(format:png/jpeg/webp) print_to_pdf(path?,overwrite?)\r\n"
            帮助文本 = 帮助文本 + "【窗口】set_zoom(level) get_zoom set_mute(mute) is_muted compress_memory list get_id get_window_handle set_focus window_info\r\n"
            帮助文本 = 帮助文本 + "【框架】get_frames frame_names frame_by_name(name)\r\n"
            帮助文本 = 帮助文本 + "【编码】base64_encode(data) base64_decode(data) uri_encode(data) uri_decode(data)\r\n"
            帮助文本 = 帮助文本 + "【工作流】workflow_list workflow_get(name) workflow_run(name/steps) workflow_stop\r\n"
            帮助文本 = 帮助文本 + "【系统】mcp_status ping mcp_result(request_id,consume?) mcp_help batch(commands) fbro_version clear_cache\r\n"
            帮助文本 = 帮助文本 + "\r\n提示:\r\n"
            帮助文本 = 帮助文本 + "- 所有browser_xxx支持短名(去前缀),如navigate等价browser_navigate\r\n"
            帮助文本 = 帮助文本 + "- 异步工具返回task_id,用mcp_result轮询: mcp_result{request_id,consume:true}\r\n"
            帮助文本 = 帮助文本 + "- 同步等待:任意工具加max_ms参数,sync_wait:true启用服务端阻塞等待\r\n"
            帮助文本 = 帮助文本 + "- 批量执行:batch{commands:[{name,arguments},...]}\r\n"
            帮助文本 = 帮助文本 + "- 网络抓包: browser_network detail_enable → 操作 → browser_network list\r\n"
            返回 (MCP_响应构建.构建简单JSON ("help", 帮助文本))
        }
        // === 别名列表 ===
        否则 (方法名 == "aliases" || 方法名 == "browser_aliases")
        {
            变量 别名列表 <类型 = 文本型>
            别名列表 = "快捷别名(browser_前缀可省略):\r\n"
            别名列表 = 别名列表 + "navigate get_url get_title back forward reload stop\r\n"
            别名列表 = 别名列表 + "evaluate execute_js get_source get_text screenshot\r\n"
            别名列表 = 别名列表 + "dom_query dom_click dom_set_value dom_get_html\r\n"
            别名列表 = 别名列表 + "create close list inject collect network intercept\r\n"
            别名列表 = 别名列表 + "wait cdp mouse_click mouse_move mouse_wheel key_event\r\n"
            别名列表 = 别名列表 + "get_cookies set_cookie delete_cookies set_proxy clear_proxy\r\n"
            别名列表 = 别名列表 + "set_mute print find fingerprint status set_zoom get_zoom\r\n"
            别名列表 = 别名列表 + "batch(批量) ping(连通检查) aliases(本列表)\r\n"
            返回 (MCP_响应构建.构建简单JSON ("aliases", 别名列表))
        }
        // === v1.8 CDP结果回传 (核心修复: 结果通过mcp_result返回) ===
        否则 (方法名 == "browser_cdp_call")
        {
            变量 cdpMethod <类型 = 文本型>
            cdpMethod = MCP命令服务器.yyjson取文本 (参数JSON, "method")
            如果 (cdpMethod != "")
            {
                // 观察者由 浏览器_创建完毕 事件自动注册, 此处仅检查不注册(避免阻塞)
                返回 (MCP命令服务器.执行CDP命令 (命令ID, cdpMethod, 参数JSON))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "CDP需要method参数"))
        }
        // === v1.8 浏览器事件查询 ===
        否则 (方法名 == "browser_event")
        {
            变量 evtType <类型 = 文本型>
            evtType = MCP命令服务器.yyjson取文本 (参数JSON, "event_type")
            如果 (evtType != "")
            {
                // 应用事件: event_type 以 app_ 开头 → 查询 event_log
                如果 (MCP命令服务器.是否以 (evtType, "app_"))
                {
                    变量 appResult <类型 = 文本型>
                    appResult = MCP命令服务器.查询事件日志 ("app_event", evtType, 0, 1)
                    如果 (appResult != "[]")
                    {
                        返回 (MCP_响应构建.命令成功_原始JSON (命令ID, appResult))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "未找到应用事件: " + evtType + " | 请先 browser_collect action=event_app_enable"))
                }
                // 浏览器事件: 需要浏览器ID → 查询 SQLite event_log
                变量 evtBrowser <类型 = 类_FBrowser_浏览器>
                evtBrowser = MCP命令服务器.取主浏览器 ()
                如果 (evtBrowser.是否为空 () == 假)
                {
                    变量 evtResult <类型 = 文本型>
                    evtResult = MCP命令服务器.查询事件日志 ("browser_event", evtType, evtBrowser.取ID (), 100)
                    如果 (evtResult != "[]")
                    {
                        返回 (MCP_响应构建.命令成功_原始JSON (命令ID, evtResult))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, "未找到事件: " + evtType + " | 支持: load_start/load_end/load_error/crash/navigate/popup/popup_failed/loading_state_change/url_changed/browser_created/browser_closing/do_close/title_changed/load_progress/resource_*/js_dialog/before_unload/file_dialog/fullscreen/favicon/find_result/frame_*/download_*/key_press/focus_* | 应用事件: app_*"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "需要event_type参数 | 浏览器事件: load_end/crash/... 应用事件: app_xxx"))
        }
        否则 (方法名 == "browser_cdp_event")
        {
            变量 eventName <类型 = 文本型>
            eventName = MCP命令服务器.yyjson取文本 (参数JSON, "event_name")
            如果 (eventName == "")
            {
                eventName = MCP命令服务器.yyjson取文本 (参数JSON, "event")
            }
            如果 (eventName != "")
            {
                // 优先读 async 缓存 (CDP 事件不再写 event_log, 防 SQLite 膨胀)
                变量 eventKey <类型 = 文本型>
                eventKey = "cdp_event:" + eventName
                变量 eventResult <类型 = 文本型>
                eventResult = MCP命令服务器.查询异步结果 (eventKey)
                如果 (eventResult == "")
                {
                    eventResult = MCP命令服务器.查询任务结果 (eventKey)
                }
                如果 (eventResult != "")
                {
                    如果 (eventName == "Debugger.paused")
                    {
                        变量 摘要2 <类型 = 文本型>
                        摘要2 = MCP命令服务器.解析Debugger暂停摘要 (eventResult)
                        返回 (MCP_响应构建.命令成功_原始JSON (命令ID, "{\"event\":\"" + MCP_响应构建.JSON转义文本 (eventName) + "\",\"raw\":" + eventResult + ",\"paused\":" + 摘要2 + "}"))
                    }
                    返回 (MCP_响应构建.命令成功_原始JSON (命令ID, eventResult))
                }
                变量 legacyLog <类型 = 文本型>
                legacyLog = MCP命令服务器.查询事件日志 ("cdp_event", eventName, 0, 1)
                如果 (legacyLog != "[]" && legacyLog != "" && MCP命令服务器.是否以 (legacyLog, "["))
                {
                    变量 内层JSON <类型 = 文本型>
                    内层JSON = 取文本中间 (legacyLog, 2, 取文本长度 (legacyLog) - 2)
                    如果 (eventName == "Debugger.paused")
                    {
                        变量 摘要 <类型 = 文本型>
                        摘要 = MCP命令服务器.解析Debugger暂停摘要 (内层JSON)
                        返回 (MCP_响应构建.命令成功_原始JSON (命令ID, "{\"event\":\"" + MCP_响应构建.JSON转义文本 (eventName) + "\",\"raw\":" + 内层JSON + ",\"paused\":" + 摘要 + "}"))
                    }
                    返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 内层JSON))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, "未找到CDP事件: " + eventName + " | 请先 debugger_enable，命中断点后会写入 async 缓存"))
            }
            // 无指定则返回通用的异步存储结果
            返回 (MCP_响应构建.命令失败 (命令ID, "指定 event_name 或 event 参数，例如 Debugger.paused"))
        }
        // === 旧版别名兼容 (CDP命令) ===
        否则 (方法名 == "browser_cdp")
        {
            变量 cdpMethod <类型 = 文本型>
            cdpMethod = MCP命令服务器.yyjson取文本 (参数JSON, "method")
            如果 (cdpMethod != "")
            {
                返回 (MCP命令服务器.执行CDP命令 (命令ID, cdpMethod, 参数JSON))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "CDP需要method参数, 例如: {method: \"Page.navigate\", params: \"{...}\"}"))
        }
        // === 网络抓包: 获取响应体 ===
        否则 (方法名 == "browser_network_body")
        {
            变量 requestId <类型 = 文本型>
            requestId = MCP命令服务器.yyjson取文本 (参数JSON, "request_id")
            如果 (requestId == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "request_id " + MCP_常量.错误_缺少参数))
            }
            变量 bodyParams <类型 = YYJSON对象类>
            bodyParams.创建自文本 ("{}")
            bodyParams.加入文本成员 ("requestId", requestId)
            返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Network.getResponseBody", bodyParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 断点调试: 暂停/继续 ===
        否则 (方法名 == "browser_debugger_pause")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.pause", 参数JSON))
        }
        否则 (方法名 == "browser_debugger_resume")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.resume", 参数JSON))
        }
        // === 断点调试: 单步执行 ===
        否则 (方法名 == "browser_debugger_step_over")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.stepOver", 参数JSON))
        }
        否则 (方法名 == "browser_debugger_step_into")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.stepInto", 参数JSON))
        }
        否则 (方法名 == "browser_debugger_step_out")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.stepOut", 参数JSON))
        }
        // === 断点设置: 按URL设置断点 ===
        否则 (方法名 == "browser_debugger_set_breakpoint")
        {
            变量 bpUrl <类型 = 文本型>
            bpUrl = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (bpUrl == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "url " + MCP_常量.错误_缺少参数))
            }
            变量 bpParams <类型 = YYJSON对象类>
            bpParams.创建自文本 ("{}")
            bpParams.加入文本成员 ("urlRegex", bpUrl)
            变量 bpLine <类型 = 整数>
            bpLine = MCP命令服务器.yyjson取整数 (参数JSON, "line")
            如果 (bpLine == 0)
            {
                bpLine = MCP命令服务器.yyjson取整数 (参数JSON, "line_number")
            }
            bpParams.加入整数成员 ("lineNumber", bpLine)
            变量 bpCol <类型 = 整数>
            bpCol = MCP命令服务器.yyjson取整数 (参数JSON, "column")
            如果 (bpCol == 0)
            {
                bpCol = MCP命令服务器.yyjson取整数 (参数JSON, "column_number")
            }
            变量 hasCol <类型 = 逻辑型 值 = 假>
            如果 (MCP命令服务器.yyjson取文本 (参数JSON, "column") != "" || MCP命令服务器.yyjson取文本 (参数JSON, "column_number") != "")
            {
                hasCol = 真
            }
            如果 (hasCol)
            {
                bpParams.加入整数成员 ("columnNumber", bpCol)
            }
            返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Debugger.setBreakpointByUrl", bpParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 调用栈 ===
        否则 (方法名 == "browser_debugger_stack")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.getStackTrace", 参数JSON))
        }
        // === 断点处查看变量 ===
        否则 (方法名 == "browser_debugger_evaluate")
        {
            变量 frameId <类型 = 文本型>
            frameId = MCP命令服务器.yyjson取文本 (参数JSON, "call_frame_id")
            变量 expr <类型 = 文本型>
            expr = MCP命令服务器.yyjson取文本 (参数JSON, "expression")
            如果 (frameId == "" || expr == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "call_frame_id和expression " + MCP_常量.错误_缺少参数))
            }
            变量 parseText <类型 = 文本型>
            parseText = MCP命令服务器.yyjson取文本 (参数JSON, "parse")
            如果 (parseText == "true" || parseText == "1")
            {
                变量 expandEv <类型 = 逻辑型>
                expandEv = MCP命令服务器.取Debugger求值展开 (参数JSON)
                变量 rbvEv <类型 = 逻辑型>
                rbvEv = MCP命令服务器.取Debugger求值ReturnByValue (参数JSON)
                变量 evRaw <类型 = 文本型>
                evRaw = MCP命令服务器.执行Debugger帧求值并等待 (命令ID, frameId, expr, 12000, rbvEv)
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, MCP命令服务器.解析Debugger求值结果 (evRaw, 命令ID, frameId, expr, expandEv)))
            }
            变量 evParams <类型 = YYJSON对象类>
            evParams.创建自文本 ("{}")
            evParams.加入文本成员 ("callFrameId", frameId)
            evParams.加入文本成员 ("expression", expr)
            如果 (MCP命令服务器.取Debugger求值ReturnByValue (参数JSON))
            {
                evParams.加入逻辑值成员 ("returnByValue", 真)
            }
            返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Debugger.evaluateOnCallFrame", evParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 断点调试: 等待暂停 / 最近暂停 / 批量帧内求值 ===
        否则 (方法名 == "browser_debugger_wait_paused")
        {
            变量 maxMs <类型 = 整数>
            maxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (maxMs == 0)
            {
                maxMs = 30000
            }
            变量 清除旧 <类型 = 逻辑型 值 = 假>
            变量 freshText <类型 = 文本型>
            freshText = MCP命令服务器.yyjson取文本 (参数JSON, "fresh")
            如果 (freshText == "true" || freshText == "1")
            {
                清除旧 = 真
            }
            变量 rawPaused <类型 = 文本型>
            rawPaused = MCP命令服务器.等待CDP事件 ("Debugger.paused", maxMs, 清除旧)
            如果 (rawPaused == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "等待 Debugger.paused 超时(" + 到文本 (maxMs) + "ms) | 流程: debugger_enable → set_breakpoint → navigate"))
            }
            变量 摘要文本 <类型 = 文本型>
            摘要文本 = MCP命令服务器.解析Debugger暂停摘要 (rawPaused)
            变量 摘要对象 <类型 = YYJSON只读对象类>
            如果 (摘要对象.创建自文本 (摘要文本) == 假 || MCP命令服务器.yyjson取文本 (摘要对象, "call_frame_id") == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "Debugger.paused 事件无效或缺少 call_frame_id | 请检查 debugger_enable 与断点 URL"))
            }
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 摘要文本))
        }
        否则 (方法名 == "browser_debugger_last_paused")
        {
            变量 rawLast <类型 = 文本型>
            rawLast = MCP命令服务器.取CDP事件数据JSON ("Debugger.paused")
            如果 (rawLast == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "尚无 Debugger.paused 事件 | 请先 enable + 断点 + 触发暂停"))
            }
            变量 摘要最后 <类型 = 文本型>
            摘要最后 = MCP命令服务器.解析Debugger暂停摘要 (rawLast)
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, 摘要最后))
        }
        否则 (方法名 == "browser_debugger_inspect")
        {
            变量 frameId2 <类型 = 文本型>
            frameId2 = MCP命令服务器.yyjson取文本 (参数JSON, "call_frame_id")
            如果 (frameId2 == "")
            {
                变量 rawInspect <类型 = 文本型>
                rawInspect = MCP命令服务器.取CDP事件数据JSON ("Debugger.paused")
                如果 (rawInspect != "")
                {
                    变量 暂停摘要 <类型 = 文本型>
                    暂停摘要 = MCP命令服务器.解析Debugger暂停摘要 (rawInspect)
                    变量 暂停解析 <类型 = YYJSON只读对象类>
                    如果 (暂停解析.创建自文本 (暂停摘要))
                    {
                        frameId2 = MCP命令服务器.yyjson取文本 (暂停解析, "call_frame_id")
                    }
                }
            }
            如果 (frameId2 == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "缺少 call_frame_id | 请先 browser_debugger_wait_paused 或 browser_debugger_last_paused"))
            }
            变量 exprRaw <类型 = 文本型>
            exprRaw = MCP命令服务器.取Debugger表达式Raw文本 (参数JSON)
            如果 (exprRaw == "")
            {
                exprRaw = "typeof location!=='undefined'?location.href:'(no location)'"
            }
            变量 expandInsp <类型 = 逻辑型>
            expandInsp = MCP命令服务器.取Debugger求值展开 (参数JSON)
            变量 rbvInsp <类型 = 逻辑型>
            rbvInsp = MCP命令服务器.取Debugger求值ReturnByValue (参数JSON)
            变量 evalOut <类型 = 文本型>
            evalOut = MCP命令服务器.Debugger帧内批量求值JSON (命令ID, frameId2, exprRaw, expandInsp, rbvInsp)
            变量 exprCount <类型 = 整数 值 = 0>
            变量 evalObj <类型 = YYJSON只读数组类>
            evalObj = MCP命令服务器.取JSON数组自文本 (evalOut, "items")
            如果 (evalObj.是否为空对象 () == 假)
            {
                exprCount = (整数)evalObj.取成员数 ()
            }
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, "{\"call_frame_id\":\"" + MCP_响应构建.JSON转义文本 (frameId2) + "\",\"count\":" + 到文本 (exprCount) + ",\"evaluations\":" + evalOut + "}"))
        }
        否则 (方法名 == "browser_debugger_flow")
        {
            变量 flowJSON <类型 = 文本型>
            flowJSON = MCP命令服务器.执行Debugger断点流程JSON (命令ID, 参数JSON)
            如果 (flowJSON == "" || MCP命令服务器.是否以 (flowJSON, "{\"ok\":false"))
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "debugger_flow 失败: " + flowJSON))
            }
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, flowJSON))
        }
        否则 (方法名 == "browser_debugger_script_source")
        {
            变量 srcJSON <类型 = 文本型>
            srcJSON = MCP命令服务器.执行Debugger脚本源JSON (命令ID, 参数JSON)
            如果 (srcJSON == "" || MCP命令服务器.是否以 (srcJSON, "{\"ok\":false"))
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "debugger_script_source 失败: " + srcJSON))
            }
            返回 (MCP_响应构建.命令成功_原始JSON (命令ID, srcJSON))
        }
        // === 自动断点求值: 断点命中→自动执行JS→自动resume→循环 (持续监控模式) ===
        否则 (方法名 == "browser_debugger_auto")
        {
            变量 autoBpUrl <类型 = 文本型>
            autoBpUrl = MCP命令服务器.yyjson取文本 (参数JSON, "breakpoint")
            如果 (autoBpUrl == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "breakpoint 不能为空 | URL正则, 如: example\\\\.com/main\\\\.js"))
            }
            变量 autoMaxHits <类型 = 整数>
            autoMaxHits = MCP命令服务器.yyjson取整数 (参数JSON, "max_hits")
            如果 (autoMaxHits <= 0)
            {
                autoMaxHits = 5
            }
            如果 (autoMaxHits > 100)
            {
                autoMaxHits = 100
            }
            变量 autoExprRaw <类型 = 文本型>
            autoExprRaw = MCP命令服务器.yyjson取文本 (参数JSON, "expressions")
            如果 (autoExprRaw == "")
            {
                autoExprRaw = "[\"location.href\"]"
            }
            变量 autoMaxMs <类型 = 整数>
            autoMaxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (autoMaxMs == 0)
            {
                autoMaxMs = 60000
            }
            变量 autoNavUrl <类型 = 文本型>
            autoNavUrl = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            // 步骤1: 启用调试器
            MCP命令服务器.确保Debugger已恢复 (命令ID + "_pre")
            变量 autoEnRaw <类型 = 文本型>
            autoEnRaw = MCP命令服务器.执行CDP并同步等待 (命令ID + "_en", "Debugger.enable", "{}", 15000)
            如果 (MCP命令服务器.CDP同步结果是否成功 (autoEnRaw) == 假)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "Debugger.enable 失败"))
            }
            MCP命令服务器.MCP可中断延时 (300)
            // 步骤2: 设置断点
            变量 autoBpParams <类型 = YYJSON对象类>
            autoBpParams.创建自文本 ("{}")
            autoBpParams.加入文本成员 ("urlRegex", autoBpUrl)
            变量 autoLine <类型 = 整数>
            autoLine = MCP命令服务器.yyjson取整数 (参数JSON, "line")
            autoBpParams.加入整数成员 ("lineNumber", autoLine)
            MCP命令服务器.清除CDP事件记录 ("Debugger.paused")
            变量 autoBpRaw <类型 = 文本型>
            autoBpRaw = MCP命令服务器.执行CDP并同步等待 (命令ID + "_bp", "Debugger.setBreakpointByUrl", autoBpParams.到可读文本 (YYJSON格式化选项.压缩), 15000)
            如果 (MCP命令服务器.CDP设置断点结果是否成功 (autoBpRaw) == 假)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "断点设置失败: " + MCP命令服务器.取CDP同步结果错误 (autoBpRaw)))
            }
            // 步骤3: 导航 (可选)
            如果 (autoNavUrl != "")
            {
                如果 (MCP命令服务器.验证URL安全 (autoNavUrl) == 假)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "URL 不安全: " + autoNavUrl))
                }
                变量 autoBrowser <类型 = 类_FBrowser_浏览器>
                autoBrowser = MCP命令服务器.取主浏览器 ()
                如果 (autoBrowser.是否为空 () == 假)
                {
                    变量 autoNavFrame <类型 = 类_FBrowser_框架>
                    autoNavFrame = MCP命令服务器.取安全主框架 (autoBrowser)
                    如果 (autoNavFrame.是否为空 () == 假 && autoNavFrame.是否有效 ())
                    {
                        autoNavFrame.载入地址 (autoNavUrl)
                        MCP命令服务器.MCP可中断延时 (1000)
                    }
                }
            }
            // 步骤4: 循环等待断点→自动求值→自动resume
            变量 autoHits <类型 = 整数 值 = 0>
            变量 autoResults <类型 = 文本数组类>
            判断循环 (autoHits < autoMaxHits)
            {
                如果 (MCP命令服务器.MCP正在关闭 || MCP_编排分派.工作流应停止)
                {
                    跳出循环
                }
                MCP命令服务器.清除CDP事件记录 ("Debugger.paused")
                变量 autoPausedRaw <类型 = 文本型>
                autoPausedRaw = MCP命令服务器.等待CDP事件 ("Debugger.paused", autoMaxMs, 假)
                如果 (autoPausedRaw == "")
                {
                    跳出循环
                }
                autoHits = autoHits + 1
                变量 autoSummary <类型 = 文本型>
                autoSummary = MCP命令服务器.解析Debugger暂停摘要 (autoPausedRaw)
                变量 autoObj <类型 = YYJSON只读对象类>
                变量 autoFrameId <类型 = 文本型>
                autoFrameId = ""
                如果 (autoObj.创建自文本 (autoSummary))
                {
                    autoFrameId = MCP命令服务器.yyjson取文本 (autoObj, "call_frame_id")
                }
                如果 (autoFrameId == "")
                {
                    autoFrameId = MCP命令服务器.提取JSON文本字段值 (autoSummary, "call_frame_id")
                }
                变量 autoEvalOut <类型 = 文本型>
                autoEvalOut = "[]"
                如果 (autoFrameId != "")
                {
                    autoEvalOut = MCP命令服务器.Debugger帧内批量求值JSON (命令ID + "_ah" + 到文本 (autoHits), autoFrameId, autoExprRaw, 真, 真)
                }
