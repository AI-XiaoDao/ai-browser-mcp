        // === 框架列表 (原生 API, 非JS) ===
        否则 (方法名 == "browser_get_frames")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 id数组 <类型 = FBrowser_文本数组>
                id数组 = browser.取框架ID ()
                变量 name数组 <类型 = FBrowser_文本数组>
                name数组 = browser.取框架名称 ()
                变量 帧JSON <类型 = 文本型>
                帧JSON = "["
                变量 帧首项 <类型 = 逻辑型 值 = 真>
                变量 帧数 <类型 = 整数>
                帧数 = id数组.取个数 ()
                计次循环 (帧数)
                {
                    变量 fi <类型 = 整数>
                    fi = 取循环索引 ()
                    如果 (帧首项)
                    {
                        帧首项 = 假
                    }
                    否则
                    {
                        帧JSON = 帧JSON + ","
                    }
                    变量 帧项 <类型 = YYJSON对象类>
                    帧项.创建自文本 ("{}")
                    如果 (fi < id数组.取个数 ())
                    {
                        帧项.加入文本成员 ("id", id数组.取数据 (fi))
                    }
                    如果 (fi < name数组.取个数 ())
                    {
                        帧项.加入文本成员 ("name", name数组.取数据 (fi))
                    }
                    如果 (fi == 0)
                    {
                        帧项.加入逻辑值成员 ("is_main", 真)
                    }
                    否则
                    {
                        帧项.加入逻辑值成员 ("is_main", 假)
                    }
                    帧JSON = 帧JSON + 帧项.到可读文本 (YYJSON格式化选项.压缩)
                }
                帧JSON = 帧JSON + "]"
                返回 (MCP_响应构建.构建命令嵌套JSON (命令ID, 真, "frames", 帧JSON))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
