<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# MCP_核心分派 — 从 MCP_Server.wsv 拆分 (L5)

类 MCP_核心分派 <公开 @全局类 = 真>
{

    # === 分类分派: 核心操作 (导航/内容/JS/DevTools/窗口管理) ===

    方法 分类分派_核心操作 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        // 名称规范化已由执行浏览器命令入口统一处理, 此处省略
        如果 (方法名 == "browser_navigate")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url != "")
            {
                // 安全: 仅允许 http/https/about/data/ftp 协议
                如果 (MCP命令服务器.验证URL安全 (url) == 假)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_不支持的URL协议))
                }
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 navFrame <类型 = 类_FBrowser_框架>
                    navFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (navFrame.是否为空 () == 假 && navFrame.是否有效 ())
                    {
                        navFrame.载入地址 (url)
                        // 可选 wait_for_load: 注册等待任务, 由浏览器_载入结束事件自动解析
                        如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "wait_for_load"))
                        {
                            返回 (MCP命令服务器.注册加载等待任务 (命令ID, 参数JSON, browser, "等待导航完成: " + url, "已导航到: " + url + " | 等待载入完成, 通过mcp_result查询"))
                        }
                        返回 (MCP_响应构建.命令成功 (命令ID, "已导航到: " + url))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "参数 url 不能为空"))
        }
        否则 (方法名 == "browser_get_url")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 urlFrame <类型 = 类_FBrowser_框架>
                urlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (urlFrame.是否为空 () == 假 && urlFrame.是否有效 ())
                {
                    返回 (MCP_响应构建.构建简单JSON ("url", urlFrame.取地址 ()))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_get_title")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 原生路径: CEF OnTitleChange 事件缓存 (async_only时走JS回退)
                如果 (浏览器容器.当前页面标题 != "" && MCP命令服务器.yyjson取逻辑 (参数JSON, "async_only") == 假)
                {
                    返回 (MCP_响应构建.构建简单JSON ("title", 浏览器容器.当前页面标题))
                }
                // 回退: 缓存为空时走异步JS (页面尚未触发标题事件)
                变量 异步标题ID <类型 = 文本型>
                异步标题ID = MCP命令服务器.生成异步任务ID ()
                MCP命令服务器.提交异步JS任务 (browser, "document.title", 异步标题ID)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步标题ID, "标题获取已提交(页面缓存为空, 已异步回退) | 通过 mcp_result {request_id:'" + 异步标题ID + "'} 查询结果", 150))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 导航控制 ===
        否则 (方法名 == "browser_back")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假 && browser.可否后退 ())
            {
                browser.后退 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "已后退"))
            }
            如果 (browser.是否为空 () == 真)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "无法后退 — 无导航历史 | 当前页面没有可后退的历史记录"))
        }
        否则 (方法名 == "browser_forward")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假 && browser.可否前进 ())
            {
                browser.前进 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "已前进"))
            }
            如果 (browser.是否为空 () == 真)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "无法前进 — 无导航历史 | 当前页面没有可前进的历史记录"))
        }
        否则 (方法名 == "browser_reload")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 忽略缓存 <类型 = 逻辑型>
                忽略缓存 = MCP命令服务器.yyjson取逻辑 (参数JSON, "ignore_cache")
                如果 (忽略缓存)
                {
                    browser.重新载入_忽略缓存 ()
                }
                否则
                {
                    browser.重新载入 ()
                }
                // 可选 wait_for_load: 注册等待任务, 由浏览器_载入结束事件自动解析
                如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "wait_for_load"))
                {
                    返回 (MCP命令服务器.注册加载等待任务 (命令ID, 参数JSON, browser, "等待刷新完成", "页面已刷新 | 等待载入完成, 通过mcp_result查询"))
                }
                返回 (MCP_响应构建.命令成功 (命令ID, "页面已刷新"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_stop")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.停止载入 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "加载已停止"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === JS执行 ===
        否则 (方法名 == "browser_execute_js")
        {
            变量 code <类型 = 文本型>
            code = MCP命令服务器.解码JS代码 (参数JSON)
            如果 (code == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "缺少参数: 请提供 code(JS代码字符串) 或 file(JS文件路径)"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 execFrame <类型 = 类_FBrowser_框架>
                execFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (execFrame.是否为空 () == 假 && execFrame.是否有效 ())
                {
                    变量 异步JSID <类型 = 文本型>
                    异步JSID = MCP命令服务器.生成异步任务ID ()
                    // v2.7: 预存pending占位 — 即使CEF回调因页面变化丢失, 任务也不"消失"
                    变量 预占位 <类型 = YYJSON对象类>
                    预占位.创建自文本 ("{}")
                    预占位.加入逻辑值成员 ("_waiting", 真)
                    预占位.加入文本成员 ("what", "js_exec")
                    预占位.加入文本成员 ("message", "JS执行中...")
                    预占位.加入长整数成员 ("start_time", 取启动时间 ())
                    预占位.加入整数成员 ("max_ms", MCP_常量.同步等待_JS执行超时)
                    预占位.加入整数成员 ("_browser_id", browser.取ID ())
                    MCP命令服务器.存储异步结果 (异步JSID, 预占位.到可读文本 (YYJSON格式化选项.压缩), browser.取ID ())
                    变量 JS回调 <类型 = 类_FBrowser_事件智能指针>
                    JS回调.创建 (类_MCP_JS异步回调)
                    JS回调.取执行类 (类_MCP_JS异步回调).任务ID = 异步JSID
                    execFrame.执行JS代码_带返回值 (code, "", 0, JS回调)
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步JSID, "JS已提交执行, 通过mcp_result查询结果"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_evaluate")
        {
            变量 code <类型 = 文本型>
            code = MCP命令服务器.解码JS代码 (参数JSON)
            如果 (code == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "缺少参数: 请提供 code(JS代码字符串) 或 file(JS文件路径)"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 异步模式: 变量 result <类型 = 文本型>
                变量 rawResult <类型 = 文本型>
                rawResult = MCP命令服务器.提交异步JS任务 (browser, code)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, rawResult, "result", "JS执行已提交"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 页面内容 ===
        否则 (方法名 == "browser_get_source")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 maxChars <类型 = 整数>
                maxChars = MCP命令服务器.yyjson取整数 (参数JSON, "max_chars")
                如果 (maxChars <= 0 || maxChars > MCP_常量.截断_源码最大字节)
                {
                    maxChars = MCP_常量.截断_源码默认字节
                }
                变量 source <类型 = 文本型>
                source = MCP命令服务器.提交异步取源码任务 (browser, , maxChars)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, source, "source", "源码获取已提交(max=" + 到文本 (maxChars) + ")"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_get_text")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 selector <类型 = 文本型>
                selector = MCP命令服务器.yyjson取文本 (参数JSON, "selector")
                如果 (selector != "")
                {
                    // 原生: 用填表框架取元素内容, 非JS
                    变量 填表框架 <类型 = 类_FBrowser_填表框架>
                    填表框架 = browser.取主填表框架 ()
                    如果 (填表框架.是否有效 ())
                    {
                        变量 异步选文本ID <类型 = 文本型>
                        异步选文本ID = MCP命令服务器.生成异步任务ID ()
                        变量 文本回调 <类型 = 类_FBrowser_事件智能指针>
                        文本回调.创建 (类_MCP_JS异步回调)
                        文本回调.取执行类 (类_MCP_JS异步回调).任务ID = 异步选文本ID
                        填表框架.取元素内容 (selector, 0, 文本回调)
                        返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步选文本ID, "文本(原生)获取已提交"))
                    }
                    返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_填表框架无效))
                }
                否则
                {
                    // selector为空: 获取页面全部文本内容
                    变量 fullText <类型 = 文本型>
                    fullText = MCP命令服务器.提交异步取文本任务 (browser)
                    返回 (MCP命令服务器.包装异步提交结果 (命令ID, fullText, "text", "全文获取已提交"))
                }
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 开发者工具 ===
        否则 (方法名 == "browser_open_devtools")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.打开开发者工具 ("AI调试工具", 0, 0, 0, 1024, 800)
                返回 (MCP_响应构建.命令成功 (命令ID, "DevTools已打开"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_close_devtools")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.关闭开发者工具 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "DevTools已关闭"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 窗口管理 ===
        否则 (方法名 == "browser_create")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url == "")
            {
                url = "about:blank"
            }
            如果 (MCP命令服务器.验证URL安全 (url) == 假)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_不支持的URL协议))
            }
            // 限制浏览器实例数量
            如果 (FBrowser_浏览器_取数量 () >= MCP_常量.浏览器实例最大数量)
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "浏览器实例已达上限(" + 到文本 (MCP_常量.浏览器实例最大数量) + ")"))
            }
            // 通过UI线程时钟(500ms)创建浏览器
            // 释放MCP执行锁让其他命令继续执行, 仅保留待创建URL供时钟线程消费
            MCP命令服务器.待创建完成 = 假
            MCP命令服务器.待创建URL = url
            变量 等待次数 <类型 = 整数 值 = 0>
            判断循环 (MCP命令服务器.待创建完成 == 假 && 等待次数 < 200)
            {
                等待次数 = 等待次数 + 1
                如果 (MCP命令服务器.MCP正在关闭)
                {
                    跳出循环
                }
                MCP命令服务器.MCP执行锁.解锁 ()
                MCP命令服务器.MCP可中断延时 (50)
                MCP命令服务器.MCP执行锁.加锁 ()
            }
            MCP命令服务器.待创建URL = ""
            如果 (MCP命令服务器.待创建完成)
            {
                返回 (MCP_响应构建.命令成功 (命令ID, "浏览器已创建: " + url + " | 通过 browser_list 查看详情"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "浏览器创建超时, 请重试"))
        }
        否则 (方法名 == "browser_close")
        {
            变量 closeID <类型 = 整数>
            closeID = MCP命令服务器.yyjson取整数 (参数JSON, "browser_id")
            变量 closeBrowser <类型 = 类_FBrowser_浏览器>
            如果 (closeID > 0)
            {
                closeBrowser = FBrowser_浏览器_通过ID取浏览器 (closeID)
            }
            否则
            {
                closeBrowser = MCP命令服务器.取主浏览器 ()
            }
            如果 (closeBrowser.是否为空 () == 假 && closeBrowser.是否已关闭 () == 假)
            {
                变量 closingID <类型 = 整数>
                closingID = closeBrowser.取ID ()
                closeBrowser.关闭浏览器 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "浏览器已关闭: id=" + 到文本 (closingID)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "浏览器不可用或已关闭"))
        }
        否则 (方法名 == "browser_list")
        {
            MCP命令服务器.浏览器数组锁.加锁 ()
            变量 ID清单 <类型 = 类_FBrowser_列表值>
            ID清单 = FBrowser_浏览器_取ID清单 ()
            // 防御: ID清单可能为空
            如果 (ID清单.是否为空 () == 假)
            {
                变量 列表JSON <类型 = 文本型>
                列表JSON = "["
                变量 首项标志 <类型 = 逻辑型 值 = 真>
                变量 listSize <类型 = 整数>
                listSize = ID清单.取大小 ()
                计次循环 (listSize)
                {
                    变量 bid <类型 = 整数>
                    bid = ID清单.取整数值 (取循环索引 ())
                    变量 b <类型 = 类_FBrowser_浏览器>
                    b = FBrowser_浏览器_通过ID取浏览器 (bid)
                    如果 (b.是否为空 () == 假 && b.是否已关闭 () == 假)
                    {
                        如果 (首项标志)
                        {
                            首项标志 = 假
                        }
                        否则
                        {
                            列表JSON = 列表JSON + ","
                        }
                        变量 listUrlFrame <类型 = 类_FBrowser_框架>
                        listUrlFrame = MCP命令服务器.取安全主框架 (b)
                        变量 urlText <类型 = 文本型>
                        如果 (listUrlFrame.是否为空 () == 假)
                        {
                            urlText = listUrlFrame.取地址 ()
                        }
                        否则
                        {
                            urlText = ""
                        }
                        变量 浏览器项 <类型 = YYJSON对象类>
                        浏览器项.创建自文本 ("{}")
                        浏览器项.加入整数成员 ("id", bid)
                        浏览器项.加入文本成员 ("url", urlText)
                        列表JSON = 列表JSON + 浏览器项.到可读文本 (YYJSON格式化选项.压缩)
                    }
                }
                列表JSON = 列表JSON + "]"
                MCP命令服务器.浏览器数组锁.解锁 ()
                返回 (MCP_响应构建.构建命令嵌套JSON (命令ID, 真, "browsers", 列表JSON))
            }
            MCP命令服务器.浏览器数组锁.解锁 ()
            返回 (MCP_响应构建.命令失败 (命令ID, "无法获取浏览器ID清单"))
        }
        // === 缩放 ===
        否则 (方法名 == "browser_set_zoom")
        {
            变量 level <类型 = 文本型>
            level = MCP命令服务器.yyjson取文本 (参数JSON, "level")
            如果 (level != "")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.置缩放级别 (文本到小数 (level))
                    MCP命令服务器.持久缩放级别 = 文本到小数 (level)
                    返回 (MCP_响应构建.命令成功 (命令ID, "缩放(持久): " + level))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "参数 level 不能为空"))
        }
        // === 查找 ===
        否则 (方法名 == "browser_find")
        {
            变量 text <类型 = 文本型>
            text = MCP命令服务器.yyjson取文本 (参数JSON, "text")
            如果 (text != "")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.查找 (text, 真, 假, 假)
                    返回 (MCP_响应构建.命令成功 (命令ID, "查找: " + text))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "参数 text 不能为空"))
        }
        否则 (方法名 == "browser_stop_find")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.停止查找 (真)
                返回 (MCP_响应构建.命令成功 (命令ID, "查找已停止"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 鼠标 ===
        如果 (方法名 == "browser_mouse_click")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 x <类型 = 整数>
                变量 y <类型 = 整数>
                x = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                如果 (x < 0 || y < 0 || x > 32767 || y > 32767)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "坐标越界 | x,y 须在 0~32767 范围内"))
                }
                // VIP优先: CDP高级鼠标点击 (绕过反自动化检测, 更可靠)
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级鼠标_单击 (x, y, MCP命令服务器.yyjson取整数 (参数JSON, "button"))
                    返回 (MCP_响应构建.命令成功 (命令ID, "VIP点击 (" + 到文本 (x) + "," + 到文本 (y) + ")"))
                }
                // 普通CEF鼠标点击 (VIP不可用时退路)
                变量 按钮文本 <类型 = 文本型>
                按钮文本 = MCP命令服务器.yyjson取文本 (参数JSON, "button")
                变量 按钮类型 <类型 = 整数>
                如果 (按钮文本 == "right")
                {
                    按钮类型 = 鼠标按键类型.右键
                }
                否则 (按钮文本 == "middle")
                {
                    按钮类型 = 鼠标按键类型.中键
                }
                否则 (按钮文本 == "left" || 按钮文本 == "")
                {
                    按钮类型 = 鼠标按键类型.左键  // 默认左键
                }
                否则
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "未知按钮类型: " + 按钮文本 + " | 支持: left/right/middle"))
                }
                变量 鼠标事件 <类型 = FBrowser_鼠标事件>
                鼠标事件.横坐标 = x
                鼠标事件.纵坐标 = y
                鼠标事件.修饰键 = 事件标识.无
                browser.发送鼠标点击事件 (按钮类型, 鼠标事件, 假, 1)
                browser.发送鼠标点击事件 (按钮类型, 鼠标事件, 真, 1)
                返回 (MCP_响应构建.命令成功 (命令ID, "点击 (" + 到文本 (x) + "," + 到文本 (y) + ") 按钮:" + 按钮文本))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_mouse_move")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 x <类型 = 整数>
                变量 y <类型 = 整数>
                x = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                如果 (x < 0 || y < 0 || x > 32767 || y > 32767)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "坐标越界 | x,y 须在 0~32767 范围内"))
                }
                // VIP优先: CDP高级鼠标移动
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级鼠标_移动 (x, y)
                    返回 (MCP_响应构建.命令成功 (命令ID, "VIP鼠标移动到 (" + 到文本 (x) + "," + 到文本 (y) + ")"))
                }
                // 普通CEF鼠标移动 (VIP不可用时退路)
                变量 鼠标事件 <类型 = FBrowser_鼠标事件>
                鼠标事件.横坐标 = x
                鼠标事件.纵坐标 = y
                鼠标事件.修饰键 = 事件标识.无
                browser.发送鼠标移动事件 (鼠标事件, 假)
                返回 (MCP_响应构建.命令成功 (命令ID, "鼠标移动到 (" + 到文本 (x) + "," + 到文本 (y) + ")"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 键盘 ===
        否则 (方法名 == "browser_key_event")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 key <类型 = 整数>
                key = MCP命令服务器.yyjson取整数 (参数JSON, "key_code")
                如果 (key <= 0)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "参数 key_code 必须为有效虚拟键码(>0)"))
                }
                变量 类型文本 <类型 = 文本型>
                类型文本 = MCP命令服务器.yyjson取文本 (参数JSON, "type")
                // VIP优先: CDP高级键盘 (绕过反自动化检测)
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假 && key <= 255)
                {
                    如果 (类型文本 == "keydown")
                    {
                        vip_ctrl.高级键盘_按下 (key)
                        返回 (MCP_响应构建.命令成功 (命令ID, "VIP按下 key_code=" + 到文本 (key)))
                    }
                    否则 (类型文本 == "keyup")
                    {
                        vip_ctrl.高级键盘_放开 (key)
                        返回 (MCP_响应构建.命令成功 (命令ID, "VIP放开 key_code=" + 到文本 (key)))
                    }
                    否则
                    {
                        vip_ctrl.高级键盘_单击 (key)
                        返回 (MCP_响应构建.命令成功 (命令ID, "VIP单击 key_code=" + 到文本 (key)))
                    }
                }
                // 普通CEF按键 (VIP不可用时退路)
                变量 按键事件 <类型 = FBrowser_按键事件>
                如果 (类型文本 == "keydown")
                {
                    按键事件.类型 = 按键事件.按下
                }
                否则 (类型文本 == "keyup")
                {
                    按键事件.类型 = 按键事件.放开
                }
                否则
                {
                    按键事件.类型 = 按键事件.单击
                }
                按键事件.系统按键 = key
                // 修饰键: 位标志组合 (1=Ctrl, 2=Alt, 4=Shift), 默认0=无
                变量 修饰位 <类型 = 整数>
                修饰位 = MCP命令服务器.yyjson取整数 (参数JSON, "modifiers")
                按键事件.修饰位 = 修饰位
                browser.发送按键事件 (按键事件)
                返回 (MCP_响应构建.命令成功 (命令ID, "按键已发送 key_code=" + 到文本 (key) + " type=" + 类型文本 + " modifiers=" + 到文本 (修饰位)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 静音/打印/缓存 ===
        否则 (方法名 == "browser_set_mute")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 静音 <类型 = 逻辑型>
                静音 = MCP命令服务器.yyjson取逻辑 (参数JSON, "mute")
                browser.置页面静音 (静音)
                MCP命令服务器.持久静音状态 = 静音
                返回 (MCP_响应构建.命令成功 (命令ID, "静音(持久): " + 到文本 (静音)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_print")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.打印 ()
                返回 (MCP_响应构建.命令成功 (命令ID, "打印已触发"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_print_to_pdf")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 路径 <类型 = 文本型>
                路径 = MCP命令服务器.yyjson取文本 (参数JSON, "path")
                // 安全: 先检查用户提供的路径, 再处理空路径默认值 (PDF写入仅允许运行目录内)
                如果 (路径 != "" && MCP命令服务器.验证安全路径 (路径, 真) == 假)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "路径不允许: " + 路径))
                }
                如果 (路径 == "")
                {
                    路径 = 取运行目录 () + "\\mcp_output.pdf"
                }
                // 最终兜底校验: 默认路径也须通过安全验证
                如果 (MCP命令服务器.验证安全路径 (路径, 真) == 假)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "路径安全校验失败: " + 路径))
                }
                // 文件覆盖保护: overwrite参数必须为true才能覆盖已存在的文件
                如果 (文件是否存在 (路径))
                {
                    变量 覆盖确认 <类型 = 逻辑型>
                    覆盖确认 = MCP命令服务器.yyjson取逻辑 (参数JSON, "overwrite")
                    如果 (覆盖确认 == 假)
                    {
                        返回 (MCP_响应构建.命令失败 (命令ID, "文件已存在: " + 路径 + " | 请设置 overwrite: true 确认覆盖, 或更换path参数"))
                    }
                }
                变量 PDF设置 <类型 = FBrowser_PDF打印设置>
                变量 异步PDFID <类型 = 文本型>
                异步PDFID = MCP命令服务器.生成异步任务ID ()
                变量 PDF回调 <类型 = 类_FBrowser_事件智能指针>
                PDF回调.创建 (类_MCP_打印PDF回调)
                PDF回调.取执行类 (类_MCP_打印PDF回调).任务ID = 异步PDFID
                browser.打印为PDF (路径, PDF设置, PDF回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步PDFID, "PDF打印已提交, 通过mcp_result查询结果", 2000))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === Cookie ===
        否则 (方法名 == "browser_get_cookies")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 可配置上限 (常量统一定义于 MCP_Constants.wsv)
                变量 cookieLimit <类型 = 整数>
                cookieLimit = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
                如果 (cookieLimit <= 0)
                {
                    cookieLimit = 200
                }
                如果 (cookieLimit > MCP_常量.Cookie最大项数)
                {
                    cookieLimit = MCP_常量.Cookie最大项数
                }
                如果 (cookieLimit > MCP_常量.Cookie绝对上限)
                {
                    cookieLimit = MCP_常量.Cookie绝对上限
                }
                // 使用官方 FBrowser Cookie管理器 回调 API (含HttpOnly)
                变量 异步CookieID <类型 = 文本型>
                异步CookieID = MCP命令服务器.生成异步任务ID ()
                变量 Cookie回调 <类型 = 类_FBrowser_事件智能指针>
                Cookie回调.创建 (类_MCP_Cookie收集回调)
                Cookie回调.取执行类 (类_MCP_Cookie收集回调).异步任务ID = 异步CookieID
                Cookie回调.取执行类 (类_MCP_Cookie收集回调).最大项数 = cookieLimit
                变量 urlFrame <类型 = 类_FBrowser_框架>
                urlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (urlFrame.是否为空 () == 假)
                {
                    FBrowser_Cookie管理器_取全局 ().取地址Cookie (urlFrame.取地址 (), 真, Cookie回调)
                }
                否则
                {
                    // 框架不可用时立即存储错误结果, 防止客户端无限轮询
                    MCP命令服务器.存储异步结果 (异步CookieID, MCP_响应构建.构建标准失败JSON ("无法获取Cookie | " + MCP_常量.错误_主框架无效))
                }
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步CookieID, "Cookie获取已提交(含HttpOnly), 通过mcp_result查询", 300))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_set_cookie")
        {
            变量 name <类型 = 文本型>
            变量 value <类型 = 文本型>
            变量 domain <类型 = 文本型>
            name = MCP命令服务器.yyjson取文本 (参数JSON, "name")
            value = MCP命令服务器.yyjson取文本 (参数JSON, "value")
            domain = MCP命令服务器.yyjson取文本 (参数JSON, "domain")
            如果 (name == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "参数 name 不能为空"))
            }
            如果 (value == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "参数 value 不能为空"))
            }
            如果 (domain == "")
            {
                // 从当前浏览器URL自动提取域名
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 currentURL <类型 = 文本型>
                    变量 setCookieFrame <类型 = 类_FBrowser_框架>
                    setCookieFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (setCookieFrame.是否为空 () == 假)
                    {
                        currentURL = setCookieFrame.取地址 ()
                    }
                    // 简单提取: 取://后到第一个/之间的部分作为域名
                    变量 schemeEnd <类型 = 整数>
                    schemeEnd = 寻找文本 (currentURL, "://", 0, 假)
                    如果 (schemeEnd > 0)
                    {
                        变量 hostStart <类型 = 整数>
                        hostStart = schemeEnd + 3
                        变量 hostEnd <类型 = 整数>
                        hostEnd = 寻找文本 (currentURL, "/", hostStart, 假)
                        如果 (hostEnd < 0)
                        {
                            // 无路径斜杠, 域名到末尾: 取://之后全部文本
                            domain = 取文本中间 (currentURL, hostStart, 取文本长度 (currentURL) - hostStart + 1)
                        }
                        否则
                        {
                            // 提取 :// 和 / 之间的域名
                            domain = 取文本中间 (currentURL, hostStart, hostEnd - hostStart)
                        }
                        // 去除端口号 (如 example.com:8080 → example.com)
                        变量 冒号位置 <类型 = 整数>
                        冒号位置 = 寻找文本 (domain, ":", 0, 假)
                        如果 (冒号位置 > 0)
                        {
                            domain = 取文本左边 (domain, 冒号位置 - 1)
                        }
                        // 加前导点以匹配子域名, 同时去掉可能的尾随空白
                        domain = "." + domain
                    }
                }
                如果 (domain == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "无法获取域名,请显式提供domain参数"))
                }
            }
            否则
            {
                // 显式提供domain时, 验证domain与当前页面URL的域名匹配, 防止向任意域注入Cookie
                变量 currentURL <类型 = 文本型>
                变量 setCookieFrame <类型 = 类_FBrowser_框架>
                变量 setBrowser <类型 = 类_FBrowser_浏览器>
                setBrowser = MCP命令服务器.取主浏览器 ()
                如果 (setBrowser.是否为空 () == 假)
                {
                    setCookieFrame = MCP命令服务器.取安全主框架 (setBrowser)
                    如果 (setCookieFrame.是否为空 () == 假)
                    {
                        currentURL = setCookieFrame.取地址 ()
                    }
                }
                如果 (currentURL != "")
                {
                    // 内联提取当前页面的域名, 与显式提供的domain进行匹配验证
                    变量 currentDomain <类型 = 文本型>
                    currentDomain = ""
                    变量 csEnd <类型 = 整数>
                    csEnd = 寻找文本 (currentURL, "://", 0, 假)
                    如果 (csEnd > 0)
                    {
                        变量 chStart <类型 = 整数>
                        chStart = csEnd + 3
                        变量 chEnd <类型 = 整数>
                        chEnd = 寻找文本 (currentURL, "/", chStart, 假)
                        如果 (chEnd < 0)
                        {
                            chEnd = 取文本长度 (currentURL) + 1
                        }
                        currentDomain = 取文本中间 (currentURL, chStart, chEnd - chStart)
                        // 去除端口号
                        变量 cpPos <类型 = 整数>
                        cpPos = 寻找文本 (currentDomain, ":", 0, 假)
                        如果 (cpPos > 0)
                        {
                            currentDomain = 取文本左边 (currentDomain, cpPos - 1)
                        }
                    }
                    变量 cleanDomain <类型 = 文本型>
                    cleanDomain = domain
                    // 去掉用户可能添加的前导点, 统一比较
                    如果 (是否以 (cleanDomain, "."))
                    {
                        cleanDomain = 取文本右边 (cleanDomain, 取文本长度 (cleanDomain) - 1)
                    }
                    如果 (currentDomain != "" && cleanDomain != "" && 是否以 (currentDomain, cleanDomain) == 假 && 是否以 (cleanDomain, currentDomain) == 假)
                    {
                        返回 (MCP_响应构建.命令失败 (命令ID, "Cookie domain(" + domain + ") 与当前页面域名(" + currentDomain + ")不匹配, 拒绝跨域设置"))
                    }
                }
            }
            // 构建URL时去除域名的前导点(如.baidu.com → baidu.com)
            变量 urlDomain <类型 = 文本型>
            urlDomain = domain
            如果 (MCP命令服务器.是否以 (urlDomain, "."))
            {
                // 去除前导点: 已知以.开头(位置1), 从位置2取剩余全部
                urlDomain = 取文本中间 (urlDomain, 2, 取文本长度 (urlDomain) - 1)
            }
            变量 Cookie数据 <类型 = FBrowser_Cookie数据>
            Cookie数据.名 = name
            Cookie数据.值 = value
            Cookie数据.域 = domain
            Cookie数据.路径 = "/"
            Cookie数据.是否只有http = 假
            Cookie数据.是否有过期时间 = 假
            FBrowser_Cookie管理器_取全局 ().置Cookie ("http://" + urlDomain, Cookie数据)
            返回 (MCP_响应构建.命令成功 (命令ID, "Cookie已设置: " + name))
        }
        否则 (方法名 == "browser_delete_cookies")
