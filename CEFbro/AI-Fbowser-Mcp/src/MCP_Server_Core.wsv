                如果 (anScanRaw == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "analyze 超时 | url_pattern=" + exUrlPat + " | 可增大超时或缩小url_pattern范围"))
                }
                变量 anScanObj <类型 = YYJSON只读对象类>
                如果 (anScanObj.创建自文本 (anScanRaw) == 假)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "analyze 结果解析失败"))
                }
                变量 anScriptsArr <类型 = YYJSON只读数组类>
                anScriptsArr = anScanObj.取数组 ("scripts")
                如果 (anScriptsArr.取成员数 () == 0)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "analyze: 未找到匹配 url_pattern=" + exUrlPat + " 的脚本"))
                }
                变量 anCount <类型 = 整数>
                anCount = MCP命令服务器.yyjson取整数 (anScanObj, "matched")
                如果 (anCount <= 0)
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "analyze: 未找到匹配 url_pattern=" + exUrlPat + " 的脚本"))
                }
                // Step2: 对每个脚本提取加密特征 (源码已内嵌在scan结果中)
                变量 anResults <类型 = YYJSON数组类>
                anResults.创建自文本数据 (MCP命令服务器.取空文本数组 ())
                变量 anMax <类型 = 整数>
                anMax = anScriptsArr.取成员数 ()
                如果 (anMax > 20)
                {
                    anMax = 20
                }
                变量 anIdx <类型 = 整数>
                计次循环 (anMax)
                {
                    anIdx = 取循环索引 ()
                    变量 anItemObj <类型 = YYJSON只读对象类>
                    anItemObj = anScriptsArr.取成员 (anIdx)
                    如果 (anItemObj.是否为空 ())
                    {
                        到循环尾
                    }
                    变量 anScriptIdx <类型 = 文本型>
                    anScriptIdx = 到文本 (MCP命令服务器.yyjson取整数 (anItemObj, "index"))
                    变量 anScriptUrl <类型 = 文本型>
                    anScriptUrl = MCP命令服务器.yyjson取文本 (anItemObj, "src")
                    变量 anSrc <类型 = 文本型>
                    anSrc = MCP命令服务器.yyjson取文本 (anItemObj, "source")
                    如果 (anSrc == "")
                    {
                        到循环尾
                    }
                    变量 anSrcLower <类型 = 文本型>
                    anSrcLower = 到小写 (anSrc)
                    // 加密特征提取
                    变量 anEntry <类型 = YYJSON对象类>
                    anEntry.创建自文本 ("{}")
                    anEntry.加入文本成员 ("script_index", anScriptIdx)
                    anEntry.加入文本成员 ("script_url", anScriptUrl)
                    anEntry.加入整数成员 ("source_size", 取文本长度 (anSrc))
                    // 算法检测 (按关键词匹配已知加密算法名)
                    变量 anAlgos <类型 = YYJSON数组类>
                    anAlgos.创建自文本数据 (MCP命令服务器.取空文本数组 ())
                    // 算法检测
                    如果 (寻找文本 (anSrcLower, "md5", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("md5")
                    }
                    如果 (寻找文本 (anSrcLower, "sha", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("sha")
                    }
                    如果 (寻找文本 (anSrcLower, "aes", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("aes")
                    }
                    如果 (寻找文本 (anSrcLower, "rsa", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("rsa")
                    }
                    如果 (寻找文本 (anSrcLower, "hmac", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("hmac")
                    }
                    如果 (寻找文本 (anSrcLower, "base64", 0, 假) != -1 || 寻找文本 (anSrcLower, "btoa", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("base64")
                    }
                    如果 (寻找文本 (anSrcLower, "des", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("des")
                    }
                    如果 (寻找文本 (anSrcLower, "ecdsa", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("ecdsa")
                    }
                    如果 (寻找文本 (anSrcLower, "crc32", 0, 假) != -1)
                    {
                        anAlgos.加入文本成员 ("crc32")
                    }
                    如果 (anAlgos.取成员数 () > 0)
                    {
                        anEntry.加入数组成员 ("algorithms", anAlgos)
                    }
                    否则
                    {
                        anEntry.加入文本成员 ("algorithms", "none_detected")
                    }
                    // 密钥常量提取: 匹配硬编码的32+ hex / 24+ base64-like 字符串
                    变量 anKeySrc <类型 = 文本型>
                    anKeySrc = anSrc
                    // 收集前10个16进制长字符串作为候选密钥
                    变量 anKeys <类型 = YYJSON数组类>
                    anKeys.创建自文本数据 (MCP命令服务器.取空文本数组 ())
                    变量 anHexCount <类型 = 整数 值 = 0>
                    变量 anPos <类型 = 整数 值 = 0>
                    判断循环 (anHexCount < 10 && anPos < 取文本长度 (anKeySrc) - 32)
                    {
                        变量 anHexPos <类型 = 整数>
                        anHexPos = 寻找文本 (anKeySrc, "0x", anPos, 假)
                        如果 (anHexPos == -1)
                        {
                            跳出循环
                        }
                        变量 anHexEnd <类型 = 整数>
                        anHexEnd = anHexPos + 2
                        判断循环 (anHexEnd < 取文本长度 (anKeySrc))
                        {
                            变量 anCh <类型 = 整数>
                            anCh = 取代码_ (anKeySrc, anHexEnd)
                            如果 (anCh >= 48 && anCh <= 57 || anCh >= 65 && anCh <= 70 || anCh >= 97 && anCh <= 102)
                            {
                                anHexEnd = anHexEnd + 1
                            }
                            否则
                            {
                                跳出循环
                            }
                        }
                        变量 anHexLen <类型 = 整数>
                        anHexLen = anHexEnd - anHexPos - 2
                        如果 (anHexLen >= 32)
                        {
                            变量 anHexVal <类型 = 文本型>
                            anHexVal = 取文本中间 (anKeySrc, anHexPos, anHexEnd - anHexPos)
                            如果 (取文本长度 (anHexVal) <= 200)
                            {
                                anKeys.加入文本成员 (anHexVal)
                                anHexCount = anHexCount + 1
                            }
                        }
                        anPos = anHexEnd
                    }
                    如果 (anKeys.取成员数 () > 0)
                    {
                        anEntry.加入数组成员 ("suspect_keys", anKeys)
                    }
                    // source_preview
                    anEntry.加入文本成员 ("source_preview", 取文本左边 (anSrc, 2000))
                    anResults.加入文本成员 (anEntry.到可读文本 (YYJSON格式化选项.压缩))
                }
                变量 anSummary <类型 = YYJSON对象类>
                anSummary.创建自文本 ("{}")
                anSummary.加入文本成员 ("url_pattern", exUrlPat)
                anSummary.加入整数成员 ("matched_scripts", anCount)
                anSummary.加入整数成员 ("analyzed", anResults.取成员数 ())
                变量 anSummaryJSON <类型 = 文本型>
                anSummaryJSON = anSummary.到可读文本 (YYJSON格式化选项.压缩)
                anSummaryJSON = 取文本左边 (anSummaryJSON, 取文本长度 (anSummaryJSON) - 1) + ",\"results\":" + anResults.到可读文本 (YYJSON格式化选项.压缩) + "}"
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, anSummaryJSON))
            }
            否则
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "未知mode: " + exMode + " | 支持: scan/download/analyze"))
            }
        }
        // === JS逆向: 网络请求发起者调用栈溯源 ===
        否则 (方法名 == "browser_reverse_initiator")
        {
            变量 niPattern <类型 = 文本型>
            niPattern = MCP命令服务器.yyjson取文本 (参数JSON, "url_pattern")
            如果 (niPattern == "")
            {
                niPattern = MCP命令服务器.yyjson取文本 (参数JSON, "request_id")
            }
            变量 niBrowser <类型 = 类_FBrowser_浏览器>
            niBrowser = MCP命令服务器.取主浏览器 ()
            如果 (niBrowser.是否为空 () == 假 && niBrowser.是否已关闭 () == 假)
            {
                变量 niCode <类型 = 文本型>
                niCode = "(function(){var p='" + MCP命令服务器.简单转义JS (niPattern) + "';var R=window.__mcp_initiator_log=window.__mcp_initiator_log||[];var _origOpen=XMLHttpRequest.prototype.open;XMLHttpRequest.prototype.open=function(m,u){var self=this;if(u.indexOf(p)!==-1){var st='';try{var e=new Error();st=e.stack}catch(_){}R.push({type:'xhr',method:m,url:u,stack:st?st.substring(0,2000):'',ts:Date.now()})}return _origOpen.apply(this,arguments)};var _origFetch=window.fetch;window.fetch=function(url,opts){var u=typeof url==='string'?url:url.url;if(u&&u.indexOf(p)!==-1){var st='';try{var e=new Error();st=e.stack}catch(_){}R.push({type:'fetch',url:u,stack:st?st.substring(0,2000):'',ts:Date.now()})}return _origFetch.apply(this,arguments)};return JSON.stringify({installed:true,pattern:p,hint:'Hooks installed on XHR+fetch. Trigger target request then use browser_evaluate \"JSON.stringify(window.__mcp_initiator_log)\" to get initiator stacks.'})})()"
                变量 niTaskID <类型 = 文本型>
                niTaskID = MCP命令服务器.生成异步任务ID ()
                MCP命令服务器.提交异步JS任务 (niBrowser, niCode, niTaskID)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, niTaskID, "网络溯源Hook已安装: " + niPattern + " | 触发目标请求后再次调用获取调用栈", 200))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === 反检测预配置 (浏览器事件级) + 一键预设Hook ===
        // === 反检测预设一键部署 (v2.8) ===
        否则 (方法名 == "browser_antidetect_presets")
        {
            变量 adPreset <类型 = 文本型>
            adPreset = MCP命令服务器.yyjson取文本 (参数JSON, "preset")
            如果 (adPreset == "")
            {
                adPreset = "stealth"
            }
            变量 adBrowser <类型 = 类_FBrowser_浏览器>
            adBrowser = MCP命令服务器.取主浏览器 ()
            变量 adHasVIP <类型 = 逻辑型 值 = 假>
            变量 adVIP <类型 = 类_FBrowserVIP_控制器>
            如果 (adBrowser.是否为空 () == 假)
            {
                adVIP = adBrowser.取VIP控制器 ()
                adHasVIP = adVIP.是否为空 () == 假
            }
            变量 adLog <类型 = 文本型>
            adLog = ""
            // Level 1: stealth — 去webdriver+自动化标志 (内核级, 不需VIP)
            如果 (adPreset == "stealth" || adPreset == "basic" || adPreset == "full")
            {
                MCP命令服务器.持久反检测_禁用Debugger检测 = 真
                MCP命令服务器.持久反检测_禁用自动化标志 = 真
                adLog = adLog + "✓ debugger检测已禁用; ✓ 自动化标志已移除"
                如果 (adHasVIP)
                {
                    adVIP.内核开关_禁用Debugger (真)
                }
            }
            // Level 2: basic — stealth + Canvas/WebGL/Audio随机化
            如果 (adPreset == "basic" || adPreset == "full")
            {
                如果 (adHasVIP)
                {
                    adVIP.指纹_虚拟Canvas_随机 (1, 99999999, (整数)(取启动时间 () % 10000))
                    adVIP.指纹_虚拟WebGL_随机 (1, 99999999, (整数)((取启动时间 () + 1) % 10000))
                    adVIP.指纹_虚拟Audio_随机 (1, 99999999, (整数)((取启动时间 () + 2) % 10000))
                    adLog = adLog + "; ✓ Canvas/WebGL/Audio指纹已随机化"
                }
                否则
                {
                    adLog = adLog + "; ⚠️ Canvas/WebGL/Audio需VIP授权"
                }
            }
            // Level 3: full — basic + 全部硬件/屏幕/时区伪装
            如果 (adPreset == "full")
            {
                如果 (adHasVIP)
                {
                    // 屏幕伪装: 常见分辨率
                    adVIP.指纹_虚拟屏幕XY (0, 0)
                    adVIP.指纹_虚拟Rect (0, 0, 1920, 1080)
                    adVIP.指纹_虚拟DevicePixelRatio (2.0)
                    // 硬件伪装
                    adVIP.指纹_虚拟HardwareConcurrency (8)
                    adVIP.指纹_虚拟DeviceMemory (8)
                    // 时区: UTC+8 北京
                    adVIP.指纹_虚拟Date时区 (8, 0, "Asia/Shanghai", "Asia/Shanghai")
                    // UA 伪装: Chrome 最新稳定版
                    变量 adUAData <类型 = 类_FBrowserVIP_UA数据>
                    adUAData.创建 ()
                    adUAData.置UserAgent ("Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36")
                    adUAData.置Platform ("Win32")
                    adUAData.置AcceptLanguage ("zh-CN,zh;q=0.9,en;q=0.8")
                    adUAData.置Mobile (假)
                    adUAData.置Architecture ("x86")
                    adUAData.置Bitness ("64")
                    adUAData.置Model ("")
                    adUAData.置Wow64 (假)
                    adVIP.指纹_虚拟UserAgent (adUAData)
                    // WebRTC 禁用 (防真实IP泄漏)
                    adVIP.指纹_虚拟WebrtcIP ("", "", "", 真)
                    // 地理位置伪装: 北京天安门
                    adVIP.指纹_虚拟定位 (39.9042, 116.4074, 50, -10000, -1, -1, -1)
                    // 触摸
                    adVIP.指纹_启用触摸事件 (假, 0)
                    adLog = adLog + "; ✓ 屏幕1920x1080@2x; ✓ 硬件8核8GB; ✓ 时区Asia/Shanghai; ✓ UA Chrome 143; ✓ WebRTC已禁用; ✓ 定位北京; ✓ 触摸"
                }
                否则
                {
                    adLog = adLog + "; ⚠️ full级伪装需VIP授权, 仅应用了内核级反检测"
                }
            }
            返回 (MCP_响应构建.响应_需要刷新 (命令ID, "反检测预设 [" + adPreset + "] 已部署 | " + adLog + " | 持久生效(新浏览器自动应用) | 部分设置需刷新页面"))
        }
        否则 (方法名 == "browser_reverse_setup")
        {
            变量 suDisableDebugger <类型 = 逻辑型>
            suDisableDebugger = MCP命令服务器.yyjson取逻辑 (参数JSON, "disable_debugger")
            如果 (suDisableDebugger)
            {
                MCP命令服务器.持久反检测_禁用Debugger检测 = 真
            }
            变量 suUA <类型 = 文本型>
            suUA = MCP命令服务器.yyjson取文本 (参数JSON, "user_agent")
            如果 (suUA != "")
            {
                MCP命令服务器.持久反检测_伪装UA = suUA
            }
            变量 suDisableAuto <类型 = 逻辑型>
            suDisableAuto = MCP命令服务器.yyjson取逻辑 (参数JSON, "disable_automation_flag")
            如果 (suDisableAuto)
            {
                MCP命令服务器.持久反检测_禁用自动化标志 = 真
            }
            // 立即应用到当前浏览器
            MCP命令服务器.应用持久配置到浏览器 (MCP命令服务器.取主浏览器 ())
            返回 (MCP_响应构建.命令成功 (命令ID, "反检测预配置已设置 | 当前浏览器已应用 + 所有新浏览器自动应用 | disable_debugger:" + 到文本 (suDisableDebugger) + " UA:" + 选择 (suUA == "", "(未设置)", suUA)))
        }
        否则 (方法名 == "browser_reverse_preset")
        {
            变量 rpPreset <类型 = 文本型>
            rpPreset = MCP命令服务器.yyjson取文本 (参数JSON, "preset")
            如果 (rpPreset == "")
            {
                rpPreset = "all"
            }
            变量 rpBrowser <类型 = 类_FBrowser_浏览器>
            rpBrowser = MCP命令服务器.取主浏览器 ()
            如果 (rpBrowser.是否为空 () == 假 && rpBrowser.是否已关闭 () == 假)
            {
                变量 rpCode <类型 = 文本型>
                rpCode = "(function(){var __hooks=[];"
                如果 (rpPreset == "xhr" || rpPreset == "all")
                {
                    rpCode = rpCode + "var __origXHROpen=XMLHttpRequest.prototype.open;XMLHttpRequest.prototype.open=function(m,u){this.__mcp_url=u;this.__mcp_method=m;if(!window.__mcp_xhr_log)window.__mcp_xhr_log=[];window.__mcp_xhr_log.push({method:m,url:u,ts:Date.now()});return __origXHROpen.apply(this,arguments)};__hooks.push('xhr');"
                }
                如果 (rpPreset == "fetch" || rpPreset == "all")
                {
                    rpCode = rpCode + "var __origFetch=window.fetch;window.fetch=function(url,opts){var u=typeof url==='string'?url:url.url;if(!window.__mcp_fetch_log)window.__mcp_fetch_log=[];window.__mcp_fetch_log.push({url:u,opts:JSON.stringify(opts||{}).substring(0,500),ts:Date.now()});return __origFetch.apply(this,arguments)};__hooks.push('fetch');"
                }
                如果 (rpPreset == "cookie" || rpPreset == "all")
                {
                    rpCode = rpCode + "var __origCookieDesc=Object.getOwnPropertyDescriptor(Document.prototype,'cookie')||Object.getOwnPropertyDescriptor(HTMLDocument.prototype,'cookie');if(__origCookieDesc&&__origCookieDesc.set){var __origCookieSet=__origCookieDesc.set;Object.defineProperty(document,'cookie',{get:function(){return __origCookieDesc.get.call(this)},set:function(v){if(!window.__mcp_cookie_log)window.__mcp_cookie_log=[];window.__mcp_cookie_log.push({value:v.substring(0,500),ts:Date.now()});return __origCookieSet.call(this,v)}});__hooks.push('cookie');}"
                }
                如果 (rpPreset == "websocket" || rpPreset == "all")
                {
                    rpCode = rpCode + "var __origWSSend=WebSocket.prototype.send;WebSocket.prototype.send=function(data){if(!window.__mcp_ws_log)window.__mcp_ws_log=[];window.__mcp_ws_log.push({data:typeof data==='string'?data.substring(0,500):'(binary)',ts:Date.now()});return __origWSSend.call(this,data)};__hooks.push('ws');"
                }
                如果 (rpPreset == "crypto" || rpPreset == "all")
                {
                    rpCode = rpCode + "if(window.SubtleCrypto){var __origDigest=SubtleCrypto.prototype.digest;SubtleCrypto.prototype.digest=function(algo,data){if(!window.__mcp_crypto_log)window.__mcp_crypto_log=[];window.__mcp_crypto_log.push({algorithm:algo.name,dataSize:data.byteLength,ts:Date.now()});return __origDigest.call(this,algo,data)};__hooks.push('crypto');}"
                }
                如果 (rpPreset == "debugger" || rpPreset == "all")
                {
                    rpCode = rpCode + "var __origSetInterval=window.setInterval;var __origSetTimeout=window.setTimeout;var __bypassCount=0;window.setInterval=function(fn,t){var s=fn.toString();if(s.indexOf('debugger')!==-1||s.indexOf('debu')!==-1){__bypassCount++;return 0}return __origSetInterval.apply(this,arguments)};window.setTimeout=function(fn,t){var s=fn.toString();if(s.indexOf('debugger')!==-1||s.indexOf('debu')!==-1){__bypassCount++;return 0}return __origSetTimeout.apply(this,arguments)};__hooks.push('debugger_bypass');"
                }
                rpCode = rpCode + "return JSON.stringify({preset:'" + rpPreset + "',hooks_installed:__hooks,bypass_count:" + 选择 (rpPreset == "debugger" || rpPreset == "all", "__bypassCount", "0") + ",hint:'Hooks active. Access window.__mcp_*_log to view collected data'})})()"
                变量 rpTaskID <类型 = 文本型>
                rpTaskID = MCP命令服务器.生成异步任务ID ()
                MCP命令服务器.提交异步JS任务 (rpBrowser, rpCode, rpTaskID)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, rpTaskID, "预设Hook已安装: " + rpPreset + " | 通过mcp_result查询安装状态", 150))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === CDP逆向: 函数调用级别断点 (Debugger.setBreakpointOnFunctionCall) ===
        否则 (方法名 == "browser_reverse_cdp_hook")
        {
            变量 chObjectId <类型 = 文本型>
            chObjectId = MCP命令服务器.yyjson取文本 (参数JSON, "object_id")
            变量 chFuncName <类型 = 文本型>
            chFuncName = MCP命令服务器.yyjson取文本 (参数JSON, "function_name")
            如果 (chObjectId == "" && chFuncName == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "需要 object_id 或 function_name | 先用 browser_evaluate 获取函数的objectId"))
            }
            如果 (chObjectId == "" && chFuncName != "")
            {
                // 通过函数名自动获取objectId
                变量 chGetObjCode <类型 = 文本型>
                chGetObjCode = "(function(){try{var fn=" + chFuncName + ";return typeof fn==='function'?'found:'+fn.name:'not_a_function:'+typeof fn}catch(e){return'error:'+e.message}})()"
                变量 chGetObjBrowser <类型 = 类_FBrowser_浏览器>
                chGetObjBrowser = MCP命令服务器.取主浏览器 ()
                如果 (chGetObjBrowser.是否为空 () == 假 && chGetObjBrowser.是否已关闭 () == 假)
                {
                    变量 chObjTmpID <类型 = 文本型>
                    chObjTmpID = MCP命令服务器.生成异步任务ID ()
                    MCP命令服务器.提交异步JS任务 (chGetObjBrowser, chGetObjCode, chObjTmpID)
                    变量 chObjResult <类型 = 文本型>
                    chObjResult = MCP命令服务器.同步等待异步任务 (chObjTmpID, 3000)
                    如果 (chObjResult != "" && 寻找文本 (chObjResult, "found:", 0, 假) != -1)
                    {
                        // 通过Runtime.evaluate获取objectId
                        变量 chEvalParams <类型 = YYJSON对象类>
                        chEvalParams.创建自文本 ("{}")
                        chEvalParams.加入文本成员 ("expression", chFuncName)
                        chEvalParams.加入文本成员 ("objectGroup", "reverse_cdp_hook")
                        chEvalParams.加入逻辑值成员 ("generatePreview", 假)
                        // 注: CDP Runtime.evaluate 返回 {result:{objectId,...}}
                        // 此处简化:用Debugger.setBreakpointOnFunctionCall
                    }
                }
            }
            变量 chCondition <类型 = 文本型>
            chCondition = MCP命令服务器.yyjson取文本 (参数JSON, "condition")
            变量 chParams <类型 = YYJSON对象类>
            chParams.创建自文本 ("{}")
            如果 (chObjectId != "")
            {
                chParams.加入文本成员 ("objectId", chObjectId)
            }
            如果 (chCondition != "")
            {
                chParams.加入文本成员 ("condition", chCondition)
            }
            变量 chBrowser <类型 = 类_FBrowser_浏览器>
            chBrowser = MCP命令服务器.取主浏览器 ()
            如果 (chBrowser.是否为空 () == 假 && chBrowser.是否已关闭 () == 假)
            {
                返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Debugger.setBreakpointOnFunctionCall", chParams.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === CDP逆向: JS CPU性能分析 ===
        否则 (方法名 == "browser_reverse_profile")
        {
            变量 prAction <类型 = 文本型>
            prAction = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (prAction == "")
            {
                prAction = "start"
            }
            如果 (prAction == "start")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Profiler.enable", "{}"))
            }
            否则 (prAction == "start_precise")
            {
                变量 prPreciseParams <类型 = YYJSON对象类>
                prPreciseParams.创建自文本 ("{}")
                prPreciseParams.加入整数成员 ("interval", 100)
                prPreciseParams.加入整数成员 ("maxDepth", 32)
                MCP命令服务器.执行逆向CDP命令 (命令ID + "_pre", "Profiler.setSamplingInterval", prPreciseParams.到可读文本 (YYJSON格式化选项.压缩))
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Profiler.enable", "{}"))
            }
            否则 (prAction == "stop")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Profiler.stop", "{}"))
            }
            否则 (prAction == "query")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Profiler.getBestEffortCoverage", "{}"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + prAction + " | 支持: start/start_precise/stop/query"))
        }
        // === CDP逆向: DOM/XHR事件断点 ===
        否则 (方法名 == "browser_reverse_dom_breakpoint")
        {
            变量 dbType <类型 = 文本型>
            dbType = MCP命令服务器.yyjson取文本 (参数JSON, "type")
            如果 (dbType == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "需要 type 参数 | 支持: xhr/fetch/dom_event/timer"))
            }
            变量 dbTarget <类型 = 文本型>
            dbTarget = MCP命令服务器.yyjson取文本 (参数JSON, "target")
            如果 (dbType == "xhr" || dbType == "fetch")
            {
                变量 dbXhrParams <类型 = YYJSON对象类>
                dbXhrParams.创建自文本 ("{}")
                dbXhrParams.加入文本成员 ("url", 选择 (dbTarget == "", "*", dbTarget))
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "DOMDebugger.setXHRBreakpoint", dbXhrParams.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (dbType == "dom_event")
            {
                如果 (dbTarget == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "dom_event需要target参数 | 事件名: click/submit/load/error/change"))
                }
                变量 dbDomParams <类型 = YYJSON对象类>
                dbDomParams.创建自文本 ("{}")
                dbDomParams.加入文本成员 ("eventName", dbTarget)
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "DOMDebugger.setEventListenerBreakpoint", dbDomParams.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (dbType == "timer")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "DOMDebugger.setInstrumentationBreakpoint", "{\"eventName\":\"requestAnimationFrame\"}"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知type: " + dbType + " | 支持: xhr/fetch/dom_event/timer"))
        }
        // === CDP逆向: 预注入脚本 (在所有页面JS之前执行) ===
        否则 (方法名 == "browser_reverse_preload")
        {
            变量 plCode <类型 = 文本型>
            plCode = MCP命令服务器.yyjson取文本 (参数JSON, "code")
            如果 (plCode == "")
            {
                plCode = MCP命令服务器.yyjson取文本 (参数JSON, "file")
            }
            如果 (plCode == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "需要 code(JS代码) 或 file(JS文件路径)"))
            }
            变量 plParams <类型 = YYJSON对象类>
            plParams.创建自文本 ("{}")
            plParams.加入文本成员 ("source", plCode)
            plParams.加入逻辑值成员 ("runImmediately", 真)
            返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Page.addScriptToEvaluateOnNewDocument", plParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === CDP逆向: Runtime.callFunctionOn 远程函数调用 ===
        否则 (方法名 == "browser_reverse_call_fn")
        {
            变量 cfObjectId <类型 = 文本型>
            cfObjectId = MCP命令服务器.yyjson取文本 (参数JSON, "object_id")
            变量 cfArgs <类型 = 文本型>
            cfArgs = MCP命令服务器.yyjson取JSON文本 (参数JSON, "arguments")
            如果 (cfArgs == "")
            {
                cfArgs = "[]"
            }
            如果 (cfObjectId == "")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "需要 object_id | 先用 browser_evaluate 获取目标对象的objectId"))
            }
            变量 cfParams <类型 = YYJSON对象类>
            cfParams.创建自文本 ("{}")
            cfParams.加入文本成员 ("objectId", cfObjectId)
            cfParams.加入文本成员 ("functionDeclaration", "function(...args){return this.apply(null,args)}")
            cfParams.加入逻辑值成员 ("returnByValue", 真)
            返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Runtime.callFunctionOn", cfParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === CDP逆向: WebSocket 消息拦截 ===
        否则 (方法名 == "browser_reverse_websocket")
        {
            变量 wsAction <类型 = 文本型>
            wsAction = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (wsAction == "")
            {
                wsAction = "enable"
            }
            如果 (wsAction == "enable")
            {
                MCP命令服务器.执行逆向CDP命令 (命令ID + "_net", "Network.enable", "{}")
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Network.enable", "{\"maxPostDataSize\":65536}"))
            }
            否则 (wsAction == "query")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "Network.getResponseBody", "{}"))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + wsAction + " | 支持: enable/query"))
        }
        // === CDP逆向: HeapProfiler 堆内存分析 ===
        否则 (方法名 == "browser_reverse_heap")
        {
            变量 hpAction <类型 = 文本型>
            hpAction = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (hpAction == "")
            {
                hpAction = "snapshot"
            }
            如果 (hpAction == "snapshot")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "HeapProfiler.takeHeapSnapshot", "{\"reportProgress\":false}"))
            }
            否则 (hpAction == "start_sampling")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "HeapProfiler.startSampling", "{\"samplingInterval\":32768}"))
            }
            否则 (hpAction == "stop_sampling")
            {
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "HeapProfiler.stopSampling", "{}"))
            }
            否则 (hpAction == "get_object")
            {
                变量 hpObjId <类型 = 文本型>
                hpObjId = MCP命令服务器.yyjson取文本 (参数JSON, "object_id")
                如果 (hpObjId == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "get_object 需要 object_id"))
                }
                变量 hpObjParams <类型 = YYJSON对象类>
                hpObjParams.创建自文本 ("{}")
                hpObjParams.加入文本成员 ("objectId", hpObjId)
                hpObjParams.加入文本成员 ("objectGroup", "reverse_heap")
                返回 (MCP命令服务器.执行逆向CDP命令 (命令ID, "HeapProfiler.getObjectByHeapObjectId", hpObjParams.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未知action: " + hpAction + " | 支持: snapshot/start_sampling/stop_sampling/get_object"))
        }
        返回 ("")  // 链末: 交给 分类分派_填表操作 / 分类分派_系统操作
    }

    #
}
