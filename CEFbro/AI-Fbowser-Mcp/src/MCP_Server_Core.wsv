                exScanCode = "(function(){var R=[];var ss=document.querySelectorAll('script');ss.forEach(function(s,i){var src=s.src||'(inline:'+i+')';var type=s.type||'text/javascript';var txt=(s.textContent||'').substring(0,500);var hasCrypto=/sign|encrypt|decrypt|token|md5|sha|aes|rsa|hmac|base64|btoa|cipher|key|salt|nonce|x-/.test(txt.toLowerCase());R.push({index:i,src:src,type:type,size:s.textContent?s.textContent.length:0,preview:txt.substring(0,200),has_crypto_patterns:hasCrypto,inline:!s.src})});return JSON.stringify({total_scripts:R.length,scripts:R})})()"
