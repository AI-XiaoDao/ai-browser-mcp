                {
                    info.加入文本成员 ("url", hwndFrame.取地址 ())
                }
                否则
                {
                    info.加入文本成员 ("url", "")
                }
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, info.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "未找到窗口句柄为 " + 到文本 (hwnd) + " 的浏览器"))
        }
        否则 (方法名 == "browser_user_tags")
