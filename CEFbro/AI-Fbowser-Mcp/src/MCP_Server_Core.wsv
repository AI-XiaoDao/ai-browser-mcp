                anScanCode = "(function(){var pat='" + MCP命令服务器.简单转义JS (exUrlPat) + "';var R=[];var ss=document.querySelectorAll('script');var maxSrc=524288;ss.forEach(function(s,i){var src=s.src||'';if(src.indexOf(pat)!==-1){var txt=s.textContent||'';if(txt.length>0){R.push({index:i,src:src,size:txt.length,source:txt.length>maxSrc?txt.substring(0,maxSrc):txt})}}});return JSON.stringify({matched:R.length,scripts:R})})()"
