        }
        // === JS逆向: 函数Hook (CDP/V8级无侵入拦截) ===
        否则 (方法名 == "browser_reverse_hook")
        {
            变量 hookTarget <类型 = 文本型>
            hookTarget = MCP命令服务器.yyjson取文本 (参数JSON, "target")
            变量 hookType <类型 = 文本型>
            hookType = MCP命令服务器.yyjson取文本 (参数JSON, "type")
            如果 (hookType == "")
            {
                hookType = "function_call"
            }
            如果 (hookTarget == "" && hookType != "xhr_fetch" && hookType != "websocket")
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "target 不能为空 | 指定函数名/URL正则/选择器"))
            }
            变量 captureArgs <类型 = 逻辑型 值 = 真>
            变量 caText <类型 = 文本型>
            caText = MCP命令服务器.yyjson取文本 (参数JSON, "capture_args")
            如果 (caText == "false" || caText == "0")
            {
                captureArgs = 假
            }
            变量 captureReturn <类型 = 逻辑型 值 = 真>
            变量 crText <类型 = 文本型>
            crText = MCP命令服务器.yyjson取文本 (参数JSON, "capture_return")
            如果 (crText == "false" || crText == "0")
            {
                captureReturn = 假
            }
            变量 captureStack <类型 = 逻辑型>
            captureStack = MCP命令服务器.yyjson取逻辑 (参数JSON, "capture_stack")
            变量 hookCode <类型 = 文本型>
            变量 hookLabel <类型 = 文本型>
            hookLabel = "mcp_hook_" + 到文本 (取启动时间 ())
            如果 (hookType == "function_call")
            {
                // 防注入: 转义目标名中的引号和反斜杠 (见 reverse_search 同款用法)
                变量 hookEsc <类型 = 文本型>
                hookEsc = MCP命令服务器.简单转义JS (hookTarget)
                // 动态注入: 包装目标函数, 记录参数/返回值/调用栈
                hookCode = "(function(){var __t=typeof window['" + hookEsc + "']!=='undefined'?window['" + hookEsc + "']:null;if(!__t){return JSON.stringify({found:false,target:'" + hookEsc + "'})}var __orig=__t;window['" + hookEsc + "']=function(){var __args=Array.prototype.slice.call(arguments);var __result=__orig.apply(this,__args);var __entry={target:'" + hookEsc + "',hook:'" + hookLabel + "',ts:Date.now()};"
                如果 (captureArgs)
                {
                    hookCode = hookCode + "__entry.args=JSON.stringify(__args).substring(0,4096);"
                }
                如果 (captureReturn)
                {
                    hookCode = hookCode + "try{__entry.ret=JSON.stringify(__result).substring(0,4096)}catch(e){__entry.ret='[unserializable]'};"
                }
                如果 (captureStack)
                {
                    hookCode = hookCode + "try{var __e=new Error();__entry.stack=__e.stack.substring(0,2048)}catch(e){};"
                }
                hookCode = hookCode + "console.log('[" + hookLabel + "]',JSON.stringify(__entry));return __result};return JSON.stringify({found:true,target:'" + hookEsc + "',hook:'" + hookLabel + "'})})()"
            }
            否则 (hookType == "xhr_fetch")
            {
                变量 hookUrlPattern <类型 = 文本型>
                hookUrlPattern = MCP命令服务器.yyjson取文本 (参数JSON, "url_pattern")
                如果 (hookUrlPattern == "" && hookTarget == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "xhr_fetch 需要 target 或 url_pattern"))
                }
                变量 hookPattern <类型 = 文本型>
                hookPattern = hookTarget
                如果 (hookPattern == "")
                {
                    hookPattern = hookUrlPattern
                }
                hookCode = "(function(){var __p='" + hookPattern + "';var __origOpen=XMLHttpRequest.prototype.open;XMLHttpRequest.prototype.open=function(m,u){this.__url=u;this.__method=m;if(u.indexOf(__p)!==-1){var __entry={type:'xhr',method:m,url:u,hook:'" + hookLabel + "',ts:Date.now()};console.log('[" + hookLabel + "]',JSON.stringify(__entry))}return __origOpen.apply(this,arguments)};return JSON.stringify({found:true,pattern:__p,hook:'" + hookLabel + "'})})()"
            }
            否则
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "未知type: " + hookType + " | 支持: function_call/xhr_fetch/websocket"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假 && browser.是否已关闭 () == 假)
            {
                变量 hookFrame <类型 = 类_FBrowser_框架>
                hookFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (hookFrame.是否为空 () == 假 && hookFrame.是否有效 ())
                {
                    变量 异步HookID <类型 = 文本型>
                    异步HookID = MCP命令服务器.生成异步任务ID ()
                    变量 Hook回调 <类型 = 类_FBrowser_事件智能指针>
                    Hook回调.创建 (类_MCP_JS异步回调)
                    Hook回调.取执行类 (类_MCP_JS异步回调).任务ID = 异步HookID
                    hookFrame.执行JS代码_带返回值 (hookCode, "", 0, Hook回调)
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步HookID, "Hook已提交: " + hookType + " → " + hookTarget + " | 通过mcp_result查询注入状态"))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_主框架无效))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === JS逆向: 可疑字符串提取 ===
        否则 (方法名 == "browser_reverse_strings")
        {
            变量 rsMode <类型 = 文本型>
            rsMode = MCP命令服务器.yyjson取文本 (参数JSON, "mode")
            如果 (rsMode == "")
            {
                rsMode = "suspicious"
            }
            变量 rsMinLen <类型 = 整数>
            rsMinLen = MCP命令服务器.yyjson取整数 (参数JSON, "min_length")
            如果 (rsMinLen <= 0)
            {
                rsMinLen = 20
            }
            变量 rsMaxResults <类型 = 整数>
            rsMaxResults = MCP命令服务器.yyjson取整数 (参数JSON, "max_results")
            如果 (rsMaxResults <= 0)
            {
                rsMaxResults = 200
            }
            变量 rsCode <类型 = 文本型>
            如果 (rsMode == "suspicious")
            {
                rsCode = "(function(){var R=[];var seen={};var re=/[A-Za-z0-9_\\-]{20,}|[A-Za-z0-9+/=]{24,}|[0-9a-fA-F]{32,}/g;var ss=document.querySelectorAll('script');for(var i=0;i<ss.length;i++){var t=ss[i].textContent||'';var m;while((m=re.exec(t))!==null){var s=m[0];if(!seen[s]&&s.length>=" + 到文本 (rsMinLen) + "){seen[s]=1;R.push({v:s.substring(0,200),l:s.length,si:i})}}}return JSON.stringify({count:R.length,results:R.slice(0," + 到文本 (rsMaxResults) + ")})})()"
            }
            否则 (rsMode == "decrypt_array")
            {
                rsCode = "(function(){var R=[];var ss=document.querySelectorAll('script');for(var i=0;i<ss.length;i++){var t=ss[i].textContent||'';var m=t.match(/var\\s+(\\w+)\\s*=\\s*\\[([\\s\\S]*?)\\];/g);if(m){for(var j=0;j<m.length;j++){var nm=m[j].match(/var\\s+(\\w+)/);var ar=m[j].match(/\\[([\\s\\S]*?)\\]/);if(nm&&ar){R.push({name:nm[1],array_preview:ar[1].substring(0,500),script_index:i})}}}}return JSON.stringify({count:R.length,arrays:R.slice(0,50)})})()"
            }
            否则
            {
                返回 (MCP_响应构建.命令失败 (命令ID, "未知mode: " + rsMode + " | 支持: suspicious/decrypt_array"))
            }
            变量 rsBrowser <类型 = 类_FBrowser_浏览器>
            rsBrowser = MCP命令服务器.取主浏览器 ()
            如果 (rsBrowser.是否为空 () == 假 && rsBrowser.是否已关闭 () == 假)
            {
                // v2.6.3: 改用 CDP Runtime.evaluate (sync-wait), 绕过不稳定的 CEF JS回调
                变量 rsWantedMS <类型 = 整数>
                rsWantedMS = MCP命令服务器.取同步等待毫秒 (方法名, 参数JSON)
                变量 rsRaw <类型 = 文本型>
                rsRaw = MCP命令服务器.CDP执行JS并等待 (rsCode, rsWantedMS, 真)
                如果 (rsRaw == "")
                {
                    返回 (MCP_响应构建.命令失败 (命令ID, "CDP Runtime.evaluate 超时(" + 到文本 (rsWantedMS) + "ms) | 可重试或使用 async_only:true"))
                }
                变量 rs解析 <类型 = YYJSON只读对象类>
                如果 (rs解析.创建自文本 (rsRaw))
                {
                    变量 rsErr <类型 = 文本型>
                    rsErr = MCP命令服务器.yyjson取文本 (rs解析, "error")
                    如果 (rsErr != "")
                    {
                        返回 (MCP_响应构建.命令失败 (命令ID, "字符串扫描错误: " + rsErr))
                    }
                }
                返回 (MCP_响应构建.命令成功_原始JSON (命令ID, rsRaw))
            }
