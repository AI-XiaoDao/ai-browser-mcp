        // === JS逆向: 静态加密模块提取 (CDP级, 不依赖CEF JS回调) ===
        否则 (方法名 == "browser_reverse_extract")
        {
            变量 exMode <类型 = 文本型>
            exMode = MCP命令服务器.yyjson取文本 (参数JSON, "mode")
            如果 (exMode == "")
            {
                exMode = "scan"
            }
            变量 exBrowser <类型 = 类_FBrowser_浏览器>
