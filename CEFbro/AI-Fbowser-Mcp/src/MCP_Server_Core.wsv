        // === 代理 ===
        否则 (方法名 == "browser_set_proxy")
        {
            变量 address <类型 = 文本型>
            变量 username <类型 = 文本型>
            变量 password <类型 = 文本型>
            address = MCP命令服务器.yyjson取文本 (参数JSON, "address")
            如果 (address != "")
            {
                username = MCP命令服务器.yyjson取文本 (参数JSON, "username")
                password = MCP命令服务器.yyjson取文本 (参数JSON, "password")
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    // VIP优先: SOCKS5代理 (通过CDP注入, 更安全可靠)
                    变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                    vip_ctrl = browser.取VIP控制器 ()
                    如果 (vip_ctrl.是否为空 () == 假)
                    {
                        vip_ctrl.高级_设置代理 (address, username, password)
                        MCP命令服务器.持久代理地址 = address
                        MCP命令服务器.持久代理账号 = username
                        MCP命令服务器.持久代理密码 = password
                        返回 (MCP_响应构建.响应_需要刷新 (命令ID, "S5代理已设置: " + address))
                    }
                    // 普通HTTP代理 (VIP不可用时退路)
                    browser.设置代理 (address, username, password)
                    // 持久化: 新浏览器自动应用
                    MCP命令服务器.持久代理地址 = address
                    MCP命令服务器.持久代理账号 = username
                    MCP命令服务器.持久代理密码 = password
                    返回 (MCP_响应构建.响应_需要刷新 (命令ID, "代理已设置(持久): " + address))
                }
                返回 (MCP_响应构建.命令失败 (命令ID, MCP_常量.错误_无浏览器))
            }
            返回 (MCP_响应构建.命令失败 (命令ID, "参数 address 不能为空"))
        }
        否则 (方法名 == "browser_clear_proxy")
        {
