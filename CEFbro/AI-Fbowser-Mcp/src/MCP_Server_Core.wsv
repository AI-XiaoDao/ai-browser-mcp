                    insCode = "(function(){var __orig=window['" + insEsc + "'];if(typeof __orig!=='function'){return JSON.stringify({error:'target_not_found',target:'" + insEsc + "'})};var __logs=window.__mcp_interpreter_logs=window.__mcp_interpreter_logs||[];var __maxCalls=100;window['" + insEsc + "']=function(){var __args=Array.prototype.slice.call(arguments);var __result=__orig.apply(this,__args);if(__logs.length<__maxCalls){__logs.push({target:'" + insEsc + "',args_preview:__args.map(function(a){return typeof a==='string'?a.substring(0,100):typeof a}).join('|'),ts:Date.now()})}return __result};window['" + insEsc + "'].toString=function(){return __orig.toString()};return JSON.stringify({installed:true,target:'" + insEsc + "',mode:'interpreter',hint:'VM interpreter hooked. toString preserved. Use browser_evaluate \"JSON.stringify(window.__mcp_interpreter_logs)\" to read collected data.'})})()"
                }
                否则
