            如果 (vipGeo.是否为空 () == 假)
            {
                // 注: API参数顺序为 (经度, 纬度), 即 (lng, lat)
                变量 geoLat <类型 = 小数>
                geoLat = MCP命令服务器.yyjson取小数 (参数JSON, "lat")
                变量 geoLng <类型 = 小数>
