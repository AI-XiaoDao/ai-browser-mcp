                }
                如果 (geoAcc < 0)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "精度不能为负数: " + 到文本 (geoAcc)))
                }
                vipGeo.指纹_虚拟定位 (geoLng, geoLat, geoAcc, -10000, -1, -1, -1)
                返回 (MCP命令服务器.响应_需要刷新 (命令ID, "定位指纹已设置"))
