                geoAcc = MCP命令服务器.yyjson取小数 (参数JSON, "accuracy")
                如果 (geoLat < -90 || geoLat > 90)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "纬度越界: " + 到文本 (geoLat) + " | 有效范围 -90 ~ 90"))
