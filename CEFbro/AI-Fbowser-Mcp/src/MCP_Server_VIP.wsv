<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# VIP 命令分派 — 从 MCP_Server.wsv 拆分 (L5/M10)
类 MCP_VIP分派 <公开 @全局类 = 真>
{
    方法 分类分派_VIP操作 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        子文本替换 (方法名, "browser.", "browser_", , , 假)
        如果 (方法名 == "browser_vip_websocket_intercept")
        {
            变量 enableFlag <类型 = 逻辑型>
            enableFlag = MCP命令服务器.yyjson取逻辑 (参数JSON, "enable")
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    如果 (enableFlag)
                    {
                        vip_ctrl.WebSocket_启用拦截 ()
                        返回 (MCP命令服务器.命令成功 (命令ID, "WebSocket拦截已启用"))
                    }
                    否则
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "WebSocket拦截不支持单独禁用, 请使用 browser_intercept action=clear 清除所有拦截"))
                    }
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === v1.6 快速连通性检查 ===
        // === VIP S5代理 ===
        否则 (方法名 == "browser_set_s5_proxy")
        {
            变量 address <类型 = 文本型>
            address = MCP命令服务器.yyjson取文本 (参数JSON, "address")
            如果 (address == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "address " + MCP_常量.错误_缺少参数))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级_设置代理 (address, MCP命令服务器.yyjson取文本 (参数JSON, "username"), MCP命令服务器.yyjson取文本 (参数JSON, "password"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "S5代理已设置: " + address))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP 高级鼠标键盘 (CDP) ===
        否则 (方法名 == "browser_vip_mouse_click")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    变量 vx <类型 = 整数>
                    vx = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                    变量 vy <类型 = 整数>
                    vy = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                    如果 (vx < 0 || vy < 0 || vx > 32767 || vy > 32767)
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "坐标越界 | x,y 须在 0~32767 范围内"))
                    }
                    vip_ctrl.高级鼠标_单击 (vx, vy, MCP命令服务器.yyjson取整数 (参数JSON, "button"))
                    返回 (MCP命令服务器.命令成功 (命令ID, "VIP鼠标点击"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_mouse_move")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级鼠标_移动 (MCP命令服务器.yyjson取整数 (参数JSON, "x"), MCP命令服务器.yyjson取整数 (参数JSON, "y"))
                    返回 (MCP命令服务器.命令成功 (命令ID, "VIP鼠标移动"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_key_press")
        {
            变量 pressKeyCode <类型 = 整数>
            pressKeyCode = MCP命令服务器.yyjson取整数 (参数JSON, "key_code")
            如果 (pressKeyCode <= 0 || pressKeyCode > 255)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "参数 key_code 无效(" + 到文本 (pressKeyCode) + ") | 虚拟键码范围 1~255, 如回车=13, 空格=32, A=65"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级键盘_按下 (pressKeyCode)
                    返回 (MCP命令服务器.命令成功 (命令ID, "VIP键盘按下: key_code=" + 到文本 (pressKeyCode)))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_key_release")
        {
            变量 releaseKeyCode <类型 = 整数>
            releaseKeyCode = MCP命令服务器.yyjson取整数 (参数JSON, "key_code")
            如果 (releaseKeyCode <= 0 || releaseKeyCode > 255)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "参数 key_code 无效(" + 到文本 (releaseKeyCode) + ") | 虚拟键码范围 1~255"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级键盘_放开 (releaseKeyCode)
                    返回 (MCP命令服务器.命令成功 (命令ID, "VIP键盘放开: key_code=" + 到文本 (releaseKeyCode)))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP 补充 ===
        否则 (方法名 == "browser_vip_clear_s5_proxy")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级_清空代理 ()
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "S5代理已清除"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_enable_inspector")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "enable"))
                    {
                        MCP命令服务器.确保CDP观察者已注册 ()
                    }
                    否则
                    {
                        MCP命令服务器.注销CDP观察者 ()
                    }
                    返回 (MCP命令服务器.命令成功 (命令ID, "监管者事件已设置"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_enable_js_env")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级_启用执行环境 (MCP命令服务器.yyjson取逻辑 (参数JSON, "enable"))
                    返回 (MCP命令服务器.命令成功 (命令ID, "JS执行环境已设置"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_get_js_env_ids")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    变量 ids <类型 = 类_FBrowser_列表值>
                    ids = vip_ctrl.高级_取当前环境ID清单 ()
                    如果 (ids.是否为空 () == 假)
                    {
                        返回 (MCP命令服务器.构建整数值JSON ("count", ids.取大小 ()))
                    }
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_vip_touch_cancel")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.高级触摸_取消 (MCP命令服务器.yyjson取整数 (参数JSON, "x"), MCP命令服务器.yyjson取整数 (参数JSON, "y"))
                    返回 (MCP命令服务器.命令成功 (命令ID, "触摸取消"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP 内核开关 ===
        否则 (方法名 == "browser_vip_disable_debugger")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.内核开关_禁用Debugger (MCP命令服务器.yyjson取逻辑 (参数JSON, "disable"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "Debugger开关已设置 | 内核开关修改, 需要刷新页面生效"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP 指纹扩展 ===
        否则 (方法名 == "browser_fingerprint_plugins")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.指纹_虚拟Plugins (MCP命令服务器.yyjson取整数 (参数JSON, "type"), MCP命令服务器.yyjson取JSON文本 (参数JSON, "json"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "Plugins指纹已设置"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        否则 (方法名 == "browser_fingerprint_appname")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    vip_ctrl.指纹_虚拟AppName (MCP命令服务器.yyjson取文本 (参数JSON, "value"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "AppName指纹已设置"))
                }
