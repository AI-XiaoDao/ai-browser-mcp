        否则 (方法名 == "browser_refresh_cookies")
        {
            FBrowser_Cookie管理器_取全局 ().刷新Cookie ()
            返回 (MCP命令服务器.命令成功 (命令ID, "Cookie已刷新到磁盘"))
        }
        否则 (方法名 == "browser_get_all_cookies")
        {
            变量 异步CookieID <类型 = 文本型>
            异步CookieID = MCP命令服务器.生成异步任务ID ()
            变量 Cookie回调 <类型 = 类_FBrowser_事件智能指针>
            Cookie回调.创建 (类_MCP_Cookie收集回调)
            Cookie回调.取执行类 (类_MCP_Cookie收集回调).异步任务ID = 异步CookieID
            FBrowser_Cookie管理器_取全局 ().取全部Cookie (Cookie回调)
            返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步CookieID, "全部Cookie获取已提交, 通过mcp_result查询"))
        }
        // === 请求环境补充 ===
        否则 (方法名 == "browser_set_preference")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 reqCtx <类型 = 类_FBrowser_请求环境>
                reqCtx = browser.取请求环境 ()
                如果 (reqCtx.是否为空 () == 假)
                {
                    变量 名称 <类型 = 文本型>
                    变量 值文本 <类型 = 文本型>
                    名称 = MCP命令服务器.yyjson取文本 (参数JSON, "name")
                    值文本 = MCP命令服务器.yyjson取文本 (参数JSON, "value")
                    如果 (名称 == "")
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "缺少参数: name(首选项名)"))
                    }
                    如果 (值文本 == "")
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "缺少参数: value(首选项值)"))
                    }
                    变量 设置值 <类型 = 类_FBrowser_值>
                    设置值.创建 ()
                    // 按优先级匹配类型: 逻辑 > 整数环回验证 > 文本兜底
                    如果 (值文本 == "true" || 值文本 == "false")
                    {
                        设置值.置逻辑值 (值文本 == "true")
                    }
                    否则
                    {
                        变量 整数结果 <类型 = 整数>
                        整数结果 = 文本到整数 (值文本)
                        // 环回验证: 文本形式的整数应该严格匹配 (防止 "123abc" 被当作整数 123)
                        如果 (值文本 == 到文本 (整数结果) && 值文本 != "")
                        {
                            设置值.置整数值 (整数结果)
                        }
                        否则
                        {
                            设置值.置文本值 (值文本)
                        }
                    }
                    变量 错误文本 <类型 = 文本型>
                    reqCtx.置首选项 (设置值, 名称, 错误文本)
                    如果 (错误文本 != "")
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "首选项设置失败: " + 错误文本))
                    }
                    返回 (MCP命令服务器.命令成功 (命令ID, "首选项 " + 名称 + " 已设置"))
                }
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
