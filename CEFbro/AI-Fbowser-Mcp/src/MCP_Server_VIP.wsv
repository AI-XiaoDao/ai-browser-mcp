                    VIPJS回调.取执行类 (类_MCP_VIP通用回调).任务ID = 异步VIPJSID
                    如果 (frmID != "")
                    {
                        vipCtrl.高级_执行JS_框架ID (jsCode, frmID, 真, 假, 真, MCP_常量.URL请求默认超时, 假, 假, VIPJS回调)
                    }
                    否则
                    {
                        vipCtrl.高级_执行JS (jsCode, ctxID, 真, 假, 真, MCP_常量.URL请求默认超时, 假, 假, VIPJS回调)
                    }
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步VIPJSID, "JS已提交到指定环境"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "需要code参数"))
        }
        // === VIP CDP DOM文档获取 (v1.7) ===
        否则 (方法名 == "browser_vip_dom_get_document")
        {
            变量 vipDom <类型 = 类_FBrowserVIP_开发者DOM>
            vipDom = MCP命令服务器.取开发者DOM_安全 ()
            如果 (vipDom.是否为空 () == 假)
            {
                vipDom.启用 ("all")
                变量 dDepth <类型 = 整数>
                dDepth = MCP命令服务器.yyjson取整数 (参数JSON, "depth")
                如果 (dDepth == 0)
                {
                    dDepth = 3
                }
                如果 (dDepth > 10)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "depth 最大为10, 超过会导致性能问题 | 当前值: " + 到文本 (dDepth)))
                }
                变量 异步DOMID <类型 = 文本型>
                异步DOMID = MCP命令服务器.生成异步任务ID ()
                变量 DOM回调 <类型 = 类_FBrowser_事件智能指针>
                DOM回调.创建 (类_MCP_VIP通用回调)
                DOM回调.取执行类 (类_MCP_VIP通用回调).任务ID = 异步DOMID
                vipDom.枚举DOM (dDepth, 假, DOM回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步DOMID, "DOM文档已提交枚举, 通过mcp_result查询"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
        }
        否则 (方法名 == "browser_vip_dom_search")
        {
            变量 searchQuery <类型 = 文本型>
            searchQuery = MCP命令服务器.yyjson取文本 (参数JSON, "query")
            如果 (searchQuery != "")
            {
                变量 vipDom2 <类型 = 类_FBrowserVIP_开发者DOM>
                vipDom2 = MCP命令服务器.取开发者DOM_安全 ()
                如果 (vipDom2.是否为空 () == 假)
                {
                    变量 sID <类型 = 文本型>
                    sID = MCP命令服务器.yyjson取文本 (参数JSON, "search_id")
                    如果 (sID != "")
                    {
                        变量 异步搜索ID <类型 = 文本型>
                        异步搜索ID = MCP命令服务器.生成异步任务ID ()
                        变量 搜索回调 <类型 = 类_FBrowser_事件智能指针>
                        搜索回调.创建 (类_MCP_VIP通用回调)
                        搜索回调.取执行类 (类_MCP_VIP通用回调).任务ID = 异步搜索ID
                        vipDom2.取查找文本 (sID, 0, 100, 搜索回调)
                        返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步搜索ID, "查找结果已提交, 通过mcp_result查询"))
                    }
                    否则
                    {
                        变量 异步预查ID <类型 = 文本型>
                        异步预查ID = MCP命令服务器.生成异步任务ID ()
                        变量 预查回调 <类型 = 类_FBrowser_事件智能指针>
                        预查回调.创建 (类_MCP_VIP通用回调)
                        预查回调.取执行类 (类_MCP_VIP通用回调).任务ID = 异步预查ID
                        vipDom2.预查找文本 (searchQuery, 假, 预查回调)
                        返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步预查ID, "预查找已提交, 通过mcp_result查询, 从结果中取searchId再query"))
                    }
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "需要query或search_id参数"))
        }
        否则 (方法名 == "browser_vip_enable_devtools_observer")
        {
            变量 enableObs <类型 = 逻辑型>
            enableObs = MCP命令服务器.yyjson取逻辑 (参数JSON, "enable")
            变量 vipObs <类型 = 类_FBrowserVIP_控制器>
            vipObs = MCP命令服务器.取VIP控制器 ()
            如果 (vipObs.是否为空 () == 假)
            {
                如果 (enableObs)
                {
                    MCP命令服务器.确保CDP观察者已注册 ()
                    返回 (MCP命令服务器.命令成功 (命令ID, "DevTools消息监听已启用(MCP观察者)"))
                }
                否则
                {
                    MCP命令服务器.注销CDP观察者 ()
                    返回 (MCP命令服务器.命令成功 (命令ID, "DevTools消息监听已关闭"))
                }
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
        }
        // === VIP 触摸模拟 (v1.7) ===
        否则 (方法名 == "browser_vip_touch_emulation")
        {
            变量 vipTouch <类型 = 类_FBrowserVIP_控制器>
            vipTouch = MCP命令服务器.取VIP控制器 ()
            如果 (vipTouch.是否为空 () == 假)
            {
                vipTouch.指纹_启用触摸事件 (MCP命令服务器.yyjson取逻辑 (参数JSON, "enable"), MCP命令服务器.yyjson取整数 (参数JSON, "max_points"))
                返回 (MCP命令服务器.响应_需要刷新 (命令ID, "触摸模拟已设置"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
        }
        // === VIP UA完整指纹 (v1.7) ===
        否则 (方法名 == "browser_fingerprint_ua")
        {
            变量 vipUA <类型 = 类_FBrowserVIP_控制器>
            vipUA = MCP命令服务器.取VIP控制器 ()
            如果 (vipUA.是否为空 () == 假)
            {
                变量 ua_data <类型 = 类_FBrowserVIP_UA数据>
                ua_data.创建 ()
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "ua") != "")
                {
                    ua_data.置UserAgent (MCP命令服务器.yyjson取文本 (参数JSON, "ua"))
                }
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "platform") != "")
                {
                    ua_data.置Platform (MCP命令服务器.yyjson取文本 (参数JSON, "platform"))
                    ua_data.置HighPlatform (MCP命令服务器.yyjson取文本 (参数JSON, "platform"))
                }
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "accept_lang") != "")
                {
                    ua_data.置AcceptLanguage (MCP命令服务器.yyjson取文本 (参数JSON, "accept_lang"))
                }
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "architecture") != "")
                {
                    ua_data.置Architecture (MCP命令服务器.yyjson取文本 (参数JSON, "architecture"))
                }
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "bitness") != "")
                {
                    ua_data.置Bitness (MCP命令服务器.yyjson取文本 (参数JSON, "bitness"))
                }
                如果 (MCP命令服务器.yyjson取文本 (参数JSON, "model") != "")
                {
                    ua_data.置Model (MCP命令服务器.yyjson取文本 (参数JSON, "model"))
                }
                ua_data.置Mobile (MCP命令服务器.yyjson取逻辑 (参数JSON, "mobile"))
                ua_data.置Wow64 (MCP命令服务器.yyjson取逻辑 (参数JSON, "wow64"))
                vipUA.指纹_虚拟UserAgent (ua_data)
                返回 (MCP命令服务器.响应_需要刷新 (命令ID, "UA完整指纹已设置"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
        }
        // === VIP 屏幕方向 (v1.7) ===
        否则 (方法名 == "browser_vip_orientation")
        {
            变量 vipOrient <类型 = 类_FBrowserVIP_控制器>
            vipOrient = MCP命令服务器.取VIP控制器 ()
            如果 (vipOrient.是否为空 () == 假)
            {
                // 整数→屏幕方向类型枚举映射 (规避火山 @常量类 模板限制)
                变量 orient_int <类型 = 整数>
                变量 angle_int <类型 = 整数>
                orient_int = MCP命令服务器.yyjson取整数 (参数JSON, "type")
                angle_int = MCP命令服务器.yyjson取整数 (参数JSON, "angle")
                变量 orient_enum <类型 = 屏幕方向类型>
                如果 (orient_int == 1)
                {
                    orient_enum = 屏幕方向类型.竖屏16_9
                }
                否则 (orient_int == 2)
                {
                    orient_enum = 屏幕方向类型.竖屏4_3
                }
                否则 (orient_int == 3)
                {
                    orient_enum = 屏幕方向类型.横屏16_9
                }
                否则 (orient_int == 4)
                {
                    orient_enum = 屏幕方向类型.横屏4_3
                }
                否则
                {
                    orient_enum = 屏幕方向类型.默认
                }
                vipOrient.指纹_虚拟屏幕方向 (orient_enum, angle_int)
                返回 (MCP命令服务器.响应_需要刷新 (命令ID, "屏幕方向已设置"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
        }
        // === 获取额外数据 (v1.7) ===
        否则 (方法名 == "browser_get_extra_data")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 extraData <类型 = 类_FBrowser_字典值>
                extraData = browser.取额外数据 ()
                如果 (extraData.是否为空 () == 假)
                {
                    变量 extraKeys <类型 = FBrowser_文本数组>
                    extraKeys = extraData.取关键字 ()
                    变量 extraObj <类型 = YYJSON对象类>
                    extraObj.创建自文本 ("{}")
                    变量 keyCount <类型 = 整数>
                    keyCount = extraKeys.取个数 ()
                    计次循环 (keyCount)
                    {
                        变量 keyName <类型 = 文本型>
                        keyName = extraKeys.取数据 (取循环索引 ())
                        extraObj.加入文本成员 (keyName, extraData.取文本值 (keyName))
                    }
                    返回 (MCP命令服务器.命令成功_原始JSON (命令ID, extraObj.到可读文本 (YYJSON格式化选项.压缩)))
                }
                返回 (MCP命令服务器.命令成功 (命令ID, "额外数据为空"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP 控制台禁用(完整) ===
        否则 (方法名 == "browser_vip_disable_console")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip <类型 = 类_FBrowserVIP_控制器>
                vip = browser.取VIP控制器 ()
                如果 (vip.是否为空 () == 假)
                {
                    vip.内核开关_禁用ConsoleLog (MCP命令服务器.yyjson取逻辑 (参数JSON, "log"))
                    vip.内核开关_禁用ConsoleWarn (MCP命令服务器.yyjson取逻辑 (参数JSON, "warn"))
                    vip.内核开关_禁用ConsoleError (MCP命令服务器.yyjson取逻辑 (参数JSON, "error"))
                    vip.内核开关_禁用ConsoleDebug (MCP命令服务器.yyjson取逻辑 (参数JSON, "debug"))
                    vip.内核开关_禁用ConsoleInfo (MCP命令服务器.yyjson取逻辑 (参数JSON, "info"))
                    vip.内核开关_禁用ConsoleTrace (MCP命令服务器.yyjson取逻辑 (参数JSON, "trace"))
                    vip.内核开关_禁用ConsoleClear (MCP命令服务器.yyjson取逻辑 (参数JSON, "clear"))
                    vip.内核开关_禁用ConsoleAssert (MCP命令服务器.yyjson取逻辑 (参数JSON, "assert"))
                    vip.内核开关_禁用ConsoleDir (MCP命令服务器.yyjson取逻辑 (参数JSON, "dir"))
                    vip.内核开关_禁用ConsoleTable (MCP命令服务器.yyjson取逻辑 (参数JSON, "table"))
                    vip.内核开关_禁用ConsoleTime (MCP命令服务器.yyjson取逻辑 (参数JSON, "time"))
                    vip.内核开关_禁用ConsoleCount (MCP命令服务器.yyjson取逻辑 (参数JSON, "count"))
                    vip.内核开关_禁用ConsoleGroup (MCP命令服务器.yyjson取逻辑 (参数JSON, "group"))
                    vip.内核开关_禁用ConsoleProfile (MCP命令服务器.yyjson取逻辑 (参数JSON, "profile"))
                    vip.内核开关_禁用Performance检测 (MCP命令服务器.yyjson取逻辑 (参数JSON, "performance"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "Console/Performance禁用已设置"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        // === VIP Event.isTrusted ===
        否则 (方法名 == "browser_vip_set_is_trusted")
        {
            变量 br <类型 = 类_FBrowser_浏览器>
            br = MCP命令服务器.取主浏览器 ()
            如果 (br.是否为空 () == 假)
            {
                变量 vp <类型 = 类_FBrowserVIP_控制器>
                vp = br.取VIP控制器 ()
                如果 (vp.是否为空 () == 假)
                {
                    vp.内核开关_设置EventIsTrusted (MCP命令服务器.yyjson取逻辑 (参数JSON, "value"))
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "isTrusted已设置"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP_常量.错误_无浏览器))
        }
        返回 ("")
    }
    #
}
