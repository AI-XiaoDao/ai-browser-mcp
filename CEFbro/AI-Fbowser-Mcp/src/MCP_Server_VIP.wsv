                {
                    变量 devJson <类型 = 文本型>
                    devJson = MCP命令服务器.yyjson取JSON文本 (参数JSON, "json")
                    如果 (devJson == "")
                    {
                        devJson = MCP命令服务器.yyjson取文本 (参数JSON, "json")
                    }
                    如果 (devJson == "")
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "json 参数不能为空"))
                    }
                    vip_ctrl.开发者消息_发送消息 (devJson)
                    返回 (MCP命令服务器.命令成功 (命令ID, "DevTools消息已发送"))
                }
