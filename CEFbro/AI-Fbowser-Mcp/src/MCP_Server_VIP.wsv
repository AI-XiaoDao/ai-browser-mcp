        // === VIP 指定环境执行JS (v1.7) ===
        否则 (方法名 == "browser_vip_execute_js_context")
        {
            变量 jsCode <类型 = 文本型>
            jsCode = MCP命令服务器.yyjson取文本 (参数JSON, "code")
            如果 (jsCode != "")
            {
                变量 vipCtrl <类型 = 类_FBrowserVIP_控制器>
                vipCtrl = MCP命令服务器.取VIP控制器 ()
                如果 (vipCtrl.是否为空 () == 假)
                {
