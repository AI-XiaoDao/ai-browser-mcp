<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# MCP_编排分派 — 工作流编排模块 (JSON 步骤 → MCP 工具链)
类 MCP_编排分派 <公开 @全局类 = 真>
{
    变量 工作流应停止 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 工作流运行中 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 当前工作流名 <公开 静态 类型 = 文本型 值 = "">
    变量 工作流目录缓存 <公开 静态 类型 = 文本型 值 = "">
    变量 工作流开始时间 <公开 静态 类型 = 长整数 值 = 0>
    常量 工作流最大运行毫秒 <公开 类型 = 整数 值 = 1800000 注释 = "30分钟, 超时强制重置">
    方法 重置工作流状态 <公开 静态>
    {
        工作流应停止 = 假
        工作流运行中 = 假
        当前工作流名 = ""
        工作流开始时间 = 0
    }
    方法 强制终止超时工作流 <公开 静态>
    {
        如果 (工作流运行中 == 假 || 工作流开始时间 == 0)
        {
            返回
        }
        如果 (取启动时间 () - 工作流开始时间 > 工作流最大运行毫秒)
        {
            调试输出 ("[MCP] 工作流运行超时, 强制终止:", 当前工作流名)
            工作流应停止 = 真
            工作流运行中 = 假
            当前工作流名 = ""
            工作流开始时间 = 0
        }
    }
    方法 分类分派_编排操作 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        如果 (方法名 == "workflow.list" || 方法名 == "workflow_list")
        {
            返回 (处理_工作流列表 (命令ID))
        }
        否则 (方法名 == "workflow.get" || 方法名 == "workflow_get")
        {
            变量 工作流名 <类型 = 文本型>
            工作流名 = MCP命令服务器.yyjson取文本 (参数JSON, "name")
            如果 (工作流名 == "")
            {
                工作流名 = MCP命令服务器.yyjson取文本 (参数JSON, "file")
            }
            返回 (处理_工作流获取 (命令ID, 工作流名))
        }
        否则 (方法名 == "workflow.run" || 方法名 == "workflow_run")
        {
            返回 (处理_工作流运行 (命令ID, 参数JSON))
        }
        否则 (方法名 == "workflow.stop" || 方法名 == "workflow_stop")
        {
            如果 (工作流运行中)
            {
                工作流应停止 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "工作流停止信号已发送 | 当前运行中: " + 当前工作流名))
            }
            否则
            {
                工作流应停止 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "没有正在运行的工作流, 无需停止"))
            }
        }
        返回 ("")
    }
    方法 目录含工作流JSON <公开 静态 类型 = 逻辑型>
    参数 目录 <类型 = 文本型>
    {
        如果 (目录 == "")
        {
            返回 (假)
        }
        变量 查找器 <类型 = 文件查找类>
        变量 找到名 <类型 = 文本型>
        找到名 = 查找器.寻找文件 (目录 + "\\*.json", -1, 文件属性.子目录)
        返回 (找到名 != "")
    }
    方法 读入工作流JSON文本 <公开 静态 类型 = 文本型>
    参数 文件路径 <类型 = 文本型>
    {
        如果 (文件路径 == "")
        {
            返回 ("")
        }
        变量 文件字节 <类型 = 字节集类>
        文件字节 = 读入文件 (文件路径)
        如果 (取字节集长度 (文件字节) == 0)
        {
            返回 ("")
        }
        返回 (UTF8到文本 (文件字节))
    }
    方法 从定义对象取步骤数组 <公开 静态 类型 = YYJSON只读数组类>
    参数 定义对象 <类型 = YYJSON只读对象类>
    {
        如果 (定义对象.是否为空 ())
        {
            变量 空数组 <类型 = YYJSON只读数组类>
            返回 (空数组)
        }
        // 委托到统一的步骤数组解析方法
        返回 (解析步骤数组参数 (定义对象))
    }
    方法 取工作流目录 <公开 静态 类型 = 文本型>
    {
        如果 (工作流目录缓存 != "")
        {
            返回 (工作流目录缓存)
        }
        变量 环境目录 <类型 = 文本型>
        环境目录 = 读环境变量 ("AI_BROWSER_WORKFLOWS_DIR")
        如果 (环境目录 != "" && 目录含工作流JSON (环境目录))
        {
            工作流目录缓存 = 环境目录
            返回 (工作流目录缓存)
        }
        变量 运行目录 <类型 = 文本型>
        运行目录 = 取运行目录 ()
        变量 候选1 <类型 = 文本型>
        候选1 = 运行目录 + "\\workflows"
        如果 (目录含工作流JSON (候选1))
        {
            工作流目录缓存 = 候选1
            返回 (工作流目录缓存)
        }
        变量 候选2 <类型 = 文本型>
        候选2 = 运行目录 + "\\..\\..\\..\\..\\..\\workflows"
        如果 (目录含工作流JSON (候选2))
        {
            工作流目录缓存 = 候选2
            返回 (工作流目录缓存)
        }
        变量 候选3 <类型 = 文本型>
        候选3 = 运行目录 + "\\..\\workflows"
        如果 (目录含工作流JSON (候选3))
        {
            工作流目录缓存 = 候选3
            返回 (工作流目录缓存)
        }
        工作流目录缓存 = 候选1
        返回 (工作流目录缓存)
    }
    方法 规范化工作流名 <公开 静态 类型 = 文本型>
    参数 原始名 <类型 = 文本型>
    {
        变量 名 <类型 = 文本型>
        名 = 删首尾空 (原始名)
        如果 (名 == "")
        {
            返回 ("")
        }
        名 = 取文件名无路径部分 (名)
        如果 (取文本右边 (名, 5) == ".json")
        {
            名 = 取文本左边 (名, 取文本长度 (名) - 5)
        }
        // 防路径穿越: 仅允许文件名成分
        如果 (寻找文本 (名, "..", 0, 假) != -1 || 寻找文本 (名, "\\", 0, 假) != -1 || 寻找文本 (名, "/", 0, 假) != -1 || 寻找文本 (名, ":", 0, 假) != -1)
        {
            返回 ("")
        }
        返回 (名)
    }
    方法 处理_工作流列表 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    {
        变量 目录 <类型 = 文本型>
        目录 = 取工作流目录 ()
        变量 列表对象 <类型 = YYJSON对象类>
        列表对象.创建自文本 ("{}")
        变量 名称数组 <类型 = 文本数组类>
        变量 工作流数组 <类型 = YYJSON数组类>
        工作流数组.创建自文本数据 (MCP命令服务器.取空文本数组 ())
        变量 查找器 <类型 = 文件查找类>
        变量 通配 <类型 = 文本型>
        通配 = 目录 + "\\*.json"
        变量 找到名 <类型 = 文本型>
        找到名 = 查找器.寻找文件 (通配, -1, 文件属性.子目录)
        判断循环 (找到名 != "")
        {
            如果 (取文本右边 (找到名, 5) == ".json")
            {
                名称数组.加入成员 (取文本左边 (找到名, 取文本长度 (找到名) - 5))
            }
            找到名 = 查找器.寻找文件 ("", -1, 文件属性.子目录)
        }
        变量 idx <类型 = 整数>
        计次循环 (名称数组.取成员数 ())
        {
            idx = 取循环索引 ()
            工作流数组.加入文本成员 (名称数组.取成员 (idx))
        }
        列表对象.加入数组成员 ("workflows", 工作流数组)
        列表对象.加入整数成员 ("count", 名称数组.取成员数 ())
        列表对象.加入文本成员 ("directory", 目录)
        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 列表对象.到可读文本 (YYJSON格式化选项.压缩)))
    }
    方法 处理_工作流获取 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 工作流名 <类型 = 文本型>
    {
        变量 安全名 <类型 = 文本型>
        安全名 = 规范化工作流名 (工作流名)
        如果 (安全名 == "")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "无效工作流名"))
        }
        变量 文件路径 <类型 = 文本型>
        文件路径 = 取工作流目录 () + "\\" + 安全名 + ".json"
        变量 JSON文本 <类型 = 文本型>
        JSON文本 = 读入工作流JSON文本 (文件路径)
        如果 (JSON文本 == "")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "工作流不存在: " + 安全名))
        }
        变量 校验 <类型 = YYJSON只读对象类>
        如果 (校验.创建自文本 (JSON文本) == 假)
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "工作流 JSON 无效: " + 安全名))
        }
        变量 包装 <类型 = YYJSON对象类>
        包装.创建自文本 ("{}")
        包装.加入文本成员 ("name", 安全名)
        包装.加入文本成员 ("definition", JSON文本)
        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 包装.到可读文本 (YYJSON格式化选项.压缩)))
    }
    方法 加载工作流定义 <公开 静态 类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        // name/file 优先于内联 definition (MCP 可能注入空的 definition:{} 占位)
        变量 工作流名 <类型 = 文本型>
        工作流名 = MCP命令服务器.yyjson取文本 (参数JSON, "name")
        如果 (工作流名 == "")
        {
            工作流名 = MCP命令服务器.yyjson取文本 (参数JSON, "file")
        }
        变量 安全名 <类型 = 文本型>
        安全名 = 规范化工作流名 (工作流名)
        如果 (安全名 != "")
        {
            变量 文件路径 <类型 = 文本型>
            文件路径 = 取工作流目录 () + "\\" + 安全名 + ".json"
            变量 文件文本 <类型 = 文本型>
            文件文本 = 读入工作流JSON文本 (文件路径)
            如果 (文件文本 != "")
            {
                返回 (文件文本)
            }
        }
        变量 定义文本 <类型 = 文本型>
        定义文本 = MCP命令服务器.yyjson取文本 (参数JSON, "definition")
        如果 (定义文本 != "")
        {
            返回 (定义文本)
        }
        变量 defObj <类型 = YYJSON只读对象类>
        defObj = 参数JSON.取对象 ("definition")
        如果 (defObj.是否为空 () == 假 && defObj.取成员数 () > 0)
        {
            返回 (defObj.到可读文本 (YYJSON格式化选项.压缩))
        }
        返回 ("")
    }
    方法 从结果提取任务ID <公开 静态 类型 = 文本型>
    参数 结果JSON <类型 = 文本型>
    {
        变量 解析 <类型 = YYJSON只读对象类>
        如果 (解析.创建自文本 (结果JSON) == 假)
        {
            返回 ("")
        }
        变量 taskID <类型 = 文本型>
        taskID = MCP命令服务器.yyjson取文本 (解析, "task_id")
        如果 (taskID != "")
        {
            返回 (taskID)
        }
        变量 dataObj <类型 = YYJSON只读对象类>
        dataObj = MCP命令服务器.yyjson取对象成员 (解析, "data")
        如果 (dataObj.是否为空 () == 假)
        {
            taskID = MCP命令服务器.yyjson取文本 (dataObj, "task_id")
            如果 (taskID != "")
            {
                返回 (taskID)
            }
        }
        变量 消息 <类型 = 文本型>
        消息 = MCP命令服务器.yyjson取文本 (解析, "message")
        变量 前缀 <类型 = 文本型>
        前缀 = "task_id="
        变量 pos <类型 = 整数>
        pos = 寻找文本 (消息, 前缀, 0, 假)
        如果 (pos != -1)
        {
            变量 前缀长 <类型 = 整数>
            前缀长 = 取文本长度 (前缀)
            变量 剩余长 <类型 = 整数>
            剩余长 = 取文本长度 (消息) - pos - 前缀长
            如果 (剩余长 <= 0)
            {
                返回 ("")
            }
            变量 提取长 <类型 = 整数>
            提取长 = 剩余长 + 1
            如果 (提取长 > 256)
            {
                提取长 = 256  // task_id 通常<64字符, 256上限防异常
            }
            变量 原始提取 <类型 = 文本型>
            原始提取 = 取文本中间 (消息, pos + 前缀长, 提取长)
            // 截断到空格或引号边界, 避免带出后续文本
            变量 边界 <类型 = 整数>
            边界 = 寻找文本 (原始提取, " ", 0, 假)
            如果 (边界 == -1)
            {
                边界 = 寻找文本 (原始提取, "\"", 0, 假)
            }
            如果 (边界 > 0)
            {
                返回 (取文本左边 (原始提取, 边界 - 1))
            }
            返回 (原始提取)
        }
        pos = 寻找文本 (结果JSON, "task_", 0, 假)
        如果 (pos != -1)
        {
            变量 JSON剩余 <类型 = 整数>
            JSON剩余 = 取文本长度 (结果JSON) - pos
            变量 片段长 <类型 = 整数>
            片段长 = 80
            如果 (JSON剩余 < 片段长)
            {
                片段长 = JSON剩余
            }
            变量 片段 <类型 = 文本型>
            片段 = 取文本中间 (结果JSON, pos, 片段长)
            变量 结束 <类型 = 整数>
            结束 = 寻找文本 (片段, "\"", 0, 假)
            如果 (结束 == -1)
            {
                结束 = 寻找文本 (片段, " ", 0, 假)
            }
            如果 (结束 == -1)
            {
                结束 = 取文本长度 (片段)
            }
            变量 候选ID <类型 = 文本型>
            候选ID = 取文本左边 (片段, 结束)
            // 验证格式: task_<毫秒>_<随机盐>_<计数器>, 仅含 task_ 数字 下划线
            如果 (是否以 (候选ID, "task_") && 取文本长度 (候选ID) >= 20 && 取文本长度 (候选ID) <= 64)
            {
                // 验证仅含数字和下划线: task_<毫秒>_<随机盐>_<计数器> (三段均为纯数字)
                变量 idValid <类型 = 逻辑型 值 = 真>
                常量 idAllowed <类型 = 文本型 值 = "0123456789_">
                变量 idLen <类型 = 整数>
                idLen = 取文本长度 (候选ID)
                计次循环 (idLen)
                {
                    变量 ch <类型 = 文本型>
                    ch = 取文本中间 (候选ID, 取循环索引 () + 1, 1)
                    如果 (寻找文本 (idAllowed, ch, 0, 假) == -1)
                    {
                        idValid = 假
                        跳出循环
                    }
                }
                如果 (idValid)
                {
                    返回 (候选ID)
                }
            }
        }
        返回 ("")
    }
    方法 等待步骤异步完成 <公开 静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    参数 最大毫秒 <类型 = 整数>
    参数 工作流命令ID <类型 = 文本型>
    参数 工具名 <类型 = 文本型 @默认值 = "">
    {
        如果 (任务ID == "")
        {
            返回 (MCP命令服务器.构建标准失败JSON ("缺少 task_id"))
        }
        如果 (工作流应停止)
        {
            返回 (MCP命令服务器.构建标准失败JSON ("工作流已停止"))
        }
        如果 (MCP命令服务器.MCP正在关闭)
        {
            返回 (MCP命令服务器.构建标准失败JSON ("MCP 正在关闭"))
        }
        变量 开始 <类型 = 长整数>
        开始 = 取启动时间 ()
        变量 存储结果 <类型 = 文本型>
        MCP命令服务器.MCP执行锁.解锁 ()
        存储结果 = MCP命令服务器.等待异步任务完成 (任务ID, 最大毫秒, 工作流命令ID, 工具名)
        MCP命令服务器.MCP执行锁.加锁 ()
        如果 (存储结果 == "")
        {
            如果 (MCP命令服务器.MCP正在关闭)
            {
                返回 (MCP命令服务器.构建标准失败JSON ("MCP 服务正在关闭"))
            }
            返回 (MCP命令服务器.构建标准失败JSON ("步骤异步超时(" + 到文本 (最大毫秒) + "ms), task_id=" + 任务ID))
        }
        变量 实际工具 <类型 = 文本型>
        实际工具 = 工具名
        如果 (实际工具 == "")
        {
            实际工具 = MCP命令服务器.当前命令方法名
        }
        返回 (MCP命令服务器.将异步结果转为命令响应 (工作流命令ID + "_w", 存储结果, MCP命令服务器.取工具结果键名 (实际工具), (整数)(取启动时间 () - 开始), 实际工具))
    }
    # 单步执行结果: skip | delay | ok | fail | fail_stop
    方法 步骤JSON片段列表到数组文本 <公开 静态 类型 = 文本型>
    参数 片段列表 <类型 = 文本数组类>
    {
        如果 (片段列表.取成员数 () == 0)
        {
            返回 ("[]")
        }
        变量 结果 <类型 = 文本型>
        结果 = "["
        变量 idx <类型 = 整数>
        计次循环 (片段列表.取成员数 ())
        {
            idx = 取循环索引 ()
            如果 (idx > 0)
            {
                结果 = 结果 + ","
            }
            结果 = 结果 + 片段列表.取成员 (idx)
        }
        结果 = 结果 + "]"
        返回 (结果)
    }
    方法 追加步骤结构失败记录 <公开 静态>
    参数 步骤结果JSON列表 <类型 = 文本数组类>
    参数 步索引 <类型 = 整数>
    参数 工具名 <类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 步记录 <类型 = YYJSON对象类>
        步记录.创建自文本 ("{}")
        步记录.加入整数成员 ("index", 步索引 + 1)
        步记录.加入文本成员 ("tool", 工具名)
        步记录.加入逻辑值成员 ("success", 假)
        步记录.加入文本成员 ("error", 错误消息)
        步记录.加入文本成员 ("result", MCP命令服务器.构建标准失败JSON (错误消息))
        步骤结果JSON列表.加入成员 (步记录.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 执行工作流单步 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 步骤 <类型 = YYJSON只读对象类>
    参数 步索引 <类型 = 整数>
    参数 全局onError <类型 = 文本型>
    参数 步骤结果JSON列表 <类型 = 文本数组类>
    {
        如果 (步骤.是否为空 ())
        {
            追加步骤结构失败记录 (步骤结果JSON列表, 步索引, "", "空步骤对象")
            返回 ("fail")
        }
        如果 (MCP命令服务器.yyjson取逻辑 (步骤, "skip"))
        {
            返回 ("skip")
        }
        变量 延时毫秒 <类型 = 整数>
        延时毫秒 = MCP命令服务器.yyjson取整数 (步骤, "delay_ms")
        如果 (延时毫秒 > 0)
        {
            MCP命令服务器.MCP可中断延时 (延时毫秒)
            返回 ("delay")
        }
        变量 工具名 <类型 = 文本型>
        工具名 = MCP命令服务器.yyjson取文本 (步骤, "tool")
        如果 (工具名 == "")
        {
            工具名 = MCP命令服务器.yyjson取文本 (步骤, "name")
        }
        如果 (工具名 == "")
        {
            追加步骤结构失败记录 (步骤结果JSON列表, 步索引, "", "缺少 tool/name 字段")
            返回 ("fail")
        }
        变量 工具参数 <类型 = YYJSON只读对象类>
        工具参数 = MCP命令服务器.yyjson取对象成员 (步骤, "args")
        如果 (工具参数.是否为空 ())
        {
            工具参数 = MCP命令服务器.yyjson取对象成员 (步骤, "arguments")
        }
        如果 (工具参数.是否为空 ())
        {
            变量 空参数 <类型 = YYJSON只读对象类>
            空参数.创建自文本 ("{}")
            工具参数 = 空参数
        }
        变量 步结果 <类型 = 文本型>
        MCP命令服务器.MCP执行锁.解锁 ()
        步结果 = MCP命令服务器.执行浏览器命令 (命令ID + "_s" + 到文本 (步索引), 工具名, 工具参数)
        MCP命令服务器.MCP执行锁.加锁 ()
        变量 需等待 <类型 = 逻辑型>
        需等待 = MCP命令服务器.yyjson取逻辑 (步骤, "wait_async")
        如果 (需等待 == 假 && 寻找文本 (步结果, "task_", 0, 假) != -1)
        {
            需等待 = 真
        }
        如果 (需等待)
        {
            变量 异步ID <类型 = 文本型>
            异步ID = 从结果提取任务ID (步结果)
            如果 (异步ID != "")
            {
                变量 最大等待 <类型 = 整数>
                最大等待 = MCP命令服务器.yyjson取整数 (步骤, "max_ms")
                如果 (最大等待 <= 0)
                {
                    最大等待 = 15000
                }
                步结果 = 等待步骤异步完成 (异步ID, 最大等待, 命令ID, 工具名)
            }
        }
        变量 步解析 <类型 = YYJSON只读对象类>
        变量 步成功 <类型 = 逻辑型 值 = 假>
        如果 (步解析.创建自文本 (步结果))
        {
            步成功 = 步解析.取逻辑值 ("success")
        }
        变量 步记录 <类型 = YYJSON对象类>
        步记录.创建自文本 ("{}")
        步记录.加入整数成员 ("index", 步索引 + 1)
        步记录.加入文本成员 ("tool", 工具名)
        步记录.加入逻辑值成员 ("success", 步成功)
        步记录.加入文本成员 ("result", 步结果)
        步骤结果JSON列表.加入成员 (步记录.到可读文本 (YYJSON格式化选项.压缩))
        如果 (步成功)
        {
            返回 ("ok")
        }
        变量 步onError <类型 = 文本型>
        步onError = MCP命令服务器.yyjson取文本 (步骤, "on_error")
        如果 (步onError == "")
        {
            步onError = 全局onError
        }
        如果 (步onError == "stop")
        {
            返回 ("fail_stop")
        }
        返回 ("fail")
    }
    方法 步骤数组无效 <公开 静态 类型 = 逻辑型>
    参数 步骤数组 <类型 = YYJSON只读数组类>
    {
        返回 (步骤数组.是否为空对象 () || 步骤数组.取成员数 () == 0)
    }
    方法 解析步骤数组参数 <公开 静态 类型 = YYJSON只读数组类>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 空数组 <类型 = YYJSON只读数组类>
        变量 步骤数组 <类型 = YYJSON只读数组类>
        步骤数组 = 参数JSON.取路径数组 ("/steps")
        如果 (步骤数组无效 (步骤数组) == 假)
        {
            返回 (步骤数组)
        }
        步骤数组 = 参数JSON.取数组 ("steps")
        如果 (步骤数组无效 (步骤数组) == 假)
        {
            返回 (步骤数组)
        }
        变量 stepsJSON文本 <类型 = 文本型>
        stepsJSON文本 = MCP命令服务器.yyjson取JSON文本 (参数JSON, "steps")
        如果 (stepsJSON文本 != "" && 是否以 (删首空 (stepsJSON文本), "["))
        {
            变量 steps包装 <类型 = YYJSON只读对象类>
            如果 (steps包装.创建自文本 ("{\"steps\":" + stepsJSON文本 + "}"))
            {
                步骤数组 = steps包装.取路径数组 ("/steps")
                如果 (步骤数组无效 (步骤数组) == 假)
                {
                    返回 (步骤数组)
                }
                步骤数组 = steps包装.取数组 ("steps")
                如果 (步骤数组无效 (步骤数组) == 假)
                {
                    返回 (步骤数组)
                }
            }
        }
        返回 (空数组)
    }
    方法 处理_工作流运行 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        // 兜底: 上次工作流异常未重置或超时, 自动强制终止
        强制终止超时工作流 ()
        如果 (工作流运行中)
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "已有工作流正在运行, 请 workflow_stop 或等待超时(" + 到文本 (工作流最大运行毫秒 / 60000) + "分钟)后重试"))
        }
        如果 (MCP命令服务器.MCP正在关闭)
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "MCP 服务正在关闭, 无法运行工作流"))
        }
        变量 定义 <类型 = YYJSON只读对象类>
        变量 步骤数组 <类型 = YYJSON只读数组类>
        步骤数组 = 解析步骤数组参数 (参数JSON)
        变量 全局onError <类型 = 文本型>
        全局onError = MCP命令服务器.yyjson取文本 (参数JSON, "on_error")
        如果 (全局onError == "")
        {
            全局onError = "stop"
        }
        变量 工作流名 <类型 = 文本型>
        工作流名 = MCP命令服务器.yyjson取文本 (参数JSON, "name")
        如果 (工作流名 == "")
        {
            工作流名 = "inline"
        }
        如果 (步骤数组无效 (步骤数组))
        {
            变量 定义文本 <类型 = 文本型>
            定义文本 = 加载工作流定义 (参数JSON)
            如果 (定义文本 == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "需要 name/file、definition 或 steps 参数"))
            }
            定义文本 = 删首尾空 (定义文本)
            如果 (定义.创建自文本 (定义文本) == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "工作流 JSON 解析失败"))
            }
            步骤数组 = 从定义对象取步骤数组 (定义)
            变量 文件onError <类型 = 文本型>
            文件onError = MCP命令服务器.yyjson取文本 (定义, "on_error")
            如果 (文件onError != "")
            {
                全局onError = 文件onError
            }
            变量 文件名 <类型 = 文本型>
            文件名 = MCP命令服务器.yyjson取文本 (定义, "name")
            如果 (文件名 != "")
            {
                工作流名 = 文件名
            }
        }
        如果 (步骤数组无效 (步骤数组))
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "工作流缺少 steps 数组"))
        }
        工作流应停止 = 假
        工作流运行中 = 真
        当前工作流名 = 工作流名
        工作流开始时间 = 取启动时间 ()
        变量 总步数 <类型 = 整数>
        总步数 = (整数)步骤数组.取成员数 ()
        变量 成功数 <类型 = 整数 值 = 0>
        变量 失败数 <类型 = 整数 值 = 0>
        变量 跳过数 <类型 = 整数 值 = 0>
        变量 步骤结果JSON列表 <类型 = 文本数组类>
        计次循环 (总步数)
        {
            如果 (工作流应停止)
            {
                跳出循环
            }
            变量 步索引 <类型 = 整数>
            步索引 = 取循环索引 ()
            变量 步骤 <类型 = YYJSON只读对象类>
            步骤 = 步骤数组.取成员 (步索引)
            变量 单步结果 <类型 = 文本型>
            单步结果 = 执行工作流单步 (命令ID, 步骤, 步索引, 全局onError, 步骤结果JSON列表)
            如果 (单步结果 == "skip")
            {
                跳过数 = 跳过数 + 1
            }
            否则 (单步结果 == "delay" || 单步结果 == "ok")
            {
                成功数 = 成功数 + 1
            }
            否则 (单步结果 == "fail")
            {
                失败数 = 失败数 + 1
            }
            否则 (单步结果 == "fail_stop")
            {
                失败数 = 失败数 + 1
                跳出循环
            }
        }
        工作流运行中 = 假
        当前工作流名 = ""
        工作流开始时间 = 0
        变量 已停止 <类型 = 逻辑型>
        已停止 = 工作流应停止
        工作流应停止 = 假
        变量 汇总成功 <类型 = 逻辑型>
        // 成功条件: 无失败 且 (未停止 或 所有步骤已执行完毕)
        // 避免所有步骤成功但收到stop信号时错误标记为"失败"
        汇总成功 = 失败数 == 0 && (已停止 == 假 || 成功数 + 跳过数 + 失败数 == 总步数)
        变量 stepsJSON <类型 = 文本型>
        stepsJSON = 步骤JSON片段列表到数组文本 (步骤结果JSON列表)
        变量 汇总对象 <类型 = YYJSON对象类>
        汇总对象.创建自文本 ("{}")
        汇总对象.加入文本成员 ("workflow", 工作流名)
        汇总对象.加入逻辑值成员 ("success", 汇总成功)
        汇总对象.加入逻辑值成员 ("stopped", 已停止)
        汇总对象.加入整数成员 ("total_steps", 总步数)
        汇总对象.加入整数成员 ("success_count", 成功数)
        汇总对象.加入整数成员 ("failure_count", 失败数)
        汇总对象.加入整数成员 ("skipped_count", 跳过数)
        变量 汇总头JSON <类型 = 文本型>
        汇总头JSON = 汇总对象.到可读文本 (YYJSON格式化选项.压缩)
        变量 汇总片段 <类型 = 文本型>
        汇总片段 = 取文本左边 (汇总头JSON, 取文本长度 (汇总头JSON) - 1) + ",\"steps\":" + stepsJSON + "}"
        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 汇总片段, 汇总成功))
    }
    #
}
