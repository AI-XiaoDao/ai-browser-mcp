<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# ================================================================
# AI浏览器 MCP Server — 启动入口 + 服务窗口
# ================================================================

类 启动类 <公开 基础类 = 窗口程序类>
{
    变量 服务窗口 <公开 类型 = MCP服务窗口>

    方法 启动方法 <公开 类型 = 整数>
    {
        // 禁止多开: 已有窗口则静默退出
        @ HWND hwnd = FindWindowW(NULL, L"AI浏览器-MCP");
        @ if (hwnd) return 0;

        如果 (MCP命令服务器.VIP授权码 == "")
        {
            MCP命令服务器.VIP授权码 = "xsmzas1"
        }
        FBrowserVIP注册.VIP注册_置授权码 (MCP命令服务器.VIP授权码)
        变量 设置 <类型 = FBrowser_初始化配置>
        设置.无沙箱 = 真
        设置.缓存目录 = 取运行目录 () + "\\CacheData\\GlobalData"
        设置.本地化语言 = "zh-CN"
        设置.接收语言清单 = "zh-CN,zh,en"
        设置.启用系统消息循环 = 真
        设置.保留Session = 真
        设置.日志目录 = 取运行目录 () + "\\log.txt"
        设置.日志模式 = 日志级别.致命
        调试输出 (取执行文件名 ())
        // 设置.执行进程 = 取运行目录 () + 取执行文件名 ()
        设置.启用自动多例模式 = 真
        变量 初始化事件 <类型 = 类_FBrowser_事件智能指针>
        初始化事件.创建 (类_MCP_初始化事件)
        如果真 (FBrowser_初始化 (设置, 初始化事件) == 假)
        {
            调试输出 ("[AI浏览器] FBrowser 初始化失败")
            返回 (0)
        }


        服务窗口.创建主窗口 ()
        返回 (1)
    }

    方法 即将退出 <公开 @虚拟方法 = 可覆盖>
    {
        MCP服务窗口.执行关闭序列 ()
        父对象.即将退出 ()
    }
}

# ── FBrowser 应用级初始化事件 ──

类 类_MCP_初始化事件 <公开 基础类 = 类_FBrowser_应用事件>
{
    方法 记录应用监控事件 <类型 = 逻辑型>
    参数 事件类型 <类型 = 文本型>
    参数 数据JSON <类型 = 文本型 @默认值 = "">
    {
        如果 (MCP命令服务器.是否监控应用事件)
        {
            MCP命令服务器.记录应用事件 (事件类型, 数据JSON)
        }
        返回 (MCP命令服务器.是否监控应用事件)
    }

    方法 浏览器_初始化完毕 <公开 @虚拟方法 = 可覆盖>
    {
        MCP命令服务器.启动MCP服务器 ()
        变量 端口文本 <类型 = 文本型>
        端口文本 = 到文本 (MCP命令服务器.服务器端口)
        变量 绑定地址 <类型 = 文本型>
        绑定地址 = MCP命令服务器.服务器绑定地址
        写环境变量 ("AI_BROWSER_MCP_URL", "ws://" + 绑定地址 + ":" + 端口文本)
        写环境变量 ("AI_BROWSER_MCP_PORT", 端口文本)
        写环境变量 ("AI_BROWSER_MCP_HEALTH", "http://" + 绑定地址 + ":" + 端口文本 + "/health")
        写环境变量 ("AI_BROWSER_MCP_HTTP_POST", "http://" + 绑定地址 + ":" + 端口文本 + "/mcp")
        调试输出 ("[AI浏览器] MCP 服务已就绪 — " + MCP命令服务器.取MCP_WS地址 ())
        浏览器容器.MCP服务已就绪 = 真
        // 触发首个浏览器创建: 通过时钟线程在UI线程上创建, 导航到欢迎页
        MCP命令服务器.待创建URL = 浏览器容器.取欢迎页地址 ()
        如果 (MCPStdio桥.是否为Stdio模式 ())
        {
            MCPStdio桥.启动并行Stdio服务 ()
        }
    }

    方法 执行关闭完毕 <公开 @虚拟方法 = 可覆盖>
    参数 是否结束程序 <类型 = 逻辑型类>
    {
        调试输出 ("[AI浏览器] FBrowser 资源已释放, 结束进程")
        是否结束程序.值 = 真
    }

    方法 渲染_即将捕获异常 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 V8环境 <类型 = 类_FBrowser_V8环境>
    参数 V8异常 <类型 = 类_FBrowser_V8异常>
    参数 V8堆栈踪迹 <类型 = 类_FBrowser_V8堆栈踪迹>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        如果 (V8异常.是否为空 () == 假)
        {
            数据.加入文本成员 ("message", V8异常.取消息 ())
        }
        记录应用监控事件 ("app_v8_exception", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_焦点节点改变 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 DOM节点 <类型 = 类_FBrowser_DOM节点>
    {
        如果 (MCP命令服务器.是否监控应用事件 == 假)
        {
            返回
        }
        变量 当前毫秒 <类型 = 长整数>
        变量 上次毫秒 <类型 = 长整数 值 = 0>
        当前毫秒 = 取启动时间 ()
        变量 prevKey <类型 = 文本型>
        prevKey = "focus_ts_" + 到文本 (浏览器.取ID ())
        如果 (MCP命令服务器.应用事件节流字典.是否为空对象 () || MCP命令服务器.应用事件节流字典.是否为空 ())
        {
            MCP命令服务器.应用事件节流字典.创建 ()
        }
        上次毫秒 = MCP命令服务器.应用事件节流字典.取整数值 (prevKey)
        如果 (当前毫秒 - 上次毫秒 < 300)
        {
            返回
        }
        MCP命令服务器.应用事件节流字典.置整数值 (prevKey, (整数)当前毫秒)
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        如果 (DOM节点.是否为空 () == 假)
        {
            数据.加入文本成员 ("tag", DOM节点.取标签名 ())
        }
        记录应用监控事件 ("app_dom_focus_changed", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_即将释放V8环境 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 V8环境 <类型 = 类_FBrowser_V8环境>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        记录应用监控事件 ("app_v8_released", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_载入错误 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 错误代码 <类型 = 整数>
    参数 错误文本 <类型 = 文本型>
    参数 失败地址 <类型 = 文本型>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入整数成员 ("error_code", 错误代码)
        数据.加入文本成员 ("error_text", 错误文本)
        数据.加入文本成员 ("failed_url", 失败地址)
        记录应用监控事件 ("app_render_load_error", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_浏览器创建 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 额外信息 <类型 = 类_FBrowser_字典值>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        记录应用监控事件 ("app_render_browser_created", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_即将销毁浏览器 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        记录应用监控事件 ("app_render_browser_destroyed", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }
}

# ── 服务窗口 (最小, 仅维护时钟 + 退出) ──

类 MCP服务窗口 <基础类 = 窗口 标题 = "AI浏览器-MCP" @视窗.布局 = "client_size = \"280, 60\"">
{
    变量 状态标签 <类型 = 标签 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"8, 8, 264, 20\"">
    变量 维护时钟 <类型 = 时钟 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"0, 0, 1, 1\"" 时钟周期 = 500>
    变量 正在退出 <静态 类型 = 逻辑型 值 = 假>

    方法 执行关闭序列 <公开 静态>
    {
        如果 (正在退出)
        {
            返回
        }

        正在退出 = 真
        MCP命令服务器.MCP正在关闭 = 真
        MCP命令服务器.是否启用 = 假
        MCPStdio桥.停止Stdio服务 ()
        MCP命令服务器.注销CDP观察者 ()
        MCP命令服务器.关闭全部事件监控 ()
        MCP命令服务器.关闭缓存数据库 ()
        MCP命令服务器.关闭MCP服务器 ()
        FBrowser_关闭 (真)
        // 强制终止残留子进程
        @ system("taskkill /F /IM FBroSubprocess.exe /T 2>nul");
        @ system("taskkill /F /IM AI-Fbowser-Mcp.exe /FI \"PID ne 99999\" 2>nul");
        结束 ()
    }

    方法 MCP服务窗口_创建完毕 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = MCP服务窗口>
    参数 标记值 <类型 = 整数>
    {
        // 窗口置顶
        变量 hwnd <类型 = 变整数>
        hwnd = 来源对象.取窗口句柄 ()
        @ SetWindowPos((HWND)(INT_P)@<hwnd>, HWND_TOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE);
        状态标签.标题 = "AI浏览器 MCP Server v" + MCP_常量.MCP_版本号 + " — " + MCP命令服务器.服务器绑定地址 + ":" + 到文本 (MCP命令服务器.服务器端口)
        MCP命令服务器.加载MCP配置 ()
        返回 (0)
    }

    方法 时钟_周期事件 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 时钟>
    参数 标记值 <类型 = 整数>
    {
        // 待创建浏览器 + 远程关闭 (通过此UI线程机制)
        如果 (MCP命令服务器.待创建URL != "")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.待创建URL
            MCP命令服务器.待创建URL = ""
            如果 (是否以 (url, "__SHUTDOWN__"))
            {
                变量 shutSec <类型 = 整数>
                shutSec = 文本到整数 (取文本右边 (url, 取文本长度 (url) - 取文本长度 ("__SHUTDOWN__")))
                如果 (shutSec > 0)
                {
                    延时 (shutSec * 1000)
                }
                执行关闭序列 ()
                返回 (0)
            }
            变量 窗口信息 <类型 = FBrowser_窗口信息>
            变量 浏览器配置 <类型 = FBrowser_浏览器配置>
            窗口信息.父窗口句柄 = 0
            窗口信息.横坐标 = 0
            窗口信息.纵坐标 = 0
            窗口信息.宽度 = 1000
            窗口信息.高度 = 800
            变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
            浏览器事件.创建 (类_MCP_浏览器事件)
            FBrowser_创建浏览器 (url, 窗口信息, 浏览器配置, , , 浏览器事件, , )
            MCP命令服务器.待创建完成 = 真
        }
        // 定期维护 (每120次=60s执行一次)
        变量 维护计数 <静态 类型 = 整数 值 = 0>
        维护计数 = 维护计数 + 1
        // 每10次(5秒)更新状态标签, 显示实时浏览器数和URL
        如果 (维护计数 % 10 == 0)
        {
            变量 状态文本 <类型 = 文本型>
            状态文本 = "AI浏览器 MCP v" + MCP_常量.MCP_版本号 + " | " + MCP命令服务器.服务器绑定地址 + ":" + 到文本 (MCP命令服务器.服务器端口)
            状态文本 = 状态文本 + " | 浏览器:" + 到文本 (FBrowser_浏览器_取数量 ())
            如果 (浏览器容器.最新地址 != "")
            {
                变量 短URL <类型 = 文本型>
                短URL = 浏览器容器.最新地址
                如果 (取文本长度 (短URL) > 50)
                {
                    短URL = 取文本左边 (短URL, 47) + "..."
                }
                状态文本 = 状态文本 + " | " + 短URL
            }
            状态标签.标题 = 状态文本
        }
        如果 (维护计数 >= 120)
        {
            维护计数 = 0
            MCP命令服务器.执行定期维护 ()
        }
        返回 (0)
    }

    方法 MCP服务窗口_将被销毁 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = MCP服务窗口>
    参数 标记值 <类型 = 整数>
    {
        执行关闭序列 ()
        返回 (0)
    }
}
