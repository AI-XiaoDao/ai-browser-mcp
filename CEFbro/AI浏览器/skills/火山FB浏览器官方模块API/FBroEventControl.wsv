包 FBrowser.事件控制 <注释 = "浏览器各事件合集">

类 类_FBrowser_应用事件 <公开 注释 = "FBroHsInitEvent,CVolObject,初始化时候设置的事件" @视窗.后缀文本 = "public FBroHsInitEvent" @禁止创建对象 = 真>
{
    方法 类_初始化
    {
        @ type_ = InitEventType;
        @ _FBRO_SHOW_CLASS_TYPE(_CT (@sn<current_source_class>),0);
    }

    方法 类_清理
    {
        @ _FBRO_SHOW_CLASS_TYPE(_CT (@sn<current_source_class>),1);
    }

