    方法 修改数据 <公开 类型 = 整数 @虚拟方法 = 可覆盖>
    参数 标识ID <类型 = 长整数>
    参数 输入指针 <类型 = 变整数 注释 = "传入数据指针">
    参数 输入大小 <类型 = 整数 注释 = "传入数据大小">
    参数 输入读取大小 <类型 = 整数类 注释 = "传入数据回写大小，用作告诉来源已经接纳了多少数据">
    参数 输出指针 <类型 = 变整数 注释 = "写回数据输出指针，写回后浏览器接收显示相应的数据">
    参数 输出大小 <类型 = 整数 注释 = "写回数据缓存能容纳数据的最大值，输出数据都不能大于此值，否则浏览器崩溃，如大于必须做分包处理">
    参数 输出写入大小 <类型 = 整数类 注释 = "写回数据会写大小，用作告诉浏览器我写入了多少数据">
    {
        // if (data_in_size > data_out_size) {
        // data_in_read = data_out_size;
        // data_out_written = data_out_size;
        // memcpy_s(data_out, data_out_size, data_in, data_out_size);
        // return RESPONSE_FILTER_NEED_MORE_DATA;
        // }
        // else {
        // data_in_read = data_in_size;
        // data_out_written = data_in_size;
        // memcpy_s(data_out, data_in_size, data_in, data_in_size);
        // return RESPONSE_FILTER_DONE;
        // }
        如果 (输入大小 > 输出大小)
        {

            输入读取大小.值 = 输出大小
            输出写入大小.值 = 输出大小
            内存复制 (输出指针, 输入指针, 输出大小)
            返回 (资源过滤器.需要更多数据)
        }
        否则
        {
            输入读取大小.值 = 输入大小
            输出写入大小.值 = 输入大小
            内存复制 (输出指针, 输入指针, 输入大小)
            返回 (资源过滤器.完成)

        }

        返回 (资源过滤器.错误)

    }

    #
}

