<火山程序 类型 = "通常" 版本 = 1 />

包 DOM.回调

类 类_FBrowser_自定义DOM回调 <公开 基础类 = 类_FBrowser_DOM回调 注释 = "特别注意：这个只有在渲染进程中有效">
{
    变量 地址 <公开 类型 = 文本型>

    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 DOM文档 <类型 = 类_FBrowser_DOM文档 注释 = "列表索引0为类指针，1为值类型，2为类型对应值">
    {
        调试输出 (取当前语句位置 (), DOM文档.取类型 (), DOM文档.取标题 (), DOM文档.取基本地址 (), 地址)

        变量 头节点 <类型 = 类_FBrowser_DOM节点>
        变量 主体节点 <类型 = 类_FBrowser_DOM节点>
        变量 根节点 <类型 = 类_FBrowser_DOM节点>
        变量 焦点节点 <类型 = 类_FBrowser_DOM节点>

        头节点 = DOM文档.取头节点 ()
        主体节点 = DOM文档.取主体节点 ()
        根节点 = DOM文档.取根节点 ()
        焦点节点 = DOM文档.取焦点节点 ()

        节点枚举 (主体节点)

        调试输出 (头节点.取类型 (), 头节点.取名字 (), 头节点.是否有子节点 ())
        调试输出 (主体节点.取类型 (), 主体节点.取名字 (), 主体节点.是否有子节点 ())
        调试输出 (根节点.取类型 (), 根节点.取名字 (), 根节点.是否有子节点 ())
        调试输出 (焦点节点.取类型 (), 焦点节点.取名字 (), 焦点节点.是否有子节点 ())


    }

    方法 节点枚举
    参数 主体节点 <类型 = 类_FBrowser_DOM节点>
    {

        变量 item <类型 = 类_FBrowser_DOM节点>
        item = 主体节点.取第一个子节点 ()
        如果 (item.是否为空 ())
        {
            返回
        }

        变量 end <类型 = 类_FBrowser_DOM节点>
        end = 主体节点.取最后一个子节点 ()
        如果 (end.是否为空 ())
        {
            返回

        }

        判断循环 (item.是否为空 () == 假)
        {

            变量 属性清单 <类型 = FBrowser_双文本数组>
            属性清单 = item.取全部属性值 ()
            计次循环 (属性清单.取个数 ())
            {
                变量 属性 <类型 = FBrowser_双文本>
                属性 = 属性清单.取当前位置数据 ()
                调试输出 (属性.name, 属性.value)
                属性清单.到下一个 ()

            }

            如果 (item.是否有子节点 ())
            {
                节点枚举 (item)

            }
            否则
            {

                如果真 (item.取属性值 ("id") == "kw")
                {
                    调试输出 (item.取属性值 ("value"), item.取内部文本 ())
                    item.置属性值 ("value", "这是文本")

                }
            }

            如果真 (end.是否相同 (item))
            {
                跳出循环

            }

            item = item.取下一个节点 ()

        }


    }
}
