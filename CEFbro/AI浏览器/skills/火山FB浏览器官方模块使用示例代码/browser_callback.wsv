类 类_FBrowser_打印为PDF回调测试 <公开 基础类 = 类_FBrowser_打印为PDF回调 折叠>
{
    方法 即将完成打印 <公开 @虚拟方法 = 可覆盖>
    参数 路径 <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    {
        调试输出 ("PDF即将完成打印", 路径, 是否成功)
        @ if(@<是否成功>){ MessageBoxA(NULL,"PDF打印成功","提示信息",NULL); return;}
        @ MessageBoxA(NULL,"PDF打印失败","提示信息",NULL);
    }

    #
}

类 类_FBrowser_JS回调测试 <公开 基础类 = 类_FBrowser_JS回调>
{
    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 返回结果 <类型 = 类_FBrowser_列表值>
    {
        调试输出 ("JS回调", 返回结果.是否有效 (), 返回结果.是否只读 (), 返回结果.取整数值 (1))
        变量 类型 <类型 = 整数>
        类型 = 返回结果.取整数值 (1)
        如果 (类型 == JS返回值类型.文本值)
        {
            调试输出 ("文本型", 返回结果.取文本值 (2))
        }
        否则 (类型 == JS返回值类型.逻辑值)
        {
            调试输出 ("逻辑型", 返回结果.取逻辑值 (2))
        }
        否则 (类型 == JS返回值类型.整数值)
        {
            调试输出 ("整数型", 返回结果.取整数值 (2))
        }
        否则 (类型 == JS返回值类型.双精度小数值)
        {
            调试输出 ("双精度小数型", 返回结果.取双精度小数值 (2))
        }
        否则 (类型 == JS返回值类型.无效)
        {
            调试输出 ("错误信息", 返回结果.取文本值 (3))

        }


    }

    #
}

