类 类_FBrowser_Cookie回调测试 <公开 基础类 = 类_FBrowser_Cookie回调>
{
    方法 开始 <公开 @虚拟方法 = 可覆盖>
    {
        调试输出 (取当前语句位置 ())

    }

    方法 结束 <公开 @虚拟方法 = 可覆盖>
    {
        调试输出 (取当前语句位置 ())
    }

    #

    方法 访问 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 Cookie数据 <类型 = FBrowser_Cookie数据>
    参数 当前项 <类型 = 整数>
    参数 总数 <类型 = 整数>
    参数 删除当前cookie <类型 = 逻辑型类 注释 = "设置为真，则删除当前项">
    {
        调试输出 (总数, 当前项, Cookie数据.名, Cookie数据.值, Cookie数据.域, Cookie数据.路径, Cookie数据.是否只有http, Cookie数据.是否有过期时间)
        调试输出 ("过期时间:" + 到文本 (Cookie数据.过期时间.年) + "/" + 到文本 (Cookie数据.过期时间.月) + "/" + 到文本 (Cookie数据.过期时间.日) + " " + 到文本 (Cookie数据.过期时间.时) + ":" + 到文本 (Cookie数据.过期时间.分) + ":" + 到文本 (Cookie数据.过期时间.秒))
        调试输出 ("访问时间:" + 到文本 (Cookie数据.访问时间.年) + "/" + 到文本 (Cookie数据.访问时间.月) + "/" + 到文本 (Cookie数据.访问时间.日) + " " + 到文本 (Cookie数据.访问时间.时) + ":" + 到文本 (Cookie数据.访问时间.分) + ":" + 到文本 (Cookie数据.访问时间.秒))

        返回 (真)



    }
}

类 类_FBrowser_JS返回值回调 <公开 基础类 = 类_FBrowser_JS回调>
{
    变量 同步类 <公开 类型 = 类_FBrowser_同步辅助类>

    方法 回调 <公开 @虚拟方法 = 可覆盖>
    参数 返回结果 <类型 = 类_FBrowser_列表值>
    {
        调试输出 ("JS回调", 同步类.取框架 ().取地址 ())
        变量 类型 <类型 = 整数>
        类型 = 返回结果.取整数值 (1)
        如果 (类型 == JS返回值类型.文本值)
        {
            同步类.置文本型 (返回结果.取文本值 (2))
        }
        否则 (类型 == JS返回值类型.逻辑值)
        {
            同步类.置逻辑型 (返回结果.取逻辑值 (2))
        }
        否则 (类型 == JS返回值类型.整数值)
        {
            同步类.置整数 (返回结果.取整数值 (2))
        }
        否则 (类型 == JS返回值类型.双精度小数值)
        {
            同步类.置双精度小数型 (返回结果.取双精度小数值 (2))
        }
        否则 (类型 == JS返回值类型.无效)
        {
            同步类.置文本型 (返回结果.取文本值 (3))

        }
        同步类.停止等待 ()


    }

    #
}

