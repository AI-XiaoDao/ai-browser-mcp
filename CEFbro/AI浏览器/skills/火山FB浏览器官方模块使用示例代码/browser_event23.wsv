    }

    方法 离屏渲染_IME范围改变 <公开 注释 = "英文名：OnImeCompositionRangeChanged  说明：启用离屏渲染功能后才会调用，IME组成范围改变" @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 选择范围 <类型 = FBrowser_范围 注释 = "selected_range">
    参数 字符范围 <类型 = FBrowser_矩形位置数组 注释 = "只读 character_bounds">
    {

    }

    方法 离屏渲染_文本选择改变 <公开 注释 = "英文名：OnTextSelectionChanged 说明：启用离屏渲染功能后才会调用" @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 选择文本 <类型 = 文本型>
    参数 选择范围 <类型 = FBrowser_范围>
    {

    }

    方法 离屏渲染_虚拟键盘请求 <公开 注释 = "英文名：OnVirtualKeyboardRequested 说明：启用离屏渲染功能后才会调用" @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器 注释 = "browser">
    参数 输入类型 <类型 = 整数 注释 = "input_mode 参考：文本输入类型.XXXXX">
    {

    }
}
