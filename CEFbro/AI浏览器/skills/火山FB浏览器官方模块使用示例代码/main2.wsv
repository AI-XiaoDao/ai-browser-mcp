类 启动类 <公开 基础类 = 窗口程序类>
{
    变量 主窗口对象 <公开 类型 = 我的主窗口 标题 = "我的主窗口">
    变量 图片显示窗口 <公开 类型 = 图片窗口>
    变量 ""

    方法 启动方法 <公开 类型 = 整数>
    {
        // FBrowser初始化控制.启用自带调试提示 (真)
        FBrowserVIP注册.VIP注册_置授权码 ("14D66770D83CBD9722B7FE8CA9082659E7EFD3069AC3154F51637D7F938A")


        变量 设置 <类型 = FBrowser_初始化配置>
        设置.缓存目录 = 取运行目录 () + "\\CacheData\\GlobalData"

        设置.本地化语言 = "zh-CN"
        设置.接收语言清单 = "zh-CN,zh,en"
        设置.启用系统消息循环 = 真
        设置.启用离屏渲染 = 假

        设置.保留Session = 真
        设置.日志目录 = 取运行目录 () + "\\log.txt"
        设置.日志模式 = 日志级别.致命

        // 多进程模式,以自身作为执行进程,也就是相关渲染、GPU的进程,也可不设置将会以内置默认exe作为执行进程
        // 设置.执行进程 = 取运行目录 () + 取执行文件名 ()


        FBrowser_初始化_设置V8环境默认堆栈大小 (4, 2048)

        变量 初始化事件 <类型 = 类_FBrowser_事件智能指针>
        初始化事件.创建 (类_FBrowser_自定义初始化事件)
        // 智能指针类 = FBrowser创建事件智能指针 (类_FBrowser_自定义初始化事件)
        如果真 (FBrowser_初始化 (设置, 初始化事件) == 假)
        {
            返回 (0)

        }
        // FBrowser_请求环境_取全局 ().VIP_高级_安装CRX插件包 ("E:\\cef\\135.0.7049.96\\E-Object\\Etest\\extensions\\full-chrome-plugin-demo.crx")
        FBrowser_请求环境_取全局 ().VIP_高级_载入插件路径 ("E:\\cef\\135.0.7049.96\\E-Object\\Etest\\extensions\\full-chrome-plugin-demo")
        主窗口对象.创建主窗口 ()
        返回 (1)
    }
}

