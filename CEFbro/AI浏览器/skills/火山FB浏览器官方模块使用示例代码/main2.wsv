类 我的主窗口 <公开 基础类 = 窗口 @视窗.布局 = "client_size = \"1131, 769\"" 最大化按钮 = 真 最小化按钮 = 真 标题 = "测试窗口" 可否移动 = 真 随意移动 = 真 窗口边框 = 普通可调边框>
{
    变量 按钮1 <类型 = 按钮 折叠2 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"21, 30, 80, 32\"" 标题 = "按钮1">
    变量 时钟1 <类型 = 时钟 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"253, 256, 26, 26\"">
    变量 窗口菜单 <类型 = 菜单>
    变量 ""
    变量 ""
    变量 c_count <类型 = 整数>

    方法 我的主窗口_创建完毕 <接收事件 类型 = 整数 注释 = "当本组件及其中所有子组件均被创建完毕后发送此事件.">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        变量 窗口信息 <类型 = FBrowser_窗口信息>
        变量 浏览器配置 <类型 = FBrowser_浏览器配置>
        变量 请求环境配置 <类型 = FBrowser_请求环境配置>
        变量 请求环境 <类型 = 类_FBrowser_请求环境>
        窗口信息.父窗口句柄 = 取窗口句柄 ()
        窗口信息.横坐标 = 0
        窗口信息.纵坐标 = 0
        窗口信息.宽度 = 宽度
        窗口信息.高度 = 高度
        // 浏览器配置.启用图片加载 = 状态.禁用
        // 请求环境配置.缓存目录 = 取运行目录 () + "\\CacheData\\TestData"
        // 调试输出 (请求环境配置.缓存目录)
        // 请求环境.创建 (请求环境配置)
        变量 额外信息 <类型 = 类_FBrowser_字典值>
        额外信息.创建 ()
        额外信息.置整数值 ("num", 1)

        变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
        浏览器事件 = FBrowser创建事件智能指针 (类_FBrowser_自定义浏览器事件)
        FBrowser_创建浏览器 ("https://www.baidu.com", 窗口信息, 浏览器配置, 请求环境, 额外信息, 浏览器事件, , "主浏览器")




        // 窗口信息.父窗口句柄 = 0
        // 创建浏览器 ("https://www.163.com", 窗口信息, 浏览器配置, 请求环境, 0, 浏览器事件)

        置实例菜单 (窗口菜单)

        返回 (0)
    }

    方法 我的主窗口_位置被改变 <接收事件 类型 = 整数 注释 = "当本组件的位置被改变后发送此事件">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        我的主窗口_尺寸被改变 (来源对象, 标记值)
        返回 (0)
    }

    方法 我的主窗口_尺寸被改变 <接收事件 类型 = 整数 注释 = "当本组件的尺寸被改变后发送此事件">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        变量 浏览器 <类型 = 类_FBrowser_浏览器>
        如果 (浏览器容器.浏览器数组.取成员数 () > 0)
        {
            浏览器 = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 0, 类_FBrowser_浏览器)
            浏览器.移动窗口 (0, 0, 取用户区宽度 (), 取用户区高度 (), 假)

        }

        返回 (0)
    }

    方法 我的主窗口_接收到命令 <接收事件 类型 = 整数 注释 = "当本窗口上的菜单项(包括弹出子菜单)/工具条按钮被单击或者对应快捷键被按下时,发送此事件." 返回值注释 = "所通知的对应命令被处理返回1,否则返回0.">
    参数 来源对象 <类型 = 我的主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 命令代码 <类型 = 整数 注释 = "提供所对应命令的ID值,对于菜单项或其快捷键来说,就是对应菜单项设计时提供的引用常量ID值," 注释 = "对于工具条来说,就是对应按钮设计时提供的引用常量ID值.">
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        变量 frame <类型 = 类_FBrowser_框架>
        如果 (对象数组类.取成员数 (浏览器容器.浏览器数组) > 0)
        {
            browser = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 0, 类_FBrowser_浏览器)
            frame = browser.取主框架 ()

        }

        如果 (命令代码 == 菜单.同步创建浏览器)
        {
            变量 任务回调 <类型 = 类_FBrowser_事件智能指针>
            任务回调.创建 (类_FBrowser_任务回调测试)
            FBrowser_任务运行器_投递任务 (线程ID.UI, 任务回调)
        }
        否则 (命令代码 == 菜单.创建后台浏览器)
        {
            变量 额外数据 <类型 = 类_FBrowser_字典值>
            额外数据.创建 ()  // 用于传递给事件区分当前浏览器是后台浏览器,在事件“浏览器_创建完毕”获取
            额外数据.置逻辑值 ("backgroud", 真)
            变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
            浏览器事件.创建 (类_FBrowser_自定义浏览器事件)

            FBrowser_创建后台浏览器 ("https://www.baidu.com", , , 额外数据, 浏览器事件, )

        }
        否则 (命令代码 == 菜单.打开后台浏览器开发者)
        {
            如果真 (浏览器容器.后台浏览器.是否为空 () == 假)
            {
                变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
                浏览器事件.创建 (类_FBrowser_自定义浏览器事件)

                浏览器容器.后台浏览器.打开开发者工具 ("后台开发者工具", 0, 0, 0, 1024, 800, , , 浏览器事件, )

            }

        }
        否则 (命令代码 == 菜单.当前窗口创建)
        {
            变量 窗口信息 <类型 = FBrowser_窗口信息>
            变量 i <类型 = 整数 值 = 0>
            变量 count <类型 = 整数 值 = 0>

            count = 对象数组类.取成员数 (浏览器容器.浏览器数组)
            计次循环 (count)
            {
                变量 tempbrowser <类型 = 类_FBrowser_浏览器>
                tempbrowser = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, count - i - 1, 类_FBrowser_浏览器)
                tempbrowser.关闭浏览器 (假)
                对象数组类.删除成员 (浏览器容器.浏览器数组, count - i - 1)
                i = i + 1

