            值 = "<html>\r\n<head>\r\n <meta charset=\"UTF-8\">\r\n <title>Test Cef</title>\r\n</head>\r\n<body bgcolor= \"white\">\r\n<h2>你好FBrowser！！！</h2>\r\n<a style=\'color:#00ff00\'>这是一个直接将网页数据载入的例子！</a>\r\n<div style=\'color:red\'>这里是个div</div>\r\n<a href=\'https://www.baidu.com\'>打开百度网页</a>\r\n</body>\r\n<script>alert(\'你好FBrowser\')</script></html>">
