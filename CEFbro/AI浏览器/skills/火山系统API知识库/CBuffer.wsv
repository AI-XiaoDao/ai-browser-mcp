    参数 数据 <类型 = 整数>
    {
        @ return pdata()->Write((void*)&@<数据>,4);
    }

    方法 添加长整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 数据 <类型 = 长整数>
    {
        @ return pdata()->Write((void*)&@<数据>,8);
    }

    方法 添加重复字节值 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 要添加的数量 <类型 = 整数>
    参数 是否用指定值填充 <类型 = 逻辑型 @默认值 = 真>
    参数 要设置的值 <类型 = 整数 注释 = "取值范围 0 - 255" @默认值 = 0>
    {
        @ @sn<this>.pdata()->AppendEmpty((size_t)@<要添加的数量>,@<要设置的值>,@<是否用指定值填充>)
    }

    方法 添加字节集 <公开 类型 = 逻辑型 注释 = "添加 字节集数据 到本类内容的 尾部" 折叠>
    参数 数据 <类型 = 字节集类>
    {
        返回 (添加指针数据 (取字节集指针 (数据), 取字节集长度 (数据)))
    }

    # //删===

    方法 删除 <公开 折叠 @嵌入式方法 = "">
    参数 起始位置 <类型 = 整数>
    参数 删除数量 <类型 = 整数>
    {
        @ @sn<this>.pdata()->Delete((size_t)@<起始位置>,(size_t)@<删除数量>)
    }

    方法 清空 <公开 注释 = "只会清空数据，不会改变内存占用大小" @嵌入式方法 = "">
    {
        @ @sn<this>.pdata()->Clear()
    }

    方法 回收内存 <公开 注释 = "会清空数据，并且回收内存" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata()->Reduce()
    }

    # //改===

    方法 写指针数据 <公开 类型 = 逻辑型 注释 = "把用户提供的内存指针中的数据写到 字节集加强类中的指定位置" 折叠 @嵌入式方法 = "">
    参数 位置 <类型 = 整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ @sn<this>.pdata()->WritePos((size_t)@<位置>,(void*)@<数据指针>,@<数据大小>)
    }

    方法 写字节集 <公开 类型 = 逻辑型 折叠>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 字节集类>
    {
        返回 (写指针数据 (位置, 取字节集指针 (数据), 取字节集长度 (数据)))
    }

    方法 写文本 <公开 类型 = 逻辑型 折叠>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 文本型>
    {
        变量 字节集数据 <类型 = 字节集类>
        字节集数据 = 文本到字节集 (数据)
        返回 (写字节集 (位置, 字节集数据))
    }

    方法 写字节 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,1);
    }

    方法 写短整数 <公开 类型 = 逻辑型 注释 = "有符号 短整数基本数据类型,有效值范围从-32768到32767,占用2个字节空间." 注释 = "无符号 有效值范围从0到65535,占用2个字节空间." @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 短整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,2);
    }

    方法 写无符号短整数 <公开>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,2);
    }

    方法 写字符 <公开 类型 = 逻辑型 注释 = "有符号 短整数基本数据类型,有效值范围从-32768到32767,占用2个字节空间." 注释 = "无符号 有效值范围从0到65535,占用2个字节空间." @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 字符>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,2);

    }

    方法 写整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,4);

    }

    方法 写无符号整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 长整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,4);
    }

    方法 写长整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 长整数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,8);
    }

    方法 写小数 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据 <类型 = 小数>
    {
        @ return pdata()->WritePos((size_t)@<位置>,(void*)&@<数据>,8);

    }

    方法 写数值数组 <公开 注释 = "只能写入基础的 a[] = {1,2,3} 这种数组" 折叠 @嵌入式方法 = "">
    参数 位置 <类型 = 整数>
    参数 数据 <@匹配类型 = 通用基本型数组>
    {
        @ @sn<this>.pdata()->WritePos((size_t)@<位置>,_VOL_GET_ARY_VAR_ADR_AND_SIZE (@<数据>))
    }

    # //查===

    方法 读指针 <公开 类型 = 逻辑型 注释 = "从指定位置 读取一些数据 到提供的内存指针中" @嵌入式方法 = "">
    参数 位置 <类型 = 整数>
    参数 内存指针 <类型 = 变整数>
    参数 内存大小 <类型 = 变整数>
    {
        @ @sn<this>.pdata()->Read((size_t)@<位置>,(void*)@<内存指针>,@<内存大小>)
    }

    方法 读字节 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 是否无符号 <类型 = 逻辑型 @默认值 = 假>
    {
        @ char v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,1);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  if(@<是否无符号> == false)
        @     return v;
        @ return (v&0xFF);


    }

    方法 读短整数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 是否无符号 <类型 = 逻辑型 @默认值 = 假>
    {
        @ short v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,2);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  if(@<是否无符号> == false)
        @     return v;
        @ return (v&0xFFFF);
    }

    方法 读字符 <公开 类型 = 字符 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    {
        @ unsigned short v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,2);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  return v;
    }

    方法 读无符号整数 <公开 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 是否无符号 <类型 = 逻辑型 @默认值 = 假>
    {
        @ int v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,4);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  if(@<是否无符号> == false)
        @     return v;
        @ return (v&0xFFFFFFFF);


    }

    方法 读整数 <公开 类型 = 整数 注释 = "有符号" @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    {
        @ int v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,4);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  return v;


    }

    方法 读长整数 <公开 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    {
        @ __int64 v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,8);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
        @  return v;
    }

    方法 读小数 <公开 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    {
        @ double v = 0;
        @ bool bOk = pdata()->Read((size_t)@<位置>,(void*)&v,8);
        @ if(bOk == false)
        @ {
        调试输出 ("错误 ", 取当前语句位置 ())
        @  return 0;
        @  }
