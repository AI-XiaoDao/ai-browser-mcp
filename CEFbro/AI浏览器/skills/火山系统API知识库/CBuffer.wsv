    方法 读字节集 <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 数据长度 <类型 = 整数>
    {
        变量 数据 <类型 = 字节集类>
        数据.分配字节集 (数据长度, 真)
        如果 (读指针 (位置, 取字节集指针 (数据), 取字节集长度 (数据)) == 假)
        {
            调试输出 ("错误 ", 取当前语句位置 ())
        }
        返回 (数据)
    }

    方法 读文本 <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 位置 <类型 = 整数>
    参数 文本长度 <类型 = 整数>
    {
        返回 (字节集到文本 (读字节集 (位置, 文本长度 * 2)))
    }

    #
}

类 读字符缓冲区类 <公开>
{
    变量 成员_缓冲区 <类型 = 缓冲区类>
    变量 成员_当前读取位置 <类型 = 整数 值 = 0>

    方法 从文本载入 <公开 类型 = 逻辑型>
    参数 数据 <类型 = 文本型>
    {
        变量 临时数据 <类型 = 字节集类>
        临时数据 = 文本到字节集 (数据)
        返回 (成员_缓冲区.从字节集载入 (临时数据))

    }

    方法 是否末尾 <公开 类型 = 逻辑型>
    {
        如果 (成员_当前读取位置 >= 成员_缓冲区.取数据大小 () - 1)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 读字符 <公开 类型 = 字符>
    {
        变量 返回值 <类型 = 字符>
        返回值 = 成员_缓冲区.读字符 (成员_当前读取位置)
        成员_当前读取位置 = 成员_当前读取位置 + 2
        返回 (返回值)

    }

    #
}

类 写字符缓冲区类 <公开>
{
    变量 成员_缓冲区 <类型 = 缓冲区类>
    变量 成员_当前写入位置 <类型 = 整数 值 = 0>

    方法 写字符 <公开 类型 = 逻辑型>
    参数 一个字符 <类型 = 字符>
    {
        变量 返回值 <类型 = 逻辑型>
        返回值 = 成员_缓冲区.写字符 (成员_当前写入位置, 一个字符)
        如果 (返回值)
        {
            // 一个字符2个字节
            成员_当前写入位置 = 一个字符 + 2
        }
        返回 (返回值)

    }

    #
}

类 "//读缓冲区"
{
    变量 成员_缓冲区 <类型 = 缓冲区类>
    变量 成员_当前读取位置 <类型 = 整数 值 = 0>

    方法 从指针加载 <公开 类型 = 逻辑型>
    参数 内存指针 <类型 = 变整数>
    参数 内存大小 <类型 = 整数>
    {
        返回 (成员_缓冲区.从指针载入 (内存指针, 内存大小))

    }

    方法 是否末尾 <公开 类型 = 逻辑型>
    {
        如果 (成员_当前读取位置 >= 成员_缓冲区.取数据大小 () - 1)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 读整数 <公开 类型 = 整数>
    参数 数据 <类型 = 整数>
    {
        如果 (成员_当前读取位置 + 4 >= 成员_缓冲区.取数据大小 () - 1)
        {
            调试输出 ("错误", 取当前语句位置 ())
            返回 (0)
        }
        变量 返回数据 <类型 = 整数>
        返回数据 = 成员_缓冲区.读整数 (成员_当前读取位置)
        成员_当前读取位置 = 成员_当前读取位置 + 4
        返回 (返回数据)
    }

    方法 读字节集 <公开 类型 = 字节集类>
    参数 读取大小 <类型 = 整数>
    {
        变量 数据 <类型 = 字节集类>
        如果 (成员_当前读取位置 + 读取大小 >= 成员_缓冲区.取数据大小 () - 1)
        {
            调试输出 ("错误", 取当前语句位置 ())
            返回 (数据)
        }
        数据 = 成员_缓冲区.读字节集 (成员_当前读取位置, 读取大小)
        成员_当前读取位置 = 成员_当前读取位置 + 读取大小
        返回 (数据)





    }
}
