<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"开源库.缓冲区类\"">

类 缓冲区类 <公开 @视窗.外部头文件 = "CBuffer\\CVolFCBuffer.h">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CFCBuffer)
    # @end

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "比较两个缓冲区是否相等" 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 缓冲区类>
    {
        @     if(pdata()->GetSize() != @<数据>.pdata()->GetSize()) return false;
        @     if(memcmp(pdata()->GetPtr(),@<数据>.pdata()->GetPtr(),pdata()->GetSize())== 0) return true;
        @     return false;
    }

    方法 置预分配字节数 <公开 注释 = "假设您有100个字节的数据 要加入100次" 注释 = "那么您可以预先直接分配好内存，这样后面就不用分配内存，效率可以提高" 折叠 折叠2 @嵌入式方法 = "">
    参数 欲分配的字节数 <类型 = 变整数>
    {
        @ @sn<this>.pdata()->PreAllocaMem((size_t)@<欲分配的字节数>)
    }

    方法 置内存增长值 <公开 注释 = "合理的设置此值，能大大提供程序的性能" 注释 = "比如 如果您设置内存增长值 为1的时候" 注释 = "你每次增加一个字节，增加十次 程序会分配十次内存"
            注释 = "假设 您设置内存增长值 为10的时候" 注释 = "你每次增加一个字节，增加十次 程序只会分配一次内存" 注释 = "默认增长值为512" 折叠 折叠2 @嵌入式方法 = "">
    参数 内存增长值 <类型 = 变整数>
    {
        @ @sn<this>.pdata()->SetMemAllocBlockSize((size_t)@<内存增长值>)
    }

    方法 取内存总大小 <公开 类型 = 变整数 注释 = "这个可以得到 占用的内存总大小" 注释 = "取数据大小只是 得到里面实际保存的数据的大小" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata()->GetTotalSize()
    }

    方法 取数据指针 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.pdata()->GetPtr()
    }

    方法 取数据大小 <公开 类型 = 整数 注释 = "得到里面实际保存的数据的大小" 折叠 @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.pdata()->GetSize()
    }

    方法 到字节集 <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    {
        @ return CVolMem(pdata()->GetPtr(),pdata()->GetSize());
    }

    # //增===

    方法 从指针载入 <公开 类型 = 逻辑型 折叠>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        回收内存 ()
        返回 (添加指针数据 (数据指针, 数据大小))
    }

    方法 从字节集载入 <公开 类型 = 逻辑型 折叠>
    参数 数据 <类型 = 字节集类>
    {
        回收内存 ()
        返回 (添加字节集 (数据))
    }

    方法 添加指针数据 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ @sn<this>.pdata()->Write((void*)@<数据指针>,@<数据大小>)
    }

    方法 添加字节 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节>
    {
        @ return pdata()->Write((void*)&@<数据>,1);
    }

    方法 添加逻辑值 <公开 @禁止流程检查 = 真>
    参数 数据 <类型 = 逻辑型>
    {
        @ return pdata()->Write((void*)&@<数据>,1);
    }

    方法 添加短整数 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
