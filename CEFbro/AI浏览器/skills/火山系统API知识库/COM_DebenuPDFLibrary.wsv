类 "//DebenuPDF" <公开 基础类 = 免注册COM调用模板 折叠 @模板实现类 = "">
{

    # @begin
    # //random_class_name 随机名称 如果你的是大漠 你可以写 Dm
    # //_REFCLSID   如果你的是大漠 你可以写 __uuidof(Dm::dmsoft)
    # // _VOL_COM_SMARTPTR_ 智能指针 如果你的是大漠，你可以写 Dm::IdmsoftPtr 或者 Idmsoft* 建议一般写Dm::IdmsoftPtr 因为这个无需调用 realse(); 
    # @m<define_vol_use_com_without_register_X86_X64>(DebenuPDF,__uuidof(DebenuPDFLibraryAX1013::PDFLibrary),__uuidof(DebenuPDFLibrary64AX1013::PDFLibrary),DebenuPDFLibraryAX1013::IPDFLibraryPtr,DebenuPDFLibrary64AX1013::IPDFLibraryPtr)
    # @end

    方法 类_初始化
    {
        变量 Com_Dll_路径 <类型 = 文本型>
        @ HRESULT hr = S_OK;
        @ hr = CoInitialize(nullptr);

        @ #ifdef _VOL_X64
        Com_Dll_路径 = 取运行目录 () + "DebenuPDFLibrary64AX1013.dll"
        @ #else
        Com_Dll_路径 = 取运行目录 () + "DebenuPDFLibraryAX1013.dll"
        @ #endif
        @ data().RegMemCOM(@<Com_Dll_路径>.GetText());
    }

    方法 注册 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 注册码 <类型 = 文本型>
    {
        @ @sn<this>.data().GetPtr()->UnlockKey(@<注册码>.GetText()) 
    }

    #
}

