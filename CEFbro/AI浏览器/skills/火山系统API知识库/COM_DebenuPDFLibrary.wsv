    # @end
    #

    方法 注册Com组件 <公开 静态 折叠>
    {
        变量 命令行 <类型 = 文本型>
        @ #ifdef _VOL_X64
        命令行 = "regsvr32 \"" + 取运行目录 () + "DebenuPDFLibrary64AX1013.dll"
        @ #else
        命令行 = "regsvr32 \"" + 取运行目录 () + "DebenuPDFLibraryAX1013.dll"
        @ #endif
        运行 (命令行)
    }

    方法 类_初始化 <折叠>
    {
        变量 是否创建成功 <类型 = 逻辑型>
        @ @<是否创建成功> = Init();
        如果 (是否创建成功 == 假)
        {
            调试输出 ("初始化 DebenuPDF 失败")
        }

    }

    方法 类_清理
    {
        @ Unit();
    }

    方法 UnlockKey <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 注册码 <类型 = 文本型>
    {
        @ @sn<this>.pdata()->UnlockKey(@<注册码>.GetText()) 
    }

    方法 SetOrigin <公开 类型 = 整数 @嵌入式方法 = "">
    参数 区域 <类型 = 整数 注释 = "1是左上脚" @默认值 = 1>
    {
        @ @sn<this>.pdata()->SetOrigin(@<区域>) 

    }

    方法 AddTrueTypeSubsettedFont <公开 类型 = 整数 返回值注释 = "返回字体ID" @嵌入式方法 = "">
    参数 字体名称 <类型 = 文本型>
    参数 内容 <类型 = 文本型>
    参数 配置 <类型 = 整数 @默认值 = 0>
    {
        @ @sn<this>.pdata()->AddTrueTypeSubsettedFont(@<字体名称>.GetText(),@<内容>.GetText(),@<配置>) 
        //    long  AddTrueTypeSubsettedFont( _bstr_t FontName, _bstr_t SubsetChars,long Options );
    }

    方法 AddTrueTypeFont <公开 类型 = 整数 返回值注释 = "返回字体id" @嵌入式方法 = "">
    参数 字体名称 <类型 = 文本型>
    参数 是否嵌入 <类型 = 整数 @默认值 = 1>
    {
        @ @sn<this>.pdata()->AddTrueTypeFont(@<字体名称>.GetText(),@<是否嵌入>) 
    }

    方法 SelectFont <公开 类型 = 整数 @嵌入式方法 = "">
    参数 字体ID <类型 = 整数>
    {
        @ @sn<this>.pdata()->SelectFont(@<字体ID>) 
    }

    方法 DrawText <公开 类型 = 整数 @嵌入式方法 = "">
    参数 横坐标 <类型 = 小数>
    参数 纵坐标 <类型 = 小数>
    参数 内容 <类型 = 文本型>
    {
        @ @sn<this>.pdata()->DrawText(@<横坐标>,@<纵坐标>,@<内容>.GetText()) 
    }

    方法 画中文文本 <公开>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 文本内容 <类型 = 文本型>
    参数 字体名称 <类型 = 文本型 @默认值 = "宋体">
    {
        变量 字体ID <类型 = 整数>
        字体ID = AddTrueTypeSubsettedFont (字体名称, 文本内容, 0)
        SelectFont (字体ID)
        DrawText (横坐标, 纵坐标, 文本内容)

    }

    方法 SaveToFile <公开 类型 = 整数 @嵌入式方法 = "">
    参数 文件名称 <类型 = 文本型>
