    {
        @ @sn<this>.GetComObjPtr()->RegExNoMac(@<code>.GetText(),@<Ver>.GetText(),@<ip>.GetText())
    }

    方法 SetEnumWindowDelay <公开 类型 = 整数 返回值注释 = "long" @嵌入式方法 = "">
