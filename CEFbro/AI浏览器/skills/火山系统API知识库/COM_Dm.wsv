<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"辅助.大漠\"" @视窗.外部头文件 = "COM_Dm\\dm.tlh" @视窗.附属文件 = "COM_Dm\\RegDm.bat"
        @视窗.附属文件.x64 = "COM_Dm\\dm.dll">

类 "//大漠最后一个免费版" <公开 基础类 = 免注册COM调用模板 注释 = "3.1233" 折叠 @模板实现类 = "">
{

    # @begin
    # //random_class_name 随机名称 如果你的是大漠 你可以写 Dm
    # //_REFCLSID   如果你的是大漠 你可以写 __uuidof(Dm::dmsoft)
    # // _VOL_COM_SMARTPTR_ 智能指针 如果你的是大漠，你可以写 Dm::IdmsoftPtr 或者 Idmsoft* 建议一般写Dm::IdmsoftPtr 因为这个无需调用 realse(); 
    # @m<define_vol_use_com_without_register>(Dm,__uuidof(Dm::dmsoft),Dm::IdmsoftPtr)
    # @end

    方法 类_初始化
    {
        变量 Com_Dll_路径 <类型 = 文本型>
        Com_Dll_路径 = 取运行目录 () + "Dm.dll"
        @ data().RegMemCOM(@<Com_Dll_路径>.GetText());
    }

    方法 Ver <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @ CVolString( (const TCHAR*)@sn<this>.data().GetPtr()->Ver() )
    }

    #
    #
}

类 "//大漠最后一个免费版" <公开 注释 = "只能32位程序调用哦" 折叠>
{

    # @begin
    # <> <include>
    # Dm::IdmsoftPtr pvObject;
    # <> <include>
    # @end

    方法 类_初始化
    {
        // 运行 (取运行目录 () + "RegDm.bat")
        @ if(  pvObject.CreateInstance(__uuidof(Dm::dmsoft)) != S_OK )
        @ {
        调试输出 ("注册大漠失败，请手动注册大漠哦 ")
        @ }
    }

    方法 Ver <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @ CVolString( (const TCHAR*)@sn<this>.pvObject->Ver() )
    }

    #
}

类 大漠最后一个免费版 <公开>
{

    # @begin
    # @m<define_vol_use_System_com_ProgID>(__uuidof(Dm::dmsoft),Dm::IdmsoftPtr)
    # @end
    #

    方法 注册组件
    {
        变量 命令行 <类型 = 文本型>
        @ #ifdef _VOL_X64
        @ #else
        命令行 = "regsvr32 \"" + 取运行目录 () + "dm.dll\""
        运行 (命令行)
        // 命令行 = "regsvr32 \"" + 取运行目录 () + "DebenuPDFLibraryAX1013.dll"
        @ #endif
    }

    方法 类_初始化
    {
        变量 是否创建成功 <类型 = 逻辑型>
        @ @<是否创建成功> = Init();

        如果 (是否创建成功 == 假)
        {
            如果 (程序_是否64位 ())
            {
                调试输出 ("当前程序为64位的，不支持大漠哦")

            }
            否则
            {
                注册组件 ()
                调试输出 (" 要用管理员权限启动，才能注册成功哦")


            }

        }

    }

    方法 类_清理
    {
        @ Unit();

    }

