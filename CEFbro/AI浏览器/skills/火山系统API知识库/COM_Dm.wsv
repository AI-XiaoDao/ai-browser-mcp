    {
        @ @sn<this>.GetComObjPtr()->SetEnumWindowDelay(@<delay>)
    }

    方法 FindMulColor <公开 类型 = 整数 返回值注释 = "long" @嵌入式方法 = "">
    参数 x1 <类型 = 整数 注释 = "long x1">
    参数 y1 <类型 = 整数 注释 = "long y1">
    参数 x2 <类型 = 整数 注释 = "long x2">
    参数 y2 <类型 = 整数 注释 = "long y2">
    参数 color <类型 = 文本型 注释 = "_bstr_t color">
    参数 sim <类型 = 小数 注释 = "double sim">
    {
        @ @sn<this>.GetComObjPtr()->FindMulColor(@<x1>,@<y1>,@<x2>,@<y2>,@<color>.GetText(),@<sim>)
    }

    方法 GetDict <公开 类型 = 文本型 返回值注释 = "_bstr_t" @嵌入式方法 = "">
    参数 index <类型 = 整数 注释 = "long index">
    参数 font_index <类型 = 整数 注释 = "long font_index">
    {
        @ CVolString((const TCHAR*)@sn<this>.GetComObjPtr()->GetDict(@<index>,@<font_index>))
    }

