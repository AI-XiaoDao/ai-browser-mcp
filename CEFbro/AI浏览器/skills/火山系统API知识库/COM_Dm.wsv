    参数 Ver <类型 = 文本型 注释 = "_bstr_t Ver">
    {
        @ @sn<this>.GetComObjPtr()->RegNoMac(@<code>.GetText(),@<Ver>.GetText())
    }

    方法 RegExNoMac <公开 类型 = 整数 返回值注释 = "long" @嵌入式方法 = "">
