    方法 AddCode <公开 类型 = 整数 返回值注释 = "HRESULT" @嵌入式方法 = "">
    参数 Code <类型 = 文本型 注释 = "_bstr_t Code">
    {
        @ @sn<this>.GetComObjPtr()->AddCode(@<Code>.GetText())
    }

    方法 "//Eval" <公开 返回值注释 = "_variant_t" 折叠 @嵌入式方法 = "">
    参数 Expression <类型 = 文本型 注释 = "_bstr_t Expression">
    参数 执行结果 <类型 = COM变体型>
    {
        @ @<执行结果>.SetVariant( &( @sn<this>.GetComObjPtr()->Eval(@<Expression>.GetText())),-1)
    }

    方法 "//Eval" <公开 类型 = COM变体型 返回值注释 = "_variant_t" @禁止流程检查 = 真>
    参数 Expression <类型 = 文本型 注释 = "_bstr_t Expression">
    {
        @ CVolComVariant vt;
        @ vt.SetVariant(&GetComObjPtr()->Eval(@<Expression>.GetText()),-1);
        @ return vt;

    }

    方法 Eval <公开 类型 = 整数 返回值注释 = "_variant_t" @嵌入式方法 = "">
    参数 Expression <类型 = 文本型 注释 = "_bstr_t Expression">
    参数 返回值 <类型 = COM变体型>
    {
        @ @sn<this>.GetComObjPtr()->raw_Eval(_bstr_t(@<Expression>.GetText()), &@<返回值>.m_var)

    }

    方法 ExecuteStatement <公开 类型 = 整数 返回值注释 = "HRESULT" @嵌入式方法 = "">
