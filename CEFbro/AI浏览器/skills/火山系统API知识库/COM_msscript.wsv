    方法 "//AddObject" <公开 类型 = 整数 返回值注释 = "HRESULT" @嵌入式方法 = "">
    参数 Name <类型 = 文本型 注释 = "_bstr_t Name">
    参数 Object <注释 = "IDispatch * Object">
    参数 AddMembers <类型 = 逻辑型 注释 = "VARIANT_BOOL AddMembers" @默认值 = 真>
    {
        @ @sn<this>.GetComObjPtr()->AddObject(@<Name>.GetText(),@<Object>,@<AddMembers>)
    }

    方法 Reset <公开 类型 = 整数 返回值注释 = "HRESULT" @嵌入式方法 = "">
