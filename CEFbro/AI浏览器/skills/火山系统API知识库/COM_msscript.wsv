    #
}

类 IScriptControl <公开 注释 = "64位的脚本控件源码 https://github.com/tablacus/TablacusScriptControl"
        @视窗.外部头文件 = "COM_msscript\\msscript.tlh" @视窗.附属文件.x64 = "COM_msscript\\tsc64.dll">
{

    #
    # @begin
    # @m<define_vol_use_System_com_ProgID>(__uuidof(MSScriptControl::ScriptControl),MSScriptControl::IScriptControlPtr)
    # //@m<define_vol_use_System_com_ProgID>("MSScriptControl.ScriptControl",MSScriptControl::IScriptControlPtr)
    # //@m<define_vol_use_com_with_registered_tlh_X86_X64>(__uuidof(MSScriptControl::ScriptControl),__uuidof(IScriptControl::IScriptControl),MSScriptControl::IScriptControlPtr,IScriptControl::IScriptControlPtr)
    #
    # //@m<define_vol_use_com_without_register_X86_X64>(__uuidof(MSScriptControl::ScriptControl),)
    #
    # <> <include>
    # //这部分代码，只有X64 下才会用到
    # HMODULE hdllInst;    
    # IClassFactory* pClassFactory;    
    # BOOL InitX64(LPCTSTR lpszDLLFile,BOOL bMutiThread ,REFCLSID clsid, REFIID iid)    
    # {
    #     HRESULT hr = S_OK;    
    #     if(bMutiThread)        
    #         hr = ::CoInitialize(nullptr);    
    #     else                    
    #         hr = ::CoInitializeEx(0, COINIT_MULTITHREADED);    
    #   typedef HRESULT(__stdcall* pDllGetClassObject)(REFCLSID, REFIID, void**);    
    #   HMODULE hdllInst = LoadLibrary(lpszDLLFile);    
    #   if (hdllInst)    
    #   {    
    #    pDllGetClassObject fnDllGetClassObject = (pDllGetClassObject)GetProcAddress(hdllInst, "DllGetClassObject");    
    #    if (fnDllGetClassObject != 0)    
    #    {    
    #     HRESULT hr = (fnDllGetClassObject)(clsid, IID_IClassFactory, (LPVOID*)&pClassFactory);    
    #     if (SUCCEEDED(hr) && (pClassFactory != NULL))    
    #     {    
    #        return  pClassFactory->CreateInstance(NULL, iid, (void**)&m_pvObject) == S_OK ? TRUE:FALSE;    
    #      }    
    #    }    
    #   }    
    #  return FALSE;    
    # }    
    # VOID UnitX64()    
    # {    
    #     if (pClassFactory) pClassFactory->Release();    
    #     if (hdllInst)    FreeLibrary(hdllInst);  
    # }    
    # <> </include>
    #
    #
    # @end

    方法 类_初始化
    {
        变量 是否创建成功 <类型 = 逻辑型>
        变量 DLL路径 <类型 = 文本型>
        @ #ifdef _VOL_X64
        DLL路径 = 取运行目录 () + "tsc64.dll"
        @ @<是否创建成功> = InitX64(@<DLL路径>.GetText(),TRUE,__uuidof(MSScriptControl::ScriptControl),__uuidof(MSScriptControl::IScriptControl));
        @ #else
        // 命令行 = "regsvr32 \"" + 取运行目录 () + "DebenuPDFLibraryAX1013.dll"
        @ @<是否创建成功> = Init();
        @ #endif

        如果 (是否创建成功 == 假)
        {
            调试输出 ("初始化 IScriptControl 失败 IScriptControl只有32位的，没有64的,目录中的64位的是我百度到加上去的")
        }

    }

    方法 类_清理
    {
        @ Unit();

    }

    #

    方法 GetLanguage <公开 类型 = 文本型 返回值注释 = "_bstr_t" @嵌入式方法 = "">
    {
        @ CVolString((const TCHAR*)@sn<this>.GetComObjPtr()->GetLanguage())
    }

    方法 PutLanguage <公开 返回值注释 = "void" @嵌入式方法 = "">
