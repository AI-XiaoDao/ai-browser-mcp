<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"windows.封装辅助库\"">

类 const_char_point_array类 <公开 折叠>
{
    变量 成员_原始字节集数组 <类型 = 字节集数组类>
    变量 成员_字符串指针数组 <类型 = 变整数数组类>

    方法 从文本数组载入 <公开>
    参数 文本数组 <类型 = 文本数组类>
    参数 是否utf8 <类型 = 逻辑型 @默认值 = 假>
    {
        成员_原始字节集数组.删除所有成员 ()
        成员_字符串指针数组.删除所有成员 ()
        文本数组.枚举循环 ()
        {
            如果 (是否utf8)
            {
                成员_字符串指针数组.加入成员 (成员_原始字节集数组.加入并返回成员 (文本到UTF8 (文本数组.取枚举值 ())).取字节集指针 ())

            }
            否则
            {
                成员_字符串指针数组.加入成员 (成员_原始字节集数组.加入并返回成员 (文本到多字节 (文本数组.取枚举值 ())).取字节集指针 ())
            }
        }

    }

    方法 从字节集数组载入 <公开>
    参数 字节集集数组 <类型 = 字节集数组类>
    {
        成员_原始字节集数组.删除所有成员 ()
        成员_字符串指针数组.删除所有成员 ()
        成员_原始字节集数组 = 字节集集数组
        成员_原始字节集数组.枚举循环 ()
        {
            成员_字符串指针数组.加入成员 (成员_原始字节集数组.取枚举值 ().取字节集指针 ())
        }

    }

    方法 加入成员 <公开 折叠>
    参数 要加入的指针 <类型 = 变整数>
    {
        成员_字符串指针数组.加入成员 (要加入的指针)
    }

    方法 取数组指针 <公开 类型 = 变整数 折叠>
    {
        返回 (成员_字符串指针数组.取数组指针 ())
    }

    方法 取成员数 <公开 类型 = 整数>
    {
        返回 (成员_字符串指针数组.取成员数 ())

    }

    #
}

类 const_wchar_point_array类 <公开 折叠>
{
    变量 成员_原始文本数组 <类型 = 文本数组类>
    变量 成员_字符串指针数组 <类型 = 变整数数组类>

    方法 从文本数组载入 <公开>
    参数 文本数组 <类型 = 文本数组类>
    {
        成员_字符串指针数组.删除所有成员 ()
        成员_原始文本数组 = 文本数组
        成员_原始文本数组.枚举循环 ()
        {
            成员_字符串指针数组.加入成员 (取文本指针 (成员_原始文本数组.取枚举值 ()))
        }

    }

    方法 加入成员 <公开 折叠>
    参数 要加入的指针 <类型 = 变整数>
    {
        成员_字符串指针数组.加入成员 (要加入的指针)
    }

    方法 取数组指针 <公开 类型 = 变整数 折叠>
    {
        返回 (成员_字符串指针数组.取数组指针 ())
    }

    方法 取成员数 <公开 类型 = 整数>
    {
        返回 (成员_字符串指针数组.取成员数 ())

    }

    #
}
