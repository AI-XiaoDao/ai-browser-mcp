<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" @文档 = "category = \"开源库.排列组合\"">

类 组合_不重复 <公开 折叠 @视窗.后缀文本 = "public CCombination" @视窗.外部头文件 = "Combination\\CCombination.h">
{
    方法 创建 <公开 注释 = "例如 5个当中取3个，那么总共几个就是5，那么取几个就是3" @嵌入式方法 = "">
    参数 取几个来组合 <类型 = 整数>
    参数 总共多少个 <类型 = 整数>
    {
        @ @sn<this>.Create(@<取几个来组合>,@<总共多少个>)
    }

    方法 到下一行 <公开 类型 = 逻辑型 注释 = "计算是否有下一个" @嵌入式方法 = "">
    {
        @ @sn<this>.Next()
    }

    方法 取列值 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 索引 <类型 = 整数 注释 = "0到X 比如5个取三个，那么 这里的索引就是从0 到 2">
    {
        @ @sn<this>.GetValue(@<索引>)
    }

    方法 取列数 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ @sn<this>.GetValueCount()
    }

    #
}

类 组合测试 <公开 折叠>
{
    方法 开始测试 <公开>
    {
        变量 索引 <类型 = 整数>
        变量 值 <类型 = 整数>
        变量 用户数组 <类型 = "整数 [5]" 值 = {1,2,3,4,5}>
        变量 组合 <类型 = 组合_不重复>
        变量 结果文本 <类型 = 文本型>
        调试输出 ("-----开始测试 不重复组合")
        组合.创建 (3, 5)
        判断循环 (真)
        {
            循环 (0, 组合.取列数 (), 索引, 1)
            {
                值 = 用户数组 [组合.取列值 (索引)]
                结果文本 = 结果文本 + 到文本 (值) + " "
            }
            结果文本 = 结果文本 + "\r\n"
            如果 (组合.到下一行 () == 假)
            {
                跳出循环
            }
        }
        调试输出 (结果文本)
        调试输出 ("-----结束测试 不重复组合")
    }

    #
    #
    #
    #
}

类 组合_不重复2 <公开 注释 = "这个速度稍快" @视窗.后缀文本 = "public CCombine" @视窗.外部头文件 = "Combination\\TCombine.h">
{

