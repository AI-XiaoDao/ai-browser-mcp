{
    常量 CBC <公开 值 = @AES_CRYPT_MODE_CBC>
    常量 CFB <公开 值 = @AES_CRYPT_MODE_CFB>
    常量 CFB_FIPS <公开 值 = @AES_CRYPT_MODE_CFB_FIPS>
    常量 OFB <公开 值 = @AES_CRYPT_MODE_OFB>
    常量 CTR <公开 值 = @AES_CRYPT_MODE_CTR>
    常量 ECB <公开 值 = @AES_CRYPT_MODE_ECB>
    常量 CBC_CTS <公开 值 = @AES_CRYPT_MODE_CBC_CTS>

    #
}

