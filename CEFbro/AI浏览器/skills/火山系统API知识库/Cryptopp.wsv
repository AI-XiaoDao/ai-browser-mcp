    常量 无 <公开 值 = @CRYPTOPP_PADDING_NO>
    常量 零 <公开 值 = @CRYPTOPP_PADDING_ZEROS>
    常量 PKCS <公开 值 = @CRYPTOPP_PADDING_PKCS>
    常量 零和一 <公开 值 = @CRYPTOPP_PADDING_ONE_AND_ZEROS>
    常量 W3C <公开 值 = @CRYPTOPP_PADDING_W3C>
    常量 默认 <公开 值 = @CRYPTOPP_PADDING_DEFAULT>

    #
    #
}

