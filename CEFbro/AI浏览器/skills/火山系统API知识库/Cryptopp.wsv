<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"开源库.加密解密Cryptopp\"" @视窗.外部头文件 = "Cryptopp\\CryptoppTool.h"
        @视窗.外部库.win32 = "Cryptopp\\CryptoppToolx86.lib" @视窗.附属文件.win32 = "Cryptopp\\CryptoppToolx86.dll"
        @视窗.外部库.x64 = "Cryptopp\\CryptoppToolx64.lib" @视窗.附属文件.x64 = "Cryptopp\\CryptoppToolx64.dll" "">

类 jsencrypt <公开 注释 = "RSA_PKCS1v15_GenerateRSAKey  jsencrypt.min" @全局类 = 真>
{
    方法 密码学_RSA_PKCS1v15_生成公钥私钥 <静态 类型 = 逻辑型 折叠>
    参数 生成的公钥 <类型 = 文本型>
    参数 生成的密钥 <类型 = 文本型>
    参数 密钥长度 <类型 = 整数 注释 = "如果没猜错，必须是8的整数倍，还要大于1024" @默认值 = 1024>
    参数 是否BASE64编码 <类型 = 逻辑型 注释 = "如果为真，则是base64 否则 hex编码" @默认值 = 真>
    {
        如果 (密钥长度 % 8 != 0)
        {
            调试输出 ("密钥长度必须为8的倍数", 取当前语句位置 ())
            返回 (假)
        }

        @ void* pPrivate = cryptopp_string_new();
        @ void* pPublic = cryptopp_string_new();
        @ RSA_PKCS1v15_GenerateRSAKey(@<密钥长度>, pPrivate, pPublic, @<是否BASE64编码>);
        @ @<生成的密钥> = cryptopp_string_GetText(pPrivate) ;
        @ @<生成的公钥> = cryptopp_string_GetText(pPublic) ;
        @ cryptopp_string_delete (pPrivate);
        @ cryptopp_string_delete (pPublic);
        返回 (真)
    }

    方法 _密码学_RSA_PKCS1v15_公钥加密 <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 公钥 <类型 = 文本型>
    参数 要加密的文本 <类型 = 文本型>
    参数 加密后的文本 <类型 = 文本型>
    参数 是否BASE64编码 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 临时文本 <类型 = 字节集类>
        变量 临时公钥 <类型 = 字节集类>
        临时文本 = 文本到多字节 (要加密的文本)
        临时公钥 = 文本到多字节 (公钥)
        @ void* lpszEncrypt = cryptopp_string_new();
        @ bool bOk = RSA_PKCS1v15_PublicKey_Encrypt( (const char*)@<临时公钥>.GetPtr(), (const char*)@<临时文本>.GetPtr(), lpszEncrypt, @<是否BASE64编码>);
        @ if(bOk)
        @   @<加密后的文本> = cryptopp_string_GetText(lpszEncrypt);
        @ cryptopp_string_delete(lpszEncrypt);
        @ return bOk;

    }

    方法 密码学_RSA_PKCS1v15_公钥加密 <公开 静态 类型 = 逻辑型>
    参数 公钥 <类型 = 文本型>
    参数 要加密的文本 <类型 = 文本型>
    参数 加密后的文本 <类型 = 文本型>
    参数 密钥长度 <类型 = 整数 注释 = "密码学_RSA_PKCS1v15_生成公钥私钥" @默认值 = 1024>
    参数 是否BASE64编码 <类型 = 逻辑型 @默认值 = 真>
    {
        如果 (密钥长度 % 8 != 0)
        {
            调试输出 ("密钥长度必须为8的倍数", 取当前语句位置 ())
            返回 (假)
        }
        加密后的文本 = ""


        变量 实际能加密的数据长度 <类型 = 整数>
        实际能加密的数据长度 = 密钥长度 / 8 - 11  // 关于这行代码的解释 https://www.cnblogs.com/isyaya/p/11073149.html

        变量 分割后的文本 <类型 = 文本数组类>
        文本_分割文本_指定长度 (要加密的文本, 实际能加密的数据长度, 分割后的文本)

        // 调试输出 (分割后的文本)
        // 调试输出 (取文本长度 (分割后的文本.取成员 (0)))

        变量 i <类型 = 整数>
        变量 键值列表 <类型 = 键值列表>

        循环 (0, 分割后的文本.取成员数 (), i)
        {
            变量 临时加密后的文本 <类型 = 文本型>
            _密码学_RSA_PKCS1v15_公钥加密 (公钥, 分割后的文本.取成员 (i), 临时加密后的文本, 是否BASE64编码)
            键值列表.添加文本 (临时加密后的文本)

        }
        加密后的文本 = 键值列表.到文本 ()
        返回 (真)

    }

    方法 _密码学_RSA_PKCS1v15_私钥解密 <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 私钥 <类型 = 文本型>
    参数 要解密的文本 <类型 = 文本型>
    参数 解密后的文本 <类型 = 文本型>
    参数 私钥是否PEM格式 <类型 = 逻辑型 @默认值 = 假>
    参数 是否BASE64编码 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 临时文本 <类型 = 字节集类>
        变量 临时私钥 <类型 = 字节集类>
        临时文本 = 文本到多字节 (要解密的文本)
        临时私钥 = 文本到多字节 (私钥)
        @ void* lpszDecrypt = cryptopp_string_new();
        @ bool bok = RSA_PKCS1v15_PrivateKey_Decrypt( (const char*)@<临时私钥>.GetPtr(), (const char*)@<临时文本>.GetPtr(), lpszDecrypt, @<是否BASE64编码>, @<私钥是否PEM格式>);
        @ if(bok)
        @   @<解密后的文本> = cryptopp_string_GetText(lpszDecrypt);
        @ cryptopp_string_delete(lpszDecrypt);
        @ return bok;

    }

    方法 密码学_RSA_PKCS1v15_私钥解密 <公开 静态 折叠>
    参数 私钥 <类型 = 文本型>
    参数 要解密的文本 <类型 = 文本型>
    参数 解密后的文本 <类型 = 文本型>
    参数 私钥是否PEM格式 <类型 = 逻辑型 @默认值 = 假>
    参数 是否BASE64编码 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 要解密的数据 <类型 = 键值列表>
        变量 i <类型 = 整数>
        要解密的数据.从文本载入 (要解密的文本)
        解密后的文本 = ""
        循环 (0, 要解密的数据.取成员数 (), i)
        {

            变量 临时解密后的文本 <类型 = 文本型>
            _密码学_RSA_PKCS1v15_私钥解密 (私钥, 要解密的数据.取文本 (i), 临时解密后的文本, 私钥是否PEM格式, 是否BASE64编码)
            解密后的文本 = 解密后的文本 + 临时解密后的文本

        }



    }
}

