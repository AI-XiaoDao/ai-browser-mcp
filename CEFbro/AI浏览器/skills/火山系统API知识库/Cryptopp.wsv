类 DES类型常量 <公开 折叠 @常量类 = 整数>
{
    常量 DES <公开 值 = @DES_CRYPT_TYPE_DES>
    常量 EDE2 <公开 值 = @DES_CRYPT_TYPE_EDE2>
    常量 EDE3 <公开 值 = @DES_CRYPT_TYPE_EDE3>
    常量 XEX3 <公开 值 = @DES_CRYPT_TYPE_XEX3>

    #
}

类 DES类 <公开 折叠>
{
    方法 加密 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 要加密的数据 <类型 = 字节集类>
    参数 加密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16" @默认值 = 空对象>
    参数 加密方式 <类型 = DES加密常量 @默认值 = DES加密常量.ECB>
    参数 填充方式 <类型 = DES填充常量 @默认值 = DES填充常量.零>
    参数 DES类型 <类型 = DES类型常量 @默认值 = DES类型常量.DES>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要加密的数据>.GetPtr(),@<要加密的数据>.GetSize());
        @ void* pOutEncryptData = cryptopp_string_new();
        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_DES_encrypt(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>,@<DES类型>);

        @ if(pOutEncryptData)
        @ {
        @   @<加密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }
        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    方法 解密 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 要解密的数据 <类型 = 字节集类>
    参数 解密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16" @默认值 = 空对象>
    参数 加密方式 <类型 = DES加密常量 @默认值 = DES加密常量.ECB>
    参数 填充方式 <类型 = DES填充常量 @默认值 = DES填充常量.零>
    参数 DES类型 <类型 = DES类型常量 @默认值 = DES类型常量.DES>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要解密的数据>.GetPtr(),@<要解密的数据>.GetSize());
        @ void* pOutEncryptData = cryptopp_string_new();
        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_DES_decrypt(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>,@<DES类型>);

        @ if(pOutEncryptData)
        @ {
        @   @<解密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }
        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    #
}

类 AES类 <公开>
{
    方法 加密 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 要加密的数据 <类型 = 字节集类>
    参数 加密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16">
    参数 加密方式 <类型 = AES加密常量 @默认值 = AES加密常量.CFB>
    参数 填充方式 <类型 = AES填充常量 @默认值 = AES填充常量.零>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要加密的数据>.GetPtr(),@<要加密的数据>.GetSize());
        @ void* pOutEncryptData = cryptopp_string_new();
        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(piv,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_Aes_encrypt(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>);

        @ if(pOutEncryptData)
        @ {
        @   @<加密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }
        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    方法 解密 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 要解密的数据 <类型 = 字节集类>
    参数 解密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16">
    参数 加密方式 <类型 = AES加密常量 @默认值 = AES加密常量.CFB>
    参数 填充方式 <类型 = AES填充常量 @默认值 = AES填充常量.零>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要解密的数据>.GetPtr(),@<要解密的数据>.GetSize());

        @ void* pOutEncryptData = cryptopp_string_new();
        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(piv,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_Aes_Decrypt(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>);

        @ if(pOutEncryptData)
        @ {
        @   @<解密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }
        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    方法 "//加密BASE64" <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 要加密的数据 <类型 = 字节集类>
    参数 加密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16">
    参数 加密方式 <类型 = AES加密常量 @默认值 = AES加密常量.CFB>
    参数 填充方式 <类型 = AES填充常量 @默认值 = AES填充常量.零>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要加密的数据>.GetPtr(),@<要加密的数据>.GetSize());
        @ void* pOutEncryptData = cryptopp_string_new();
        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_Aes_encrypt_BASE64(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>);

        @ if(pOutEncryptData)
        @ {
        @   @<加密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }
        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    方法 "//解密BASE64" <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 要解密的数据 <类型 = 字节集类>
    参数 解密后的数据 <类型 = 字节集类>
    参数 密钥 <类型 = 字节集类 注释 = "密钥长度 可以是 16 24 32">
    参数 IV <类型 = 字节集类 注释 = "固定长度 16">
    参数 加密方式 <类型 = AES加密常量 @默认值 = AES加密常量.CFB>
    参数 填充方式 <类型 = AES填充常量 @默认值 = AES填充常量.零>
    {
        @ void* pSrcData = cryptopp_string_new();
        @ cryptopp_string_SetData(pSrcData,@<要解密的数据>.GetPtr(),@<要解密的数据>.GetSize());

        @ void* pOutEncryptData = cryptopp_string_new();

        @ void* pKey = cryptopp_string_new();
        @ cryptopp_string_SetData(pKey,@<密钥>.GetPtr(),@<密钥>.GetSize());
        @ void* piv = cryptopp_string_new();
        @ cryptopp_string_SetData(piv,@<IV>.GetPtr(),@<IV>.GetSize());

        @ bool bOk =  Cryptopp_Aes_Decrypt_BASE64(pSrcData, pOutEncryptData,pKey, piv, @<加密方式>, @<填充方式>);

        @ if(pOutEncryptData)
        @ {
        @   @<解密后的数据> = CVolMem( cryptopp_string_GetText(pOutEncryptData),cryptopp_string_GetSize(pOutEncryptData));
        @ }

        @ cryptopp_string_delete (pSrcData);
        @ cryptopp_string_delete (pOutEncryptData);
        @ cryptopp_string_delete (pKey);
        @ cryptopp_string_delete (piv);
        @ return bOk;

    }

    #
}

类 ______MD5系列函数 <公开 @全局类 = 真>
{
    方法 校验_取文件MD <公开 静态 类型 = 文本型 注释 = "注意，犹豫开源库内部有问题，再x64下面是无错误的，再x86 下面会异常" 折叠 @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型>
    参数 是否大写 <类型 = 逻辑型 @默认值 = 假>
    参数 md类型 <类型 = 整数 注释 = "可选值 5 4 2 分别代表 MD5 MD4 MD2" @默认值 = 5>
    {
        @ void* pOutData = cryptopp_string_new();
        @ Cryptopp_GetFileMdNW(@<文件名>,@<md类型>,@<是否大写>,pOutData);
        @ CVolString szRet(cryptopp_string_GetText(pOutData));
        @ cryptopp_string_delete (pOutData);
        @ return szRet;
    }

    方法 校验_取字节集MD <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 要取校验数据 <类型 = 字节集类>
    参数 是否大写 <类型 = 逻辑型 @默认值 = 假>
    参数 md类型 <类型 = 整数 注释 = "可选值 5 4 2 分别代表 MD5 MD4 MD2" @默认值 = 5>
    {
        @ void* pInputData = cryptopp_string_new();
        @ void* pOutData = cryptopp_string_new();
        @ cryptopp_string_SetData(pInputData,@<要取校验数据>.GetPtr(),@<要取校验数据>.GetSize());
        @ Cryptopp_GetBinMdN(pInputData,@<md类型>,@<是否大写>,pOutData);
        @ CVolString szRet(cryptopp_string_GetText(pOutData));
        @ cryptopp_string_delete (pInputData);
        @ cryptopp_string_delete (pOutData);
        @ return szRet;
    }

    #
}

类 ______SHA系列函数 <公开 @全局类 = 真>
{
    方法 校验_取文件SHA <公开 静态 类型 = 文本型 注释 = "注意，犹豫开源库内部有问题，再x64下面是无错误的，再x86 下面会异常" 编辑时信息 = "40FFB, 0, 0, 0" @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型 编辑时信息 = "40FFB, 0, 0, 0">
    参数 是否大写 <类型 = 逻辑型 编辑时信息 = "40FFB, 0, 0, 0" @默认值 = 假>
    参数 类型 <类型 = 整数 注释 = "//1  SHA1" 注释 = "//224  SHA224" 注释 = "//256  SHA256" 注释 = "//384  SHA384" 注释 = "//512  SHA512"
            注释 = "//3224  SHA3_224" 注释 = "//3256  SHA3_256" 注释 = "//3384  SHA3_384" 注释 = "//3512  SHA3_512" 编辑时信息 = "40FFB, 0, 0, 0"
            @默认值 = 1>
    {
        @ void* pOutData = cryptopp_string_new();
        @ Cryptopp_GetFileSHAW(@<文件名>,@<类型>,@<是否大写>,pOutData);
        @ CVolString szRet(cryptopp_string_GetText(pOutData));
        @ cryptopp_string_delete (pOutData);
        @ return szRet;
    }

    方法 校验_取字节集SHA <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    参数 要取校验数据 <类型 = 字节集类>
    参数 是否大写 <类型 = 逻辑型 @默认值 = 假>
    参数 类型 <类型 = 整数 注释 = "//1  SHA1" 注释 = "//224  SHA224" 注释 = "//256  SHA256" 注释 = "//384  SHA384" 注释 = "//512  SHA512"
            注释 = "//3224  SHA3_224" 注释 = "//3256  SHA3_256" 注释 = "//3384  SHA3_384" 注释 = "//3512  SHA3_512" @默认值 = 1>
    {
        @ void* pInputData = cryptopp_string_new();
        @ void* pOutData = cryptopp_string_new();
        @ cryptopp_string_SetData(pInputData,@<要取校验数据>.GetPtr(),@<要取校验数据>.GetSize());
        @ Cryptopp_GetBinSHA(pInputData,@<类型>,@<是否大写>,pOutData);
        @ CVolString szRet(cryptopp_string_GetText(pOutData));
        @ cryptopp_string_delete (pInputData);
        @ cryptopp_string_delete (pOutData);
        @ return szRet;
    }

    #
}
