    # @end

    方法 类_清理 <折叠>
    {
        结束hook ()

    }

    方法 类_初始化 <折叠>
    {
        开始Hook ()

    }

    方法 自定义时钟函数 <公开 静态 类型 = 整数 @视窗.前缀文本 = "@WINAPI">
    参数 dwMilliseconds <类型 = 整数>
    参数 bAlertable <类型 = 逻辑型>
    {
        // DWORD WINAPI TimedSleepEx(DWORD dwMilliseconds, BOOL bAlertable)
        调试输出 ("SleepEx被拦截")
        @ return SysSleepEx(@<dwMilliseconds>,@<bAlertable>);
        返回 (0)
    }

    方法 开始HOOK代码 <@虚拟方法 = 可覆盖>
    {
        调试输出 ("///////////////////////////////////开始HOOK代码 ")
        // @ @<TrueSleepEx> = (INT64) GetProcAddress( LoadLibrary(_T("kernel32.dll")),"SleepEx");
        // 调用这个直接 HOOK函数
        @ DetourAttach(&(PVOID&)SysSleepEx, @<自定义时钟函数>);

    }

    方法 结束HOOK代码 <@虚拟方法 = 可覆盖>
    {
        调试输出 ("///////////////////////////////////结束HOOK代码 ")
        @ DetourDetach(&(PVOID&)SysSleepEx,@<自定义时钟函数>);
    }
}
