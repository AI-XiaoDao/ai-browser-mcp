类 树形列表框Ex <公开 基础类 = 组件Ex 注释 = "TreeListEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "TreeListEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    #
    # static AutoInt CALLBACK Exui_EventPro_ScrollCallBack_TreeListEx(AutoInt CtrHandle,AutoInt EventType,AutoInt Param1,AutoInt Param2,AutoInt Param3,AutoInt Param4)
    # {
    #  return GetControlExClassThis(CtrHandle,@sn<current_class>)->TreeListExEvent_ScrollCallBack(CtrHandle,EventType,Param1,Param2,Param3,Param4);
    # }
    #
    # static AutoInt CALLBACK Exui_EventPro_VirtualTableCallBack_TreeListEx(AutoInt CtrHandle,AutoInt EventType,AutoInt Param1,AutoInt Param2,AutoInt Param3,AutoInt Param4)
    # {
    #  return GetControlExClassThis(CtrHandle,@sn<current_class>)->TreeListExEvent_VirtualTableCallBack(CtrHandle,EventType,Param1,Param2,Param3,Param4);
    # }
    #
    # <> </include>
    # @end

    方法 Exui_EventPro_TreeListEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_TreeListEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {

        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case TreeListEx_Event_Item_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_MouseIn : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标进入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_MouseOut : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标离开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_FoldChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将展开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case TreeListEx_Event_Item_OtherEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目其它事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 现行选中项 <类型 = 变整数 注释 = "现行选中项" 折叠2 @默认值 = -1 @输出名 = "CurrentItem">
    参数 项目自动扩展 <类型 = 逻辑型 注释 = "为真时项目背景将填充整个客户区" 折叠2 @默认值 = 真 @输出名 = "AutoSize">
    参数 折叠钮宽度 <类型 = 整数 注释 = "折叠钮宽度" 折叠2 @默认值 = 20 @输出名 = "FoldBtnWidth">
    参数 折叠钮高度 <类型 = 整数 注释 = "折叠钮高度" 折叠2 @默认值 = 20 @输出名 = "FoldBtnHeight">
    参数 图标宽 <类型 = 整数 注释 = "图标宽" 折叠2 @默认值 = 16 @输出名 = "IcoWidth">
    参数 图标高 <类型 = 整数 注释 = "图标高" 折叠2 @默认值 = 16 @输出名 = "IcoHeight">
    参数 字体 <类型 = 字节集类 注释 = "Ex自定义字体数据 , 可在编辑器生成或编辑.或使用 结构体创建自参数( , 字体名 , 字体大小 , 字体风格 , 字体渲染模式 , 渲染参数1 , 渲染参数2) 命令生成." 折叠2
            @默认值 = 空对象 @输出名 = "Font">
    参数 子级缩进 <类型 = 整数 注释 = "子项目相对父项目的起始位置偏移 单位像素" 折叠2 @默认值 = 20 @输出名 = "ChildMigration">
    参数 背景缩进 <类型 = 整数 注释 = "项目背景起始位置 单位像素" 折叠2 @默认值 = 0 @输出名 = "BackMigration">
    参数 内容缩进 <类型 = 整数 注释 = "内容起始位置 单位像素" 折叠2 @默认值 = 20 @输出名 = "ContentMigration">
    参数 选中模式 <类型 = 整数 注释 = "选中模式:0.时不显示现行选中仅绘制使用置选中命令设置的选中项 , 1.时自动单选.2.多选模式4.ctrl多选8.shift多选.16.鼠标框选" 折叠2 @默认值 = 1
            @输出名 = "SelectMode">
    参数 表格线模式 <类型 = 整数 注释 = "参考表格线模式_前缀常量" 折叠2 @默认值 = 3 @输出名 = "LineMode">
    参数 滚动条方式 <类型 = 整数 注释 = "参考滚动条方式_前缀常量前缀常量" 折叠2 @默认值 = 0 @输出名 = "ScrollBarMode">
    参数 项目数据 <类型 = 字节集类 注释 = "用于设定组件初始项目数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ItemData">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_TreeListEx>,(AutoInt)this,@<标识值>}; control = CreateControl_TreeListEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,dtpdv(@<皮肤>,ControlType_TreeListEx),@<现行选中项>,@<项目自动扩展>,@<折叠钮宽度>,@<折叠钮高度>,@<图标宽>,@<图标高>,dtp(@<字体>),@<子级缩进>,@<背景缩进>,@<内容缩进>,@<选中模式>,@<表格线模式>,@<滚动条方式>,dtp(@<项目数据>),dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 插入项目 <公开 类型 = 变整数 注释 = "插入项目" 折叠 折叠2 @嵌入式方法 = "" @禁止流程检查 = 真 @输出名 = "InsertItem">
    参数 插入位置 <类型 = 变整数 注释 = "在指定索引前插入一项 , 索引起始值为0 , 如插入到最后填-1" 折叠2 @默认值 = 0 @输出名 = "Index">
    参数 插入数量 <类型 = 变整数 @默认值 = 0>
    参数 相关数值 <类型 = 变整数 @默认值 = 0>
    参数 图标 <注释 = "参数可提供图标句柄或图标字节集.图标句柄可用 装载位图Ex()命令装载 , 图标句柄传递给本命令后 , 即可释放 当一个图标被多次使用如列表中或图标过大时建议使用位图句柄 , 预先格式化会提升效率" 折叠2
            @匹配类型 = 通用型 @默认值 = 0 @输出名 = "Ico">
    参数 标题 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @默认值 = "" @输出名 = "Title">
    参数 字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = 0 @输出名 = "FontColor">
    参数 项目宽度 <类型 = 整数 注释 = "此宽度用于限定项目横向占用" 折叠2 @默认值 = 0 @输出名 = "ItemWidth">
    参数 项目高度 <类型 = 整数 注释 = "项目高度" 折叠2 @默认值 = 0 @输出名 = "Height">
    参数 项目类型 <类型 = 整数 注释 = "参考树形框项目风格_前缀常量 , 任一背景风格折叠形态位或叠加" 折叠2 @默认值 = 0 @输出名 = "ItemType">
    参数 默认展开 <类型 = 逻辑型 注释 = "默认展开" 折叠2 @默认值 = 假 @输出名 = "DefaultExpand">
    参数 插入模式 <类型 = 整数 注释 = "插入模式与插入位置协同工作!取值范围参考树形框插入模式_前缀常量" 折叠2 @默认值 = 0 @输出名 = "InsMode">
    {
        @ InsertItem_TreeListEx(@sn<this>.control,@<插入位置>,@<插入数量>,@<相关数值>,atimage(@<图标>),stp(@<标题>),@<字体色>,@<项目宽度>,@<项目高度>,@<项目类型>,@<默认展开>,@<插入模式>)
    }

