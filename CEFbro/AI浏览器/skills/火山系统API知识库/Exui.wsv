    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_ComboButtonEx>,(AutoInt)this,@<标识值>}; control = CreateControl_ComboButtonEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,dtpdv(@<皮肤>,ControlType_ComboButtonEx),@<按钮样式>,@<伙伴钮尺寸>,@<背景颜色>,dtp(@<图标>),@<图标宽>,@<图标高>,@<对齐方式>,stp(@<标题>),dtp(@<字体>),@<字体色>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

