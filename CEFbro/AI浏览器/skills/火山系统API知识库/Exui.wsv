    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 100 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 模式 <类型 = 整数 注释 = "0.自动" 折叠2 @默认值 = 0 @输出名 = "Mode">
    参数 横向位置 <类型 = 整数 注释 = "横向位置" 折叠2 @默认值 = 0 @输出名 = "HorizontalPosition">
    参数 纵向位置 <类型 = 整数 注释 = "纵向位置" 折叠2 @默认值 = 0 @输出名 = "VerticalPosition">
    参数 横向最大位置 <类型 = 整数 注释 = "横向最大位置" 折叠2 @默认值 = 0 @输出名 = "MaxHorizontalPosition">
    参数 纵向最大位置 <类型 = 整数 注释 = "纵向最大位置" 折叠2 @默认值 = 0 @输出名 = "MaxVerticalPosition">
    参数 保留属性1 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve1">
    参数 保留属性2 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve2">
    参数 保留属性3 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve3">
    参数 保留属性4 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve4">
    参数 保留属性5 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve5">
    参数 保留属性6 <类型 = 整数 注释 = "保留属性" 折叠2 @默认值 = 0 @输出名 = "Reserve6">
    参数 滚动条方式 <类型 = 整数 注释 = "滚动条方式" 折叠2 @默认值 = 0 @输出名 = "ScrollBarMode">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_ScrollLayoutBoxEx>,(AutoInt)this,@<标识值>}; control = CreateControl_ScrollLayoutBoxEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,dtpdv(@<皮肤>,ControlType_ScrollLayoutBoxEx),@<模式>,@<横向位置>,@<纵向位置>,@<横向最大位置>,@<纵向最大位置>,@<保留属性1>,@<保留属性2>,@<保留属性3>,@<保留属性4>,@<保留属性5>,@<保留属性6>,@<滚动条方式>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;

    }

    方法 添加组件 <公开 类型 = 逻辑型 注释 = "添加组件" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "InsertControl">
    参数 组件 <类型 = 组件Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 0 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 0 @输出名 = "Top">
    {
        @ return InsertControl_ScrollLayoutBoxEx(control,(Control_P )(@<组件>.GetControlType() !=ControlType_WindowBoxEx ? @<组件>.control : NULL),@<左边>,@<顶边>);
    }

    方法 移除组件 <公开 类型 = 逻辑型 注释 = "移除组件" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "RemoveControl">
    参数 组件 <类型 = 组件Ex @默认值 = 空对象>
    参数 目的组件 <类型 = 组件Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 0 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 0 @输出名 = "Top">
    {
