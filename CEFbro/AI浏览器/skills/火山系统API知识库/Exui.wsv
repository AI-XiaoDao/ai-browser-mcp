    方法 Exui_EventPro_AttributeEditEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_AttributeEditEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {

        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case AttributeEditEx_Event_Item_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_MouseIn : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标进入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_MouseOut : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标离开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_WillEnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_WillExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_EnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_ExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_SizeChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目尺寸被改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_FoldChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目折叠将改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AttributeEditEx_Event_Item_OtherEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目其它事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

