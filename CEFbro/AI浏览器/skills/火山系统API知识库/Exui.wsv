    方法 取按钮标题 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 索引 <类型 = 变整数 @默认值 = 0>
    {
        @ return pts(GetButtonTitle_ToolBarEx(control,@<索引>));
    }

    方法 置字体色 <公开 注释 = "置字体色" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "SetButtonFontColor">
    参数 索引 <类型 = 变整数 注释 = "按钮索引" 折叠2 @默认值 = 0 @输出名 = "Index">
    参数 字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = 0 @输出名 = "FontColor">
    {
        @ SetButtonFontColor_ToolBarEx(control,@<索引>,@<字体色>);
