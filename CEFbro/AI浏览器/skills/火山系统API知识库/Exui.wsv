类 属性编辑框Ex <公开 基础类 = 组件Ex 注释 = "AttributeEditEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "AttributeEditEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    # static AutoInt CALLBACK Exui_EventPro_ScrollCallBack_AttributeEditEx(AutoInt CtrHandle,AutoInt EventType,AutoInt Param1,AutoInt Param2,AutoInt Param3,AutoInt Param4)
