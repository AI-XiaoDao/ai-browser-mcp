    {
        @ return pts(ReadEventParamTextEx(@<数据指针>,@<数据编码>));
    }

    方法 写事件参数文本Ex <公开 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 @默认值 = 0>
    参数 数据 <类型 = 文本型 @默认值 = "">
    参数 数据编码 <类型 = 变整数 @默认值 = 0>
    {
        @ WriteEventParamTextEx(@<数据指针>,stp(@<数据>),@<数据编码>);
