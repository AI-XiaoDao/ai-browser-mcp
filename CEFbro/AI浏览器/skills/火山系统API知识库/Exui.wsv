    }

    方法 创建自组件 <公开 类型 = 变整数 注释 = "基于参数组件创建,不会创建新窗口,本类的窗口win的事件不会生效,请在来源处理,本类的窗口ex将作为子组件部分功能如控制按钮事件需要自行实现" 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex 注释 = "若组件为选择" @默认值 = 空对象>
    {
        @ return this->CreateFromParam(( AutoInt )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(AutoInt )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),0,0,-1,(AutoInt )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : ControlGetWindow(@<父级组件>.control)));
    }

    方法 创建自组件句柄 <公开 类型 = 变整数 注释 = "基于参数组件创建,不会创建新窗口,本类的窗口win的事件不会生效,请在来源处理,本类的窗口ex将作为子组件部分功能如控制按钮事件需要自行实现" 折叠 折叠2 @禁止流程检查 = 真
            @输出名 = "CreateFromControlExHandle" @强制输出 = 真>
    参数 父级组件 <类型 = 变整数 注释 = "必须为Exui组件句柄" @默认值 = 0>
    {
        @ return this->CreateFromParam(( AutoInt)@<父级组件>,NULL,0,0,-1,(AutoInt)ControlGetWindow(( Control_P)@<父级组件>));
    }

    方法 创建自窗口句柄 <公开 类型 = 变整数 注释 = "基于参数窗口句柄创建,不会创建新窗口,本类的窗口win的事件不会生效,请在来源处理,若目标窗口已经接入Exui,本命令功能与创建自组件句柄相同" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 @默认值 = 0>
    {
        @ return this->CreateFromParam(NULL,(AutoInt)@<窗口句柄>,0,0,-1,(AutoInt)@<窗口句柄>);


