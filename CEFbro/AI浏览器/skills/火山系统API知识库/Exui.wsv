类 菜单Ex <公开 基础类 = 基类Ex 注释 = "MenuEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "MenuEx">
{

    # @begin
    # <> <include>
    # public: MenuEx_P control=NULL;
    # void @an<_CopySelfFromExtra>(const @sn<current_class>& objCopyFrom)
    # {
    #  control = objCopyFrom.control;
    # }
    # <> </include>
    # @end

    方法 Exui_EventPro_MenuEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_MenuEx" @禁止流程检查 = 真>
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {
        @ switch(EventType){
        @ case Event_MenuEx_ExtendPop : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<扩展处理弹出>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_ExtendClose : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<扩展处理关闭>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_ExtendMmeasure : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<扩展处理测量>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_ExtendDraw : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<扩展处理重画>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_WillPop : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<将弹出>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Pop : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<已弹出>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_WillClose : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<将关闭>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Close : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<已关闭>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_MouseIn : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标进入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Event_MenuEx_Item_MouseOut : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标离开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        @ return NULL;

    }

