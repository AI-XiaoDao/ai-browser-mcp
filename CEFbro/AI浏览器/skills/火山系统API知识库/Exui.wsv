        @ return IsPopUp_MenuEx(control,(MenuInfoEx_P)@<菜单项句柄>);
    }

    方法 弹出 <公开 折叠 @禁止流程检查 = 真>
    参数 菜单项句柄 <类型 = 变整数 注释 = "MenuInfo*" @默认值 = 0>
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 父窗口句柄 <类型 = 变整数 注释 = "HWND" @默认值 = 0>
    参数 弹出模式 <类型 = 整数 注释 = "莫乱填非特殊情况请填0,需要其它值的时候会有例子" @默认值 = 0>
    参数 例外组件 <类型 = 变整数 @默认值 = 0>
    参数 相对弹出模式 <类型 = 整数 注释 = "用于设定左顶宽高参数与相对相对组件模式 详见 相对弹出模式常亮 此参数通常用于高dpi适配时使用" 折叠2 @输出名 = "ReferType" @默认值 = 0>
    参数 相对弹出组件 <类型 = 变整数 注释 = "为上一参数提供参考组件 此参数通常用于高dpi适配时使用" 折叠2 @输出名 = "ReferControl" @默认值 = 0>
    {
        @ PopUp_MenuEx(control,(MenuInfoEx_P)@<菜单项句柄>,@<左边>,@<顶边>,(HWND)@<父窗口句柄>,@<弹出模式>,(void *)@<例外组件>,ReferType,(Control_P)ReferControl);
    }

    方法 关闭 <公开 折叠 @禁止流程检查 = 真>
    参数 菜单项句柄 <类型 = 变整数 注释 = "MenuInfo*" @默认值 = 0>
    参数 关闭模式 <类型 = 逻辑型 @默认值 = 假>
    {
        @ Close_MenuEx(control,(MenuInfoEx_P)@<菜单项句柄>,@<关闭模式>);
    }

    方法 插入项目 <公开 类型 = 变整数 折叠 折叠2 @嵌入式方法 = "" @禁止流程检查 = 真>
    参数 父菜单项句柄 <类型 = 变整数 注释 = "MenuInfo*" @默认值 = 0>
