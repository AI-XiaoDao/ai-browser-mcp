类 Exui核心命令 <公开 折叠 折叠2 @全局类 = 真 @文档 = "category = \"Exui核心命令\"">
{
    方法 初始化Exui <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 @默认值 = "">
    参数 数据 <类型 = 字节集类 @默认值 = 空对象>
    {
        变量 data <类型 = 变整数 @输出名 = "data">
        变量 datalen <类型 = 整数 @输出名 = "datalen">
        data = 0
        datalen = 数据.取字节集长度 ()
        如果 (datalen > 0)
        {
            data = 取字节集指针 (数据)
        }
        否则 (取文本长度 (路径) > 0)
        {
            data = 取文本指针 (路径)
            datalen = 0

        }

        @ AutoInt ExuihIns =(AutoInt)InitExui(( TCHAR *)@<data>,@<datalen>);
        @ if(CallInternalFunction_Ex){CallInternalFunction_Ex(2021,(AutoInt)ControlEx::Exui_EventPro_Element_ControlEx,0,0,9);}
        @ return ExuihIns;

    }

    方法 调用exui内部功能 <公开 静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "CallInternalFunction_Ex">
    参数 功能编号 <类型 = 变整数 @默认值 = 0>
    参数 参数1 <类型 = 变整数 注释 = "文本型可用PTA或者PTU获取数据" 折叠2 @默认值 = 0 @输出名 = "Param1">
    参数 参数2 <类型 = 变整数 注释 = "文本型可用PTA或者PTU获取数据" 折叠2 @默认值 = 0 @输出名 = "Param2">
    参数 参数3 <类型 = 变整数 注释 = "文本型可用PTA或者PTU获取数据" 折叠2 @默认值 = 0 @输出名 = "Param3">
    参数 参数4 <类型 = 变整数 注释 = "参数4" 折叠2 @默认值 = 0 @输出名 = "Param4">
    {
        @ return CallInternalFunction_Ex(@<功能编号>,@<参数1>,@<参数2>,@<参数3>,@<参数4>);
    }

    方法 装载位图Ex <公开 静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @嵌入式方法 = "" @输出名 = "LoadImageEx">
    参数 资源数据 <类型 = 字节集类 @默认值 = 空对象>
    参数 预处理模式 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数 @默认值 = 0>
    参数 高度 <类型 = 整数 @默认值 = 0>
    参数 圆角度 <类型 = 整数 @默认值 = 0>
    参数 边线颜色 <类型 = 整数 @默认值 = 0>
    参数 边线宽度 <类型 = 整数 @默认值 = 0>
    参数 对齐方式 <类型 = 整数 @默认值 = 0>
    {
        @ (AutoInt)LoadImageEx(dtp(@<资源数据>),@<预处理模式>,@<宽度>,@<高度>,@<圆角度>,@<边线颜色>,@<边线宽度>,@<对齐方式>)
    }

    方法 销毁位图Ex <公开 静态 折叠 @禁止流程检查 = 真>
    参数 图片句柄 <类型 = 变整数>
    {
        @ DestroyImageEx(( void *)@<图片句柄>);
    }

    方法 取位图属性Ex <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 图片句柄 <类型 = 变整数>
    参数 欲取类型 <类型 = 整数 注释 = "0:gdi+位图句柄 1: 宽度 2:高度">
    {
        @ return GetImageAttributeEx(( void *)@<图片句柄>,@<欲取类型>);
    }

    方法 取位图数据Ex <公开 静态 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 图片句柄 <类型 = 变整数>
    {
        @ return ptd(GetImageData(( void *)@<图片句柄>));
    }

    方法 申请内存数据Ex <公开 静态 类型 = 变整数 注释 = "返回值需自行释放" 折叠 @禁止流程检查 = 真>
    参数 初始数据指针 <类型 = 变整数>
    参数 数据长度 <类型 = 整数>
    {
        @ return (AutoInt)CreateBinEx(( void *)@<初始数据指针>,@<数据长度>);

    }

    方法 释放内存数据Ex <公开 静态 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    {
        @ DeleteBinEx(( BinEx_P)@<数据指针>);

    }

    方法 取内存数据地址Ex <公开 静态 类型 = 变整数 注释 = "返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    {
        @ return (AutoInt)GetBinExDataPointer(( BinEx_P)@<数据指针>);

    }

    方法 取内存数据长度Ex <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    {
        @ return (AutoInt)GetBinExDatalength(( BinEx_P)@<数据指针>);


    }

    方法 执行内存数据命令Ex <公开 静态 类型 = 变整数 注释 = "返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 @默认值 = 0>
    参数 命令 <类型 = 变整数 @默认值 = 0>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    参数 参数3 <类型 = 变整数 @默认值 = 0>
    参数 参数4 <类型 = 变整数 @默认值 = 0>
    {
        @ return (AutoInt)ExecuteBinExCmd(( BinEx_P)@<数据指针>,@<命令>,@<参数1>,@<参数2>,@<参数3>,@<参数4>);


    }

    方法 内存数据到数据Ex <公开 静态 类型 = 字节集类 注释 = "Exui字节集到字节集类" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "必须为Exui提供的指针">
    {
        @ return ptd(@<数据指针>);
    }

    方法 数据到内存数据Ex <公开 静态 类型 = 变整数 注释 = "字节集类到Exui字节集指针,返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ return (AutoInt)dtp(@<数据>);

    }

    方法 内存数据到文本Ex <公开 静态 类型 = 文本型 注释 = "Exui文本指针到文本" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    {
        @ return pts(@<数据指针>);
    }

    方法 文本到内存数据Ex <公开 静态 类型 = 变整数 注释 = "文本到Exui文本指针,返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ return (AutoInt)stp(@<数据>);
    }

    方法 PTD <公开 静态 类型 = 字节集类 注释 = "Exui字节集到字节集类" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "必须为Exui提供的指针">
    {
        @ return ptd(@<数据指针>);
    }

    方法 DTP <公开 静态 类型 = 变整数 注释 = "字节集类到Exui字节集指针,返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ return (AutoInt)dtp(@<数据>);

    }

    方法 PTS <公开 静态 类型 = 文本型 注释 = "Exui文本指针到文本" 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数>
    {
        @ return pts(@<数据指针>);
    }

    方法 STP <公开 静态 类型 = 变整数 注释 = "文本到Exui文本指针,返回值无须释放" 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ return (AutoInt)stp(@<数据>);

    }

    方法 读事件参数数据Ex <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 @默认值 = 0>
    参数 数据编码 <类型 = 变整数 @默认值 = 0>
    {
        @ return ptd(ReadEventParamTextEx(@<数据指针>,@<数据编码>));
    }

    方法 写事件参数数据Ex <公开 折叠 @禁止流程检查 = 真>
