类 Exui窗口程序 <公开 基础类 = 可设计类 折叠 折叠2 @输出名 = "ExuiProgram"
        @设计器 = "name = \"Exui界面设计器\"\r\ndll_file_name\r\n{\r\n x64 = \"designer\\exui_designer_x64.dll\"\r\n win32 = \"designer\\exui_designer_win32.dll\"\r\n}\r\nauto_generate_mark = \"exui\"\r\nuser_param = 1"
        @可插入程序类 = "icon=\"designer\\layout.bmp\"\r\nexplain=\"在所插入新Exui窗口程序类上单击鼠标右键,选择\\\"打开Exui设计器\\\"菜单项即可设计该Exui窗口程序的内容.\"">
