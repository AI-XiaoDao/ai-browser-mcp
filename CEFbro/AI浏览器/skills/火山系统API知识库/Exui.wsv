类 超级列表框Ex <公开 基础类 = 组件Ex 注释 = "SuperListBoxEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "SuperListBoxEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    # static AutoInt CALLBACK Exui_EventPro_ScrollCallBack_SuperListBoxEx(AutoInt CtrHandle,AutoInt EventType,AutoInt Param1,AutoInt Param2,AutoInt Param3,AutoInt Param4)
    # {
    #  return GetControlExClassThis(CtrHandle,@sn<current_class>)->SuperListBoxExEvent_ScrollCallBack(CtrHandle,EventType,Param1,Param2,Param3,Param4);
    # }
    #
    # static AutoInt CALLBACK Exui_EventPro_VirtualTableCallBack_SuperListBoxEx(AutoInt CtrHandle,AutoInt EventType,AutoInt Param1,AutoInt Param2,AutoInt Param3,AutoInt Param4)
    # {
    #  return GetControlExClassThis(CtrHandle,@sn<current_class>)->SuperListBoxExEvent_VirtualTableCallBack(CtrHandle,EventType,Param1,Param2,Param3,Param4);
    # }
    #
    #
    # <> </include>
    # @end

    方法 Exui_EventPro_SuperListBoxEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_SuperListBoxEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {

        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case SuperListBoxEx_Event_Item_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_MouseIn : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标进入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_MouseOut : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标离开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_WillEnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_WillExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_EnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_ExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_SizeChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目尺寸被改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case SuperListBoxEx_Event_Item_OtherEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目其它事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
