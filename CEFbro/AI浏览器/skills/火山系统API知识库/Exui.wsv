类 窗口Ex <公开 基础类 = 组件Ex 注释 = "WindowEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "WindowEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    # <> </include>
    # @end

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 100 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 图标 <类型 = 字节集类 注释 = "常用图片格式 , 不支持ico.本属性仅负责窗口的界面展示图标不与其它数据同步.以便在不同场景的个性化控制.置空不显示." 折叠2 @默认值 = 空对象 @输出名 = "Icon">
    参数 标题 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @默认值 = "Exui火山版" @输出名 = "Title">
    参数 字体 <类型 = 字节集类 注释 = "Ex自定义字体数据 , 可在编辑器生成或编辑.或使用 结构体创建自参数( , 字体名 , 字体大小 , 字体风格 , 字体渲染模式 , 渲染参数1 , 渲染参数2) 命令生成." 折叠2
            @默认值 = 空对象 @输出名 = "Font">
    参数 字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = 0 @输出名 = "FontColor">
    参数 分层透明 <类型 = 整数 注释 = "若制作异形窗口或透明窗口设置此属性 取值范围0-256 , 0-255 为开启分层透明的透明度 , 256为关闭分层透明." 折叠2 @默认值 = 256
            @输出名 = "LayeredTransparency">
    参数 拖动模式 <类型 = 整数 @默认值 = 1>
    参数 尺寸调整模式 <类型 = 整数 注释 = "设定禁止鼠标拖拽调整尺寸部位 参考 尺寸调整模式_前缀常量 多个部位可用位或叠加 511为禁止全部" 折叠2 @默认值 = 0 @输出名 = "DragSizeMode">
    参数 最大化模式 <类型 = 整数 注释 = "该属性设定窗口最大化时 尺寸位置限定模式 参考 尺寸限定模式_ 前缀常量 档位自定义时 需要在其它事件内自行处理 可看例程" 折叠2 @默认值 = 0 @输出名 = "MaxMode">
    参数 控制钮 <类型 = 字节集类 注释 = "控制钮扩展元素.可在设计模式时使用编辑器设计.运行时有相关操作函数.不建议直接操作此属性调整控制钮." 折叠2 @默认值 = 空对象 @输出名 = "ButtonData">
    参数 控制钮动画参数 <类型 = 整数 注释 = " 0 为无效果 1-255 可指定渐显渐隐 速度 也可使用高地位分别指定 步进 1-255 帧延迟 单位毫秒 这里有个 2621465 你可以尝试下" 折叠2 @默认值 = 0
            @输出名 = "AnimationParam">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参数具体参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_WindowEx>,(AutoInt)this,@<标识值>}; control = CreateControl_WindowEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtpdv(@<鼠标光标>,Rc_Cur_WindowEx),@<标识值>,dtpdv(@<皮肤>,ControlType_WindowEx),dtp(@<图标>),stp(@<标题>),dtp(@<字体>),@<字体色>,@<分层透明>,@<拖动模式>,@<尺寸调整模式>,@<最大化模式>,dtpdv(@<控制钮>,(ControlType_WindowBoxEx+1)),@<控制钮动画参数>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 插入控制钮 <公开 类型 = 变整数 注释 = "插入控制钮" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "InsertButton">
    参数 插入位置 <类型 = 变整数 注释 = "在指定索引前插入一项 , 索引起始值为0 , 如插入到最后填-1" 折叠2 @默认值 = 0 @输出名 = "Index">
    参数 相关数值 <类型 = 变整数 @默认值 = 0>
    参数 按钮类型 <类型 = 整数 注释 = "参考控制钮类型_前缀常量" 折叠2 @默认值 = 0 @输出名 = "ButtonType">
    参数 控制按钮皮肤 <类型 = 字节集类 @默认值 = 空对象>
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 假 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 选中 <类型 = 逻辑型 注释 = "选中" 折叠2 @默认值 = 假 @输出名 = "Selected">
    {
        @ return InsertButton_WindowEx(control,@<插入位置>,@<相关数值>,@<按钮类型>,dtp(@<控制按钮皮肤>),@<可视>,@<禁止>,@<选中>);
    }

    方法 删除控制钮 <公开 注释 = "删除控制钮" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "DeleteButton">
