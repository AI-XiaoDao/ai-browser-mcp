类 富文本框Ex <公开 基础类 = 组件Ex 注释 = "RichEditEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "RichEditEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    # <> </include>
    # @end

    方法 Exui_EventPro_RichEditEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_RichEditEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {

        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case RichEditEx_Event_ContentChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<内容被改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case RichEditEx_Event_SelectionChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<选择区被改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case RichEditEx_Event_OtherExtendEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<接口其它事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 内容 <类型 = 文本型 注释 = "内容赋值权重较高 , 其不受输入方式和最大文本长度以及是否允许多行约束.若要严格限定请自行在赋值前校验数据" 折叠2 @默认值 = "富文本框Ex" @输出名 = "Content">
    参数 类型 <类型 = 整数 注释 = "0纯文本 1富文本" 折叠2 @默认值 = 0 @输出名 = "Type">
    参数 背景透明 <类型 = 逻辑型 折叠2 @默认值 = 假 @输出名 = "BackTransparent">
    参数 背景色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择 若有不显示光标需求可将此颜色设定为 0透明的颜色值" 折叠2 @默认值 = -1
            @输出名 = "BackColor">
    参数 光标色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择 若有不显示光标需求可将此颜色设定为 0透明的颜色值" 折叠2 @默认值 = -33554432
            @输出名 = "CursorColor">
    参数 默认字符格式 <类型 = 字节集类 注释 = "默认字符格式" 折叠2 @默认值 = 空对象 @输出名 = "DefaultCharFormat">
    参数 默认段落格式 <类型 = 字节集类 注释 = "默认段落格式" 折叠2 @默认值 = 空对象 @输出名 = "DefaultParaFormat">
    参数 输入方式 <类型 = 整数 注释 = "参考 输入模式_ 前缀常量 多种输入模式可用 位或() 组合" 折叠2 @默认值 = 0 @输出名 = "InputMode">
    参数 最大允许长度 <类型 = 整数 注释 = "限定最大输入的字符数量 , 与易编辑框不同本属性限定的是字符个数 , 而非字符数据长度.另本参数无法约束直接调整内容属性 或其它代码直接设定内容值" 折叠2 @默认值 = 0
            @输出名 = "MaxInput">
    参数 密码替换符 <类型 = 文本型 注释 = "限定一个字符请不要设定多个字符挑战容错率" 折叠2 @默认值 = "*" @输出名 = "PasswordChar">
    参数 是否允许多行 <类型 = 逻辑型 注释 = "限定输入内容可否多行 , 本参数无法约束直接调整内容属性 或其它代码直接设定内容值" 折叠2 @默认值 = 真 @输出名 = "Multiline">
    参数 自动换行 <类型 = 逻辑型 注释 = "自动换行" 折叠2 @默认值 = 假 @输出名 = "Wrapped">
    参数 滚动条方式 <类型 = 整数 注释 = "参考滚动条方式_前缀常量前缀常量" 折叠2 @默认值 = 0 @输出名 = "ScrollBarMode">
    参数 菜单项目宽度 <类型 = 整数 @默认值 = 100>
    参数 菜单项目高度 <类型 = 整数 @默认值 = 30>
    参数 菜单字体 <类型 = 字节集类 注释 = "自定义字体数据 , 可在编辑器生成或编辑.或使用 结构体创建自参数( , 字体名 , 字体大小 , 字体风格 , 字体渲染模式 , 渲染参数1 , 渲染参数2) 命令生成." 折叠2
            @默认值 = 空对象 @输出名 = "MenuFont">
    参数 菜单字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = -33554432 @输出名 = "MenuFontColor">
    参数 菜单禁止字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = -33554432
            @输出名 = "MenuDisabledFontColor">
    参数 菜单透明度 <类型 = 整数 注释 = "菜单透明度取置范围0-255" 折叠2 @默认值 = 255 @输出名 = "MenuTransparency">
    参数 菜单语言 <类型 = 整数 注释 = "0中文 1英文(暂无实现)" 折叠2 @默认值 = 0 @输出名 = "MenuLanguage">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_RichEditEx>,(AutoInt)this,@<标识值>}; control = CreateControl_RichEditEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtpdv(@<鼠标光标>,Rc_Cur_RichEditEx),@<标识值>,dtpdv(@<皮肤>,ControlType_RichEditEx),stp(@<内容>),@<类型>,@<背景透明>,@<背景色>,@<光标色>,dtp(@<默认字符格式>),dtp(@<默认段落格式>),@<输入方式>,@<最大允许长度>,stp(@<密码替换符>),@<是否允许多行>,@<自动换行>,@<滚动条方式>,@<菜单项目宽度>,@<菜单项目高度>,dtp(@<菜单字体>),@<菜单字体色>,@<菜单禁止字体色>,@<菜单透明度>,@<菜单语言>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 插入文本 <公开 注释 = "插入文本" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "InsertText">
    参数 插入位置 <类型 = 变整数 注释 = "位置从0开始 , 以字符个数作为度量单位.-1为插入到内容末尾" 折叠2 @默认值 = 0 @输出名 = "Index">
