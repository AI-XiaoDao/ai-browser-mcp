    方法 创建自参数 <公开 类型 = 变整数 折叠 折叠2 @输出名 = "CreateFromParam" @强制输出 = 真 @禁止流程检查 = 真>
    参数 参数1 <类型 = 变整数 @输出名 = "Param1">
    参数 参数2 <类型 = 变整数 @输出名 = "Param2">
    参数 参数3 <类型 = 变整数 @输出名 = "Param3">
    参数 参数4 <类型 = 变整数 @输出名 = "Param4">
    参数 参数5 <类型 = 变整数 @输出名 = "Param5">
    参数 参数6 <类型 = 变整数 @输出名 = "Param6">
    {
        @ InitExui(NULL,NULL); if(!CallInternalFunction_Ex){return false;} CallInternalFunction_Ex(2021,(AutoInt)ControlEx::Exui_EventPro_Element_ControlEx,0,0,9);
        @ AutoInt controlinfo=(( AutoInt)this)+sizeof(ExuiProgram)+sizeof(AutoInt);
        @ BinEx_P Exuidata = ReadRcDataEx(RT_RCDATA,*(short* )(controlinfo - sizeof(AutoInt)));
        @ if(Param6){(( BaseEx*)controlinfo)->control=(Control_P)Param6; controlinfo+= sizeof(WindowBoxEx);}
        @ AutoInt returnvalue = LoadControlEx(( Control_P)Param1,(HWND)Param2,(AutoInt)Param3,(AutoInt)Param4,(AutoInt)Param5,Exuidata,(AutoInt)Exui_EventPro_LoadControlEx,(AutoInt)&controlinfo);
        @ DeleteBinEx(Exuidata);
        @ return returnvalue;
    }

    方法 创建主窗口 <公开 类型 = 变整数 注释 = "创建本窗口类的对象并将其作为程序的主窗口" 注释 = "注意:" 注释 = " 1. 程序中必须存在且只能存在一个主窗口,调用本方法后,主窗口将被设置为本窗口;"
            注释 = " 2. 主窗口必须在程序的\"启动类\"中存在成员变量定义,避免其在程序退出前被释放," 注释 = "否则将可能导致程序运行时崩溃." 折叠 折叠2 @禁止流程检查 = 真>
    {
        @ return this->CreateFromParam(NULL,NULL,1,9,-1,NULL);
    }

    方法 创建窗口 <公开 类型 = 变整数 注释 = "创建本窗口类的对象(非主窗口)" 折叠 @禁止流程检查 = 真>
    参数 父窗口 <类型 = 窗口Win 注释 = "HWND" @默认值 = 空对象>
    {
        @ return this->CreateFromParam(NULL,(AutoInt)@<父窗口>.control,1,0,-1,NULL);
    }

