            注释 = "lParam" 注释 = "正在显示的窗口的状态。 如果 lParam 为零，则由于调用 ShowWindow 函数而发送消息;否则， lParam 为以下值之一。" 注释 = "SW _OTHERUNZOOM" 注释 = "4"
            注释 = "由于已还原最大化窗口或最小化窗口，该窗口被覆盖。" 注释 = "SW _OTHERZOOM" 注释 = "2" 注释 = "窗口已被最大化。" 注释 = "SW _PARENTCLOSING" 注释 = "1"
