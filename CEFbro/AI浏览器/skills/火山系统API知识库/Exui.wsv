    方法 Exui_EventPro_FilterPanelEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_FilterPanelEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
