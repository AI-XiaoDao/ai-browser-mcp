    参数 选中字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "SelectedFontColor"
            @默认值 = -16777217>
    参数 选中背景色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "SelectedColor" @默认值 = -436172545>
    参数 光标色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择 若有不显示光标需求可将此颜色设定为 0透明的颜色" 折叠2
            @输出名 = "CursorColor" @默认值 = -33554432>
    参数 滚动条方式 <类型 = 整数 注释 = "参考滚动条方式_前缀常量前缀常量" 折叠2 @输出名 = "ScrollBarMode" @默认值 = 0>
