    常量 内侧 <公开 类型 = 整数 值 = 1 注释 = "Complement 指定由从新区域移除的现有区域的结果替代现有区域。换言之，从新区域中排除现有区域。">
    常量 外侧 <公开 类型 = 整数 值 = 2 注释 = "1.0没有使用">
    常量 左侧 <公开 类型 = 整数 值 = 3 注释 = "1.0没有使用">
    常量 右侧 <公开 类型 = 整数 值 = 4 注释 = "1.0没有使用">

    #
}

类 合并模式 <公开 折叠 折叠2 @全局类 = 真 @文档 = "category = \"Exui常量\"">
{
    常量 替代 <公开 类型 = 整数 值 = 0 注释 = "Replace 一个剪辑区域被另一个剪辑区域替代。">
    常量 交集 <公开 类型 = 整数 值 = 1 注释 = "Intersect 通过采用两个剪辑区域的交集组合两个剪辑区域。">
    常量 并集 <公开 类型 = 整数 值 = 2 注释 = "Union 通过采用两个剪辑区域的联合组合两个剪辑区域。">
    常量 并集减交集 <公开 类型 = 整数 值 = 3 注释 = "Xor 两者的并集减去两者的交集。通过只采纳单独由其中一个区域（而非两个区域一起）包括的范围来组合两个剪辑区域。">
    常量 排除新区域 <公开 类型 = 整数 值 = 4 注释 = "Exclude 指定由从现有区域移除的新区域的结果替代现有区域。换言之，从现有区域中排除新区域。">
    常量 排除旧区域 <公开 类型 = 整数 值 = 5 注释 = "Complement 指定由从新区域移除的现有区域的结果替代现有区域。换言之，从新区域中排除现有区域。">

    #
}

