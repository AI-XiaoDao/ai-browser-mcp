    方法 创建 <公开 类型 = 变整数 注释 = "HWND" 折叠 @禁止流程检查 = 真>
    参数 模式 <类型 = 整数 注释 = "0:普通载入 1:模态载入 2:普通带消息循环" @默认值 = 0>
    参数 位置 <类型 = 整数 注释 = "初始值为“1”。0:通常 1:居中" @默认值 = 1>
    参数 父窗口 <类型 = 基类Ex 注释 = "HWND" @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 50 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 50 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 380 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 250 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 图标 <类型 = 字节集类 注释 = "常用图片格式 , 不支持ico.本属性仅负责窗口的界面展示图标不与其它数据同步.以便在不同场景的个性化控制.置空不显示." 折叠2 @默认值 = 空对象 @输出名 = "Icon">
    参数 标题 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @默认值 = "" @输出名 = "Title">
    参数 总在最前 <类型 = 逻辑型 @默认值 = 假>
    参数 任务栏显示 <类型 = 逻辑型 @默认值 = 真>
    参数 退出键关闭 <类型 = 逻辑型 @默认值 = 假>
    参数 类名 <类型 = 文本型 @默认值 = "">
    参数 类风格 <类型 = 整数 @默认值 = 0>
    参数 扩展风格 <类型 = 整数 @默认值 = 0>
    参数 窗口风格 <类型 = 整数 @默认值 = 268959744>
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    {
        @ static @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_WindowBoxEx>,(AutoInt)this,@<标识值>}; control =(Control_P)Create_WindowBoxEx(@<模式>,@<位置>,(HWND)@<父窗口>.control,@<左边>,@<顶边>,@<宽度>,@<高度>,(WNDPROC)-1,(AutoInt)InitAttr,@<可视>,@<禁止>,dtp(@<图标>),stp(@<标题>),@<总在最前>,@<任务栏显示>,@<退出键关闭>,stp(@<类名>),@<类风格>,@<扩展风格>,@<窗口风格>,(AutoInt)InitAttr); return (AutoInt)control;
    }

