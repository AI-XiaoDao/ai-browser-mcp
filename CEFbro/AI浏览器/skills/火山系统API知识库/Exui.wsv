    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 0 @输出名 = "Top">
    {
        @ return InsertControl_ExtendContainerEx(control,@<组件类型>,@<组件句柄>,@<左边>,@<顶边>);
    }

