    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 当前进度 <类型 = 变整数 注释 = "当前进度" 折叠2 @默认值 = -1 @输出名 = "CurrentPosition">
    参数 纵向 <类型 = 整数 注释 = "纵向" 折叠2 @默认值 = 20 @输出名 = "Vertical">
    参数 间距 <类型 = 整数 注释 = "间距" 折叠2 @默认值 = 20 @输出名 = "Spacing">
    参数 布局样式 <类型 = 整数 注释 = "布局样式 , 目前就一种有特殊需求可找作者定制" 折叠2 @默认值 = 1 @输出名 = "LayoutStyle">
    参数 布局参数 <类型 = 整数 注释 = "布局参数 , 控制部件可见性 可位或叠加使用 1禁止调节按钮 2禁止条目调节按钮" 折叠2 @默认值 = 0 @输出名 = "LayoutParam">
    参数 控制模式 <类型 = 整数 注释 = "控制模式 1鼠标进入暂停滚动" 折叠2 @默认值 = 0 @输出名 = "CtrlModel">
    参数 轮播模式 <类型 = 整数 注释 = "轮播模式 0逐帧轮播1整体轮播" 折叠2 @默认值 = 0 @输出名 = "CarouselMode">
    参数 滚动方向 <类型 = 整数 注释 = "滚动方向" 折叠2 @默认值 = 0 @输出名 = "ScrollDirection">
    参数 自动播放 <类型 = 整数 注释 = "自动播放" 折叠2 @默认值 = 0 @输出名 = "AutoPlay">
    参数 停留时长 <类型 = 整数 注释 = "停留时长" 折叠2 @默认值 = 0 @输出名 = "DurationTime">
    参数 帧延迟 <类型 = 整数 注释 = "帧延迟单位毫秒" 折叠2 @默认值 = 0 @输出名 = "FrameDelay">
    参数 帧步进 <类型 = 整数 注释 = "帧步进单位毫秒为负数时为百分比" 折叠2 @默认值 = 0 @输出名 = "Step">
    参数 滚动算法 <类型 = 整数 注释 = "滚动算法 , 备用参数暂时无用" 折叠2 @默认值 = 0 @输出名 = "AlgorithmMode">
    参数 项目数据 <类型 = 字节集类 注释 = "用于设定组件初始项目数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ItemData">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)Exui_EventPro_CarouselBoxEx,(AutoInt)this,@<标识值>}; control = CreateControl_CarouselBoxEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,dtpdv(@<皮肤>,ControlType_CarouselBoxEx),@<当前进度>,@<纵向>,@<间距>,@<布局样式>,@<布局参数>,@<控制模式>,@<轮播模式>,@<滚动方向>,@<自动播放>,@<停留时长>,@<帧延迟>,@<帧步进>,@<滚动算法>,dtp(@<项目数据>),dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 插入项目 <公开 类型 = 变整数 注释 = "插入项目" 折叠 折叠2 @嵌入式方法 = "" @禁止流程检查 = 真 @输出名 = "InsertItem">
    参数 插入位置 <类型 = 变整数 注释 = "在指定索引前插入一项 , 索引起始值为0 , 如插入到最后填-1" 折叠2 @默认值 = 0 @输出名 = "Index">
    参数 相关数值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "背景配色 数据为4个颜色整数到字节集后相加 分别为普通 热点 选中 选中热点" 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 图标 <注释 = "参数可提供图标句柄或图标字节集.图标句柄可用 装载位图Ex()命令装载 , 图标句柄传递给本命令后 , 即可释放 当一个图标被多次使用如列表中或图标过大时建议使用位图句柄 , 预先格式化会提升效率" 折叠2
            @匹配类型 = 通用型 @默认值 = 0 @输出名 = "Ico">
    参数 图标宽度 <类型 = 整数 注释 = "图标宽度" 折叠2 @默认值 = 0 @输出名 = "IcoWidth">
    参数 图标高度 <类型 = 整数 注释 = "图标高度" 折叠2 @默认值 = 0 @输出名 = "IcoHeight">
    参数 标题 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @默认值 = "" @输出名 = "Title">
    参数 字体 <类型 = 字节集类 注释 = "字体" 折叠2 @默认值 = 空对象 @输出名 = "Font">
    参数 字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = 0 @输出名 = "FontColor">
    参数 热点字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @默认值 = 0 @输出名 = "HotspotFontColor">
    参数 项目类型 <类型 = 整数 注释 = "参考轮播项目类型_前缀常量0100200" 折叠2 @默认值 = 0 @输出名 = "ItemType">
    参数 对齐方式 <类型 = 整数 注释 = "取决于项目类型" 折叠2 @默认值 = 0 @输出名 = "Align">
    参数 保留参数 <类型 = 整数 注释 = "保留参数" 折叠2 @默认值 = 0 @输出名 = "Reserve">
    参数 项目尺寸 <类型 = 整数 注释 = "项目尺寸" 折叠2 @默认值 = 30 @输出名 = "Size">
    {
        @ InsertItem_CarouselBoxEx(@sn<this>.control,@<插入位置>,@<相关数值>,dtp(@<皮肤>),atimage(@<图标>),@<图标宽度>,@<图标高度>,stp(@<标题>),dtp(@<字体>),@<字体色>,@<热点字体色>,@<项目类型>,@<对齐方式>,@<保留参数>,@<项目尺寸>)
    }

