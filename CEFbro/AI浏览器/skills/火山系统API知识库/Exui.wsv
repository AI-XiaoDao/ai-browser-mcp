    方法 Exui_EventPro_AdvancedGridEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_AdvancedGridEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {

        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case AdvancedGridEx_Event_Item_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键单击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键放开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键按下>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目左键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目右键双击>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_MouseIn : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标进入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_MouseOut : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目鼠标离开>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_WillEnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_WillExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目将退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_EnterEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目进入编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_ExitEdit : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目退出编辑>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_SizeChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目尺寸被改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_FoldChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目折叠将改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case AdvancedGridEx_Event_Item_OtherEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<项目其它事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据,可在编辑器中设计,或赋值设计后的资源" 折叠2 @默认值 = 空对象 @输出名 = "Skin">
    参数 现行选中项 <类型 = 变整数 注释 = "现行选中项" 折叠2 @默认值 = -1 @输出名 = "CurrentItem">
    参数 现行选中列 <类型 = 变整数 注释 = "现行选中列" 折叠2 @默认值 = -1 @输出名 = "CurrentColumn">
    参数 表头行数 <类型 = 变整数 注释 = "表头行数" 折叠2 @默认值 = 2 @输出名 = "HeaderRowNum">
    参数 表头列数 <类型 = 变整数 注释 = "表头列数" 折叠2 @默认值 = 2 @输出名 = "HeaderColumnNum">
    参数 底悬浮行数 <类型 = 变整数 注释 = "底悬浮行数" 折叠2 @默认值 = 2 @输出名 = "BottomFixedRow">
    参数 右悬浮列数 <类型 = 变整数 注释 = "右悬浮列数" 折叠2 @默认值 = 2 @输出名 = "RightFixedColumn">
    参数 调整模式 <类型 = 整数 注释 = "参考 高表调整模式_前缀常量" 折叠2 @默认值 = -1 @输出名 = "AdjustmentMode">
    参数 选中模式 <类型 = 整数 注释 = "选中模式:0.时不显示现行选中仅绘制使用置选中命令设置的选中项 , 1.时自动单选.2.多选模式4.ctrl多选8.shift多选.16.鼠标框选" 折叠2 @默认值 = 1
            @输出名 = "SelectMode">
    参数 整行选择 <类型 = 逻辑型 注释 = "整行选择" 折叠2 @默认值 = 真 @输出名 = "EntireLine">
    参数 事件模式 <类型 = 整数 注释 = "1启用表头事件 2启用表项事件 4启用单元格事件 可使用位或叠加.启用多个事件时需要事件处理函数里判断事件来源" 折叠2 @默认值 = 4 @输出名 = "EventMode">
    参数 编辑模式 <类型 = 整数 注释 = "1启用左键按下编辑 2启用左键单击编辑 4.启用左键双击编辑 注意选择合适的编辑模式避免与选中模式和编辑元素冲突" 折叠2 @默认值 = 4 @输出名 = "EditMode">
    参数 树形模式 <类型 = 逻辑型 @默认值 = 假>
    参数 表格线模式 <类型 = 整数 注释 = "参考 表格线模式_前缀常量" 折叠2 @默认值 = 7 @输出名 = "LineMode">
    参数 滚动条方式 <类型 = 整数 注释 = "参考滚动条方式_前缀常量前缀常量" 折叠2 @默认值 = 0 @输出名 = "ScrollBarMode">
    参数 项目数据 <类型 = 字节集类 注释 = "用于设定组件初始项目数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ItemData">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_AdvancedGridEx>,(AutoInt)this,@<标识值>}; control = CreateControl_AdvancedGridEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtpdv(@<鼠标光标>,Rc_Cur_AdvancedGridEx),@<标识值>,dtpdv(@<皮肤>,ControlType_AdvancedGridEx),@<现行选中项>,@<现行选中列>,@<表头行数>,@<表头列数>,@<底悬浮行数>,@<右悬浮列数>,@<调整模式>,@<选中模式>,@<整行选择>,@<事件模式>,@<编辑模式>,@<树形模式>,@<表格线模式>,@<滚动条方式>,dtp(@<项目数据>),dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 插入列 <公开 类型 = 变整数 注释 = "插入列" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "InsertColumn">
    参数 插入位置 <类型 = 变整数 注释 = "在指定索引前插入一项,索引起始值为0,如插入到最后填-1" 折叠2 @默认值 = 0 @输出名 = "ColumnIndex">
