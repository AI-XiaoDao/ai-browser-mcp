类 滚动条Ex <公开 基础类 = 组件Ex 注释 = "ScrollBarEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "ScrollBarEx">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
