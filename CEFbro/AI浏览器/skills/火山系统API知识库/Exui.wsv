        @ SetItemEditConfig_SuperListBoxEx(control,AttributeId,InputMode,MaxInput,stp(PasswordChar),ContentAlign,Multiline,Wrapped,dtp(Skin),dtp(Cursor),dtp(Font),FontColor,SelectedFontColor,SelectedColor,CursorColor,ScrollBarMode,MenuTableWidth,MenuTableHeight,dtp(MenuFont),MenuFontColor,MenuDisabledFontColor,MenuAttributeTransparency,MenuLanguage);

