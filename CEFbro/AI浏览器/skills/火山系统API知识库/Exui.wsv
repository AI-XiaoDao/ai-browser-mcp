    参数 菜单语言 <类型 = 整数 折叠2 @输出名 = "MenuLanguage" @默认值 = 0>
    {
        @ return pts(PopUpItemInputEx(( Control_P)control,index,cloid,Reserve,mode,stp(Content),InputMode,MaxInput,stp(PasswordChar),ContentAlign,Multiline,Wrapped,dtp(Skin),dtp(Cursor),dtp(Font),FontColor,SelectedFontColor,SelectedColor,CursorColor,ScrollBarMode,MenuTableWidth,MenuTableHeight,dtp(MenuFont),MenuFontColor,MenuDisabledFontColor,MenuAttributeTransparency,MenuLanguage));
