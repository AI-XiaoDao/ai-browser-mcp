    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_FilterPanelEx>,(AutoInt)this,@<标识值>}; control = CreateControl_FilterPanelEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,@<滤镜类型>,@<滤镜参数1>,@<滤镜参数2>,@<滤镜参数3>,@<滤镜参数4>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

