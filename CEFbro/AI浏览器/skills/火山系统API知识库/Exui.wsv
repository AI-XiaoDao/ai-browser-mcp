类 浏览框Ex <公开 基础类 = 组件Ex 注释 = "WebBrowserEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "WebBrowserEx"
        @视窗.附属文件.win32 = "designer\\miniblink\\node_x32.dll" @视窗.附属文件.x64 = "designer\\miniblink\\node_x64.dll" ""
        @视窗.附属文件.win32 = "designer\\miniblink\\mb_x32.dll" @视窗.附属文件.x64 = "designer\\miniblink\\mb_x64.dll" "">
{

    # @begin
    # <> <include>
    # public: friend class ExuiProgram;
    # <> </include>
    # @end

    方法 Exui_EventPro_WebBrowserEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_WebBrowserEx">
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {
        @ switch(EventType){
        @ case Control_Event_L_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Click : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Click(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Down : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Down(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_Up : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_Up(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_L_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_L_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_R_DClick : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_R_DClick(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseMove : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Move(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseEnterLeave : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_EnterLeave(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_MouseWheel : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Wheell(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_keyEvent : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_keyEvent(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_CharInput : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_CharInput(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Focus : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Focus(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case Control_Event_Other : return GetControlExClassThis(CtrHandle,@sn<current_class>)->ControlExEvent_Other(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        // ---
        // 私有事件
        // ---
        @ case WebBrowserEx_Event_Navigation : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<开始载入>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_CreateView : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<即将打开新窗口>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_URLChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<地址改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_TitleChanged : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<标题改变>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_DocumentReady : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<文档就绪>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_LoadingFinish : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<载入完成>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_Download : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<文件下载>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_AlertBox : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<调用提示框>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_ConfirmBox : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<调用信息框>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_PromptBox : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<调用输入框>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_LoadUrlBegin : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<资源载入开始>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_LoadUrlFail : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<资源载入出错>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_LoadUrlEnd : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<资源载入完毕>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_NetResponse : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<网络响应事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_JsCallResponse : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<响应Js命令>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_RelateEvent1 : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<保留事件1>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ case WebBrowserEx_Event_RelateEvent2 : return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<保留事件2>(CtrHandle,EventType,Param1,Param2,Param3,Param4); break;
        @ default: break;
        @ }
        返回 (0)


    }

    方法 创建 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 父级组件 <类型 = 基类Ex @默认值 = 空对象>
    参数 左边 <类型 = 整数 注释 = "左边" 折叠2 @默认值 = 10 @输出名 = "Left">
    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 40 @输出名 = "Top">
    参数 宽度 <类型 = 整数 注释 = "宽度" 折叠2 @默认值 = 100 @输出名 = "Width">
    参数 高度 <类型 = 整数 注释 = "高度" 折叠2 @默认值 = 40 @输出名 = "Height">
    参数 可视 <类型 = 逻辑型 注释 = "可视" 折叠2 @默认值 = 真 @输出名 = "Visual">
    参数 禁止 <类型 = 逻辑型 注释 = "禁止" 折叠2 @默认值 = 假 @输出名 = "Disabled">
    参数 透明度 <类型 = 整数 注释 = "用于设置组件的透明度，取值范围0-256 若为256时适应与无透明组件效率更高 但组件的透明部分将被黑色取代" 折叠2 @默认值 = 255 @输出名 = "Transparency">
    参数 穿透模式 <类型 = 整数 注释 = "0为不可穿透，1为全部穿透,2为透明穿透" 折叠2 @默认值 = 0 @输出名 = "Pierced">
    参数 焦点权重 <类型 = 整数 注释 = "焦点可使用TAB键按权重从大到小顺序切换，0即不生效" 折叠2 @默认值 = 0 @输出名 = "FocusWeight">
    参数 鼠标光标 <类型 = 字节集类 注释 = "通过编辑器生成" 折叠2 @默认值 = 空对象 @输出名 = "Cursor">
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    参数 背景透明 <类型 = 逻辑型 注释 = "背景透明" 折叠2 @默认值 = 假 @输出名 = "BackgroundTransparent">
    参数 媒体音量 <类型 = 整数 注释 = "取值范围0-100 , MB未实现" 折叠2 @默认值 = 100 @输出名 = "MediaVolume">
    参数 缩放度 <类型 = 整数 注释 = "取值范围0-100" 折叠2 @默认值 = 100 @输出名 = "ZoomFactor">
    参数 允许新窗口跳转 <类型 = 逻辑型 注释 = "允许新窗口跳转" 折叠2 @默认值 = 假 @输出名 = "NavigationToNewWind">
    参数 启用Cookie <类型 = 逻辑型 注释 = "启用Cookie" 折叠2 @默认值 = 真 @输出名 = "CookieEnabled">
    参数 启用插件 <类型 = 逻辑型 注释 = "启用插件" 折叠2 @默认值 = 真 @输出名 = "NpapiEnabled">
    参数 启用菜单 <类型 = 逻辑型 注释 = "启用菜单" 折叠2 @默认值 = 假 @输出名 = "MenuEnabled">
    参数 拖拽模式 <类型 = 整数 注释 = "参考浏览框拖放模式_前缀常量.如果没效果我也没法子.其调用的是 wkeSetDragEnable和wkeSetDragDropEnable" 折叠2 @默认值 = 0
            @输出名 = "DragEnable">
    参数 初始页面 <类型 = 文本型 注释 = "本属性仅限 设定浏览框创建后初始页面 , 运行状态不建议操作此属性 , 改用载入() 实现 , 由于浏览框初始后窗体可能尚未载入完毕故此时可能会无法接收到部分事件" 折叠2
            @默认值 = "https://iexui.com/downexui" @输出名 = "StartPage">
    参数 用户代理 <类型 = 文本型 注释 = "作为保留属性 , 用于后续升级." 折叠2 @默认值 = "" @输出名 = "UserAgent">
    参数 版本 <类型 = 整数 注释 = "版本0为普通版1为vip版 vip版指的的是浏览器vip内核" 折叠2 @默认值 = 0 @输出名 = "Version">
    参数 扩展元素 <类型 = 字节集类 注释 = "用于设定组件初始元素数据 , 不建议运行时动态操作本属性" 折叠2 @默认值 = 空对象 @输出名 = "ElementData">
    参数 布局器 <类型 = 字节集类 注释 = "用于设定组件布局模式 , 由5个整数的字节集组成 , 第一个指定布局模式后续四个指定相关参考 布局模式_ 常量说明" 折叠2 @默认值 = 空对象 @输出名 = "LayoutData">
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_WebBrowserEx>,(AutoInt)this,@<标识值>}; control = CreateControl_WebBrowserEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtpdv(@<鼠标光标>,Rc_Cur_WebBrowserEx),@<标识值>,@<背景透明>,@<媒体音量>,@<缩放度>,@<允许新窗口跳转>,@<启用Cookie>,@<启用插件>,@<启用菜单>,@<拖拽模式>,stp(@<初始页面>),stp(@<用户代理>),@<版本>,dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

    方法 取内核句柄 <公开 类型 = 变整数 注释 = "wkeWebView" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "GetWebView">
    {
        @ return GetWebView_WebBrowserEx(control);
    }

    方法 载入 <公开 注释 = "载入" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "Load">
    参数 url <类型 = 文本型 注释 = "Unicode编码 , 参数内容取决与LoadMode" 折叠2 @默认值 = "" @输出名 = "URL">
