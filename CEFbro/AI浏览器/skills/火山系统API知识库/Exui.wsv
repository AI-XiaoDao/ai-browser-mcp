    参数 菜单类型 <类型 = 整数 @默认值 = 0>
    参数 禁止 <类型 = 逻辑型 @默认值 = 假>
    参数 勾选 <类型 = 逻辑型 @默认值 = 假>
    {
        @ InsertItem_MenuEx(@sn<this>.control,(void *)@<父菜单项句柄>,@<插入位置>,@<附加数值>,atimage(@<图标>),stp(@<标题>),@<标题颜色>,@<禁止标题颜色>,@<宽度>,@<高度>,@<菜单类型>,@<禁止>,@<勾选>)
    }

