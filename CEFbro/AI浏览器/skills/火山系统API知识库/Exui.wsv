    常量 阴影百分75阴影 <公开 类型 = 整数 值 = 315 注释 = "Percent75 指定 75 % 阴影。前景色与背景色的比例为 75 : 100。">
    常量 阴影百分80阴影 <公开 类型 = 整数 值 = 316 注释 = "Percent80 指定 80 % 阴影。前景色与背景色的比例为 80 : 100。">
    常量 阴影百分90阴影 <公开 类型 = 整数 值 = 317 注释 = "Percent90 指定 90 % 阴影。前景色与背景色的比例为 90 : 100。">
    常量 阴影细向下对角线 <公开 类型 = 整数 值 = 318 注释 = "LightDownwardDiagonal">
    常量 阴影细向上对角线 <公开 类型 = 整数 值 = 319 注释 = "LightUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其两边夹角比 BackwardDiagonal 小 50 % ，但这些直线不是锯齿消除的。">
    常量 阴影粗向下对角线 <公开 类型 = 整数 值 = 320
            注释 = "DarkDownwardDiagonal 指定从顶点到底点向右倾斜的对角线，其两边夹角比 ForwardDiagonal 小 50 % ，宽度是其两倍。此阴影图案不是锯齿消除的。">
    常量 阴影粗向上对角线 <公开 类型 = 整数 值 = 321
            注释 = "DarkUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其两边夹角比 BackwardDiagonal 小 50 % ，宽度是其两倍，但这些直线不是锯齿消除的。">
    常量 阴影宽向下对角线 <公开 类型 = 整数 值 = 322 注释 = "WideDownwardDiagonal 指定从顶点到底点向右倾斜的对角线，其间距与阴影样式 ForwardDiagonal 相同，宽度是其三倍，但它们不是锯齿消除的。">
    常量 阴影宽向上对角线 <公开 类型 = 整数 值 = 323 注释 = "WideUpwardDiagonal 指定从顶点到底点向左倾斜的对角线，其间距与阴影样式 BackwardDiagonal 相同，宽度是其三倍，但它们不是锯齿消除的。">
    常量 阴影细垂直线 <公开 类型 = 整数 值 = 324 注释 = "LightVertical 指定垂直线的两边夹角比 Vertical 小 50 % 。">
    常量 阴影细水平线 <公开 类型 = 整数 值 = 325 注释 = "LightHorizontal 指定水平线，其两边夹角比 Horizontal 小 50 % 。">
    常量 阴影密垂直线 <公开 类型 = 整数 值 = 326 注释 = "NarrowVertical 指定垂直线的两边夹角比阴影样式 Vertical 小 75 % （或者比 LightVertical 小 25 % ）。">
    常量 阴影密水平线 <公开 类型 = 整数 值 = 327 注释 = "NarrowHorizontal 指定水平线的两边夹角比阴影样式 Horizontal 小 75 % （或者比 LightHorizontal 小 25 % ）。">
    常量 阴影粗垂直线 <公开 类型 = 整数 值 = 328 注释 = "DarkVertical 指定垂直线的两边夹角比 Vertical 小 50 % 并且宽度是其两倍。">
    常量 阴影粗水平线 <公开 类型 = 整数 值 = 329 注释 = "DarkHorizontal 指定水平线的两边夹角比水平小 50 % 并且宽度是 HatchStyleHorizontal 的两倍。">
    常量 阴影右斜虚线 <公开 类型 = 整数 值 = 330 注释 = "DashedDownwardDiagonal 指定虚线对角线，这些对角线从顶点到底点向右倾斜。">
    常量 阴影左斜虚线 <公开 类型 = 整数 值 = 331 注释 = "DashedUpwardDiagonal 指定虚线对角线，这些对角线从顶点到底点向左倾斜。">
    常量 阴影水平虚线 <公开 类型 = 整数 值 = 332 注释 = "DashedHorizontal 指定虚线水平线。">
    常量 阴影垂直虚线 <公开 类型 = 整数 值 = 333 注释 = "DashedVertical 指定虚线垂直线。">
    常量 阴影小五彩纸屑 <公开 类型 = 整数 值 = 334 注释 = "SmallConfetti 指定带有五彩纸屑外观的阴影。">
    常量 阴影大五彩纸屑 <公开 类型 = 整数 值 = 335 注释 = "LargeConfetti 指定具有五彩纸屑外观的阴影，并且它是由比 SmallConfetti 更大的片构成的。">
    常量 阴影曲线 <公开 类型 = 整数 值 = 336 注释 = "ZigZag 指定由 Z 字形构成的水平线。">
    常量 阴影波浪线 <公开 类型 = 整数 值 = 337 注释 = "Wave 指定由代字号“~”构成的水平线。">
    常量 阴影对角砖块 <公开 类型 = 整数 值 = 338 注释 = "DiagonalBrick 指定具有分层砖块外观的阴影，它从顶点到底点向左倾斜。">
    常量 阴影水平砖块 <公开 类型 = 整数 值 = 339 注释 = "HorizontalBrick 指定具有水平分层砖块外观的阴影。">
    常量 阴影编织 <公开 类型 = 整数 值 = 340 注释 = "Weave 指定具有织物外观的阴影。">
    常量 阴影花格子 <公开 类型 = 整数 值 = 341 注释 = "Plaid 指定具有格子花呢材料外观的阴影。">
    常量 阴影草皮 <公开 类型 = 整数 值 = 342 注释 = "Divot 指定具有草皮层外观的阴影。">
    常量 阴影十字点线 <公开 类型 = 整数 值 = 343 注释 = "DottedGrid 指定互相交叉的水平线和垂直线，每一直线都是由点构成的。">
    常量 阴影交叉点线 <公开 类型 = 整数 值 = 344 注释 = "DottedDiamond 指定互相交叉的正向对角线和反向对角线，每一对角线都是由点构成的。">
    常量 阴影瓦片 <公开 类型 = 整数 值 = 345 注释 = "Shingle 指定带有对角分层鹅卵石外观的阴影，它从顶点到底点向右倾斜。">
    常量 阴影网格 <公开 类型 = 整数 值 = 346 注释 = "Trellis 指定具有格架外观的阴影。">
    常量 阴影球形 <公开 类型 = 整数 值 = 347 注释 = "Sphere 指定具有球体彼此相邻放置的外观的阴影。">
    常量 阴影小网格 <公开 类型 = 整数 值 = 348 注释 = "SmallGrid 指定互相交叉的水平线和垂直线，其两边夹角比阴影样式 Cross 小 50 % 。">
    常量 阴影小棋盘 <公开 类型 = 整数 值 = 349 注释 = "SmallCheckerBoard 指定带有棋盘外观的阴影。">
    常量 阴影大棋盘 <公开 类型 = 整数 值 = 350 注释 = "LargeCheckerBoard 指定具有棋盘外观的阴影，棋盘所具有的方格大小是 SmallCheckerBoard 大小的两倍。">
    常量 阴影边线金刚石 <公开 类型 = 整数 值 = 351 注释 = "OutlinedDiamond 指定互相交叉的正向对角线和反向对角线，但这些对角线不是锯齿消除的。">
    常量 阴影金刚石 <公开 类型 = 整数 值 = 352 注释 = "SolidDiamond 指定具有对角放置的棋盘外观的阴影。">

    #
}

类 画笔对齐方式 <公开 折叠 折叠2 @全局类 = 真 @文档 = "category = \"Exui常量\"">
{
