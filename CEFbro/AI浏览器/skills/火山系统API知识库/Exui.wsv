    方法 创建 <公开 类型 = 变整数 注释 = "菜单*" 折叠 @禁止流程检查 = 真>
    参数 图标宽 <类型 = 整数 @默认值 = 0>
    参数 图标高 <类型 = 整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "是皮肤不是图片 要从皮肤编辑器里编辑出来的那种皮肤" @默认值 = 空对象>
    参数 字体 <类型 = 字节集类 注释 = "可使用 结构体创建自参数(,字体名,字体大小,字体风格,字体渲染模式,渲染参数1,渲染参数2)命令生成" @默认值 = 空对象>
    参数 鼠标光标 <类型 = 字节集类 @默认值 = 空对象>
    参数 透明度 <类型 = 整数 @默认值 = 255>
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_MenuEx>,(AutoInt)this,@<标识值>}; control = Create_MenuEx(@<图标宽>,@<图标高>,dtpdv(@<皮肤>,ControlType_MenuEx),dtp(@<字体>),dtp(@<鼠标光标>),@<透明度>,(void *)-1,(AutoInt)InitAttr); return (AutoInt)control;
    }

    方法 销毁 <公开 折叠 折叠2 @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ Destroy_MenuEx(control);
    }

    方法 置属性 <公开 折叠 @禁止流程检查 = 真>
    参数 属性id <类型 = 变整数 注释 = "参见常量 该id值可以用位或叠加 当id被叠加是代表对应参数有效 其它参数被忽略 若为0代表全部参数有效" @默认值 = 0>
    参数 图标宽 <类型 = 整数 @默认值 = 0>
    参数 图标高 <类型 = 整数 @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 @默认值 = 空对象>
    参数 字体 <类型 = 字节集类 @默认值 = 空对象>
    参数 鼠标光标 <类型 = 字节集类 @默认值 = 空对象>
    参数 透明度 <类型 = 整数 @默认值 = 255>
    参数 标识值 <类型 = 变整数 @默认值 = 0>
    {
        @ SetAttribute_MenuEx(control,@<属性id>,@<图标宽>,@<图标高>,dtp(@<皮肤>),dtp(@<字体>),dtp(@<透明度>),(void *)&@<Exui_EventPro_MenuEx>,@<标识值>);
    }

    方法 取属性 <公开 折叠 折叠2 @禁止流程检查 = 真 @嵌入式方法 = "">
    参数 属性id <类型 = 变整数 注释 = "参见常量" 折叠2 @默认值 = 0 @输出名 = "aid">
    参数 所欲获取数据的类型 <注释 = "提供所欲获取数据的数据类型" 折叠2 @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    {
        @ RETURN_@<所欲获取数据的类型>(GetAttribute_MenuEx(@sn<this>.control,@<属性id>))
    }

    方法 是否已弹出 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 菜单项句柄 <类型 = 变整数 注释 = "MenuInfo*" @默认值 = 0>
