    参数 顶边 <类型 = 整数 注释 = "顶边" 折叠2 @默认值 = 0 @输出名 = "Top">
    {
        @ return RemoveControl_WindowEx(control,(Control_P )(@<组件>.GetControlType() !=ControlType_WindowBoxEx ? @<组件>.control : NULL),(void * )(@<目的组件>.GetControlType() !=ControlType_WindowBoxEx ? @<目的组件>.control : NULL),@<左边>,@<顶边>);
    }

    方法 调用反馈事件 <公开 类型 = 变整数 注释 = "调用反馈事件" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "CallFeedBackEvent">
    参数 附加参数1 <类型 = 变整数 注释 = "附加参数" 折叠2 @默认值 = 0 @输出名 = "Param1">
    参数 附加参数2 <类型 = 变整数 注释 = "附加参数" 折叠2 @默认值 = 0 @输出名 = "Param2">
    参数 调用方式 <类型 = 逻辑型
            注释 = "为真则采用发送方式传递事件消息，此时本命令将一直等待到反馈事件用户事件处理子程序处理完毕后才返回，为假则采用投递方式传递事件消息，此时本命令将直接返回且不等待用户事件处理子程序处理完毕（用户事件处理子程序将在空闲时被调用）"
            折叠2 @默认值 = 假 @输出名 = "InvocationMode">
    {
        @ return CallFeedBackEvent_WindowEx(control,@<附加参数1>,@<附加参数2>,@<调用方式>);
    }

    方法 播放窗口动画 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 动画规模 <类型 = 变整数 注释 = "千分比 0-1000 填0取值 1000" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 1000>
    参数 动画模式 <类型 = 变整数 注释 = "参考窗口 动画模式_前缀 常量" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 0>
    参数 动画算法 <类型 = 变整数 注释 = "参考 缓动_前缀常量" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 0>
    参数 帧延迟 <类型 = 变整数 注释 = "单位毫秒 填0取值10 当为负数时 本参数视作预估总时长 内部将根据其绝对值 自动计算 帧延迟" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 10>
    参数 步进 <类型 = 变整数 注释 = "千分比 0-1000 填0取值25" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 25>
    参数 渐显渐隐 <类型 = 逻辑型 注释 = "渐显渐隐" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 假>
    参数 等待完毕 <类型 = 逻辑型 注释 = "决定是否等待缓动执行完毕后返回 默认为假" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 假>
    参数 播放结束后销毁组件 <类型 = 逻辑型 注释 = "决定动画播放完毕后是否销毁窗口 默认为假" 编辑时信息 = "3B4B1, 0, 0, 0" @默认值 = 假>
    {
        @ return PlayWindowAnimationEx(control,@<动画规模>,@<动画模式>,@<动画算法>,@<帧延迟>,@<步进>,@<渐显渐隐>,@<等待完毕>,@<播放结束后销毁组件>);

    }

