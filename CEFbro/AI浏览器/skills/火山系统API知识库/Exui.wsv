    {
        @ SetItemTitle_ListBoxEx(control,@<索引>,stp(@<文本>));
    }

    方法 取项目标题 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 索引 <类型 = 变整数 @默认值 = 0>
    {
        @ return pts(GetItemTitle_ListBoxEx(control,@<索引>));
    }

    方法 取字体色 <公开 类型 = 整数 注释 = "取字体色" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "GetItemFontColor">
    参数 索引 <类型 = 变整数 注释 = "项目索引" 折叠2 @默认值 = 0 @输出名 = "Index">
    {
