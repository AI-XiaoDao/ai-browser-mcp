    参数 表头对齐方式 <类型 = 整数 注释 = "0居左 1居中 2居右" 折叠2 @默认值 = 0 @输出名 = "HeaderAlign">
    参数 项目字体 <类型 = 字节集类 注释 = "Ex自定义字体数据,可在编辑器生成或编辑.或使用相关字体打包接口动态生成" 折叠2 @默认值 = 空对象 @输出名 = "ItemFont">
    参数 项目图标宽 <类型 = 整数 注释 = "项目图标宽" 折叠2 @默认值 = 16 @输出名 = "ItemIcoWidth">
    参数 项目图标高 <类型 = 整数 注释 = "项目图标高" 折叠2 @默认值 = 16 @输出名 = "ItemIcoHeight">
    参数 项目对齐方式 <类型 = 整数 注释 = "0居左 1居中 2居右" 折叠2 @默认值 = 0 @输出名 = "ItemAlign">
    参数 悬浮项目字体 <类型 = 字节集类 注释 = "Ex自定义字体数据,可在编辑器生成或编辑.或使用相关字体打包接口动态生成" 折叠2 @默认值 = 空对象 @输出名 = "FixedItemFont">
    参数 悬浮项目图标宽 <类型 = 整数 注释 = "项目图标宽" 折叠2 @默认值 = 16 @输出名 = "FixedItemIcoWidth">
    参数 悬浮项目图标高 <类型 = 整数 注释 = "项目图标高" 折叠2 @默认值 = 16 @输出名 = "FixedItemIcoHeight">
    参数 悬浮项目对齐方式 <类型 = 整数 注释 = "0居左 1居中 2居右" 折叠2 @默认值 = 0 @输出名 = "FixedItemAlign">
    参数 表头行树样式 <类型 = 整数 注释 = "表头行树样式 0 关闭 1开启" 折叠2 @默认值 = 0 @输出名 = "HeaderTreeType">
    参数 项目行树形样式 <类型 = 整数 注释 = "项目行树形样式 0 关闭 1开启" 折叠2 @默认值 = 0 @输出名 = "TreeType">
    参数 悬浮行树样式 <类型 = 整数 注释 = "悬浮行树样式 0 关闭 1开启" 折叠2 @默认值 = 0 @输出名 = "BottomFixedTreeType">
    参数 子级缩进 <类型 = 整数 注释 = "子级缩进" 折叠2 @默认值 = 20 @输出名 = "ChildMigration">
    参数 内容缩进 <类型 = 整数 注释 = "内容缩进" 折叠2 @默认值 = 10 @输出名 = "ContentMigration">
    参数 表格线样式 <类型 = 整数 注释 = "表格线样式" 折叠2 @默认值 = 0 @输出名 = "LineMode">
    参数 折叠钮皮肤 <类型 = 字节集类 注释 = "折叠按钮皮肤" 折叠2 @默认值 = 空对象 @输出名 = "FoldBtnSkin">
    {
        @ return InsertColumn_AdvancedGridEx(control,@<插入位置>,@<插入数量>,@<列宽>,@<最小宽度>,@<最大宽度>,dtp(@<项目字体>),@<项目图标宽>,@<项目图标高>,@<项目对齐方式>,dtp(@<表头字体>),@<表头图标宽>,@<表头图标高>,@<表头对齐方式>,dtp(@<悬浮项目字体>),@<悬浮项目图标宽>,@<悬浮项目图标高>,@<悬浮项目对齐方式>,@<表头行树样式>,@<项目行树形样式>,@<悬浮行树样式>,@<子级缩进>,@<内容缩进>,@<表格线样式>,dtp(@<折叠钮皮肤>));
    }

    方法 删除列 <公开 注释 = "删除列" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "DeleteColumn">
    参数 列索引 <类型 = 变整数 注释 = "索引从0开始,为-1时删除全部" 折叠2 @默认值 = 0 @输出名 = "ColumnIndex">
