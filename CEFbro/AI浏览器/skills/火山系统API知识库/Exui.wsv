    方法 Exui_EventPro_WindowBoxEx <静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_WindowBoxEx" @禁止流程检查 = 真>
    参数 hwnd <类型 = 变整数 @输出名 = "hwnd">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 wParam <类型 = 变整数 @输出名 = "wParam">
    参数 lParam <类型 = 变整数 @输出名 = "lParam">
    {
        @ @sn<current_class>* WinExthis=(( @sn<current_class>*)GetProp(( HWND)hwnd,TEXT("ExuiWindow_BindThis")));
        @ switch(EventType){
        @ case WM_CREATE : return WinExthis->@<创建完毕>(hwnd,EventType,wParam,lParam); break;
        @ case WM_CLOSE : return WinExthis->@<可否被关闭>(hwnd,EventType,wParam,lParam); break;
        @ case WM_DESTROY : return WinExthis->@<将被销毁>(hwnd,EventType,wParam,lParam); break;
        @ case WM_MOVE : return WinExthis->@<位置被改变>(hwnd,EventType,wParam,lParam); break;
        @ case WM_SIZE : return WinExthis->@<尺寸被改变>(hwnd,EventType,wParam,lParam); break;
        @ case WM_ACTIVATE : return WinExthis->@<激活状态改变>(hwnd,EventType,wParam,lParam); break;
        @ case 12313 : return WinExthis->@<托盘事件>(hwnd,EventType,wParam,lParam); break;
        @ case WM_SHOWWINDOW : return WinExthis->@<可视状态改变>(hwnd,EventType,wParam,lParam); break;
        @ case WM_LBUTTONDOWN : return WinExthis->@<鼠标左键被按下>(hwnd,EventType,wParam,lParam); break;
        @ case WM_LBUTTONUP : return WinExthis->@<鼠标左键被放开>(hwnd,EventType,wParam,lParam); break;
        @ case WM_LBUTTONDBLCLK : return WinExthis->@<被双击>(hwnd,EventType,wParam,lParam); break;
        @ case WM_RBUTTONDOWN : return WinExthis->@<鼠标右键被按下>(hwnd,EventType,wParam,lParam); break;
        @ case WM_RBUTTONUP : return WinExthis->@<鼠标右键被放开>(hwnd,EventType,wParam,lParam); break;
        @ case WM_MOUSEMOVE : return WinExthis->@<鼠标位置被移动>(hwnd,EventType,wParam,lParam); break;
        @ case WM_SETFOCUS : return WinExthis->@<获得焦点>(hwnd,EventType,wParam,lParam); break;
        @ case WM_KILLFOCUS : return WinExthis->@<失去焦点>(hwnd,EventType,wParam,lParam); break;
        @ case WM_KEYDOWN : return WinExthis->@<按下某键>(hwnd,EventType,wParam,lParam); break;
        @ case WM_KEYUP : return WinExthis->@<放开某键>(hwnd,EventType,wParam,lParam); break;
        @ case WM_CHAR : return WinExthis->@<字符输入>(hwnd,EventType,wParam,lParam); break;
        @ case WM_MOUSEWHEEL : return WinExthis->@<滚轮滚动>(hwnd,EventType,wParam,lParam); break;
        @ case WM_DROPFILES : return WinExthis->@<接收到文件拖放>(hwnd,EventType,wParam,lParam); break;
        @ default: break;
        @ }
        @ return WinExthis->@<其它事件>(hwnd,EventType,wParam,lParam);
    }

