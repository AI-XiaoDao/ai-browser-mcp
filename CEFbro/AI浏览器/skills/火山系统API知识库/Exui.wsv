    方法 置项目编辑配置 <公开 注释 = "置项目编辑配置" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "SetItemEditConfig">
    参数 配置ID <类型 = 整数 注释 = "全部设置填-1 否则填对应常量" 折叠2 @输出名 = "AttributeId" @默认值 = -1>
    参数 输入方式 <类型 = 整数 注释 = "参考 输入模式_ 前缀常量 多种输入模式可用 位或() 组合" 折叠2 @输出名 = "InputMode" @默认值 = 0>
    参数 最大允许长度 <类型 = 整数 注释 = "限定最大输入的字符数量 , 与易编辑框不同本属性限定的是字符个数 , 而非字符数据长度.另本参数无法约束直接调整内容属性 或其它代码直接设定内容值" 折叠2 @输出名 = "MaxInput"
            @默认值 = 0>
    参数 密码替换符 <类型 = 文本型 注释 = "限定一个字符请不要设定多个字符挑战容错率" 折叠2 @输出名 = "PasswordChar" @默认值 = "*">
    参数 对齐方式 <类型 = 整数 注释 = "0居左 1居中 2居右 若应用非居左属性 请关闭多行属性 当前对多行文本并不友好." 折叠2 @输出名 = "ContentAlign" @默认值 = 0>
    参数 是否允许多行 <类型 = 逻辑型 注释 = "限定输入内容可否多行 , 本参数无法约束直接调整内容属性 或其它代码直接设定内容值" 折叠2 @输出名 = "Multiline" @默认值 = 真>
    参数 自动换行 <类型 = 逻辑型 注释 = "自动换行" 折叠2 @输出名 = "Wrapped" @默认值 = 假>
    参数 皮肤 <类型 = 字节集类 注释 = "皮肤数据 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @输出名 = "Skin" @默认值 = 空对象>
    参数 鼠标光标 <类型 = 字节集类 注释 = "鼠标光标 , 可在编辑器中设计 , 或赋值设计后的资源 , 若不能打开编辑器请完整安装支持库." 折叠2 @输出名 = "Cursor" @默认值 = 空对象>
    参数 字体 <类型 = 字节集类 注释 = "Ex自定义字体数据 , 可在编辑器生成或编辑.或使用 结构体创建自参数( , 字体名 , 字体大小 , 字体风格 , 字体渲染模式 , 渲染参数1 , 渲染参数2) 命令生成." 折叠2
            @输出名 = "Font" @默认值 = 空对象>
    参数 字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "FontColor" @默认值 = -33554432>
    参数 选中字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "SelectedFontColor"
            @默认值 = -16777217>
    参数 选中背景色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "SelectedColor" @默认值 = -436172545>
    参数 光标色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择 若有不显示光标需求可将此颜色设定为 0透明的颜色" 折叠2
            @输出名 = "CursorColor" @默认值 = -33554432>
    参数 滚动条方式 <类型 = 整数 注释 = "参考滚动条方式_前缀常量前缀常量" 折叠2 @输出名 = "ScrollBarMode" @默认值 = 0>
    参数 菜单项目宽度 <类型 = 整数 折叠2 @输出名 = "MenuTableWidth" @默认值 = 100>
    参数 菜单项目高度 <类型 = 整数 折叠2 @输出名 = "MenuTableHeight" @默认值 = 30>
    参数 菜单字体 <类型 = 字节集类 注释 = "自定义字体数据 , 可在编辑器生成或编辑.或使用 结构体创建自参数( , 字体名 , 字体大小 , 字体风格 , 字体渲染模式 , 渲染参数1 , 渲染参数2) 命令生成." 折叠2
            @输出名 = "MenuFont" @默认值 = 空对象>
    参数 菜单字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "MenuFontColor" @默认值 = -33554432>
    参数 菜单禁止字体色 <类型 = 整数 注释 = "Argb色 , 可用RGBTARGB命令转换 , 或_ARGB后缀常量 , 或在工具箱里颜色选择框选择" 折叠2 @输出名 = "MenuDisabledFontColor"
            @默认值 = -33554432>
