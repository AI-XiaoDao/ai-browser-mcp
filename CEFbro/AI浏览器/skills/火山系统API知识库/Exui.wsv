    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_CalendarBoxEx>,(AutoInt)this,@<标识值>}; control = CreateControl_CalendarBoxEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtp(@<鼠标光标>),@<标识值>,dtpdv(@<皮肤>,ControlType_CalendarBoxEx),stp(@<最小日期>),stp(@<最大日期>),stp(@<当前日期>),dtp(@<标题字体>),dtp(@<星期字体>),dtp(@<日期字体>),dtp(@<时间字体>),@<标题色>,@<星期色>,@<双休星期色>,@<日期色>,@<双休日期色>,@<非本月色>,@<时间字体色>,@<只显示本月>,@<时间调整模式>,@<自动选中>,@<标题高度>,@<星期高度>,@<时间调节器高度>,@<伙伴高度>,@<语言>,dtp(@<项目数据>),dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

