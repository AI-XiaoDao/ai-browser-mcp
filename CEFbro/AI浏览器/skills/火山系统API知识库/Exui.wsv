    {
        @ DrawString_DrawPanelEx(control,stp(@<文本>),(float)@<左边>,(float)@<顶边>,(float)@<宽度>,(float)@<高度>,dtp(@<字体>),@<对齐方式>,@<画出方式>,@<效果参数>,@<颜色>,@<辅色>);
    }

    方法 画多边形 <公开 注释 = "绘制命令通常建议用在 预处理事件的被动请求重画里 若在其它地方使用时 在一系列绘制结束要调用 更新 命令请求刷新 如有必要还需在绘制前后加上组件更新缓存命令 老保证绘画结果按预期显示到界面" 折叠 折叠2
            @禁止流程检查 = 真 @输出名 = "DrawPolygon">
    参数 顶点 <类型 = 小数数组类 注释 = "float*" 折叠2 @默认值 = 空对象 @输出名 = "Polygon">
    参数 顶点数量 <类型 = 整数 注释 = "顶点数量" 折叠2 @默认值 = 0 @输出名 = "PolygonNum">
    参数 画出方式 <类型 = 整数 注释 = "参考画出方式常量" 折叠2 @默认值 = 0 @输出名 = "DrawMethod">
    参数 效果参数 <类型 = 整数 注释 = "效果参数取决于画出方式如画出方式为轮廓此参数通常用于指定线的宽度" 折叠2 @默认值 = 0 @输出名 = "EffectParam">
    参数 颜色 <类型 = 整数 注释 = "颜色" 折叠2 @默认值 = 0 @输出名 = "Color">
    参数 辅色 <类型 = 整数 注释 = "辅色 , 取决于画出方式当画出方式为填充型时此参数用于指定第二颜色如线性渐变和阴影" 折叠2 @默认值 = 0 @输出名 = "SecondaryColor">
    {
