        @ AutoInt InitAttr[5]{0,(AutoInt)&control,(AutoInt)&@<Exui_EventPro_SuperListBoxEx>,(AutoInt)this,@<标识值>}; control = CreateControl_SuperListBoxEx(( Control_P )(@<父级组件>.GetControlType() !=ControlType_WindowBoxEx ? @<父级组件>.control : NULL),(HWND )(@<父级组件>.GetControlType() ==ControlType_WindowBoxEx ? @<父级组件>.control : NULL),@<左边>,@<顶边>,@<宽度>,@<高度>,(ExuiCallback)-1,InitAttr,@<可视>,@<禁止>,@<透明度>,@<穿透模式>,@<焦点权重>,dtpdv(@<鼠标光标>,Rc_Cur_SuperListBoxEx),@<标识值>,dtpdv(@<皮肤>,ControlType_SuperListBoxEx),@<现行选中项>,@<现行选中列>,@<表头高度>,@<表头模式>,@<隔行换色>,@<选中模式>,@<整行选择>,@<事件模式>,@<编辑模式>,@<表格线模式>,@<滚动条方式>,dtp(@<项目数据>),dtp(@<扩展元素>),dtp(@<布局器>));return (AutoInt)control;
    }

