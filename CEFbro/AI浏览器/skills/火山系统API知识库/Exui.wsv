    方法 置事件回调 <类型 = 变整数 返回值注释 = "返回当前事件指针,如果你后续需要还原原事件或需要在事件内回调原事件请保存此值" 折叠 编辑时信息 = "8554D, 0, 0, 0" @禁止流程检查 = 真>
    参数 事件类型 <类型 = 变整数 注释 = "101共有事件 102私有事件" 折叠2 编辑时信息 = "8554D, 0, 0, 0" @默认值 = 101 @输出名 = "mode">
    参数 事件指针 <类型 = 变整数 注释 = "参数为1时调用组件类事件,通常设置为1" 折叠2 编辑时信息 = "8554D, 0, 0, 0" @输出名 = "Callback" @默认值 = 1>
    {
        @ switch(mode)
        @ {
        @ case 101:
        @ return (AutoInt)ControlSetCallback(control,mode,(Callback==(ExuiCallback)1)?(ExuiCallback)Exui_EventPro_PublicCallback_ControlEx:(ExuiCallback)Callback);
        @ break;
        @ case 102:
        @ return (AutoInt)ControlSetCallback(control,mode,(ExuiCallback )(Callback==(ExuiCallback)1)?(ExuiCallback)ControlExEvent_PrivateCallback:(ExuiCallback)Callback);
        @ break;
        @ default:
        @ break;
        @ }
        @ return 0;
    }

