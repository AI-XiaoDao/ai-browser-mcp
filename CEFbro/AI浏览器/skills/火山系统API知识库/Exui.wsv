    }
}

类 Exui常用功能 <公开 @全局类 = 真 @文档 = "category = \"Exui常用功能\"">
{
    方法 RGBTARGB <公开 静态 类型 = 整数 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "RGBTARGB">
    参数 RGB色 <类型 = 整数 注释 = "Rgb颜色" @输出名 = "rgb">
    参数 透明度 <类型 = 整数 注释 = "0-255" @输出名 = "tmd">
    {
        @ return (tmd<< 24)|(( rgb& 0xFF)<< 16)|(( rgb>> 8 & 0xFF)<< 8)|(rgb>> 16 & 0xFF);
    }

    方法 ARGBTRGB <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    参数 ARGB色 <类型 = 整数 @输出名 = "argb">
    参数 模式 <类型 = 整数 @输出名 = "mode">
    {
        @ return (mode==1)?(argb>> 24 & 0xFF):(RGB(argb >> 16 & 0xFF,argb >> 8 & 0xFF,argb& 0xFF));
    }

    方法 测量文本Ex <公开 静态 类型 = 小数矩形类 折叠 @禁止流程检查 = 真>
    参数 文本 <类型 = 文本型>
    参数 字体 <类型 = 字节集类 @默认值 = 空对象>
    参数 对齐方式 <类型 = 变整数 @默认值 = 0>
    参数 左边 <类型 = 小数 @默认值 = 0>
    参数 顶边 <类型 = 小数 @默认值 = 0>
    参数 宽度 <类型 = 小数 @默认值 = 0>
    参数 高度 <类型 = 小数 @默认值 = 0>
    参数 测量模式 <类型 = 整数 @默认值 = 0>
    {
        变量 返回矩形 <类型 = 小数矩形类 "">
        @ float * rect =(float *)RexMeasureStringEx(stp(@<文本>),dtp(@<字体>),@<对齐方式>,(float)@<左边>,(float)@<顶边>,(float)@<宽度>,(float)@<高度>,@<测量模式>);
        @ @<返回矩形.左边> = *(rect+2); @<返回矩形.顶边>=*(rect+3); @<返回矩形.右边>= *(rect+2)+ *(rect+4);@<返回矩形.底边>=*(rect+3)+ *(rect+5);
        @ return @<返回矩形>;
    }

    方法 生成字体Ex <公开 静态 类型 = 字节集类 折叠>
    参数 字体名称 <类型 = 文本型>
    参数 字体大小 <类型 = 整数>
    参数 字体风格 <类型 = 整数>
    参数 绘画模式 <类型 = 整数>
    参数 渲染参数1 <类型 = 整数>
    参数 渲染参数2 <类型 = 整数>
    {
        变量 临时字体结构 <类型 = 字节集类>
        临时字体结构.添加字节集空间 (84, 真)
        临时字体结构.插入文本到字节集 (0, 字体名称)
        临时字体结构.插入值到字节集 (64, 字体大小)
        临时字体结构.插入值到字节集 (68, 字体风格)
        临时字体结构.插入值到字节集 (72, 绘画模式)
        临时字体结构.插入值到字节集 (76, 渲染参数1)
        临时字体结构.插入值到字节集 (80, 渲染参数2)
        返回 (临时字体结构)
    }

    方法 创建布局器配置Ex <公开 静态 类型 = 字节集类 折叠>
    参数 布局模式 <类型 = 整数 @默认值 = 0>
    参数 左 <类型 = 整数 @默认值 = 0>
    参数 顶 <类型 = 整数 @默认值 = 0>
    参数 宽 <类型 = 整数 @默认值 = 0>
    参数 高 <类型 = 整数 @默认值 = 0>
    参数 设计时隐藏 <类型 = 整数 @默认值 = 0>
    参数 保留1 <类型 = 整数 @默认值 = 0>
    参数 保留2 <类型 = 整数 @默认值 = 0>
    参数 保留3 <类型 = 整数 @默认值 = 0>
    参数 保留4 <类型 = 整数 @默认值 = 0>
    参数 组件名称 <类型 = 文本型 @默认值 = "">
    {
        返回 (组合字节集 (布局模式, 左, 顶, 宽, 高, 保留1, 保留2, 保留3, 保留4, 组件名称))
    }

    方法 解析布局器配置Ex <公开 折叠>
    参数 数据 <类型 = 字节集类 @默认值 = 空对象>
    参数 布局模式 <类型 = 整数类 @默认值 = 空对象>
    参数 左 <类型 = 整数类 @默认值 = 空对象>
    参数 顶 <类型 = 整数类 @默认值 = 空对象>
    参数 宽 <类型 = 整数类 @默认值 = 空对象>
    参数 高 <类型 = 整数类 @默认值 = 空对象>
    参数 设计时隐藏 <类型 = 整数类 @默认值 = 空对象>
    参数 保留1 <类型 = 整数类 @默认值 = 空对象>
    参数 保留2 <类型 = 整数类 @默认值 = 空对象>
    参数 保留3 <类型 = 整数类 @默认值 = 空对象>
    参数 保留4 <类型 = 整数类 @默认值 = 空对象>
    参数 组件名称 <类型 = 文本型 @默认值 = "">
    {
        如果真 (取字节集长度 (数据) < 4)
        {
            返回
        }
        布局模式.值 = 取字节集数据 (数据, 1, 整数)
        左.值 = 取字节集数据 (数据, 5, 整数)
        顶.值 = 取字节集数据 (数据, 9, 整数)
        宽.值 = 取字节集数据 (数据, 13, 整数)
        高.值 = 取字节集数据 (数据, 17, 整数)
        设计时隐藏.值 = 取字节集数据 (数据, 21, 整数)
        如果 (取字节集长度 (数据) > 24)
        {
            保留1.值 = 取字节集数据 (数据, 25, 整数)
            保留2.值 = 取字节集数据 (数据, 29, 整数)
            保留3.值 = 取字节集数据 (数据, 33, 整数)
            保留4.值 = 取字节集数据 (数据, 37, 整数)
            组件名称 = 字节集到文本 (取字节集右边 (数据, 取字节集长度 (数据) - 40))
        }
        否则
        {
            保留1.值 = 0
            保留2.值 = 0
            保留3.值 = 0
            保留4.值 = 0
            组件名称 = ""


        }



    }

    方法 启用异常捕获Ex <公开 静态>
    参数 文本通知函数 <类型 = 变整数 @输出名 = "ExceptionTextCall" @默认值 = 0>
    参数 信息通知函数 <类型 = 变整数 @输出名 = "ExceptionInfoCall" @默认值 = 0>
    参数 自定义严重性 <类型 = 整数 @输出名 = "CustomSeverity" @默认值 = 0>
    参数 严重性级别 <类型 = 整数 @输出名 = "SeverityLevel" @默认值 = 0>
    {
        @ ExceptionCaptureEx((void*)ExceptionTextCall, (void*)ExceptionInfoCall, CustomSeverity, SeverityLevel);
    }
}

类 缓动任务Ex <公开 注释 = "SlowMotionTaskEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "SlowMotionTaskEx">
{

    # @begin
    # <> <include>
    # public: SlowMotionTaskEx_P CtrHandle=NULL;
    # void @an<_CopySelfFromExtra>(const @sn<current_class>& objCopyFrom)
    # {
    #  CtrHandle = objCopyFrom.CtrHandle;
    # }
    # <> </include>
    # @end

    方法 创建 <公开 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "Create_StructEx">
    参数 任务数量 <类型 = 变整数 @默认值 = 0>
    参数 默认缓动模式 <类型 = 变整数 @默认值 = 0>
    参数 默认起始值 <类型 = 变整数 @默认值 = 0>
    参数 默认结束值 <类型 = 变整数 @默认值 = 0>
    参数 帧延迟 <类型 = 变整数 @默认值 = 0>
    参数 步进 <类型 = 变整数 @默认值 = 0>
    参数 附加参数 <类型 = 变整数 @默认值 = 0>
    参数 等待完毕 <类型 = 逻辑型 @默认值 = 假>
    参数 手动销毁 <类型 = 逻辑型 @默认值 = 假>
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&CtrHandle,(AutoInt)&@<Exui_EventPro_SlowMotionTaskEx>,(AutoInt)this,@<附加参数>};
        @ CtrHandle = CreateSlowMotionTaskEx(@<任务数量>,@<默认缓动模式>,@<默认起始值>,@<默认结束值>,@<帧延迟>,@<步进>,(SlowMotionCallBack)-1,(AutoInt)InitAttr,@<等待完毕>,@<手动销毁>); return (AutoInt)CtrHandle;

    }

    方法 置配置 <公开 折叠 @禁止流程检查 = 真>
    参数 任务索引 <类型 = 变整数>
    参数 缓动模式 <类型 = 变整数 @默认值 = 0>
    参数 起始值 <类型 = 变整数 @默认值 = 0>
    参数 结束值 <类型 = 变整数 @默认值 = 0>
    {
        @ SetSlowMotionTaskConfigEx(CtrHandle,@<任务索引>,@<缓动模式>,@<起始值>,@<结束值>);
    }

    方法 执行命令 <公开 折叠 @禁止流程检查 = 真>
    参数 命令 <类型 = 变整数
            注释 = "10001.置总任务进度 10002.取总任务进度 10003.取指定id任务当前进度计算结果 10004.根据参数计算结果四个参数指定 模式,起始值,结束值,进度 20001-20008分别是 帧延迟.步进.回调.附加参数的取置">
    参数 任务索引 <类型 = 变整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    参数 参数3 <类型 = 变整数>
    参数 参数4 <类型 = 变整数>
    {
        @ RunSlowMotionTaskCmd(CtrHandle,@<命令>,@<任务索引>,@<参数1>,@<参数2>,@<参数3>,@<参数4>);
    }

    方法 销毁 <公开 折叠 @禁止流程检查 = 真>
    {
        @ DestroySlowMotionTaskEx(CtrHandle);CtrHandle=NULL;
    }

    方法 缓动任务事件 <公开 定义事件 类型 = 整数 返回值注释 = "部分事件可阻止时返回1 阻止 0放行" 折叠 折叠2 @输出名 = "UserEventPro_SlowMotionTaskEx" @强制输出 = 真>
    参数 任务句柄 <类型 = 变整数>
    参数 事件类型 <类型 = 变整数 注释 = "可参考 缓动事件_ 常量">
    参数 任务索引 <类型 = 变整数>
    参数 缓动结果 <类型 = 变整数>
    参数 缓动进度 <类型 = 变整数>
    参数 附加数值 <类型 = 变整数>
    {

    }

    方法 Exui_EventPro_SlowMotionTaskEx <公开 静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_SlowMotionTaskEx" @禁止流程检查 = 真>
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {
        @ return GetControlExClassThis(CtrHandle,@sn<current_class>)->UserEventPro_SlowMotionTaskEx(CtrHandle,EventType,Param1,Param2,Param3,Param4);
    }
}

类 定时器Ex <公开 注释 = "TimerEx" 折叠 折叠2 @强制输出 = 真 @输出名 = "TimerEx">
{

    # @begin
    # <> <include>
    # public: TimeEx_P CtrHandlele=NULL;
    # void @an<_CopySelfFromExtra>(const @sn<current_class>& objCopyFrom)
    # {
    #  CtrHandlele = objCopyFrom.CtrHandlele;
    # }
    # <> </include>
    # @end

    方法 创建 <公开 类型 = 变整数 注释 = "这是一个奇怪且不怎么安全的命令,慎用!" 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "Create_StructEx">
    参数 周期时间 <类型 = 变整数 @默认值 = 0>
    参数 附加参数 <类型 = 变整数 @默认值 = 0>
    参数 可否重入 <类型 = 逻辑型 @默认值 = 假>
    参数 回调方式 <类型 = 变整数 @默认值 = 32>
    {
        @ AutoInt InitAttr[5]{0,(AutoInt)&CtrHandlele,(AutoInt)&@<Exui_EventPro_TimerEx>,(AutoInt)this,@<附加参数>};
        @ CtrHandlele = CreateTimerEx(@<周期时间>,(TimeExCallBack)-1,(AutoInt)InitAttr,@<可否重入>,@<回调方式>); return (AutoInt)CtrHandlele;
    }

    方法 销毁 <公开 折叠 @禁止流程检查 = 真>
    {
        @ DeleteTimerEx(CtrHandlele);CtrHandlele=NULL;

    }

    方法 置配置 <公开 折叠 @禁止流程检查 = 真>
    参数 配置id <类型 = 变整数 注释 = "0为时钟周期,其他值意义不多," @默认值 = 0>
    参数 周期时间 <类型 = 变整数>
    {
        @ SetConfigTimerEx(CtrHandlele,@<配置id>,@<周期时间>);
    }

    方法 取配置 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 配置id <类型 = 变整数 注释 = "0为时钟周期,其他值意义不多," @默认值 = 0>
    {
        @ return GetConfigTimerEx(CtrHandlele,@<配置id>);
    }

    方法 定时器事件 <公开 定义事件 类型 = 整数 返回值注释 = "部分事件可阻止时返回1 阻止 0放行" 折叠>
    参数 定时器句柄 <类型 = 变整数>
    参数 事件类型 <类型 = 变整数 注释 = "可参考 定时器事件_ 常量">
    参数 理应触发次数 <类型 = 变整数>
    参数 实际触发次数 <类型 = 变整数>
    参数 事件状态 <类型 = 变整数>
    参数 附加数值 <类型 = 变整数>
    {

    }

    方法 Exui_EventPro_TimerEx <公开 静态 类型 = 变整数 折叠 折叠2 @强制输出 = 真 @输出名 = "Exui_EventPro_TimerEx" @禁止流程检查 = 真>
    参数 CtrHandle <类型 = 变整数 @输出名 = "CtrHandle">
    参数 EventType <类型 = 变整数 @输出名 = "EventType">
    参数 Param1 <类型 = 变整数 @输出名 = "Param1">
    参数 Param2 <类型 = 变整数 @输出名 = "Param2">
    参数 Param3 <类型 = 变整数 @输出名 = "Param3">
    参数 Param4 <类型 = 变整数 @输出名 = "Param4">
    {
        @ return GetControlExClassThis(CtrHandle,@sn<current_class>)->@<定时器事件>(CtrHandle,EventType,Param1,Param2,Param3,Param4);

    }
}

类 Exui对话框 <公开 折叠 折叠2 @全局类 = 真 @文档 = "category = \"Exui对话框\"">
{
    方法 信息框Ex <公开 静态 类型 = 整数 折叠 折叠2 @禁止流程检查 = 真 @输出名 = "MsgBoxEx">
    参数 图标 <类型 = 字节集类 注释 = "参数可提供图标句柄或图标字节集.图标句柄可用 装载位图Ex()命令装载 , 图标句柄传递给本命令后 , 即可释放 当一个图标被多次使用如列表中或图标过大时建议使用位图句柄 , 预先格式化会提升效率"
            折叠2 @输出名 = "Icon" @默认值 = 空对象>
    参数 标题 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @输出名 = "Title" @默认值 = "">
    参数 提示图标 <类型 = 字节集类 注释 = "提示图标的ID" 折叠2 @输出名 = "tipico" @默认值 = 空对象>
    参数 提示文本 <类型 = 文本型 注释 = "Unicode编码 , 可用ATU()命令转换 , 或其它模块的编码转换." 折叠2 @输出名 = "tiptext" @默认值 = "">
    参数 按钮 <类型 = 文本型 注释 = "确定&&取消" 折叠2 @输出名 = "Button" @默认值 = "确定&&取消">
    参数 默认按钮 <类型 = 整数 注释 = "默认按钮" 折叠2 @输出名 = "dfbtn" @默认值 = 0>
    参数 父窗口 <类型 = 变整数 注释 = "窗口句柄 将配置项内的组件 创建到此窗口内 若此参数为0或父组件不为0 则以父组件为准" 折叠2 @输出名 = "ParentWindow" @默认值 = 0>
    参数 信息框风格 <类型 = 整数 折叠2 @输出名 = "Style" @默认值 = 0>
    参数 皮肤 <类型 = 字节集类 注释 = "\"是皮肤不是图片 要从皮肤编辑器里编辑出来的那种皮肤\"" 折叠2 @输出名 = "Skin" @默认值 = 空对象>
    参数 回调函数 <类型 = 变整数 注释 = "逻辑返回 参数1 整数错误码 , 参数二文本 错误文本" 折叠2 @输出名 = "callback" @默认值 = 0>
    参数 回调参数 <类型 = 变整数 注释 = "回调参数" 折叠2 @默认值 = 0 @输出名 = "Param">
    {
        @ return MsgBox_Ex(dtp(Icon),stp(Title),dtp(tipico),stp(tiptext),stp(Button),dfbtn,(HWND)ParentWindow,Style,dtp(Skin),(ExuiCallback)callback,Param);

    }

    方法 输入框Ex <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 图标 <类型 = 字节集类 折叠2 @输出名 = "Icon" @默认值 = 空对象>
