    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return @dt<逻辑型>(IsEmpty());
    }

    #

    方法 创建 <公开>
    {
        @ m_data=FBroDoubleString_Creat();
    }

    #

    方法 取个数 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return IsEmpty()?0:FBroDoubleString_Size(m_data);//.size();
    }

    方法 加入成员 <公开>
    参数 成员 <类型 = FBrowser_双文本>
    {
        @ if(!IsEmpty()) FBroDoubleString_Add(m_data,@<成员.name>.GetText(), @<成员.value>.GetText());
    }

    方法 到数组首 <公开 注释 = "当前指向数组第一个数据">
    {
        @ if(!IsEmpty()) FBroDoubleString_ToBegin(m_data);
    }

    方法 到下一个 <公开 类型 = 逻辑型 注释 = "第一次使用前要使用“到数组首”使指针指向第一个值，读取完毕再执行将会返回假" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) return FBroDoubleString_ToNext(m_data);
        返回 (假)



    }

    方法 取当前位置数据 <公开 类型 = FBrowser_双文本>
    {
        变量 temp <类型 = FBrowser_双文本>
        temp.name = 取当前位置数据_关键字 ()
        temp.value = 取当前位置数据_数据 ()
        返回 (temp)
    }

    方法 取当前位置数据_关键字 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroDoubleString_GetCurrentData_Key(m_data);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 取当前位置数据_数据 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroDoubleString_GetCurrentData_Value(m_data);
        @ return FBroUnit::FBroStringToCWString(fbrostring);


    }

    方法 置当前位置数据 <公开 注释 = "通过到首位置、下一个控制当前位置后设置当前的值" @禁止流程检查 = 真>
    参数 值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroDoubleString_SetCurrentData(m_data,@<值>.GetText());

    }

    方法 查找数据 <公开 类型 = 文本型 注释 = "通过KEY查找value，查找到返回value，否则返回\"\"" @禁止流程检查 = 真>
    参数 关键字 <类型 = 文本型>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroDoubleString_FindKeyValue(m_data,@<关键字>.GetText());
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 删除数据 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 关键字 <类型 = 文本型>
    {
        @ if(IsEmpty()) return false;
        @ return FBroDoubleString_Delete(m_data,@<关键字>.GetText());

    }

    方法 清空 <公开>
    {
        @ if(!IsEmpty()) FBroDoubleString_Clear(m_data);



    }
}

