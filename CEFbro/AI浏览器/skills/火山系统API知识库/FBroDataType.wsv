    #     @<禁用打印事件> = m_data.disableGetPrintHandler;
    #     @<禁用离屏渲染事件> = m_data.disableGetRenderHandler;
    #     @<禁用请求事件> = m_data.disableGetRequestHandler;
    # }
    # @end
    #
}

