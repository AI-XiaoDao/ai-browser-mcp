    变量 禁用命令事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetCommandHandler 控制“浏览器_即将执行Chrome命令”事件，暂不只支持未使用">
    变量 禁用菜单事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetContextMenuHandler">
    变量 禁用对话框事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetDialogHandler">
    变量 禁用显示事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetDisplayHandler，主要控制状态栏显示,全屏显示等事件">
    变量 禁用下载事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetDownloadHandler">
    变量 禁用触摸事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetDragHandler">
    变量 禁用查找事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetFindHandler">
    变量 禁用焦点事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetFocusHandler">
    变量 禁用框架事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetFrameHandler，暂不只支持未使用">
    变量 禁用媒体许可事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetPermissionHandler，暂不只支持未使用">
    变量 禁用JS对话框事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetJSDialogHandler">
    变量 禁用键盘事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetKeyboardHandler">
    变量 禁用生命周期事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetLifeSpanHandler，主要控制浏览器创建销毁等事件，不建议禁用">
    变量 禁用加载事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetLoadHandler，主要控制即将加载资源等事件">
    变量 禁用打印事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetPrintHandler linux平台才有用，这里设置没意义，无用保留格式而已">
    变量 禁用离屏渲染事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetRenderHandler">
    变量 禁用请求事件 <公开 类型 = 逻辑型 值 = 假 注释 = "disableGetRequestHandler，主要控制包含请求的事件">

    # @begin
    # <> <include>
    # ~@sn<current_class>(){} //销毁构析函数
    # @sn<current_class> (Event_Disable_Control data) : @sn<current_class> () { m_data = data;ToHsData();}
    # Event_Disable_Control* ToFBroData();
    # void ToHsData();
    # Event_Disable_Control m_data;
    # <> </include>
    # Event_Disable_Control* @sn<current_class>::ToFBroData(){
    #     m_data.disableGetAudioHandler = @<禁用音频获取事件>;
    #     m_data.disableGetCommandHandler = @<禁用命令事件>;
    #     m_data.disableGetContextMenuHandler = @<禁用菜单事件>;
    #     m_data.disableGetDialogHandler = @<禁用对话框事件>;
    #     m_data.disableGetDisplayHandler = @<禁用显示事件>;
    #     m_data.disableGetDownloadHandler = @<禁用下载事件>;
    #     m_data.disableGetDragHandler = @<禁用触摸事件>;
    #     m_data.disableGetFindHandler = @<禁用查找事件>;
    #     m_data.disableGetFocusHandler = @<禁用焦点事件>;
    #     m_data.disableGetFrameHandler = @<禁用框架事件>;
    #     m_data.disableGetPermissionHandler = @<禁用媒体许可事件>;
    #     m_data.disableGetJSDialogHandler = @<禁用JS对话框事件>;
    #     m_data.disableGetKeyboardHandler = @<禁用键盘事件>;
    #     m_data.disableGetLifeSpanHandler = @<禁用生命周期事件>;
    #     m_data.disableGetLoadHandler = @<禁用加载事件>;
    #     m_data.disableGetPrintHandler = @<禁用打印事件>;
    #     m_data.disableGetRenderHandler = @<禁用离屏渲染事件>;
    #     m_data.disableGetRequestHandler = @<禁用请求事件>;
    #     return &m_data;
    # }
    # void @sn<current_class>::ToHsData(){
    #     @<禁用音频获取事件> = m_data.disableGetAudioHandler;
    #     @<禁用命令事件> = m_data.disableGetCommandHandler;
    #     @<禁用菜单事件> = m_data.disableGetContextMenuHandler;
    #     @<禁用对话框事件> = m_data.disableGetDialogHandler;
    #     @<禁用显示事件> = m_data.disableGetDisplayHandler;
    #     @<禁用下载事件> = m_data.disableGetDownloadHandler;
    #     @<禁用触摸事件> = m_data.disableGetDragHandler;
    #     @<禁用查找事件> = m_data.disableGetFindHandler;
    #     @<禁用焦点事件> = m_data.disableGetFocusHandler;
