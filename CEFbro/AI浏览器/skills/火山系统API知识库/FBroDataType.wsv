    方法 加入数据 <公开 类型 = 整数 注释 = "加入数据，并返回数据ID，ID为累加唯一标识" @禁止流程检查 = 真>
    参数 驱动ID <类型 = 文本型>
    参数 硬件名 <类型 = 文本型>
    参数 分组ID <类型 = 文本型>
    {
        @ return AddItem(@<驱动ID>.GetText(),@<硬件名>.GetText(),@<分组ID>.GetText());
    }

    方法 删除数据 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 ID <类型 = 整数>
    {
        @ return DeleteItem(@<ID>);
    }

    方法 取驱动ID <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 ID <类型 = 整数>
    {
        @ return GetItemDeviceId(@<ID>);
    }

    方法 取驱动名 <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 ID <类型 = 整数>
    {
        @ return GetItemLabel(@<ID>);
    }

    方法 取分组ID <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 ID <类型 = 整数>
    {
        @ return GetItemGroupId(@<ID>);
    }

    方法 清空全部数据 <公开 @禁止流程检查 = 真>
    {
        @ Clear();
    }

    方法 取数量 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return Size();
    }

    # @end
}

