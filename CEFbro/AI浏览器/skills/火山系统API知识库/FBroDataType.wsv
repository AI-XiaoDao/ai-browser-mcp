    {
        @ m_data=FBroCefStringList_Creat();
    }

    #

    方法 取个数 <公开 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return FBroCefStringList_Size(m_data);//.size();
    }

    方法 加入成员 <公开>
    参数 成员 <类型 = 文本型>
    {
        @ if(!IsEmpty()) FBroCefStringList_Add(m_data, @<成员>.GetText());
    }

    方法 到数组首 <公开 注释 = "当前指向数组第一个数据">
    {
        @ if(!IsEmpty()) FBroCefStringList_ToBegin(m_data);
    }

    方法 到下一个 <公开 类型 = 逻辑型 注释 = "第一次使用前要使用“到数组首”使指针指向第一个值，读取完毕再执行将会返回假" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty()) return FBroCefStringList_ToNext(m_data);
        返回 (假)

    }

    方法 取数据 <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 索引 <类型 = 整数 注释 = "0开始">
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroCefStringList_GetValue(m_data,@<索引>);
        @ return FBroUnit::FBroStringToCWString(fbrostring);


    }

    方法 取当前位置数据 <公开 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroCefStringList_GetCurrentData_Value(m_data);
        @ return FBroUnit::FBroStringToCWString(fbrostring);


    }

    方法 置当前位置数据 <公开 注释 = "通过到首位置、下一个控制当前位置后设置当前的值" @禁止流程检查 = 真>
    参数 值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroCefStringList_SetCurrentData(m_data,@<值>.GetText());

    }

    方法 删除数据 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 值 <类型 = 文本型>
    {
        @ if(IsEmpty()) return false;
        @ return FBroCefStringList_Delete(m_data,@<值>.GetText());

    }

    方法 清空 <公开>
    {
        @ if(!IsEmpty()) FBroCefStringList_Clear(m_data);



    }

    方法 到火山文本数组 <公开 类型 = 文本数组类 @禁止流程检查 = 真>
    {
        变量 tempret <类型 = 文本数组类>
        如果真 (取个数 () > 0)
        {
            到数组首 ()
            循环判断首 ()
            {
                tempret.加入成员 (取当前位置数据 ())
            }
            循环判断尾 (到下一个 ())

        }

        返回 (tempret)

    }
}

