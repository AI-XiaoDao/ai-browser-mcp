类 FBrowser_PDF打印设置 <公开 折叠>
{
    变量 横向模式 <公开 类型 = 逻辑型 注释 = "英文名：landscape 说明：Set to true (1) for landscape mode or false (0) for portrait mode.">
    变量 打印背景 <公开 类型 = 逻辑型 注释 = "英文名：print_background 说明：Set to true (1) to print background graphics.">
    变量 缩放比例 <公开 类型 = 小数
            注释 = "英文名：scale 说明：The percentage to scale the PDF by before printing (e.g. .5 is 50%).If this value is less than or equal to zero the default value of 1.0 will be used.">
    变量 页面宽度 <公开 类型 = 小数
            注释 = "英文名：paper_width 说明：Output paper size in inches. If either of these values is less than or equal to zero then the default paper size (letter, 8.5 x 11 inches) will be used.">
    变量 页面高度 <公开 类型 = 小数
            注释 = "英文名：paper_height 说明：Output paper size in inches. If either of these values is less than or equal to zero then the default paper size (letter, 8.5 x 11 inches) will be used.">
    变量 首选CSS页面大小 <公开 类型 = 逻辑型
            注释 = "英文名：prefer_css_page_size 说明：Set to true (1) to prefer page size as defined by css. Defaults to false (0), in which case the content will be scaled to fit the paper size.">
    变量 边框类型 <公开 类型 = 整数 注释 = "英文名：margin_type 说明：Margin type.参考：#PDF打印_边框">
    变量 边框顶点 <公开 类型 = 小数
            注释 = "英文名：margin_top 说明：Margins in inches. Only used if |margin_type| is set to PDF_PRINT_MARGIN_CUSTOM.">
    变量 边框右边 <公开 类型 = 小数
            注释 = "英文名：margin_right 说明：Margins in inches. Only used if |margin_type| is set to PDF_PRINT_MARGIN_CUSTOM.">
    变量 边框底部 <公开 类型 = 小数
            注释 = "英文名：margin_bottom 说明：Margins in inches. Only used if |margin_type| is set to PDF_PRINT_MARGIN_CUSTOM.">
    变量 边框左边 <公开 类型 = 小数
            注释 = "英文名：margin_left 说明：Margins in inches. Only used if |margin_type| is set to PDF_PRINT_MARGIN_CUSTOM">
    变量 页面范围 <公开 类型 = 文本型
            注释 = "英文名：page_ranges 说明：Paper ranges to print, one based, e.g., \'1-5, 8, 11-13\'. Pages are printed in the document order, not in the order specified, and no more than once.Defaults to empty string, which implies the entire document is printed.">
    变量 显示页眉页脚 <公开 类型 = 逻辑型
            注释 = "英文名：display_header_footer 说明：Set to true (1) to display the header and/or footer. Modify |header_template| and/or |footer_template| to customize the display.">
    变量 头模板 <公开 类型 = 文本型
            注释 = "英文名：header_template 说明：HTML template for the print header. Only displayed if |display_header_footer| is true (1). Should be valid HTML markup with the following classes used to inject printing values into them:For example, \"<span class=title></span>\" would generate a span containing the title.">
    变量 页脚模板 <公开 类型 = 文本型
            注释 = "英文名：footer_template 说明：HTML template for the print footer. Only displayed if |display_header_footer| is true (1). Uses the same format as |header_template|.">
    变量 生成带标签的PDF <公开 类型 = 逻辑型 注释 = "英文名：generate_tagged_pdf 说明：Set to true (1) to generate tagged (accessible) PDF.">
    变量 生成文档大纲 <公开 类型 = 逻辑型 注释 = "英文名：generate_document_outline 说明：Set to true (1) to generate a document outline.">

    # @begin
    # <> <include>
    # ~@sn<current_class>(){release();} //销毁构析函数
    # @sn<current_class> (FBroPdfPrintSettings data) : @sn<current_class> () { m_data = data;ToHsData();}
    # FBroPdfPrintSettings* ToFBroData();
    # void ToHsData();
    # void release();
    # FBroPdfPrintSettings m_data;
    #
    # <> </include>
    # FBroPdfPrintSettings* @sn<current_class>::ToFBroData(){
    #     m_data.landscape;
    #     m_data.print_background;
    #     m_data.scale;
    #     m_data.paper_width;
    #     m_data.paper_height;
    #     m_data.prefer_css_page_size;
    #     m_data.margin_type;
    #
    #     m_data.margin_top;
    #     m_data.margin_right;
    #     m_data.margin_bottom;
    #     m_data.margin_left;
    #
    #     m_data.page_ranges=FBroUnit::UnicodeToAnsi(@<页面范围>.GetText());
    #
    #     m_data. display_header_footer;
    #
    #     m_data.header_template=FBroUnit::UnicodeToAnsi(@<头模板>.GetText());
    #     m_data.footer_template=FBroUnit::UnicodeToAnsi(@<页脚模板>.GetText());
    #
    #     m_data.generate_tagged_pdf;
    #     m_data.generate_document_outline;
    #
    #     return &m_data;
    # }
    # void @sn<current_class>::ToHsData(){
    #     @<横向模式> = m_data.landscape;
    #     @<打印背景> = m_data.print_background;
    #     @<缩放比例> = m_data.scale;
    #     @<页面宽度> = m_data.paper_width;
    #     @<页面高度> = m_data.paper_height;
    #     @<首选CSS页面大小> = m_data.prefer_css_page_size;
