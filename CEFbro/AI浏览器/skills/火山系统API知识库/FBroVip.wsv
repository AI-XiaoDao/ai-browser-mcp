    方法 指纹_设置SSL加密套件 <公开 注释 = "VIP功能，需要赞助后才能使用,用于TLS指纹，通过此设置即可控制对应的TLS协议，以达到修改TLS指纹的效果；" 注释 = "注意：协议如果设置错误可能会导致网页无法打开或者某些功能异常；">
    参数 TLS最小版本 <类型 = TLS版本 注释 = "参考：TLS版本,不设置默认为1.2到1.3" @默认值 = TLS版本.空>
    参数 TLS最大版本 <类型 = TLS版本 注释 = "参考：TLS版本,不设置默认为1.2到1.3" @默认值 = TLS版本.空>
    参数 加密支持文本 <类型 = 文本型 注释 = "设置支持的加密方式，不设置当前浏览器默认值为“ALL:!aPSK:!ECDSA+SHA1:!3DES”，"
            注释 = "可设置的值包括kRSA，kDHE，kECDHE，kPSK，kECDHE，kPSK，aRSA，aECDSA，aPSK，RSA，DHE，ECDHE，PSK，ECDSA，PSK，RSA，kRSA，aRSA，3DES，AES128，AES256，AES，AESGCM，CHACHA20，AES，AES128，AES256，SHA1，SHA；"
            注释 = "多个值用小写的冒号隔开；" 注释 = "例如：“ALL:!AES128”其中ALL代表使用所有套件，带!的代表排除的项，因此这个意思就是包括全部套件除了AES128;"
            注释 = "当然也可以不用ALL，直接指定可设置的值，例如：“AES128:AES256”">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetSSLCipher(m_class,@<TLS最小版本>,@<TLS最大版本>,@<加密支持文本>.GetText());

    }

