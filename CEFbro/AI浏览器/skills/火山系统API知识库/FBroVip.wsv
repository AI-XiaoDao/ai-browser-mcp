    方法 逐字分割
    参数 待分割文本 <类型 = 文本型>
    参数 返回数据 <类型 = 文本数组类>
    {
        @ std::wstring wstr(@<待分割文本>.GetText());
        @ for(wchar_t ch: wstr){std::wstring temp(1, ch);@<返回数据>.data ().Add2(temp.c_str());}

    }

    方法 高级键盘_输入文本 <公开 注释 = "模拟输入连续的文本，可以是中文，VIP高级功能，需赞助后才能使用，向浏览器发送键盘事件，支持后台操作" "">
    参数 文本 <类型 = 文本型 注释 = "输入文本，可以是中文，连续的文本">
    参数 逐字输入延时 <类型 = 整数 注释 = "单位：毫秒；为空，默认为0，不延时" @默认值 = 0>
    {
        变量 listData <类型 = 文本数组类>
        逐字分割 (文本, listData)
        计次循环 (listData.取成员数 ())
        {
            变量 tempStr <类型 = 文本型>
            tempStr = listData.取成员 (取循环索引 ())
            高级键盘_输入字符 (tempStr)
            @ FBroUnit::WaitUserTimer(@<逐字输入延时>);

        }

    }

    方法 高级_发送鼠标事件 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送">
    参数 类型 <类型 = 文本型 注释 = "type:Type of the mouse event.Allowed Values: mousePressed, mouseReleased, mouseMoved, mouseWheel."
            注释 = "鼠标事件类型。允许的值:mousePressed, mouserrelease, mouemoved, mouseWheel">
    参数 横坐标 <类型 = 整数 注释 = "x:X coordinate of the event relative to the main frame\'s viewport in CSS pixels."
            注释 = "事件相对于主帧视口的X坐标(CSS像素)。" "">
    参数 纵坐标 <类型 = 整数
            注释 = "y:Y coordinate of the event relative to the main frame\'s viewport in CSS pixels. 0 refers to the top of the viewport and Y increases as it proceeds towards the bottom of the viewport."
            注释 = "y:在CSS像素中，事件相对于主帧视口的y坐标。0表示视口的顶部，Y则随着它向视口的底部移动而增加。">
    参数 修饰键 <类型 = 整数
            注释 = "modifiers:Bit field representing pressed modifier keys. Alt=1, Ctrl=2, Meta/Command=4, Shift=8 (default: 0)."
            注释 = "表示按下的修饰键的位域。Alt=1, Ctrl=2, Meta/Command=4, Shift=8(默认值:0)。" @默认值 = 0>
    参数 按键文本 <类型 = 文本型
            注释 = "button:Allowed Values: none, left, middle, right, back, forward.允许值:none, left, middle, right, back, forward"
            @默认值 = "">
    参数 按键集 <类型 = 整数
            注释 = "buttons:A number indicating which buttons are pressed on the mouse when a mouse event is triggered. Left=1, Right=2, Middle=4, Back=8, Forward=16, None=0."
            注释 = "按钮:当触发鼠标事件时，指示按下鼠标上哪些按钮的数字。左=1，右=2，中=4，后=8，前=16，无=0" @默认值 = 0>
    参数 点击次数 <类型 = 整数 注释 = "clickCount:Number of times the mouse button was clicked (default: 0)." 注释 = "点击鼠标按钮的次数(默认值:0)。"
            @默认值 = 0>
    参数 CSS像素横坐标 <类型 = 整数 注释 = "deltaX:X delta in CSS pixels for mouse wheel event (default: 0)."
            注释 = "鼠标滚轮事件的CSS像素的X delta(默认值:0)。" @默认值 = 0>
    参数 CSS像素纵坐标 <类型 = 整数 注释 = "deltaY:Y delta in CSS pixels for mouse wheel event (default: 0)."
            注释 = "鼠标滚轮事件在CSS像素中的Y delta(默认值:0)。" @默认值 = 0>
    参数 指针类型 <类型 = 文本型 注释 = "pointerType:Pointer type (default: \"mouse\").Allowed Values: mouse, pen."
            注释 = "指针类型(默认:\"mouse\")。允许的值:mouse，pen" @默认值 = "">
    {
        @ FBroHsVIPControl_DispatchMouseEvent (m_class, @<类型>.GetText(), @<横坐标>, @<纵坐标>, @<修饰键>, @<按键文本>.GetText(), @<按键集>, @<点击次数>, @<CSS像素横坐标>, @<CSS像素纵坐标>, @<指针类型>.GetText());

    }

    方法 高级鼠标_按下 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送，不占用鼠标">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 按键类型 <类型 = 整数 注释 = "0为左键，1为中间，2为右键，默认为0，左键" @默认值 = 0>
    {
        变量 按键文本 <类型 = 文本型>
        如果 (按键类型 == 0)
        {
            按键文本 = "left"
        }
        否则 (按键类型 == 1)
        {
            按键文本 = "middle"
        }
        否则 (按键类型 == 2)
        {
            按键文本 = "right"

        }
        高级_发送鼠标事件 ("mousePressed", 横坐标, 纵坐标, , 按键文本, , 1, , , )
    }

    方法 高级鼠标_放开 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送，不占用鼠标">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 按键类型 <类型 = 整数 注释 = "0为左键，1为中间，2为右键，默认为0，左键" @默认值 = 0>
    {
        变量 按键文本 <类型 = 文本型>
        如果 (按键类型 == 0)
        {
            按键文本 = "left"
        }
        否则 (按键类型 == 1)
        {
            按键文本 = "middle"
        }
        否则 (按键类型 == 2)
        {
            按键文本 = "right"

        }
        高级_发送鼠标事件 ("mouseReleased", 横坐标, 纵坐标, , 按键文本, , 1, , , )
    }

    方法 高级鼠标_移动 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送，不占用鼠标">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    {
        高级_发送鼠标事件 ("mouseMoved", 横坐标, 纵坐标, , , , , , , )
    }

    方法 高级鼠标_滚轮滚动 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送，不占用鼠标">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 横向滚动 <类型 = 整数 注释 = "负数向左，正数向右，以像素点位单位">
    参数 纵向滚动 <类型 = 整数 注释 = "负数向上，正数向下，以像素点位单位">
    {
        高级_发送鼠标事件 ("mouseWheel", 横坐标, 纵坐标, , , , , 横向滚动, 纵向滚动, )
    }

    方法 高级鼠标_单击 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送鼠标事件，支持后台发送，不占用鼠标">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 按键类型 <类型 = 整数 注释 = "0为左键，1为中间，2为右键，默认为0，左键">
    参数 单击延时 <类型 = 整数 注释 = "单位：毫秒；为空，默认为50毫秒" @默认值 = 50>
    {
        高级鼠标_按下 (横坐标, 纵坐标, 按键类型)
        @ FBroUnit::WaitUserTimer(@<单击延时>);
        高级鼠标_放开 (横坐标, 纵坐标, 按键类型)

    }

    方法 过滤器_修改内容 <公开 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源过滤器自行分包处理，此功能更方便更快；"
            注释 = "对目标地址通过匹配目标文本修改内容，在资源加载前设置，浏览器创建后设置，如果\"浏览器_获取资源过滤器\"事件中返回真自定义拦截此设置将不会生效；"
            注释 = "如果同一个目标存在多个需要修改的数据，多次调用本方法即可，但要注意目标地址和匹配模式要保持一致，否则可能会出错">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 替换模式 <类型 = 整数 注释 = "VIP过滤器.xxx;如果模式为插入，将会在查找到的目标文本后面插入替换的文本；模式为修改，将会将目标文本删除替换为新文本；">
    参数 目标文本 <类型 = 文本型 注释 = "要查找的文本">
    参数 替换文本 <类型 = 文本型 注释 = "要替换或插入的文本">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_AddResponseFilterChangeData (m_class,@<匹配模式>,@<目标地址>.GetText(), @<替换模式>, @<目标文本>.GetText(), @<替换文本>.GetText());
    }

    方法 过滤器_取消修改内容 <公开 注释 = "在资源加载前设置，取消当前浏览器设置的对应目标地址的修改内容">
    参数 目标地址 <类型 = 文本型 注释 = "和之前设置的目标地址一一对应">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_DeletResponseFiltereChangeData (m_class,@<目标地址>.GetText());

    }

    方法 过滤器_取消全部修改内容 <公开 注释 = "在资源加载前设置，取消当前浏览器设置的对应目标地址的修改内容">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_DeleteResponseFilterAllData (m_class);

    }

    方法 过滤器_替换资源_数据 <公开 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源处理器自行分包处理，此功能更方便更快；"
            注释 = "用数据直接将整体链接资源替换，在资源加载前设置，也可在浏览器创建后设置，如果\"浏览器_获取资源处理器\"事件中返回真自定义资源此设置将不会生效">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 MINI类型 <类型 = 文本型 注释 = "mini_type，资源类型，和协议头的content-type对应，例如：\"application/javascript\"或\"text/html\"，如果不设置默认为download">
    参数 响应协议头 <类型 = FBrowser_双文本数组 注释 = "要设置的资源响应的协议头" @默认值 = 空对象>
    参数 替换的数据 <类型 = 字节集类>
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_AddResourceHandlerChangeData (m_class,@<匹配模式>,@<目标地址>.GetText(), @<MINI类型>.GetText(), @<响应协议头>.m_data, @<替换的数据>.GetPtr (),@<替换的数据>.GetSize ());
    }

    方法 过滤器_替换资源_文件 <公开 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源处理器自行分包处理，此功能更方便更快；"
            注释 = "用本地文件直接将整体链接资源替换，在资源加载前设置，也可在浏览器创建后设置，如果\"浏览器_获取资源处理器\"事件中返回真自定义资源此设置将不会生效">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 MINI类型 <类型 = 文本型 注释 = "mini_type，资源类型，和协议头的content-type对应，例如：\"application/javascript\"或\"text/html\"，如果不设置默认为download">
    参数 响应协议头 <类型 = FBrowser_双文本数组 注释 = "要设置的资源响应的协议头" @默认值 = 空对象>
    参数 替换的文件 <类型 = 文本型 注释 = "完整的路径+文件名，例如：\"F:\\\\xxx\\\\xxx\\\\xxx.txt\"">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_AddResourceHandlerChangeFile (m_class,@<匹配模式>,@<目标地址>.GetText(), @<MINI类型>.GetText(), @<响应协议头>.m_data,@<替换的文件>.GetText());
    }

    方法 过滤器_取消替换资源 <公开 注释 = "在资源加载前设置，取消当前浏览器设置的对应目标地址的替换资源">
    参数 目标地址 <类型 = 文本型 注释 = "和之前设置的目标地址一一对应">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_DeleteResourceHandlerChangeData (m_class,@<目标地址>.GetText());

    }

    方法 过滤器_取消全部替换资源 <公开 注释 = "在资源加载前设置，取消当前浏览器设置的所有替换的资源">
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_DeleteResourceHandlerAllData (m_class);

    }

    方法 高级_创建标签浏览器 <公开 注释 = "VIP高级功能，需赞助后才能使用，谷歌模式下才可以使用，" 注释 = "在当前谷歌UI界面创建一个新的Tab标签浏览器，" 注释 = "设置了浏览器事件后即可和创建浏览器一样控制该标签浏览器">
    参数 地址 <类型 = 文本型 注释 = "可以为空，为空会获取当前浏览器的地址">
    参数 序号 <类型 = 整数 注释 = "UI上需要插入的序号位置，设置为-1为在末尾添加" @默认值 = -1>
    参数 是否激活 <类型 = 逻辑型 注释 = "为真会激活并跳转标签，为假为不激活" @默认值 = 假>
    参数 额外信息 <类型 = 类_FBrowser_字典值 注释 = "传递给事件的额外数据，可不设置，和创建浏览器不同的事这里不会传递给渲染进程" @默认值 = 空对象>
    参数 浏览器事件 <类型 = 类_FBrowser_事件智能指针 注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_浏览器事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    参数 禁用事件 <类型 = FBrowser_禁用事件 注释 = "当前浏览器器事件开关，可关闭某些不必要的事件加载，合理设置可提高加载速度" @默认值 = 空对象>
    参数 标识 <类型 = 文本型 注释 = "设置创建后的浏览器的用户标识，设置后可通过用户标识获取到对应的浏览器，注意用户标识不要重复" @默认值 = "">
    {
        @ if(IsEmpty()) return;
        @ _FBRO_CHECK_EVENT_TYPE(@<浏览器事件>.GetPtr(),BroEventType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsBroEvent> hsbroevent = static_cast<FBroHsBroEvent*>(@<浏览器事件>.GetPtr());
        @ FBroHsVIPControl_AddTabAt (m_class, @<地址>.GetText(), @<序号>, @<是否激活>, @<额外信息>.m_class,hsbroevent, @<禁用事件>.ToFBroData(), @<标识>.GetText());

    }

    方法 内核开关_禁用ConsoleDebug <公开 注释 = "VIP功能，需赞助后才能使用，禁用console.debug功能防止检测到开发者工具">
    参数 是否禁用 <类型 = 逻辑型 注释 = "为真为禁用，假为不禁用">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetDisableConsoleDebug(m_class,@<是否禁用>);

    }

