            @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return;
        @ CWString temp = @an<CVolString>(@<类型>) + _CT(";");
        @ if(!@<媒体硬件清单>.IsNullObject()) temp += @<媒体硬件清单>.MapToString();
        @ FBroHsVIPControl_SetVirAudioInput(m_class,temp.GetText());
    }

