<火山程序 类型 = "通常" 版本 = 1 />

包 浏览器.VIP

类 FBrowserVIP注册 <公开 @全局类 = 真>
{
    方法 VIP注册_取机器码 <公开 静态 类型 = 文本型 注释 = "取当前电脑机器码" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsBrowser_GetMachineCode();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取开始时间 <公开 静态 类型 = 文本型 注释 = "取注册VIP开始时间" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseStartDate();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取到期时间 <公开 静态 类型 = 文本型 注释 = "取VIP到期时间，永久版为空" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseEndDate();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取注册功能 <公开 静态 类型 = 文本型 注释 = "取注册的功能" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseFunction();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取注册版本 <公开 静态 类型 = 文本型 注释 = "取注册的版本" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseDevTool();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取注册码类型 <公开 静态 类型 = 文本型 注释 = "取注册的版本" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseType();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_取目标系统平台 <公开 静态 类型 = 文本型 注释 = "取注册的版本" @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetShowLicenseSysVersion();
        @ return FBroUnit::FBroStringToCWString(temp);


    }

    方法 VIP注册_取错误信息 <公开 静态 类型 = 文本型 @禁止流程检查 = 真>
    {
        @ CefRefPtr<FBroString> temp = FBroHsOnlineLicenseControl_GetError();
        @ return FBroUnit::FBroStringToCWString(temp);

    }

    方法 VIP注册_置授权码 <公开 静态 类型 = 逻辑型 注释 = "在浏览器初始化之前，否则将会出现功能异常">
    参数 授权码 <类型 = 文本型>
    {
        @ if(FBroGetProcessType() != BrowserProcess) return true;//其他进程不处理直接返回真

        变量 设置成功 <类型 = 逻辑型>
        @ @<设置成功> = FBroHsOnlineLicenseControl_SetKey (@<授权码>.GetText());

        如果真 (设置成功)
        {
            变量 VIP注册版本 <类型 = 文本型>
            VIP注册版本 = VIP注册_取注册版本 ()
            如果真 (寻找文本 (VIP注册版本, "火山", , ) != -1)
            {
                FBrowser初始化控制.是否为VIP = 真
                返回 (真)
            }

        }

        调试输出 ("【FBrowserVIP注册】尊敬的VIP用户：校验失败，已到期或许可KEY已失效，详情请联系作者")
        返回 (假)

    }

    方法 VIP注册_生成本地授权文件 <静态 注释 = "弃用，仅永久版用户使用有效且仅调试模式下有效，在“VIP注册_置授权码”之前调用；" 注释 = "调试时会生成授权文件，用于控制发布版用户授权模式和到期时间；"
            注释 = "使用该模式需要将本地授权文件一起拷贝给用户VIP功能才会生效，否则无效，不调用此功能则为不使用授权文件">
    参数 授权码 <类型 = 文本型 注释 = "和“VIP注册_置授权码”保持一致，否则无效">
    参数 授权类型 <类型 = 整数 注释 = "参考：VIP授权类型，设置为永久后到期时间无效">
    参数 授权功能 <类型 = 整数 注释 = "参考：VIP授权功能，多个功能相加或位或，本身具有功能的授权才能设置，否则设置无效">
    参数 授权开始时间 <类型 = 小数 注释 = "发布版开始时间，其实这个不起什么作用，最多发布的用户自己显示一下，如果设置了发布模式下调用“VIP注册_取开始时间”即该为设置的时间">
    参数 授权到期时间 <类型 = 小数 注释 = "发布版到期时间，如果设置了发布模式下调用“VIP注册_取到期时间”即为该设置的时间">
    {
        变量 开始时间 <类型 = 文本型>
        变量 到期时间 <类型 = 文本型>
        开始时间 = 时间到格式文本 (授权开始时间, "%Y-%m-%d %H:%M:%S")
        到期时间 = 时间到格式文本 (授权到期时间, "%Y-%m-%d %H:%M:%S")

        @ FBroHsOnlineLicenseControl_SetLocalLicence (@<授权码>.GetText(),@<授权类型>,@<授权功能>,@<开始时间>.GetText(),@<到期时间>.GetText());

    }
}

类 FBrowserVIP全局功能 <公开 注释 = "VIP功能，需要赞助后才能使用" @全局类 = 真>
{
    方法 FBrowser_VIP功能_启用插件高级功能 <公开 静态 注释 = "VIP功能，需赞助后才能使用,必须在加载插件前启用，启用插件的高级功能，默认CEF不支持插件content_scripts.js脚本执行，启用高级功能后才能支持">
    {
        @ FBroHsVIPRequestContext_EnableExtensionPlus();
    }

    方法 FBrowser_VIP过滤器_修改内容 <公开 静态 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源过滤器自行分包处理，此功能更方便更快；"
            注释 = "对目标地址通过匹配目标文本修改内容，在资源加载前设置，也可在初始化后设置，使用该方法后对应请求目标地址的\"浏览器_获取资源过滤器\"事件将不会被触发；"
            注释 = "如果同一个目标存在多个需要修改的数据，多次调用本方法即可，但要注意目标地址和匹配模式要保持一致，否则可能会出错">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 替换模式 <类型 = 整数 注释 = "VIP过滤器.xxx;如果模式为插入，将会在查找到的目标文本后面插入替换的文本；模式为修改，将会将目标文本删除替换为新文本；">
    参数 目标文本 <类型 = 文本型 注释 = "要查找的文本">
    参数 替换文本 <类型 = 文本型 注释 = "要替换或插入的文本">
    {
        @ FBroHsVIPResponseFilter_AddChangeData (@<匹配模式>,@<目标地址>.GetText(), @<替换模式>, @<目标文本>.GetText(), @<替换文本>.GetText());
    }

    方法 FBrowser_VIP过滤器_取消修改内容 <公开 静态 注释 = "在资源加载前设置，取消全局之前设置的对应目标地址的修改内容">
    参数 目标地址 <类型 = 文本型 注释 = "和之前设置的目标地址一一对应">
    {
        @ FBroHsVIPResponseFilter_DeleteChangeData (@<目标地址>.GetText());

    }

    方法 FBrowser_VIP过滤器_取消全部修改内容 <公开 静态 注释 = "在资源加载前设置，取消全局所有的修改内容">
    {
        @ FBroHsVIPResponseFilter_DeleteAllData ();

    }

    方法 FBrowser_VIP过滤器_替换资源_数据 <公开 静态 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源处理器自行分包处理，此功能更方便更快；"
            注释 = "用数据直接将整体链接资源替换，在资源加载前设置，也可在初始化后设置，使用该方法后对应请求目标地址的\"浏览器_获取资源处理器\"事件将不会被触发">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 MINI类型 <类型 = 文本型 注释 = "mini_type，资源类型，和协议头的content-type对应，例如：\"application/javascript\"或\"text/html\"，如果不设置默认为download">
    参数 响应协议头 <类型 = FBrowser_双文本数组 注释 = "要设置的资源响应的协议头" @默认值 = 空对象>
    参数 替换的数据 <类型 = 字节集类>
    {
        @ FBroHsVIPResourceHandler_AddChangeData (@<匹配模式>,@<目标地址>.GetText(), @<MINI类型>.GetText(), @<响应协议头>.m_data, @<替换的数据>.GetPtr (),@<替换的数据>.GetSize ());
    }

    方法 FBrowser_VIP过滤器_替换资源_文件 <公开 静态 注释 = "VIP高级功能，需赞助后才能使用，非VIP用户可通过资源处理器自行分包处理，此功能更方便更快；"
            注释 = "用数据直接将整体链接资源替换，在资源加载前设置，也可在初始化后设置，使用该方法后对应请求目标地址的\"浏览器_获取资源处理器\"事件将不会被触发">
    参数 匹配模式 <类型 = 整数 注释 = "地址匹配模式，参考：VIP过滤器地址." @默认值 = VIP过滤器地址.完全匹配>
    参数 目标地址 <类型 = 文本型 注释 = "要替换目标资源链接地址，地址要为完整地址">
    参数 MINI类型 <类型 = 文本型 注释 = "mini_type，资源类型，和协议头的content-type对应，例如：\"application/javascript\"或\"text/html\"，如果不设置默认为download">
    参数 响应协议头 <类型 = FBrowser_双文本数组 注释 = "要设置的资源响应的协议头" @默认值 = 空对象>
    参数 替换的文件 <类型 = 文本型 注释 = "完整的路径+文件名，例如：\"F:\\\\xxx\\\\xxx\\\\xxx.txt\"">
    {
        @ FBroHsVIPResourceHandler_AddChangeFile (@<匹配模式>,@<目标地址>.GetText(), @<MINI类型>.GetText(), @<响应协议头>.m_data,@<替换的文件>.GetText());
    }

    方法 FBrowser_VIP过滤器_取消替换资源 <公开 静态 注释 = "在资源加载前设置，取消之前设置的对应目标地址的替换资源">
    参数 目标地址 <类型 = 文本型 注释 = "和之前设置的目标地址一一对应">
    {
        @ FBroHsVIPResourceHandler_DeleteChangeData (@<目标地址>.GetText());

    }

    方法 FBrowser_VIP过滤器_取消全部替换资源 <公开 静态 注释 = "在资源加载前设置，取消之前设置的所有替换的资源，包括通过浏览器设置的资源">
    {
        @ FBroHsVIPResourceHandler_DeleteAllData ();

    }
}

类 类_FBrowserVIP_控制器 <公开 注释 = "VIP功能，需要赞助后才能使用">
{

    # @begin
    # <> <include>
    #     CefRefPtr<FBroVIPControl> m_class;
    #     @sn<current_class> (CefRefPtr<FBroVIPControl> object) : @sn<current_class> () { m_class = object; }
    #     void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    #     BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    #     BOOL IsEmpty () const { return m_class.get () == nullptr; }
    #     void Set (CefRefPtr<FBroVIPControl> object) { m_class = object; }
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty() || FBroHsVIPControl_IsNULL(m_class);
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 取浏览器 <公开 类型 = 类_FBrowser_浏览器 注释 = "取出当前控制器对应的浏览器，如果不存在或者已经关闭将返回空" @禁止流程检查 = 真>
    {
        @ if(!IsEmpty ()) return @dt<类_FBrowser_浏览器>(FBroHsVIPControl_GetBrowser(m_class));
        @ return @dt<类_FBrowser_浏览器>();
    }

    方法 清理数据 <公开 注释 = "清理全部VIP设置的参数，包括指纹、代理、wss、debugger、isTrusted相关参数数据">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_ClearAllData(m_class);

    }

    方法 指纹_清空调用计数 <公开>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_ClearFingerCount(m_class);
    }

    方法 指纹_取调用计数 <公开 类型 = 文本型 注释 = "获取对应指纹被调用的次数，有的数据被调用不一定是为了指纹，仅供参考，返回类型为一个json文本" @禁止流程检查 = 真>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return CVolString();
        @ auto fbrostring = FBroHsVIPControl_GetFingerCount(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);


    }

    方法 指纹_虚拟ProductSub <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirProductSub(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟Vendor <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirVendor(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟VendorSub <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirVendorSub(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟UserAgent <公开 注释 = "虚拟用户标识，在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 userAgent <类型 = 类_FBrowserVIP_UA数据 注释 = "UA数据">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirUserAgent(m_class,@<userAgent>.m_class);
    }

    方法 指纹_虚拟Languages <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirLanguages(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟AppCodeName <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirAppCodeName(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟AppName <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirAppName(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟AppVersion <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirAppVersion(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟Product <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 文本型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirProduct(m_class,@<虚拟值>.GetText());
    }

    方法 指纹_虚拟HardwareConcurrency <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 整数>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirHardwareConcurrency(m_class,@<虚拟值>);
    }

    方法 指纹_虚拟CookieEnabled <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 逻辑型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirCookieEnabled(m_class,@<虚拟值>);
    }

    方法 指纹_虚拟DeviceMemory <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用">
    参数 虚拟值 <类型 = 整数>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirDeviceMemory(m_class,@<虚拟值>);
    }

    方法 指纹_虚拟Canvas_随机 <公开 类型 = 文本型 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用" @禁止流程检查 = 真>
    参数 最少噪点数 <类型 = 整数>
    参数 最大噪点数 <类型 = 整数 注释 = "100以下">
    参数 随机种子 <类型 = 整数>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsVIPControl_SetCanvasFingerPrint_random(m_class,@<最少噪点数>,@<最大噪点数>,@<随机种子>);
        @ return FBroUnit::FBroStringToCWString(fbrostring);

    }

    方法 指纹_虚拟WebGL_随机 <公开 类型 = 文本型 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用" @禁止流程检查 = 真>
    参数 最少噪点数 <类型 = 整数>
    参数 最大噪点数 <类型 = 整数 注释 = "100以下">
    参数 随机种子 <类型 = 整数>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> && IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsVIPControl_SetWebGLFingerPrint_random(m_class,@<最少噪点数>,@<最大噪点数>,@<随机种子>);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 指纹_虚拟Audio_随机 <公开 类型 = 文本型 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用" @禁止流程检查 = 真>
    参数 最少噪点数 <类型 = 整数 注释 = "最好不低于100个">
    参数 最大噪点数 <类型 = 整数 注释 = "1000以下">
    参数 随机种子 <类型 = 整数>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> && IsEmpty()) return CVolString();
