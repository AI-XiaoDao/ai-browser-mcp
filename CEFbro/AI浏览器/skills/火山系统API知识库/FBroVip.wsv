    参数 本地IP <类型 = 文本型 注释 = "本地地址一般是192、127、10开头，设置为“”则为不修改，如不设置一般默认是host名" @默认值 = "">
    参数 host <类型 = 文本型
            注释 = "本地本机名，一般样式为924ce16d-52c7-42a3-a29d-b78004f9e534234.local，也可直接设置为本地地址，不设置则为默认本地机器名，有的代理存在代理主机名，最好设置为一致" @默认值 = "">
    参数 是否禁用 <类型 = 逻辑型
            注释 = "禁用webrtc功能，设置为真禁用，禁用后IP等参数将无效，网页也无法获取到对应的地址数据，注意禁用后可能会导致某些网页判断无法使用webrtc而直接风控，建议还是通过参数设置为代理地址进行模拟修改" @默认值 = 假>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirWebrtcIP(m_class,@<当地IP>.GetText(),@<本地IP>.GetText(),@<host>.GetText(),@<是否禁用>);



    }

