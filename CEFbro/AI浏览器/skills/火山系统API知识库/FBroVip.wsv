    方法 指纹_虚拟定位 <公开 注释 = "虚拟Geolocation经纬度值，不设置此值默认CEF是获取不到经纬度的，本命令值支持实时设置；" 注释 = "注意：如还有通过外网IP判断定位，则要配合代理和webrtc一起使用，"
            注释 = "可通过navigator.geolocation.getCurrentPosition(function(t){console.log(t);})命令查看是否设置成功">
    参数 经度 <类型 = 小数 注释 = "longitude">
    参数 维度 <类型 = 小数 注释 = "latitude">
    参数 精确度 <类型 = 小数 注释 = "accuracy">
    参数 海拔 <类型 = 小数 注释 = "altitude" @默认值 = -10000>
    参数 海拔精确度 <类型 = 小数 注释 = "altitude_accuracy" @默认值 = -1>
    参数 方向 <类型 = 小数 注释 = "heading 0到360" @默认值 = -1>
    参数 速度 <类型 = 小数 注释 = "speed" @默认值 = -1>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return; 
        @ FBroHsVIPControl_SetVirLongitudeAndLatitude(m_class,@<经度>, @<维度>, @<海拔>, @<精确度>, @<海拔精确度>, @<方向>, @<速度>);
    }

    方法 指纹_虚拟屏幕方向 <公开 注释 = "VIP功能，需赞助后才能使用，用于手机模式下虚拟屏幕为横屏或者竖屏，配合分辨率窗口大小一起使用">
    参数 方向类型 <类型 = 屏幕方向类型 注释 = "设置方向类型，横屏或竖屏；参考:屏幕方向类型.，通过window.screen.orientation.type验证">
    参数 角度 <类型 = 整数 注释 = "-90到180，一般0为横屏，90为竖屏，可通过window.orientation验证">
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return; 
        @ FBroHsVIPControl_SetVirOrientation(m_class ,@<角度>,@<方向类型>);
    }

    方法 WebSocket_启用拦截 <公开>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_EnableWebsocketClientHook(m_class);

    }

    方法 高级_设置触发鼠标触摸事件 <公开 注释 = "在浏览器载入完成后调用,VIP功能，需要赞助后才能使用">
    参数 启用 <类型 = 逻辑型>
    参数 配置 <类型 = 整数 注释 = "默认为0，0为MOBILE模式，1为DESKTOP模式" @默认值 = 0>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetEmitTouchEventsForMouse(m_class,@<启用>,@<配置>);
    }

    方法 高级_设置代理 <公开 注释 = "设置当前浏览器代理，在\"浏览器_即将导航\"或\"浏览器_创建完毕\"事件中设置，也可在其他地方设置，但刷新后才会生效；"
            注释 = "配合独立缓存一起使用设置的代理也会成为独立，否则还是全局，如果需要认证则需要设置账号密码；" 注释 = "带账号密码的S5代理，需赞助会员才可使用"
            注释 = "注意：因为设置代理利用的首选项功能，如果启用了保留用户首选项，关闭的时候就要使用清理代理功能，否则可能再次打开浏览器还是使用的之前的代理，但又未手动设置账号密码或代理已经关闭而导致代理失败网页无法显示">
    参数 代理地址 <类型 = 文本型 注释 = "要区分大小写，不要有空格，否则地址错误将会设置失败">
    参数 代理账号 <类型 = 文本型 @默认值 = "">
    参数 代理密码 <类型 = 文本型 @默认值 = "">
    参数 关闭S5错误提示 <类型 = 逻辑型 注释 = "关闭S5代理错误弹窗提示，默认为假，为真关闭提示" @默认值 = 假>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty())
        @ {
        @    FBroHsVIPControl_SetS5Auth(m_class,@<代理地址>.GetText(),@<代理账号>.GetText(),@<代理密码>.GetText(),@<关闭S5错误提示>);
        @ }
    }

    方法 高级_清空代理 <公开>
    {
        @ if(IsEmpty()) return;
        @ FBroHsVIPControl_ClearS5Auth (m_class);

    }

    方法 开发者消息_发送消息 <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用"
            注释 = "英文名：SendDevToolsMessage 说明：Send a method call message over the DevTools protocol"
            注释 = "See the DevTools protocol documentation at https://chromedevtools.github.io/devtools-protocol/"
            注释 = "for details of supported methods and the expected \"params\" dictionary contents."
            注释 = "|message| will be copied if necessary. This method will return true if"
            注释 = "called on the UI thread and the message was successfully submitted for"
            注释 = "validation, otherwise false. Validation will be applied asynchronously and"
            注释 = "any messages that fail due to formatting errors or missing parameters may"
            注释 = "be discarded without notification. Prefer ExecuteDevToolsMethod if a more"
            注释 = "structured approach to message formatting is desired." 注释 = ""
            注释 = "Every valid method call will result in an asynchronous method result or"
            注释 = "error message that references the sent message \"id\". Event messages are"
            注释 = "received while notifications are enabled (for example, between method calls"
            注释 = "for \"Page.enable\" and \"Page.disable\"). All received messages will be"
            注释 = "delivered to the observer(s) registered with AddDevToolsMessageObserver."
            注释 = "See CefDevToolsMessageObserver::OnDevToolsMessage documentation for details" 注释 = "of received message contents."
            注释 = "" 注释 = "Usage of the SendDevToolsMessage, ExecuteDevToolsMethod and"
            注释 = "AddDevToolsMessageObserver methods does not require an active DevTools"
            注释 = "front-end or remote-debugging session. Other active DevTools sessions will"
            注释 = "continue to function independently. However, any modification of global"
            注释 = "browser state by one session may not be reflected in the UI of other" 注释 = "sessions." 注释 = ""
            注释 = "Communication with the DevTools front-end (when displayed) can be logged"
            注释 = "for development purposes by passing the" 注释 = "`--devtools-protocol-log-file=<path>` command-line flag." 注释 = "">
    参数 消息文本 <类型 = 文本型
            注释 = "|message| must be a UTF8-encoded JSON dictionary that contains \"id\" (int), \"method\" (string) and \"params\" (dictionary, optional) values">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SendDevToolsMessage(m_class,@<消息文本>.GetText());


    }

    方法 开发者消息_执行方法 <公开 注释 = "在浏览器创建成功事件中或刷新前调用，此为VIP功能，需赞助后才能使用"
            注释 = "英文名：ExecuteDevToolsMethod 说明：Execute a method call over the DevTools protocol."
            注释 = "This is a more structured version of SendDevToolsMessage；"
            注释 = "This method will return the assigned message ID if called on the UI thread and the message was successfully submitted for validation, otherwise 0."
            注释 = "See the SendDevToolsMessage documentation for additional usage information.">
    参数 消息ID <类型 = 整数
            注释 = "|message_id| is an incremental number that uniquely identifies the message (pass 0 to have the next number assigned automatically based on previous values)">
    参数 方法文本 <类型 = 文本型 注释 = "|method| is the method name">
    参数 参数 <类型 = 类_FBrowser_字典值
            注释 = "|params| are the method parameters, which may be empty. See the DevTools protocol documentation (linked above) for details of supported methods and the expected |params| dictionary contents.">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_ExecuteDevToolsMethod(m_class,@<消息ID>,@<方法文本>.GetText(),@<参数>.m_class);

    }

    方法 开发者消息_启用监管者事件 <公开 类型 = 逻辑型 注释 = "启用后，事件中的开发者消息才会有效,创建成功返回真，已创建或者创建失败返回假" @禁止流程检查 = 真>
    参数 消息事件 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser_开发者消息事件”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<消息事件>.GetPtr(),DevToolsMessageObserverType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return false;
        @ CefRefPtr<FBroHsDevToolsMessageObserver> event = static_cast<FBroHsDevToolsMessageObserver*>(@<消息事件>.GetPtr());
        @ return FBroHsVIPControl_AddDevToolsMessageObserver(m_class,event);
    }

    方法 开发者消息_关闭监管者事件 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return false;
        @ return FBroHsVIPControl_DeleteDevToolsMessageObserver(m_class);

    }

    方法 高级_网页截图 <公开 注释 = "执行截图后，数据在回调类\"类_FBrowser通用回调\"中的\"数据回调\"获取，可通过继承实现自定义回调类，执行成功返回标识ID，执行失败返回0"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 格式类型 <类型 = 文本型 注释 = "图像压缩格式(默认为png)，取值范围:jpeg、png、webp">
    参数 截图质量 <类型 = 整数 注释 = "压缩质量从范围[0..] 100) (jpeg)。">
    参数 截图大小 <类型 = FBrowser_截图边框数据 注释 = "设置截图的坐标，大小，和缩放比例，宽度和高度不能为0">
    参数 是否表面 <类型 = 逻辑型 注释 = "fromSurface：从表面而不是视图捕获截图">
    参数 是否包括视窗以外 <类型 = 逻辑型 注释 = "captureBeyondViewport：捕获viewport之外的截图。">
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowser通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass = static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_PageCaptureScreenshot(m_class,@<格式类型>.GetText(),@<截图质量>,@<截图大小>.ToFBroData(),@<是否表面>,@<是否包括视窗以外>,tempclass,nullptr,0);


    }

    方法 高级_启用执行环境 <公开 注释 = "执行高级JS功能之前需要先启用执行环境，否则无效，一个浏览器执行一次就行，如果关闭了需要重新开启才会有效，使用完毕后设置假关闭执行环境">
    参数 是否启用 <类型 = 逻辑型 注释 = "真启用，假关闭">
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return;
        @ FBroHsVIPControl_RuntimeEnable (m_class, @<是否启用>);
    }

    方法 高级_取当前环境ID清单 <公开 类型 = 类_FBrowser_列表值 注释 = " VIP高级功能，需赞助后才能使用，执行\"高级_启用执行环境\"启用后生效，"
            注释 = "返回值为文本列表值，值为环境ID文本数据,如果网站还在加载获取的清单值也会因为加载状态的不同而不同" @禁止流程检查 = 真>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return @dt<类_FBrowser_列表值>();
        @ return @dt<类_FBrowser_列表值>(FBroHsVIPControl_PageGetContextID(m_class));

    }

    方法 高级_执行JS <公开
            注释 = "VIP高级功能，需赞助后才能使用，执行\"VIP_高级_启用执行环境\"启用后生效，执行JS代码，数据在回调类\"类_FBrowserVIP_通用回调\"中的\"数据回调\"获取，可通过继承实现自定义回调类"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 JS文本 <类型 = 文本型 注释 = "expression">
    参数 环境ID <类型 = 整数 注释 = "contextId 框架ID可通过\"VIP_高级_取当前环境ID清单\"获取,如果是第一次加载网页主框架就是1，刷新和重新载入新地址后动态ID会变更">
    参数 包含命令行API <类型 = 逻辑型 注释 = "includeCommandLineAPI 确定在求值期间命令行API是否可用。" @默认值 = 真>
    参数 静默 <类型 = 逻辑型 注释 = "silent 在静默模式下，计算期间抛出的异常不会被报告，也不会暂停执行" @默认值 = 假>
    参数 用户手势 <类型 = 逻辑型 注释 = "userGesture 是否应该将执行视为用户在UI中发起的。" @默认值 = 真>
    参数 超时 <类型 = 整数 注释 = "timeout 单位毫秒" @默认值 = 99999999>
    参数 禁用断点 <类型 = 逻辑型 注释 = "disableBreaks 在执行过程中禁用断点。" @默认值 = 假>
    参数 repl模式 <类型 = 逻辑型 注释 = "replMode 将该标志设置为true，允许重新声明和顶级等待。 请注意，只有当let变量来自于replMode本身时，才能重新声明它们。" @默认值 = 假>
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass = static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_RuntimeEvaluate(m_class,@<JS文本>.GetText(),@<包含命令行API>,@<环境ID>,@<静默>,@<用户手势>,@<超时>,@<禁用断点>,@<repl模式>,tempclass,nullptr,0);

    }

    方法 高级_执行JS_框架ID <公开
            注释 = "VIP高级功能，需赞助后才能使用，执行\"VIP_高级_启用执行环境\"启用后生效，通过框架ID执行JS，框架ID只能通过\"VIP_高级_取当前环境ID清单\"获取中的frameID获取，不同于浏览器获取的框架ID"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 JS文本 <类型 = 文本型 注释 = "expression，如果js语法或者逻辑存在错误，回调也会返回成功，错误信息可以在回调返回的JSON值中查看">
    参数 框架ID <类型 = 文本型 注释 = "这个框架ID不同于浏览器获取的框架ID，该框架ID只能通过\"VIP_高级_取当前环境ID清单\"获取中的frameID获取,框架ID不会因为刷新而改变">
    参数 包含命令行API <类型 = 逻辑型 注释 = "includeCommandLineAPI 确定在求值期间命令行API是否可用。" @默认值 = 真>
    参数 静默 <类型 = 逻辑型 注释 = "silent 在静默模式下，计算期间抛出的异常不会被报告，也不会暂停执行" @默认值 = 假>
    参数 用户手势 <类型 = 逻辑型 注释 = "userGesture 是否应该将执行视为用户在UI中发起的。" @默认值 = 真>
    参数 超时 <类型 = 整数 注释 = "timeout 单位毫秒" @默认值 = 99999999>
    参数 禁用断点 <类型 = 逻辑型 注释 = "disableBreaks 在执行过程中禁用断点。" @默认值 = 假>
    参数 repl模式 <类型 = 逻辑型 注释 = "replMode 将该标志设置为true，允许重新声明和顶级等待。 请注意，只有当let变量来自于replMode本身时，才能重新声明它们。" @默认值 = 假>
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass=static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_RuntimeEvaluate_FrameID(m_class,@<JS文本>.GetText(),@<包含命令行API>,0,0,@<框架ID>.GetText(),@<静默>,@<用户手势>,@<超时>,@<禁用断点>,@<repl模式>,tempclass,NULL,0);
    }

    方法 高级_执行JS_主框架 <公开 注释 = "VIP高级功能，需赞助后才能使用，执行\"VIP_高级_启用执行环境\"启用后生效，在主框架/顶级框架执行JS"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 JS文本 <类型 = 文本型 注释 = "expression，如果js语法或者逻辑存在错误，回调也会返回成功，错误信息可以在回调返回的JSON值中查看">
    参数 包含命令行API <类型 = 逻辑型 注释 = "includeCommandLineAPI 确定在求值期间命令行API是否可用。" @默认值 = 真>
    参数 静默 <类型 = 逻辑型 注释 = "silent 在静默模式下，计算期间抛出的异常不会被报告，也不会暂停执行" @默认值 = 假>
    参数 用户手势 <类型 = 逻辑型 注释 = "userGesture 是否应该将执行视为用户在UI中发起的。" @默认值 = 真>
    参数 超时 <类型 = 整数 注释 = "timeout 单位毫秒" @默认值 = 99999999>
    参数 禁用断点 <类型 = 逻辑型 注释 = "disableBreaks 在执行过程中禁用断点。" @默认值 = 假>
    参数 repl模式 <类型 = 逻辑型 注释 = "replMode 将该标志设置为true，允许重新声明和顶级等待。 请注意，只有当let变量来自于replMode本身时，才能重新声明它们。" @默认值 = 假>
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass = static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_RuntimeEvaluate_FrameID(m_class,@<JS文本>.GetText(),@<包含命令行API>,1,0,"",@<静默>,@<用户手势>,@<超时>,@<禁用断点>,@<repl模式>,tempclass,NULL,0);
    }

    方法 高级_执行JS_全部框架 <公开 注释 = "VIP高级功能，需赞助后才能使用，执行\"VIP_高级_启用执行环境\"启用后生效，在当前所有框架里面都执行JS代码，所有框架都会执行一遍，回调会被多次调取"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 JS文本 <类型 = 文本型 注释 = "expression，如果js语法或者逻辑存在错误，回调也会返回成功，错误信息可以在回调返回的JSON值中查看">
    参数 包含命令行API <类型 = 逻辑型 注释 = "includeCommandLineAPI 确定在求值期间命令行API是否可用。" @默认值 = 真>
    参数 静默 <类型 = 逻辑型 注释 = "silent 在静默模式下，计算期间抛出的异常不会被报告，也不会暂停执行" @默认值 = 假>
    参数 用户手势 <类型 = 逻辑型 注释 = "userGesture 是否应该将执行视为用户在UI中发起的。" @默认值 = 真>
    参数 超时 <类型 = 整数 注释 = "timeout 单位毫秒" @默认值 = 99999999>
    参数 禁用断点 <类型 = 逻辑型 注释 = "disableBreaks 在执行过程中禁用断点。" @默认值 = 假>
    参数 repl模式 <类型 = 逻辑型 注释 = "replMode 将该标志设置为true，允许重新声明和顶级等待。 请注意，只有当let变量来自于replMode本身时，才能重新声明它们。" @默认值 = 假>
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass=static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_RuntimeEvaluate_FrameID(m_class,@<JS文本>.GetText(),@<包含命令行API>,2,0,"",@<静默>,@<用户手势>,@<超时>,@<禁用断点>,@<repl模式>,tempclass,NULL,0);

    }

    方法 高级_执行JS_框架序号 <公开
            注释 = "VIP高级功能，需赞助后才能使用，执行\"VIP_高级_启用执行环境\"启用后生效，通过框架ID执行JS，框架ID只能通过\"VIP_高级_取当前环境ID清单\"获取中的frameID获取，不同于浏览器获取的框架ID"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 JS文本 <类型 = 文本型 注释 = "expression，如果js语法或者逻辑存在错误，回调也会返回成功，错误信息可以在回调返回的JSON值中查看">
    参数 框架序号 <类型 = 整数 注释 = "浏览器依次加载框架的序号，一般第一个为主框架，序号从0开始，超出框架个数将会执行失败，" 注释 = "注意这个序号和开发者工具显示的序号和浏览器取出的框架顺序不一定一样">
    参数 包含命令行API <类型 = 逻辑型 注释 = "includeCommandLineAPI 确定在求值期间命令行API是否可用。" @默认值 = 真>
    参数 静默 <类型 = 逻辑型 注释 = "silent 在静默模式下，计算期间抛出的异常不会被报告，也不会暂停执行" @默认值 = 假>
    参数 用户手势 <类型 = 逻辑型 注释 = "userGesture 是否应该将执行视为用户在UI中发起的。" @默认值 = 真>
    参数 超时 <类型 = 整数 注释 = "timeout 单位毫秒" @默认值 = 99999999>
    参数 禁用断点 <类型 = 逻辑型 注释 = "disableBreaks 在执行过程中禁用断点。" @默认值 = 假>
    参数 repl模式 <类型 = 逻辑型 注释 = "replMode 将该标志设置为true，允许重新声明和顶级等待。 请注意，只有当let变量来自于replMode本身时，才能重新声明它们。" @默认值 = 假>
    参数 通用回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<通用回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> tempclass = static_cast<FBroHsGeneralResultCallback*>(@<通用回调>.GetPtr());
        @ FBroHsVIPControl_RuntimeEvaluate_FrameID(m_class,@<JS文本>.GetText(),@<包含命令行API>,3,@<框架序号>,"",@<静默>,@<用户手势>,@<超时>,@<禁用断点>,@<repl模式>,tempclass,NULL,0);
    }

    方法 高级_发送触摸事件 <公开 注释 = "VIP高级功能，需赞助后才能使用，可不启用触摸模式发送触摸事件">
    参数 类型 <类型 = 整数 注释 = "touchStart=0,touchMove=1,touchCancel=2,touchEnd=3，第一次执行要先touchStart,执行完操作后touchEnd">
    参数 触摸事件 <类型 = FBrowser_VIP触摸事件>
    参数 修饰符 <类型 = 整数 注释 = "Alt=1, Ctrl=2, Meta/Command=4, Shift=8 (default: 0)" @默认值 = 0>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        @ FBroHsVIPControl_DispatchTouchEvent(m_class,@<类型>,@<触摸事件>.ToFBroData(),@<修饰符>);

    }

    方法 高级触摸_按下 <公开 注释 = "VIP高级功能，需赞助后才能使用，可不启用触摸模式发送触摸事件">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    {
        变量 触摸事件 <类型 = FBrowser_VIP触摸事件>
        触摸事件.横坐标 = 横坐标
        触摸事件.纵坐标 = 纵坐标
        高级_发送触摸事件 (0, 触摸事件, )

    }

