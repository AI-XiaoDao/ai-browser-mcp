    }

    方法 内核开关_禁用Performance检测 <公开
            注释 = "VIP功能需赞助后才可使用，不会直接关闭Performance功能，只会影响now，mark，measure用于检测执行速度的返回值（返回值将变成你所设置的最小值到最大值范围内的一个随机值），防止被探测到在调试网页，打了断点或者hook了函数，原理可自行百度">
    参数 是否禁用 <类型 = 逻辑型 注释 = "为真为禁用，假为不禁用">
    参数 最小值 <类型 = 小数 注释 = "默认值0.3，单位毫秒,间隔最小值，不能太小，太小太假" @默认值 = 0>
    参数 最大值 <类型 = 小数 注释 = "默认值1，单位毫秒，间隔最大值，不能太大，太大你猜" @默认值 = 0>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetDisablePerformanceCheck(m_class,@<是否禁用>,@<最小值>,@<最大值>);

    }

    方法 内核开关_设置CSS内核 <公开 注释 = "VIP功能需赞助后才可使用，通过对应的内核版本号，结合谷歌功能关闭对应版本添加或删除的功能，达到模拟对应内核的效果，注意：如使用后出现网页异常说明你设置的内核不兼容当前网页">
    参数 内核版本 <类型 = 整数 注释 = "支持设置值为135到116">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetCSSKernel(m_class,@<内核版本>);

    }

    方法 内核开关_设置Web内核 <公开 注释 = "VIP功能需赞助后才可使用，同“内核开关_设置CSS内核”功能，通过版本号关闭和添加浏览器对应功能API，达到模拟对应内核的效果，注意：如使用后出现网页异常说明你设置的内核不兼容当前网页">
    参数 内核版本 <类型 = 整数 注释 = "支持设置值为135到116">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetWebFeatureKernel(m_class,@<内核版本>);
    }

    方法 内核开关_设置V8内核 <公开 注释 = "VIP功能需赞助后才可使用，同“内核开关_设置CSS内核”功能，通过版本号关闭和添加浏览器V8对应功能API，达到模拟对应内核的效果，注意：如使用后出现网页异常说明你设置的内核不兼容当前网页">
    参数 内核版本 <类型 = 整数 注释 = "支持设置值为135到116">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetV8Kernel(m_class,@<内核版本>);
    }

    方法 内核开关_禁用Debugger <公开 注释 = "原名：高级_禁用Debugger，VIP功能，需要赞助后才能使用，禁用当前浏览器的debugger断点功能，禁用后开发者工具断点功能任然可以使用，方便调试">
    参数 是否禁用 <类型 = 逻辑型 注释 = "为真为禁用，假为不禁用">
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetDisableDebugger(m_class,@<是否禁用>);
    }

    方法 内核开关_设置EventIsTrusted <公开 注释 = "原名：事件_虚拟isTrusted"
            注释 = "是否信任，event.isTrusted 参考资料：https://blog.csdn.net/weixin_39871162/article/details/111605327">
    参数 是否信任 <类型 = 逻辑型>
    {
        @ if(@<FBrowser初始化控制.是否为VIP> && !IsEmpty()) FBroHsVIPControl_SetVirisTrusted(m_class,@<是否信任>);

    }
}

类 类_FBrowserVIP_WebSocket客户端 <公开 注释 = "只能在渲染进程中执行，VIP功能，需赞助后才能使用">
{

    # @begin
    # <> <include>
    # CefRefPtr<FBroDOMWssClient> m_class;
    # inline_ @sn<current_class> (CefRefPtr<FBroDOMWssClient> object) : @sn<current_class> () { m_class = object; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    # inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    # inline_ void Set (CefRefPtr<FBroDOMWssClient> object) { m_class = object; }
    # ~@sn<current_class>(){};
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ return IsEmpty()? true:FBroHsWSSClient_IsNull(m_class);

    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 是否相同 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return false;
        @ return FBroHsWSSClient_IsSame(m_class);


    }

    方法 连接 <公开 @禁止流程检查 = 真>
    参数 连接地址 <类型 = 文本型>
    参数 连接端口 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsWSSClient_Connect(m_class,@<连接地址>.GetText(),@<连接端口>.GetText());


    }

    方法 关闭 <公开 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return;
        @ FBroHsWSSClient_Close(m_class);

    }

    方法 销毁 <公开 @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return;
        @ FBroHsWSSClient_Destroy(m_class);

    }

    方法 取地址 <公开 类型 = 文本型 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsWSSClient_GetAddress(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 取协议 <公开 类型 = 文本型 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsWSSClient_GetProtocol(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 取插件 <公开 类型 = 文本型 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsWSSClient_GetExtensions(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 取数据类型 <公开 类型 = 文本型 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    {
        @ if(IsEmpty()) return CVolString();
        @ CefRefPtr<FBroString> fbrostring = FBroHsWSSClient_GetBinaryType(m_class);
        @ return FBroUnit::FBroStringToCWString(fbrostring);
    }

    方法 发送文本 <公开 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ if(IsEmpty()) return;
        @ FBroHsWSSClient_Send(m_class,@<数据>.GetText());
    }

    方法 发送数据 <公开 注释 = "只能在渲染进程中执行" @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ if(IsEmpty()) return; 
        @ FBroHsWSSClient_SendData(m_class,(char *)@<数据>.GetPtr (),@<数据>.GetSize ());
    }

    #
}

类 类_FBrowserVIP_开发者DOM <公开 注释 = "VIP功能，需要赞助后才能使用" 折叠>
{

    # @begin
    # <> <include>
    #     CefRefPtr<CefBrowser> m_class;
    #     inline_ @sn<current_class> (CefRefPtr<CefBrowser> object) : @sn<current_class> () { m_class = object; }
    #     inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom) { m_class = objCopyFrom.m_class; }
    #     inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const { return (m_class.get () == objCompare.m_class.get ()); }
    #     inline_ BOOL IsEmpty () const { return m_class.get () == nullptr; }
    #     inline_ void Set (CefRefPtr<CefBrowser> object) { m_class = object; }
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "为空返回真，不为空返回假" @禁止流程检查 = 真>
    {
        @ return IsEmpty();
    }

    方法 置空 <公开 注释 = "手动置空当前类包含的cef类指针，置空后该类将无法使用，如没有其他引用将自动释放cef类指针的资源数据">
    {
        @ m_class = nullptr;
    }

    方法 启用 <公开 注释 = "Enables DOM agent for the given page.">
    参数 包括空格 <类型 = 文本型 注释 = "includeWhitespace:Whether to include whitespaces in the children array of returned Nodes."
            注释 = "Allowed Values: none, all">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_enable(m_class,@<包括空格>.GetText());
    }

    方法 禁用 <公开 注释 = "Enables DOM agent for the given page.">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_disable(m_class);

    }

    方法 置焦点元素 <公开 注释 = "focusElement，nodeID必须是Element才会有效,执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数>
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_focusElement(m_class,@<节点ID>);
    }

    方法 移除节点属性 <公开 注释 = "removeAttribute" 注释 = "移除节点\"attributes\"中的属性名,使用之前必选先枚举DOM获取到节点ID才会有效,移除属性后，可通过枚举DOM查看是否移除成功"
            注释 = "执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    参数 属性名 <类型 = 文本型 注释 = "name">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_removeAttribute(m_class,@<节点ID>,@<属性名>.GetText());
    }

    方法 移除节点 <公开 注释 = "removeNode" 注释 = "移除当前节点已经当前节点下的子节点都会被删除,使用之前必选先枚举DOM获取到节点ID才会有效，不能是根节点," 注释 = "执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_removeNode(m_class,@<节点ID>);
    }

    方法 置节点属性文本 <公开 注释 = "setAttributesAsText" 注释 = "使用之前必选先枚举DOM获取到节点ID才会有效,执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    参数 属性名 <类型 = 文本型 注释 = "name">
    参数 文本 <类型 = 文本型 注释 = "text">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_setAttributesAsText(m_class,@<节点ID>,@<文本>.GetText(),@<属性名>.GetText());
    }

    方法 置节点属性值 <公开 注释 = "setAttributeValue" 注释 = "使用之前必选先枚举DOM获取到节点ID才会有效,执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    参数 属性名 <类型 = 文本型 注释 = "name">
    参数 值 <类型 = 文本型 注释 = "value">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_setAttributeValue(m_class,@<节点ID>,@<属性名>.GetText(),@<值>.GetText());
    }

    方法 置节点值 <公开 注释 = "setNodeValue" 注释 = "Can only set value of text nodes" 注释 = "使用之前必选先枚举DOM获取到节点ID才会有效,执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    参数 值 <类型 = 文本型 注释 = "value">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_setNodeValue(m_class,@<节点ID>,@<值>.GetText());
    }

    方法 置节点源码 <公开 注释 = "setOuterHTML" 注释 = "使用之前必选先枚举DOM获取到节点ID才会有效,执行失败或者错误信息可在开发者事件中获取">
    参数 节点ID <类型 = 整数 注释 = "nodeID">
    参数 源码文本 <类型 = 文本型 注释 = "outerHTML">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_setOuterHTML(m_class,@<节点ID>,@<源码文本>.GetText());
    }

    方法 清除查找 <公开 注释 = "清除通过预查找文本查找的数据，释放资源,执行失败或者错误信息可在开发者事件中获取">
    参数 查找ID <类型 = 文本型 注释 = "searchId">
    {
        @ if(!IsEmpty()) FBroHsDevToolsDOM_discardSearchResults(m_class,@<查找ID>.GetText());
    }

    方法 枚举DOM <公开 注释 = "getDocument,同步方法不能在事件中使用，否则可能会卡事件造成浏览器异常" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；"
            @禁止流程检查 = 真>
    参数 深度 <类型 = 整数 注释 = "depth">
    参数 穿透 <类型 = 逻辑型 注释 = "pierce">
    参数 回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。" 注释 = "获取到的数据为JSON格式"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> callback = static_cast<FBroHsGeneralResultCallback*>(@<回调>.GetPtr());
        @ FBroHsDevToolsDOM_getDocument(m_class,@<深度>,@<穿透>,callback,nullptr,0);


    }

    方法 取节点属性 <公开 注释 = "getAttributes,使用之前必选先枚举DOM获取到节点ID才会有效,节点必须是\"nodeType\": 1类型及Element类型"
            注释 = "同步方法不能在事件中使用，否则可能会卡事件造成浏览器异常" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 节点ID <类型 = 整数>
    参数 回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "获取到的数据格式：{\"attributes\":[\"http-equiv\",\"Content-Type\",\"content\",\"text/html;charset=utf-8\"]}"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return ;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> callback = static_cast<FBroHsGeneralResultCallback*>(@<回调>.GetPtr());
        @ FBroHsDevToolsDOM_getAttributes(m_class, @<节点ID>,callback,nullptr,0);


    }

    方法 取节点源码 <公开 注释 = "getOuterHTML,使用之前必选先枚举DOM获取到节点ID才会有效" 注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；"
            @禁止流程检查 = 真>
    参数 节点ID <类型 = 整数 注释 = "nodeId">
    参数 回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。" 注释 = "获取到的数据格式：{\"outerHTML\":\"\"}"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> callback = static_cast<FBroHsGeneralResultCallback*>(@<回调>.GetPtr());
        @ FBroHsDevToolsDOM_getOuterHTML(m_class, @<节点ID>, callback, nullptr, 0);


    }

    方法 取节点_查询选择器 <公开 注释 = "querySelector,返回查找出来的节点ID,使用之前必选先枚举DOM获取到节点ID才会有效"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
