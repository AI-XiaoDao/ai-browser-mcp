    }

    方法 取查找文本 <公开 注释 = "通过\"预查找文本\"的searchId获取到查找的数据,数据存放在\"返回值\"参数中，" 注释 = "使用之前必选先枚举DOM获取到节点ID才会返回有效的ID值，不然全是0"
            注释 = "注意：静态回调和动态回调只能设置一个，优先静态回调有效；采用动态回调可实现回调的动态多态操作，更加灵活；" @禁止流程检查 = 真>
    参数 查找ID <类型 = 文本型 注释 = "searchId">
    参数 开始索引 <类型 = 整数 注释 = "fromIndex">
    参数 结束索引 <类型 = 整数 注释 = "toIndex 不能超过最大查找个数">
    参数 回调 <类型 = 类_FBrowser_事件智能指针 注释 = "异步获取数据或者触发响应事件的回调，数据反馈或者事件响应会触发回调中对应的方法。"
            注释 = "使用“FBrowser创建事件智能指针”全局方法或者在设置之前用该类型参数中的“创建”方法来创建一个继承于“类_FBrowserVIP_通用回调”的自定义类事件；"
            注释 = "即可实现事件触发到你所自定义的类事件方法中；采用智能指针引用完毕后会自动释放，如不设置将不会触发；" @默认值 = 空对象>
    {
        @ if(IsEmpty()) return;
        // 判断设置事件是否匹配,只在调试情况下生效
        @ _FBRO_CHECK_EVENT_TYPE(@<回调>.GetPtr(),GeneralResultCallbackType,_CT(@sn<current_source_class>),_CT(@sn<current_source_method>));

        @ CefRefPtr<FBroHsGeneralResultCallback> callback = static_cast<FBroHsGeneralResultCallback*>(@<回调>.GetPtr());
        @ FBroHsDevToolsDOM_getSearchResults(m_class,@<查找ID>.GetText(),@<开始索引>,@<结束索引>, callback, nullptr, 0);

    }
}

