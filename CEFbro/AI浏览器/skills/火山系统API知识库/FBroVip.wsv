    方法 高级触摸_单击 <公开 注释 = "VIP高级功能，需赞助后才能使用，可不启用触摸模式发送触摸事件">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 单击延时 <类型 = 整数 注释 = "单位：毫秒；为空，默认为50毫秒" @默认值 = 50>
    {
        高级触摸_按下 (横坐标, 纵坐标)
        @ FBroUnit::WaitUserTimer(@<单击延时>);
        高级触摸_放开 (横坐标, 纵坐标)


    }

    方法 高级_发送键盘事件 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送键盘事件，支持后台操作">
    参数 类型 <类型 = 文本型 注释 = "type:Type of the key event.Allowed Values: keyDown, keyUp, rawKeyDown, char."
            注释 = "键事件的类型。允许的值:keyDown, keyUp, rawKeyDown, char">
    参数 修饰键 <类型 = 整数
            注释 = "modifiers:Bit field representing pressed modifier keys. Alt=1, Ctrl=2, Meta/Command=4, Shift=8 (default: 0)."
            注释 = "表示按下的修饰键。Alt=1, Ctrl=2, Meta/Command=4, Shift=8(默认值:0)。" @默认值 = 0>
    参数 文本 <类型 = 文本型
            注释 = "text:Text as generated by processing a virtual key code with a keyboard layout. Not needed for for keyUp and rawKeyDown events (default: \"\")"
            注释 = "通过处理带有键盘布局的虚拟键代码而生成的文本。对于keyUp和rawKeyDown事件不需要(默认值:\"\")。" @默认值 = "">
    参数 未修饰文本 <类型 = 文本型
            注释 = "unmodifiedText:Text that would have been generated by the keyboard if no modifiers were pressed (except for shift). Useful for shortcut (accelerator) key handling (default: \"\")."
            注释 = "如果没有按下修饰符(shift除外)，将由键盘生成的文本。用于快捷键(加速器)处理(默认值:\"\")。" @默认值 = "">
    参数 关键标识符 <类型 = 文本型 注释 = "keyIdentifier:Unique key identifier (e.g., \'U+0041\') (default: \"\")."
            注释 = "唯一键标识符(例如，\'U+0041\')(默认值:\"\")。" @默认值 = "">
    参数 代码 <类型 = 文本型 注释 = "code:Unique DOM defined string value for each physical key (e.g., \'KeyA\') (default: \"\")."
            注释 = "每个物理键(例如\'KeyA\')的唯一DOM定义的字符串值(默认值:\"\")。" @默认值 = "">
    参数 按键 <类型 = 文本型
            注释 = "key:Unique DOM defined string value describing the meaning of the key in the context of active modifiers, keyboard layout, etc (e.g., \'AltGr\') (default: \"\")."
            注释 = "唯一的DOM定义的字符串值，描述在活动修饰符、键盘布局等上下文中的键的含义(例如，\'AltGr\')(默认值:\"\")。" @默认值 = "">
    参数 系统虚拟键代码 <类型 = 整数 注释 = "windowsVirtualKeyCode:Windows virtual key code (default: 0)." 注释 = "Windows虚拟按键代码(默认值:0)。"
            @默认值 = 0>
    参数 本机虚拟键代码 <类型 = 整数 注释 = "nativeVirtualKeyCode:Native virtual key code (default: 0)." 注释 = "本机虚拟键代码(默认值:0)。" @默认值 = 0>
    参数 自动重复 <类型 = 逻辑型 注释 = "autoRepeat:Whether the event was generated from auto repeat (default: false)."
            注释 = "事件是否由自动重复产生(默认值:false)" @默认值 = 假>
    参数 是否为键盘 <类型 = 逻辑型 注释 = "isKeypad:Whether the event was generated from the keypad (default: false)." 注释 = "事件是否从键盘生成。"
            @默认值 = 假>
    参数 是否为系统 <类型 = 逻辑型 注释 = "isSystemKey:Whether the event was a system key event (default: false)." 注释 = "事件是否为系统按键事件。"
            @默认值 = 假>
    参数 键盘位置 <类型 = 整数
            注释 = "location:Whether the event was from the left or right side of the keyboard. 1=Left, 2=Right (default: 0)."
            注释 = "事件是来自键盘的左边还是右边。1=左，2=右(默认值:0)。" @默认值 = 0>
    {
        @ if(!@<FBrowser初始化控制.是否为VIP> || IsEmpty()) return ;
        @ FBroHsVIPControl_DispatchKeyEvent(m_class, @<类型>.GetText(), @<修饰键>, @<文本>.GetText(), @<未修饰文本>.GetText(), @<关键标识符>.GetText(), @<代码>.GetText(), @<按键>.GetText(), @<系统虚拟键代码>, @<本机虚拟键代码>, @<自动重复>, @<是否为键盘>, @<是否为系统>, @<键盘位置>);

    }

    方法 高级键盘_按下 <公开 注释 = "VIP高级功能，需赞助后才能使用，向浏览器发送键盘事件，支持后台操作">
    参数 键代码 <类型 = 整数>
