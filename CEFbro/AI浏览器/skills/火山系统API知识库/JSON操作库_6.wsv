    # <> </include>
    # @end
    #

    方法 是否有效 <公开 属性读 类型 = 逻辑型 注释 = "查询节点是否有效" 折叠 @禁止流程检查 = 真>
    {
        @ return m_doc && m_val;
    }

    方法 取节点 <公开 类型 = JSON构造数组类_yy 注释 = "根据键名取对象的子节点" 折叠 @禁止流程检查 = 真>
    参数 键名 <类型 = 文本型 注释 = "不支持路径,若要取路径节点[取路径节点]系列方法">
    {
        @ return @sn<current_class>(m_doc, get_val((const wchar_t*)@<键名>.GetText()));
    }

    方法 取成员节点 <公开 类型 = JSON构造数组类_yy 注释 = "根据索引取容器(对象型/数组型)成员节点" 折叠 @禁止流程检查 = 真>
    参数 索引 <类型 = 变整数 注释 = "从0开始">
    {
        @ return @sn<current_class>(m_doc, get_val((size_t)@<索引>));
    }

    方法 取路径节点 <公开 类型 = JSON构造数组类_yy 注释 = "根据路径取节点(RFC 6901标准)" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    {
        @ return @sn<current_class>(m_doc, pointer_get_val((const wchar_t*)@<路径>.GetText()));
    }

    方法 添加路径节点 <公开 类型 = JSON构造数组类_yy 注释 = "根据路径添加节点" 注释 = "特殊转义符: ~k表示指定为键名(比如: /~k0 节点不存在时创建键名为\"0\"的节点而非数组索引)"
            注释 = "注意: 新添加的节点为null型" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0] RFC 6901标准">
    {
        @ return @sn<current_class>(m_doc, pointer_set_val((const wchar_t*)@<路径>.GetText()));
    }

    方法 删除路径节点 <公开 类型 = 逻辑型 注释 = "根据路径删除指定节点((RFC 6901标准))" 折叠 @嵌入式方法 = "">
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    参数 数组删除数量 <类型 = 变整数 注释 = "目标节点为数组成员时生效" 注释 = "例子: [1,2,3,4,5,6] 执行 删除路径节点(\"/0\",3) 结果为 [4,5,6]" @默认值 = 1>
    {
        @ @sn<this>.pointer_remove((const wchar_t*)@<路径>.GetText(), (size_t)@<数组删除数量>)
    }

    方法 交换路径节点 <公开 类型 = 逻辑型 注释 = "交换路径节点" 折叠 @嵌入式方法 = "">
    参数 路径1 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0] RFC 6901标准">
    参数 路径2 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0] RFC 6901标准">
    {
        @ @sn<this>.pointer_swap((const wchar_t*)@<路径1>.GetText(),(const wchar_t*)@<路径2>.GetText())
    }

    方法 取路径整数值 <公开 类型 = 整数 注释 = "根据路径取整数值,路径不存在则自动构造并设置为默认值." 注释 = "注意: 如果节点无效,也将返回默认值" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    参数 默认值 <类型 = 整数 注释 = "配置不存在时返回的默认值" @默认值 = 0>
    {
        @ if (m_doc && m_val){
        @     bool exist;
        @     yyjson_mut_val* val = pointer_set_val((const wchar_t*)@<路径>.GetText(), exist);
        @     if (val) {
        @         yy_mut_val _val(m_doc, val);
        @         if (exist && (yyjson_mut_is_sint(val) || yyjson_mut_is_uint(val))) return (int)_val.get_int64();
        @         _val.yy_mut_val::set((int64_t)@<默认值>);
        @     }
        @ }
        @ return @<默认值>;
    }

    方法 取路径长整数值 <公开 类型 = 长整数 注释 = "根据路径取长整数值,路径不存在则自动构造并设置为默认值." 注释 = "注意: 如果节点无效,也将返回默认值" 折叠 折叠2 @禁止流程检查 = 真>
