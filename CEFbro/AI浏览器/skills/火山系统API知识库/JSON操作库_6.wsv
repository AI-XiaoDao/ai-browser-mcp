    }

    方法 取类型 <公开 类型 = 文本型 注释 = "返回键名称对应键值的类型" 折叠>
    参数 索引 <类型 = 变整数 注释 = "从0开始">
    {
        变量 类型名 <类型 = 文本型>
        类型名 = 对象1.取成员节点 (索引).类型名称
        如果真 (类型名 == "长整数值")
        {
            如果真 (对象1.取成员节点 (索引).长整数值 < 2147483648)
            {
                类型名 = "整数值"
            }
        }
        返回 (类型名)
    }

    方法 取类型2 <公开 类型 = 整数 注释 = "返回键名称对应键值的类型" 返回值注释 = "1、文本型 2、整数型 3、长整数型 4、小数型 5、逻辑型 6、对象型 7、数组型" 折叠>
    参数 索引 <类型 = 变整数 注释 = "从0开始">
    {
        变量 类型名 <类型 = 文本型>
        类型名 = 取类型 (索引)
        如果 (类型名 == "文本值")
        {
            返回 (1)
        }
        否则 (类型名 == "整数值")
        {
            返回 (2)
        }
        否则 (类型名 == "长整数值")
        {
            返回 (3)
        }
        否则 (类型名 == "小数值")
        {
            返回 (4)
        }
        否则 (类型名 == "true值" || 类型名 == "false值")
        {
            返回 (5)
        }
        否则 (类型名 == "对象型")
        {
            返回 (6)
        }
        否则 (类型名 == "数组型")
        {
            返回 (7)
        }
        返回 (-1)
    }

    方法 取路径类型 <公开 类型 = 文本型 注释 = "返回键名称对应键值的类型" 折叠>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
