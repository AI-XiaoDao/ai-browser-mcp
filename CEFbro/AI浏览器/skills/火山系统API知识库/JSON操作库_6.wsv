    方法 字节集值 <公开 属性读 类型 = 字节集类 注释 = "取当前节点的字节集节点值" 折叠>
    {
        返回 (转BASE64解码_ (文本值))
    }

    方法 可读文本 <公开 属性读 类型 = 文本型 注释 = "将当前节点的值转换为可读文本" 注释 = "由于是通过转换的方式,大数数值有可能与原始json不同" 折叠 折叠2 @禁止流程检查 = 真>
    {
        @ switch (yyjson_get_type(m_val)) {
        @ case YYJSON_TYPE_NULL: return _CT("null");
        @ case YYJSON_TYPE_BOOL: return get_bool() ? _CT("true") : _CT("false");
        @ case YYJSON_TYPE_NUM:  return yyjson_get_subtype(m_val) == YYJSON_SUBTYPE_REAL ? @an<CVolString> (get_double()) : @an<CVolString> (get_int64());
        @ case YYJSON_TYPE_STR:  return @an<CVolString> ((const CHAR*)get_str());
        @ case YYJSON_TYPE_OBJ:
        @ case YYJSON_TYPE_ARR:  return @an<CVolString> ((const CHAR*)get_json(YYJSON_WRITE_NOFLAG).get_ptr());
        @ default:               return _CT("");
        @ }
    }

    方法 到可读文本 <公开 类型 = 文本型 注释 = "将容器型节点(对象型/数组型)构造为JSON文本数据" 折叠 @嵌入式方法 = "">
    参数 构造标志 <类型 = 整数 @默认值 = 构造标志_yy.默认模式>
