类 JSON解析对象类_yy <公开 基础类 = JSON解析数组类_yy 注释 = "解析类根节点" 折叠 折叠2 @文档 = "category = \"JSON操作库.yyjson.解析对象\""
        @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include" @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h"
        @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_hs.cpp" @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_.c"
        @视窗.后缀文本 = "public yy_doc">
{

    # @begin
    # <> <include>
    # virtual void CopySelfFromExtra(yyjson_val* val) {
    #     parse(val);
    # };
    # <> </include>
    # @end
    #

    方法 清空 <公开 注释 = "局部变量无需调用,重新解析 或 类销毁 会自动清空." 折叠 @禁止流程检查 = 真>
    {
        @ yy_doc::~yy_doc();
        @ memset(&m_read_err, 0, sizeof(yyjson_read_err));
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "解析Unicode文本" 返回值注释 = "成功返回真, 失败返回假" 折叠 @嵌入式方法 = "">
    参数 json <类型 = 文本型>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ @sn<this>.parse((const wchar_t*)@<json>.GetText(),(yyjson_read_flag)@<解析标志>)
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "解析UTF8字节集" 返回值注释 = "成功返回真, 失败返回假" 折叠 @禁止流程检查 = 真>
    参数 json <类型 = 字节集类>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ return parse((char*)@<json>.GetPtr(),(size_t)@<json>.GetSize(),(yyjson_read_flag)@<解析标志>);
    }

    方法 创建自指针 <公开 类型 = 逻辑型 注释 = "解析UTF8数据指针" 返回值注释 = "成功返回真, 失败返回假" 折叠 @嵌入式方法 = "">
    参数 json指针 <类型 = 变整数>
    参数 数据长度 <类型 = 变整数>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ @sn<this>.parse((char*)@<json指针>,(size_t)@<数据长度>,(yyjson_read_flag)@<解析标志>)
    }

    方法 创建自文件 <公开 类型 = 逻辑型 注释 = "从uft8文件解析创建 (注意: yyjson是将文件一次性读入到内存后再进行解析创建.)" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠
            @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        变量 局_文件路径 <类型 = 字节集类>
        局_文件路径 = 文本到多字节 (文件路径, 真)
        @ return parse_file((const char*)@<局_文件路径>.GetPtr(),(yyjson_read_flag)@<解析标志>);
    }

    方法 错误类型 <公开 属性读 类型 = 整数 注释 = "取解析失败时的错误代码" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_read_err.code
    }

    方法 错误描述 <公开 属性读 类型 = 文本型 注释 = "取解析失败时的错误描述信息" 折叠 @禁止流程检查 = 真>
    {
        @ if (m_read_err.msg){
        @     return @an<CVolString> ((const CHAR*)m_read_err.msg);
        @ }
        返回 ("")
    }

    方法 错误位置 <公开 属性读 类型 = 变整数 注释 = "取解析失败时的错误位置(utf8编码下的位置)" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_read_err.pos
    }

    方法 是否已解析 <公开 属性读 类型 = 逻辑型 注释 = "判断是否已经解析" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_doc != NULL
    }

    方法 键值总数 <公开 属性读 类型 = 变整数 注释 = "取JSON键和值的总数量" 折叠 @嵌入式方法 = "">
    {
        @ yyjson_doc_get_val_count(@sn<this>.m_doc)
    }
}

类 JSON解析数组类_yy <公开 注释 = "全类型解析类节点" 折叠 折叠2 @文档 = "category = \"JSON操作库.yyjson.解析数组\""
        @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include" @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h"
