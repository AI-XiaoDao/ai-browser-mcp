类 JSON构造对象类迭代器_yy <公开 注释 = "遍历对象时建议使用迭代器,性能高" 注释 = "yyjson采用的是单向链表储存数据,仅支持正向迭代" 折叠 折叠2
        @文档 = "category = \"JSON操作库.yyjson.构造对象\"" @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include"
        @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h" @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_hs.cpp"
        @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_.c">
{

    # @begin
    # <> <include>
    # public:
    #     yyjson_mut_obj_iter m_obj_iter;
    #     yyjson_mut_doc* m_doc = NULL;
    #     size_t m_max;
    # <> </include>
    # @end

    方法 类_初始化 <折叠 @禁止流程检查 = 真>
    {
        @ memset(&m_obj_iter, 0, sizeof(yyjson_mut_obj_iter));
    }

    方法 初始化 <公开 类型 = 逻辑型 注释 = "初始化构造类节点" 折叠 @禁止流程检查 = 真>
    参数 构造类节点 <类型 = JSON构造数组类_yy>
    参数 开始位置 <类型 = 变整数 注释 = "位置从0开始, 超过最大长度则初始化失败" @默认值 = 0>
    参数 上限次数 <类型 = 变整数 注释 = "允许迭代次数, 默认为迭代失败为止" @默认值 = -1>
    {
        @ if ((size_t)@<上限次数> > 0 && @<构造类节点>.m_doc && yyjson_mut_obj_iter_init(@<构造类节点>.m_val, &m_obj_iter)){
        @    size_t idx = @<开始位置>;
        @    while (idx && yyjson_mut_obj_iter_next(&m_obj_iter)) idx--;
        @    if (!idx) {
        @        m_max = (size_t)@<上限次数>;
        @        m_doc = @<构造类节点>.m_doc;
        @        return true;
        @    }
        @    memset(&m_obj_iter, 0, sizeof(yyjson_mut_obj_iter));
        @ }
        @ return false;

    }

    方法 迭代键名节点 <公开 类型 = 逻辑型 注释 = "迭代键值" 折叠 @禁止流程检查 = 真>
    参数 结果键名 <类型 = 文本型>
    参数 结果节点 <类型 = JSON构造数组类_yy "">
    {
        @ yyjson_mut_val* key;
        @ if (m_max && (key = yyjson_mut_obj_iter_next(&m_obj_iter))){
        @    @<结果键名> = @an<CVolString> ((const CHAR*)(key->uni.ptr ? key->uni.ptr : ""));
        @    @<结果节点>.set_doc_val(m_doc, yyjson_mut_obj_iter_get_val(key));
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_mut_obj_iter));
        @    m_doc = NULL;
        @    return false;
        @ }
    }

    方法 迭代键名 <公开 类型 = 逻辑型 注释 = "迭代键" 折叠 @禁止流程检查 = 真>
    参数 结果键名 <类型 = 文本型>
    {
        @  yyjson_mut_val* key;
        @ if (m_max && (key = yyjson_mut_obj_iter_next(&m_obj_iter))){
        @    @<结果键名> = @an<CVolString> ((const CHAR*)(key->uni.ptr ? key->uni.ptr : ""));
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_mut_obj_iter));
        @    m_doc = NULL;
        @    return false;
        @ }
    }

    方法 迭代节点 <公开 类型 = 逻辑型 注释 = "迭代值" 折叠 @禁止流程检查 = 真>
    参数 结果节点 <类型 = JSON构造数组类_yy "">
    {
        @ yyjson_mut_val* key;
        @ if (m_max && (key = yyjson_mut_obj_iter_next(&m_obj_iter))){
        @    @<结果节点>.set_doc_val(m_doc, yyjson_mut_obj_iter_get_val(key));
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_mut_obj_iter));
        @    m_doc = NULL;
        @    return false;
        @ }
    }
}

类 JSON构造数组类迭代器_yy <公开 注释 = "遍历数组时建议使用迭代器,性能高" 注释 = "yyjson采用的是单向链表储存数据,仅支持正向迭代" 折叠 折叠2
        @文档 = "category = \"JSON操作库.yyjson.构造数组\"" @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include"
        @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h" @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_hs.cpp"
        @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_.c">
{

    # @begin
    # <> <include>
    # public:
    #     yyjson_mut_arr_iter m_arr_iter;
    #     yyjson_mut_doc* m_doc = NULL;
    #     size_t m_max;
    # <> </include>
    # @end

    方法 类_初始化 <折叠 "">
    {
        @ memset(&m_arr_iter, 0, sizeof(yyjson_mut_arr_iter));
    }

    方法 初始化 <公开 类型 = 逻辑型 注释 = "初始化构造类节点" 折叠 @禁止流程检查 = 真>
    参数 构造类节点 <类型 = JSON构造数组类_yy>
    参数 开始位置 <类型 = 变整数 注释 = "位置从0开始, 超过最大长度则初始化失败" @默认值 = 0>
    参数 上限次数 <类型 = 变整数 注释 = "允许迭代次数, 默认为迭代失败为止" @默认值 = -1>
    {
        @ if ((size_t)@<上限次数> > 0 && @<构造类节点>.m_doc && yyjson_mut_arr_iter_init(@<构造类节点>.m_val, &m_arr_iter)){
        @    size_t idx = @<开始位置>;
        @    while (idx && yyjson_mut_arr_iter_next(&m_arr_iter)) idx--;
        @    if (!idx) {
        @        m_max = (size_t)@<上限次数>;
        @        m_doc = @<构造类节点>.m_doc;
        @        return true;
        @    }
        @    memset(&m_arr_iter, 0, sizeof(yyjson_mut_arr_iter));
        @ }
        @ return false;

    }

    方法 迭代节点 <公开 类型 = 逻辑型 注释 = "迭代值" 折叠 @禁止流程检查 = 真>
    参数 构造类节点 <类型 = JSON构造数组类_yy "">
    {
        @ yyjson_mut_val* val;
        @ if (m_max && (val = yyjson_mut_arr_iter_next(&m_arr_iter))){
        @    @<构造类节点>.set_doc_val(m_doc, val);
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_arr_iter, 0, sizeof(yyjson_mut_arr_iter));
        @    m_doc = NULL;
        @    return false;
        @ }

    }
}

类 解析标志_yy <公开 注释 = "多项标志可用 连续位或() 来叠加" 折叠 @文档 = "category = \"JSON操作库.yyjson.附加类\"">
{
    常量 默认 <公开 类型 = 整数 值 = @YYJSON_READ_NOFLAG 注释 = "默认模式" "">
    常量 原位解析 <公开 类型 = 整数 值 = @YYJSON_READ_INSITU 注释 = "原位解析,会破坏源变量内容,可以提高解析速度.">
    常量 完成时停止 <公开 类型 = 整数 值 = @YYJSON_READ_STOP_WHEN_DONE 注释 = "解析完成直接返回,JSON后面还有内容则不报错.如: \"{\"name\":\"yyjson\"}{\"age\":1}\"">
    常量 允许尾随逗号 <公开 类型 = 整数 值 = @YYJSON_READ_ALLOW_TRAILING_COMMAS 注释 = "允许在对象或数组的末尾使用单个尾随逗号. 如: [1,2,] 或 {\"name\":\"yyjson\",}">
    常量 允许注释 <公开 类型 = 整数 值 = @YYJSON_READ_ALLOW_COMMENTS 注释 = "允许C样式的单行和多行注释. 如: \"//注释\" \"/*注释*/\"">
    常量 允许nan_inf <公开 类型 = 整数 值 = @YYJSON_READ_ALLOW_INF_AND_NAN 注释 = "允许nan/inf数字或文字，如1e999、nan、inf、无穷大.">
}

