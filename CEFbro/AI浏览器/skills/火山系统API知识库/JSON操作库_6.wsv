    参数 默认值 <类型 = 长整数 注释 = "配置不存在时返回的默认值" @默认值 = 0>
    {
        @ if (m_doc && m_val){
        @     bool exist;
        @     yyjson_mut_val* val = pointer_set_val((const wchar_t*)@<路径>.GetText(), exist);
        @     if (val) {
        @         yy_mut_val _val(m_doc, val);
        @         if (exist && (yyjson_mut_is_sint(val) || yyjson_mut_is_uint(val))) return _val.get_int64();
        @         _val.yy_mut_val::set((int64_t)@<默认值>);
        @     }
        @ }
        @ return @<默认值>;
    }

    方法 取路径逻辑值 <公开 类型 = 逻辑型 注释 = "根据路径取逻辑值,路径不存在则自动构造并设置为默认值." 注释 = "注意: 如果节点无效,也将返回默认值" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    参数 默认值 <类型 = 逻辑型 注释 = "配置不存在时返回的默认值" @默认值 = 假>
    {
        @ if (m_doc && m_val){
        @     bool exist;
        @     yyjson_mut_val* val = pointer_set_val((const wchar_t*)@<路径>.GetText(), exist);
        @     if (val) {
        @         yy_mut_val _val(m_doc, val);
        @         if (exist && yyjson_mut_is_bool(val)) return _val.get_bool();
        @         _val.yy_mut_val::set((bool)@<默认值>);
        @     }
        @ }
        @ return @<默认值>;
    }

    方法 取路径小数值 <公开 类型 = 小数 注释 = "根据路径取小数值,路径不存在则自动构造并设置为默认值." 注释 = "注意: 如果节点无效,也将返回默认值" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    参数 默认值 <类型 = 小数 注释 = "配置不存在时返回的默认值" @默认值 = 0.0>
    {
        @ if (m_doc && m_val){
        @     bool exist;
        @     yyjson_mut_val* val = pointer_set_val((const wchar_t*)@<路径>.GetText(), exist);
        @     if (val) {
        @         yy_mut_val _val(m_doc, val);
        @         if (exist && yyjson_mut_is_real(val)) return _val.get_double();
        @         _val.yy_mut_val::set((double)@<默认值>);
        @     }
        @ }
        @ return @<默认值>;

    }

    方法 取路径文本值 <公开 类型 = 文本型 注释 = "根据路径取文本值,路径不存在则自动构造并设置为默认值." 注释 = "注意: 如果节点无效,也将返回默认值" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "必须以\"/\"开头(如\"/name\"),支持多路径 \"/array/0\" 等于 arrat[0]">
    参数 默认值 <类型 = 文本型 注释 = "配置不存在时返回的默认值" @默认值 = "">
    {
        @ if (m_doc && m_val){
        @     bool exist;
        @     yyjson_mut_val* val = pointer_set_val((const wchar_t*)@<路径>.GetText(), exist);
        @     if (val) {
        @         yy_mut_val _val(m_doc, val);
        @         if (exist && yyjson_mut_is_str(val)) return @an<CVolString> ((const CHAR*)_val.get_str());
        @         _val.yy_mut_val::set((const wchar_t*)@<默认值>.GetText());
        @     }
        @ }
        @ return @<默认值>;
    }

    方法 取对象成员键名 <公开 类型 = 文本型 注释 = "根据索引取对象节点的成员键名" 折叠 @嵌入式方法 = "">
    参数 索引 <类型 = 变整数 注释 = "从0开始">
    {
        @ @an<CVolString> ((const CHAR*)@sn<this>.obj_get_key(@<索引>))
    }

    方法 添加对象节点 <公开 类型 = JSON构造数组类_yy 注释 = "说明: 新添加的节点为null型"
            注释 = "使用例子: 添加对象节点(\"key\").文本值 = \"str\" 在当前节点下添加 \"key\":\"str\" 键值对" 返回值注释 = "成功返回有效的节点, 失败返回无效的节点" 折叠 折叠2 @禁止流程检查 = 真>
    参数 键名 <类型 = 文本型>
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        @ return @sn<current_class>(m_doc, obj_add((const wchar_t*)@<键名>.GetText(),@<查找>));
    }

