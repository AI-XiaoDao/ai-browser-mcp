<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <注释 = "本库修改自“lyjdgkg”的yyjson" @文档 = "category = \"JSON操作库\"">

# 简例1：
# 新建变量：JSON对象　JSON构造对象类_yy　　　JSON数组　JSON构造数组类_yy　　　JSON数组2　JSON构造数组类_yy
# JSON对象.初始化空对象 ()
# JSON数组 = JSON对象.添加对象节点 ("A级", 假).置空对象 ()
# JSON数组.添加对象节点 ("姓名", 假).文本值 = "张三"
# JSON数组.添加对象节点 ("年龄", 假).整数值 = 20
# JSON数组 = JSON对象.添加对象节点 ("B组", 假).置空对象 ()
# JSON数组.添加对象节点 ("爱好", 假).文本值 = "编程"
# JSON数组 = JSON对象.添加对象节点 ("C组", 假).置空数组 ()
# JSON数组.添加数组节点 ().文本值 = "王五"
# JSON数组.添加数组节点 ().文本值 = "赵六"
# 调试输出 (JSON对象.到可读文本 ())
# 结果：{"A级":{"姓名":"张三","年龄":20},"B组":{"爱好":"编程"},"C组":["王五","赵六"]}
#
# 简例2：
# JSON对象.初始化空对象 ()
# JSON数组 = JSON对象.添加对象节点 ("信息组", 假).置空数组 ()
# JSON数组2 = JSON数组.添加数组节点 ().置空对象 ()
# JSON数组2.添加对象节点 ("姓名", 假).文本值 = "张三"
# JSON数组2.添加对象节点 ("年龄", 假).整数值 = 12
# JSON数组2 = JSON数组.添加数组节点 ().置空对象 ()
# JSON数组2.添加对象节点 ("姓名", 假).文本值 = "李四"
# JSON数组2.添加对象节点 ("年龄", 假).整数值 = 14
# 调试输出 (JSON对象.到可读文本 ())
# 结果：{"信息组":[{"姓名":"张三","年龄":12},{"姓名":"李四","年龄":14}]}
#
# 简例3：
# JSON对象.初始化空数组 ()
# JSON数组 = JSON对象.添加数组节点 ().置空对象 ()
# JSON数组.添加对象节点 ("姓名", 假).文本值 = "张三"
# JSON数组.添加对象节点 ("年龄", 假).整数值 = 12
# JSON数组 = JSON对象.添加数组节点 ().置空对象 ()
# JSON数组.添加对象节点 ("姓名", 假).文本值 = "李四"
# JSON数组.添加对象节点 ("年龄", 假).整数值 = 14
# 调试输出 (JSON对象.到可读文本 ())
# 结果：[{"姓名":"张三","年龄":12},{"姓名":"李四","年龄":14}]

类 JSON辅助类_ <公开 折叠 折叠2 @文档 = "category = \"JSON操作库.yyjson简化\"" @全局类 = 真>
{
    方法 JSON_取所有键名 <公开 静态 类型 = 整数 返回值注释 = "返回总数，错误返回－1" 折叠>
    参数 文本数据 <类型 = 文本型 注释 = "提供文本型JSON数据，参数一、二只需给一个即可" @默认值 = "">
    参数 字节集数据 <类型 = 字节集类 注释 = "提供字节集型JSON数据，参数一、二只需给一个即可" @默认值 = 空对象>
    参数 返回的键名组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 JSON对象 <类型 = JSON解析对象类_yy>
        变量 JSON迭代对象 <类型 = JSON解析对象类迭代器_yy>
        变量 键名称 <类型 = 文本型>
        如果 (文本是否为空 (文本数据) && 字节集数据.取字节集长度 () == 0)
        {
            返回 (-1)
        }
        如果 (文本是否为空 (文本数据))
        {
            JSON对象.创建自字节集 (字节集数据)
        }
        否则
        {
            JSON对象.创建自文本 (文本数据)
        }
        如果真 (JSON迭代对象.初始化 (JSON对象))
        {
            判断循环 (JSON迭代对象.迭代键名 (键名称))
            {
                返回的键名组.加入成员 (键名称)
            }
        }
        返回 (返回的键名组.取成员数 ())
    }

    方法 JSON_取所有键值 <公开 静态 类型 = 整数 返回值注释 = "返回总数，错误返回－1" 折叠>
    参数 文本数据 <类型 = 文本型 注释 = "提供文本型JSON数据，参数一、二只需给一个即可" @默认值 = "">
    参数 字节集数据 <类型 = 字节集类 注释 = "提供字节集型JSON数据，参数一、二只需给一个即可" @默认值 = 空对象>
    参数 返回的键值组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 JSON对象 <类型 = JSON解析对象类_yy>
        变量 JSON迭代对象 <类型 = JSON解析对象类迭代器_yy>
        变量 JSON数组 <类型 = JSON解析数组类_yy>
        如果 (文本是否为空 (文本数据) && 字节集数据.取字节集长度 () == 0)
        {
            返回 (-1)
        }
        如果 (文本是否为空 (文本数据))
        {
            JSON对象.创建自字节集 (字节集数据)
        }
        否则
        {
            JSON对象.创建自文本 (文本数据)
        }
        如果真 (JSON迭代对象.初始化 (JSON对象))
        {
            判断循环 (JSON迭代对象.迭代节点 (JSON数组))
            {
                返回的键值组.加入成员 (JSON数组.可读文本)
            }
        }
        返回 (返回的键值组.取成员数 ())
    }

    方法 JSON_枚举结构 <公开 静态 类型 = 整数 注释 = "取出json数据中所有键名、键值、类型" 返回值注释 = "返回总数，错误返回－1" 折叠>
    参数 文本数据 <类型 = 文本型 注释 = "提供文本型JSON数据，参数一、二只需给一个即可" @默认值 = "">
    参数 字节集数据 <类型 = 字节集类 注释 = "提供字节集型JSON数据，参数一、二只需给一个即可" @默认值 = 空对象>
    参数 返回的键名组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的类型组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的键值组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 JSON对象 <类型 = JSON解析对象类_yy>
        变量 JSON迭代对象 <类型 = JSON解析对象类迭代器_yy>
        变量 JSON数组 <类型 = JSON解析数组类_yy>
        变量 键名称 <类型 = 文本型>
        如果 (文本是否为空 (文本数据) && 字节集数据.取字节集长度 () == 0)
        {
            返回 (-1)
        }
        如果 (文本是否为空 (文本数据))
        {
            JSON对象.创建自字节集 (字节集数据)
        }
        否则
        {
            JSON对象.创建自文本 (文本数据)
        }
        如果真 (JSON迭代对象.初始化 (JSON对象))
        {
            判断循环 (JSON迭代对象.迭代键名节点 (键名称, JSON数组))
            {
                返回的键名组.加入成员 (键名称)
                返回的类型组.加入成员 (JSON数组.类型名称)
                返回的键值组.加入成员 (JSON数组.可读文本)
            }
        }
        返回 (返回的键名组.取成员数 ())
    }
}

# //=====

类 JSON对象类_ <公开 注释 = "基于yyJson" 折叠 @文档 = "category = \"JSON操作库.yyjson简化\"">
{
    变量 对象1 <类型 = JSON构造对象类_yy>
    变量 数组1 <类型 = JSON构造数组类_yy>

    方法 类_初始化 <折叠>
    {
        对象1.初始化空对象 ()
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "从JSON文本创建,返回是否成功." 折叠>
    参数 内容 <类型 = 文本型 注释 = "必须是Json格式的文本">
    {
        返回 (对象1.创建自文本 (内容, ))
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "从JSON字节集创建,返回是否成功." 折叠>
    参数 内容 <类型 = 字节集类 注释 = "必须是Json格式的字节集">
    {
        返回 (对象1.创建自字节集 (内容, ))
    }

    方法 清空 <公开 注释 = "清空本对象中的数据" 折叠>
    {
        对象1.清空 ()
        对象1.初始化空对象 ()
    }

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "如果操作当前属性的是JSON对象类,则返回键数量.如果是JSON数组类,则返回数组成员数." 折叠>
    {
        返回 (对象1.成员数)
    }

    方法 成员数2 <公开 类型 = 整数 注释 = "如果操作当前属性的是JSON对象类,则返回键数量.如果是JSON数组类,则返回数组成员数." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供要判断的键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            返回 (对象1.取路径节点 (键名称).成员数)
        }
        返回 (对象1.取节点 (键名称).成员数)
    }

    方法 到可读文本 <公开 类型 = 文本型 注释 = "把JSON转换成可读文本并格式化数据" 折叠>
    参数 构造标志 <类型 = 整数 @默认值 = 构造标志_yy.默认模式>
    {
        返回 (对象1.到可读文本 (构造标志))
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把JSON格式化成UTF8的字节集" 折叠>
    参数 构造标志 <类型 = 整数 @默认值 = 构造标志_yy.默认模式>
    参数 是否包括结束零字符 <类型 = 逻辑型 注释 = "指定在所转换到的结果文本字节集中是否包括结束零字符" @默认值 = 真>
    {
        返回 (对象1.到字节集 (构造标志, 是否包括结束零字符))
    }

    方法 成员是否存在 <公开 类型 = 逻辑型 注释 = "判断指定键名是否存在." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供要判断的键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            返回 (对象1.取路径节点 (键名称).是否有效)
        }
        返回 (对象1.取节点 (键名称).是否有效)
    }

    方法 置入文本值 <公开 注释 = "将指定的文本值置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 文本型 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).文本值 = 值内容
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).文本值 = 值内容
        }
    }

    方法 置入字节集值 <公开 注释 = "将指定的字节集置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 字节集类 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).文本值 = 转BASE64编码_ (值内容)
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).文本值 = 转BASE64编码_ (值内容)
        }
    }

    方法 置入整数值 <公开 注释 = "将指定的整数值置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 整数 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).整数值 = 值内容
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).整数值 = 值内容
        }
    }

    方法 置入长整数值 <公开 注释 = "将指定的长整数值置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 长整数 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).长整数值 = 值内容
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).长整数值 = 值内容
        }
    }

    方法 置入小数值 <公开 注释 = "将指定的小数值置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 小数 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).小数值 = 值内容
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).小数值 = 值内容
        }
    }

    方法 置入逻辑值 <公开 注释 = "将指定的逻辑值置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 值内容 <类型 = 逻辑型 注释 = "提供键值">
    参数 查找 <类型 = 逻辑型 注释 = "真 = 先查找节点是否存在,存在则返回其节点,不存在则添加新节点." 注释 = "假 = 不查找键是否存在,直接添加新节点,(注意: 若节点已存在则会造成节点重复,优点是性能好)" @默认值 = 真>
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            对象1.添加路径节点 (键名称).逻辑值 = 值内容
        }
        否则
        {
            对象1.添加对象节点 (键名称, 查找).逻辑值 = 值内容
        }
    }

    方法 置入对象值 <公开 注释 = "将指定的JSON对象类置入当前JSON对象内指定名称键所对应的值中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 要置入的对象 <类型 = JSON对象类_ 注释 = "提供要置入的JSON对象">
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            数组1 = 对象1.添加路径节点 (键名称).置空对象 ()
            数组1.置JSON字节集 (要置入的对象.到字节集 ())
        }
        否则
        {
            数组1 = 对象1.添加对象节点 (键名称).置空对象 ()
            数组1.置JSON字节集 (要置入的对象.到字节集 ())
        }
    }

    方法 置入数组值 <公开 注释 = "将指定JSON数组类添加到当前数组中." 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    参数 要置入的数组 <类型 = JSON数组类_ 注释 = "提供要置入的JSON数组">
    {
        如果 (取文本左边 (键名称, 1) == "/")
        {
            数组1 = 对象1.添加路径节点 (键名称).置空对象 ()
            数组1.置JSON字节集 (要置入的数组.到字节集 ())
        }
        否则
        {
            数组1 = 对象1.添加对象节点 (键名称).置空对象 ()
            数组1.置JSON字节集 (要置入的数组.到字节集 ())
        }
    }

    方法 取类型 <公开 类型 = 文本型 注释 = "返回键名称对应键值的类型" 折叠>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径。路径必须以“/”开头，如：“/name”，支持多路径“/array/0”(等于 arrat[0])">
    {
        变量 类型名 <类型 = 文本型>
        如果真 (取文本左边 (键名称, 1) == "/")
        {
            类型名 = 对象1.取路径节点 (键名称).类型名称
            如果真 (类型名 == "长整数值")
            {
                如果真 (对象1.取路径节点 (键名称).长整数值 < 2147483648)
                {
                    类型名 = "整数值"
                }
            }
            返回 (类型名)
        }
        类型名 = 对象1.取节点 (键名称).类型名称
        如果真 (类型名 == "长整数值")
        {
            如果真 (对象1.取节点 (键名称).长整数值 < 2147483648)
            {
                类型名 = "整数值"
            }
        }
        返回 (类型名)
    }

    方法 取类型2 <公开 类型 = 整数 注释 = "返回键名称对应键值的类型" 返回值注释 = "1、文本型 2、整数型 3、长整数型 4、小数型 5、逻辑型 6、对象型 7、数组型" 折叠>
