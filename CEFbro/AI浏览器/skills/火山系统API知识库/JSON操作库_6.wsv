类 JSON类_TX <公开 注释 = "Tencent json;" 注释 = "本库改自于“到底是为了什么”" 折叠 折叠2 @文档 = "category = \"JSON操作库.Tencent\""
        @视窗.外部头文件 = "..\\json\\document.h\r\n..\\json\\writer.h\r\n..\\json\\stringbuffer.h\r\n..\\json\\pointer.h">
{

    # @begin
    # using namespace rapidjson;
    # <> <include>
    # rapidjson::Document dom;
    # <> </include>
    # @end

    方法 文本_是否为数字 <类型 = 逻辑型 折叠>
    参数 文本 <类型 = 文本型>
    {
        变量 len <类型 = 整数>
        变量 asc <类型 = 整数>
        len = 取文本长度 (文本)
        如果真 (len == 0)
        {
            返回 (假)
        }
        计次循环 (len)
        {
            asc = 取代码_ (文本, 取循环索引 ())
            如果 (asc < 48)  // ' a=97
            {
                返回 (假)
            }
            否则 (asc > 57)  // ' z=122
            {
                返回 (假)
            }

        }
        返回 (真)
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "解析成功返回真 否则假" 折叠 @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型>
    {
        @ int dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<内容>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<内容>,-1,pszCode,dwNum,0,NULL);
        @ bool ret=!dom.Parse(pszCode).HasParseError();
        @ delete []pszCode;
        @ return ret;
    }

    方法 取文本值 <公开 类型 = 文本型 注释 = "支持路径取值  语法参考备注  如果类型不对将报错  ;" 注释 = "例如：{\"姓名\":\"张三\"}  取：json.取文本值 (\"/姓名\");"
            注释 = "例如：{\"名称\":{\"姓名\":\"张三\"}}  取：json.取文本值 (\"/名称/姓名\")" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const CHAR* ps = GetMbsText (@<路径>.GetText (), memBuf, &npResultTextLength);
        @ const char * ret = Pointer(ps).Get(dom)->GetString();
        @ int len = ::MultiByteToWideChar(CP_ACP, NULL, ret, strlen(ret), NULL, 0);//CP_UTF8
        @ CVolMem text;
        @ text.Alloc(len * 2 + 2, TRUE);
        @ ::MultiByteToWideChar(CP_ACP, NULL, ret, strlen(ret), (LPWSTR)text.GetPtr(), len);//CP_UTF8
        @ return CVolString ((LPWSTR)text.GetPtr());
    }

    方法 取整数值 <公开 类型 = 整数 注释 = "支持路径取值  语法参考备注  如果类型不对将报错 ;" 注释 = "例如：{\"年龄\":18}  取：json.取整数值 (\"/年龄\");"
            注释 = "例如：{\"数值\":{\"年龄\":18}}  取：json.取整数值 (\"/数值/年龄\")" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        // @ const char * ret= dom[pszCode].GetString();
        // @ if(Pointer(pszCode).Get(dom)->IsInt()){//可以不判断
        @ int ret=Pointer(pszCode).Get(dom)->GetInt();
        @ delete []pszCode;
        @ return ret;//}
        // @ else { return -1 ;};

    }

    方法 取长整数值 <公开 类型 = 长整数 注释 = "支持路径取值  语法参考备注  如果类型不对将报错 ;" 注释 = "例如：{\"年龄\":18}  取：json.取整数值 (\"/年龄\");"
            注释 = "例如：{\"数值\":{\"年龄\":18}}  取：json.取整数值 (\"/数值/年龄\")" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ long long  ret=Pointer(pszCode).Get(dom)->GetInt64();
        @ delete []pszCode;
        @ return ret;
    }

    方法 取小数值 <公开 类型 = 小数 注释 = "支持路径取值  语法参考备注  如果类型不对将报错 ;" 注释 = "例如：{\"金额\":1.8}  取：json.取小数值 (\"/金额\");"
            注释 = "例如：{\"数值\":{\"金额\":1.8}}  取：json.取小数值 (\"/数值/金额\")" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ double  ret=Pointer(pszCode).Get(dom)->GetDouble();//单精度GetFloat
        @ delete []pszCode;
        @ return ret;
    }

    方法 取单精度小数值 <公开 类型 = 小数 注释 = "支持路径取值  语法参考备注  如果类型不对将报错 虽然是取 float 但火山没有此类型 返回时自动转为double" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ float  ret=Pointer(pszCode).Get(dom)->GetFloat();
        @ delete []pszCode;
        @ return ret;
    }

    方法 取逻辑值 <公开 类型 = 逻辑型 注释 = "支持路径取值  语法参考备注  如果类型不对将报错 ;" 注释 = "例如：{\"确定\":true}  取：json.取逻辑值 (\"/确定\");"
            注释 = "例如：{\"结果\":{\"确定\":true}}  取：json.取逻辑值 (\"/结果/确定\")" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ bool  ret=Pointer(pszCode).Get(dom)->GetBool();
        @ delete []pszCode;
        @ return ret;
    }

    方法 到可读文本 <公开 类型 = 文本型 注释 = "取 ：后面的内容  可以调试输出解析的内容 或 查看修改后的内容" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "留空为取出所有json数据 ①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1"
            @默认值 = "">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ CString theString;
        @ rapidjson::StringBuffer buffer1;
        @ rapidjson::Writer<rapidjson::StringBuffer> writer1(buffer1);
        @ Pointer(pszCode).Get(dom)->Accept(writer1);
        @ const char * ret=buffer1.GetString();
        @ delete []pszCode;
        @ theString=CA2CT(ret);
        @ return theString;

    }

    方法 取类型 <公开 类型 = 整数 注释 = "0 null  1false 2true 3object 4array 5string 6number" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ int ret=Pointer(pszCode).Get(dom)->GetType();
        @ delete []pszCode;
        @ return ret;

    }

    方法 取数组成员数 <公开 类型 = 整数 注释 = "    如果不是数组 或者路径不对 将出错" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "留空为取根目录所有文本 ①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1"
            @默认值 = "">
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        // @ const char * ret= dom[pszCode].GetString();
        // @ if(Pointer(pszCode).Get(dom)->IsArray()){//可以不判断
        @ unsigned int  ret=Pointer(pszCode).Get(dom)->Size();
        @ delete []pszCode;
        @ return ret;//}

    }

    方法 成员是否存在 <公开 类型 = 逻辑型 注释 = "[注意：必须精确到\"成员名\"]  无法判断 数组成员的下标成员  必须精确到 某个具体数组型成员的下标成员中的成员名"
            注释 = "例：\"name\";[{\"id\":\"1\",\"pid\":\"2\"},{...},...]为数组  无法判断name的成员0  只能判断\"id\"  /name/0/id" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = " 例如 /id     /name/0/qid 【0是name数组成员0】"
            注释 = "①/id ②/id/qid ③/id/0/cid ④/id/c1/c11 ⑤/id/a/0/w ⑥/id/0/s/len ⑦/id/0/s/0/d  ⑧/id/wid/1">
    {
        变量 索引 <类型 = 整数>
        变量 路径左 <类型 = 文本型>
        变量 路径右 <类型 = 文本型>
        索引 = 倒找文本 (路径, "/")
        路径左 = 取文本左边 (路径, 索引)
        路径右 = 取文本右边 (路径, 取文本长度 (路径) - 索引 - 1)  // -1去掉/
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径左>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径左>,-1,pszCode,dwNum,0,NULL);
        @ DWORD dwNum2 = WideCharToMultiByte(CP_OEMCP,NULL,@<路径右>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode2 = new char[dwNum2]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径右>,-1,pszCode2,dwNum2,0,NULL);
        @ bool  ret=Pointer(pszCode).Get(dom)->HasMember(pszCode2);
        @ delete []pszCode;
        @ delete []pszCode2;
        @ return ret;//}






    }

