    方法 取所有键名_ <公开 类型 = 整数 返回值注释 = "返回总数，错误返回-1" 折叠>
    参数 待解析数据 <类型 = 文本型 注释 = "参数一与参数二只需要提供一个即可" @默认值 = "">
    参数 待解析数据2 <类型 = 字节集类 注释 = "UTF8字节集，参数一与参数二只需要提供一个即可" @默认值 = 空对象>
    参数 返回的键名组 <类型 = 文本数组类 注释 = "如果解析的数据只有数组部份，本参数将为空" @默认值 = 空对象>
    参数 返回的键值组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的类型组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 迭代对象1 <类型 = JSON解析对象类迭代器_yy>
        变量 迭代数组1 <类型 = JSON解析数组类迭代器_yy>
        变量 解析对象1 <类型 = JSON解析对象类_yy>
        变量 解析数组1 <类型 = JSON解析数组类_yy>
        变量 解析数组2 <类型 = JSON解析数组类_yy>
        变量 键名称 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果 (文本是否为空 (待解析数据))
        {
            结果 = 解析对象1.创建自字节集 (待解析数据2, )
            如果真 (结果 == 假)
            {
                返回 (-1)
            }
        }
        否则
        {
            结果 = 解析对象1.创建自文本 (待解析数据, )
            如果真 (结果 == 假)
            {
                返回 (-1)
            }
        }
        如果 (取文本左边 (待解析数据, 1) == "{")
        {
            如果真 (迭代对象1.初始化 (解析对象1))
            {
                判断循环 (迭代对象1.迭代键名节点 (键名称, 解析数组1))
                {
                    返回的键名组.加入成员 (键名称)
                    返回的键值组.加入成员 (解析数组1.可读文本)
                    返回的类型组.加入成员 (解析数组1.类型名称)
                }
            }
        }
        否则
        {
            如果真 (迭代数组1.初始化 (解析对象1))
            {
                判断循环 (迭代数组1.迭代节点 (解析数组1))
                {
                    返回的键名组.加入成员 ("")
                    返回的键值组.加入成员 (解析数组1.可读文本)
                    返回的类型组.加入成员 (解析数组1.类型名称)
                }
            }
        }
        返回 (返回的键名组.取成员数 ())
    }
}

类 JSON解析对象类迭代器_yy <公开 注释 = "遍历对象时建议使用迭代器,性能高" 注释 = "yyjson采用的是单向链表储存数据,仅支持正向迭代" 折叠 折叠2
        @文档 = "category = \"JSON操作库.yyjson.解析对象\"" @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include"
        @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h" @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_hs.cpp"
        @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_.c">
{

    # @begin
    # <> <include>
    # public:
    #     yyjson_obj_iter m_obj_iter;
    #     size_t m_max;
    # <> </include>
    # @end

    方法 类_初始化 <折叠 "">
    {
        @ memset(&m_obj_iter, 0, sizeof(yyjson_obj_iter));
    }

    方法 初始化 <公开 类型 = 逻辑型 注释 = "初始化解析类节点" 返回值注释 = "成功返回真, 失败返回假" 折叠 @禁止流程检查 = 真>
    参数 解析类节点 <类型 = JSON解析数组类_yy>
    参数 开始位置 <类型 = 变整数 注释 = "位置从0开始" @默认值 = 0>
    参数 上限次数 <类型 = 变整数 注释 = "允许迭代次数, 默认为迭代失败为止" @默认值 = -1>
    {
        @ if ((size_t)@<上限次数> > 0 && yyjson_obj_iter_init(@<解析类节点>.m_val, &m_obj_iter)){
        @    size_t idx = @<开始位置>;
        @    while (idx && yyjson_obj_iter_next(&m_obj_iter)) idx--;
        @    if (!idx) {
        @        m_max = (size_t)@<上限次数>;
        @        return true;
        @    }
        @    memset(&m_obj_iter, 0, sizeof(yyjson_obj_iter));
        @ }
        @ return false;
    }

    方法 迭代键名节点 <公开 类型 = 逻辑型 注释 = "迭代键值对" 返回值注释 = "迭代成功返回真, 失败返回假" 折叠 @禁止流程检查 = 真>
    参数 结果键名 <类型 = 文本型 注释 = "结果将保存到传递的变量内">
    参数 结果节点 <类型 = JSON解析数组类_yy 注释 = "结果将保存到传递的变量内">
    {
        @ yyjson_val* key;
        @ if (m_max && (key = yyjson_obj_iter_next(&m_obj_iter))){
        @    @<结果键名> = @an<CVolString> ((const CHAR*)(key->uni.ptr ? key->uni.ptr : ""));
        @    @<结果节点>.m_val = yyjson_obj_iter_get_val(key);
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_obj_iter));
        @    return false;
        @ }

    }

    方法 迭代键名 <公开 类型 = 逻辑型 注释 = "迭代键" 返回值注释 = "迭代成功返回真, 失败返回假" 折叠 @禁止流程检查 = 真>
    参数 结果键名 <类型 = 文本型 注释 = "结果将保存到传递的变量内">
    {
        @  yyjson_val* key;
        @ if (m_max && (key = yyjson_obj_iter_next(&m_obj_iter))){
        @    @<结果键名> = @an<CVolString> ((const CHAR*)(key->uni.ptr ? key->uni.ptr : ""));
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_obj_iter));
        @    return false;
        @ }

    }

    方法 迭代节点 <公开 类型 = 逻辑型 注释 = "迭代值" 返回值注释 = "迭代成功返回真, 失败返回假" 折叠 @禁止流程检查 = 真>
    参数 结果节点 <类型 = JSON解析数组类_yy 注释 = "结果将保存到传递的变量内">
    {
        @  yyjson_val* key;
        @ if (m_max && (key = yyjson_obj_iter_next(&m_obj_iter))){
        @    @<结果节点>.m_val = yyjson_obj_iter_get_val(key);
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_obj_iter, 0, sizeof(yyjson_obj_iter));
        @    return false;
        @ }
    }

    方法 取所有键名_ <公开 类型 = 整数 返回值注释 = "返回总数，错误返回-1" 折叠>
