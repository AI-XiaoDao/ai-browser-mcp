    方法 删除成员 <公开 类型 = 逻辑型 注释 = "删除成员   支持删除 根路径成员   数组类型的成员  数组类型成员的下标成员 ;"
            注释 = "例如：{\"姓名\":\"张三\",\"年龄\":18}  删除：json.删除成员 (\"/姓名\") ;"
            注释 = "例如：{\"名称\":{\"姓名\":\"张三\"},\"名称2\":{\"年龄\":18}}  删除：json.删除成员 (\"/名称2\")"
            注释 = "/pid/wid     /pid/wid/0    /name/1/required" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    {
        如果 (寻找文本 (路径, "/", 1) == -1)  // 判断是否有第二个 /     删除根路径成员
        {
            子文本替换 (路径, "/", "")
            @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
            @ char *pszCode = new char[dwNum]; 
            @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
            @ bool ret=Pointer().Get(dom)->RemoveMember(pszCode);
            @ delete []pszCode;
            @ return ret;
        }
        否则
        {
            变量 索引 <类型 = 整数>
            变量 路径左 <类型 = 文本型>
            变量 路径右 <类型 = 文本型>
            索引 = 倒找文本 (路径, "/")
            路径左 = 取文本左边 (路径, 索引)
            路径右 = 取文本右边 (路径, 取文本长度 (路径) - 索引 - 1)  // -1去掉/
            @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径左>,-1,NULL,NULL,0,NULL); 
            @ char *pszCode = new char[dwNum]; 
            @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径左>,-1,pszCode,dwNum,0,NULL);
            如果 (成员是否为数组 (路径左) && 文本_是否为数字 (路径右))  //  "/name/0"   判断循环/name 是否为数组 && /0 是否为数字
            {
                变量 数组索引 <类型 = 整数>
                数组索引 = 文本到整数 (路径右)
                @ rapidjson::Value& imp = Pointer(pszCode).Get(dom)->GetArray();
                @ imp.Erase(imp.Begin()+@<数组索引>);
                @ delete []pszCode;
                @ return true; 
            }
            否则
            {
                @ DWORD dwNum2 = WideCharToMultiByte(CP_OEMCP,NULL,@<路径右>,-1,NULL,NULL,0,NULL); 
                @ char *pszCode2 = new char[dwNum2]; 
                @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径右>,-1,pszCode2,dwNum2,0,NULL);
                @ bool  ret=Pointer(pszCode).Get(dom)->RemoveMember(pszCode2);
                @ delete []pszCode;
                @ return ret; 

            }

        }




    }

    方法 置入文本值 <公开 注释 = "添加成员  也可以修改值  支持路径  根据所提供路径也可以插入数组 ;" 注释 = "例如：json.置入文本值 (\"/姓名\", \"张三\")  得到：{\"姓名\":\"张三\"};"
            注释 = "例如：json.置入文本值 (\"/名称/姓名\", \"张三\")  得到：{\"名称\":{\"姓名\":\"张三\"}}" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    参数 值 <类型 = 文本型>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ DWORD Num2 = WideCharToMultiByte(CP_OEMCP,NULL,@<值>,-1,NULL,NULL,0,NULL); 
        @ char *Code2 = new char[Num2]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<值>,-1,Code2,Num2,0,NULL);
        @ Pointer(pszCode).Set(dom, Code2);//Create 创建的 格式为 "b":null
        @ delete []pszCode;
        @ delete []Code2;
    }

