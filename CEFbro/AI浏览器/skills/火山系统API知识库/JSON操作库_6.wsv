    方法 到字节集 <公开 类型 = 字节集类 注释 = "将容器型节点(对象型/数组型)构造为JSON UTF8字节集数据" 返回值注释 = "UTF8编码" 折叠 @禁止流程检查 = 真>
    参数 构造标志 <类型 = 整数 @默认值 = 构造标志_yy.默认模式>
    参数 是否包括结束零字符 <类型 = 逻辑型 注释 = "指定在所转换到的结果文本字节集中是否包括结束零字符" @默认值 = 真>
    {
        @ yy_buf buf = get_json(@<构造标志>);
        @ const char* ptr = (const char*)buf.get_ptr();
        @ size_t len = buf.get_len();
        @ if (ptr && len){
        @    return CVolMem (ptr,@<是否包括结束零字符> ? ++len: len);
        @ }
        @ else {
        @    return CVolMem ("",@<是否包括结束零字符> ? 1 : 0);
        @ }
    }

    方法 是否为容器 <公开 属性读 类型 = 逻辑型 注释 = "判断当前节点是否为 对象型 或 数组型" 折叠 @嵌入式方法 = "">
