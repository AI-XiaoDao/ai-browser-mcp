    方法 初始化 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 解析类节点 <类型 = JSON解析数组类_yy>
    参数 开始位置 <类型 = 变整数 注释 = "位置从0开始, 超过最大长度则初始化失败" @默认值 = 0>
    参数 上限次数 <类型 = 变整数 注释 = "允许迭代次数, 默认为迭代失败为止" @默认值 = -1>
    {
        @ if ((size_t)@<上限次数> > 0 && yyjson_arr_iter_init(@<解析类节点>.m_val, &m_arr_iter)){
        @    size_t idx = @<开始位置>;
        @    while (idx && yyjson_arr_iter_next(&m_arr_iter)) idx--;
        @    if (!idx) {
        @        m_max = (size_t)@<上限次数>;
        @        return true;
        @    }
        @    memset(&m_arr_iter, 0, sizeof(yyjson_arr_iter));
        @ }
        @ return false;
    }

    方法 迭代节点 <公开 类型 = 逻辑型 注释 = "迭代下一个" 折叠 @禁止流程检查 = 真>
    参数 结果节点 <类型 = JSON解析数组类_yy>
    {
        @ yyjson_val* val;
        @ if (m_max && (val = yyjson_arr_iter_next(&m_arr_iter))){
        @    @<结果节点>.m_val = val;
        @    m_max--;
        @    return true;
        @ }
        @ else {
        @    memset(&m_arr_iter, 0, sizeof(yyjson_arr_iter));
        @    return false;
        @ }
    }

    方法 取所有键名_ <公开 类型 = 整数 返回值注释 = "返回总数，错误返回-1" 折叠>
    参数 待解析数据 <类型 = 文本型 注释 = "参数一与参数二只需要提供一个即可" @默认值 = "">
    参数 待解析数据2 <类型 = 字节集类 注释 = "UTF8字节集，参数一与参数二只需要提供一个即可" @默认值 = 空对象>
    参数 返回的键名组 <类型 = 文本数组类 注释 = "如果解析的数据只有数组部份，本参数将为空" @默认值 = 空对象>
    参数 返回的键值组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的类型组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 迭代对象1 <类型 = JSON解析对象类迭代器_yy>
        变量 迭代数组1 <类型 = JSON解析数组类迭代器_yy>
        变量 解析对象1 <类型 = JSON解析对象类_yy>
        变量 解析数组1 <类型 = JSON解析数组类_yy>
        变量 解析数组2 <类型 = JSON解析数组类_yy>
        变量 键名称 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果 (文本是否为空 (待解析数据))
        {
            结果 = 解析对象1.创建自字节集 (待解析数据2, )
            如果真 (结果 == 假)
            {
                返回 (-1)
            }
        }
        否则
        {
            结果 = 解析对象1.创建自文本 (待解析数据, )
            如果真 (结果 == 假)
            {
                返回 (-1)
            }
        }
        如果 (取文本左边 (待解析数据, 1) == "{")
        {
            如果真 (迭代对象1.初始化 (解析对象1))
            {
                判断循环 (迭代对象1.迭代键名节点 (键名称, 解析数组1))
                {
                    返回的键名组.加入成员 (键名称)
                    返回的键值组.加入成员 (解析数组1.可读文本)
                    返回的类型组.加入成员 (解析数组1.类型名称)
                }
            }
        }
        否则
        {
            如果真 (迭代数组1.初始化 (解析对象1))
            {
                判断循环 (迭代数组1.迭代节点 (解析数组1))
                {
                    返回的键名组.加入成员 ("")
                    返回的键值组.加入成员 (解析数组1.可读文本)
                    返回的类型组.加入成员 (解析数组1.类型名称)
                }
            }
        }
        返回 (返回的键名组.取成员数 ())
    }
}

类 JSON构造对象类_yy <公开 基础类 = JSON构造数组类_yy 注释 = "构造类根节点" 折叠 折叠2 @文档 = "category = \"JSON操作库.yyjson.构造对象\""
        @视窗.头文件搜寻目录 = "..\\json\\yyjson\\include" @视窗.外部头文件 = "..\\json\\yyjson\\include\\yyjson_hs2.h"
        @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_hs.cpp" @视窗.外部源文件 = "..\\json\\yyjson\\src\\yyjson_.c"
        @视窗.后缀文本 = "public yy_mut_doc">
{

    # @begin
    # <> <include>
    # virtual void CopySelfFromExtra(yyjson_mut_doc* doc, yyjson_mut_val* val) {
    #     yy_mut_doc::create(doc, val);
    # }
    #
    # <> </include>
    # @end

    方法 清空 <公开 注释 = "清空数据" 折叠>
    {
        @ yy_mut_doc::clear();
    }

    方法 初始化空对象 <公开 类型 = 逻辑型 注释 = "构造json前先进行初始化配置，将json创建为空对象 {}" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.create((uint8_t)YYJSON_TYPE_OBJ)
    }

    方法 初始化空数组 <公开 类型 = 逻辑型 注释 = "构造json前先进行初始化配置，将json创建为空数组 []" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.create((uint8_t)YYJSON_TYPE_ARR)
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "从文本解析创建" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠 @嵌入式方法 = "">
    参数 json <类型 = 文本型>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ @sn<this>.create((const wchar_t*)@<json>.GetText(),(yyjson_read_flag)@<解析标志>)
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "从字节集(UTF8编码)解析创建" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠 @禁止流程检查 = 真>
    参数 json <类型 = 字节集类>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ return yy_mut_doc::create((char*)@<json>.GetPtr(),(size_t)@<json>.GetSize(),(yyjson_read_flag)@<解析标志>);
    }

    方法 创建自指针 <公开 类型 = 逻辑型 注释 = "从指针(UTF8编码数据)解析创建" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠 @嵌入式方法 = "">
    参数 json指针 <类型 = 变整数>
    参数 数据长度 <类型 = 变整数>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        @ @sn<this>.create((char*)@<json指针>,(size_t)@<数据长度>,(yyjson_read_flag)@<解析标志>)
    }

    方法 创建自文件 <公开 类型 = 逻辑型 注释 = "从uft8文件解析创建 (注意: yyjson是将文件一次性读入到内存后再进行解析创建.)" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)." 折叠
            @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 解析标志 <类型 = 整数 注释 = "参考常量[解析标志_yy.]系列" @默认值 = 0>
    {
        变量 局_文件路径 <类型 = 字节集类>
        局_文件路径 = 文本到多字节 (文件路径, 真)
        @ return create_from_file((const char*)@<局_文件路径>.GetPtr(),(yyjson_read_flag)@<解析标志>);
    }

    方法 创建自解析类节点 <公开 类型 = 逻辑型 注释 = "从 JSON解析数组类_yy 拷贝数据创建," 注释 = "必须为容器节点(对象型/数组型),否则将创建失败" 返回值注释 = "创建成功返回真, 失败返回假(旧数据将被清空)."
            折叠 折叠2 @嵌入式方法 = "">
    参数 解析类节点 <类型 = JSON解析数组类_yy>
    {
        @ @sn<this>.create(@<解析类节点>.m_val)
    }

    方法 错误类型 <公开 属性读 类型 = 整数 注释 = "取 解析创建 时的错误代码" 返回值注释 = "错误代码" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_read_err.code
    }

    方法 错误描述 <公开 属性读 类型 = 文本型 注释 = "取 解析创建 时的错误描述" 折叠 @禁止流程检查 = 真>
    {
        @ if (m_read_err.msg){
        @     return @an<CVolString> ((const CHAR*)m_read_err.msg);
        @ }
        返回 ("")
    }

    方法 错误位置 <公开 属性读 类型 = 变整数 注释 = "取 解析创建 时的错误位置 (utf8编码下的位置)" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_read_err.pos
    }

    方法 是否已创建 <公开 属性读 类型 = 逻辑型 注释 = "判断是否已经创建" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.m_doc != NULL
    }

    方法 置空值 <公开 类型 = 逻辑型 注释 = "禁止将根节点置为非容器值,直接返回假" 折叠 @虚拟方法 = 不可覆盖>
    {
        返回 (假)
    }
}

类 JSON构造数组类_yy <公开 注释 = "全类型构造类节点" 折叠 折叠2 @文档 = "category = \"JSON操作库.yyjson.构造数组\""
