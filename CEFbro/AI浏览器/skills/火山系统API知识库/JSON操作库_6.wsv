    方法 置入逻辑值 <公开 注释 = "添加成员 也可以修改值  支持路径  根据所提供路径也可以插入数组 ;" 注释 = "例如：json.置入逻辑值 (\"/确定\", 真)  得到：{\"确定\":true};"
            注释 = "例如：json.置入逻辑值 (\"/结果/确定\", 真)  得到：{\"结果\":{\"确定\":true}}" 折叠 折叠2 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    参数 值 <类型 = 逻辑型>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ Pointer(pszCode).Set(dom, @<值> ? true :false);//火山的逻辑型直接传入 是0或1 不是true 或false
        @ delete []pszCode;// Create 创建的 格式为 "b":null
    }

    方法 置入对象值 <公开 注释 = "添加Object成员      目前只能嵌套 尚未实现2个json合并拼接" 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型 注释 = "不允许\"\"  目前尚未实现2个json合并">
    参数 Object <类型 = JSON类_TX>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ Pointer(pszCode).Set(dom, @<Object>.dom); 
        @ delete []pszCode;
    }

    方法 取路径所有键名 <公开 注释 = "取指定路径下所有 成员 名" 折叠>
    参数 路径 <类型 = 文本型 注释 = "\"\"为根目录">
    参数 键名数组 <类型 = 文本数组类>
    {
        @ DWORD dwNum = WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,NULL,NULL,0,NULL); 
        @ char *pszCode = new char[dwNum]; 
        @ WideCharToMultiByte(CP_OEMCP,NULL,@<路径>,-1,pszCode,dwNum,0,NULL);
        @ for(Value::ConstMemberIterator iter = Pointer(pszCode).Get(dom)->MemberBegin(); iter != Pointer(pszCode).Get(dom)->MemberEnd(); ++iter){
        变量 theString <类型 = 文本型>
        @ const char * ret=iter->name.GetString();
        @ @<theString>=CA2CT(ret);
        键名数组.加入成员 (theString)
        // printf("％s\t",iter->name.GetString());
        // printf("％s\t",iter->value.GetString());
        @    }
        @ delete []pszCode;

    }
}
