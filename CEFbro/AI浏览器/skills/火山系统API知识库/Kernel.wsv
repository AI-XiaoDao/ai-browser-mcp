    # 系统相关==

    方法 系统_是否64位 <公开 静态 类型 = 逻辑型 @禁止流程检查 = 真>
    {
        @ #ifndef PROCESSOR_ARCHITECTURE_AMD64
        @  #define PROCESSOR_ARCHITECTURE_AMD64 9
        @ #endif
        @  typedef void (WINAPI *LPGetNativeSystemInfo)(LPSYSTEM_INFO); 
        @  LPGetNativeSystemInfo pGetNativeSystemInfo = (LPGetNativeSystemInfo)GetProcAddress(GetModuleHandle(TEXT("kernel32.dll")),"GetNativeSystemInfo"); 
        @  SYSTEM_INFO cur_system_info;
        @  pGetNativeSystemInfo(&cur_system_info);
        @  WORD system_str= cur_system_info.wProcessorArchitecture;
        @  //判断是否为64位系统
        @  if (system_str == PROCESSOR_ARCHITECTURE_IA64 || system_str == PROCESSOR_ARCHITECTURE_AMD64)
        @  {
        @   return true;
        @  }
        @  return false;


    }

    方法 系统_取CPU核心数F <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    {
        @  SYSTEM_INFO SysemInfo;
        @  GetSystemInfo(&SysemInfo);    //获取系统信息
        @  return (INT) SysemInfo.dwNumberOfProcessors;   

    }

    方法 系统_取内存大小F <公开 静态 类型 = 小数 返回值注释 = "单位 GB" @禁止流程检查 = 真>
    {
        @  MEMORYSTATUS ms;              //记录内容空间信息的结构体变量
        @  GlobalMemoryStatus(&ms);   //调用GlobalMemoryStatus()函数获取内存信息
        @  double fGB = (double)ms.dwTotalPhys / 1024 / 1024 / 1024;                                //总的物理内存大小
        @  //float y = (float)(ms.dwTotalPhys - ms.dwAvailPhys) / 1024 / 1024;  //已用物理内存大小
        @  //int k = ms.dwAvailPhys / 1024 / 1024 ;                                         //可用物理内存大小
        @  return fGB;
    }

    # //===

