    方法 RGB555_2_RGB24 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 rgb555 <类型 = 整数>
    {
        // COLORREF rgb_555_2_24(int rgb555)
        // {
        // unsigned r = ((rgb555 >> 7) & 0xF8);
        // unsigned g = ((rgb555 >> 2) & 0xF8);
        // unsigned b = ((rgb555 << 3) & 0xF8);
        // return RGB(r,g,b);
        // }
        @ unsigned r = ((@<rgb555> >> 7) & 0xF8);
        @ unsigned g = ((@<rgb555> >> 2) & 0xF8);
        @ unsigned b = ((@<rgb555> << 3) & 0xF8);
        @ return RGB(r,g,b);



    }

    方法 RGB555_2_BGR24 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "这个必须是三个字节">
    {
        // void rgb_555_2_bgr24(BYTE* p, int rgb555)
        // {
        // p[0] = ((rgb555 << 3) & 0xF8);
        // p[1] = ((rgb555 >> 2) & 0xF8);
        // p[2] = ((rgb555 >> 7) & 0xF8);
        // }
        @ int rgb555 = 0;
        @ BYTE* p = (BYTE*)@<数据指针>;
        @ p[0] = ((rgb555 << 3) & 0xF8);
        @ p[1] = ((rgb555 >> 2) & 0xF8);
        @ p[2] = ((rgb555 >> 7) & 0xF8);
        @ return rgb555;

    }

