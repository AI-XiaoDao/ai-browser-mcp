        // return (USHORT)(((unsigned(r) << 8) & 0xF800) |
        // ((unsigned(g) << 3) & 0x7E0)  |
        // ((unsigned(b) >> 3)));
        // }
        @ return (USHORT)(((unsigned(@<r>) << 8) & 0xF800) | ((unsigned(@<g>) << 3) & 0x7E0)  | ((unsigned(@<b>) >> 3)));



    }

