    方法 延时_不卡界面 <公开 静态>
    参数 时长 <类型 = 长整数 注释 = "微妙">
    {
        @     HANDLE hEvent = ::CreateWaitableTimer(NULL,FALSE,NULL);
        @     LARGE_INTEGER ltm;
        @     ltm.QuadPart =-10*@<时长>;
        @     ::SetWaitableTimer(hEvent,&ltm,0,NULL,NULL,FALSE);
        @     while(MsgWaitForMultipleObjects(1, &hEvent, FALSE, INFINITE,QS_ALLEVENTS ) != WAIT_OBJECT_0)
        @     {
        @         MSG msg;
        @         while ( ::PeekMessage( &msg, NULL, 0, 0, PM_REMOVE ) != 0 ) 
        @         {
        @              DispatchMessage(&msg);
        @              TranslateMessage(&msg);
        @         }
        @     }
        @     CloseHandle(hEvent);

    }

    方法 取启动时间_整数 <公开 静态 类型 = 整数 注释 = "WinBase.h" @嵌入式方法 = "">
