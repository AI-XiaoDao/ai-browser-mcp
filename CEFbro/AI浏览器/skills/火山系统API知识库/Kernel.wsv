    方法 程序_取命令行数组 <公开 静态 类型 = 整数 返回值注释 = "返回命令行数量" @禁止流程检查 = 真>
    参数 用来保存命令行 <类型 = 文本数组类>
    {
        变量 临时文本 <类型 = 文本型>
        @ int argc = 0;
        @ LPWSTR *wargv = CommandLineToArgvW(GetCommandLine(),&argc);
        @ for (int i = 0; i < argc; i++)
        @ {
        @   @<临时文本> = wargv[i];
        用来保存命令行.加入成员 (临时文本)
        @ }
        @ GlobalFree((HGLOBAL)wargv);
        @ return argc;
    }

