        @ }






    }

    方法 RGB565_2_RGB24短整数 <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    参数 RGB565 <类型 = 短整数>
    {
        @ int rgb24 = 0;
        @ byte* pRGB24 = (byte*)&rgb24;
        @ pRGB24[2] = (@<RGB565> & 0xF800) >> 11;
        @ pRGB24[1] = (@<RGB565> & 0x07E0) >> 5;
        @ pRGB24[0] = (@<RGB565> & 0x001F);
        @ pRGB24[2] <<= 3;
        @ pRGB24[1] <<= 2;
        @ pRGB24[0] <<= 3;
        @ return rgb24;
