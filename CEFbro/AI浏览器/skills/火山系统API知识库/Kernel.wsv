类 ______系统杂项 <公开 折叠 @全局类 = 真 @禁止创建对象 = 真 @视窗.外部头文件 = "<Shlwapi.h>" @视窗.外部库 = "Shlwapi.lib" @视窗.外部头文件 = "<math.h>">
{
    方法 BGR2RGB整数 <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    参数 颜色 <类型 = 整数>
    {
        @ INT C = @<颜色>;
        @ BYTE* pRGB = (BYTE*) &C;
        @ BYTE color = pRGB[1];
        @ pRGB[1] = pRGB[3];
        @ pRGB[3] = color;
        @ return C;

    }

    方法 RGB2BGR整数 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 颜色 <类型 = 整数>
    {
        @ INT C = @<颜色>;
        @ BYTE* pRGB = (BYTE*) &C;
        @ BYTE color = pRGB[1];
        @ pRGB[1] = pRGB[3];
        @ pRGB[3] = color;
        @ return C;
    }

    方法 RGB2BGR字节集 <公开 静态 折叠>
    参数 需要转换的字节集 <类型 = 字节集类>
    {
        @ BYTE* pData = (BYTE*)@<需要转换的字节集>.GetPtr();
        @ int nSize= @<需要转换的字节集>.GetSize();
        @ int nSteps = 0;
        @ if (nSize % 4 == 0) nSteps = 4;
        @ else if(nSize % 3 == 0) nSteps = 4;
        @ else  return;
        @ for(int i = 0; i < nSize; i+=nSteps)
        @ {
        @  BYTE color = pRGB[i - (nSteps -3)];
        @  pRGB[i - (nSteps -3)] = pRGB[i+nSteps-1];
        @  pRGB[i+nSteps-1] = color;
        @ }
    }

    方法 BGR2RGB字节集 <公开 静态 折叠>
