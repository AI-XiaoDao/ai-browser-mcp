类 ______键盘鼠标模拟类 <公开 @全局类 = 真>
{

    # @begin
    # <> <include>
    # static void Mouse_GetCursorPos_FC(int* px,int* py);
    # <> </include>
    #
    # void @sn<current_class>::Mouse_GetCursorPos_FC(int* px,int* py)
    # {
    #     POINT pt;
    #     GetCursorPos (&pt);
    #     *px = pt.x;
    #     *py = pt.y;
    # }
    #
    # @end

    方法 键盘_模拟组合键2_SendInput <公开 类型 = 逻辑型 注释 = "sendinput是不支持后台的哟" 注释 = "支持两个组合键 例如 ctrl+A alt+B 这种" @禁止流程检查 = 真>
    参数 控制键 <类型 = 键代码_常量类 注释 = "一般这个为 ctrl alt win 之类的控制键">
    参数 普通键 <类型 = 键代码_常量类 注释 = "一般为 A B C D到Z之类的字母键">
    {

        @     INPUT inputs[4] = {};
        @     ZeroMemory(inputs, sizeof(inputs));
        @ 
        @     inputs[0].type = INPUT_KEYBOARD;
        @     inputs[0].ki.wVk = @<控制键>;
        @    
        @     inputs[1].type = INPUT_KEYBOARD;
        @     inputs[1].ki.wVk = @<普通键>;
        @ 
        @     inputs[2].type = INPUT_KEYBOARD;
        @     inputs[2].ki.wVk = @<普通键>;
        @     inputs[2].ki.dwFlags = KEYEVENTF_KEYUP;
        @ 
        @     inputs[3].type = INPUT_KEYBOARD;
        @     inputs[3].ki.wVk = @<控制键>;
        @     inputs[3].ki.dwFlags = KEYEVENTF_KEYUP;
        @ 
        @     UINT uSent = SendInput(ARRAYSIZE(inputs), inputs, sizeof(INPUT));
        @     if (uSent != ARRAYSIZE(inputs))
        @     {
        @         return FALSE;
        @         //OutputString(L"SendInput failed: 0x%x\n", HRESULT_FROM_WIN32(GetLastError()));
        @     } 
        @    return TRUE;

    }

    方法 键盘_模拟组合键3_SendInput <公开 类型 = 逻辑型 注释 = "sendinput是不支持后台的哟" 注释 = "支持两个组合键 例如 ctrl+alt+A ctrl+alt+B 这种" @禁止流程检查 = 真>
    参数 控制键 <类型 = 键代码_常量类 注释 = "一般这个为 ctrl  之类的控制键">
    参数 控制键2 <类型 = 键代码_常量类 注释 = "一般这个为 alt shift 之类的控制键">
    参数 普通键 <类型 = 键代码_常量类 注释 = "一般为 A B C D到Z之类的字母键">
    {

        @     INPUT inputs[6] = {};
        @     ZeroMemory(inputs, sizeof(inputs));
        @ 
        @     inputs[0].type = INPUT_KEYBOARD;
        @     inputs[0].ki.wVk = @<控制键>;
        @    
        @     inputs[1].type = INPUT_KEYBOARD;
        @     inputs[1].ki.wVk = @<控制键2>;

        @     inputs[2].type = INPUT_KEYBOARD;
        @     inputs[2].ki.wVk = @<普通键>;
        @ 
        @     inputs[3].type = INPUT_KEYBOARD;
        @     inputs[3].ki.wVk = @<普通键>;
        @     inputs[3].ki.dwFlags = KEYEVENTF_KEYUP;
        @ 
        @     inputs[4].type = INPUT_KEYBOARD;
        @     inputs[4].ki.wVk = @<控制键2>;
        @     inputs[4].ki.dwFlags = KEYEVENTF_KEYUP;

        @     inputs[5].type = INPUT_KEYBOARD;
        @     inputs[5].ki.wVk = @<控制键>;
        @     inputs[5].ki.dwFlags = KEYEVENTF_KEYUP;
        @ 
        @     UINT uSent = SendInput(ARRAYSIZE(inputs), inputs, sizeof(INPUT));
        @     if (uSent != ARRAYSIZE(inputs))
        @     {
        @         return FALSE;
        @         //OutputString(L"SendInput failed: 0x%x\n", HRESULT_FROM_WIN32(GetLastError()));
        @     } 
        @    return TRUE;

    }

    方法 键盘_模拟按键_SendInput <公开 类型 = 逻辑型 注释 = "sendinput是不支持后台的哟" @禁止流程检查 = 真>
    参数 普通键 <类型 = 键代码_常量类 注释 = "一般为 A B C D到Z之类的字母键">
    {

        @     INPUT inputs[2] = {};
        @     ZeroMemory(inputs, sizeof(inputs));
        @ 
        @     inputs[0].type = INPUT_KEYBOARD;
        @     inputs[0].ki.wVk = @<普通键>;
        @ 
        @     inputs[1].type = INPUT_KEYBOARD;
        @     inputs[1].ki.wVk = @<普通键>;
        @     inputs[1].ki.dwFlags = KEYEVENTF_KEYUP;
        @ 
        @     UINT uSent = SendInput(ARRAYSIZE(inputs), inputs, sizeof(INPUT));
        @     if (uSent != ARRAYSIZE(inputs))
        @     {
        @         return FALSE;
        @         //OutputString(L"SendInput failed: 0x%x\n", HRESULT_FROM_WIN32(GetLastError()));
        @     } 
        @    return TRUE;

    }

    # //下面是keybd_event相关=======
    #

    常量 MOUSEEVENTF_ABSOLUTE <公开 类型 = 整数 值 = @MOUSEEVENTF_ABSOLUTE 注释 = "鼠标事件 绝对坐标标志">
    常量 MOUSEEVENTF_MOVE <公开 类型 = 整数 值 = @MOUSEEVENTF_MOVE 注释 = "鼠标事件 移动">
    常量 MOUSEEVENTF_LEFTDOWN <公开 类型 = 整数 值 = @MOUSEEVENTF_LEFTDOWN>
    常量 MOUSEEVENTF_LEFTUP <公开 类型 = 整数 值 = @MOUSEEVENTF_LEFTUP>
    常量 MOUSEEVENTF_RIGHTDOWN <公开 类型 = 整数 值 = @MOUSEEVENTF_RIGHTDOWN>
    常量 MOUSEEVENTF_RIGHTUP <公开 类型 = 整数 值 = @MOUSEEVENTF_RIGHTUP>
    常量 MOUSEEVENTF_MIDDLEDOWN <公开 类型 = 整数 值 = @MOUSEEVENTF_MIDDLEDOWN>
    常量 MOUSEEVENTF_MIDDLEUP <公开 类型 = 整数 值 = @MOUSEEVENTF_MIDDLEUP>
    常量 MOUSEEVENTF_WHEEL <公开 类型 = 整数 值 = @MOUSEEVENTF_WHEEL>
    常量 MOUSEEVENTF_XDOWN <公开 类型 = 整数 值 = @MOUSEEVENTF_XDOWN>
    常量 MOUSEEVENTF_XUP <公开 类型 = 整数 值 = @MOUSEEVENTF_XUP>
    常量 ""
    常量 ""

    方法 keybd_event <公开 静态 折叠 @嵌入式方法 = "">
    参数 虚拟键代码 <类型 = 字节 注释 = "bVk,欲模拟的虚拟键码 win键代码=91">
    参数 扫描码 <类型 = 字节 注释 = "bScan,键的OEM扫描码" @默认值 = 0>
    参数 标志 <类型 = 整数 注释 = "dwFlags,标志常数  KEYEVENTF_KEYUP=2  放开某键的标志" @默认值 = 0>
    参数 dwExtraInfo <类型 = 长整数 注释 = "不常用" @默认值 = 0>
    {
        @ keybd_event(@<虚拟键代码>,@<扫描码>,@<标志>,@<dwExtraInfo>)
    }

    方法 键盘_模拟按下某键 <公开 静态 折叠 @嵌入式方法 = "">
    参数 虚拟键代码 <类型 = 字节 注释 = "bVk,欲模拟的虚拟键码 win键代码=91">
    参数 扫描码 <类型 = 字节 注释 = "bScan,键的OEM扫描码" @默认值 = 0>
    参数 标志 <类型 = 整数 注释 = "dwFlags,标志常数  KEYEVENTF_KEYUP=2  放开某键的标志" @默认值 = 0>
    参数 dwExtraInfo <类型 = 长整数 @默认值 = 0>
    {
        // VOID keybd_event(  BYTE bVk,               // virtual-key code
        // BYTE bScan,             // hardware scan code
        // DWORD dwFlags,          // function options
        // ULONG_PTR dwExtraInfo   // additional keystroke data
        //);
        @ keybd_event(@<虚拟键代码>,@<扫描码>,@<标志>,@<dwExtraInfo>)
    }

    方法 键盘_模拟放开某键 <公开 静态 折叠 @嵌入式方法 = "">
    参数 虚拟键代码 <类型 = 字节 注释 = "bVk,欲模拟的虚拟键码 win键代码=91">
    参数 扫描码 <类型 = 字节 注释 = "bScan,键的OEM扫描码" @默认值 = 0>
    参数 标志 <类型 = 整数 注释 = "dwFlags,标志常数  KEYEVENTF_KEYUP=2  放开某键的标志" @默认值 = 2>
    参数 dwExtraInfo <类型 = 长整数 @默认值 = 0>
    {
        // VOID keybd_event(  BYTE bVk,               // virtual-key code
        // BYTE bScan,             // hardware scan code
        // DWORD dwFlags,          // function options
        // ULONG_PTR dwExtraInfo   // additional keystroke data
        //);
        @ keybd_event(@<虚拟键代码>,@<扫描码>,@<标志>,@<dwExtraInfo>)
    }

    方法 键盘_模拟按键 <公开 静态 注释 = "这个包括了 按下和放开两个操作" 折叠 "">
    参数 键代码 <类型 = 键代码_常量类 注释 = "bVk,欲模拟的虚拟键码 win键代码=91">
    参数 扫描码 <类型 = 字节 注释 = "bScan,键的OEM扫描码" @默认值 = 0>
    参数 延时 <类型 = 整数 注释 = "按下键和松开键之间的间隔时间" @默认值 = 20>
    {
        @ keybd_event (@<键代码>, @<扫描码>, 0, 0);
        @ Sleep(@<延时>);
        @ keybd_event (@<键代码>, @<扫描码>, 2, 0);

    }

    方法 键盘_模拟组合键 <公开 静态 折叠 "">
    参数 控制键 <类型 = 键代码_常量类 注释 = "比如说 ctrl啥的">
    参数 键代码 <类型 = 键代码_常量类 注释 = "比如说 s键">
    参数 延时 <类型 = 整数 注释 = "按下键和松开键之间的间隔时间" @默认值 = 20>
    {
        @ keybd_event (@<控制键>, 0, 0, 0);
        @ Sleep(@<延时>);
        @ keybd_event (@<键代码>, 0, 0, 0);
        @ Sleep(@<延时>);
        @ keybd_event (@<键代码>, 0, 2, 0);
        @ Sleep(@<延时>);
        @ keybd_event (@<控制键>, 0, 2, 0);

    }

    方法 键盘_模拟回车 <公开 静态 折叠 @嵌入式方法 = "">
    参数 延时 <类型 = 整数 注释 = "按下键和松开键之间的间隔时间" @默认值 = 20>
    {
        @ keybd_event(VK_RETURN, 0, 0, 0);
        @ Sleep(@<延时>);
        @ keybd_event(VK_RETURN, 0, 2, 0);
    }

    方法 mouse_event <公开 静态 折叠 @嵌入式方法 = "">
    参数 dwFlags <类型 = 整数 注释 = "motion and click options">
    参数 dx <类型 = 整数 注释 = " horizontal position or change">
    参数 dy <类型 = 整数 注释 = "horizontal position or change">
    参数 dwData <类型 = 整数 注释 = " wheel movement">
    参数 dwExtraInfo <类型 = 长整数 注释 = "application-defined information">
    {
        // VOID mouse_event(  DWORD dwFlags,         // motion and click options
        // DWORD dx,              // horizontal position or change
        // DWORD dy,              // vertical position or change
        // DWORD dwData,          // wheel movement
        // ULONG_PTR dwExtraInfo  // application-defined information);
        @ mouse_event(@<dwFlags>,@<dx>,@<dy>,@<dwData>,(ULONG_PTR)@<dwExtraInfo>)


    }

    方法 鼠标_模拟移动鼠标位置_mouse_event <公开 静态 注释 = "绝对坐标，相对于屏幕左上角" 折叠>
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    {
        mouse_event (位或 (MOUSEEVENTF_ABSOLUTE, MOUSEEVENTF_MOVE), 65535 / 取屏幕宽度f () * x, 65535 / 取屏幕高度f () * y, 0, 0)
    }

    方法 鼠标_模拟左键点击_mouse_event <公开 静态 注释 = "mouse_event 相对于光标的。。意思就是 当前鼠标光标再哪里，就点击哪里" 折叠>
    参数 延时 <类型 = 整数 @默认值 = 20>
    {
        mouse_event (MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0)
        延时 (延时)
        mouse_event (MOUSEEVENTF_LEFTUP, 0, 0, 0, 0)

    }

    方法 鼠标_模拟左键点击_屏幕坐标_mouse_event <公开 静态 折叠>
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    参数 延时 <类型 = 整数 @默认值 = 20>
    {
        鼠标_模拟移动鼠标位置_mouse_event (x, y)
        延时 (延时)
        鼠标_模拟左键点击_mouse_event ()

    }

    方法 鼠标_模拟右键点击_mouse_event <公开 静态 注释 = "mouse_event 相对于光标的。。坐标是" 折叠>
    参数 延时 <类型 = 整数 @默认值 = 20>
    {
        mouse_event (MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, 0)
        延时 (延时)
        mouse_event (MOUSEEVENTF_RIGHTUP, 0, 0, 0, 0)
    }

    方法 鼠标_模拟滚轮滚动_mouse_event <公开 静态 注释 = "注意，必须某个窗口先获得焦点，才能收到滚轮消息" 折叠>
    参数 滚动距离 <类型 = 整数>
    {
        mouse_event (MOUSEEVENTF_WHEEL, 0, 0, 滚动距离, 0)
    }

    方法 鼠标_置位置_屏幕位置 <公开 静态 折叠 @嵌入式方法 = "">
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    {
        @ SetCursorPos(@<x>,@<y>)
    }

    方法 "// 鼠标_取位置" <公开 静态 折叠 "">
    参数 "// x" <类型 = 整数 @返回值类型>
    参数 "// y" <类型 = 整数 @返回值类型>
    {
        // @ POINT pt;
        // @ GetCursorPos (&pt);
        // @ @<x>= pt.x;
        // @ @<y>= pt.y;
    }

    方法 鼠标_取位置窗口句柄 <公开 静态 类型 = 长整数 折叠>
    {
        变量 窗口句柄 <类型 = 长整数>
        @ POINT pt;
        @ GetCursorPos (&pt);
        @ @<窗口句柄> =(INT64) WindowFromPoint(pt);
        返回 (窗口句柄)
    }

    方法 鼠标_取位置子窗口句柄 <公开 静态 类型 = 长整数>
    {
        变量 窗口句柄 <类型 = 长整数>
        @ POINT pt;
        @ GetCursorPos (&pt);
        @ @<窗口句柄> =(INT64) WindowFromPoint(pt);
        @ if(@<窗口句柄> != 0)  @<窗口句柄> = (@dt<变整数>)ChildWindowFromPoint((HWND)@<窗口句柄>,pt);
        返回 (窗口句柄)

    }

    方法 鼠标_取当前屏幕坐标 <公开 静态 注释 = "取当前 鼠标光标再屏幕中的坐标" @嵌入式方法 = "">
    参数 输出_横坐标 <类型 = 整数>
    参数 输出_纵坐标 <类型 = 整数>
    {
        @  @dt<______键盘鼠标模拟类>::Mouse_GetCursorPos_FC(&@<输出_横坐标>,&@<输出_纵坐标>)
    }

    方法 鼠标_是否左键被按下 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ (GetAsyncKeyState(VK_LBUTTON)&0x8000?TRUE:FALSE)
    }

    #
}
