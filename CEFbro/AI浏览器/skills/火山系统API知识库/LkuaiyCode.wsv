    {
        缓存对象锁定时长 = dwFreeSocketObjLockTime

    }

    方法 设置缓存池大小 <公开 注释 = "设置 Socket 缓存池大小（通常设置为平均并发连接数量的 1/3 - 1/2）" 折叠>
    参数 服务句柄 <类型 = 变整数 注释 = "服务句柄">
    参数 dwFreeSocketObjPool <类型 = 整数>
