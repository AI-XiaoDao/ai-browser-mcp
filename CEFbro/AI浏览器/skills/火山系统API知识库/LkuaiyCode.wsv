        @视窗.附属文件.x64 = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\x64\\bin\\libcrypto-1_1-x64.dll"
        @视窗.外部库 = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\$(p)\\lib\\libcrypto.lib"
        @视窗.外部头文件 = "openssl\\evp.h\r\nopenssl\\aes.h\r\nopenssl\\des.h\r\nopenssl\\rsa.h\r\nopenssl\\pem.h\r\nopenssl\\hmac.h">
