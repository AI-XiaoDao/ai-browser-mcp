    方法 设置最大连接数 <公开 注释 = "设置最大连接数（组件会根据设置值预分配内存，因此需要根据实际情况设置，不宜过大）" 折叠>
    参数 服务句柄 <类型 = 变整数 注释 = "服务句柄">
    参数 dwMaxConnectionCount <类型 = 整数 注释 = "最大连接数">
    {
        最大连接数 = dwMaxConnectionCount
    }

    方法 设置工作线程数量 <公开 注释 = "设置工作线程数量（通常设置为 2 * CPU + 2）" 折叠>
    参数 服务句柄 <类型 = 变整数 注释 = "服务句柄">
    参数 dwWorkerThreadCount <类型 = 整数 注释 = "工作线程数量">
