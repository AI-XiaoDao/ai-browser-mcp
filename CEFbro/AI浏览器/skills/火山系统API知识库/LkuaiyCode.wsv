    方法 设置异常心跳包间隔 <公开 注释 = "设置异常心跳包间隔（毫秒，0 不发送心跳包，，默认：20 * 1000，如果超过若干次 [默认：WinXP 5 次, Win7 10 次] 检测不到心跳确认包则认为已断线" 折叠>
    参数 hServer <类型 = 变整数>
    参数 dwKeepAliveTime <类型 = 整数>
    {
        异常心跳发送间隔 = dwKeepAliveTime
    }

    方法 获取Accept预投递数量 <公开 类型 = 整数 注释 = "获取 Accept 预投递数量" 折叠 @禁止流程检查 = 真>
    参数 hServer <类型 = 变整数>
    {
        返回 (预投递数量)
    }

    方法 获取通信数据缓冲区大小 <公开 类型 = 整数 注释 = "获取通信数据缓冲区大小" 折叠 @禁止流程检查 = 真>
    参数 hServer <类型 = 变整数>
    {
        返回 (通信缓冲区尺寸)
    }

    方法 获取监听Socket的等候队列大小 <公开 类型 = 整数 注释 = "获取监听 Socket 的等候队列大小" 折叠 @禁止流程检查 = 真>
    参数 hServer <类型 = 变整数>
    {
        返回 (等候队列尺寸)
    }

    方法 获取正常心跳包间隔 <公开 类型 = 整数 注释 = "获取正常心跳包间隔" 折叠 @禁止流程检查 = 真>
    参数 hServer <类型 = 变整数>
    {
        返回 (正常心跳发送间隔)
    }

    方法 获取异常心跳包间隔 <公开 类型 = 整数 注释 = "获取异常心跳包间隔" 折叠 @禁止流程检查 = 真>
    参数 hServer <类型 = 变整数>
    {
        返回 (异常心跳发送间隔)

    }

    #
    #
    # //====
    # @ @m<DECLARE_HPSOCKET_SERVER_REF> (ITcpPullServer, TcpPullServer, ITcpServerListener)

    方法 启动 <公开 类型 = 逻辑型 注释 = "启动服务器并且监听指定端口号." 返回值注释 = "返回是否操作成功." 折叠 @嵌入式方法 = "">
    参数 地址 <类型 = 文本型 注释 = "提供所欲监听的地址.">
    参数 端口号 <类型 = 短整数 注释 = "提供所欲监听的端口号.">
    {
        @ @sn<this>.GetTcpPullServer()->Start(@<地址>, @<端口号>)
    }

    方法 开始握手 <公开 定义事件 类型 = 整数 注释 = "  当客户端通过事件\"客户进入\"后,将会立即触发本事件,只有通过本事件,才会进行握手动作." 返回值注释 = "可选返回值:"
            返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手." 返回值注释 = "  1 = 忽略本次操作, 客户端可与服务器建立正式连接." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接."
            折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>

    方法 发送完毕 <公开 定义事件 类型 = 整数 注释 = "当服务器发送数据成功后,将触发本事件." 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "接收本次发送所对应的连接ID.">
    参数 数据 <类型 = 字节集类 注释 = "本次所发送的数据.">
    参数 数据大小 <类型 = 整数 注释 = "所发送数据的长度.">

    方法 数据进入 <公开 定义事件 类型 = 整数 注释 = "当服务器成功接收数据后将触发本事件,此时可以进行抓取数据/窥探数据." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 继续执行."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接并触发关闭事件." 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "接收到的数据由该连接ID发过来.">
    参数 数据大小 <类型 = 整数 注释 = "本次接收的数据长度.">

    方法 客户离开 <公开 定义事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件." 折叠>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = 整数 注释 = "0未知操作，1接受请求，2连接请求，3发送请求，4接收请求，5主动断开">
    参数 错误码 <类型 = 整数 注释 = "0成功，1未启动，2参数错误，3创建失败，4绑定失败，5设置失败，6监听失败，7端口错误，8创建线程失败"
            注释 = "9监测线程失败，10绑定端口失败，11连接失败，12网络错误，13数据处理错误，14数据发送失败，101SSL环境错误">

    方法 服务器被关闭 <公开 定义事件 类型 = 整数 注释 = "当服务器被关闭后,将会触发本事件." 折叠>
    参数 服务句柄 <类型 = 变整数>

    方法 启动完毕 <公开 定义事件 类型 = 整数 注释 = "服务器端启动完毕并开始监听后,将触发本事件." 折叠>
    参数 服务句柄 <类型 = 变整数>

    方法 客户进入 <公开 定义事件 类型 = 整数 注释 = "  当客户连接到服务器后,将会触发本事件,请注意,本事件下的连接并非是正式连接,"
            注释 = "只有该连接通过\"完成握手\"事件,才可以与服务器建立正式连接,本事件返回值拥有具体意义,请参考返回值说明." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 将触发\"完成握手\"事件."
            返回值注释 = "  1 = 忽略本次操作, 将触发\"完成握手\"事件." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接." 折叠 折叠2>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>

    方法 类_初始化 <折叠>
    {
        @ CreateSocket();
    }

    # 事件实现 ---
    #
    # @begin
    # <> <include>
    # virtual EnHandleResult OnHandShake(ITcpServer* pSender, CONNID dwConnID) override { return (EnHandleResult)@<开始握手>((@dt<变整数>)pSender,dwConnID); }
    # virtual EnHandleResult OnSend(ITcpServer* pSender, CONNID dwConnID, const BYTE* pData, int iLength) override { return (EnHandleResult)@<发送完毕>((@dt<变整数>)pSender,dwConnID, @an<CVolMem> (pData, iLength), iLength); }
    # virtual EnHandleResult OnReceive(ITcpServer* pSender, CONNID dwConnID, const BYTE* pData, int iLength) override { return HR_IGNORE; }  //忽略,仅在PUSH/PACK模型下触发.
    # virtual EnHandleResult OnReceive(ITcpServer* pSender, CONNID dwConnID, int iLength) override { return (EnHandleResult)@<数据进入>((@dt<变整数>)pSender,dwConnID, iLength); }
    # virtual EnHandleResult OnClose(ITcpServer* pSender, CONNID dwConnID, EnSocketOperation enOperation, int iErrorCode) override { return (EnHandleResult)@<客户离开>((@dt<变整数>)pSender,dwConnID, (INT)enOperation, (INT)iErrorCode); } 
    # virtual EnHandleResult OnShutdown(ITcpServer* pSender) override { return (EnHandleResult)@<服务器被关闭>((@dt<变整数>)pSender); } 
    # virtual EnHandleResult OnPrepareListen(ITcpServer* pSender, SOCKET soListen) override { return (EnHandleResult)@<启动完毕>((@dt<变整数>)pSender);@<服务器句柄>=(@dt<变整数>)pSender; }
    # virtual EnHandleResult OnAccept(ITcpServer* pSender, CONNID dwConnID, UINT_PTR soClient) override { return (EnHandleResult)@<客户进入>((@dt<变整数>)pSender,dwConnID); }
    # <> </include>
    # @end
}

类 基类网络_HP_PULL安全服务器 <基础类 = HPPULL服务器基础类 折叠 @视窗.后缀文本 = "public ITcpServerListener">
{
    变量 服务器句柄 <类型 = 变整数>

    # //====

    方法 抓取数据_ <公开 类型 = 字节集类 注释 = "抓取指定连接所发送的数据." 返回值注释 = "返回本次数据抓取结果." 折叠 @禁止流程检查 = 真>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "提供所欲抓取其数据的连接ID.">
    参数 数据长度 <类型 = 整数 注释 = "提供所欲抓取数据的长度." "">
    {
        变量 缓冲区 <类型 = 字节集类 注释 = "提供所欲装载该数据的缓冲区." 注释 = "注意:如所提供缓冲区未分配空间程序将自动按数据长度参数分配指定空间." 折叠2>
        抓取数据 (连接ID, 缓冲区, 数据长度)
        返回 (缓冲区)

    }

    方法 窥探数据_ <公开 类型 = 字节集类 注释 = "窥探指定连接所发送的数据(不会移除缓冲区数据)." 返回值注释 = "返回本次数据窥探结果." 折叠 @禁止流程检查 = 真>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数 注释 = "提供所欲窥探其数据的连接ID.">
    参数 数据长度 <类型 = 整数 注释 = "提供所欲窥探数据的长度.">
    {
        变量 缓冲区 <类型 = 字节集类 注释 = "提供所欲装载该数据的缓冲区." 注释 = "注意:如所提供缓冲区未分配空间程序将自动按数据长度参数分配指定空间." 折叠2>
        窥探数据 (连接ID, 缓冲区, 数据长度)
        返回 (缓冲区)

    }

    方法 发送字节集 <公开 类型 = 逻辑型 注释 = "向指定客户连接ID发送数据." 返回值注释 = "发送成功返回真,失败返回假." 折叠 @禁止流程检查 = 真>
    参数 服务句柄 <类型 = 变整数 注释 = "所欲接收数据的客户连接ID.">
    参数 连接ID <类型 = 变整数 注释 = "所欲接收数据的客户连接ID.">
    参数 数据 <类型 = 字节集类 注释 = "所欲发送数据,本参数不可为空,否则将会发送失败.">
    {
        返回 (发送数据 (连接ID, 数据))
    }

    方法 属性_服务器句柄 <公开 属性读 类型 = 变整数 折叠>
    {
        返回 (服务器句柄)

    }

    方法 启动服务 <公开 类型 = 逻辑型
            注释 = "名称：启动通信组件 描述：启动服务端通信组件，启动完成后可开始接收客户端连接并收发数据,TRUE-- 成功,FALSE-- 失败，可通过 HP_Server_GetLastError() 获取错误代码" 折叠>
    参数 服务句柄_ <类型 = 变整数>
    参数 服务地址 <类型 = 文本型 注释 = "默认0.0.0.0" @默认值 = "0.0.0.0">
    参数 服务端口 <类型 = 短整数 注释 = "默认9550" @默认值 = 9550>
    {
        返回 (启动 (服务地址, 服务端口))
    }

    方法 关闭服务 <公开 类型 = 逻辑型
            注释 = "名称：关闭通信组件 描述：关闭服务端通信组件，关闭完成后断开所有客户端连接并释放所有资源,TRUE-- 成功,FALSE-- 失败，可通过 HP_Server_GetLastError() 获取错误代码" 折叠>
    参数 服务句柄_ <类型 = 变整数>
    {
        返回 (关闭服务器 (服务句柄_))

    }

    方法 关闭服务器 <类型 = 逻辑型
            注释 = "名称：关闭通信组件 描述：关闭服务端通信组件，关闭完成后断开所有客户端连接并释放所有资源,TRUE-- 成功,FALSE-- 失败，可通过 HP_Server_GetLastError() 获取错误代码" 折叠
            @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
