    }

    方法 主动断开连接 <公开 类型 = 逻辑型 注释 = "主动断开连接,TRUE-- 成功,FALSE-- 失败,/" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    参数 连接ID <类型 = 变整数 注释 = "连接ID" "">
    参数 bForce <类型 = 逻辑型 注释 = "是否强制断开连接" @默认值 = 真>
    {
        返回 (断开连接 (连接ID, bForce))

    }

    方法 断开超时连接_ <公开 类型 = 逻辑型 注释 = "设置断开超时连接,TRUE-- 成功,FALSE-- 失败,/" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    参数 dwPeriod <类型 = 整数 注释 = "连接时长" "">
    参数 bForce <类型 = 逻辑型 注释 = "是否强制断开连接" "">
    {
        返回 (断开超时连接 (dwPeriod, bForce))

    }

    方法 断开静默连接_ <公开 类型 = 逻辑型 注释 = "名称：断开静默连接 描述：断开超过指定时长的静默连接,TRUE-- 成功,FALSE-- 失败,/" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    参数 dwPeriod <类型 = 整数 注释 = "时长（毫秒）" "">
    参数 bForce <类型 = 逻辑型 注释 = "是否强制断开连接" @默认值 = 真>
    {
        返回 (断开静默连接 (dwPeriod, bForce))
    }

    方法 服务是否已启动 <公开 类型 = 逻辑型 注释 = "检查通信组件是否已启动" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    {
        返回 (是否已启动)
    }

    方法 最后一次失败描述 <公开 类型 = 文本型 注释 = "获取最近一次失败操作的错误描述" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    {
        返回 (当前错误描述)
    }

    方法 最后一次失败代码 <公开 类型 = 整数 注释 = "获取最近一次失败操作的错误代码" 返回值注释 = "0成功，1未启动，2参数错误，3创建失败，4绑定失败，5设置失败，6监听失败，7端口错误，8创建线程失败"
            返回值注释 = "9监测线程失败，10绑定端口失败，11连接失败，12网络错误，13数据处理错误，14数据发送失败，101SSL环境错误" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    {
        返回 ((整数)当前错误码)
    }

    方法 获取客户端连接数 <公开 类型 = 整数 注释 = "获取客户端连接数" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄">
    {
        返回 (客户端连接数)
    }

    方法 检测是否有效连接 <公开 类型 = 逻辑型 注释 = "检测是否有效连接" 折叠 @禁止流程检查 = 真>
    参数 pServer <类型 = 变整数 注释 = "服务句柄" "">
    参数 dwConnID <类型 = 变整数>
    {
        返回 (取连接状态 (dwConnID))

    }

    方法 设置缓存对象锁定时间 <公开 注释 = "设置 Socket 缓存对象锁定时间（毫秒，在锁定期间该 Socket 缓存对象不能被获取使用）" 折叠>
    参数 服务句柄 <类型 = 变整数 注释 = "服务句柄">
