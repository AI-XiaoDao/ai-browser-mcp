类 官方库基类_网络传输类 <公开 注释 = "编译库信息:libcurl/7.74.0 OpenSSL/1.1.1h zlib/1.2.11 libssh2/1.9.0" 注释 = "官方网站:https://curl.se/"
        @视窗.头文件搜寻目录 = "..\\curl\\lib\\include\\" @视窗.外部头文件 = "vol_curl.h"
        @视窗.附属文件.non_static = "..\\curl\\lib\\$(p)\\libcurl.dll\r\n..\\curl\\lib\\$(p)\\zlib1.dll"
        @视窗.外部库.non_static = "..\\curl\\lib\\$(p)\\libcurl.lib"
        @视窗.外部库.static = "..\\curl\\lib\\$(p)\\static\\libcurl-$(d).lib\r\nCrypt32.lib\r\nWldap32.lib"
        @视窗.外部库.static = "..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\zlib-$(d).lib" @视窗.需求VS版本.static = "16-"
        @视窗.后缀文本 = "public IVolNoticeReceiver" "">

