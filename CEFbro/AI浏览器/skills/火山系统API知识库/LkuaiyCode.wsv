        工作线程数 = dwWorkerThreadCount
    }

    方法 设置是否标记静默时间 <公开 注释 = "设置是否标记静默时间（设置为 TRUE 时 DisconnectSilenceConnections() 和 GetSilencePeriod() 才有效，默认：TRUE）" 折叠>
    参数 服务句柄 <类型 = 变整数 注释 = "服务句柄">
    参数 bMarkSilence <类型 = 逻辑型>
