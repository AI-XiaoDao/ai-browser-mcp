类 Code_FOF_用户数组 <公开 基础类 = 对象数组模板类 注释 = "最基本的对象类数组" @模板实现类 = "FOFHTTP_用户数据">

类 Code_FOF_用户管理模式 <折叠>
{
    变量 用户数据对象 <类型 = Code_FOF_用户数组>

    方法 类_初始化

    方法 删除成员 <公开 折叠>
    参数 连接ID <类型 = 变整数>
    {
        变量 成员数 <类型 = 整数>
        成员数 = 用户数据对象.取成员数 ()
        变量 循环变量 <类型 = 整数>
        变量 成员位置 <类型 = 整数 值 = -1>
        循环 (0, 成员数, 循环变量, )
        {
            变量 临时成员 <类型 = FOFHTTP_用户数据>
            临时成员 = 用户数据对象.取成员 (循环变量)
            如果 (临时成员.HTTP_用户ID == 连接ID)
            {
                成员位置 = 循环变量
                跳出循环

            }

        }

        如果 (成员位置 != -1)
        {
            用户数据对象.删除成员 (成员位置)

        }

    }

    方法 获取成员位置 <公开 类型 = 整数 返回值注释 = "失败返回-1，否则返回成员位置" 折叠>
    参数 连接ID <类型 = 变整数>
    {
        变量 成员数 <类型 = 整数>
        成员数 = 用户数据对象.取成员数 ()
        变量 循环变量 <类型 = 整数>
        变量 成员位置 <类型 = 整数 值 = -1>
        循环 (0, 成员数, 循环变量, )
        {
            变量 临时成员 <类型 = FOFHTTP_用户数据>
            临时成员 = 用户数据对象.取成员 (循环变量)
            如果 (临时成员.HTTP_用户ID == 连接ID)
            {
                成员位置 = 循环变量
                跳出循环

            }

        }

        返回 (成员位置)

    }

    方法 添加用户对象 <公开 注释 = "如果用户存在则进行更新" 折叠>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 成员位置 <类型 = 整数>
    {
        如果 (成员位置 != -1)
        {
            更新用户对象 (用户数据, 成员位置)
        }
        否则
        {
            用户数据对象.加入成员 (用户数据)

        }

    }

    方法 更新用户对象 <折叠>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 成员位置 <类型 = 整数>
    {
        如果 (成员位置 > 用户数据对象.取成员数 () - 1)
        {
            返回
        }
        如果 (成员位置 == -1)
        {
            调试输出 (">------更新用户成员数位置错误")
            返回

        }

        用户数据对象.置成员值 (成员位置, 用户数据)
    }

    方法 获取用户对象 <公开 类型 = FOFHTTP_用户数据 折叠>
    参数 成员位置 <类型 = 整数>
    {
        如果 (成员位置 == -1)
        {
            调试输出 (">------获取用户成员数位置错误")
            变量 空数据 <类型 = FOFHTTP_用户数据>
            返回 (空数据)

        }
        如果 (成员位置 > 用户数据对象.取成员数 () - 1)
        {
            变量 空数据 <类型 = FOFHTTP_用户数据>
            返回 (空数据)

        }

        返回 (用户数据对象.取成员 (成员位置))
    }
}

