类 类_微信公众号 <公开 折叠>
{
    变量 appID <类型 = 文本型>
    变量 appsecret <类型 = 文本型>
    变量 ACCESSTOKEN <类型 = 文本型>
    变量 地理位置纬度 <类型 = 文本型 注释 = "只在关注时有用">
    变量 地理位置经度 <类型 = 文本型 注释 = "只在关注时有用">
    变量 地理位置精度 <类型 = 文本型 注释 = "只在关注时有用">
    变量 扫码登录临时缓存表 <类型 = JSONCPP对象类>
    变量 微信支付临时缓存表 <类型 = JSONCPP对象类>
    变量 微信支付订单信息表 <类型 = JSONCPP对象类>
    变量 ACCESS_TOKEN时间戳 <类型 = 长整数>
    变量 jsapi_ticket时间戳 <类型 = 长整数>
    变量 jsapi_ticket文本 <类型 = 文本型>

    方法 初始化公众号 <公开 类型 = 逻辑型 折叠>
    参数 appID_ <类型 = 文本型>
    参数 appsecret_ <类型 = 文本型>
    {
        appID = appID_
        appsecret = appsecret_
        变量 返回信息 <类型 = 文本型>
        如果 (ACCESS_TOKEN获取 (appID, appsecret, 返回信息) == 假)
        {
            调试输出 (返回信息)
            返回 (假)
        }
        否则
        {
            ACCESSTOKEN = 返回信息

        }
        返回 (真)

    }

    方法 ACCESS_TOKEN获取 <类型 = 逻辑型 折叠>
    参数 appid_ <类型 = 文本型>
    参数 secret_ <类型 = 文本型>
    参数 返回的ACCESS_TOKEN <类型 = 文本型>
    {
        变量 access_token <类型 = JSONCPP对象类>
        变量 返回指针 <类型 = 变整数>
        返回指针 = 类_微信公众号基类.ACCESS_TOKEN获取 (appid_, secret_)
        变量 字节集 <类型 = 字节集类>
        access_token.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类)))
        字节集 = 读指针处对象 (返回指针, 字节集类)
        销毁对象指针 (返回指针)
        变量 ACCESS_TOKEN文本 <类型 = 文本型>
        如果 (access_token.成员是否存在 ("access_token") == 假)
        {
            ACCESS_TOKEN文本 = UTF8到文本 (字节集)
            返回的ACCESS_TOKEN = ACCESS_TOKEN文本
            返回 (假)
        }
        ACCESS_TOKEN文本 = access_token.取文本值 ("access_token")
        返回的ACCESS_TOKEN = ACCESS_TOKEN文本
        变量 时间 <类型 = 类_时间辅助函数>
        ACCESS_TOKEN时间戳 = 时间.时间_取现行时间戳10位_长整数 ()
        返回 (真)
    }

    方法 jsapi_ticket获取 <类型 = 文本型 折叠>
    {
        变量 时间 <类型 = 类_时间辅助函数>
        如果 (jsapi_ticket时间戳 <= 时间.时间_取现行时间戳10位_长整数 () - (长整数)(60 * 8))
        {
            jsapi_ticket时间戳 = 时间.时间_取现行时间戳10位_长整数 ()
            变量 返回的JSON <类型 = JSONCPP对象类>
            如果 (返回的JSON.创建自文本 (UTF8到文本 (网页_访问lky ("https://api.weixin.qq.com/cgi-bin/ticket/getticket?access_token=" + ACCESSTOKEN + "&type=jsapi", , , , , , , , , , ))) == 真)
            {
                如果 (返回的JSON.取文本值 ("errmsg") == "ok")
                {
                    jsapi_ticket文本 = 返回的JSON.取文本值 ("ticket")

                }

            }
        }
        返回 (jsapi_ticket文本)
    }

    方法 获取微信登录链接 <公开 类型 = 文本型 折叠>
    参数 回调域名 <类型 = 文本型 注释 = "例如:https://www.xxx.com">
    参数 回调标识 <类型 = 长整数 注释 = "当登录成功时，回调的信息会收到此标识">
    {
        变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
        返回 ("https://open.weixin.qq.com/connect/oauth2/authorize?appid=" + appID + "&redirect_uri=" + UTF8到文本 (HTTP辅助.URL编码 (文本到UTF8 (回调域名, 假))) + "&response_type=code&scope=snsapi_userinfo&state=FOFZF" + 到文本 (回调标识) + "#wechat_redirect")
    }

    方法 微信Token验证_GET <公开 类型 = 逻辑型 折叠>
    参数 来源对象 <类型 = FOFHTTP 注释 = "提供事件产生的具体来源对象">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, "signature=", , 假) != -1 && 寻找文本 (用户数据.HTTP_待发整理.请求Url, "&echostr=", , 假) != -1)
        {
            变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
            用户数据.HTTP_待发整理.文件后缀 = "html"
            来源对象.发送页面数据 (服务句柄, 连接ID, 文本到UTF8 (HTTP辅助.取参数 ("echostr", 用户数据.HTTP_待发整理.解析参数, ), 假), 用户数据)
            返回 (真)

        }

        返回 (假)
    }

    方法 微信Token验证_GET_HTTPS <公开 类型 = 逻辑型 折叠>
    参数 来源对象 <类型 = FOFHTTPS 注释 = "提供事件产生的具体来源对象">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    {
        如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, "signature=", , 假) != -1 && 寻找文本 (用户数据.HTTP_待发整理.请求Url, "&echostr=", , 假) != -1)
        {
            变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
            用户数据.HTTP_待发整理.文件后缀 = "html"
            来源对象.发送页面数据 (服务句柄, 连接ID, 文本到UTF8 (HTTP辅助.取参数 ("echostr", 用户数据.HTTP_待发整理.解析参数, ), 假), 用户数据)
            返回 (真)

        }

        返回 (假)
    }

    方法 微信登录_是否成功 <公开 类型 = 逻辑型 折叠>
    参数 回调标识 <类型 = 文本型>
    参数 返回微信登录信息 <类型 = JSONCPP对象类>
    {
        如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回的回调标识") == 真)
        {
            返回微信登录信息.置入文本值 ("返回的回调标识", 扫码登录临时缓存表.取文本值 (回调标识 + "返回的回调标识"))
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户头像") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户头像", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户头像"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户头像")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户昵称") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户昵称", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户昵称"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户昵称")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户国家") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户国家", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户国家"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户国家")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户城市") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户城市", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户城市"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户城市")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户性别") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户性别", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户性别"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户性别")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户省份") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户省份", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户省份"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户省份")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "返回用户唯一ID") == 真)
            {
                返回微信登录信息.置入文本值 ("返回用户唯一ID", 扫码登录临时缓存表.取文本值 (回调标识 + "返回用户唯一ID"))
                扫码登录临时缓存表.删除成员 (回调标识 + "返回用户唯一ID")
            }
            如果 (扫码登录临时缓存表.成员是否存在 (回调标识 + "登录信息描述") == 真)
            {
                返回微信登录信息.置入文本值 ("登录信息描述", 扫码登录临时缓存表.取文本值 (回调标识 + "登录信息描述"))
                扫码登录临时缓存表.删除成员 (回调标识 + "登录信息描述")

            }
            扫码登录临时缓存表.删除成员 (回调标识 + "返回的回调标识")
            返回 (真)
        }
        否则
        {
            返回 (假)

        }

    }

    方法 通用微信成功返回页面 <公开 类型 = 字节集类 折叠>
    参数 页面名称 <类型 = 文本型 @默认值 = "扫码登录成功">
    参数 状态名称 <类型 = 文本型 @默认值 = "登录成功">
    参数 页面描述 <类型 = 文本型 @默认值 = "恭喜您，本次扫码登录成功！">
    参数 是否显示按钮 <类型 = 逻辑型 @默认值 = 真>
    参数 按钮标题 <类型 = 文本型 @默认值 = "返回主页">
    参数 按钮跳转地址 <类型 = 文本型 @默认值 = "#">
    {
        变量 微信页面代码 <类型 = 文本型
                值 = "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>${title}</title>\r\n</head>\r\n\r\n<body>\r\n    <div class=\"login-success\">\r\n        <div class=\"wx\">\r\n            <svg t=\"1662184926426\" class=\"icon\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\"\r\n                p-id=\"2630\" width=\"100\" height=\"100\">\r\n                <path\r\n                    d=\"M693.12 347.264c11.776 0 23.36 0.896 35.008 2.176-31.36-146.048-187.456-254.528-365.696-254.528C163.2 94.912 0 230.656 0 403.136c0 99.52 54.272 181.248 145.024 244.736L108.8 756.864l126.72-63.488c45.312 8.896 81.664 18.112 126.912 18.112 11.392 0 22.656-0.512 33.792-1.344-7.04-24.256-11.2-49.6-11.2-76.032C385.088 475.776 521.024 347.264 693.12 347.264zM498.304 249.024c27.392 0 45.376 17.984 45.376 45.248 0 27.136-17.984 45.312-45.376 45.312-27.072 0-54.336-18.176-54.336-45.312C443.968 266.944 471.168 249.024 498.304 249.024zM244.672 339.584c-27.2 0-54.592-18.176-54.592-45.312 0-27.264 27.392-45.248 54.592-45.248S289.92 266.944 289.92 294.272C289.92 321.408 271.872 339.584 244.672 339.584zM1024 629.76c0-144.896-145.024-262.976-307.904-262.976-172.48 0-308.224 118.144-308.224 262.976 0 145.28 135.808 262.976 308.224 262.976 36.096 0 72.512-9.024 108.736-18.112l99.392 54.528-27.264-90.624C969.728 783.872 1024 711.488 1024 629.76zM616.128 584.384c-17.984 0-36.224-17.92-36.224-36.224 0-18.048 18.24-36.224 36.224-36.224 27.52 0 45.376 18.176 45.376 36.224C661.504 566.464 643.648 584.384 616.128 584.384zM815.488 584.384c-17.856 0-36.032-17.92-36.032-36.224 0-18.048 18.112-36.224 36.032-36.224 27.264 0 45.376 18.176 45.376 36.224C860.864 566.464 842.752 584.384 815.488 584.384z\"\r\n                    p-id=\"2631\" fill=\"#15d36a\"></path>\r\n            </svg>\r\n        </div>\r\n        <h2>${TypeName}</h2>\r\n        <div class=\"text\">\r\n            <p>${Text}</p>\r\n        </div>\r\n        ${butIf1}\r\n        <a href=\"${href}\"><button class=\"btn\">${NameA}</button></a>\r\n        ${butIf2}\r\n    </div>\r\n    <style>\r\n        body{\r\n            min-height: 100vh;\r\n            margin: 0;\r\n            padding: 0;\r\n        }\r\n        .login-success {\r\n            padding-top: 120px;\r\n            text-align: center;\r\n        }\r\n\r\n        .login-success .wx svg {\r\n            max-width: 100px;\r\n        }\r\n\r\n        .login-success h2 {\r\n            color: #15d36a;\r\n            font-weight: normal;\r\n            margin: 0;\r\n        }\r\n\r\n        .login-success .text {\r\n            color: #999;\r\n            font-size: 14px;\r\n        }\r\n\r\n        .login-success .btn {\r\n            margin-top: 40px;\r\n            width: 75vw;\r\n            height: 38px;\r\n            line-height: 38px;\r\n            padding: 0 35px;\r\n            background-color: #15d36a;\r\n            font-size: 16px;\r\n            color: #fff;\r\n            background: linear-gradient(45deg, #15d36a 0%, #276a45 100%);\r\n            border-radius: 50px;\r\n            outline: none;\r\n            border: none;\r\n        }\r\n    </style>\r\n</body>\r\n\r\n</html>">
        变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 最终字节集 <类型 = 字节集类>
        最终字节集 = 文本到UTF8 (微信页面代码, 假)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "title", 页面名称)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "TypeName", 状态名称)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "Text", 页面描述)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "href", 按钮跳转地址)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "NameA", 按钮标题)
        如果 (是否显示按钮 == 真)
        {
            最终字节集 = HTTP辅助.解析标签 (最终字节集, "butIf1", "")
            最终字节集 = HTTP辅助.解析标签 (最终字节集, "butIf2", "")
        }
        否则
        {
            最终字节集 = HTTP辅助.解析标签 (最终字节集, "butIf1", "<!--")
            最终字节集 = HTTP辅助.解析标签 (最终字节集, "butIf2", "-->")

        }
        返回 (最终字节集)
    }

    方法 微信登录_GET <公开 类型 = 逻辑型 返回值注释 = "返回真登陆成功，返回假登陆失败" 折叠>
    参数 解析参数 <类型 = 文本型>
    参数 返回错误结果 <类型 = 文本型 注释 = "如果错误，则这里返回错误结果" @默认值 = "">
    参数 返回用户头像 <类型 = 文本型 注释 = "非错误情况下有效"
            注释 = "用户头像，最后一个数值代表正方形头像大小（有0、46、64、96、132数值可选，0代表640*640正方形头像），用户没有头像时该项为空。若用户更换头像，原有头像 URL 将失效。" @默认值 = "">
    参数 返回用户昵称 <类型 = 文本型 @默认值 = "">
    参数 返回用户性别 <类型 = 文本型 注释 = "用户的性别，值为1时是男性，值为2时是女性，值为0时是未知" @默认值 = "">
    参数 返回用户国家 <类型 = 文本型 @默认值 = "">
    参数 返回用户省份 <类型 = 文本型 @默认值 = "">
    参数 返回用户城市 <类型 = 文本型 @默认值 = "">
    参数 返回用户唯一ID <类型 = 文本型 @默认值 = "">
    参数 返回的回调标识 <类型 = 文本型 @默认值 = "">
    {
        变量 access_token <类型 = JSONCPP对象类>
        变量 http辅助 <类型 = FOFHTTP_HTTP辅助>
        如果 (http辅助.取参数 ("code", 解析参数, ) != "" && 寻找文本 (http辅助.取参数 ("state", 解析参数, ), "FOFZF", , ) != -1 && 寻找文本 (解析参数, "&state=FOFZF", , ) != -1)
        {
            如果 (扫码登录临时缓存表.成员数 >= 9000)
            {
                扫码登录临时缓存表.清空 ()
                扫码登录临时缓存表.创建自文本 ("{}")

            }
            返回的回调标识 = http辅助.取参数 ("state", 解析参数, )
            子文本替换 (返回的回调标识, "FOFZF", "", , , )
            变量 返回指针 <类型 = 变整数>
            返回指针 = 类_微信公众号基类.微信登陆_GET1 (appID, appsecret, http辅助.取参数 ("code", 解析参数, ))
            变量 返回字节集 <类型 = 字节集类>
            返回字节集 = 读指针处对象 (返回指针, 字节集类)
            如果 (access_token.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)
            如果 (access_token.成员是否存在 ("access_token") == 假)
            {
                返回错误结果 = UTF8到文本 (返回字节集)
                返回 (假)

            }

            变量 最终JSON <类型 = JSONCPP对象类>
            返回指针 = 类_微信公众号基类.微信登陆_GET2 (access_token.取文本值 ("access_token"), access_token.取文本值 ("openid"))
            如果 (最终JSON.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)
            返回用户头像 = 最终JSON.取文本值 ("headimgurl")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户头像", 返回用户头像)
            返回用户昵称 = 最终JSON.取文本值 ("nickname")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户昵称", 返回用户昵称)
            返回用户国家 = 最终JSON.取文本值 ("country")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户国家", 返回用户国家)
            返回用户城市 = 最终JSON.取文本值 ("city")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户城市", 返回用户城市)
            返回用户性别 = 到文本 (最终JSON.取整数值 ("sex"))
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户性别", 返回用户性别)
            返回用户省份 = 最终JSON.取文本值 ("province")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户省份", 返回用户省份)
            返回用户唯一ID = 最终JSON.取文本值 ("openid")
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回用户唯一ID", 返回用户唯一ID)
            变量 登录信息描述 <类型 = 文本型
                    值 = "用户头像：最后一个数值代表正方形头像大小（有0、46、64、96、132数值可选，0代表640*640正方形头像），用户没有头像时该项为空。若用户更换头像，原有头像 URL 将失效。\r\n用户的性别：值为1时是男性，值为2时是女性，值为0时是未知">
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "登录信息描述", 登录信息描述)
            扫码登录临时缓存表.置入文本值 (返回的回调标识 + "返回的回调标识", 返回的回调标识)

            返回 (真)
        }
        返回错误结果 = "请求登录失败"
        返回 (假)

    }

    方法 微信公众号初始化JS代码 <公开 类型 = 文本型 折叠>
    参数 APPID_ <类型 = 文本型>
    参数 回调标识 <类型 = 文本型>
    参数 当前页面URL <类型 = 文本型 注释 = "例如：https://xxx.xxx.com">
    参数 JS接口列表 <类型 = JSONCPP数组类>
    参数 是否开启调试模式 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 时间 <类型 = 类_时间辅助函数>
        变量 时间戳 <类型 = 文本型>
        变量 替换文本 <类型 = 文本型
                值 = "wx.config({\r\n  debug: 调试模式,\r\n  appId: \'appId替换\',\r\n  timestamp: timestamp替换,\r\n  nonceStr: \'nonceStr替换\',\r\n  signature: \'signature替换\',\r\n  jsApiList: JS接口列表替换\r\n});">
        时间戳 = 到文本 (时间.时间_取现行时间戳10位_长整数 ())
        子文本替换 (替换文本, "appId替换", APPID_, , , )
        子文本替换 (替换文本, "timestamp替换", 时间戳, , , )
        子文本替换 (替换文本, "nonceStr替换", 回调标识, , , )
        子文本替换 (替换文本, "signature替换", 内部_微信公众号JSAPISING (回调标识, 时间戳, 当前页面URL), , , )
        子文本替换 (替换文本, "JS接口列表替换", JS接口列表.到可读文本 (, ), , , )
        如果 (是否开启调试模式 == 假)
        {
            子文本替换 (替换文本, "调试模式", "false", , , )
        }
        否则
        {
            子文本替换 (替换文本, "调试模式", "true", , , )
        }
        返回 (替换文本)
    }

    方法 内部_微信公众号JSAPISING <类型 = 文本型 注释 = "微信公众号专用" 注释 = "微信公众号初始化JS代码专用" 折叠 折叠2>
    参数 回调标识 <类型 = 文本型>
    参数 时间戳 <类型 = 文本型>
    参数 当前页面URL <类型 = 文本型>
    {
        变量 签名数据 <类型 = 文本型 值 = "jsapi_ticket=jsapi_ticket替换&noncestr=noncestr替换&timestamp=timestamp替换&url=url替换">
        子文本替换 (签名数据, "jsapi_ticket替换", jsapi_ticket获取 (), , , )
        子文本替换 (签名数据, "noncestr替换", 回调标识, , , )
        子文本替换 (签名数据, "timestamp替换", 时间戳, , , )
        子文本替换 (签名数据, "url替换", 当前页面URL, , , )

        变量 返回指针 <类型 = 变整数>
        返回指针 = 类_微信公众号基类.SHA1加密 (签名数据)
        变量 返回字节集 <类型 = 字节集类>
        返回字节集 = 读指针处对象 (返回指针, 字节集类)
        销毁对象指针 (返回指针)
        签名数据 = UTF8到文本 (返回字节集)

        返回 (签名数据)
    }

    方法 模板消息发送 <公开 折叠>
    参数 用户OpenID <类型 = 文本型>
    参数 模板消息ID <类型 = 文本型>
    参数 单击后载入网址 <类型 = 文本型 注释 = "留空则ios单击进入空页面" 注释 = "安卓无法单击" @默认值 = "">
    参数 模板替换标题 <类型 = JSONCPP数组类 注释 = "例如：" 注释 = "{{first.DATA}}" 注释 = "系统帐号：{{keyword1.DATA}}" 注释 = "登录系统：{{keyword2.DATA}}"
            注释 = "登录时间：{{keyword3.DATA}}" 注释 = "{{remark.DATA}}" 注释 = "则这里是"
            注释 = "[\"first\",\"keyword1\",\"keyword2\",\"keyword3\",\"remark\"]">
    参数 模板替换数据 <类型 = JSONCPP数组类 注释 = "标题对应的值">
    {
        变量 JSON对象 <类型 = JSONCPP对象类>
        JSON对象.置入文本值 ("touser", 用户OpenID)
        JSON对象.置入文本值 ("template_id", 模板消息ID)
        JSON对象.置入文本值 ("url", 单击后载入网址)
        变量 循环变量 <类型 = 整数>
        变量 模板替换数据对象 <类型 = JSONCPP对象类>
        循环 (0, 模板替换标题.成员数, 循环变量)
        {
            变量 临时对象 <类型 = JSONCPP对象类>
            临时对象.置入文本值 ("value", 模板替换数据.取文本值 (循环变量))
            临时对象.置入文本值 ("color", "#173177")
            模板替换数据对象.置入对象值 (模板替换标题.取文本值 (循环变量), 临时对象)

        }

        JSON对象.置入对象值 ("data", 模板替换数据对象)
        变量 返回指针 <类型 = 变整数>
        变量 时间 <类型 = 类_时间辅助函数>
        如果 (ACCESS_TOKEN时间戳 <= 时间.时间_取现行时间戳10位_长整数 () - (长整数)(60 * 8))
        {
            变量 返回信息 <类型 = 文本型>
            ACCESS_TOKEN获取 (appID, appsecret, 返回信息)

        }

        返回指针 = 类_微信公众号基类.模板消息发送 (ACCESSTOKEN, JSON对象.到可读文本 (, ))
        销毁对象指针 (返回指针)
        返回
    }

    方法 公众号收到数据 <折叠>
    参数 源文本 <类型 = 文本型>
    参数 OpenID <类型 = 文本型>
    参数 开发者号码 <类型 = 文本型>
    参数 时间戳 <类型 = 文本型>
    参数 消息类型 <类型 = 文本型>
    参数 消息内容 <类型 = 文本型>
    参数 消息id <类型 = 文本型>
    参数 是否扫码 <类型 = 文本型>
    参数 二维码内容 <类型 = 文本型>
    {
        OpenID = 取文本中间_ (源文本, "<FromUserName><![CDATA[", "]]><")
        开发者号码 = 取文本中间_ (源文本, "<ToUserName><![CDATA[", "]]><")
        时间戳 = 取文本中间_ (源文本, "<CreateTime>", "<")
        消息类型 = 取文本中间_ (源文本, "<MsgType><![CDATA[", "]]><")
        消息内容 = 取文本中间_ (源文本, "<Content><![CDATA[", "]]><")
        二维码内容 = 取文本中间_ (源文本, "<EventKey><![CDATA[", "]]><")
        消息id = 取文本中间_ (源文本, "<MsgId>", "<")
        变量 Event <类型 = 文本型>
        Event = 取文本中间_ (源文本, "<Event><![CDATA[", "]]><", , , )
        如果 (到小写 (Event) == "scan" || 寻找文本 (二维码内容, "qrscene_", , 真) != -1)
        {
            子文本替换 (二维码内容, "qrscene_", "", , , 假)
            是否扫码 = "1"
        }
        否则
        {
            是否扫码 = "2"
            二维码内容 = ""

        }
        如果 (消息类型 == "event" && 寻找文本 (源文本, "CDATA[unsubscribe]", , 真) != -1)
        {
            消息类型 = 消息类型 + "[取消关注]"
        }
        如果 (消息类型 == "event" && 寻找文本 (源文本, "CDATA[subscribe]", , 真) != -1)
        {
            消息类型 = 消息类型 + "[关注公众号]"

        }
        如果 (寻找文本 (源文本, "CDATA[location]", , 真) != -1)
        {
            地理位置纬度 = 取文本中间_ (源文本, "<Latitude>", "<")
            地理位置经度 = 取文本中间_ (源文本, "<Longitude>", "<", , , )
            地理位置精度 = 取文本中间_ (源文本, "<Precision>", "<", , , )

        }


    }

    方法 取文本中间_ <类型 = 文本型 折叠>
    参数 文本内容 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 @默认值 = 0>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        开始位置 = 寻找文本 (文本内容, 开始文本, 开始搜索位置)
        如果真 (开始位置 == -1)
        {
            返回 (中间文本)
        }
        开始搜索位置 = 开始位置 + 取文本长度 (开始文本)
        结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置) + 取文本长度 (结束文本)
        如果真 (是否包含起始文本 == 假)
        {
            开始位置 = 开始搜索位置
            结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置)
        }
        如果真 (结束位置 == -1)
        {
            如果 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            否则
            {
                返回 (文本内容)
            }
        }
        中间文本 = 取文本中间 (文本内容, 开始位置, 结束位置 - 开始位置)
        返回 (中间文本)
    }

    方法 子文本替换xk <类型 = 文本型 注释 = "替换指定文本" 折叠>
    参数 原始内容 <类型 = 文本型>
    参数 要替换的文本 <类型 = 文本型>
    参数 用作替换的文本 <类型 = 文本型>
    参数 开始位置 <类型 = 整数 @默认值 = 0>
    参数 替换次数 <类型 = 整数 @默认值 = -1>
    参数 是否区分大小 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 替换后的内容 <类型 = 文本型>
        替换后的内容 = 原始内容
