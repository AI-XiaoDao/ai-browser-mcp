    方法 微信支付_GET <公开 类型 = 逻辑型>
    参数 参商户信息 <类型 = 微信支付_商户信息>
    参数 参订单信息 <类型 = 微信支付_订单信息 注释 = "如果【获取微信支付链接】方法的第三个参数不为空对象，则这里不用填写" @默认值 = 空对象>
    参数 来源对象 <类型 = FOFHTTP 注释 = "提供事件产生的具体来源对象">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 返回的支付信息 <类型 = JSONCPP对象类 @默认值 = 空对象>
    参数 支付询问页面 <类型 = 文本型 注释 = "默认不填写情况下使用FOF自带的询问页面数据" @默认值 = 空对象>
    {
        变量 返回错误结果 <类型 = 文本型 注释 = "如果错误，则这里返回错误结果">
        变量 返回用户头像 <类型 = 文本型 注释 = "非错误情况下有效"
                注释 = "用户头像，最后一个数值代表正方形头像大小（有0、46、64、96、132数值可选，0代表640*640正方形头像），用户没有头像时该项为空。若用户更换头像，原有头像 URL 将失效。" 折叠2>
        变量 返回用户昵称 <类型 = 文本型>
        变量 返回用户性别 <类型 = 文本型 注释 = "用户的性别，值为1时是男性，值为2时是女性，值为0时是未知">
        变量 返回用户国家 <类型 = 文本型>
        变量 返回用户省份 <类型 = 文本型>
        变量 返回用户城市 <类型 = 文本型>
        变量 返回用户唯一ID <类型 = 文本型>
        变量 返回的回调标识 <类型 = 文本型>
        变量 access_token <类型 = JSONCPP对象类>
        变量 http辅助 <类型 = FOFHTTP_HTTP辅助>
        如果 (http辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数, ) != "" && 寻找文本 (http辅助.取参数 ("state", 用户数据.HTTP_待发整理.解析参数, ), "FOFwxpayZF", , ) != -1)
        {
            返回的回调标识 = http辅助.取参数 ("state", 用户数据.HTTP_待发整理.解析参数, )
            子文本替换 (返回的回调标识, "FOFwxpayZF", "", , , )
            如果 (返回的回调标识 == "")
            {
                返回 (假)

            }
            变量 成_订单信息 <类型 = 微信支付_订单信息>
            成_订单信息 = 参订单信息
            如果 (微信支付订单信息表.成员是否存在 (返回的回调标识) == 真)
            {
                成_订单信息.商品名 = 微信支付订单信息表.取文本值 (返回的回调标识 + "商品名")
                成_订单信息.商品编号 = 微信支付订单信息表.取文本值 (返回的回调标识 + "商品编号")
                成_订单信息.客户ip = 微信支付订单信息表.取文本值 (返回的回调标识 + "客户ip")
                成_订单信息.订单编号 = 微信支付订单信息表.取文本值 (返回的回调标识 + "订单编号")
                成_订单信息.订单金额 = 微信支付订单信息表.取文本值 (返回的回调标识 + "订单金额")
                成_订单信息.成功后跳转地址 = 微信支付订单信息表.取文本值 (返回的回调标识 + "成功后跳转地址")
                成_订单信息.支付确认页面描述 = 微信支付订单信息表.取文本值 (返回的回调标识 + "支付确认页面描述")
            }
            如果 (成_订单信息.订单编号 == "")
            {
                返回 (假)

            }

            变量 返回指针 <类型 = 变整数>
            返回指针 = 类_微信公众号基类.微信登陆_GET1 (appID, appsecret, http辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数, ))
            变量 返回字节集 <类型 = 字节集类>
            返回字节集 = 读指针处对象 (返回指针, 字节集类)
            如果 (access_token.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)
            如果 (access_token.成员是否存在 ("access_token") == 假)
            {
                返回错误结果 = UTF8到文本 (返回字节集)
                返回 (假)

            }

            变量 最终JSON <类型 = JSONCPP对象类>
            返回指针 = 类_微信公众号基类.微信登陆_GET2 (access_token.取文本值 ("access_token"), access_token.取文本值 ("openid"))
            如果 (最终JSON.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)

            返回用户头像 = 最终JSON.取文本值 ("headimgurl")
            返回用户昵称 = 最终JSON.取文本值 ("nickname")
            返回用户国家 = 最终JSON.取文本值 ("country")
            返回用户城市 = 最终JSON.取文本值 ("city")
            返回用户性别 = 到文本 (最终JSON.取整数值 ("sex"))
            返回用户省份 = 最终JSON.取文本值 ("province")
            返回用户唯一ID = 最终JSON.取文本值 ("openid")

            变量 最终数据 <类型 = 文本型
                    值 = "<xml>\r\n    <body><![CDATA[商品名称]]></body>\r\n    <out_trade_no><![CDATA[订单编号]]></out_trade_no>\r\n    <total_fee>支付金额</total_fee>\r\n    <notify_url><![CDATA[回调地址]]></notify_url>\r\n    <trade_type><![CDATA[JSAPI]]></trade_type>\r\n    <appid><![CDATA[APPID替换]]></appid>\r\n    <mch_id>商户号</mch_id>\r\n    <spbill_create_ip><![CDATA[客户IP]]></spbill_create_ip>\r\n    <nonce_str><![CDATA[随机字符串]]></nonce_str>\r\n    <openid><![CDATA[用户ID替换]]></openid>\r\n    <sign><![CDATA[签名数据]]></sign>\r\n</xml>">
            子文本替换 (最终数据, "APPID替换", 参商户信息.APPID, , , )
            子文本替换 (最终数据, "随机字符串", 返回的回调标识, , , )
            子文本替换 (最终数据, "商品名称", 成_订单信息.商品名, , , )
            子文本替换 (最终数据, "商户号", 参商户信息.商户号, , , )
            子文本替换 (最终数据, "回调地址", 参商户信息.成功后回调地址, , , )
            子文本替换 (最终数据, "订单编号", 成_订单信息.订单编号, , , )
            子文本替换 (最终数据, "客户IP", 成_订单信息.客户ip, , , )
            子文本替换 (最终数据, "用户ID替换", 返回用户唯一ID, , , )
            子文本替换 (最终数据, "支付金额", 成_订单信息.订单金额, , , )
            子文本替换 (最终数据, "签名数据", 内部_Sign (参商户信息.APIv2密钥, 参商户信息.商户号, 参商户信息.APPID, 成_订单信息.商品名, 参商户信息.成功后回调地址, 成_订单信息.订单编号, 成_订单信息.客户ip, 成_订单信息.订单金额, 返回的回调标识, 返回用户唯一ID), , , )
            变量 局数据 <类型 = 文本型>
            返回指针 = 类_微信公众号基类.提交微信支付 (最终数据)
            局数据 = UTF8到文本 (读指针处对象 (返回指针, 字节集类))
            销毁对象指针 (返回指针)
            返回的支付信息.清空 ()
            返回的支付信息.置入文本值 ("通讯状态", 取文本中间_ (局数据, "<return_code><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("通讯消息", 取文本中间_ (局数据, "<return_msg><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("业务状态", 取文本中间_ (局数据, "<result_code><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("JSAPI专用ID", 取文本中间_ (局数据, "<prepay_id><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("随机字符串", 取文本中间_ (局数据, "<nonce_str><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("订单号", 成_订单信息.订单编号)
            返回的支付信息.置入文本值 ("支付类型", 取文本中间_ (局数据, "<trade_type><![CDATA[", "]]"))
            用户数据.HTTP_待发整理.文件后缀 = "html"
            变量 支付确认页面描述 <类型 = 文本型>
            变量 成功后跳转地址 <类型 = 文本型>
            支付确认页面描述 = 成_订单信息.支付确认页面描述
            如果 (支付确认页面描述 == "")
            {
                支付确认页面描述 = 参商户信息.支付确认页面描述

            }
            成功后跳转地址 = 成_订单信息.成功后跳转地址
            如果 (成功后跳转地址 == "")
            {
                成功后跳转地址 = 参商户信息.成功后跳转地址

            }

            变量 支付页面 <类型 = 字节集类>
            支付页面 = 内部_获取支付页面 (参商户信息.支付确认页面描述, 参商户信息.APPID, 返回的回调标识, 取文本中间_ (局数据, "<prepay_id><![CDATA[", "]]", , , ), 参商户信息.APIv2密钥, 成功后跳转地址, 支付询问页面)
            来源对象.发送页面数据 (服务句柄, 连接ID, 支付页面, 用户数据, )
            返回 (真)
        }
        返回 (假)
    }

    方法 微信支付_GET_HTTPS <公开 类型 = 逻辑型 折叠>
    参数 参商户信息 <类型 = 微信支付_商户信息>
    参数 参订单信息 <类型 = 微信支付_订单信息 注释 = "如果【获取微信支付链接】方法的第三个参数不为空对象，则这里不用填写" @默认值 = 空对象>
    参数 来源对象 <类型 = FOFHTTPS 注释 = "提供事件产生的具体来源对象">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 返回的支付信息 <类型 = JSONCPP对象类 @默认值 = 空对象>
    参数 支付询问页面 <类型 = 文本型 注释 = "默认不填写情况下使用FOF自带的询问页面数据" @默认值 = 空对象>
    {
        变量 返回错误结果 <类型 = 文本型 注释 = "如果错误，则这里返回错误结果">
        变量 返回用户头像 <类型 = 文本型 注释 = "非错误情况下有效"
                注释 = "用户头像，最后一个数值代表正方形头像大小（有0、46、64、96、132数值可选，0代表640*640正方形头像），用户没有头像时该项为空。若用户更换头像，原有头像 URL 将失效。" 折叠2>
        变量 返回用户昵称 <类型 = 文本型>
        变量 返回用户性别 <类型 = 文本型 注释 = "用户的性别，值为1时是男性，值为2时是女性，值为0时是未知">
        变量 返回用户国家 <类型 = 文本型>
        变量 返回用户省份 <类型 = 文本型>
        变量 返回用户城市 <类型 = 文本型>
        变量 返回用户唯一ID <类型 = 文本型>
        变量 返回的回调标识 <类型 = 文本型>
        变量 access_token <类型 = JSONCPP对象类>
        变量 http辅助 <类型 = FOFHTTP_HTTP辅助>
        如果 (http辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数, ) != "" && 寻找文本 (http辅助.取参数 ("state", 用户数据.HTTP_待发整理.解析参数, ), "ZF", , ) != -1)
        {
            返回的回调标识 = http辅助.取参数 ("state", 用户数据.HTTP_待发整理.解析参数, )
            子文本替换 (返回的回调标识, "FOFZF", "", , , )
            变量 成_订单信息 <类型 = 微信支付_订单信息>
            成_订单信息 = 参订单信息
            如果 (微信支付订单信息表.成员是否存在 (返回的回调标识) == 真)
            {
                成_订单信息.商品名 = 微信支付订单信息表.取文本值 (返回的回调标识 + "商品名")
                成_订单信息.商品编号 = 微信支付订单信息表.取文本值 (返回的回调标识 + "商品编号")
                成_订单信息.客户ip = 微信支付订单信息表.取文本值 (返回的回调标识 + "客户ip")
                成_订单信息.订单编号 = 微信支付订单信息表.取文本值 (返回的回调标识 + "订单编号")
                成_订单信息.订单金额 = 微信支付订单信息表.取文本值 (返回的回调标识 + "订单金额")
                成_订单信息.成功后跳转地址 = 微信支付订单信息表.取文本值 (返回的回调标识 + "成功后跳转地址")
                成_订单信息.支付确认页面描述 = 微信支付订单信息表.取文本值 (返回的回调标识 + "支付确认页面描述")
            }
            如果 (成_订单信息.订单编号 == "")
            {
                返回 (假)

            }

            变量 返回指针 <类型 = 变整数>
            返回指针 = 类_微信公众号基类.微信登陆_GET1 (appID, appsecret, http辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数, ))
            变量 返回字节集 <类型 = 字节集类>
            返回字节集 = 读指针处对象 (返回指针, 字节集类)
            如果 (access_token.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)
            如果 (access_token.成员是否存在 ("access_token") == 假)
            {
                返回错误结果 = UTF8到文本 (返回字节集)
                返回 (假)

            }

            变量 最终JSON <类型 = JSONCPP对象类>
            返回指针 = 类_微信公众号基类.微信登陆_GET2 (access_token.取文本值 ("access_token"), access_token.取文本值 ("openid"))
            如果 (最终JSON.创建自文本 (UTF8到文本 (读指针处对象 (返回指针, 字节集类))) == 假)
            {
                销毁对象指针 (返回指针)
                返回错误结果 = "请求登录失败"
                返回 (假)

            }
            销毁对象指针 (返回指针)

            返回用户头像 = 最终JSON.取文本值 ("headimgurl")
            返回用户昵称 = 最终JSON.取文本值 ("nickname")
            返回用户国家 = 最终JSON.取文本值 ("country")
            返回用户城市 = 最终JSON.取文本值 ("city")
            返回用户性别 = 到文本 (最终JSON.取整数值 ("sex"))
            返回用户省份 = 最终JSON.取文本值 ("province")
            返回用户唯一ID = 最终JSON.取文本值 ("openid")

            变量 最终数据 <类型 = 文本型
                    值 = "<xml>\r\n    <body><![CDATA[商品名称]]></body>\r\n    <out_trade_no><![CDATA[订单编号]]></out_trade_no>\r\n    <total_fee>支付金额</total_fee>\r\n    <notify_url><![CDATA[回调地址]]></notify_url>\r\n    <trade_type><![CDATA[JSAPI]]></trade_type>\r\n    <appid><![CDATA[APPID替换]]></appid>\r\n    <mch_id>商户号</mch_id>\r\n    <spbill_create_ip><![CDATA[客户IP]]></spbill_create_ip>\r\n    <nonce_str><![CDATA[随机字符串]]></nonce_str>\r\n    <openid><![CDATA[用户ID替换]]></openid>\r\n    <sign><![CDATA[签名数据]]></sign>\r\n</xml>">
            子文本替换 (最终数据, "APPID替换", 参商户信息.APPID, , , )
            子文本替换 (最终数据, "随机字符串", 返回的回调标识, , , )
            子文本替换 (最终数据, "商品名称", 参订单信息.商品名, , , )
            子文本替换 (最终数据, "商户号", 参商户信息.商户号, , , )
            子文本替换 (最终数据, "回调地址", 参商户信息.成功后回调地址, , , )
            子文本替换 (最终数据, "订单编号", 参订单信息.订单编号, , , )
            子文本替换 (最终数据, "客户IP", 参订单信息.客户ip, , , )
            子文本替换 (最终数据, "用户ID替换", 返回用户唯一ID, , , )
            子文本替换 (最终数据, "支付金额", 参订单信息.订单金额, , , )
            子文本替换 (最终数据, "签名数据", 内部_Sign (参商户信息.APIv2密钥, 参商户信息.商户号, 参商户信息.APPID, 参订单信息.商品名, 参商户信息.成功后回调地址, 参订单信息.订单编号, 参订单信息.客户ip, 参订单信息.订单金额, 返回的回调标识, 返回用户唯一ID), , , )
            变量 局数据 <类型 = 文本型>
            返回指针 = 类_微信公众号基类.提交微信支付 (最终数据)
            局数据 = UTF8到文本 (读指针处对象 (返回指针, 字节集类))
            销毁对象指针 (返回指针)
            返回的支付信息.清空 ()
            返回的支付信息.置入文本值 ("通讯状态", 取文本中间_ (局数据, "<return_code><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("通讯消息", 取文本中间_ (局数据, "<return_msg><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("业务状态", 取文本中间_ (局数据, "<result_code><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("JSAPI专用ID", 取文本中间_ (局数据, "<prepay_id><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("随机字符串", 取文本中间_ (局数据, "<nonce_str><![CDATA[", "]]"))
            返回的支付信息.置入文本值 ("订单号", 参订单信息.订单编号)
            返回的支付信息.置入文本值 ("支付类型", 取文本中间_ (局数据, "<trade_type><![CDATA[", "]]"))
            用户数据.HTTP_待发整理.文件后缀 = "html"
            变量 支付确认页面描述 <类型 = 文本型>
            变量 成功后跳转地址 <类型 = 文本型>
            支付确认页面描述 = 参订单信息.支付确认页面描述
            如果 (支付确认页面描述 == "")
            {
                支付确认页面描述 = 参商户信息.支付确认页面描述

            }
            成功后跳转地址 = 参订单信息.成功后跳转地址
            如果 (成功后跳转地址 == "")
            {
                成功后跳转地址 = 参商户信息.成功后跳转地址

            }

            来源对象.发送页面数据 (服务句柄, 连接ID, 内部_获取支付页面 (参商户信息.支付确认页面描述, 参商户信息.APPID, 返回的回调标识, 取文本中间_ (局数据, "<prepay_id><![CDATA[", "]]", , , ), 参商户信息.APIv2密钥, 成功后跳转地址, 支付询问页面), 用户数据, )
            返回 (真)
        }
        返回 (假)
    }

    方法 内部_获取支付页面 <类型 = 字节集类 折叠>
    参数 页面描述 <类型 = 文本型>
    参数 APPID_ <类型 = 文本型>
    参数 回调标识 <类型 = 文本型>
    参数 JSAPI专用ID <类型 = 文本型>
    参数 密钥信息 <类型 = 文本型>
    参数 成功后跳转地址 <类型 = 文本型>
    参数 支付询问页面 <类型 = 文本型 @默认值 = "">
    {
        变量 微信页面代码 <类型 = 文本型
                值 = "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>微信支付确认页面</title>\r\n</head>\r\n\r\n<body>\r\n    <div class=\"login-success\">\r\n        <div class=\"wx\">\r\n            <svg t=\"1662184926426\" class=\"icon\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\"\r\n                p-id=\"2630\" width=\"100\" height=\"100\">\r\n                <path\r\n                    d=\"M693.12 347.264c11.776 0 23.36 0.896 35.008 2.176-31.36-146.048-187.456-254.528-365.696-254.528C163.2 94.912 0 230.656 0 403.136c0 99.52 54.272 181.248 145.024 244.736L108.8 756.864l126.72-63.488c45.312 8.896 81.664 18.112 126.912 18.112 11.392 0 22.656-0.512 33.792-1.344-7.04-24.256-11.2-49.6-11.2-76.032C385.088 475.776 521.024 347.264 693.12 347.264zM498.304 249.024c27.392 0 45.376 17.984 45.376 45.248 0 27.136-17.984 45.312-45.376 45.312-27.072 0-54.336-18.176-54.336-45.312C443.968 266.944 471.168 249.024 498.304 249.024zM244.672 339.584c-27.2 0-54.592-18.176-54.592-45.312 0-27.264 27.392-45.248 54.592-45.248S289.92 266.944 289.92 294.272C289.92 321.408 271.872 339.584 244.672 339.584zM1024 629.76c0-144.896-145.024-262.976-307.904-262.976-172.48 0-308.224 118.144-308.224 262.976 0 145.28 135.808 262.976 308.224 262.976 36.096 0 72.512-9.024 108.736-18.112l99.392 54.528-27.264-90.624C969.728 783.872 1024 711.488 1024 629.76zM616.128 584.384c-17.984 0-36.224-17.92-36.224-36.224 0-18.048 18.24-36.224 36.224-36.224 27.52 0 45.376 18.176 45.376 36.224C661.504 566.464 643.648 584.384 616.128 584.384zM815.488 584.384c-17.856 0-36.032-17.92-36.032-36.224 0-18.048 18.112-36.224 36.032-36.224 27.264 0 45.376 18.176 45.376 36.224C860.864 566.464 842.752 584.384 815.488 584.384z\"\r\n                    p-id=\"2631\" fill=\"#15d36a\"></path>\r\n            </svg>\r\n        </div>\r\n        <h2>支付确认</h2>\r\n        <div class=\"text\">\r\n            <p>${Text}</p>\r\n        </div>\r\n        <a href=\"javascript:void(0);\" onclick=\"onBridgeReady()\"><button class=\"btn\">点击开始支付</button></a>\r\n    </div>\r\n    <style>\r\n        body {\r\n            min-height: 100vh;\r\n            margin: 0;\r\n            padding: 0;\r\n        }\r\n\r\n        .login-success {\r\n            padding-top: 120px;\r\n            text-align: center;\r\n        }\r\n\r\n        .login-success .wx svg {\r\n            max-width: 100px;\r\n        }\r\n\r\n        .login-success h2 {\r\n            color: #25c09f;\r\n            font-weight: normal;\r\n            margin: 0;\r\n        }\r\n\r\n        .login-success .text {\r\n            color: #999;\r\n            font-size: 14px;\r\n        }\r\n\r\n        .login-success .btn {\r\n            margin-top: 40px;\r\n            width: 75vw;\r\n            height: 38px;\r\n            line-height: 38px;\r\n            padding: 0 35px;\r\n            background-color: #15d36a;\r\n            font-size: 16px;\r\n            color: #fff;\r\n            background: linear-gradient(45deg, #15d36a 0%, #276a45 100%);\r\n            border-radius: 50px;\r\n            outline: none;\r\n            border: none;\r\n        }\r\n    </style>\r\n    <script>\r\n        function onBridgeReady() {\r\n            WeixinJSBridge.invoke(\r\n                \'getBrandWCPayRequest\', {\r\n                \"appId\": \"${appId}\",     //公众号ID，由商户传入     \r\n                \"timeStamp\": \"${Time}\",         //时间戳，自1970年以来的秒数     \r\n                \"nonceStr\": \"${StrData}\", //随机串     \r\n                \"package\": \"prepay_id=${package}\",\r\n                \"signType\": \"MD5\",         //微信签名方式：     \r\n                \"paySign\": \"${Sing}\" //微信签名 \r\n            },\r\n                function (res) {\r\n                    if (res.err_msg == \"get_brand_wcpay_request:ok\") {\r\n                        location.href=\"${OKURL}\"\r\n                    }\r\n                });\r\n        }\r\n    </script>\r\n</body>\r\n\r\n</html>">
        变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
        变量 最终字节集 <类型 = 字节集类>
        如果 (支付询问页面 == 空对象 && 支付询问页面 == "")
        {
            最终字节集 = 文本到UTF8 (微信页面代码, 假)
        }
        否则
        {
            最终字节集 = 文本到UTF8 (支付询问页面, 假)
        }
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "Text", 页面描述)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "appId", APPID_)
        变量 时间 <类型 = 类_时间辅助函数>
        变量 时间戳 <类型 = 文本型>
        时间戳 = 到文本 (时间.时间_取现行时间戳10位_长整数 ())
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "Time", 时间戳)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "StrData", 回调标识)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "package", JSAPI专用ID)
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "Sing", 内部_JSAPISING (密钥信息, 回调标识, APPID_, JSAPI专用ID, 时间戳))
        最终字节集 = HTTP辅助.解析标签 (最终字节集, "OKURL", 成功后跳转地址)
        返回 (最终字节集)
    }

    方法 获取微信支付链接 <公开 类型 = 文本型 折叠>
    参数 回调域名 <类型 = 文本型 注释 = "例如:https://www.xxx.com">
    参数 回调标识 <类型 = 长整数 注释 = "当支付成功时，回调的信息会收到此标识">
    参数 参订单信息 <类型 = 微信支付_订单信息 注释 = "如果此处不为空，则【微信支付_GET】【微信支付_GET_HTTPS】两个方法中的【参订单信息】参数失效" @默认值 = 空对象>
    {
        变量 HTTP辅助 <类型 = FOFHTTP_HTTP辅助>
        如果 (微信支付订单信息表.成员数 >= 9000)
        {
            微信支付订单信息表.清空 ()
            微信支付订单信息表.创建自文本 ("{}")

        }
        如果 (参订单信息 != 空对象)
        {
            微信支付订单信息表.置入文本值 (到文本 (回调标识), 到文本 (回调标识))
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "商品名", 参订单信息.商品名)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "商品编号", 参订单信息.商品编号)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "客户ip", 参订单信息.客户ip)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "订单编号", 参订单信息.订单编号)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "订单金额", 参订单信息.订单金额)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "成功后跳转地址", 参订单信息.成功后跳转地址)
            微信支付订单信息表.置入文本值 (到文本 (回调标识) + "支付确认页面描述", 参订单信息.支付确认页面描述)

        }

        返回 ("https://open.weixin.qq.com/connect/oauth2/authorize?appid=" + appID + "&redirect_uri=" + UTF8到文本 (HTTP辅助.URL编码 (文本到UTF8 (回调域名, 假))) + "&response_type=code&scope=snsapi_userinfo&state=FOFwxpayZF" + 到文本 (回调标识) + "#wechat_redirect")
    }

    方法 内部_JSAPISING <类型 = 文本型 注释 = "微信支付专用" 折叠>
    参数 参密钥 <类型 = 文本型>
    参数 回调标识 <类型 = 文本型>
    参数 APPID <类型 = 文本型>
    参数 JSAPI专用ID <类型 = 文本型>
    参数 时间戳 <类型 = 文本型>
    {
        变量 数据 <类型 = 文本型 值 = "appId=appId替换&nonceStr=nonceStr替换&package=package替换&signType=signType替换&timeStamp=timeStamp替换&key=密钥">
        变量 MD5 <类型 = 类_密码处理>
        子文本替换 (数据, "appId替换", APPID, , , )
        子文本替换 (数据, "nonceStr替换", 回调标识, , , )
        子文本替换 (数据, "package替换", "prepay_id=" + JSAPI专用ID, , , )
        子文本替换 (数据, "signType替换", "MD5", , , )
        子文本替换 (数据, "timeStamp替换", 时间戳, , , )
        子文本替换 (数据, "密钥", 参密钥, , , )
        数据 = 到大写 (MD5.校验_取字节集MD5 (文本到UTF8 (数据, 假), ))
        返回 (数据)
    }

    方法 内部_Sign <类型 = 文本型 折叠>
    参数 参密钥 <类型 = 文本型>
    参数 商户号 <类型 = 文本型>
    参数 APPID替换 <类型 = 文本型>
    参数 商品名称 <类型 = 文本型>
    参数 回调地址 <类型 = 文本型>
    参数 订单编号 <类型 = 文本型>
    参数 客户IP <类型 = 文本型>
    参数 支付金额 <类型 = 文本型>
    参数 随机字符串 <类型 = 文本型>
    参数 用户ID <类型 = 文本型>
    {
        变量 数据 <类型 = 文本型
                值 = "appid=APPID替换&body=商品名称&mch_id=商户号&nonce_str=随机字符串&notify_url=回调地址&openid=用户ID替换&out_trade_no=订单编号&spbill_create_ip=客户IP&total_fee=支付金额&trade_type=JSAPI&key=参密钥">
        变量 MD5 <类型 = 类_密码处理>
        子文本替换 (数据, "APPID替换", APPID替换, , , )
        子文本替换 (数据, "随机字符串", 随机字符串, , , )
        子文本替换 (数据, "商品名称", 商品名称, , , )
        子文本替换 (数据, "商户号", 商户号, , , )
        子文本替换 (数据, "回调地址", 回调地址, , , )
        子文本替换 (数据, "订单编号", 订单编号, , , )
        子文本替换 (数据, "客户IP", 客户IP, , , )
        子文本替换 (数据, "支付金额", 支付金额, , , )
        子文本替换 (数据, "参密钥", 参密钥, , , )
        子文本替换 (数据, "用户ID替换", 用户ID, , , )
        数据 = 到大写 (MD5.校验_取字节集MD5 (文本到UTF8 (数据, 假), ))
        返回 (数据)
    }
}

