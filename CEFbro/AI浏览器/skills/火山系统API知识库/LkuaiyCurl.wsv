            注释 = "ADD_SCENE_PROFILE_CARD 名片分享" 注释 = "ADD_SCENE_QR_CODE 扫描二维码" 注释 = "ADD_SCENE_PROFILE_LINK 图文页内名称点击"
            注释 = "ADD_SCENE_PROFILE_ITEM 图文页右上角菜单" 注释 = "ADD_SCENE_PAID 支付后关注" 注释 = "ADD_SCENE_WECHAT_ADVERTISEMENT 微信广告"
            注释 = "ADD_SCENE_REPRINT 他人转载" 注释 = "ADD_SCENE_LIVESTREAM 视频号直播" 注释 = "ADD_SCENE_CHANNELS 视频号" 注释 = "ADD_SCENE_OTHERS 其他"
            折叠2 @默认值 = "">
    {
