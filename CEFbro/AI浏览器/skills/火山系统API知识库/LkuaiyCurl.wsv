    {
        // 判断QQ回调URL====
        // 调试输出 (用户数据.HTTP_待发整理.请求Url, 判断QQ回调地址 ())
        如果 (ID == "" && KEY == "")
        {
            返回 (假)
        }
        如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, 回调2) != -1)
        {
            变量 辅助 <类型 = FOFHTTP_HTTP辅助>
            变量 互联信息 <类型 = QQ互联数据>
            互联信息 = QQ互联_登录成功获取QQ信息 (辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数))
            // 调试输出 (辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数, ), 11122)
            如果 (互联信息.openid != "")
            {
                QQ登录成功 (ID, KEY, 互联信息.openid, 互联信息.Access_Token, 互联信息.refresh_token, 互联信息.QQ昵称, 互联信息.QQ头像, 来源对象, 服务句柄, 连接ID, 数据大小, 用户数据)
                返回 (真)

            }

        }
        返回 (假)
        // 判断QQ回调URL====


    }

