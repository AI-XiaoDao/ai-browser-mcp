    方法 取文本中 <类型 = 文本型 折叠>
    参数 需取文本 <类型 = 文本型>
    参数 左边内容 <类型 = 文本型>
    参数 右边内容 <类型 = 文本型>
    {
        变量 长度 <类型 = 整数>
        变量 左边位置 <类型 = 整数>
        变量 左边长度 <类型 = 整数>
        变量 右边位置 <类型 = 整数>
        变量 右边长度 <类型 = 整数>
        长度 = 取文本长度 (需取文本)
        左边位置 = 寻找文本 (需取文本, 左边内容, 0, 假)
        左边长度 = 取文本长度 (左边内容)
        如果真 (左边位置 == -1)
        {
            返回 ("")

        }

        右边位置 = 寻找文本 (需取文本, 右边内容, 左边位置, 假)
        右边长度 = 取文本长度 (右边内容)
        如果真 (右边位置 == -1)
        {
            返回 ("")

        }

        返回 (取文本中间 (需取文本, 左边位置 + 左边长度, 长度 - (左边位置 + 左边长度) - (长度 - 右边位置)))




    }

    方法 判断QQ回调地址 <类型 = 文本型 折叠>
    {
        变量 文本 <类型 = 类_文本操作>
        返回 (文本.文本_取右边 (回调, "/"))

    }

    方法 QQ互联_登录成功获取QQ信息 <类型 = QQ互联数据 折叠>
    参数 Authorization_Code <类型 = 文本型 注释 = "通过QQ登录成功的回调信息获取" 注释 = "获取方法：辅助.取参数 (\"code\", 用户数据.HTTP_待发整理.解析参数)">
    {
        变量 QQ互联 <类型 = QQ互联数据>
        变量 返回指针 <类型 = 变整数>
        变量 返回文本 <类型 = 文本型>
        返回指针 = 类_QQ互联基类.登录成功获取QQ信息 (Authorization_Code, ID, KEY, 回调)
        返回文本 = UTF8到文本 (读指针处对象 (返回指针, 字节集类))
        销毁对象指针 (返回指针)
        如果 (返回文本 != "")
        {
            变量 文本分割 <类型 = 文本数组类>
            分割子文本 (返回文本, "[fofserver]", 文本分割, , )
            如果 (文本分割.取成员数 () >= 5)
            {
                QQ互联.Access_Token = 文本分割.取成员 (0)
                QQ互联.refresh_token = 文本分割.取成员 (1)
                QQ互联.openid = 文本分割.取成员 (2)
                QQ互联.QQ昵称 = 文本分割.取成员 (3)
                QQ互联.QQ头像 = 文本分割.取成员 (4)

            }

        }
        返回 (QQ互联)
    }
}

类 类_网页_访问_对象 <公开 注释 = "GET与POST请求" 折叠 @全局类 = 真>
{
    方法 网页_访问lky <公开 静态 类型 = 字节集类 注释 = "返回字节集数据  ；使用WinHttp的对象方式访问网页" 折叠>
    参数 请求网址 <类型 = 文本型>
    参数 访问方式_参数 <类型 = 逻辑型 注释 = "假为:GET请求，真为:POST请求" @默认值 = 假>
    参数 提交数据 <类型 = 字节集类 注释 = "提交字节集数据" @默认值 = 空对象>
    参数 提交Cookies <类型 = 文本型 注释 = "设置提交时的cookie" @默认值 = "">
    参数 附加协议头 <类型 = 文本型 注释 = "附加协议" 注释 = "一行一个请用换行符隔开" 折叠2 @默认值 = "">
    参数 返回Cookies <类型 = 文本型 @默认值 = 空对象>
    参数 返回协议头 <类型 = 文本型 @默认值 = 空对象>
    参数 返回状态代码 <类型 = 文本型 @默认值 = 空对象>
    参数 禁止重定向 <类型 = 逻辑型 注释 = "默认不禁止网页重定向" @默认值 = 假>
    参数 超时时间 <类型 = 整数 注释 = "默认为15秒,-1为无限等待" @默认值 = 15>
    参数 是否补全协议头 <类型 = 逻辑型 注释 = "当附件协议头为空时自动添加必要的UA协议头 默认为真，假将不再添加非传入协议头" @默认值 = 真>
    {
        变量 提交信息 <类型 = 文本型 值 = "" 注释 = "\"POST\"专用   自动UTF8编码" "">
        变量 空字节集 <类型 = 字节集类>
        变量 WinHttp <类型 = COM对象类>
        变量 方式 <类型 = 文本型>
        变量 数据组1 <类型 = 文本数组类>
        变量 数据组2 <类型 = 文本数组类>
        变量 局_变体 <类型 = COM变体型>
        变量 返回数据 <类型 = 字节集类>
        变量 Cook <类型 = 文本型>
        变量 执行结果 <类型 = 逻辑型>
        @ CoInitialize(NULL);
        变量 访问方式 <类型 = 整数>
        如果 (访问方式_参数 == 假)
        {
            访问方式 = 0
        }
        否则
        {
            访问方式 = 1

        }
        方式 = 多项选择 (访问方式, "GET", "POST", "HEAD", "PUT", "OPTIONS", "DELETE", "TRACE", "CONNECT")
        如果真 (WinHttp.创建 ("WinHttp.WinHttpRequest.5.1") == 假)
        {
            返回 (空字节集)
        }
        如果真 (超时时间 != -1)
        {
            如果 (超时时间 < 1)
            {
                超时时间 = 15000
            }
            否则
            {
                超时时间 = 超时时间 * 1000
            }
            执行结果 = WinHttp.无返回值方法 ("SetTimeouts", 超时时间, 超时时间, 超时时间, 超时时间)
        }
        如果真 (到小写 (取文本左边 (请求网址, 4)) != "http")
        {
            请求网址 = "http://" + 请求网址
        }
        执行结果 = WinHttp.无返回值方法 ("Open", 方式, 请求网址, 假)
        如果真 (禁止重定向)
        {
            执行结果 = WinHttp.写属性 ("Option", 6, 0)
        }
        执行结果 = WinHttp.写属性 ("Option", 4, 13056)
        如果真 (是否补全协议头 == 真)
        {
            如果真 (寻找文本 (附加协议头, "Accept:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nAccept: */*"
            }
            如果真 (寻找文本 (附加协议头, "Referer:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nReferer:" + 请求网址
            }
            如果真 (寻找文本 (附加协议头, "Accept-Language:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nAccept-Language: zh-cn"
            }
            如果真 (寻找文本 (附加协议头, "User-Agent:", , 真) == -1)
            {
                附加协议头 = 附加协议头 + "\r\nUser-Agent: Mozilla/4.0 (compatible; MSIE 9.0; Windows NT 6.1)"
            }
            如果真 (访问方式 == 1)
            {
                如果真 (寻找文本 (附加协议头, "Content-Type:", , 真) == -1)
                {
                    附加协议头 = 附加协议头 + "\r\nContent-Type: application/x-www-form-urlencoded"
                }
            }
        }
        如果真 (取反 (提交Cookies == ""))
        {
            如果真 (取文本长度 (提交Cookies) > 0)
            {
                如果真 (寻找文本 (提交Cookies, "Cookie:", , 真) != -1)
                {
                    子文本替换 (提交Cookies, "Cookie:", "", , , 假)
                }
            }
            执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", "Cookie", 提交Cookies)
        }
        如果 (寻找文本 (附加协议头, "\r\n", , 假) == -1)
        {
            执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", 内部_协议头取名_ (附加协议头), 内部_协议头取值_ (附加协议头))
        }
        否则
        {
            分割文本 (附加协议头, "\r\n", 数据组1)
            计次循环 (数据组1.取成员数 ())
            {
                如果真 (数据组1.取成员 (取循环索引 ()) != "")
                {
                    如果真 (内部_协议头取名_ (数据组1.取成员 (取循环索引 ())) == "Connection")
                    {
                        如果真 (内部_协议头取值_ (数据组1.取成员 (取循环索引 ())) == "keep - alive")
                        {
                            到循环尾
                        }
                    }
                    执行结果 = WinHttp.无返回值方法 ("SetRequestHeader", 内部_协议头取名_ (数据组1.取成员 (取循环索引 ())), 内部_协议头取值_ (数据组1.取成员 (取循环索引 ())))
                }
            }
        }
        如果 (提交数据 == 空对象)
        {
            执行结果 = WinHttp.无返回值方法 ("Send", 提交信息)
        }
        否则
        {
            局_变体.置字节集 (提交数据)
            执行结果 = WinHttp.无返回值方法 ("Send", 局_变体)
        }
        局_变体 = WinHttp.读无参数属性 ("ResponseBody", COM变体型)
        执行结果 = 局_变体.取字节集 (返回数据)
        返回协议头 = WinHttp.读无参数属性 ("GetAllResponseHeaders", 文本型)
        返回状态代码 = 到文本 (WinHttp.读无参数属性 ("Status", 整数))
        WinHttp.读无参数属性 ("StatusText", 文本型)
        分割文本 (返回协议头, "\r\n", 数据组2)
        返回Cookies = ""
        计次循环 (数据组2.取成员数 ())
        {
            Cook = 数据组2.取成员 (取循环索引 ())
            如果真 (取文本左边 (Cook, 寻找文本 (Cook, ":")) == "Set-Cookie")
            {
                如果 (寻找文本 (Cook, ";", , 假) != -1)
                {
                    返回Cookies = 返回Cookies + 删首尾空 (内部_取文本中间_ (Cook, "Set-Cookie:", ";")) + "; "
                }
                否则
                {
                    子文本替换 (Cook, "Set-Cookie:", "")
                    返回Cookies = 返回Cookies + 删首尾空 (Cook) + "; "
                }
            }
        }
        如果真 (取文本左边 (返回Cookies, 2) == "; ")
        {
            返回Cookies = 取文本左边 (返回Cookies, 取文本长度 (返回Cookies) - 2)
        }
        返回Cookies = 返回Cookies
        WinHttp.清除 ()
        @ CoUninitialize();
        返回 (返回数据)
    }

    方法 内部_协议头取值_ <静态 类型 = 文本型 折叠>
    参数 协议头 <类型 = 文本型>
    {
        变量 位置 <类型 = 整数>
        变量 结果 <类型 = 文本型>
        位置 = 寻找文本 (协议头, ":", , 假)
        如果真 (位置 != -1)
        {
            结果 = 取文本右边 (协议头, 取文本长度 (协议头) - 位置 - 1)
        }
        返回 (删首尾空 (结果))
    }

    方法 内部_取文本中间_ <静态 类型 = 文本型 折叠>
    参数 文本内容 <类型 = 文本型>
    参数 开始文本 <类型 = 文本型>
    参数 结束文本 <类型 = 文本型>
    参数 开始搜索位置 <类型 = 整数 @默认值 = 0>
    参数 是否包含起始文本 <类型 = 逻辑型 @默认值 = 假>
    参数 如果找不到返回原始文本 <类型 = 逻辑型 注释 = "默认找不到就返回空文本" @默认值 = 假>
    {
        变量 中间文本 <类型 = 文本型>
        变量 开始位置 <类型 = 整数>
        变量 结束位置 <类型 = 整数>
        开始位置 = 寻找文本 (文本内容, 开始文本, 开始搜索位置)
        如果真 (开始位置 == -1)
        {
            返回 (中间文本)
        }
        开始搜索位置 = 开始位置 + 取文本长度 (开始文本)
        结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置) + 取文本长度 (结束文本)
        如果真 (是否包含起始文本 == 假)
        {
            开始位置 = 开始搜索位置
            结束位置 = 寻找文本 (文本内容, 结束文本, 开始搜索位置)
        }
        如果真 (结束位置 == -1)
        {
            如果 (如果找不到返回原始文本 == 假)
            {
                返回 ("")
            }
            否则
            {
                返回 (文本内容)
            }
        }
        中间文本 = 取文本中间 (文本内容, 开始位置, 结束位置 - 开始位置)
        返回 (中间文本)
    }

    方法 内部_协议头取名_ <静态 类型 = 文本型 折叠>
    参数 协议头 <类型 = 文本型>
    {
        变量 位置 <类型 = 整数>
        变量 结果 <类型 = 文本型>
        位置 = 寻找文本 (协议头, ":", , 假)
        如果真 (位置 != -1)
        {
            结果 = 取文本左边 (协议头, 位置)
        }
        返回 (删首尾空 (结果))

    }
}
