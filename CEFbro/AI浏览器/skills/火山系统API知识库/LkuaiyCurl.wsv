    方法 微信支付_是否成功 <公开 类型 = 逻辑型 折叠>
    参数 回调标识 <类型 = 文本型>
    参数 返回微信支付信息 <类型 = JSONCPP对象类>
    {
        如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "返回的回调标识") == 真)
        {
            返回微信支付信息.置入文本值 ("返回的回调标识", 微信支付临时缓存表.取文本值 (回调标识 + "返回的回调标识"))
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "支付状态") == 真)
            {
                返回微信支付信息.置入文本值 ("支付状态", 微信支付临时缓存表.取文本值 (回调标识 + "支付状态"))
                微信支付临时缓存表.删除成员 (回调标识 + "支付状态")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "货币种类") == 真)
            {
                返回微信支付信息.置入文本值 ("货币种类", 微信支付临时缓存表.取文本值 (回调标识 + "货币种类"))
                微信支付临时缓存表.删除成员 (回调标识 + "货币种类")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "现金支付金额") == 真)
            {
                返回微信支付信息.置入文本值 ("现金支付金额", 微信支付临时缓存表.取文本值 (回调标识 + "现金支付金额"))
                微信支付临时缓存表.删除成员 (回调标识 + "现金支付金额")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "订单金额") == 真)
            {
                返回微信支付信息.置入文本值 ("订单金额", 微信支付临时缓存表.取文本值 (回调标识 + "订单金额"))
                微信支付临时缓存表.删除成员 (回调标识 + "订单金额")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "用户是否关注公众号") == 真)
            {
                返回微信支付信息.置入文本值 ("用户是否关注公众号", 微信支付临时缓存表.取文本值 (回调标识 + "用户是否关注公众号"))
                微信支付临时缓存表.删除成员 (回调标识 + "用户是否关注公众号")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "回调标识") == 真)
            {
                返回微信支付信息.置入文本值 ("回调标识", 微信支付临时缓存表.取文本值 (回调标识 + "回调标识"))
                微信支付临时缓存表.删除成员 (回调标识 + "回调标识")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "订单编号") == 真)
            {
                返回微信支付信息.置入文本值 ("订单编号", 微信支付临时缓存表.取文本值 (回调标识 + "订单编号"))
                微信支付临时缓存表.删除成员 (回调标识 + "订单编号")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "用户OPENID") == 真)
            {
                返回微信支付信息.置入文本值 ("用户OPENID", 微信支付临时缓存表.取文本值 (回调标识 + "用户OPENID"))
                微信支付临时缓存表.删除成员 (回调标识 + "用户OPENID")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "微信订单号") == 真)
            {
                返回微信支付信息.置入文本值 ("微信订单号", 微信支付临时缓存表.取文本值 (回调标识 + "微信订单号"))
                微信支付临时缓存表.删除成员 (回调标识 + "微信订单号")
            }
            如果 (微信支付临时缓存表.成员是否存在 (回调标识 + "支付信息描述") == 真)
            {
                返回微信支付信息.置入文本值 ("支付信息描述", 微信支付临时缓存表.取文本值 (回调标识 + "支付信息描述"))
                微信支付临时缓存表.删除成员 (回调标识 + "支付信息描述")
            }
            微信支付临时缓存表.删除成员 (回调标识 + "返回的回调标识")
            返回 (真)
        }
        否则
        {
            返回 (假)

        }

    }

    方法 微信支付_支付成功POST <公开 类型 = 逻辑型 折叠>
    参数 来源对象 <类型 = FOFHTTP 注释 = "提供事件产生的具体来源对象">
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 成功回调URL <类型 = 文本型>
    参数 返回支付数据 <类型 = JSONCPP对象类 @默认值 = 空对象>
    参数 是否告知微信已处理回调 <类型 = 逻辑型 注释 = "这里一般默认为真即可，代表告诉微信你给FOF的回调这边已经处理了；如果为假微信会重复进行回调" @默认值 = 真>
    {
        如果 (寻找文本 (成功回调URL, 用户数据.HTTP_待发整理.请求Url, , ) != -1)
        {
            如果 (取字节集长度 (用户数据.HTTP_提交数据) <= 8000)
            {
                如果 (寻找文本 (UTF8到文本 (用户数据.HTTP_提交数据), "<trade_type><![CDATA[JSAPI]]></trade_type>", , ) != -1)
                {
                    如果 (微信支付临时缓存表.成员数 >= 9000)
                    {
                        微信支付临时缓存表.清空 ()
                        扫码登录临时缓存表.创建自文本 ("{}")

                    }

                    变量 回调内容 <类型 = 文本型>
                    回调内容 = UTF8到文本 (用户数据.HTTP_提交数据)
                    返回支付数据.清空 ()
                    变量 返回的回调标识 <类型 = 文本型>
                    返回的回调标识 = 取文本中间_ (回调内容, "<nonce_str><![CDATA[", "]]", , , )
                    如果 (返回的回调标识 == "")
                    {
                        返回 (假)
                    }
                    返回支付数据.置入文本值 ("支付状态", 取文本中间_ (回调内容, "<bank_type><![CDATA[", "]]"))
                    返回支付数据.置入文本值 ("货币种类", 取文本中间_ (回调内容, "<fee_type><![CDATA[", "]]"))
                    返回支付数据.置入文本值 ("现金支付金额", 取文本中间_ (回调内容, "<cash_fee><![CDATA[", "]]", , , ))
                    返回支付数据.置入文本值 ("订单金额", 取文本中间_ (回调内容, "<total_fee>", "</total_fee>"))
                    返回支付数据.置入文本值 ("用户是否关注公众号", 取文本中间_ (回调内容, "<is_subscribe><![CDATA[", "]]"))
                    返回支付数据.置入文本值 ("回调标识", 取文本中间_ (回调内容, "<nonce_str><![CDATA[", "]]", , , ))
                    返回支付数据.置入文本值 ("订单编号", 取文本中间_ (回调内容, "<out_trade_no><![CDATA[", "]]", , , ))
                    返回支付数据.置入文本值 ("用户OPENID", 取文本中间_ (回调内容, "<openid><![CDATA[", "]]", , , ))
                    返回支付数据.置入文本值 ("微信订单号", 取文本中间_ (回调内容, "<transaction_id><![CDATA[", "]]", , , ))
                    返回支付数据.置入文本值 ("微信整体数据", 回调内容)

                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "支付状态", 返回支付数据.取文本值 ("支付状态"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "货币种类", 返回支付数据.取文本值 ("货币种类"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "现金支付金额", 返回支付数据.取文本值 ("现金支付金额"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "订单金额", 返回支付数据.取文本值 ("订单金额"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "用户是否关注公众号", 返回支付数据.取文本值 ("用户是否关注公众号"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "回调标识", 返回支付数据.取文本值 ("回调标识"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "订单编号", 返回支付数据.取文本值 ("订单编号"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "用户OPENID", 返回支付数据.取文本值 ("用户OPENID"))
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "微信订单号", 返回支付数据.取文本值 ("微信订单号"))
                    变量 支付信息描述 <类型 = 文本型
                            值 = "用户是否关注公众账号，Y-关注，N-未关注\r\n支付的金额以：【订单金额】为主，单位为分\r\n货币类型参考：https://pay.weixin.qq.com/wiki/doc/api/jsapi.php?chapter=4_2">
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "支付信息描述", 支付信息描述)
                    微信支付临时缓存表.置入文本值 (返回的回调标识 + "返回的回调标识", 返回的回调标识)
                    如果 (是否告知微信已处理回调 == 真)
                    {
                        用户数据.HTTP_待发整理.文件后缀 = "html"
                        变量 返回信息 <类型 = 文本型
                                值 = "<xml>\r\n    <return_code>\r\n        <![CDATA[SUCCESS]]>\r\n    </return_code>\r\n    <return_msg>\r\n        <![CDATA[OK]]>\r\n    </return_msg>\r\n</xml>">
                        来源对象.发送页面数据 (服务句柄, 连接ID, 文本到UTF8 (返回信息, 假), 用户数据, )

                    }
                    返回 (真)

                }
                返回 (假)
            }
            返回 (假)
        }
        返回 (假)
    }

