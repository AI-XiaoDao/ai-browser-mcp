    方法 GetQQ互联处理_软件 <公开 类型 = 逻辑型 注释 = "本方法为软件专用，会自动进行相关处理，不需要在关注【QQ登录成功】的事件" 折叠>
    参数 来源对象 <类型 = FOFHTTP>
    参数 服务句柄 <类型 = 变整数>
    参数 连接ID <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 用户数据 <类型 = FOFHTTP_用户数据>
    参数 登录成功URL协议 <类型 = 文本型 注释 = "登录成功进行301跳转的标识，例如输入：qq123"
            注释 = "则整体301连接为：/qq123?openid=xxxxx&Access_Token=xxxxx&refresh_token=xxxxx&name=QQ昵称&image=QQ头像"
            注释 = "注意：其中QQ昵称和QQ头像为十六进制文本">
    参数 登录成功页面提示 <类型 = 文本型 注释 = "301跳转后页面上显示的提示信息" 注释 = "可以是单纯的文本，也可以是html代码">
    {
        // 判断QQ回调URL====
        如果 (ID == "" && KEY == "")
        {
            返回 (假)
        }
        如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, 回调2) != -1)
        {
            变量 辅助 <类型 = FOFHTTP_HTTP辅助>
            变量 互联信息 <类型 = QQ互联数据>
            互联信息 = QQ互联_登录成功获取QQ信息 (辅助.取参数 ("code", 用户数据.HTTP_待发整理.解析参数))
            如果 (互联信息.openid != "")
            {
                用户数据.HTTP_待发整理.文件后缀 = "html"
                来源对象.发送301跳转 (服务句柄, 连接ID, "/" + 登录成功URL协议 + "?openid=" + 互联信息.openid + "&Access_Token=" + 互联信息.Access_Token + "&refresh_token=" + 互联信息.refresh_token + "&name=" + 字节集到十六进制文本 (文本到UTF8 (互联信息.QQ昵称, 假)) + "&image=" + 字节集到十六进制文本 (文本到UTF8 (互联信息.QQ头像, 假)) + "", 用户数据)
                返回 (真)

            }

        }
        如果 (寻找文本 (用户数据.HTTP_待发整理.请求Url, 登录成功URL协议) != -1)
        {
            用户数据.HTTP_待发整理.文件后缀 = "html"
            来源对象.发送页面数据 (服务句柄, 连接ID, 文本到UTF8 (登录成功页面提示, 假), 用户数据, )
            返回 (真)

        }
        返回 (假)
        // 判断QQ回调URL====


    }

