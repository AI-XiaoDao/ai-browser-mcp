        文本指针 = 取字节集指针 (数据)
        文本长度 = 取字节集长度 (数据)
        @ return LoadFromStringA((const char*)@<文本指针>,@<文本长度>);
    }

    方法 创建自文本2 <公开 类型 = 逻辑型 注释 = "创建数据之前会清空原有的数据，该命令可以在对象频繁在循环中创建时使用" 折叠 @禁止流程检查 = 真>
