    方法 取对象值 <公开 静态 注释 = "取出指定键名的JSONCPP对象类" 折叠 @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = JSONCPP对象类>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径.">
    参数 保存取出的对象 <类型 = JSONCPP对象类 注释 = "取出后的对象值保存在此参数中.">
    {
        @ @<所操作的本对象>.GetJsonMap(@<键名称>,@<保存取出的对象>)
    }

    方法 取数组值 <公开 静态 注释 = "取出指定键名的JSONCPP数组类" 折叠 @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = JSONCPP对象类>
    参数 键名称 <类型 = 文本型 注释 = "提供键名,支持传递JSON路径.">
    参数 保存取出的对象 <类型 = JSONCPP数组类 注释 = "取出后的数组值保存在此参数中.">
    {
        @ @<所操作的本对象>.GetJsonList(@<键名称>,@<保存取出的对象>)
    }

    方法 取所有键名 <公开 注释 = "把JSON对象里面的所有\"键名称\"都加入到文本数组类中." 折叠>
    参数 键名数组 <类型 = 文本数组类 注释 = "结果保存在此参数中.">
    {
        变量 utf8 <类型 = 字节集类>
        @ Json::Value::Members mb = GetKeyArray();
        @ for ( Json::Value::Members::iterator it = mb.begin();it != mb.end();it++)
        @ {
        @     @<utf8>.CopyFrom ( it->c_str(),it->length());
        键名数组.加入成员 (UTF8到文本 (utf8))
        @ }
    }
}

类 JSONCPP类型 <公开 注释 = "用来判断键值类型" 折叠 折叠2 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 空 <公开 值 = 0 注释 = "表示空值">
    常量 整数值 <公开 值 = 1 注释 = "表示整数值">
    常量 无符号整数值 <公开 值 = 2 注释 = "表示无符号整数值">
    常量 小数值 <公开 值 = 3 注释 = "表示小数型">
    常量 文本值 <公开 值 = 4 注释 = "表示文本型">
    常量 逻辑值 <公开 值 = 5 注释 = "表示逻辑型">
    常量 键值列表 <公开 值 = 6 注释 = "表示JSONCPP数组类">
    常量 键值表 <公开 值 = 7 注释 = "表示JSONCPP对象类">
}

类 类_键值数组 <公开 基础类 = 对象数组模板类 注释 = "最基本的对象类数组" @模板实现类 = "类_键值表">

类 类_键值列表 <公开 基础类 = JSONCPP数组类>

类 类_键值表 <公开 基础类 = JSONCPP对象类 折叠>
{

    #
}

类 类_正则处理 <公开 折叠>
{
    变量 obj <类型 = COM对象类>
    变量 过度对象 <类型 = COM对象类>
    变量 局_被搜索文本 <类型 = 文本型>

    方法 创建 <公开 类型 = 逻辑型 折叠>
    参数 正则表达式文本 <类型 = 文本型>
    参数 被搜索的文本 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 @默认值 = 真>
    参数 是否匹配多行 <类型 = 逻辑型 @默认值 = 真>
    参数 是否全局匹配 <类型 = 逻辑型 @默认值 = 真>
    {
        obj.清除 ()
        obj.创建 ("VBScript.RegExp")
        obj.写属性 ("IgnoreCase", 是否区分大小写)
        obj.写属性 ("Multiline", 是否匹配多行)
        obj.写属性 ("Global", 是否全局匹配)
        obj.写属性 ("Pattern", 正则表达式文本)
        过度对象 = obj.方法 ("Execute", COM对象类, 被搜索的文本)
        局_被搜索文本 = 被搜索的文本
        返回 (过度对象.是否为空 () == 假)
    }

    方法 替换 <公开 类型 = 文本型 折叠>
    参数 用作替换的文本 <类型 = 文本型>
    {
        变量 Val <类型 = COM变体型>
        Val = obj.方法 ("Replace", COM变体型, 局_被搜索文本, 用作替换的文本)
        返回 (Val.取值 (文本型))

    }

    方法 取匹配数量 <公开 类型 = 整数 折叠>
    {
        返回 (过度对象.读无参数属性 ("Count", 整数))
    }

    方法 取匹配文本 <公开 类型 = 文本型 折叠>
    参数 匹配索引 <类型 = 整数>
    {
        变量 Match <类型 = COM对象类>
        变量 Val <类型 = COM变体型>
        Match = 过度对象.读属性 ("Item", COM对象类, 匹配索引)
        Val = Match.读无参数属性 ("Value", COM变体型)
        返回 (Val.取值 (文本型))
    }

    方法 取子匹配文本 <公开 类型 = 文本型 折叠>
    参数 匹配索引 <类型 = 整数>
    参数 子表达式索引 <类型 = 整数>
    {
        变量 Match <类型 = COM对象类>
        变量 SubMatches <类型 = COM对象类>
        变量 Val <类型 = COM变体型>
        Match = 过度对象.读属性 ("Item", COM对象类, 匹配索引 - 1)
        SubMatches = Match.读无参数属性 ("SubMatches", COM对象类)
        Val = SubMatches.读属性 ("Item", COM变体型, 子表达式索引 - 1)
        返回 (Val.取值 (文本型))
    }

    方法 取子匹配数量 <公开 类型 = 整数 折叠>
    {
        变量 Match <类型 = COM对象类>
        变量 SubMatches <类型 = COM对象类>
        变量 Val <类型 = COM变体型>
        Match = 过度对象.读属性 ("Item", COM对象类, 0)
        SubMatches = Match.读无参数属性 ("SubMatches", COM对象类)
        Val = SubMatches.读无参数属性 ("Count", COM变体型)
        返回 (Val.取值 (整数))
    }

    方法 清除 <公开 折叠>
    {
        obj.清除 ()
        局_被搜索文本 = ""
    }
}
