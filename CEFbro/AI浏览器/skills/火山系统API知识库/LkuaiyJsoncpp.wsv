    # @end

    变量 内部_启用全局空数组不为NULL <静态 类型 = 逻辑型 值 = 假>

    方法 启用顺序输出 <公开 静态 注释 = "调用本方法以启用JSON顺序输出文本,即\"到可读文本\"时键值的顺序将遵循添加该键值时的顺序." @视窗.预定义宏 = "JSON_CPP_SEQUE_OUTPUT">

    方法 启用线程安全 <公开 静态 注释 = "   如果调用了此方法,那么模块内部会自动加锁,多线程操作时会处于安全状态." 注释 = "   如果不调用此方法,则模块不保证线程安全."
            注释 = "   此时用户应该自行确保不同线程操作的时候,不要出现一个线程读一个线程写,另外一个线程" 注释 = "删除的情况,否则会引起程序的崩溃." 折叠2 @视窗.预定义宏 = "JSON_CPP_THREAD_SAFE">

    方法 启用全局空数组不为NULL <公开 静态 折叠>
    {
        内部_启用全局空数组不为NULL = 真
    }

    方法 到可读文本_ <类型 = 文本型 注释 = " 把JSON转换成可读文本并格式化数据." 注释 = " 例如:" 注释 = " {" 注释 = "  \"query\": \"VolDev\","
            注释 = "  \"locations\": [" 注释 = "     100," 注释 = "     101" 注释 = "  ]" 注释 = " }" 折叠 折叠2 @嵌入式方法 = "">
    参数 是否格式化 <类型 = 逻辑型 注释 = "提供真将会进行格式化操作,则会用空格换行进行格式化." @默认值 = 假>
    参数 是否不转义 <类型 = 逻辑型 注释 = "如果假,遇到中文则会以这种方式显示\"\\0xfbfe\\0xfafd\",填写真将显示为正常的中文字符." @默认值 = 真>
    {
        @ @an<CVolString>( @sn<this>.ToStringW(@<是否格式化>,@<是否不转义>).c_str() )
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "把JSON格式化成UTF8的字节集" 折叠 @禁止流程检查 = 真>
    参数 是否格式化 <类型 = 逻辑型 注释 = "如果格式化,则会用空格换行进行格式化操作." @默认值 = 假>
    参数 是否使用UTF8编码 <类型 = 逻辑型 注释 = "如果真将进行UTF8编码字节集." @默认值 = 假>
    {
        @ std::string& str = ToStringA(@<是否格式化>,@<是否使用UTF8编码>);
        @ return CVolMem (str.c_str(),str.length());
    }

    方法 创建自文本 <公开 类型 = 逻辑型 注释 = "从JSON文本创建,返回是否成功." 折叠 @禁止流程检查 = 真>
