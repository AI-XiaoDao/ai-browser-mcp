类 高性能缓存表事件 <公开 基础类 = 高性能缓存表基础库 注释 = "全局只能定义一个" 折叠 折叠2 @文档 = "category = \"辅助类\"" @视窗.后缀文本 = "CMMKVEventBase">
{

    # @begin
    # <> <include>
    # virtual void ContentChangeHandler(const char* lpszmmapID)
    # {
    #     @<内容变化>(CVolString (lpszmmapID));
    # }
    # virtual int ErrorHandler(const char* lpszmmapID, int errorType)
    # {
    #     return @<遇到错误>(CVolString (lpszmmapID),errorType);
    # }
    # virtual void LogHandler(int level, const char* file, int line, const char* function, const char* message)
    # {
    #     @<日志内容>(level,CVolString (file),line,CVolString (file),CVolString (file));
    # }
    # <> </include>
    # @end

    常量 启用日志 <公开 类型 = 整数 值 = 1 注释 = "事件类型常量">
    常量 启用遇到错误 <公开 类型 = 整数 值 = 2 注释 = "事件类型常量">
    常量 启用内容变化 <公开 类型 = 整数 值 = 4 注释 = "事件类型常量">

    方法 类_初始化
    {
        @ MMKVTool_BindEventClass(this);
    }

    方法 启用事件 <公开 注释 = "是否启用键值表事件监听." @嵌入式方法 = "">
    参数 事件类型 <类型 = 整数 注释 = "事件类型共有3个：" 注释 = "   高性能缓存表事件.启用日志" 注释 = "   高性能缓存表事件.启用遇到错误" 注释 = "   高性能缓存表事件.启用内容变化"
            注释 = " 如果要同时启用三个事件,可以将其相加起来." @默认值 = 7>
    参数 是否启用 <类型 = 逻辑型 @默认值 = 真>
    {
        @ MMKVTool_EnableEvent(@<事件类型>,@<是否启用>)
    }

    方法 内容变化 <公开 定义事件 类型 = 整数 注释 = "当内容被改变时触发本事件.">
    参数 表名称 <类型 = 文本型 注释 = "返回被改变的表名称">

    方法 遇到错误 <公开 定义事件 类型 = 整数 注释 = "遇到错误时触发本事件." 返回值注释 = "返回0表示终止,返回1表示恢复.">
    参数 表名称 <类型 = 文本型 注释 = "返回表名称">
    参数 错误类型 <类型 = 整数 注释 = "返回0表示循环冗余校验码(CRC)出错,返回1表示获取文件长度失败.">

    方法 日志内容 <公开 定义事件 类型 = 整数 注释 = "产生日志时触发本事件.">
    参数 日志等级 <类型 = 高性能缓存表日志 注释 = "返回日志等级">
    参数 文件名称 <类型 = 文本型 注释 = "返回文件名称">
    参数 行号 <类型 = 整数 注释 = "返回行号">
    参数 函数名称 <类型 = 文本型 注释 = "返回名称">
    参数 消息内容 <类型 = 文本型 注释 = "返回消息内容">
}

类 高性能缓存表日志 <公开 注释 = "用于存储高性能缓存表日志等级" 折叠 折叠2 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 调试 <公开 值 = 0>
    常量 信息 <公开 值 = 1>
    常量 警告 <公开 值 = 2>
    常量 错误 <公开 值 = 3>
    常量 无 <公开 值 = 4>
}

类 高性能缓存表 <公开 基础类 = 高性能缓存表基础库 注释 = "腾讯开源项目(MMKV)高性能缓存表" 折叠>
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVolMMKVWapper)
    # <> <include>
    # inline_ void* GetData()
    # {
    #     return data().GetData();
    # }
    # inline_ void SetData(void * pData)
    # {
    #     data().SetData(pData);
    # }
    # <> </include>
    # @end

    方法 置保存路径 <公开 静态 注释 = "设置数据存储路径,在使用键值表之前必须首先设置数据目录." 注释 = "注意: 本路径为全局路径,在所有高性能缓存表对象中共享." @嵌入式方法 = "">
    参数 目录 <类型 = 文本型>
    {
        @ MMKVTool_InitDataPath(@<目录>)
    }

    常量 单进程模式 <公开 类型 = 整数 值 = 1 注释 = "本常量用于打开方法.">
    常量 多进程模式 <公开 类型 = 整数 值 = 2 注释 = "本常量用于打开方法.">

    方法 打开 <公开 注释 = "打开一个数据表,一个键值表对象只能打开一个表,想要操作多个键值表需要定义多个键值表变量." @禁止流程检查 = 真>
    参数 表名称 <类型 = 文本型 注释 = "类似数据库的表名称,如果为空,则打开默认的表" @默认值 = "">
    参数 模式 <类型 = 整数 注释 = "参考本类中的常量值,提供\"高性能缓存表.单进程模式\"或\"高性能缓存表.多进程模式\"." @默认值 = 单进程模式>
    参数 加密密码 <类型 = 文本型 注释 = "可空" @默认值 = "">
    {
        关闭 ()
        @ SetData( MMKVTool_Open( @<表名称>.IsEmpty () ? NULL : (const char*)CU8String (@<表名称>.GetText ()).GetText()  ,@<模式>, @<加密密码>.IsEmpty () ? NULL : (const char*)CU8String (@<加密密码>.GetText ()).GetText()  ) );
    }

    方法 关闭 <公开 静态 注释 = "关闭被打开的表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    {
        @ @<所欲操作的本对象>.data().Close()
    }

    方法 取键数量 <公开 静态 类型 = 长整数 注释 = "取出当前键值表的键数量" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    {
        @ MMKVTool_Count(@<所欲操作的本对象>.GetData())
    }

    方法 取总大小 <公开 静态 类型 = 长整数 注释 = "取出当前表总大小" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    {
        @ MMKVTool_TotalSize(@<所欲操作的本对象>.GetData())
    }

    方法 取实际大小 <公开 静态 类型 = 长整数 注释 = "取当前表实际大小" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    {
        @ MMKVTool_ActualSize(@<所欲操作的本对象>.GetData())
    }

    方法 是否存在表 <公开 类型 = 逻辑型 注释 = "判断指定表名是否存在" @禁止流程检查 = 真>
    参数 表名称 <类型 = 文本型>
    参数 相对路径 <类型 = 文本型 @默认值 = "">
    {
        @ return MMKVTool_isFileValid((const char*)CU8String (@<表名称>.GetText ()).GetText(),(@<相对路径>.IsEmpty () ? NULL : @<相对路径>.GetText()));
    }

    方法 是否存在键 <公开 静态 类型 = 逻辑型 注释 = "判断当前表是否存在指定键名" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_IsExist(@<所欲操作的本对象>.GetData(),CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 删除键 <公开 静态 注释 = "删除指定键" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_RemoveValue(@<所欲操作的本对象>.GetData(),CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 清空 <公开 静态 注释 = "清空当前表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    {
        @ MMKVTool_ClearALL(@<所欲操作的本对象>.GetData())
    }

    方法 清空缓存 <公开 静态 注释 = "清理垃圾数据,释放空间,数据过多时防止表越来越大." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
