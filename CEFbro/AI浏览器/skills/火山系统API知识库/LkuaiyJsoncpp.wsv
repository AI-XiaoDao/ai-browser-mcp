类 JSONCPP对象类 <公开 基础类 = JSONCPP基础类 注释 = "通过本类可对JSON对象进行操作." 折叠>
{
    方法 类_初始化 <折叠>
    {
        如果 (内部_启用全局空数组不为NULL == 真)
        {
            置入文本值 ("kkcosappfoflkuaiyun", "")
            删除成员 ("kkcosappfoflkuaiyun")

        }
    }

    方法 到可读文本 <公开 类型 = 文本型 折叠>
    参数 是否格式化 <类型 = 逻辑型 注释 = "提供真将会进行格式化操作,则会用空格换行进行格式化." @默认值 = 假>
    参数 是否不转义 <类型 = 逻辑型 注释 = "如果假,遇到中文则会以这种方式显示\"\\0xfbfe\\0xfafd\",填写真将显示为正常的中文字符." @默认值 = 真>
    {
        如果 (内部_启用全局空数组不为NULL == 真)
        {
            变量 可读文本 <类型 = 文本型>
            可读文本 = 到可读文本_ (是否格式化, 是否不转义)
            可读文本 = 删首尾空 (可读文本)
            如果 (可读文本 == "")
            {
                返回 ("{}")

            }
            返回 (可读文本)

        }
        否则
        {
            返回 (到可读文本_ (是否格式化, 是否不转义))

        }

    }

