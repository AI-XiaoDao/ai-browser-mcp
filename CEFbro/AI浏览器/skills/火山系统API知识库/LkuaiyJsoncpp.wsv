    方法 置入小数值 <公开 静态 类型 = 逻辑型 注释 = "将指定的小数值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 小数 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetDouble(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>)
    }

    方法 取小数值 <公开 静态 类型 = 小数 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_GetDouble(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 置入文本值 <公开 静态 类型 = 逻辑型 注释 = "将指定的文本值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 文本型 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),(const char*)CU8String (@<值>.GetText ()).GetText())
    }

    方法 取文本值 <公开 静态 类型 = 文本型 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    {
        变量 返回值 <类型 = 文本型>
        @ const char* pText = MMKVTool_GetString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText());
        @ if (pText != NULL)
        @ { 
        @     @<返回值>.SetText (pText);
        @     MMKVTool_FreeString (pText);
        @ }
        返回 (返回值)
    }

    方法 置入字节集 <公开 静态 类型 = 逻辑型 注释 = "将指定的字节集置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 字节集类 注释 = "提供要置入的键值">
    {
        @ return MMKVTool_SetBin(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),(void*)@<值>.GetPtr(),(int)@<值>.GetSize());
    }

    方法 取字节集 <公开 静态 类型 = 字节集类 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    {
        变量 结果变量 <类型 = 字节集类>
        取字节集2 (所欲操作的本对象, 键名称, 结果变量)
        返回 (结果变量)
    }

    方法 取字节集2 <公开 静态 注释 = "取出指定键名所对应的键值" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    参数 结果存储变量 <类型 = 字节集类 注释 = "用作保存所获取的字节集数据">
    {
        @ @<结果存储变量>.Free ();
        @ int nDataSize = 0;
        @ const char* pb = MMKVTool_GetBin(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),&nDataSize);
        @ if (pb != NULL && nDataSize > 0)
        @ {
        @     @<结果存储变量>.Append (pb,nDataSize);
        @     MMKVTool_FreeBin (pb);
        @ }
    }

    方法 置入数组值 <公开 静态 类型 = 逻辑型 注释 = "将指定的文本数组置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    参数 值 <类型 = 高性能缓存数组类>
    {
        @ MMKVTool_SetVectorString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>.GetData())
    }

    方法 取数组值 <公开 静态 注释 = "通过键名取出文本数组" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 键名称 <类型 = 文本型>
    参数 用来保存文本数组 <类型 = 高性能缓存数组类 注释 = "结果保存在此参数中">
    {
        @ MMKVTool_GetVectorString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<用来保存文本数组>.GetData())
    }

    方法 取所有键名 <公开 静态 注释 = "取出当前表中所有键名" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能缓存表>
    参数 数组 <类型 = 高性能缓存数组类 注释 = "结果保存在此参数中">
    {
        @ MMKVTool_GetAllKey(@<所欲操作的本对象>.GetData(),@<数组>.GetData())
    }
}

类 高性能缓存数组类 <公开 基础类 = 高性能缓存表基础库 注释 = "此类可以配合\"高性能缓存表\"使用,也可以单独使用,作用和\"文本数组类\"一致,但性能更高." 折叠>
{

    # @begin
    # <> <include>
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     MMKVVectorStringTool_CopyConstruct(m_pData,objCopyFrom.m_pData);
    # }
    # public:
    # inline_ void* GetData()
    # {
    #     return m_pData;
    # }
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ m_pData = MMKVVectorStringTool_New();
    }

    方法 类_清理
    {
        @ MMKVVectorStringTool_Delete(m_pData);
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回当前已有成员数目" @嵌入式方法 = "">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    {
        @ MMKVVectorStringTool_GetCount(@<欲操作的本对象>.GetData())
    }

    方法 取成员 <公开 静态 类型 = 文本型 注释 = "返回所指定索引位置处的成员值" @禁止流程检查 = 真>
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 索引 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ CVolString str;
        如果 (索引 >= 0 && 索引 < 欲操作的本对象.取成员数 ())
        {
            @ str.SetText (MMKVVectorStringTool_GetString(@<欲操作的本对象>.GetData(),@<索引>));
        }
        @ return str;
    }

    方法 加入成员 <公开 静态 注释 = "将一个文本型的成员值加入到本数组的尾部">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲添加成员值 <类型 = 文本型 注释 = "提供要添加到成员">
    {
        @ MMKVVectorStringTool_PushString(@<欲操作的本对象>.GetData(),(const char*) CU8String (@<所欲添加成员值>.GetText ()).GetText());
    }

    方法 删除成员 <公开 静态 注释 = "删除数组中所指定索引位置处的成员">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 索引 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    {
        如果 (索引 >= 0 && 索引 < 欲操作的本对象.取成员数 ())
        {
            @ MMKVVectorStringTool_Erase(@<欲操作的本对象>.GetData(),@<索引>);
        }
    }

    方法 删除所有成员 <公开 静态 注释 = "删除当前数组中所有成员" @嵌入式方法 = "">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    {
        @ MMKVVectorStringTool_Clear(@<欲操作的本对象>.GetData())
    }

    方法 添加数组 <公开 静态 注释 = "将另一个高性能文本数组中的内容添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲添加的数组 <类型 = 高性能缓存数组类>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
        }
    }

    方法 添加文本数组 <公开 静态 注释 = "将另一个文本数组中的内容添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲添加的数组 <类型 = 文本数组类>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
        }
    }

    方法 对比删除重复成员 <公开 静态 注释 = "将本数组中在\"所欲检查的数组\"内已经存在的成员删除掉">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲检查的数组 <类型 = 高性能缓存数组类 注释 = "提供用作检查重复成员的文本数组">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        逆向计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (所欲检查的数组.查找首成员 (欲操作的本对象.取成员 (取循环索引 ()), 是否区分大小写) != -1)
            {
                欲操作的本对象.删除成员 (取循环索引 ())
            }
        }
    }

    方法 查找删除成员 <公开 静态 类型 = 逻辑型 注释 = "查找第一个等于所指定值的成员,如果找到则将其删除并返回真,否则返回假.">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲查找文本 <类型 = 文本型 注释 = "提供所欲查找并删除的成员值">
    {
        计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (欲操作的本对象.取成员 (取循环索引 ()) == 所欲查找文本)
            {
                欲操作的本对象.删除成员 (取循环索引 ())
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 添加数组独有成员 <公开 静态 注释 = "将另一个文本数组中在本数组内不存在的成员添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲添加的数组 <类型 = 高性能缓存数组类>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            如果 (欲操作的本对象.查找首成员 (所欲添加的数组.取成员 (取循环索引 ()), 是否区分大小写) == -1)
            {
                欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
            }
        }
    }

    方法 查找首成员 <公开 静态 类型 = 整数 注释 = "正向查找等于所指定值的第一个成员,找到返回其索引位置,未找到返回-1.">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (文本比较 (欲操作的本对象.取成员 (取循环索引 ()), 所欲查找的成员值, 是否区分大小写) == 0)
            {
                返回 (取循环索引 ())
            }
        }
        返回 (-1)
    }

    方法 查找尾成员 <公开 静态 类型 = 整数 注释 = "逆向查找等于所指定值的最后一个成员,找到返回其索引位置,未找到返回-1.">
    参数 欲操作的本对象 <类型 = 高性能缓存数组类>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        逆向计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (文本比较 (欲操作的本对象.取成员 (取循环索引 ()), 所欲查找的成员值, 是否区分大小写) == 0)
            {
                返回 (取循环索引 ())
            }
        }
        返回 (-1)
    }
}

