类 JSONCPP基础类 <公开 注释 = "不要直接使用本类,请使用\"JSONCPP数组类\"或\"JSONCPP对象类\",来操作JSON数据." 注释 = "2021.5.12升级至jsoncpp-1.9.4" 折叠
        @视窗.头文件搜寻目录 = "..\\..\\shared\\extern_lib\\common\\json\\2\\jsoncpp-1.9.7\\include" @视窗.外部头文件 = "JsoncppTool.h"
        @视窗.外部源文件 = "..\\..\\shared\\extern_lib\\common\\json\\2\\jsoncpp-1.9.7\\src\\json_reader.cpp\r\n..\\..\\shared\\extern_lib\\common\\json\\2\\jsoncpp-1.9.7\\src\\json_value.cpp\r\n..\\..\\shared\\extern_lib\\common\\json\\2\\jsoncpp-1.9.7\\src\\json_writer.cpp\r\n..\\..\\shared\\extern_lib\\common\\json\\2\\jsoncpp-1.9.7\\src\\JsoncppTool.cpp"
        @视窗.需求VS版本 = "14-" @视窗.后缀文本 = "public CJsonObject">
{

    # @begin
    # <> <include>
