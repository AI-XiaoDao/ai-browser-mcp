类 JSONCPP数组类 <公开 基础类 = JSONCPP基础类 注释 = "通过本类可对JSON数组进行操作" 折叠>
{
    方法 类_初始化 <折叠>
    {
        如果 (内部_启用全局空数组不为NULL == 真)
        {
            置入文本值 ("kkcosappfoflkuaiyun")
            删除成员 (0)

        }
    }

    方法 到可读文本 <公开 类型 = 文本型 折叠>
    参数 是否格式化 <类型 = 逻辑型 注释 = "提供真将会进行格式化操作,则会用空格换行进行格式化." @默认值 = 假>
    参数 是否不转义 <类型 = 逻辑型 注释 = "如果假,遇到中文则会以这种方式显示\"\\0xfbfe\\0xfafd\",填写真将显示为正常的中文字符." @默认值 = 真>
    {
        如果 (内部_启用全局空数组不为NULL == 真)
        {
            变量 可读文本 <类型 = 文本型>
            可读文本 = 到可读文本_ (是否格式化, 是否不转义)
            可读文本 = 删首尾空 (可读文本)
            如果 (可读文本 == "")
            {
                返回 ("[]")

            }
            返回 (可读文本)

        }
        否则
        {
            返回 (到可读文本_ (是否格式化, 是否不转义))

        }

    }

    方法 到文本数组 <公开 静态 注释 = "  将当前JSON数组的每个成员取出,转换成文本数组," 注释 = "并将其存放到所指定的结果文本数组参数中." 折叠 折叠2>
    参数 所操作的本对象 <类型 = JSONCPP数组类>
    参数 结果数组 <类型 = 文本数组类 注释 = "结果保存在此参数中">
    {
        结果数组.删除所有成员 ()
        变量 索引值 <类型 = 整数>
        循环 (, 所操作的本对象.成员数, 索引值)
        {
            结果数组.加入成员 (所操作的本对象.取文本值 (索引值))
        }
    }

    方法 删除成员 <公开 静态 注释 = "删除指定索引位置处的成员" 折叠 编辑时信息 = "8DFF7, 0, 0, 0" @嵌入式方法 = "">
