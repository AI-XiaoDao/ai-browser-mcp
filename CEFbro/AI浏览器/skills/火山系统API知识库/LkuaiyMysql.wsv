    方法 检索字符串 <公开 类型 = 文本型
            注释 = "检索字符串，该字符串提供了关于最近执行查询的信息，但仅对这里列出的语句有效。对于其他语句，mysql_info()返回NULL。字符串的格式取决于查询的类型，如本节所述。数值仅是说明性的，字符串包含与查询相适应的值。"
            注释 = "例如：" 注释 = "·         INSERT INTO ... SELECT ..." 注释 = "" 注释 = "字符串格式：记录，100；副本，0；警告，0" 注释 = ""
            注释 = "·         INSERT INTO ... VALUES (...),(...),(...)..." 注释 = "" 注释 = "字符串格式：记录，3；副本，0；警告，0" 注释 = ""
            注释 = "·         LOAD DATA INFILE ..." 注释 = "" 注释 = "字符串格式：记录，1；删除，0；跳过，0；警告，0" 注释 = "" 注释 = "·         ALTER TABLE"
            注释 = "" 注释 = "字符串格式：记录，3；副本，0；警告，0" 注释 = "" 注释 = "·         UPDATE" 注释 = "" 注释 = "字符串格式：匹配行，40；更改，40；警告，0" 折叠 折叠2
            @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    {
        @ if((MYSQL *)@<MYSQL池子句柄>==NULL)
        @ {
        @ return _T ("");
        @ }
        @ const char* Text = mysql_info((MYSQL *)@<MYSQL池子句柄>);  //可能会返回NULL.
        @ if (Text != NULL) return @an<CVolString> (Text);
        @ return _T ("");
    }

