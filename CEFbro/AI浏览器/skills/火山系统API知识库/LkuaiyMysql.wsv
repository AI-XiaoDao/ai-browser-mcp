    方法 连接MYSQL <类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    参数 数据库地址 <类型 = 文本型 注释 = "数据库地址">
    参数 数据库名称 <类型 = 文本型 注释 = "数据库名称">
    参数 用户名 <类型 = 文本型 注释 = "用户名">
    参数 密码 <类型 = 文本型 注释 = "密码">
    参数 端口 <类型 = 整数 注释 = "链接端口">
    {
        @ CU8String u8str (@<数据库地址>.GetText ());
        @ const U8CHAR* Host = u8str.GetText ();

        @ CU8String Useru (@<用户名>.GetText ());
        @ const U8CHAR* User = Useru.GetText ();

        @ CU8String passwdu (@<密码>.GetText ());
        @ const U8CHAR* passwd = passwdu.GetText ();

        @ CU8String dbu (@<数据库名称>.GetText ());
        @ const U8CHAR* db = dbu.GetText ();

        // @ return (@dt<变整数>)mysql_real_connect((MYSQL *)@<MYSQL池子句柄>,Host,User,passwd, db,@<端口>,NULL,0);
        @ if((@dt<变整数>)mysql_real_connect((MYSQL *)@<MYSQL池子句柄>,Host,User,passwd, db,@<端口>,NULL,0)==0){return false;}
        返回 (真)

        // 数据库测试.连接 ("localhost", "fof", "root", "root", 3306, 10, MYSQL连接选项.MYSQL选项_默认字符集名, "UTF8")
        变量 "// 记录集" <类型 = 数据库_LibMySQL记录集>
        变量 "// 句柄" <类型 = 变整数>
        // 句柄 = 数据库测试.获取句柄 ()
        // 数据库测试.执行SQL语句 (句柄, "select * from fofusername where F_UserName='asd的方式'")
        // 记录集.获取记录集 (句柄)
        // 调试输出 (记录集.读文本 ("F_UserName"))
        // 调试输出 (记录集.读文本 ("F_Password"))
        // 记录集.到下一条 ()
        // 调试输出 (记录集.读文本 ("F_UserName"))
        // 调试输出 (记录集.读文本 ("F_Password"))

        // 记录集.释放记录集 ()
        // 数据库测试.释放句柄 (句柄)

    }

