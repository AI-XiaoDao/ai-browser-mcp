类 数据库_LibMySQL记录集 <公开 基础类 = MySqlDLL 折叠>
{
    变量 keys <类型 = 文本数组类>
    变量 keystext <类型 = 文本数组类>
    变量 记录集句柄 <类型 = 变整数>

    方法 获取键值表 <公开 类型 = 类_键值数组 注释 = "本方法可以将所有的数据保存到键值列表中，注意：使用本命令可以直接使用，使用完成后不用释放记录集" 注释 = "因为没有使用获取记录集，就不用释放记录集"
            注释 = "本方法的使用案例请观看本方法内屏蔽的示例代码" 注释 = "使用方法参考本案例：https://www.lkuaiy.com/rsdetails?id=16064486821870&page=1" 返回值注释 = "返回键值列表"
            折叠 折叠2>
    参数 MYSQL池子句柄 <类型 = 变整数>
    {
        变量 记录集数据 <类型 = 数据库_LibMySQL记录集>
        记录集数据.获取记录集 (MYSQL池子句柄)

        变量 记录数 <类型 = 整数>
        变量 循环变量 <类型 = 整数>
        变量 键值表 <类型 = 类_键值表>
        变量 键值列表 <类型 = 类_键值数组>
        记录数 = 记录集数据.取记录数 ()
        循环 (0, 记录数, 循环变量, 1)
        {
            变量 内部循环 <类型 = 整数>
            循环 (0, 记录集数据.读字段集合 ().取成员数 (), 内部循环, 1)
            {
                变量 字段 <类型 = 文本型>
                变量 内容 <类型 = 文本型>
                字段 = 记录集数据.读字段集合 ().取成员 (内部循环)
                内容 = 记录集数据.读内容集合 ().取成员 (内部循环)
                键值表.置入文本值 (字段, 内容)
                键值表.置入文本值 (到文本 (内部循环), 内容)

            }

            键值列表.加入成员 (键值表)
            键值表.清空 ()
            记录集数据.到下一条 ()

        }

        记录集数据.释放记录集 ()
        返回 (键值列表)


    }

    方法 获取JSON文本 <公开 类型 = 文本型 注释 = "直接返回JSON的文本数组" 注释 = "使用方法参考本案例：https://www.lkuaiy.com/rsdetails?id=34821606472173&page=1"
            返回值注释 = "直接返回JSON的文本数组" 折叠 折叠2>
    参数 MYSQL池子句柄 <类型 = 变整数>
    参数 JSON字段名 <类型 = 文本型>
    {
        变量 记录集数据 <类型 = 数据库_LibMySQL记录集>
        记录集数据.获取记录集 (MYSQL池子句柄)
        变量 记录数 <类型 = 整数>
        变量 循环变量 <类型 = 整数>
        变量 键值表 <类型 = 类_键值表>
        变量 JSON文本 <类型 = 文本型>
        变量 JSON最终文本 <类型 = 文本型 值 = "{\r\n   \"表名替换\": \r\n   [\r\n\t文本内容替换\r\n   ]\r\n}">
        记录数 = 记录集数据.取记录数 ()
        循环 (0, 记录数, 循环变量, 1)
        {
            变量 内部循环 <类型 = 整数>
            循环 (0, 记录集数据.读字段集合 ().取成员数 (), 内部循环, 1)
            {
                变量 字段 <类型 = 文本型>
                变量 内容 <类型 = 文本型>
                字段 = 记录集数据.读字段集合 ().取成员 (内部循环)
                内容 = 记录集数据.读内容集合 ().取成员 (内部循环)
                键值表.置入文本值 (字段, 内容)

            }

            变量 换行符_ <类型 = 文本型 值 = "\r\n">
            如果 (循环变量 + 1 >= 记录数)
            {
                加入文本 (JSON文本, 键值表.到可读文本 ())
            }
            否则
            {
                加入文本 (JSON文本, 键值表.到可读文本 () + "," + 换行符_)

            }

            键值表.清空 ()
            记录集数据.到下一条 ()

        }

        记录集数据.释放记录集 ()
        子文本替换 (JSON最终文本, "表名替换", JSON字段名)
        子文本替换 (JSON最终文本, "文本内容替换", JSON文本)
        返回 (JSON最终文本)


    }

    方法 获取记录集2 <公开 类型 = 逻辑型 注释 = "查询,如果结果有多个记录集，则使用本函数" 折叠 @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    {
        变量 临时文本 <类型 = 文本型>
        keys.删除所有成员 ()
        keystext.删除所有成员 ()
        @ MYSQL_RES * MYSQL_RESID=mysql_store_result((MYSQL *)@<MYSQL池子句柄>);
        @ if(MYSQL_RESID!=NULL)
        @ {
        @       int num=mysql_num_fields(MYSQL_RESID);
        @       MYSQL_FIELD *fields=mysql_fetch_fields(MYSQL_RESID);
        @       if(fields!=NULL)
        @       {
        @           for(int i = 0; i < num; i++)
        @           {
        @            @<临时文本>=fields[i].name;
        keys.加入成员 (临时文本)
        @           }
        @       }
        @       MYSQL_ROW column=mysql_fetch_row(MYSQL_RESID);
        @       long *lengths;
        @       lengths = mysql_fetch_lengths(MYSQL_RESID);
        @       if(column!=NULL)
        @       {
        @           for(int i = 0; i < num; i++)
        @           {
        @               if(lengths[i]<=0)
        @                {
        @                    @<临时文本>=_T("");
        @                }else{
        @                    @<临时文本>=column[i];
        @                }
        keystext.加入成员 (临时文本)
        @               
        @           }
        @       }
        @ }
        @ @<记录集句柄>=(@dt<变整数>)MYSQL_RESID;
        @ while(!mysql_next_result((MYSQL *)@<MYSQL池子句柄>))
        @  {
        @         MYSQL_RES *pRes = mysql_store_result((MYSQL *)@<MYSQL池子句柄>);
        @         if(pRes!=NULL){ mysql_free_result(pRes);}
        @    }
        如果 (记录集句柄 <= 0)
        {
            返回 (假)
        }
        否则
        {
            返回 (真)

        }
    }

    方法 获取记录集 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    {
        变量 临时文本 <类型 = 文本型>
