    }

    方法 读字段集合 <公开 类型 = 文本数组类 返回值注释 = "返回字段的集合" 折叠>
    {
        返回 (keys)
    }

    方法 读内容集合 <公开 类型 = 文本数组类 返回值注释 = "返回内容的集合" 折叠>
    {
        返回 (keystext)
    }

    方法 到下一条 <公开 类型 = 逻辑型 折叠>
    {
        @ if ((MYSQL_RES *)@<记录集句柄> == NULL){return false;}
        @ MYSQL_ROW MYSQL_ROWOBJ=mysql_fetch_row((MYSQL_RES *)@<记录集句柄>);
        @ long *lengths;
        @ lengths = mysql_fetch_lengths((MYSQL_RES *)@<记录集句柄>);
        keystext.删除所有成员 ()
        @ if(MYSQL_ROWOBJ==NULL){return false;}
        变量 num <类型 = 整数>
        变量 text <类型 = 文本型>
        num = keys.取成员数 ()
        @ for(int i = 0; i < @<num>; i++)
        @ {
        @    if(lengths[i]<=0)
        @    {
        @        @<text>=_T("");
        @    }else{
        @        @<text>=MYSQL_ROWOBJ[i];
        @    }
        keystext.加入成员 (text)
        @ }
        返回 (真)
    }

    方法 到指定行 <公开 折叠>
    参数 指定行 <类型 = 整数>
    {
        @ if ((MYSQL_RES *)@<记录集句柄> == NULL){return;}
        @ mysql_data_seek((MYSQL_RES *)@<记录集句柄>,(my_ulonglong)@<指定行>);
        如果 (指定行 >= 1)
        {
            到下一条 ()

        }
    }

