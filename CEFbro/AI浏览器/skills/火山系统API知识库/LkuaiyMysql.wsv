<火山程序 类型 = "通常" 版本 = 1 />

包 利快云.libmysql

类 MYSQL连接选项 <公开 折叠>
{
    常量 MYSQL选项_连接超时 <公开 类型 = 整数 值 = 0 注释 = "MYSQL_OPT_CONNECT_TIMEOUT 值为：整数型">
    常量 MYSQL选项_使用压缩协议 <公开 类型 = 整数 值 = 1 注释 = "MYSQL_OPT_COMPRESS 值为：0或1">
    常量 MYSQL选项_使用命名管道 <公开 类型 = 整数 值 = 2 注释 = "MYSQL_OPT_NAMED_PIPE 值为：0或1">
    常量 MYSQL选项_初始命令 <公开 类型 = 整数 值 = 3 注释 = "MYSQL_INIT_COMMAND 值为：文本型，连接到服务器自动执行的SQL命令，如果重新连接，则自动重新执行">
    常量 MYSQL选项_读取默认文件 <公开 类型 = 整数 值 = 4 注释 = "MYSQL_READ_DEFAULT_FILE，值为：文本型，从指定文件中读取配置，而不是my.cnf">
    常量 MYSQL选项_读取默认分组 <公开 类型 = 整数 值 = 5 注释 = "MYSQL_READ_DEFAULT_GROUP，值为：文本型，从my.cnf指定的组中读取配置">
    常量 MYSQL选项_字符集定义文件目录 <公开 类型 = 整数 值 = 6 注释 = "MYSQL_SET_CHARSET_DIR 值为：文本型">
    常量 MYSQL选项_默认字符集名 <公开 类型 = 整数 值 = 7 注释 = "MYSQL_SET_CHARSET_NAME 值为：文本型，\"auto\" 表示系统默认">
    常量 MYSQL选项_LOCAL_INFILE <公开 类型 = 整数 值 = 8 注释 = "MYSQL_OPT_LOCAL_INFILE，值为：0或1，启用或禁用 LOAD DATA">
    常量 MYSQL选项_连接协议 <公开 类型 = 整数 值 = 9 注释 = "MYSQL_OPT_PROTOCOL 值为：整数型， “MYSQL协议_”开头常量">
    常量 MYSQL选项_共享内存名 <公开 类型 = 整数 值 = 10 注释 = "MYSQL_SHARED_MEMORY_BASE_NAME，文本型，与 --shared-memory-base-name 配置一样">
    常量 MYSQL选项_读取超时 <公开 类型 = 整数 值 = 11 注释 = "MYSQL_OPT_READ_TIMEOUT 值为：整数型">
    常量 MYSQL选项_写入超时 <公开 类型 = 整数 值 = 12 注释 = "MYSQL_OPT_WRITE_TIMEOUT 值为：整数型">
    常量 MYSQL_OPT_USE_RESULT <公开 类型 = 整数 值 = 13 注释 = "MYSQL_OPT_USE_RESULT，没有使用">
    常量 MYSQL选项_使用远程连接 <公开 类型 = 整数 值 = 14 注释 = "MYSQL_OPT_USE_REMOTE_CONNECTION，无参数，对于嵌入式库这将强制远程连接，对于客户端库没有任何效果">
    常量 MYSQL选项_使用嵌入式连接 <公开 类型 = 整数 值 = 15 注释 = "MYSQL_OPT_USE_EMBEDDED_CONNECTION，无参数，对于嵌入式库这将强制嵌入式连接，对于客户端库没有任何效果">
    常量 MYSQL选项_使用智能连接 <公开 类型 = 整数 值 = 16
            注释 = "MYSQL_OPT_GUESS_CONNECTION，无参数，对于嵌入式库，如果是本地IP就使用嵌入式连接，远程IP地址就使用远程连接，对于客户端库没有任何效果">
    常量 MYSQL选项_置客户端IP <公开 类型 = 整数 值 = 17 注释 = "MYSQL_SET_CLIENT_IP，值为：文本型，对于嵌入式库有效">
    常量 MYSQL选项_安全验证 <公开 类型 = 整数 值 = 18 注释 = "MYSQL_SECURE_AUTH，值为：0或1">
    常量 MYSQL选项_报告数据交换 <公开 类型 = 整数 值 = 19 注释 = "MYSQL_REPORT_DATA_TRUNCATION，值为：0或1，MYSQL_BIND结构的error成员">
    常量 MYSQL选项_自动重新连接 <公开 类型 = 整数 值 = 20 注释 = "MYSQL_OPT_RECONNECT 值为：0或1" 注释 = "所设置的重连并不是连接断开就自动重连，而是在执行 mysql_ping() 的时候"
            注释 = "如果连接断开了且自动重连设置为了true，则 mysql_ping() 会进行自动重连" 注释 = "若没有设置为自动重连，则 mysql_ping() 仅返回当前连接状态是否正常" 折叠2>
    常量 MYSQL选项_SSL验证服务器证书 <公开 类型 = 整数 值 = 21 注释 = "MYSQL_OPT_SSL_VERIFY_SERVER_CERT，值为：0或1">
    常量 MYSQL选项_插件目录 <公开 类型 = 整数 值 = 22 注释 = "MYSQL_PLUGIN_DIR，值为：文本型">
    常量 MYSQL选项_默认验证插件名 <公开 类型 = 整数 值 = 23 注释 = "MYSQL_DEFAULT_AUTH，值为：文本型">
    常量 MYSQL选项_客户端网络接口 <公开 类型 = 整数 值 = 24 注释 = "MYSQL_OPT_BIND，值为：文本型">
    常量 MYSQL选项_SSL_秘钥文件 <公开 类型 = 整数 值 = 25 注释 = "MYSQL_OPT_SSL_KEY，值为：文本型，pem格式">
    常量 MYSQL选项_SSL_证书文件 <公开 类型 = 整数 值 = 26 注释 = "MYSQL_OPT_SSL_CERT，值为：文本型，pem格式">
    常量 MYSQL选项_SSL_CA文件 <公开 类型 = 整数 值 = 27 注释 = "MYSQL_OPT_SSL_CA，值为：文本型，pem格式">
    常量 MYSQL选项_SSL_CA文件目录 <公开 类型 = 整数 值 = 28 注释 = "MYSQL_OPT_SSL_CAPATH，值为：文本型">
    常量 MYSQL选项_SSL_加密列表 <公开 类型 = 整数 值 = 29 注释 = "MYSQL_OPT_SSL_CIPHER，值为：文本型">
    常量 MYSQL选项_SSL_吊销列表文件 <公开 类型 = 整数 值 = 30 注释 = "MYSQL_OPT_SSL_CRL，值为：文本型">
    常量 MYSQL选项_SSL_吊销列表文件目录 <公开 类型 = 整数 值 = 31 注释 = "MYSQL_OPT_SSL_CRLPATH，值为：文本型">
    常量 MYSQL选项_连接属性清除 <公开 类型 = 整数 值 = 32 注释 = "MYSQL_OPT_CONNECT_ATTR_RESET，无参数">
    常量 MYSQL选项_连接属性添加 <公开 类型 = 整数 值 = 33 注释 = "MYSQL_OPT_CONNECT_ATTR_ADD，值为：文本型，参数1 和 参数2 分别代表 key/value，需要调用 mysql.置连接选项2（）">
    常量 MYSQL选项_连接属性删除 <公开 类型 = 整数 值 = 34 注释 = "YSQL_OPT_CONNECT_ATTR_DELETE，值为：文本型，key">
    常量 MYSQL选项_服务器公钥文件 <公开 类型 = 整数 值 = 35 注释 = "MYSQL_SERVER_PUBLIC_KEY，值为：文本型，pem格式">
    常量 MYSQL选项_使用明文认证插件 <公开 类型 = 整数 值 = 36 注释 = "MYSQL_ENABLE_CLEARTEXT_PLUGIN 值为：0或1">
    常量 MYSQL选项_可处理过期密码 <公开 类型 = 整数 值 = 37 注释 = "MYSQL_OPT_CAN_HANDLE_EXPIRED_PASSWORDS 值为：0或1">
    常量 MYSQL_OPT_SSL_ENFORCE <公开 类型 = 整数 值 = 28>
    常量 MYSQL选项_最大允许包 <公开 类型 = 整数 值 = 39 注释 = "MYSQL_OPT_MAX_ALLOWED_PACKET 值为：整数型，同my.ini里面的 max_allowed_packet">
    常量 MYSQL选项_缓冲区大小 <公开 类型 = 整数 值 = 40 注释 = "MYSQL_OPT_NET_BUFFER_LENGTH 值为：整数型，同my.ini里面的 net_buffer_length">
    常量 MYSQL选项_TLS版本 <公开 类型 = 整数 值 = 41 注释 = "MYSQL_OPT_TLS_VERSION，文本型">
    常量 MYSQL选项_SSL_模式 <公开 类型 = 整数 值 = 42 注释 = "MYSQL_OPT_SSL_MODE，值为：整数型，“SSL_MODE_”开头常量">

    #
}

类 MySqlDLL <折叠 折叠2 @视窗.头文件搜寻目录 = "lib\\MysqlLib\\include" @视窗.附属文件.x64 = "lib\\MysqlLib\\win64\\libmysql.dll"
        @视窗.附属文件.win32 = "lib\\MysqlLib\\win32\\libmysql.dll" @视窗.外部头文件 = "lib\\MysqlLib\\include\\mysql.h" @视窗.外部头文件 = "wchar.h">
{
    方法 Utf8ToUnicode <类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 Utf8 <类型 = 变整数>
    {
        @  int textlen = 0;
        @  wchar_t* result;
        @  textlen = ::MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)@<Utf8>,-1,NULL,0 );  
        @  result =  new wchar_t[textlen+1];
        @  textlen = ::MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)@<Utf8>,-1,result,textlen);
        @  result[textlen] = L'\0';
        @  @an<CVolString> str(result);
        @  delete [] result;
        @  result = NULL;
        @  free (result);
        @ return str;
    }

    方法 AsciiToUnicode <类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 Ascii <类型 = 变整数>
    {
        @  int textlen = 0;
        @  wchar_t * result;
        @  textlen = MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<Ascii>,-1,NULL,0 );  
        @  result = (wchar_t *)malloc((textlen+1)*sizeof(wchar_t));
        @  result[textlen] = L'\0';
        @  MultiByteToWideChar(CP_ACP, 0, (LPCSTR)@<Ascii>,-1,result,textlen);  
        @  @an<CVolString> str = result;
        @  free (result);
        @ return str;

    }

    方法 UnicodeToUtf8 <类型 = 变整数 折叠>
    参数 Unicode <类型 = 变整数>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( CP_UTF8,0,(LPCWSTR)@<Unicode>,-1,NULL,0,NULL,NULL);
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( CP_UTF8, 0, (LPCWSTR)@<Unicode>,-1,(LPSTR) @<MemBuf>.GetPtr(),@<textlen>, NULL, NULL );
        返回 (取字节集指针 (MemBuf))

    }

    方法 UicodeToAscii <类型 = 变整数 折叠>
    参数 Uicode <类型 = 文本型>
    {
        变量 MemBuf <类型 = 字节集类>
        变量 textlen <类型 = 整数>
        @ @<textlen> = WideCharToMultiByte( CP_ACP,0,(LPCWSTR)@<Uicode>,-1,NULL, 0, NULL, NULL );
        分配字节集 (MemBuf, textlen)
        @ WideCharToMultiByte( CP_ACP, 0, (LPCWSTR)@<Uicode>,-1,(LPSTR)@<MemBuf>.GetPtr(),  @<textlen>, NULL, NULL );
        返回 (取字节集指针 (MemBuf))
    }

