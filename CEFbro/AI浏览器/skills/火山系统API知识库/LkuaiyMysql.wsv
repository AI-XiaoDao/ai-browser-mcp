        @               if(lengths[i]<=0)
        @                {
        @                    @<临时文本>=_T("");
        @                }else{
        @                    @<临时文本>=column[i];
        @                }
        keystext.加入成员 (临时文本)
        @               
        @           }
        @       }
        @ }
        @ @<记录集句柄>=(@dt<变整数>)MYSQL_RESID;
        如果 (记录集句柄 <= 0)
        {
            返回 (假)
        }
        否则
        {
            返回 (真)

        }
    }

    方法 释放记录集 <公开 折叠>
    {
        keys.删除所有成员 ()
        keystext.删除所有成员 ()
        @ mysql_free_result ((MYSQL_RES *)@<记录集句柄>);
    }

    方法 取记录数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ if ((MYSQL_RES *)@<记录集句柄> == NULL){return 0;}
        @ return (int)mysql_num_rows((MYSQL_RES *)@<记录集句柄>);
    }

    方法 读文本 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 name <类型 = 文本型>
    {
        变量 item <类型 = 整数 值 = 0>
        变量 字段名称 <类型 = 文本型>
        变量 字段数量 <类型 = 整数>
        变量 循环变量 <类型 = 整数>
        @ if ((MYSQL_RES *)@<记录集句柄> == NULL){return _T("");}
        字段数量 = keys.取成员数 ()
        如果 (字段数量 >= 1)
        {
            循环 (0, keys.取成员数 (), 循环变量, 1)
            {
                如果 (name == keys.取成员 (循环变量))
                {
                    字段名称 = keys.取成员 (循环变量)
                    item = 循环变量
                    跳出循环

                }

            }

            如果 (keystext.取成员数 () < 字段数量)
            {
                返回 ("")
            }
            否则
            {
                返回 (keystext.取成员 (item))

            }

        }
        否则
        {
            返回 ("")

        }
    }

    方法 读整数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 name <类型 = 文本型>
    {
        @ if ((MYSQL_RES *)@<记录集句柄> == NULL){return 0;}
        返回 (文本到整数 (读文本 (name)))
    }

