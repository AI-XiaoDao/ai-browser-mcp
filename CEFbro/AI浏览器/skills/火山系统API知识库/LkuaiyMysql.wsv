    方法 执行SQL语句 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    参数 SQL语句 <类型 = 文本型 注释 = "SQL语句命令，不需要进行转码处理，可以直接输入中文使用">
    {
        如果 (是否连接成功 (MYSQL池子句柄) != 0)
        {
            调试输出 ("连接校验失败:", 取最后错误 (MYSQL池子句柄), SQL语句)
            返回 (假)
        }
        变量 失败 <类型 = 逻辑型>
        @ CU8String u8str (@<SQL语句>.GetText ());
        @ const U8CHAR* ps = u8str.GetText ();
        @ int Ret=mysql_query((MYSQL *)@<MYSQL池子句柄>,ps);
        @ if(Ret!=0){ @<失败>=true; }
        如果真 (失败)
        {
            调试输出 ("执行语句出错:", 取最后错误 (MYSQL池子句柄), SQL语句)
        }
        @ if(Ret!=0){return false;}
        返回 (真)
    }

    方法 执行查询语句并分页 <公开 类型 = 整数 注释 = "本方法参考案例地址：https://www.lkuaiy.com/rsdetails?id=16084465804144&page=1"
            注释 = "本方法效率测试案例地址：https://www.lkuaiy.com/rsdetails?id=37461615352297" 返回值注释 = "成功返回总页数,失败或者没有数据返回0" 折叠 折叠2 @禁止流程检查 = 真>
    参数 MYSQL池子句柄 <类型 = 变整数>
    参数 表名 <类型 = 文本型>
    参数 条件 <类型 = 文本型 注释 = "需要带上where 例如:where XXX=XXX" @默认值 = "">
    参数 当前页数 <类型 = 整数 @默认值 = 1>
    参数 每页数量 <类型 = 整数 @默认值 = 10>
    {
        如果 (是否连接成功 (MYSQL池子句柄) != 0)
        {
            返回 (0)

        }

        变量 临时句柄 <类型 = 变整数>
        临时句柄 = 获取句柄 ()
        执行SQL语句 (临时句柄, "select COUNT(*) from " + 表名 + " " + 条件)
        变量 临时记录集 <类型 = 数据库_LibMySQL记录集>
        临时记录集.获取记录集 (临时句柄)
        变量 总数 <类型 = 整数>
        总数 = 临时记录集.读整数 ("COUNT")
        临时记录集.释放记录集 ()
        释放句柄 (临时句柄)

        变量 SQL语句 <类型 = 文本型>
        SQL语句 = "select * from " + 表名 + " " + 条件 + " limit " + 到文本 ((当前页数 - 1) * 每页数量) + "," + 到文本 (每页数量)
        @ CU8String u8str (@<SQL语句>.GetText ());
        @ const U8CHAR* ps = u8str.GetText ();
        @ int Ret=mysql_query((MYSQL *)@<MYSQL池子句柄>,ps);
        @ if(Ret!=0){return 0;}
        如果 (总数 <= 0)
        {
            返回 (0)

        }

        如果 (总数 % 每页数量 == 0)
        {
            返回 (总数 / 每页数量)

        }
        否则
        {
            返回 (总数 / 每页数量 + 1)

        }

    }

