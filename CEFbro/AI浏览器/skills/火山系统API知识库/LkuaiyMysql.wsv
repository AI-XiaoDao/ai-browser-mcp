类 数据库_LibMySQL数据库 <公开 基础类 = MySqlDLL 注释 = "使用方法参考本案例：https://www.lkuaiy.com/rsdetails?id=16064486821870&page=1"
        注释 = "本数据库效率测试案例地址：https://www.lkuaiy.com/rsdetails?id=37461615352297" 折叠2>
{
    变量 队列 <类型 = 类_超级队列>

    方法 类_初始化 <折叠>
    {
        变量 杂项 <类型 = 类_系统杂项>
        如果 (杂项.程序_是否64位 () == 真)
        {
            调试输出 ("64位MYSQL可能会初始化失败，如果你遇见链接MYSQL崩溃的情况，请下载安装驱动包:https://www.lkuaiy.com/rsdetails?id=16180224193018")

        }
    }

    方法 创建 <类型 = 变整数 折叠 @禁止流程检查 = 真>
    {
        @ MYSQL* MysqlThis;
        @ MysqlThis=mysql_init (NULL);
        @ return (@dt<变整数>)MysqlThis;

    }

    方法 连接 <公开 类型 = 整数 注释 = "返回最终连接成功的数量" 折叠>
    参数 参连接地址 <类型 = 文本型 注释 = "注意：如果是远程连接，请参考这个案例：https://www.lkuaiy.com/rsdetails?id=23241606530849&page=1">
    参数 参数据库名 <类型 = 文本型>
    参数 参用户名 <类型 = 文本型>
    参数 参密码 <类型 = 文本型>
    参数 参端口 <类型 = 整数 @默认值 = 3306>
    参数 参最大连接数 <类型 = 整数 注释 = "需要时FOF连接池数量的两倍，也就是FOF连接池是10，那么这里要填写20" @默认值 = 20>
    参数 连接选项 <类型 = 整数数组类 注释 = "默认空对象，这个可以忽略掉，设置方法参考MYSQL连接选项"
            注释 = "使用方法参考这篇案例：https://www.lkuaiy.com/rsdetails?id=16064490721459&page=1" 折叠2 @默认值 = 空对象>
    参数 连接内容 <类型 = 文本数组类 注释 = "默认空，这个可以忽略掉，如果上方的连接选项设置使用了MYSQL连接选项，就一定要设置本处"
            注释 = "使用方法参考这篇案例：https://www.lkuaiy.com/rsdetails?id=16064490721459&page=1" 折叠2 @默认值 = 空对象>
    参数 是否支持SSL <类型 = 逻辑型 注释 = "注意:如果是远程SSL连接，本处务设置为真" @默认值 = 假>
    {
        变量 局句柄 <类型 = 变整数>
        变量 局计次 <类型 = 整数>
        如果真 (参最大连接数 <= 0)
        {
            参最大连接数 = 10
        }
        如果 (参最大连接数 <= 50)
        {
            参最大连接数 = 参最大连接数 * 2
        }
        计次循环 (参最大连接数)
        {
            局句柄 = 创建 ()
            如果真 (局句柄 > 0)
            {
                变量 循环N <类型 = 整数>
                变量 是否设置 <类型 = 逻辑型>
                循环 (0, 连接选项.取成员数 (), 循环N, 1)
                {
                    如果 (连接选项.取成员 (循环N) == MYSQL连接选项.MYSQL选项_默认字符集名)
                    {
                        是否设置 = 真
                        如果 (连接选项.取成员数 () >= 1 && 连接内容.取成员数 () >= 1 && 连接选项.取成员数 () == 连接内容.取成员数 ())
                        {
                            设置访问字符集 (局句柄, 连接内容.取成员 (循环N))

                        }

                    }
                }
                如果 (是否设置 == 假)
                {
                    设置额外连接选项 (局句柄, MYSQL连接选项.MYSQL选项_默认字符集名, "UTF8")
                    设置访问字符集 (局句柄, "UTF8")
                }
                如果 (连接选项.取成员数 () >= 1 && 连接内容.取成员数 () >= 1 && 连接选项.取成员数 () == 连接内容.取成员数 ())
                {
                    变量 循环变量 <类型 = 整数>
                    循环 (0, 连接选项.取成员数 (), 循环变量, 1)
                    {
                        设置额外连接选项 (局句柄, 连接选项.取成员 (循环变量), 连接内容.取成员 (循环变量))

                    }
                }
                如果 (是否支持SSL == 真)
                {
                    @ int optval2=1;
                    @ mysql_options((MYSQL *)@<局句柄>,MYSQL_OPT_SSL_MODE,(char*)&optval2);
                }
                @ char optval=1;
                @ mysql_options((MYSQL *)@<局句柄>,MYSQL_OPT_RECONNECT,&optval);
                如果真 (连接MYSQL (局句柄, 参连接地址, 参数据库名, 参用户名, 参密码, 参端口) == 真)
                {
                    局计次 = 局计次 + 1
                    队列.投递变整数 (局句柄)

                }

            }

        }

        返回 (局计次)
    }

