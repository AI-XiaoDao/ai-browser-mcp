    }

    方法 获取小数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @     if (idouble.empty()) 
        @     {
        @        return -1; 
        @     }
        @     double tmp = idouble.front();
        @     idouble.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (idouble.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return -1; 
        @     }
        @     double tmp = idouble.front();
        @     idouble.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }

    }

    方法 获取整数 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ if(IFCRITICAL_SECTION==true){
        @     if (iqueue.empty()) 
        @     {
        @        return -1; 
        @     }
        @     int tmp = iqueue.front();
        @     iqueue.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iqueue.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return -1; 
        @     }
        @     int tmp = iqueue.front();
        @     iqueue.pop();
        @     LeaveCriticalSection(&m_CriticalSection);
        @     return tmp;
        @ }

    }

