    方法 获取字节集 <公开 类型 = 字节集类 返回值注释 = "失败返回空字节集" 折叠 @禁止流程检查 = 真>
    {
        变量 空字节 <类型 = 字节集类>
        @ if(IFCRITICAL_SECTION==true){
        @     if (iCVolMem.empty()) 
        @     {
        @        return @<空字节>; 
        @     }
        @     @an<CVolMem> tmp = iCVolMem.front();
        @     iCVolMem.pop();
        @     return tmp;
        @ }
        @ else{
        @     EnterCriticalSection(&m_CriticalSection);
        @     if (iCVolMem.empty()) 
        @     {
        @        LeaveCriticalSection(&m_CriticalSection);
        @        return @<空字节>; 
        @     }
