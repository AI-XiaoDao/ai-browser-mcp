<火山程序 类型 = "通常" 版本 = 1 />

包 LkuaiyHttp.com

类 类_超级队列 <公开 @视窗.外部头文件 = "<queue>">
{

    # @begin
    # <> <include>
    # @ std::queue<int> iqueue;
    # @ std::queue<CWString> iCS;
    # @ std::queue<double> idouble;
    # @ std::queue<@an<CVolMem>> iCVolMem;
    # @ std::queue<CVolObjectArray> iCVolObjectArray;
    # @ std::queue<@an<CVolObject>> iCVolObject;
    # @ std::queue<@dt<COM对象类>> iCVolComObject;
    # @ std::queue<@dt<变整数>> iCVoBzs;
    # @ CRITICAL_SECTION m_CriticalSection; 
    # @ bool IFCRITICAL_SECTION=false; 
    # <> </include>
    # @end

    方法 关闭队列加锁 <公开 注释 = "队列默认是加锁状态" 折叠>
    {
        @ IFCRITICAL_SECTION = true;
    }

    方法 类_清理 <折叠>
    {
        @ DeleteCriticalSection(&m_CriticalSection);
    }

    方法 类_初始化 <折叠>
    {
        @ InitializeCriticalSection(&m_CriticalSection); 
    }

    方法 投递整数 <公开 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 整数>
    {
        @ if(IFCRITICAL_SECTION==true){iqueue.push(@<数据>);}
        @ else{EnterCriticalSection(&m_CriticalSection);iqueue.push(@<数据>);LeaveCriticalSection(&m_CriticalSection);}
    }

    方法 投递文本 <公开 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 文本型>
    {
        @ if(IFCRITICAL_SECTION==true){iCS.push(@<数据>);}
        @ else{EnterCriticalSection(&m_CriticalSection);iCS.push(@<数据>);LeaveCriticalSection(&m_CriticalSection);}
    }

    方法 投递小数 <公开 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 小数>
    {
        @ if(IFCRITICAL_SECTION==true){idouble.push(@<数据>);}
        @ else{EnterCriticalSection(&m_CriticalSection);idouble.push(@<数据>);LeaveCriticalSection(&m_CriticalSection);}

    }

    方法 投递变整数 <公开 折叠 @禁止流程检查 = 真>
    参数 数据 <类型 = 变整数>
    {
        @ if(IFCRITICAL_SECTION==true){iCVoBzs.push(@<数据>);}
        @ else{EnterCriticalSection(&m_CriticalSection);iCVoBzs.push(@<数据>);LeaveCriticalSection(&m_CriticalSection);}

    }

