        返回 (到文本 (到文本 (取年份 (到时间 (文本时间))) + "-" + 到文本 (取月份 (到时间 (文本时间))) + "-" + 到文本 (取日 (到时间 (文本时间)))))
    }

    方法 时间_时间戳转时间 <公开 类型 = 文本型 注释 = "只支持10位时间戳" 折叠 @禁止流程检查 = 真>
    参数 时间戳 <类型 = 长整数>
    参数 时间格式 <类型 = 文本型 @默认值 = "%Y-%m-%d %H:%M:%S">
    {
        @ const TCHAR* lpFormat = (const TCHAR*)@<时间格式>;
        @ time_t t = @<时间戳>;
        @  TCHAR str_time[100];
        @  struct tm* local_time = localtime(&t);
        @  _tcsftime(str_time, sizeof(str_time), lpFormat, local_time);
        @ return str_time;

    }

    方法 时间_时间戳转格林 <公开 类型 = 文本型 注释 = "只支持10位时间戳" 折叠 @禁止流程检查 = 真>
    参数 时间戳 <类型 = 长整数>
