        @     time(&rawTime);
        @     timeInfo = gmtime(&rawTime);
        @  return   mktime(timeInfo);

    }

    方法 时间_格林时间转时间戳 <公开 类型 = 长整数 折叠>
    参数 格林时间文本 <类型 = 文本型 注释 = "必须时这种格式 Thu, 23 Jul 2020 06:04:11 GMT 其他格式解析不了">
    参数 是否转换成北京时间 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 文本 <类型 = 类_文本操作>
        变量 临时文本 <类型 = 文本型>
        // Thu, 23 Jul 2020 06:04:11 GMT
        // 第一步 去掉星期几
        临时文本 = 文本.文本_取右边_从右往左查找 (格林时间文本, ",")
        // 处理月份
        子文本替换 (临时文本, "Jan", "01")
        子文本替换 (临时文本, "Feb", "02")
        子文本替换 (临时文本, "Mar", "03")
        子文本替换 (临时文本, "Apr", "04")
        子文本替换 (临时文本, "May", "05")
        子文本替换 (临时文本, "Jun", "06")
        子文本替换 (临时文本, "Jul", "07")
        子文本替换 (临时文本, "Aug", "08")
        子文本替换 (临时文本, "Sep", "09")
        子文本替换 (临时文本, "Oct", "10")
        子文本替换 (临时文本, "Nov", "11")
        子文本替换 (临时文本, "Dec", "12")

        // 处理GMT 字符串
        子文本替换 (临时文本, "GMT", "")

        // 如果有 PM 和 AM 也要干掉
        子文本替换 (临时文本, "AM", "", 0, -1, 假)
        子文本替换 (临时文本, "PM", "", 0, -1, 假)

        临时文本 = 删首尾空 (临时文本)

        // 得到  23 Jul 2020 06:04:11
        如果 (是否转换成北京时间)
        {
            返回 (_时间_格林时间转北京时间戳 (临时文本) + 8 * 60 * 60)
        }
        否则
        {
            返回 (_时间_格林时间转北京时间戳 (临时文本))
        }










    }

    方法 时间_格林时间转北京时间 <公开 类型 = 文本型 折叠>
    参数 格林时间文本 <类型 = 文本型 注释 = "必须时这种格式 Thu, 23 Jul 2020 06:04:11 GMT">
    参数 北京时间格式 <类型 = 文本型 @默认值 = "%Y-%m-%d %H:%M:%S">
    {
        变量 时间戳 <类型 = 长整数>
        时间戳 = 时间_格林时间转时间戳 (格林时间文本, 真)
        返回 (时间_时间戳转时间 (时间戳, 北京时间格式))





    }

    方法 _时间_格林时间转北京时间戳 <类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 年月日时分秒 <类型 = 文本型 注释 = "23 Jul 2020 06:04:11">
    参数 格式 <类型 = 文本型 注释 = "%d %d %d %d:%d:%d" @默认值 = "%d %d %d %d:%d:%d">
    {
        @     const TCHAR *cha = (const TCHAR*)@<年月日时分秒>;             // 将string转换成char*。
        @      const TCHAR *pFormat = (const TCHAR*)@<格式>;
        @     tm tm_;                                    // 定义tm结构体。
        @     int year, month, day, hour, minute, second;// 定义时间的各个int临时变量。
        @     swscanf(cha, pFormat, &day, &month, &year, &hour, &minute, &second);// 将string存储的日期时间,转换为int临时变量。
        @     tm_.tm_year = year - 1900;                 // 年,由于tm结构体存储的是从1900年开始的时间,所以tm_year为int临时变量减去1900。
        @     tm_.tm_mon = month - 1;                    // 月,由于tm结构体的月份存储范围为0-11,所以tm_mon为int临时变量减去1。
        @     tm_.tm_mday = day;                         // 日。
        @     tm_.tm_hour = hour;                        // 时。
        @     tm_.tm_min = minute;                       // 分。
        @     tm_.tm_sec = second;                       // 秒。
        @     tm_.tm_isdst = 0;                          // 非夏令时。
        @     time_t t_ = mktime(&tm_);                  // 将tm结构体转换成time_t格式。
        @     return t_;                                 // 返回值。

    }

    方法 时间_取年月日 <公开 类型 = 文本型 折叠 @禁止流程检查 = 真>
    {
        @  TCHAR szBuffer[256];
        @  SYSTEMTIME st;
        @  ::GetLocalTime(&st);
        @  ::wsprintf(szBuffer, TEXT("%u-%u-%u"),
        @   st.wYear, st.wMonth, st.wDay);
        @ return szBuffer;

    }

