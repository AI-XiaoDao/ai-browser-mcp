    方法 时间_生成时间戳 <公开 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数>
    参数 日 <类型 = 整数>
    参数 时 <类型 = 整数>
    参数 分 <类型 = 整数>
    参数 秒 <类型 = 整数>
    {
        @     tm tm_; 
        @     tm_.tm_year = @<年> - 1900;                 // 年,由于tm结构体存储的是从1900年开始的时间,所以tm_year为int临时变量减去1900。
        @     tm_.tm_mon = @<月> - 1;                    // 月,由于tm结构体的月份存储范围为0-11,所以tm_mon为int临时变量减去1。
        @     tm_.tm_mday = @<日>;                         // 日。
        @     tm_.tm_hour = @<时>;                        // 时。
        @     tm_.tm_min = @<分>;                       // 分。
        @     tm_.tm_sec = @<秒>;                       // 秒。
        @     tm_.tm_isdst = 0;                          // 非夏令时。
        @     time_t t_ = mktime(&tm_);                  // 将tm结构体转换成time_t格式。
        @   return t_;
    }

