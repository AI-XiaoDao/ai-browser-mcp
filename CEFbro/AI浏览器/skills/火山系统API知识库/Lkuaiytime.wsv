    }

    方法 秒格式化 <类型 = 文本型 折叠>
    参数 秒 <类型 = 长整数>
    {
        变量 余数 <类型 = 长整数>
        变量 天 <类型 = 长整数>
        变量 小时 <类型 = 长整数>
        变量 分钟 <类型 = 长整数>
        变量 秒钟 <类型 = 长整数>
        余数 = 秒
        天 = 余数 / (1 * 24 * 60 * 60)
        余数 = 余数 % (1 * 24 * 60 * 60)
        小时 = 余数 / (1 * 60 * 60)
        余数 = 余数 % (1 * 60 * 60)
        分钟 = 余数 / 60
        余数 = 余数 % 60
        秒钟 = 余数
        返回 (到文本 (天) + "天" + 到文本 (小时) + "时" + 到文本 (分钟) + "分" + 到文本 (秒钟) + "秒")




    }

    方法 秒转天 <类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / (1 * 24 * 60 * 60))
    }

    方法 秒转小时 <类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / (1 * 60 * 60))
    }

    方法 秒转分钟 <类型 = 长整数 折叠>
    参数 时间间隔 <类型 = 长整数 注释 = "时间间隔是以秒为单位的">
    {
        返回 (时间间隔 / 60)


    }

    #
}
