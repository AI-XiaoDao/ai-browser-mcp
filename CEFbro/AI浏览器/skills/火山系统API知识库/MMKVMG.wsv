    方法 腾讯键值表事件_日志内容 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 腾讯键值表事件>
    参数 标记值 <类型 = 整数>
    参数 日志等级 <类型 = 整数>
    参数 文件名称 <类型 = 文本型>
    参数 行号 <类型 = 整数>
    参数 函数名称 <类型 = 文本型>
    参数 消息内容 <类型 = 文本型>
    {

        如果 (日志等级 == 0)
        {
            调试输出 ("日志 等级 调试")
        }
        否则 (日志等级 == 1)
        {
            调试输出 ("日志 等级 信息 " + 文件名称)
        }
        否则 (日志等级 == 2)
        {
            调试输出 ("日志 等级 警告")
        }
        否则 (日志等级 == 3)
        {
            调试输出 ("日志 等级 错误")
        }
        否则 (日志等级 == 4)
        {
            调试输出 ("日志 等级 空")
        }



        返回 (0)
    }

    #

    方法 线程类f_工作函数 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 线程类f 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 线程参数 <类型 = 变整数>
    {

        如果 (来源对象 == 线程1)
        {
            变量 i <类型 = 整数>
            循环 (0, 100, i)
            {
                // 调试输出 ("->1", i)
                成员键值表.置文本 ("aaa", "bbbb")
                // 调试输出 ("1<-", i)


            }


            调试输出 ("1 end")

        }
        否则 (来源对象 == 线程2)
        {
            变量 i <类型 = 整数>

            循环 (0, 100, i)
            {
                // 调试输出 ("->2", i)
                成员键值表.置文本 ("aaa", "bbbb")
                // 调试输出 (i)
                // 调试输出 ("2<-", i)

            }

            调试输出 ("2 end")

        }



        调试输出 ("线程退出")


        返回 (0)
    }
}
