<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" @文档 = "category = \"windows.菜单\"">

类 ______弹出菜单 <公开 @全局类 = 真>
{
    方法 菜单_创建 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (@dt<变整数>)CreateMenu()
    }

    方法 菜单_创建弹出菜单 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (@dt<变整数>) CreatePopupMenu()
    }

    方法 菜单_销毁 <公开 静态 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    {
        @ DestroyMenu((HMENU)@<菜单句柄>)
    }

    方法 菜单_添加文本项 <公开 静态 类型 = 逻辑型 注释 = "添加成功返回真，失败返回假 添加一个文本菜单项" 折叠 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单ID <类型 = 变整数>
    参数 菜单文本 <类型 = 文本型>
    {
        @ AppendMenu((HMENU)@<菜单句柄>,MF_STRING,(UINT_PTR)@<菜单ID>,@<菜单文本>)
    }

    方法 菜单_添加分割线 <公开 静态 类型 = 逻辑型 注释 = "添加成功返回真，失败返回假 添加一个文本菜单项" 折叠 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    {
        @ AppendMenu((HMENU)@<菜单句柄>,MF_SEPARATOR,NULL,NULL)
    }

    方法 菜单_选中 <公开 静态 类型 = 整数 返回值注释 = "返回设置前的菜单标记 例如 MF_CHECKED ，如果没有状态返回-1" 折叠 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单ID <类型 = 整数>
    参数 是否选中 <类型 = 逻辑型>
    {
        @ if (@<是否选中>)
        @ {
        @     return CheckMenuItem((HMENU)@<菜单句柄>,(UINT)@<菜单ID>,MF_CHECKED);
        @ }
        @ else
        @ {
        @     return CheckMenuItem((HMENU)@<菜单句柄>,(UINT)@<菜单ID>,MF_UNCHECKED);
        @ }

    }

    方法 菜单_添加弹出菜单_通过句柄 <公开 静态 类型 = 逻辑型 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    参数 弹出菜单句柄 <类型 = 变整数>
    参数 菜单标题 <类型 = 文本型>
    {
        @ AppendMenu((HMENU)@<菜单句柄>,MF_POPUP,(UINT_PTR)@<弹出菜单句柄>,@<菜单标题>)
    }

    方法 菜单_添加弹出菜单 <公开 静态 类型 = 变整数 注释 = "内部会直接创建一个弹出菜单，然后绑定" 注释 = "返回弹出菜单句柄" @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单标题 <类型 = 文本型>
    {
        @ HMENU hMenu = CreatePopupMenu();
        @ AppendMenu((HMENU)@<菜单句柄>,MF_POPUP,(UINT_PTR)hMenu,@<菜单标题>);
        @ return (@dt<变整数>)hMenu;
    }

    方法 "//菜单_添加子菜单" <公开 静态 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    参数 弹出菜单句柄 <类型 = 变整数>
    参数 弹出菜单标题 <类型 = 文本型>
    {

    }

    #

    方法 菜单_禁止_通过ID <公开 静态 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 菜单句柄 <类型 = 变整数>
    参数 菜单ID <类型 = 整数>
    参数 是否禁止 <类型 = 逻辑型>
    {
        @ if(@<是否禁止>)
        @ {
        @     return EnableMenuItem ((HMENU)@<菜单句柄>,@<菜单ID>,MF_DISABLED|MF_GRAYED);
        @ }else
        @ {
        @     return EnableMenuItem ((HMENU)@<菜单句柄>,@<菜单ID>,MF_ENABLED);
        @ }
        // BOOL EnableMenuItem(
        // HMENU hMenu,         // handle to menu
        // UINT uIDEnableItem,  // menu item to update
        // UINT uEnable         // options);

    }

    方法 菜单_取子菜单 <公开 静态 类型 = 变整数 注释 = "返回子菜单句柄" @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数 注释 = "从0开始">
    {
        @ (@dt<变整数>) GetSubMenu ((HMENU)@<菜单句柄>,@<索引>)
    }

    方法 菜单_取数量 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    {
        @ GetMenuItemCount((HMENU)@<菜单句柄>)
    }

    方法 菜单_取项ID <公开 静态 类型 = 整数 注释 = "返回菜单项目ID,如果菜单没有子项目，则返回0" 注释 = "如果指定菜单项包含弹出菜单，则返回-1" @嵌入式方法 = "">
    参数 菜单句柄 <类型 = 变整数>
    参数 索引 <类型 = 整数>
    {
        @ (INT)GetMenuItemID((HMENU)@<菜单句柄>,@<索引>)
    }

    方法 菜单_显示弹出菜单 <公开 静态>
    参数 菜单句柄 <类型 = 变整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 是否将坐标转换为屏幕坐标 <类型 = 逻辑型 注释 = "如果默认传递是窗口坐标，那么此时设置为真" 注释 = "则函数会自动将窗口坐标转换为屏幕坐标" @默认值 = 假>
    {
        @ if(@<是否将坐标转换为屏幕坐标>)
        @ {
        @ POINT pt;
        @ pt.x = @<横向位置>;
        @ pt.y = @<纵向位置>;
        @ ClientToScreen((HWND)@<窗口句柄>,&pt);
        @ TrackPopupMenu ((HMENU)@<菜单句柄>,TPM_LEFTALIGN|TPM_TOPALIGN,pt.x,pt.y,0,(HWND)@<窗口句柄>,NULL);
        @ }else
        @ {
        @ TrackPopupMenu ((HMENU)@<菜单句柄>,TPM_LEFTALIGN|TPM_TOPALIGN,@<横向位置>,@<纵向位置>,0,(HWND)@<窗口句柄>,NULL);
        @ }
    }

    #
}
