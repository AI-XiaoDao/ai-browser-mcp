<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <注释 = "支持32/64位，离线式，无限制" @文档 = "category = \"OCR文字识别库\"">

类 RapidOCR识别类_GPU <公开 注释 = "本库为GPU+CPU版，主打GPU性能强，基于RapidOCR所开发的OCR文字识别。编译库出自“李逍遥”作品" 折叠 折叠2 编辑时信息 = "A3130, 0, 0, 0"
        @文档 = "category = \"OCR文字识别库.RapidOCR识别库_GPU\""
        @视窗.附属文件 = "OCR\\RapidOCR_GPU\\$(p)\\RapidOcrOnnxGpu.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cublas64_11.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cublasLt64_11.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cudart64_110.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cudnn_cnn_infer64_8.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cudnn_ops_infer64_8.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cudnn64_8.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\cufft64_10.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\onnxruntime.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\onnxruntime_providers_cuda.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\onnxruntime_providers_shared.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\onnxruntime_providers_tensorrt.dll\r\nOCR\\RapidOCR_GPU\\$(p)\\zlibwapi.dll"
        @视窗.附属文件 = "OCR\\OCR模型>OCR模型" @视窗.需求目标平台 = @"64位平台">
{
    变量 集模型指针 <类型 = 变整数>

    方法 类_清理 <折叠>
    {
        如果真 (集模型指针 > 0)
        {
            释放模型_ (集模型指针)
            集模型指针 = 0
        }
    }

    方法 加载模型_ <公开 类型 = 变整数 注释 = "不用时记得调用“释放模型_”释放内存，不然会造成内存泄漏" 返回值注释 = "成功返回大于0的模型指针，错误返回负数" 折叠>
    参数 线程数量 <类型 = 整数 注释 = "默认4 不超过CPU核心数，设置高不一定就快" @默认值 = 4>
    参数 检测模型路径 <类型 = 文本型 注释 = "默认为“中文_OCRv4.onnx”，也可调用类名参数如：OCR检测模型.中文_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    参数 语言模型路径 <类型 = 文本型 注释 = "默认为“中文简体_OCRv4”，也可调用类名参数如：OCR语言模型.中文简体_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    参数 语言字典路径 <类型 = 文本型 注释 = "可留空无需设置，默认是跟随参数三。也可调用类名参数如：OCR字典模型.中文简体_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    参数 是否开启GPU <类型 = 逻辑型 注释 = "真为GPU模式，假为CPU模式。GPU模式有显卡要求，需要N卡列表，且越大越爽，CUDA驱动版本至少需要11.8" @默认值 = 真>
    {
        变量 语言模型路径2 <类型 = 文本型>
        变量 语言字典路径2 <类型 = 文本型>
        变量 检测模型路径2 <类型 = 文本型>
        变量 det <类型 = 字节集类>
        变量 cls <类型 = 字节集类>
        变量 rec <类型 = 字节集类>
        变量 keys <类型 = 字节集类>
        变量 结果 <类型 = 文本型>
        变量 结果2 <类型 = 文本型>
        运行控制台程序 ("nvidia-smi", 结果)
        结果2 = 取文本中间_ (结果, "CUDA Version: ", " ")
        如果真 (文本到小数 (结果2) < 11.8)
        {
            调试输出 ("当前显卡CUDA驱动版本为" + 结果2 + "，不合要求，至少需要11.8的版本")
            返回 (-1)
        }
        如果 (检测模型路径 == "")
        {
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\检测模型\\中文_OCRv4.onnx") == 假)
            {
                返回 (-2)
            }
            det = 读入文件 (取运行目录 () + "OCR模型\\检测模型\\中文_OCRv4.onnx")
        }
        否则
        {
            检测模型路径2 = 取文本左边2_ (检测模型路径, ".onnx", 真)
            如果真 (文件是否存在 (检测模型路径2 + ".onnx") == 假)
            {
                返回 (-3)
            }
            det = 读入文件 (检测模型路径2 + ".onnx")
        }
        如果真 (文件是否存在 (取运行目录 () + "OCR模型\\方向模型\\原始分类器模型.onnx") == 假)
        {
            返回 (-3)
        }
        cls = 读入文件 (取运行目录 () + "OCR模型\\方向模型\\原始分类器模型.onnx")
        如果 (语言模型路径 == "")
        {
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\识别模型\\中文简体_OCRv4.onnx") == 假)
            {
                返回 (-4)
            }
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\识别字典\\中文简体_OCRv4.txt") == 假)
            {
                返回 (-5)
            }
            rec = 读入文件 (取运行目录 () + "OCR模型\\识别模型\\中文简体_OCRv4.onnx")
            keys = 读入文件 (取运行目录 () + "OCR模型\\识别字典\\中文简体_OCRv4.txt")
        }
        否则
        {
            语言模型路径2 = 取文本左边2_ (语言模型路径, ".onnx", 真)
            如果真 (文件是否存在 (语言模型路径2 + ".onnx") == 假)
            {
                返回 (-6)
            }
            rec = 读入文件 (语言模型路径2 + ".onnx")
            如果 (语言字典路径 == "")
            {
                子文本替换 (语言模型路径2, "识别模型", "识别字典")
                如果真 (文件是否存在 (语言模型路径2 + ".txt") == 假)
                {
                    返回 (-7)
                }
                keys = 读入文件 (语言模型路径2 + ".txt")
            }
            否则
            {
                语言字典路径2 = 取文本左边2_ (语言字典路径, ".txt", 真)
                如果真 (文件是否存在 (语言字典路径2 + ".txt") == 假)
                {
                    返回 (-8)
                }
                keys = 读入文件 (语言字典路径2 + ".txt")
            }
        }
        如果 (rec.取字节集长度 () == 0 || keys.取字节集长度 () == 0)
        {
            调试输出 ("载入模型失败")
            返回 (-9)
        }
        集模型指针 = RapidOCR_GPU识别类api.model (det.取字节集指针 (), det.取字节集长度 (), cls.取字节集指针 (), cls.取字节集长度 (), rec.取字节集指针 (), rec.取字节集长度 (), keys.取字节集指针 (), 线程数量, 选择 (是否开启GPU, 1, 0))
        返回 (集模型指针)
    }

    方法 识别_多行 <公开 类型 = 字节集类 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 识别类型 <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度(文本|#|位置|#|可信度|#|单字信息)  默认2" @默认值 = 1>
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    {
        变量 局_返回内容指针 <类型 = 变整数>
        变量 局_返回内容长度 <类型 = 整数>
        变量 局_结果数据 <类型 = 字节集类>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        RapidOCR_GPU识别类api.ocr (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 识别类型, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度, 取变量地址 (局_返回内容指针), 取变量地址 (局_返回内容长度))
        如果真 (局_返回内容指针 < 0 && 局_返回内容长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_返回内容指针, 局_返回内容长度)
        RapidOCR_GPU识别类api.del (局_返回内容指针)
        返回 (局_结果数据)
    }

    方法 识别_多行2 <公开 类型 = 文本型 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 识别类型 <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度(文本|#|位置|#|可信度|#|单字信息)  默认2" @默认值 = 2>
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_多行 (模型指针, 图片数据, 识别类型, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 识别_单行 <公开 类型 = 字节集类 注释 = "成功返回识别到的文字内容." 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠 折叠2>
    参数 模型指针 <类型 = 变整数>
    参数 图片数据 <类型 = 字节集类>
    {
        变量 局_结果数据 <类型 = 字节集类>
        变量 局_指针 <类型 = 变整数>
        变量 局_长度 <类型 = 整数>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        RapidOCR_GPU识别类api.ocrlite (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 取变量地址 (局_指针), 取变量地址 (局_长度))
        如果真 (局_长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_指针, 局_长度)
        RapidOCR_GPU识别类api.del (局_指针)
        返回 (局_结果数据)
    }

    方法 识别_单行2 <公开 类型 = 文本型 注释 = "成功返回识别到的文字内容" 折叠>
    参数 模型指针 <类型 = 变整数>
    参数 图片数据 <类型 = 字节集类>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_单行 (模型指针, 图片数据)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 识别_找字 <公开 类型 = 字节集类 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 找字数据 <类型 = 文本型 注释 = "找多个请用|隔开，比如： 李逍遥|赵灵儿  注意：为了仅支持多语言使用，字典和要找的文字必须都是utf8编码的；还有如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    {
        变量 局_返回内容指针 <类型 = 变整数>
        变量 局_返回内容长度 <类型 = 整数>
        变量 局_结果数据 <类型 = 字节集类>
        变量 找字数据2 <类型 = 字节集类>
        变量 找字数据3 <类型 = 字节集类>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        如果真 (找字数据 == "")
        {
            调试输出 ("找字数据不能为空")
            返回 (取空白字节集 (0))
        }
        找字数据2 = 文本到UTF8_ (找字数据)
        找字数据3 = 找字数据2
        找字数据3.添加字节集内容 (124)
        RapidOCR_GPU识别类api.findtext (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 找字数据3.取字节集指针 (), 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度, 取变量地址 (局_返回内容指针), 取变量地址 (局_返回内容长度))
        如果真 (局_返回内容指针 < 0 && 局_返回内容长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_返回内容指针, 局_返回内容长度)
        RapidOCR_GPU识别类api.del (局_返回内容指针)
        返回 (局_结果数据)
    }

    方法 识别_找字2 <公开 类型 = 文本型 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 找字数据 <类型 = 文本型 注释 = "找多个请用|隔开，比如： 李逍遥|赵灵儿  注意：为了仅支持多语言使用，字典和要找的文字必须都是utf8编码的；还有如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_找字 (模型指针, 图片数据, 找字数据, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 释放模型_ <公开 折叠>
    参数 模型指针 <类型 = 变整数>
    {
        如果真 (模型指针 < 1)
        {
            返回
        }
        RapidOCR_GPU识别类api.delmodel (模型指针)
        集模型指针 = 0
        模型指针 = 0
    }
}

类 RapidOCR_GPU识别类api <折叠 @文档 = "category = \"OCR文字识别库.RapidOCR识别库_GPU.附加库\"">
{
    方法 model <公开 静态 类型 = 变整数 注释 = "成功返回模型指针" @输出名 = "model" @视窗.输入 = "RapidOcrOnnxGpu.dll">
