类 OCR结果类 <公开 注释 = "存坐标的数组" 折叠 折叠2 @文档 = "category = \"OCR文字识别库.NCNN识别库.附加库\"" @视窗.结构类 = 0>
{
    变量 文字 <公开 类型 = 文本型 注释 = "识别的文字">
    变量 x1 <公开 类型 = 整数 注释 = "左上" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 y1 <公开 类型 = 整数 注释 = "左上" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 x2 <公开 类型 = 整数 注释 = "右上" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 y2 <公开 类型 = 整数 注释 = "右上" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 x3 <公开 类型 = 整数 注释 = "右下" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 y3 <公开 类型 = 整数 注释 = "右下" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 x4 <公开 类型 = 整数 注释 = "左下" 编辑时信息 = "0, 10F0E, 0, 0">
    变量 y4 <公开 类型 = 整数 注释 = "左下" 编辑时信息 = "0, 10F0E, 0, 0">
}
