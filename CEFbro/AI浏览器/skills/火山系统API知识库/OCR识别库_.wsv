类 RapidOCR识别类api <折叠 @文档 = "category = \"OCR文字识别库.RapidOCR识别库.附加库\"">
{
    方法 model <公开 静态 类型 = 变整数 注释 = "成功返回模型指针" 折叠 折叠2 @输出名 = "model" @视窗.输入 = "RapidOCR.dll">
    参数 modelDet <类型 = 变整数>
    参数 modelDetlen <类型 = 整数>
    参数 modelCls <类型 = 变整数>
    参数 modelClslen <类型 = 整数>
    参数 modelRec <类型 = 变整数>
    参数 modelReclen <类型 = 整数>
    参数 keys <类型 = 变整数>
    参数 numThread <类型 = 整数>
    {

    }

    方法 delmodel <公开 静态 注释 = "释放模型" 折叠 折叠2 @输出名 = "delmodel" @视窗.输入 = "RapidOCR.dll">
    参数 model <类型 = 变整数>
    {

    }

    方法 ocr <公开 静态 注释 = "多行识别" 折叠 折叠2 @输出名 = "ocr" @视窗.输入 = "RapidOCR.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 return_type <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度（文本|#|位置|#|可信度|#|单字信息）  6多行文字格式JSON   7多行文字格式JSON(不转义)">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值">
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32">
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值">
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度">
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大">
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类">
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }

    方法 del <公开 静态 类型 = 变整数 注释 = "释放返回内容指针" 折叠 折叠2 @输出名 = "del" @视窗.输入 = "RapidOCR.dll">
    参数 buffer <类型 = 变整数>
    {

    }

    方法 ocrlite <公开 静态 注释 = "单行识别" 折叠 折叠2 @输出名 = "ocrlite" @视窗.输入 = "RapidOCR.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }

    方法 findtext <公开 静态 注释 = "找字坐标" 折叠 折叠2 @输出名 = "findtext" @视窗.输入 = "RapidOCR.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 findtext <类型 = 变整数
            注释 = "不区分大小写，识别多个请用|隔开，比如： 李逍遥|赵灵儿|林月如  找到返回：要找的字,坐标X,坐标Y  没找到返回-1   注意：如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移。">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值">
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32">
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值">
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度">
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大">
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类">
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }
}

