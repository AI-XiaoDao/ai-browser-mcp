类 验证码识别类DdddOcr_X64 <公开 注释 = "基于DdddOcr所开发的识别" 折叠 折叠2 @文档 = "category = \"OCR文字识别库.Dddd识别库\""
        @视窗.附属文件 = "OCR\\DdddOcr\\X64\\ddddocr.dll" @视窗.需求目标平台 = @"64位平台">
{
    变量 已初始 <类型 = 逻辑型>

    方法 初始化_ <公开 类型 = 逻辑型 折叠>
    参数 线程数量 <类型 = 整数 @默认值 = 7>
    {
        已初始 = dddd_init (线程数量, 真)
        返回 (已初始)
    }

    方法 识别图片_ <公开 类型 = 文本型 折叠>
    参数 图片数据 <类型 = 字节集类>
    {
        变量 数据指针 <类型 = 变整数>
        如果真 (已初始 == 假)
        {
            初始化_ ()
        }
        数据指针 = identify (图片数据.取字节集指针 (), 图片数据.取字节集长度 ())
        返回 (多字节指针到文本 (数据指针))
    }

    方法 dddd_init <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "dddd_init" @视窗.输入 = "ddddocr.dll">
    参数 线程数量 <类型 = 整数>
    参数 old <类型 = 逻辑型>
    {

    }

    方法 identify <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "dddd_cls" @视窗.输入 = "ddddocr.dll">
    参数 图片数据 <类型 = 变整数>
    参数 图片长度 <类型 = 整数>
}

