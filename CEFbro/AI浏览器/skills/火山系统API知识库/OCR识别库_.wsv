# //====

类 OCR识别类_ <公开 注释 = "基于NCNN所开发的OCR文字识别。外置模块文件" 注释 = "" 折叠 折叠2 @文档 = "category = \"OCR文字识别库.NCNN识别库\""
        @视窗.附属文件 = "OCR\\OcrLiteOnnx\\$(p)\\OcrLiteOnnx.dll" @视窗.附属文件 = "OCR\\models\\Resource.dat">
{
    变量 字典 <静态 类型 = 视窗文件资源 值 = "OCR\\models\\keys.txt">
    变量 模型指针 <类型 = 变整数>
    变量 资源1 <类型 = 资源包类_>

    方法 初始化 <公开 类型 = 变整数 返回值注释 = "返回创建指针" 折叠>
    {
        变量 db <类型 = 字节集类>
        变量 ag <类型 = 字节集类>
        变量 cr <类型 = 字节集类>
        变量 ky <类型 = 字节集类>
        如果 (模型指针 == 0)
        {
            资源1.加载资源包_路径 (取运行目录 () + "Resource.dat")
            db = 资源1.读取_ ("Dbnet")
            ag = 资源1.读取_ ("Angle")
            cr = 资源1.读取_ ("Crnn")
            ky = 取出资源文件_ (字典)
            模型指针 = OCRapi类.创建多行识别模型 (4, db.取字节集指针 (), db.取字节集长度 (), ag.取字节集指针 (), ag.取字节集长度 (), cr.取字节集指针 (), cr.取字节集长度 (), ky.取字节集指针 ())
        }
        否则
        {
            调试输出 ("已经初始化", 模型指针)
        }
        返回 (模型指针)
    }

    方法 关闭 <公开 折叠>
    参数 指针 <类型 = 变整数 注释 = "初始化时所返回的指针">
    {
        OCRapi类.释放模型 (指针)
    }

    方法 单行识别 <公开 类型 = 文本型 折叠>
    参数 图片数据 <类型 = 字节集类>
    {
        变量 结果文本 <类型 = 文本型>
        结果文本 = 指针到文本_多字节 (OCRapi类.DLL_单行识别 (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 ()))
        返回 (结果文本)
    }

    方法 多行识别 <公开 类型 = 对象数组类 返回值注释 = "OCR结果类" 折叠>
    参数 图片数据 <类型 = 字节集类>
    参数 参数 <类型 = 文本型 注释 = "50,1024,0.6,0.3,2,1,1" @默认值 = "50,1024,0.6,0.3,2,1,1">
    参数 识别结果 <类型 = 文本型 @默认值 = "">
    {
        变量 临时参数数组 <类型 = 文本数组类>
        变量 填充 <类型 = 整数>
        变量 大文本长度 <类型 = 整数>
        变量 边框置信度阈值 <类型 = 单精度小数>
        变量 边框合并阈值 <类型 = 单精度小数>
        变量 非裁剪系数 <类型 = 单精度小数>
        变量 是否做角度检测 <类型 = 逻辑型>
        变量 启用最大角度 <类型 = 逻辑型>
        变量 结果文本 <类型 = 文本型>
        分割文本 (参数, ",", 临时参数数组, , )
        // 填充,最大文本长度,边框置信度阈值,边框合并阈值,非裁剪系数,是否做角度检测
        如果 (临时参数数组.取成员数 () == 7)
        {
            填充 = 文本到整数 (临时参数数组.取成员 (0))
            大文本长度 = 文本到整数 (临时参数数组.取成员 (1))
            边框置信度阈值 = 文本到单精度小数 (临时参数数组.取成员 (2))
            边框合并阈值 = 文本到单精度小数 (临时参数数组.取成员 (3))
            非裁剪系数 = 文本到单精度小数 (临时参数数组.取成员 (4))
            如果 (文本到整数 (临时参数数组.取成员 (5)) == 1)
            {
                是否做角度检测 = 真
            }
            否则
            {
                是否做角度检测 = 假
            }
            如果 (文本到整数 (临时参数数组.取成员 (6)) == 1)
            {
                启用最大角度 = 真
            }
            否则
            {
                启用最大角度 = 假
            }
        }
        否则
        {
            填充 = 50
            大文本长度 = 1024
            边框置信度阈值 = 0.6
            边框合并阈值 = 0.3
            非裁剪系数 = 2
            是否做角度检测 = 假
            启用最大角度 = 真
        }
        结果文本 = 指针到文本_多字节 (OCRapi类.DLL_多行识别 (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 填充, 大文本长度, 边框置信度阈值, 边框合并阈值, 非裁剪系数, 是否做角度检测, 启用最大角度))
        变量 JSON <类型 = JSON对象类_ 折叠>
        变量 键名数组 <类型 = 文本数组类>
        变量 临时文本 <类型 = 文本型>
        变量 识别内容 <类型 = 文本型>
        变量 JSON数组 <类型 = JSON数组类_>
        变量 JSON2 <类型 = JSON对象类_>
        变量 坐标数组 <类型 = JSON数组类_>
        变量 JSON4 <类型 = JSON对象类_>
        变量 x1 <类型 = 整数>
        变量 y4 <类型 = 整数>
        变量 y3 <类型 = 整数>
        变量 y2 <类型 = 整数>
        变量 y1 <类型 = 整数>
        变量 x4 <类型 = 整数>
        变量 x3 <类型 = 整数>
        变量 x2 <类型 = 整数>
        变量 临时坐标文本 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 OCR结果数组 <类型 = 对象数组类>
        JSON.创建自文本 (结果文本)
        如果真 (JSON.成员数 > 0)
        {
            JSON.取数组值 ("list", JSON数组)
            计次循环 (JSON数组.成员数)
            {
                临时文本 = JSON数组.取文本值 (取循环索引 ())
                JSON2.创建自文本 (临时文本)
                识别内容 = JSON2.取文本值 ("txt")
                加入文本 (识别结果, 识别内容 + "\r\n")
                JSON2.取数组值 ("pts", 坐标数组)
                计次循环 (坐标数组.成员数)
                {
                    i = 取循环索引 ()
                    临时坐标文本 = 坐标数组.取文本值 (i)
                    JSON4.创建自文本 (临时坐标文本)
                    如果 (i == 0)
                    {
                        x1 = JSON4.取整数值 ("x1")
                    }
                    否则 (i == 1)
                    {
                        y1 = JSON4.取整数值 ("y1")
                    }
                    否则 (i == 2)
                    {
                        x2 = JSON4.取整数值 ("x2")
                    }
                    否则 (i == 3)
                    {
                        y2 = JSON4.取整数值 ("y2")
                    }
                    否则 (i == 4)
                    {
                        x3 = JSON4.取整数值 ("x3")
                    }
                    否则 (i == 5)
                    {
                        y3 = JSON4.取整数值 ("y3")
                    }
                    否则 (i == 6)
                    {
                        x4 = JSON4.取整数值 ("x4")
                    }
                    否则 (i == 7)
                    {
                        y4 = JSON4.取整数值 ("y4")
                    }
                }
                变量 临时OCR <类型 = OCR结果类>
                临时OCR.x1 = x1
                临时OCR.y1 = y1
                临时OCR.x2 = x2
                临时OCR.y2 = y2
                临时OCR.x3 = x3
                临时OCR.y3 = y3
                临时OCR.x4 = x4
                临时OCR.y4 = y4
                临时OCR.文字 = 识别内容
                OCR结果数组.加入成员 (临时OCR)
            }
        }
        返回 (OCR结果数组)
    }

    方法 多行找字 <公开 类型 = 整数 折叠>
    参数 图片数据 <类型 = 字节集类>
    参数 参数 <类型 = 文本型 @默认值 = "50,1024,0.6,0.3,2,1,1">
    参数 欲寻找文字 <类型 = 文本型>
    参数 x <类型 = 整数类>
    参数 y <类型 = 整数类>
    {
        变量 识别结果 <类型 = 文本型>
        变量 识别结果数组 <类型 = 对象数组类>
        变量 寻找字数组 <类型 = 文本数组类>
        变量 临时文字 <类型 = 文本型>
        变量 临时数值 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 文字索引 <类型 = 整数>
        变量 找到的字 <类型 = 文本型>
        识别结果数组 = 多行识别 (图片数据, 参数, 识别结果)
        分割文本 (欲寻找文字, "|", 寻找字数组, , )
        计次循环 (寻找字数组.取成员数 ())
        {
            i = 取循环索引 ()
            临时文字 = 寻找字数组.取成员 (i)
            临时数值 = 寻找文本 (识别结果, 临时文字, , )
            如果真 (临时数值 != -1)
            {
                文字索引 = i + 1
                找到的字 = 临时文字
                跳出循环
            }
        }
        如果真 (文字索引 > 0)
        {
            计次循环 (识别结果数组.取成员数 ())
            {
                变量 临时结果 <类型 = OCR结果类>
                变量 总长度 <类型 = 整数>
                变量 每个字的长度 <类型 = 整数>
                变量 起始位置 <类型 = 整数>
                变量 文字长度 <类型 = 整数>
                变量 文字中心 <类型 = 整数>
                临时结果 = (OCR结果类)识别结果数组.取成员 (取循环索引 ())
                临时数值 = 寻找文本 (临时结果.文字, 找到的字, , )
                如果真 (临时数值 != -1)
                {
                    y.值 = 临时结果.y1 + (临时结果.y3 - 临时结果.y1) / 2
                    如果 (临时结果.文字 == 找到的字)
                    {
                        x.值 = 临时结果.x1 + (临时结果.x3 - 临时结果.x1) / 2
                    }
                    否则
                    {
                        总长度 = 取文本长度 (临时结果.文字)
                        文字长度 = 取文本长度 (找到的字)
                        每个字的长度 = (临时结果.x3 - 临时结果.x1 + 1) / 总长度
                        起始位置 = 临时结果.x1 + 临时数值 * 每个字的长度
                        文字中心 = 文字长度 * 每个字的长度 / 2
                        x.值 = 起始位置 + 文字中心
                    }
                    跳出循环
                }
            }
        }
        返回 (文字索引)
    }
}

