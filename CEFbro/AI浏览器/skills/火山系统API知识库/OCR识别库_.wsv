    参数 modelDetlen <类型 = 整数>
    参数 modelCls <类型 = 变整数>
    参数 modelClslen <类型 = 整数>
    参数 modelRec <类型 = 变整数>
    参数 modelReclen <类型 = 整数>
    参数 keys <类型 = 变整数>
    参数 numThread <类型 = 整数>
    参数 gpu <类型 = 整数>
    {

    }

    方法 delmodel <公开 静态 注释 = "释放模型" 折叠 @输出名 = "delmodel" @视窗.输入 = "RapidOcrOnnxGpu.dll">
    参数 model <类型 = 变整数>
    {

    }

    方法 ocr <公开 静态 注释 = "多行识别" 折叠 @输出名 = "ocr" @视窗.输入 = "RapidOcrOnnxGpu.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 return_type <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度（文本|#|位置|#|可信度|#|单字信息）  6多行文字格式JSON   7多行文字格式JSON(不转义)">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值">
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32">
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值">
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度">
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大">
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类">
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }

    方法 del <公开 静态 类型 = 变整数 注释 = "释放返回内容指针" 折叠 @输出名 = "del" @视窗.输入 = "RapidOcrOnnxGpu.dll">
    参数 buffer <类型 = 变整数>
    {

    }

    方法 ocrlite <公开 静态 注释 = "单行识别" 折叠 @输出名 = "ocrlite" @视窗.输入 = "RapidOcrOnnxGpu.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }

    方法 findtext <公开 静态 注释 = "找字坐标" 折叠 @输出名 = "findtext" @视窗.输入 = "RapidOcrOnnxGpu.dll">
    参数 model <类型 = 变整数 注释 = "模型指针">
    参数 ingbuffer <类型 = 变整数 注释 = "图片">
    参数 ingbufferlen <类型 = 整数 注释 = "图片长度">
    参数 findtext <类型 = 变整数
            注释 = "不区分大小写，识别多个请用|隔开，比如： 李逍遥|赵灵儿|林月如  找到返回：要找的字,坐标X,坐标Y  没找到返回-1   注意：如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移。">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值">
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32">
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值">
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度">
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大">
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类">
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用">
    参数 return_str <类型 = 变整数 注释 = "返回内容指针">
    参数 return_str_len <类型 = 变整数 注释 = "返回内容长度">
    {

    }
}

类 RapidOCR识别类_ <公开 注释 = "本库为CPU版，基于RapidOCR所开发的OCR文字识别。编译库出自“李逍遥”作品" 折叠 折叠2 @文档 = "category = \"OCR文字识别库.RapidOCR识别库\""
        @视窗.附属文件 = "OCR\\RapidOCR\\$(p)\\RapidOCR.dll" @视窗.附属文件 = "OCR\\OCR模型>OCR模型">
{
    变量 集模型指针 <类型 = 变整数>

    方法 类_清理 <折叠>
    {
        如果真 (集模型指针 > 0)
        {
            释放模型_ (集模型指针)
            集模型指针 = 0
        }
    }

    方法 加载模型_ <公开 类型 = 变整数 注释 = "不用时记得调用“释放模型_”释放内存，不然会造成内存泄漏" 返回值注释 = "成功返回大于0的模型指针，错误返回负数" 折叠>
    参数 线程数量 <类型 = 整数 注释 = "默认4 不超过CPU核心数，设置高不一定就快" @默认值 = 4>
    参数 检测模型路径 <类型 = 文本型 注释 = "默认为“中文_OCRv4.onnx”，也可调用类名参数如：OCR检测模型.中文_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    参数 语言模型路径 <类型 = 文本型 注释 = "默认为“中文简体_OCRv4”，也可调用类名参数如：OCR语言模型.中文简体_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    参数 语言字典路径 <类型 = 文本型 注释 = "可留空无需设置，默认是跟随参数三。也可调用类名参数如：OCR字典模型.中文简体_OCRv4（需要在前面加上“取运行目录 ()”）" @默认值 = "">
    {
        变量 语言模型路径2 <类型 = 文本型>
        变量 语言字典路径2 <类型 = 文本型>
        变量 检测模型路径2 <类型 = 文本型>
        变量 det <类型 = 字节集类>
        变量 cls <类型 = 字节集类>
        变量 rec <类型 = 字节集类>
        变量 keys <类型 = 字节集类>
        如果 (检测模型路径 == "")
        {
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\检测模型\\中文_OCRv4.onnx") == 假)
            {
                返回 (-1)
            }
            det = 读入文件 (取运行目录 () + "OCR模型\\检测模型\\中文_OCRv4.onnx")
        }
        否则
        {
            检测模型路径2 = 取文本左边2_ (检测模型路径, ".onnx", 真)
            如果真 (文件是否存在 (检测模型路径2 + ".onnx") == 假)
            {
                返回 (-2)
            }
            det = 读入文件 (检测模型路径2 + ".onnx")
        }
        如果真 (文件是否存在 (取运行目录 () + "OCR模型\\方向模型\\原始分类器模型.onnx") == 假)
        {
            返回 (-3)
        }
        cls = 读入文件 (取运行目录 () + "OCR模型\\方向模型\\原始分类器模型.onnx")
        如果 (语言模型路径 == "")
        {
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\识别模型\\中文简体_OCRv4.onnx") == 假)
            {
                返回 (-4)
            }
            如果真 (文件是否存在 (取运行目录 () + "OCR模型\\识别字典\\中文简体_OCRv4.txt") == 假)
            {
                返回 (-5)
            }
            rec = 读入文件 (取运行目录 () + "OCR模型\\识别模型\\中文简体_OCRv4.onnx")
            keys = 读入文件 (取运行目录 () + "OCR模型\\识别字典\\中文简体_OCRv4.txt")
        }
        否则
        {
            语言模型路径2 = 取文本左边2_ (语言模型路径, ".onnx", 真)
            如果真 (文件是否存在 (语言模型路径2 + ".onnx") == 假)
            {
                返回 (-6)
            }
            rec = 读入文件 (语言模型路径2 + ".onnx")
            如果 (语言字典路径 == "")
            {
                子文本替换 (语言模型路径2, "识别模型", "识别字典")
                如果真 (文件是否存在 (语言模型路径2 + ".txt") == 假)
                {
                    返回 (-7)
                }
                keys = 读入文件 (语言模型路径2 + ".txt")
            }
            否则
            {
                语言字典路径2 = 取文本左边2_ (语言字典路径, ".txt", 真)
                如果真 (文件是否存在 (语言字典路径2 + ".txt") == 假)
                {
                    返回 (-8)
                }
                keys = 读入文件 (语言字典路径2 + ".txt")
            }
        }
        如果 (rec.取字节集长度 () == 0 || keys.取字节集长度 () == 0)
        {
            调试输出 ("载入模型失败")
            返回 (-8)
        }
        集模型指针 = RapidOCR识别类api.model (det.取字节集指针 (), det.取字节集长度 (), cls.取字节集指针 (), cls.取字节集长度 (), rec.取字节集指针 (), rec.取字节集长度 (), keys.取字节集指针 (), 线程数量)
        返回 (集模型指针)
    }

    方法 识别_多行 <公开 类型 = 字节集类 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 识别类型 <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度(文本|#|位置|#|可信度|#|单字信息)  默认2" @默认值 = 1>
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    {
        变量 局_返回内容指针 <类型 = 变整数>
        变量 局_返回内容长度 <类型 = 整数>
        变量 局_结果数据 <类型 = 字节集类>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        RapidOCR识别类api.ocr (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 识别类型, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度, 取变量地址 (局_返回内容指针), 取变量地址 (局_返回内容长度))
        如果真 (局_返回内容指针 < 0 && 局_返回内容长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_返回内容指针, 局_返回内容长度)
        RapidOCR识别类api.del (局_返回内容指针)
        返回 (局_结果数据)
    }

    方法 识别_多行2 <公开 类型 = 文本型 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 识别类型 <类型 = 整数 注释 = "0单行文字识别   1多行文字识别   2多行文字识别并返回位置可信度(文本|#|位置|#|可信度|#|单字信息)  默认2" @默认值 = 2>
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_多行 (模型指针, 图片数据, 识别类型, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 识别_单行 <公开 类型 = 字节集类 注释 = "成功返回识别到的文字内容." 注释 = "如需更高性能版，请联系仰望，付费购买" 折叠 折叠2>
    参数 模型指针 <类型 = 变整数>
    参数 图片数据 <类型 = 字节集类>
    {
        变量 局_结果数据 <类型 = 字节集类>
        变量 局_指针 <类型 = 变整数>
        变量 局_长度 <类型 = 整数>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        RapidOCR识别类api.ocrlite (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 取变量地址 (局_指针), 取变量地址 (局_长度))
        如果真 (局_长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_指针, 局_长度)
        RapidOCR识别类api.del (局_指针)
        返回 (局_结果数据)
    }

    方法 识别_单行2 <公开 类型 = 文本型 注释 = "成功返回识别到的文字内容" 折叠>
    参数 模型指针 <类型 = 变整数>
    参数 图片数据 <类型 = 字节集类>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_单行 (模型指针, 图片数据)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 识别_找字 <公开 类型 = 字节集类 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 找字数据 <类型 = 文本型 注释 = "找多个请用|隔开，比如： 李逍遥|赵灵儿  注意：为了仅支持多语言使用，字典和要找的文字必须都是utf8编码的；还有如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    {
        变量 局_返回内容指针 <类型 = 变整数>
        变量 局_返回内容长度 <类型 = 整数>
        变量 局_结果数据 <类型 = 字节集类>
        变量 找字数据2 <类型 = 字节集类>
        变量 找字数据3 <类型 = 字节集类>
        如果真 (图片数据.取字节集长度 () == 0 || 模型指针 < 0)
        {
            调试输出 ("图片数据为空或模型指针错误")
            返回 (取空白字节集 (0))
        }
        如果真 (找字数据 == "")
        {
            调试输出 ("找字数据不能为空")
            返回 (取空白字节集 (0))
        }
        找字数据2 = 文本到UTF8_ (找字数据)
        找字数据3 = 找字数据2
        找字数据3.添加字节集内容 (124)
        RapidOCR识别类api.findtext (模型指针, 图片数据.取字节集指针 (), 图片数据.取字节集长度 (), 找字数据3.取字节集指针 (), 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度, 取变量地址 (局_返回内容指针), 取变量地址 (局_返回内容长度))
        如果真 (局_返回内容指针 < 0 && 局_返回内容长度 == 0)
        {
            调试输出 ("识别返回错误")
            返回 (取空白字节集 (0))
        }
        局_结果数据 = 指针到字节集 (局_返回内容指针, 局_返回内容长度)
        RapidOCR识别类api.del (局_返回内容指针)
        返回 (局_结果数据)
    }

    方法 识别_找字2 <公开 类型 = 文本型 折叠>
    参数 模型指针 <类型 = 变整数 注释 = "加载模型_ 返回的模型指针">
    参数 图片数据 <类型 = 字节集类>
    参数 找字数据 <类型 = 文本型 注释 = "找多个请用|隔开，比如： 李逍遥|赵灵儿  注意：为了仅支持多语言使用，字典和要找的文字必须都是utf8编码的；还有如果一行字存在间隔和大小相差较大的情况下，坐标也会有较大的偏移">
    参数 图像白边度 <类型 = 整数 注释 = "图像预处理，在图片外周添加白边，用于提升识别率，文字框没有正确框住所有文字时，增加此值" @默认值 = 60>
    参数 图像缩放度 <类型 = 整数 注释 = "按图片最长边的长度，此值为0代表不缩放，例：1024，如果图片长边大于1024则把图像整体缩小到1024再进行图像分割计算，如果图片长边小于1024则不缩放，如果图片长边小于32，则缩放到32"
            @默认值 = 1024>
    参数 文本框置信度 <类型 = 单精度小数 注释 = "文字框文本框置信度，文字框没有正确框住所有文字时，减小此值" @默认值 = 0.3>
    参数 文本框置信度2 <类型 = 单精度小数 注释 = "文本框置信度" @默认值 = 0.3>
    参数 大小倍率 <类型 = 单精度小数 注释 = "单个文字框大小倍率，越大时单个文字框越大。此项与图片的大小相关，越大的图片此值应该越大" @默认值 = 1.5>
    参数 旋转文字方向 <类型 = 逻辑型 注释 = "文字方向分类，只有图片倒置的情况下(旋转90~270度的图片)，才需要旋转文字方向分类" @默认值 = 假>
    参数 旋转角度 <类型 = 逻辑型 注释 = "整张图片以最大可能文字方向来识别，当禁用旋转文字方向检测时，此项也不起作用" @默认值 = 假>
    参数 编码类型 <类型 = 逻辑型 注释 = "真：UTF-8 假：ANSI" @默认值 = 真>
    {
        变量 局_结果数据 <类型 = 字节集类>
        局_结果数据 = 识别_找字 (模型指针, 图片数据, 找字数据, 图像白边度, 图像缩放度, 文本框置信度, 文本框置信度2, 大小倍率, 旋转文字方向, 旋转角度)
        返回 (选择 (编码类型, UTF8到文本_ (局_结果数据), 多字节到文本_ (局_结果数据)))
    }

    方法 释放模型_ <公开 折叠>
    参数 模型指针 <类型 = 变整数>
    {
        如果真 (模型指针 < 1)
        {
            返回
        }
        RapidOCR识别类api.delmodel (模型指针)
        集模型指针 = 0
        模型指针 = 0
    }
}

