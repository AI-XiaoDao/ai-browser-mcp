    参数 unClipRatio <类型 = 单精度小数 注释 = "非裁剪系数" "">
    参数 doAngle <类型 = 逻辑型 注释 = "是否做角度检测" "">
    参数 mostAngle <类型 = 逻辑型 注释 = "？？" "">
    {

    }

    方法 DLL_单行识别 <公开 静态 类型 = 变整数 折叠 折叠2 @视窗.输入 = "OcrLiteOnnx.dll" @输出名 = "GetTextLine" @视窗.前缀文本 = "@CDECL">
    参数 modelHandle <类型 = 变整数>
    参数 img <类型 = 变整数>
    参数 imgLength <类型 = 整数>

    方法 释放模型 <公开 静态 折叠 折叠2 @视窗.输入 = "OcrLiteOnnx.dll" @输出名 = "OcrDestroy" @视窗.前缀文本 = "@CDECL">
    参数 modelHandle <类型 = 变整数>
