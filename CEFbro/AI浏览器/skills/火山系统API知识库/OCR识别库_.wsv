                    否则 (i == 7)
                    {
                        y4 = JSON4.取整数值 ("y4")
                    }
                }
                变量 临时OCR <类型 = OCR结果类>
                临时OCR.x1 = x1
                临时OCR.y1 = y1
                临时OCR.x2 = x2
                临时OCR.y2 = y2
                临时OCR.x3 = x3
                临时OCR.y3 = y3
                临时OCR.x4 = x4
                临时OCR.y4 = y4
                临时OCR.文字 = 识别内容
                OCR结果数组.加入成员 (临时OCR)
            }
        }
        返回 (OCR结果数组)
    }

    方法 多行找字 <公开 类型 = 整数 折叠>
    参数 图片数据 <类型 = 字节集类>
    参数 参数 <类型 = 文本型 @默认值 = "50,1024,0.6,0.3,2,1,1">
    参数 欲寻找文字 <类型 = 文本型>
    参数 x <类型 = 整数类>
    参数 y <类型 = 整数类>
    {
        变量 识别结果 <类型 = 文本型>
        变量 识别结果数组 <类型 = 对象数组类>
        变量 寻找字数组 <类型 = 文本数组类>
        变量 临时文字 <类型 = 文本型>
        变量 临时数值 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 文字索引 <类型 = 整数>
        变量 找到的字 <类型 = 文本型>
        识别结果数组 = 多行识别 (图片数据, 参数, 识别结果)
        分割文本 (欲寻找文字, "|", 寻找字数组, , )
        计次循环 (寻找字数组.取成员数 ())
        {
            i = 取循环索引 ()
            临时文字 = 寻找字数组.取成员 (i)
            临时数值 = 寻找文本 (识别结果, 临时文字, , )
            如果真 (临时数值 != -1)
            {
                文字索引 = i + 1
                找到的字 = 临时文字
                跳出循环
            }
        }
        如果真 (文字索引 > 0)
        {
            计次循环 (识别结果数组.取成员数 ())
            {
                变量 临时结果 <类型 = OCR结果类>
                变量 总长度 <类型 = 整数>
                变量 每个字的长度 <类型 = 整数>
                变量 起始位置 <类型 = 整数>
                变量 文字长度 <类型 = 整数>
                变量 文字中心 <类型 = 整数>
                临时结果 = (OCR结果类)识别结果数组.取成员 (取循环索引 ())
                临时数值 = 寻找文本 (临时结果.文字, 找到的字, , )
                如果真 (临时数值 != -1)
                {
                    y.值 = 临时结果.y1 + (临时结果.y3 - 临时结果.y1) / 2
                    如果 (临时结果.文字 == 找到的字)
                    {
                        x.值 = 临时结果.x1 + (临时结果.x3 - 临时结果.x1) / 2
                    }
                    否则
                    {
                        总长度 = 取文本长度 (临时结果.文字)
                        文字长度 = 取文本长度 (找到的字)
                        每个字的长度 = (临时结果.x3 - 临时结果.x1 + 1) / 总长度
                        起始位置 = 临时结果.x1 + 临时数值 * 每个字的长度
                        文字中心 = 文字长度 * 每个字的长度 / 2
                        x.值 = 起始位置 + 文字中心
                    }
                    跳出循环
                }
            }
        }
        返回 (文字索引)
    }
}

类 OCRapi类 <折叠 @文档 = "category = \"OCR文字识别库.NCNN识别库.附加库\"">
{
    方法 创建多行识别模型 <公开 静态 类型 = 变整数 折叠 折叠2 @视窗.输入 = "OcrLiteOnnx.dll" @输出名 = "OcrInitBin" @视窗.前缀文本 = "@CDECL">
