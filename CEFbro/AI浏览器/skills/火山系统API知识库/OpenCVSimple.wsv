<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <编辑时信息 = "246FDB, 0, 0, 0" @文档 = "category = \"开源库.OpenCV\"" "" "" @视窗.外部头文件 = "OpenCVSimple\\OpenCVTool.h"
        @视窗.外部库.win32 = "OpenCVSimple\\OpenCVSimplex86.lib" @视窗.附属文件.win32 = "OpenCVSimple\\OpenCVSimplex86.dll" "" ""
        @视窗.外部库.x64 = "OpenCVSimple\\OpenCVSimplex64.lib" @视窗.附属文件.x64 = "OpenCVSimple\\OpenCVSimplex64.dll" "" "" "">

类 视频设备类型常量类 <公开 注释 = "       CAP_ANY          = 0,            //!< Auto detect == 0"
        注释 = "       CAP_VFW          = 200,          //!< Video For Windows (obsolete, removed)"
        注释 = "       CAP_V4L          = 200,          //!< V4L/V4L2 capturing support"
        注释 = "       CAP_V4L2         = CAP_V4L,      //!< Same as CAP_V4L"
        注释 = "       CAP_FIREWIRE     = 300,          //!< IEEE 1394 drivers"
        注释 = "       CAP_FIREWARE     = CAP_FIREWIRE, //!< Same value as CAP_FIREWIRE"
        注释 = "       CAP_IEEE1394     = CAP_FIREWIRE, //!< Same value as CAP_FIREWIRE"
        注释 = "       CAP_DC1394       = CAP_FIREWIRE, //!< Same value as CAP_FIREWIRE"
        注释 = "       CAP_CMU1394      = CAP_FIREWIRE, //!< Same value as CAP_FIREWIRE"
        注释 = "       CAP_QT           = 500,          //!< QuickTime (obsolete, removed)"
        注释 = "       CAP_UNICAP       = 600,          //!< Unicap drivers (obsolete, removed)"
        注释 = "       CAP_DSHOW        = 700,          //!< DirectShow (via videoInput)"
        注释 = "       CAP_PVAPI        = 800,          //!< PvAPI, Prosilica GigE SDK"
        注释 = "       CAP_OPENNI       = 900,          //!< OpenNI (for Kinect)"
        注释 = "       CAP_OPENNI_ASUS  = 910,          //!< OpenNI (for Asus Xtion)"
        注释 = "       CAP_ANDROID      = 1000,         //!< Android - not used"
        注释 = "       CAP_XIAPI        = 1100,         //!< XIMEA Camera API"
        注释 = "       CAP_AVFOUNDATION = 1200,         //!< AVFoundation framework for iOS (OS X Lion will have the same API)"
        注释 = "       CAP_GIGANETIX    = 1300,         //!< Smartek Giganetix GigEVisionSDK"
        注释 = "       CAP_MSMF         = 1400,         //!< Microsoft Media Foundation (via videoInput)"
        注释 = "       CAP_WINRT        = 1410,         //!< Microsoft Windows Runtime using Media Foundation"
        注释 = "       CAP_INTELPERC    = 1500,         //!< RealSense (former Intel Perceptual Computing SDK)"
        注释 = "       CAP_REALSENSE    = 1500,         //!< Synonym for CAP_INTELPERC"
        注释 = "       CAP_OPENNI2      = 1600,         //!< OpenNI2 (for Kinect)"
        注释 = "       CAP_OPENNI2_ASUS = 1610,         //!< OpenNI2 (for Asus Xtion and Occipital Structure sensors)"
        注释 = "       CAP_GPHOTO2      = 1700,         //!< gPhoto2 connection"
        注释 = "       CAP_GSTREAMER    = 1800,         //!< GStreamer"
        注释 = "       CAP_FFMPEG       = 1900,         //!< Open and record video file or stream using the FFMPEG library"
        注释 = "       CAP_IMAGES       = 2000,         //!< OpenCV Image Sequence (e.g. img_%02d.jpg)"
        注释 = "       CAP_ARAVIS       = 2100,         //!< Aravis SDK"
        注释 = "       CAP_OPENCV_MJPEG = 2200,         //!< Built-in OpenCV MotionJPEG codec"
        注释 = "       CAP_INTEL_MFX    = 2300,         //!< Intel MediaSDK"
        注释 = "       CAP_XINE         = 2400,         //!< XINE engine (Linux)" 折叠2 @常量类 = 整数>
{
    常量 任意设备 <公开 值 = 0 注释 = "">

    #
}

类 视频操作类 <公开 折叠>
{

    #
    # @begin
    # <> <include>
    # public:
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ m_pData = cv_VideoCapture_Create();
    }

    方法 类_清理
    {
        @ cv_VideoCapture_Destory(m_pData);
    }

    方法 关闭 <公开 @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Close(@sn<this>.m_pData)
    }

    方法 打开视频 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 视频地址 <类型 = 文本型 注释 = "可以是一个视频，或者是一个网络视频地址" 注释 = "protocol: //host:port/script_name?script_params|auth">
    参数 设备类型 <类型 = 视频设备类型常量类 @默认值 = 视频设备类型常量类.任意设备>
    {
        变量 地址 <类型 = 字节集类>
        地址 = 文本到多字节 (视频地址)
        @ return cv_VideoCapture_OpenFromUrl(m_pData,(const char*)@<地址>.GetPtr(),@<设备类型>);
    }

    方法 打开摄像头 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 摄像头索引 <类型 = 整数>
    参数 设备类型 <类型 = 视频设备类型常量类 @默认值 = 视频设备类型常量类.任意设备>
    {
        @ cv_VideoCapture_OpenFromCamera(@sn<this>.m_pData,@<摄像头索引>,@<设备类型>)
    }

    方法 是否已打开 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ cv_VideoCapture_IsOpen(@sn<this>.m_pData)
    }

    方法 取下一帧 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 当前帧图片 <类型 = 图片操作类>
    {
        @ cv_VideoCapture_read(@sn<this>.m_pData,@<当前帧图片>.m_pData)
    }

    方法 ""
    {
        // enum VideoCaptureProperties {
        // CAP_PROP_POS_MSEC       =0, //!< Current position of the video file in milliseconds.
        // CAP_PROP_POS_FRAMES     =1, //!< 0-based index of the frame to be decoded/captured next.
        // CAP_PROP_POS_AVI_RATIO  =2, //!< Relative position of the video file: 0=start of the film, 1=end of the film.
        // CAP_PROP_FRAME_WIDTH    =3, //!< Width of the frames in the video stream.
        // CAP_PROP_FRAME_HEIGHT   =4, //!< Height of the frames in the video stream.
        // CAP_PROP_FPS            =5, //!< Frame rate.
        // CAP_PROP_FOURCC         =6, //!< 4-character code of codec. see VideoWriter::fourcc .
        // CAP_PROP_FRAME_COUNT    =7, //!< Number of frames in the video file.
        // CAP_PROP_FORMAT         =8, //!< Format of the %Mat objects (see Mat::type()) returned by VideoCapture::retrieve().
        // //!< Set value -1 to fetch undecoded RAW video streams (as Mat 8UC1).
        // CAP_PROP_MODE           =9, //!< Backend-specific value indicating the current capture mode.
        // CAP_PROP_BRIGHTNESS    =10, //!< Brightness of the image (only for those cameras that support).
        // CAP_PROP_CONTRAST      =11, //!< Contrast of the image (only for cameras).
        // CAP_PROP_SATURATION    =12, //!< Saturation of the image (only for cameras).
        // CAP_PROP_HUE           =13, //!< Hue of the image (only for cameras).
        // CAP_PROP_GAIN          =14, //!< Gain of the image (only for those cameras that support).
        // CAP_PROP_EXPOSURE      =15, //!< Exposure (only for those cameras that support).
        // CAP_PROP_CONVERT_RGB   =16, //!< Boolean flags indicating whether images should be converted to RGB. <br/>
        // //!< *GStreamer note*: The flag is ignored in case if custom pipeline is used. It's user responsibility to interpret pipeline output.
        // CAP_PROP_WHITE_BALANCE_BLUE_U =17, //!< Currently unsupported.
        // CAP_PROP_RECTIFICATION =18, //!< Rectification flag for stereo cameras (note: only supported by DC1394 v 2.x backend currently).
