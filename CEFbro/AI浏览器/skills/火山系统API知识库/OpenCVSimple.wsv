        // #ifndef CV_DOXYGEN
        // CV__CAP_PROP_LATEST
        // #endif
        // };
    }

    #
    #

    方法 当前帧时间戳 <公开 属性读 类型 = 整数 注释 = "视频当前点的毫秒值或视频捕捉的时间戳" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,0)        //CAP_PROP_POS_MSEC       =0, //!< Current position of the video file in milliseconds.
    }

    方法 总帧数 <公开 属性读 类型 = 整数 注释 = "下次将被捕获的0基索引的帧" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,7)  //       CAP_PROP_FRAME_COUNT    =7, //!< Number of frames in the video file.
    }

    方法 帧率 <公开 属性读 类型 = 小数 @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,5) // CAP_PROP_FPS            =5, //!< Frame rate.
    }

    方法 宽度 <公开 属性读 类型 = 整数 注释 = "视频流帧的宽度" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,3)   //CAP_PROP_FRAME_WIDTH    =3, //!< Width of the frames in the video stream.
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "视频流帧的高." @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,4) //CAP_PROP_FRAME_HEIGHT   =4, //!< Height of the frames in the video stream.
    }

    方法 亮度 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,10)  //CAP_PROP_BRIGHTNESS    =10, //!< Brightness of the image (only for those cameras that support).
    }

    方法 对比度 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,11)  // CAP_PROP_CONTRAST      =11, //!< Contrast of the image (only for cameras).
    }

    方法 饱和度 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,12);  //CAP_PROP_SATURATION    =12, //!< Saturation of the image (only for cameras).
    }

    方法 色调 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,13)  //CAP_PROP_HUE           =13, //!< Hue of the image (only for cameras).
    }

    方法 增益 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,14)  //CAP_PROP_GAIN          =14, //!< Gain of the image (only for those cameras that support).
    }

    方法 曝光 <公开 属性读 类型 = 整数 注释 = "只对摄像头" @嵌入式方法 = "">
    {
        @ cv_VideoCapture_Get(@sn<this>.m_pData,15)  //CAP_PROP_EXPOSURE      =15, //!< Exposure (only for those cameras that support).
    }

    #
}

类 视频保存类 <公开 折叠>
{

    # @begin
    # <> <include>
    # public:
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化 <折叠>
    {
        @ m_pData = cv_VideoWriter_Create();
    }

    方法 类_清理 <折叠>
    {
        @ cv_VideoWriter_Destory(m_pData);
    }

    方法 是否已经打开 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ cv_VideoWriter_IsOpen(@sn<this>.m_pData)
    }

    方法 打开 <公开 类型 = 逻辑型 注释 = "注意，首先要装解码器的，如何判断系统中已经安装解码器 https://jingyan.baidu.com/article/27fa7326e7108907f9271f18.html"
            注释 = "一般得到的文件为空，一般都是解码器出问题了，一般用微软自带的 DIVX 编码器" @禁止流程检查 = 真>
    参数 欲保存的文件路径 <类型 = 文本型 注释 = "例如  c:\\\\aa.mp4">
    参数 视频类型 <类型 = 文本型 注释 = "X264 DIVX 只能四个字符。。。等等" @默认值 = "DIVX">
    参数 帧率 <类型 = 小数 @默认值 = 15>
    参数 视频宽度 <类型 = 整数>
    参数 视频高度 <类型 = 整数>
    参数 是否彩色 <类型 = 逻辑型 注释 = "如果为真表示是彩色的，否则就是灰色的" @默认值 = 真>
    {
        变量 临时文件路径 <类型 = 字节集类>
        变量 文件路径指针 <类型 = 变整数>
        临时文件路径 = 文本到多字节 (欲保存的文件路径)
        文件路径指针 = 临时文件路径.取字节集指针 ()
        变量 临时视频类型 <类型 = 字节集类>
        变量 视频类型长度 <类型 = 整数>
        变量 视频类型指针 <类型 = 变整数>
        变量 类型字节1 <类型 = 字节>
        变量 类型字节2 <类型 = 字节>
        变量 类型字节3 <类型 = 字节>
        变量 类型字节4 <类型 = 字节>
        变量 ""
        @ int fourcc = -1;
        如果 (视频类型 != "" || 取文本长度 (视频类型) == 4)
        {

            临时视频类型 = 文本到多字节 (视频类型)
            视频类型长度 = 取文本长度 (视频类型)
            视频类型指针 = 临时视频类型.取字节集指针 ()

            如果 (视频类型长度 >= 1)
            {
                类型字节1 = 临时视频类型.取字节集数据 (0, 字节)
            }
            如果 (视频类型长度 >= 2)
            {
                类型字节2 = 临时视频类型.取字节集数据 (1, 字节)
            }
            如果 (视频类型长度 >= 3)
            {
                类型字节3 = 临时视频类型.取字节集数据 (2, 字节)
            }
            如果 (视频类型长度 >= 4)
            {
                类型字节4 = 临时视频类型.取字节集数据 (3, 字节)

            }
            @  fourcc = cv_VideoWriter_fourcc(@<类型字节1>,@<类型字节2>,@<类型字节3>,@<类型字节4>);

        }
        @ return cv_VideoWriter_Open (m_pData,(const char*)@<文件路径指针>,fourcc,@<帧率>,@<视频宽度>,@<视频高度>,@<是否彩色>);


    }

    方法 写入图片 <公开 注释 = "如果得到的视频文件出错，那么请 把图片转换成BGR模式，只支持三通道，不支持BGRA四通道" @嵌入式方法 = "">
    参数 图片 <类型 = 图片操作类>
    {
        @ cv_VideoWriter_write(@sn<this>.m_pData, @<图片>.m_pData)
    }

    方法 关闭 <公开 @嵌入式方法 = "">
    {
        @ cv_VideoWriter_Close(@sn<this>.m_pData)
    }

    #
}

类 图片操作类 <公开>
{

    # @begin
    # <> <include>
    # virtual void GetDumpString (CVolString& strDump, INT nMaxDumpSize)
    # {
    #     void* pText = FImage_ToString((void*)GetData());
    #     if(pText)
    #     {
    #          strDump = (const char*)pText;
    #          FImage_FreeString(pText);
    #      }else
    #     {
    #         strDump = _T("图片操作类 内容为空");
    #     }
    # }
    #
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     FImage_RefConstruct(m_pData,objCopyFrom.m_pData);
    # }
    # public:
    # void* GetData()
    # {
    #     return m_pData;
    # }
    # void* m_pData;
    # <> </include>
    # @end
    #

    方法 类_初始化 <公开>
    {
        @ m_pData = FImage_New();
    }

    方法 类_清理 <公开>
    {
        @ FImage_Delete (m_pData);
    }

    方法 取像素数据指针 <公开 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (@dt<变整数>)FImage_GetRawPixPoint((void*)@sn<this>.GetData())
    }

    方法 取像素数据 <公开 类型 = 字节集类>
    {
        返回 (指针到字节集 (取像素数据指针 (), 宽度 * 高度 * 通道数))

    }

    方法 取感性区 <公开 @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 感性区域 <类型 = 图片操作类 注释 = "用来保存感性区域">
    {
        @ FImage_GetRoi((void*)@sn<this>.GetData(),@<横坐标>,@<纵坐标>,@<宽度>,@<高度>,(void*)@<感性区域>.GetData())
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将图片格式化成  [ 255 255 255 ] 这样格式的文本">
    {
        变量 返回值 <类型 = 文本型>
        @ void* pText = FImage_ToString((void*)GetData());
        @ if(pText)
        @ {
        @     @<返回值> = (const char*)pText;
        @     FImage_FreeString(pText);
        @ }
        返回 (返回值)
    }

    方法 从文件载入 <公开 类型 = 逻辑型 编辑时信息 = "44FFB, 0, 0, 0" @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型 编辑时信息 = "44FFB, 0, 0, 0">
    参数 读入方式 <类型 = 整数
            注释 = "       IMREAD_UNCHANGED            = -1, //!< If set, return the loaded image as is (with alpha channel, otherwise it gets cropped). Ignore EXIF orientation."
            注释 = "       IMREAD_GRAYSCALE            = 0,  //!< If set, always convert image to the single channel grayscale image (codec internal conversion)."
            注释 = "       IMREAD_COLOR                = 1,  //!< If set, always convert image to the 3 channel BGR color image."
            注释 = "       IMREAD_ANYDEPTH             = 2,  //!< If set, return 16-bit/32-bit image when the input has the corresponding depth, otherwise convert it to 8-bit."
            注释 = "       IMREAD_ANYCOLOR             = 4,  //!< If set, the image is read in any possible color format."
            注释 = "       IMREAD_LOAD_GDAL            = 8,  //!< If set, use the gdal driver for loading the image."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_2  = 16, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_COLOR_2      = 17, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_4  = 32, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_COLOR_4      = 33, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_8  = 64, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/8."
            注释 = "       IMREAD_REDUCED_COLOR_8      = 65, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/8."
            注释 = "       IMREAD_IGNORE_ORIENTATION   = 128 //!< If set, do not rotate the image according to EXIF\'s orientation flag."
            编辑时信息 = "44FFB, 0, 0, 0" @默认值 = 1>
    {
        变量 bin <类型 = 字节集类>
        bin = 文本到多字节 (文件路径)
        @ return FImage_LoadFile((void*)GetData() ,(const char*)@<bin>.GetPtr(),@<读入方式>);
    }

    方法 到文件 <公开 类型 = 逻辑型 注释 = "保存到文件" @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    {
        变量 bin <类型 = 字节集类>
        bin = 文本到多字节 (文件路径)
        @ return FImage_SaveToFile((void*)GetData(),(const char*)@<bin>.GetPtr());

    }

    方法 到文件Ex <公开 类型 = 逻辑型 注释 = "保存到文件" @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型>
    参数 类型 <类型 = 整数
            注释 = "       IMWRITE_JPEG_QUALITY        = 1,  //!< For JPEG, it can be a quality from 0 to 100 (the higher is the better). Default value is 95."
            注释 = "       IMWRITE_JPEG_PROGRESSIVE    = 2,  //!< Enable JPEG features, 0 or 1, default is False."
            注释 = "       IMWRITE_JPEG_OPTIMIZE       = 3,  //!< Enable JPEG features, 0 or 1, default is False."
            注释 = "       IMWRITE_JPEG_RST_INTERVAL   = 4,  //!< JPEG restart interval, 0 - 65535, default is 0 - no restart."
            注释 = "       IMWRITE_JPEG_LUMA_QUALITY   = 5,  //!< Separate luma quality level, 0 - 100, default is 0 - don\'t use."
            注释 = "       IMWRITE_JPEG_CHROMA_QUALITY = 6,  //!< Separate chroma quality level, 0 - 100, default is 0 - don\'t use."
            注释 = "       IMWRITE_PNG_COMPRESSION     = 16, //!< For PNG, it can be the compression level from 0 to 9. A higher value means a smaller size and longer compression time. If specified, strategy is changed to IMWRITE_PNG_STRATEGY_DEFAULT (Z_DEFAULT_STRATEGY). Default value is 1 (best speed setting)."
            注释 = "       IMWRITE_PNG_STRATEGY        = 17, //!< One of cv::ImwritePNGFlags, default is IMWRITE_PNG_STRATEGY_RLE."
            注释 = "       IMWRITE_PNG_BILEVEL         = 18, //!< Binary level PNG, 0 or 1, default is 0."
            注释 = "       IMWRITE_PXM_BINARY          = 32, //!< For PPM, PGM, or PBM, it can be a binary format flag, 0 or 1. Default value is 1."
            注释 = "       IMWRITE_EXR_TYPE            = (3 << 4) + 0, /* 48 */ //!< override EXR storage type (FLOAT (FP32) is default)"
            注释 = "       IMWRITE_WEBP_QUALITY        = 64, //!< For WEBP, it can be a quality from 1 to 100 (the higher is the better). By default (without any parameter) and for quality above 100 the lossless compression is used."
            注释 = "       IMWRITE_PAM_TUPLETYPE       = 128,//!< For PAM, sets the TUPLETYPE field to the corresponding string value that is defined for the format"
            注释 = "       IMWRITE_TIFF_RESUNIT = 256,//!< For TIFF, use to specify which DPI resolution unit to set; see libtiff documentation for valid values"
            注释 = "       IMWRITE_TIFF_XDPI = 257,//!< For TIFF, use to specify the X direction DPI"
            注释 = "       IMWRITE_TIFF_YDPI = 258, //!< For TIFF, use to specify the Y direction DPI"
            注释 = "       IMWRITE_TIFF_COMPRESSION = 259, //!< For TIFF, use to specify the image compression scheme. See libtiff for integer constants corresponding to compression formats. Note, for images whose depth is CV_32F, only libtiff\'s SGILOG compression scheme is used. For other supported depths, the compression scheme can be specified by this flag; LZW compression is the default."
            注释 = "       IMWRITE_JPEG2000_COMPRESSION_X1000 = 272 //!< For JPEG2000, use to specify the target compression rate (multiplied by 1000). The value can be from 0 to 1000. Default is 1000."
            "">
    参数 参数2 <类型 = 整数>
    {
        变量 bin <类型 = 字节集类>
        bin = 文本到多字节 (文件路径)
        @ return cv_imwriteEx((void*)GetData(),(const char*)@<bin>.GetPtr(),@<类型>,@<参数2>);

    }

    方法 到字节集 <公开 类型 = 字节集类>
    参数 文件格式 <类型 = 文本型 注释 = ".png  .jpg">
    {
        变量 后缀 <类型 = 字节集类>
        后缀 = 文本到多字节 (文件格式)
        @ void * pBuffer = NULL;
        @ __int64 nBufferLen = 0;
        调试输出 ("00000")
        @ bool bOk = FImage_SaveToBuffer((void*)GetData(),(const char*)@<后缀>.GetPtr(),&pBuffer,&nBufferLen);
        @ if(bOk)
        @ {
        调试输出 ("11111")

        @     CVolMem mem(pBuffer,nBufferLen);
        调试输出 ("2222")
        @     FImage_FreeBuffer(pBuffer);
        @     return mem;
        @ }
        变量 空字节集 <类型 = 字节集类>
        返回 (空字节集)
    }

    方法 到字节集扩展 <公开 类型 = 字节集类>
    参数 文件格式 <类型 = 文本型 注释 = ".png  .jpg">
    参数 类型 <类型 = 整数
            注释 = "       IMWRITE_JPEG_QUALITY        = 1,  //!< For JPEG, it can be a quality from 0 to 100 (the higher is the better). Default value is 95."
            注释 = "       IMWRITE_JPEG_PROGRESSIVE    = 2,  //!< Enable JPEG features, 0 or 1, default is False."
            注释 = "       IMWRITE_JPEG_OPTIMIZE       = 3,  //!< Enable JPEG features, 0 or 1, default is False."
            注释 = "       IMWRITE_JPEG_RST_INTERVAL   = 4,  //!< JPEG restart interval, 0 - 65535, default is 0 - no restart."
            注释 = "       IMWRITE_JPEG_LUMA_QUALITY   = 5,  //!< Separate luma quality level, 0 - 100, default is 0 - don\'t use."
            注释 = "       IMWRITE_JPEG_CHROMA_QUALITY = 6,  //!< Separate chroma quality level, 0 - 100, default is 0 - don\'t use."
            注释 = "       IMWRITE_PNG_COMPRESSION     = 16, //!< For PNG, it can be the compression level from 0 to 9. A higher value means a smaller size and longer compression time. If specified, strategy is changed to IMWRITE_PNG_STRATEGY_DEFAULT (Z_DEFAULT_STRATEGY). Default value is 1 (best speed setting)."
            注释 = "       IMWRITE_PNG_STRATEGY        = 17, //!< One of cv::ImwritePNGFlags, default is IMWRITE_PNG_STRATEGY_RLE."
            注释 = "       IMWRITE_PNG_BILEVEL         = 18, //!< Binary level PNG, 0 or 1, default is 0."
            注释 = "       IMWRITE_PXM_BINARY          = 32, //!< For PPM, PGM, or PBM, it can be a binary format flag, 0 or 1. Default value is 1."
            注释 = "       IMWRITE_EXR_TYPE            = (3 << 4) + 0, /* 48 */ //!< override EXR storage type (FLOAT (FP32) is default)"
            注释 = "       IMWRITE_WEBP_QUALITY        = 64, //!< For WEBP, it can be a quality from 1 to 100 (the higher is the better). By default (without any parameter) and for quality above 100 the lossless compression is used."
            注释 = "       IMWRITE_PAM_TUPLETYPE       = 128,//!< For PAM, sets the TUPLETYPE field to the corresponding string value that is defined for the format"
            注释 = "       IMWRITE_TIFF_RESUNIT = 256,//!< For TIFF, use to specify which DPI resolution unit to set; see libtiff documentation for valid values"
            注释 = "       IMWRITE_TIFF_XDPI = 257,//!< For TIFF, use to specify the X direction DPI"
            注释 = "       IMWRITE_TIFF_YDPI = 258, //!< For TIFF, use to specify the Y direction DPI"
            注释 = "       IMWRITE_TIFF_COMPRESSION = 259, //!< For TIFF, use to specify the image compression scheme. See libtiff for integer constants corresponding to compression formats. Note, for images whose depth is CV_32F, only libtiff\'s SGILOG compression scheme is used. For other supported depths, the compression scheme can be specified by this flag; LZW compression is the default."
            注释 = "       IMWRITE_JPEG2000_COMPRESSION_X1000 = 272 //!< For JPEG2000, use to specify the target compression rate (multiplied by 1000). The value can be from 0 to 1000. Default is 1000.">
    参数 参数2 <类型 = 整数 注释 = "质量。。。">
    {
        变量 后缀 <类型 = 字节集类>
        后缀 = 文本到多字节 (文件格式)
        @ void * pBuffer = NULL;
        @ __int64 nBufferLen = 0;
        @ bool bOk = FImage_SaveToBufferEx((void*)GetData(),(const char*)@<后缀>.GetPtr(),&pBuffer,&nBufferLen,@<类型>,@<参数2>);
        @ if(bOk)
        @ {
        @     CVolMem mem(pBuffer,nBufferLen);
        @     FImage_FreeBuffer(pBuffer);
        @     return mem;
        @ }
        变量 空字节集 <类型 = 字节集类>
        返回 (空字节集)


    }

    方法 到JPG <公开 类型 = 字节集类>
    参数 质量 <类型 = 整数 注释 = "1 - 100" @默认值 = 95>
    {
        返回 (到字节集扩展 (".jpg", 1, 质量))
    }

    方法 到PNG <公开 类型 = 字节集类>
    参数 质量 <类型 = 整数 注释 = "0-9 数字越大，图片越小" @默认值 = 9>
    {
        返回 (到字节集扩展 (".png", 16, 质量))
    }

    方法 到WEBP <公开 类型 = 字节集类>
    参数 质量 <类型 = 整数 注释 = "0-100 数字越大，图片质量越好" @默认值 = 95>
    {
        返回 (到字节集扩展 (".webp", 64, 质量))
    }

    方法 从指针载入 <公开 类型 = 逻辑型 注释 = "从内存图片的指针载入" @嵌入式方法 = "">
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    参数 读入模式 <类型 = 整数
            注释 = "       IMREAD_UNCHANGED            = -1, //!< If set, return the loaded image as is (with alpha channel, otherwise it gets cropped). Ignore EXIF orientation."
            注释 = "       IMREAD_GRAYSCALE            = 0,  //!< If set, always convert image to the single channel grayscale image (codec internal conversion)."
            注释 = "       IMREAD_COLOR                = 1,  //!< If set, always convert image to the 3 channel BGR color image."
            注释 = "       IMREAD_ANYDEPTH             = 2,  //!< If set, return 16-bit/32-bit image when the input has the corresponding depth, otherwise convert it to 8-bit."
            注释 = "       IMREAD_ANYCOLOR             = 4,  //!< If set, the image is read in any possible color format."
            注释 = "       IMREAD_LOAD_GDAL            = 8,  //!< If set, use the gdal driver for loading the image."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_2  = 16, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_COLOR_2      = 17, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_4  = 32, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_COLOR_4      = 33, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_8  = 64, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/8."
            注释 = "       IMREAD_REDUCED_COLOR_8      = 65, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/8."
            注释 = "       IMREAD_IGNORE_ORIENTATION   = 128 //!< If set, do not rotate the image according to EXIF\'s orientation flag."
            @默认值 = 1>
    {
        @ FImage_LoadFromBuffer((void*)@sn<this>.GetData(),(void *)@<数据指针>, @<数据大小>,@<读入模式>)
    }

    方法 从字节集载入 <公开 类型 = 逻辑型>
    参数 字节集 <类型 = 字节集类>
    参数 图片读入模式常量 <类型 = 整数
            注释 = "       IMREAD_UNCHANGED            = -1, //!< If set, return the loaded image as is (with alpha channel, otherwise it gets cropped). Ignore EXIF orientation."
            注释 = "       IMREAD_GRAYSCALE            = 0,  //!< If set, always convert image to the single channel grayscale image (codec internal conversion)."
            注释 = "       IMREAD_COLOR                = 1,  //!< If set, always convert image to the 3 channel BGR color image."
            注释 = "       IMREAD_ANYDEPTH             = 2,  //!< If set, return 16-bit/32-bit image when the input has the corresponding depth, otherwise convert it to 8-bit."
            注释 = "       IMREAD_ANYCOLOR             = 4,  //!< If set, the image is read in any possible color format."
            注释 = "       IMREAD_LOAD_GDAL            = 8,  //!< If set, use the gdal driver for loading the image."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_2  = 16, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_COLOR_2      = 17, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/2."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_4  = 32, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_COLOR_4      = 33, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/4."
            注释 = "       IMREAD_REDUCED_GRAYSCALE_8  = 64, //!< If set, always convert image to the single channel grayscale image and the image size reduced 1/8."
            注释 = "       IMREAD_REDUCED_COLOR_8      = 65, //!< If set, always convert image to the 3 channel BGR color image and the image size reduced 1/8."
            注释 = "       IMREAD_IGNORE_ORIENTATION   = 128 //!< If set, do not rotate the image according to EXIF\'s orientation flag."
            @默认值 = 1>
    {
        返回 (从指针载入 (字节集.取字节集指针 (), 字节集.取字节集长度 ()))

    }

    方法 从像素数据载入 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 像素数据 <类型 = 字节集类>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 通道数 <类型 = 整数 注释 = "最后一个参数 可选值 CV_8UC1 0  CV_8UC2 8  CV_8UC3 16 CV_8UC4 24" @默认值 = 3>
    {
        变量 数据指针 <类型 = 变整数>
        数据指针 = 像素数据.取字节集指针 ()
        // 最后一个参数 可选值 CV_8UC1 0  CV_8UC2 8  CV_8UC3 16 CV_8UC4 24
        @ return FImage_LoadFromRawPix((void*)GetData(), (void*)@<数据指针>,@<宽度>, @<高度>, @<通道数>, (@<通道数> - 1)*8 );

    }

    方法 从像素字节数组载入 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 行数 <类型 = 整数>
    参数 列数 <类型 = 整数>
    参数 图片类型 <类型 = 整数 注释 = "默认  CV_8UC3 八位三通道  一个通道占用一个字节(八位)" 注释 = "CV_8UC1 0" 注释 = "CV_8UC2 8" 注释 = "CV_8UC3 16"
            注释 = "CV_8UC4 24">
    参数 行字节数 <类型 = 整数 注释 = "如果不足，那么就补齐,一般可以不用填写，自动计算" @默认值 = 0>
    参数 像素数据 <@匹配类型 = 通用数值型数组>
    {
        // bool FUCTIONTYPE FImage_LoadFromPix2DArray(void* pMat, int rows, int cols, int type, void* data, size_t step = 0);
        @ FImage_LoadFromPix2DArray(@sn<this>.GetData(),@<行数>,@<列数>,@<图片类型>,(void*)@<像素数据>,@<行字节数>)

    }

    方法 从像素数据指针载入 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 像素数据指针 <类型 = 变整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 通道数 <类型 = 整数 @默认值 = 3>
    {
        @ return FImage_LoadFromRawPix((void*)GetData(), (void*)@<像素数据指针>,@<宽度>, @<高度>, @<通道数>, (@<通道数> - 1)*8 );
    }

    方法 创建 <公开 注释 = "调用此函数之后，才会有像素数据，否则是空图片的" @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 图片类型 <类型 = 整数 注释 = "默认  CV_8UC3 八位三通道  一个通道占用一个字节(八位)" 注释 = "CV_8UC1 0" 注释 = "CV_8UC2 8" 注释 = "CV_8UC3 16"
            注释 = "CV_8UC4 24" @默认值 = 16>
    {
        @ FImage_Create((void*)@sn<this>.GetData(),@<宽度>,@<高度>,@<图片类型>);

    }

    方法 填充零 <公开 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 图片类型 <类型 = 整数 注释 = "#define CV_8U   0" 注释 = "#define CV_8S   1" 注释 = "#define CV_16U  2" 注释 = "#define CV_16S  3"
            注释 = "#define CV_32S  4" 注释 = "#define CV_32F  5" 注释 = "#define CV_64F  6" 注释 = "#define CV_16F  7">
    {
        @ FImage_zeros(@sn<this>.GetData(),@<宽度>,@<高度>,@<图片类型>)
    }

    方法 填充一 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 图片类型 <类型 = 整数 注释 = "#define CV_8U   0" 注释 = "#define CV_8S   1" 注释 = "#define CV_16U  2" 注释 = "#define CV_16S  3"
            注释 = "#define CV_32S  4" 注释 = "#define CV_32F  5" 注释 = "#define CV_64F  6" 注释 = "#define CV_16F  7">
    {
        @ FImage_ones(@sn<this>.GetData(),@<宽度>,@<高度>,@<图片类型>)
    }

    方法 宽度 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ FImage_GetCols((void*)@sn<this>.GetData())
    }

    方法 高度 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ FImage_GetRows((void*)@sn<this>.GetData())

    }

    方法 是否为空 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @ FImage_IsEmpty((void*)@sn<this>.GetData())
    }

    方法 通道数 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ FImage_GetChannels((void*)@sn<this>.GetData())
    }

    方法 行字节数 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ FImage_GetStep((void*)@sn<this>.GetData())
    }

    方法 创建窗口 <公开 @嵌入式方法 = "">
    参数 窗口名称 <类型 = 文本型>
    参数 窗口类型 <类型 = 整数 注释 = "0 表示常规" 注释 = "1 表示自动大小 此时不能设置窗口大小" @默认值 = 0>
    {
        @ FImage_namedWindow(GetMbsText(@<窗口名称>, CVolMem(), NULL),@<窗口类型>)
    }

    方法 置窗口大小 <公开 @嵌入式方法 = "">
    参数 窗口名称 <类型 = 文本型>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ FImage_resizeWindow(GetMbsText(@<窗口名称>, CVolMem(), NULL),@<宽度>,@<高度>)
    }

    方法 显示 <公开 @嵌入式方法 = "">
    参数 窗口名称 <类型 = 文本型 @默认值 = "图片">
    {
        @ FImage_Show((void*)@sn<this>.GetData(),GetMbsText(@<窗口名称>, CVolMem(), NULL))
    }

    方法 等待按键 <公开 类型 = 整数 返回值注释 = "返回 键代码  也就是按键代码值" @嵌入式方法 = "">
    参数 等待时间 <类型 = 整数 @默认值 = 1>
    {
        @ FImage_WaitKey(@<等待时间>)
    }

    方法 赋值 <公开 注释 = "将图片2赋值给本图片类 实现的功能是 Mat = Mat" @嵌入式方法 = "">
    参数 图片2 <类型 = 图片操作类>
    {
        @ FImage_assignment((void*)@sn<this>.GetData(),@<图片2>.GetData())
    }

    方法 克隆 <公开 @嵌入式方法 = "">
    参数 新图片 <类型 = 图片操作类>
    {
        @ FImage_Clone((void*)@sn<this>.GetData(),@<新图片>.GetData())
    }

    方法 图片类型 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ FImage_GetType((void*)@sn<this>.GetData())
    }

    方法 算数运算 <公开 注释 = "两个图片算数运算 加减乘除" 注释 = "例如 图片1 [1,0,0]" 注释 = "     参与运算的图片 [2,0,0]" 注释 = "图片1 + 参与运算的图片 等于 [3,0,0]"
            @嵌入式方法 = "">
    参数 参与运算的图片 <类型 = 图片操作类>
    参数 运算方式 <类型 = 整数 注释 = "//nOperate 运算类型 可选值 1 2 3 4" 注释 = "//1 == +" 注释 = "//2 == -" 注释 = "//3 == *" 注释 = "//4 == /">
    参数 运算后的图片 <类型 = 图片操作类>
    {
        @ FImage_ArithmeticOperation((void*)@sn<this>.GetData(),@<参与运算的图片>.GetData(),@<运算方式>,@<运算后的图片>.GetData())
    }

    方法 像素运算 <公开 注释 = "像素运算" @嵌入式方法 = "">
    参数 参与运算的数值 <类型 = 小数>
    参数 运算方式 <类型 = 整数 注释 = "//nOperate 运算类型 可选值 1 2 3 4" 注释 = "//1 == +" 注释 = "//2 == -" 注释 = "//3 == *" 注释 = "//4 == /">
    参数 运算后的图片 <类型 = 图片操作类>
    {
        @ FImage_PixelOperation((void*)@sn<this>.GetData(),@<参与运算的数值>,@<运算方式>,@<运算后的图片>.GetData())
    }

    方法 位运算 <公开 @嵌入式方法 = "">
    参数 参与运算的图片 <类型 = 图片操作类 注释 = "当运算方式为 位取反的时候，这个参数是不需要的，可以填空对象">
    参数 运算方式 <类型 = 整数 注释 = "//位运算" 注释 = "// 1 位与" 注释 = "// 2 位或" 注释 = "// 3 异或" 注释 = "// 4 位取反">
    参数 运算后的图片 <类型 = 图片操作类>
    {
        @ FImage_BitOperation((void*)@sn<this>.GetData(),@<参与运算的图片>.GetData(),@<运算方式>,@<运算后的图片>.GetData())
    }

    方法 颜色模型转换 <公开 注释 = "针对图像不同颜色模型的相互转换" 注释 = "比如可以从 rgb 或者 bgr 转换为灰度图 等等" 折叠2 @嵌入式方法 = "">
    参数 处理后的图片 <类型 = 图片操作类>
    参数 转换方式 <类型 = 整数 注释 = "    COLOR_BGR2BGRA     = 0, //!< add alpha channel to RGB or BGR image"
            注释 = "    COLOR_RGB2RGBA     = COLOR_BGR2BGRA," 注释 = ""
            注释 = "    COLOR_BGRA2BGR     = 1, //!< remove alpha channel from RGB or BGR image"
            注释 = "    COLOR_RGBA2RGB     = COLOR_BGRA2BGR," 注释 = ""
            注释 = "    COLOR_BGR2RGBA     = 2, //!< convert between RGB and BGR color spaces (with or without alpha channel)"
