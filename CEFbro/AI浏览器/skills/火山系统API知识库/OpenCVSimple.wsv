        // CAP_PROP_SHARPNESS     =20,
        // CAP_PROP_AUTO_EXPOSURE =21, //!< DC1394: exposure control done by camera, user can adjust reference level using this feature.
        // CAP_PROP_GAMMA         =22,
        // CAP_PROP_TEMPERATURE   =23,
