            注释 = "    COLOR_YUV420p2BGR   = COLOR_YUV2BGR_YV12," 注释 = "" 注释 = "    COLOR_YUV2RGBA_YV12 = 102,"
            注释 = "    COLOR_YUV2BGRA_YV12 = 103," 注释 = "    COLOR_YUV2RGBA_IYUV = 104," 注释 = "    COLOR_YUV2BGRA_IYUV = 105,"
            注释 = "    COLOR_YUV2RGBA_I420 = COLOR_YUV2RGBA_IYUV," 注释 = "    COLOR_YUV2BGRA_I420 = COLOR_YUV2BGRA_IYUV,"
            注释 = "    COLOR_YUV420p2RGBA  = COLOR_YUV2RGBA_YV12," 注释 = "    COLOR_YUV420p2BGRA  = COLOR_YUV2BGRA_YV12," 注释 = ""
            注释 = "    COLOR_YUV2GRAY_420  = 106," 注释 = "    COLOR_YUV2GRAY_NV21 = COLOR_YUV2GRAY_420,"
            注释 = "    COLOR_YUV2GRAY_NV12 = COLOR_YUV2GRAY_420," 注释 = "    COLOR_YUV2GRAY_YV12 = COLOR_YUV2GRAY_420,"
            注释 = "    COLOR_YUV2GRAY_IYUV = COLOR_YUV2GRAY_420," 注释 = "    COLOR_YUV2GRAY_I420 = COLOR_YUV2GRAY_420,"
            注释 = "    COLOR_YUV420sp2GRAY = COLOR_YUV2GRAY_420," 注释 = "    COLOR_YUV420p2GRAY  = COLOR_YUV2GRAY_420," 注释 = ""
            注释 = "    //! YUV 4:2:2 family to RGB" 注释 = "    COLOR_YUV2RGB_UYVY = 107," 注释 = "    COLOR_YUV2BGR_UYVY = 108,"
            注释 = "    //COLOR_YUV2RGB_VYUY = 109," 注释 = "    //COLOR_YUV2BGR_VYUY = 110,"
            注释 = "    COLOR_YUV2RGB_Y422 = COLOR_YUV2RGB_UYVY," 注释 = "    COLOR_YUV2BGR_Y422 = COLOR_YUV2BGR_UYVY,"
            注释 = "    COLOR_YUV2RGB_UYNV = COLOR_YUV2RGB_UYVY," 注释 = "    COLOR_YUV2BGR_UYNV = COLOR_YUV2BGR_UYVY," 注释 = ""
            注释 = "    COLOR_YUV2RGBA_UYVY = 111," 注释 = "    COLOR_YUV2BGRA_UYVY = 112," 注释 = "    //COLOR_YUV2RGBA_VYUY = 113,"
            注释 = "    //COLOR_YUV2BGRA_VYUY = 114," 注释 = "    COLOR_YUV2RGBA_Y422 = COLOR_YUV2RGBA_UYVY,"
            注释 = "    COLOR_YUV2BGRA_Y422 = COLOR_YUV2BGRA_UYVY," 注释 = "    COLOR_YUV2RGBA_UYNV = COLOR_YUV2RGBA_UYVY,"
            注释 = "    COLOR_YUV2BGRA_UYNV = COLOR_YUV2BGRA_UYVY," 注释 = "" 注释 = "    COLOR_YUV2RGB_YUY2 = 115,"
            注释 = "    COLOR_YUV2BGR_YUY2 = 116," 注释 = "    COLOR_YUV2RGB_YVYU = 117," 注释 = "    COLOR_YUV2BGR_YVYU = 118,"
            注释 = "    COLOR_YUV2RGB_YUYV = COLOR_YUV2RGB_YUY2," 注释 = "    COLOR_YUV2BGR_YUYV = COLOR_YUV2BGR_YUY2,"
            注释 = "    COLOR_YUV2RGB_YUNV = COLOR_YUV2RGB_YUY2," 注释 = "    COLOR_YUV2BGR_YUNV = COLOR_YUV2BGR_YUY2," 注释 = ""
            注释 = "    COLOR_YUV2RGBA_YUY2 = 119," 注释 = "    COLOR_YUV2BGRA_YUY2 = 120," 注释 = "    COLOR_YUV2RGBA_YVYU = 121,"
            注释 = "    COLOR_YUV2BGRA_YVYU = 122," 注释 = "    COLOR_YUV2RGBA_YUYV = COLOR_YUV2RGBA_YUY2,"
            注释 = "    COLOR_YUV2BGRA_YUYV = COLOR_YUV2BGRA_YUY2," 注释 = "    COLOR_YUV2RGBA_YUNV = COLOR_YUV2RGBA_YUY2,"
            注释 = "    COLOR_YUV2BGRA_YUNV = COLOR_YUV2BGRA_YUY2," 注释 = "" 注释 = "    COLOR_YUV2GRAY_UYVY = 123,"
            注释 = "    COLOR_YUV2GRAY_YUY2 = 124," 注释 = "    //CV_YUV2GRAY_VYUY    = CV_YUV2GRAY_UYVY,"
            注释 = "    COLOR_YUV2GRAY_Y422 = COLOR_YUV2GRAY_UYVY," 注释 = "    COLOR_YUV2GRAY_UYNV = COLOR_YUV2GRAY_UYVY,"
            注释 = "    COLOR_YUV2GRAY_YVYU = COLOR_YUV2GRAY_YUY2," 注释 = "    COLOR_YUV2GRAY_YUYV = COLOR_YUV2GRAY_YUY2,"
            注释 = "    COLOR_YUV2GRAY_YUNV = COLOR_YUV2GRAY_YUY2," 注释 = "" 注释 = "    //! alpha premultiplication"
            注释 = "    COLOR_RGBA2mRGBA    = 125," 注释 = "    COLOR_mRGBA2RGBA    = 126," 注释 = ""
            注释 = "    //! RGB to YUV 4:2:0 family" 注释 = "    COLOR_RGB2YUV_I420  = 127," 注释 = "    COLOR_BGR2YUV_I420  = 128,"
            注释 = "    COLOR_RGB2YUV_IYUV  = COLOR_RGB2YUV_I420," 注释 = "    COLOR_BGR2YUV_IYUV  = COLOR_BGR2YUV_I420," 注释 = ""
            注释 = "    COLOR_RGBA2YUV_I420 = 129," 注释 = "    COLOR_BGRA2YUV_I420 = 130,"
            注释 = "    COLOR_RGBA2YUV_IYUV = COLOR_RGBA2YUV_I420," 注释 = "    COLOR_BGRA2YUV_IYUV = COLOR_BGRA2YUV_I420,"
            注释 = "    COLOR_RGB2YUV_YV12  = 131," 注释 = "    COLOR_BGR2YUV_YV12  = 132," 注释 = "    COLOR_RGBA2YUV_YV12 = 133,"
            注释 = "    COLOR_BGRA2YUV_YV12 = 134," 注释 = "" 注释 = "    //! Demosaicing" 注释 = "    COLOR_BayerBG2BGR = 46,"
            注释 = "    COLOR_BayerGB2BGR = 47," 注释 = "    COLOR_BayerRG2BGR = 48," 注释 = "    COLOR_BayerGR2BGR = 49," 注释 = ""
            注释 = "    COLOR_BayerBG2RGB = COLOR_BayerRG2BGR," 注释 = "    COLOR_BayerGB2RGB = COLOR_BayerGR2BGR,"
            注释 = "    COLOR_BayerRG2RGB = COLOR_BayerBG2BGR," 注释 = "    COLOR_BayerGR2RGB = COLOR_BayerGB2BGR," 注释 = ""
            注释 = "    COLOR_BayerBG2GRAY = 86," 注释 = "    COLOR_BayerGB2GRAY = 87," 注释 = "    COLOR_BayerRG2GRAY = 88,"
            注释 = "    COLOR_BayerGR2GRAY = 89," 注释 = "" 注释 = "    //! Demosaicing using Variable Number of Gradients"
            注释 = "    COLOR_BayerBG2BGR_VNG = 62," 注释 = "    COLOR_BayerGB2BGR_VNG = 63," 注释 = "    COLOR_BayerRG2BGR_VNG = 64,"
            注释 = "    COLOR_BayerGR2BGR_VNG = 65," 注释 = "" 注释 = "    COLOR_BayerBG2RGB_VNG = COLOR_BayerRG2BGR_VNG,"
            注释 = "    COLOR_BayerGB2RGB_VNG = COLOR_BayerGR2BGR_VNG," 注释 = "    COLOR_BayerRG2RGB_VNG = COLOR_BayerBG2BGR_VNG,"
            注释 = "    COLOR_BayerGR2RGB_VNG = COLOR_BayerGB2BGR_VNG," 注释 = "" 注释 = "    //! Edge-Aware Demosaicing"
            注释 = "    COLOR_BayerBG2BGR_EA  = 135," 注释 = "    COLOR_BayerGB2BGR_EA  = 136," 注释 = "    COLOR_BayerRG2BGR_EA  = 137,"
            注释 = "    COLOR_BayerGR2BGR_EA  = 138," 注释 = "" 注释 = "    COLOR_BayerBG2RGB_EA  = COLOR_BayerRG2BGR_EA,"
            注释 = "    COLOR_BayerGB2RGB_EA  = COLOR_BayerGR2BGR_EA," 注释 = "    COLOR_BayerRG2RGB_EA  = COLOR_BayerBG2BGR_EA,"
            注释 = "    COLOR_BayerGR2RGB_EA  = COLOR_BayerGB2BGR_EA," 注释 = "" 注释 = "    //! Demosaicing with alpha channel"
            注释 = "    COLOR_BayerBG2BGRA = 139," 注释 = "    COLOR_BayerGB2BGRA = 140," 注释 = "    COLOR_BayerRG2BGRA = 141,"
            注释 = "    COLOR_BayerGR2BGRA = 142," 注释 = "" 注释 = "    COLOR_BayerBG2RGBA = COLOR_BayerRG2BGRA,"
            注释 = "    COLOR_BayerGB2RGBA = COLOR_BayerGR2BGRA," 注释 = "    COLOR_BayerRG2RGBA = COLOR_BayerBG2BGRA,"
            注释 = "    COLOR_BayerGR2RGBA = COLOR_BayerGB2BGRA," 注释 = "" 注释 = "    COLOR_COLORCVT_MAX  = 143" "">
    参数 通道数 <类型 = 整数 注释 = "转换后的图片 通道数，必须填，如果原来的通道是 ARGB，您想要转换成rgb 那么这里就填3" @默认值 = 0>
    {
        @ FImage_cvtColor((void*)@sn<this>.GetData(),@<处理后的图片>.GetData(),@<转换方式>,@<通道数>)
    }

    方法 取颜色分量 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 颜色分量索引 <类型 = 整数 注释 = "可选值 0 1 2 3" 注释 = "当通道数为1 时，这个只能填0" 注释 = "当通道数为2 时  这个可以填 0 或者 1"
            注释 = "当通道数为3 时  这个可以填 0 或者 1 或者 2" 注释 = "当通道数为4 时  这个可以填 0 或者 1 或者 2 或者 4" 注释 = "注意，opencv默认颜色模型为 b g r a"
            注释 = "当通道数 大于等于3 时  索引0 取出来的是 颜色分量 b(blue  蓝色)" 注释 = "                       索引1 取出来的是 颜色分量 g(green 绿色)"
            注释 = "                       索引2 取出来的是 颜色分量 r(red   红色)" 注释 = "这个只有当通道数为4    索引3 取出来的是 颜色分量 a(alpha 透明度)" 注释 = ""
            注释 = "如果您自己转换过颜色模型，那么请根据实际情况来取颜色分量" @默认值 = 0>
    {
        @ FImage_GetColor((void*)@sn<this>.GetData(),@<横坐标>,@<纵坐标>,@<颜色分量索引>)

    }

    方法 取索引颜色分量 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    参数 颜色分量索引 <类型 = 整数 注释 = "可选值 0 1 2 3" 注释 = "当通道数为1 时，这个只能填0" 注释 = "当通道数为2 时  这个可以填 0 或者 1"
            注释 = "当通道数为3 时  这个可以填 0 或者 1 或者 2" 注释 = "当通道数为4 时  这个可以填 0 或者 1 或者 2 或者 4" 注释 = "注意，opencv默认颜色模型为 b g r a"
            注释 = "当通道数 大于等于3 时  索引0 取出来的是 颜色分量 b(blue  蓝色)" 注释 = "                       索引1 取出来的是 颜色分量 g(green 绿色)"
            注释 = "                       索引2 取出来的是 颜色分量 r(red   红色)" 注释 = "这个只有当通道数为4    索引3 取出来的是 颜色分量 a(alpha 透明度)" 注释 = ""
            注释 = "如果您自己转换过颜色模型，那么请根据实际情况来取颜色分量" @默认值 = 0>
    {
        @ FImage_GetIndexColor((void*)@sn<this>.GetData(),@<索引>,@<颜色分量索引>)

    }

    方法 置颜色分量 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 颜色分量索引 <类型 = 整数 注释 = "可选值 0 1 2 3" 注释 = "当通道数为1 时，这个只能填0" 注释 = "当通道数为2 时  这个可以填 0 或者 1"
            注释 = "当通道数为3 时  这个可以填 0 或者 1 或者 2" 注释 = "当通道数为4 时  这个可以填 0 或者 1 或者 2 或者 3" 注释 = "注意，opencv默认颜色模型为 b g r a"
            注释 = "当通道数 大于等于3 时  索引0 取出来的是 颜色分量 b(blue  蓝色)" 注释 = "                       索引1 取出来的是 颜色分量 g(green 绿色)"
            注释 = "                       索引2 取出来的是 颜色分量 r(red   红色)" 注释 = "这个只有当通道数为4    索引3 取出来的是 颜色分量 a(alpha 透明度)" 注释 = ""
            注释 = "如果您自己转换过颜色模型，那么请根据实际情况来取颜色分量" @默认值 = 0>
    参数 颜色分量值 <类型 = 整数>
    {
        @ FImage_SetColor((void*)@sn<this>.GetData(),@<横坐标>,@<纵坐标>,@<颜色分量索引>,@<颜色分量值>)
    }

    方法 翻转 <公开 @嵌入式方法 = "">
    参数 翻转后的图片 <类型 = 图片操作类>
    参数 翻转方式 <类型 = 整数 注释 = "大于 0: 沿y-轴翻转," 注释 = "等于 0: 沿x-轴翻转," 注释 = "小于 0: x、y轴同时翻转" @默认值 = 0>
    {
        @ FImage_flip((void*)@sn<this>.GetData(),(void*)@<翻转后的图片>.GetData(),@<翻转方式>)
    }

    方法 填充 <公开 折叠 @嵌入式方法 = "">
    参数 颜色分量1 <类型 = 整数 @默认值 = 0>
    参数 颜色分量2 <类型 = 整数 @默认值 = 0>
    参数 颜色分量3 <类型 = 整数 @默认值 = 0>
    参数 颜色分量4 <类型 = 整数 @默认值 = 0>
    {
        @ FImage_Fill((void*)@sn<this>.GetData(),@<颜色分量1>,@<颜色分量2>,@<颜色分量3>,@<颜色分量4>)
    }

    方法 画矩形 <公开 折叠 @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 线条粗细 <类型 = 整数 @默认值 = 2>
    参数 红色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 绿色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 蓝色 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    参数 透明度 <类型 = 整数 @默认值 = 0>
    {
        @ FImage_rectangle((void*)@sn<this>.GetData(), @<横坐标>, @<纵坐标>, @<宽度>, @<高度>,@<红色>, @<绿色>, @<蓝色>,@<透明度>,@<线条粗细>)
    }

    方法 画文本 <公开 注释 = "不支持中文" 折叠>
    参数 要绘制的文本 <类型 = 文本型>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 字体类型 <类型 = 整数 注释 = "    FONT_HERSHEY_SIMPLEX        = 0, //!< normal size sans-serif font"
            注释 = "    FONT_HERSHEY_PLAIN          = 1, //!< small size sans-serif font"
            注释 = "    FONT_HERSHEY_DUPLEX         = 2, //!< normal size sans-serif font (more complex than FONT_HERSHEY_SIMPLEX)"
            注释 = "    FONT_HERSHEY_COMPLEX        = 3, //!< normal size serif font"
            注释 = "    FONT_HERSHEY_TRIPLEX        = 4, //!< normal size serif font (more complex than FONT_HERSHEY_COMPLEX)"
            注释 = "    FONT_HERSHEY_COMPLEX_SMALL  = 5, //!< smaller version of FONT_HERSHEY_COMPLEX"
            注释 = "    FONT_HERSHEY_SCRIPT_SIMPLEX = 6, //!< hand-writing style font"
            注释 = "    FONT_HERSHEY_SCRIPT_COMPLEX = 7, //!< more complex variant of FONT_HERSHEY_SCRIPT_SIMPLEX"
            注释 = "    FONT_ITALIC                 = 16 //!< flag for italic font" @默认值 = 0>
    参数 字体缩放 <类型 = 小数 @默认值 = 1>
    参数 粗细 <类型 = 整数 @默认值 = 1>
    参数 线条类型 <类型 = 整数 注释 = "    FILLED  = -1," 注释 = "    LINE_4  = 4, //!< 4-connected line"
            注释 = "    LINE_8  = 8, //!< 8-connected line" 注释 = "    LINE_AA = 16 //!< antialiased line" @默认值 = 4>
    参数 是否从右下角开始 <类型 = 逻辑型 @默认值 = 假>
    参数 红色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 绿色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 蓝色 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    参数 透明度 <类型 = 整数 @默认值 = 0>
    {
        变量 txt <类型 = 字节集类>
        txt = 文本到UTF8 (要绘制的文本)
        @ FImage_putText((void*)GetData(),(const char*)@<txt>.GetPtr(), @<横坐标>, @<纵坐标>, @<红色>, @<绿色>, @<蓝色>,@<透明度>,@<字体类型>,@<字体缩放>,@<粗细>,@<线条类型>,@<是否从右下角开始>);
    }

    方法 画文本2 <公开 类型 = 整数 注释 = "支持中文" 返回值注释 = "返回文本宽度" @禁止流程检查 = 真>
    参数 要绘制的文本 <类型 = 文本型>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    参数 字体文件 <类型 = 文本型 @默认值 = "C:\\Windows\\Fonts\\simhei.ttf">
    参数 字体宽度 <类型 = 整数 @默认值 = 20>
    参数 字体高度 <类型 = 整数 注释 = "0 自动计算" @默认值 = 0>
    参数 字体透明度 <类型 = 小数 @默认值 = 1.0>
    参数 红色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 绿色 <类型 = 整数 注释 = "0-255" @默认值 = 0>
    参数 蓝色 <类型 = 整数 注释 = "0-255" @默认值 = 255>
    参数 透明度 <类型 = 整数 @默认值 = 0>
    {
        变量 font <类型 = 字节集类>
        font = 文本到多字节 (字体文件)
        @ return FImage_putText2((void*)GetData(),@<要绘制的文本>.GetText(), @<横坐标>, @<纵坐标>, @<红色>, @<绿色>, @<蓝色>,@<透明度>,(const char*)@<font>.GetPtr(),@<字体宽度>,@<字体高度>,@<字体透明度>);

    }

    方法 缩放 <公开 折叠 @嵌入式方法 = "">
    参数 处理后的图片 <类型 = 图片操作类>
    参数 缩放后的宽度 <类型 = 整数>
    参数 缩放后的高度 <类型 = 整数>
    参数 缩放插值方式 <类型 = 整数 注释 = "enum InterpolationFlags{" 注释 = "    /** nearest neighbor interpolation */"
            注释 = "    INTER_NEAREST        = 0," 注释 = "    /** bilinear interpolation */" 注释 = "    INTER_LINEAR         = 1,"
            注释 = "    /** bicubic interpolation */" 注释 = "    INTER_CUBIC          = 2,"
            注释 = "    /** resampling using pixel area relation. It may be a preferred method for image decimation, as"
            注释 = "    it gives moire\'-free results. But when the image is zoomed, it is similar to the INTER_NEAREST"
            注释 = "    method. */" 注释 = "    INTER_AREA           = 3," 注释 = "    /** Lanczos interpolation over 8x8 neighborhood */"
            注释 = "    INTER_LANCZOS4       = 4," 注释 = "    /** Bit exact bilinear interpolation */"
            注释 = "    INTER_LINEAR_EXACT = 5," 注释 = "    /** mask for interpolation codes */" 注释 = "    INTER_MAX            = 7,"
            注释 = "    /** flag, fills all of the destination image pixels. If some of them correspond to outliers in the"
            注释 = "    source image, they are set to zero */" 注释 = "    WARP_FILL_OUTLIERS   = 8,"
            注释 = "    /** flag, inverse transformation" 注释 = "" 注释 = "    For example, #linearPolar or #logPolar transforms:"
            注释 = "    - flag is __not__ set: \\f$dst( \\rho , \\phi ) = src(x,y)\\f$"
            注释 = "    - flag is set: \\f$dst(x,y) = src( \\rho , \\phi )\\f$" 注释 = "    */" 注释 = "    WARP_INVERSE_MAP     = 16"
            注释 = "};" 折叠2 @默认值 = 1>
    参数 横向缩放比例 <类型 = 小数 @默认值 = 0>
    参数 纵向缩放比例 <类型 = 小数 @默认值 = 0>
    {
        @ FImage_resize((void*)@sn<this>.GetData(), @<处理后的图片>.GetData(),@<缩放后的宽度>,@<缩放后的高度>,@<横向缩放比例>,@<纵向缩放比例>,@<缩放插值方式>)
    }

    方法 旋转 <公开 @嵌入式方法 = "">
    参数 处理后的图片 <类型 = 图片操作类>
    参数 旋转角度 <类型 = 整数>
    {
        @ FImage_Rotate((void*)@sn<this>.GetData(), @<处理后的图片>.GetData(),@<旋转角度>)
    }

    方法 统计行 <公开 注释 = "可以计算" @嵌入式方法 = "">
    参数 处理后的图片 <类型 = 图片操作类>
    参数 运算方式 <类型 = 整数 注释 = "0 相加" 注释 = "1 平均" 注释 = "2 最大" 注释 = "3 最小" 折叠2>
    参数 输出图片的类型 <类型 = 整数 注释 = "// -1 表示 输出图片类型和 输入类型一样，但是当 你调用了 REDUCE_SUM 相加的时候，数据类型肯定会变" 注释 = "// 此时要手动指定输出类型，可以设置为 CV_32SC1"
            注释 = "#define CV_8UC1 CV_MAKETYPE(CV_8U,1)" 注释 = "#define CV_8UC2 CV_MAKETYPE(CV_8U,2)"
            注释 = "#define CV_8UC3 CV_MAKETYPE(CV_8U,3)" 注释 = "#define CV_8UC4 CV_MAKETYPE(CV_8U,4)"
            注释 = "#define CV_8UC(n) CV_MAKETYPE(CV_8U,(n))" 注释 = "" 注释 = "#define CV_8SC1 CV_MAKETYPE(CV_8S,1)"
            注释 = "#define CV_8SC2 CV_MAKETYPE(CV_8S,2)" 注释 = "#define CV_8SC3 CV_MAKETYPE(CV_8S,3)"
            注释 = "#define CV_8SC4 CV_MAKETYPE(CV_8S,4)" 注释 = "#define CV_8SC(n) CV_MAKETYPE(CV_8S,(n))" 注释 = ""
            注释 = "#define CV_16UC1 CV_MAKETYPE(CV_16U,1)" 注释 = "#define CV_16UC2 CV_MAKETYPE(CV_16U,2)"
            注释 = "#define CV_16UC3 CV_MAKETYPE(CV_16U,3)" 注释 = "#define CV_16UC4 CV_MAKETYPE(CV_16U,4)"
            注释 = "#define CV_16UC(n) CV_MAKETYPE(CV_16U,(n))" 折叠2 @默认值 = -1>
    {
        @ FImage_reduce((void*)@sn<this>.GetData(), @<处理后的图片>.GetData(),0,@<运算方式>,@<输出图片的类型>)
    }

    方法 统计列 <公开 折叠 @嵌入式方法 = "">
    参数 处理后的图片 <类型 = 图片操作类>
    参数 运算方式 <类型 = 整数 注释 = "0 相加" 注释 = "1 平均" 注释 = "2 最大" 注释 = "3 最小">
    参数 输出图片的类型 <类型 = 整数 注释 = "// -1 表示 输出图片类型和 输入类型一样，但是当 你调用了 REDUCE_SUM 相加的时候，数据类型肯定会变" 注释 = "// 此时要手动指定输出类型，可以设置为 CV_32SC1"
            注释 = "#define CV_8UC1 CV_MAKETYPE(CV_8U,1)" 注释 = "#define CV_8UC2 CV_MAKETYPE(CV_8U,2)"
            注释 = "#define CV_8UC3 CV_MAKETYPE(CV_8U,3)" 注释 = "#define CV_8UC4 CV_MAKETYPE(CV_8U,4)"
            注释 = "#define CV_8UC(n) CV_MAKETYPE(CV_8U,(n))" 注释 = "" 注释 = "#define CV_8SC1 CV_MAKETYPE(CV_8S,1)"
            注释 = "#define CV_8SC2 CV_MAKETYPE(CV_8S,2)" 注释 = "#define CV_8SC3 CV_MAKETYPE(CV_8S,3)"
            注释 = "#define CV_8SC4 CV_MAKETYPE(CV_8S,4)" 注释 = "#define CV_8SC(n) CV_MAKETYPE(CV_8S,(n))" 注释 = ""
            注释 = "#define CV_16UC1 CV_MAKETYPE(CV_16U,1)" 注释 = "#define CV_16UC2 CV_MAKETYPE(CV_16U,2)"
            注释 = "#define CV_16UC3 CV_MAKETYPE(CV_16U,3)" 注释 = "#define CV_16UC4 CV_MAKETYPE(CV_16U,4)"
            注释 = "#define CV_16UC(n) CV_MAKETYPE(CV_16U,(n))" @默认值 = -1>
    {
        @ FImage_reduce((void*)@sn<this>.GetData(), @<处理后的图片>.GetData(),1,@<运算方式>,@<输出图片的类型>)
    }

    方法 取整体最大外接矩形 <公开 类型 = 逻辑型 注释 = "解释说明：" 注释 = "srcMat=" 注释 = "[  0,   0,   0,   0,   0;" 注释 = "   0,  44,  12,  22,   0;"
            注释 = "   0,  25,  26,  33,   0;" 注释 = "   0,  11,  22,  44,   0;" 注释 = "   0,   0,   0,   0,   0]" 注释 = "处理后"
            注释 = "desMat=" 注释 = "[ 44,  12,  22;" 注释 = "  25,  26,  33;" 注释 = "  11,  22,  44]" 注释 = "调用代码" 注释 = " cv::Mat output;"
            注释 = " int x1, y1, x2, y2;" 注释 = " if (FImage_reduceImage(&srcMat, &x1, &y1, &x2, &y2))" 注释 = " {"
            注释 = "  FImage_GetRoi(&srcMat, x1, y1, x2 - x1+1, y2 - y1+1, &output);" 注释 = " }" 返回值注释 = "返回真，则有最大外接矩形，返回假则没有，"
            @嵌入式方法 = "">
    参数 开始横坐标 <类型 = 整数>
    参数 开始纵坐标 <类型 = 整数>
    参数 结束横坐标 <类型 = 整数>
    参数 结束纵坐标 <类型 = 整数>
    {
        @ FImage_reduceImage(@sn<this>.GetData(), &@<开始横坐标>, &@<开始纵坐标>,&@<结束横坐标>,&@<结束纵坐标>)

    }

    方法 分离通道 <公开 @嵌入式方法 = "">
    参数 通道1 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道2 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道3 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道4 <类型 = 图片操作类 @默认值 = 空对象>
    {
        @ FImage_SplitChannel(@sn<this>.GetData(),@<通道1>.GetData(),@<通道2>.GetData(),@<通道3>.GetData(),@<通道4>.GetData())
    }

    方法 合并通道 <公开 @嵌入式方法 = "">
    参数 通道1 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道2 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道3 <类型 = 图片操作类 @默认值 = 空对象>
    参数 通道4 <类型 = 图片操作类 @默认值 = 空对象>
    {
        @ FImage_MergeChannel(@sn<this>.GetData(),@<通道1>.GetData(),@<通道2>.GetData(),@<通道3>.GetData(),@<通道4>.GetData())
    }

    方法 "//查找轮廓矩形数组" <公开 类型 = 逻辑型 注释 = "对于屏幕传输效果不理想" @嵌入式方法 = "">
    参数 输出_轮廓矩形数组 <类型 = 轮廓矩形数组类>
    {
        @ CVContours_FindContours(@sn<this>.GetData(),@<输出_轮廓矩形数组>.GetData())
    }

    方法 "//融合" <公开 注释 = "暂时丢弃" 折叠 @嵌入式方法 = "">
    参数 本类图片权重 <类型 = 小数>
    参数 要融合的图片 <类型 = 图片操作类>
    参数 要融合的图片权重 <类型 = 小数>
    参数 合成后的图片 <类型 = 图片操作类>
    参数 融合后添加的数值 <类型 = 小数 @默认值 = 0>
    参数 深度 <类型 = 整数 @默认值 = -1>
    {
        @ FImage_addWeighted((void*)@sn<this>.GetData(),@<本类图片权重>,(void*)@<要融合的图片>.GetData(),@<要融合的图片权重>,@<融合后添加的数值>,(void*)@<合成后的图片>.GetData(),@<深度>)
    }
}

类 轮廓矩形数组类 <公开>
{

    # @begin
    # <> <include>
    # public:
    # void* GetData()
    # {
    #     return m_pData;
    # }
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ m_pData = CVRectArray_new();
    }

    方法 类_清理
    {
        @ CVRectArray_delete(m_pData);
    }

    方法 取数量 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ CVRectArray_GetCount(@sn<this>.GetData())
    }

    方法 取矩形坐标 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    {
        @ CVRectArray_GekRect(@sn<this>.GetData(),@<索引>,&@<左边>,&@<顶边>,&@<右边>,&@<底边>)
    }

    #
}
