            }
        }
        返回 (假)
    }

    方法 进程_进程名称是否存在 <公开 静态 类型 = 逻辑型 折叠>
    参数 要查找的进程名称 <类型 = 文本型>
    {
        变量 进程ID <类型 = 整数数组类>
        进程_枚举进程ID (进程ID)
        进程ID.枚举循环 ()
        {
            如果 (进程_取路径通过ID (进程ID.取枚举值 (), 假) == 要查找的进程名称)
            {
                返回 (真)
            }
        }
        返回 (假)

    }

    方法 进程_取ID通过进程名称 <公开 静态 类型 = 整数 注释 = "比如有两个 ie.exe 只会返回第一个找到的，如果您要同时找到两个id ，可以用 进程_取指定进程名称ID数组" 注释 = "如果找到，返回进程id 否则返回 -1"
            折叠>
    参数 进程名称 <类型 = 文本型 注释 = "例如id.exe">
    {
        变量 进程ID <类型 = 整数数组类>
        进程_枚举进程ID (进程ID)
        进程ID.枚举循环 ()
        {
            如果 (进程_取路径通过ID (进程ID.取枚举值 (), 假) == 进程名称)
            {
                返回 (进程ID.取枚举值 ())
            }
        }
        返回 (-1)
    }
}

类 进程打开_常量类 <公开 折叠>
{
    常量 全部权限 <公开 类型 = 整数 值 = @PROCESS_ALL_ACCESS>
    常量 创建进程 <公开 类型 = 整数 值 = @PROCESS_CREATE_PROCESS>
    常量 创建线程 <公开 类型 = 整数 值 = @PROCESS_CREATE_THREAD>
    常量 取真实句柄 <公开 类型 = 整数 值 = @PROCESS_DUP_HANDLE>
    常量 查询进程信息 <公开 类型 = 整数 值 = @PROCESS_QUERY_INFORMATION>
    常量 SET_QUOTA <公开 类型 = 整数 值 = @PROCESS_SET_QUOTA>
    常量 设置进程信息 <公开 类型 = 整数 值 = @PROCESS_SET_INFORMATION>
    常量 结束进程 <公开 类型 = 整数 值 = @PROCESS_TERMINATE>
    常量 打打开虚拟内存 <公开 类型 = 整数 值 = @PROCESS_VM_OPERATION>
    常量 读虚拟内存 <公开 类型 = 整数 值 = @PROCESS_VM_READ>
    常量 写虚拟内存 <公开 类型 = 整数 值 = @PROCESS_VM_WRITE>
    常量 SYNCHRONIZE <公开 类型 = 整数 值 = @SYNCHRONIZE
            注释 = "Enables using the process handle in any of the wait functions to wait for the process to terminate.">

    #
}

类 CMD回显类 <公开 @视窗.后缀文本 = "public CProcessToolCMDEchoBase">
{

    # @begin
    # <> <include>
    #  virtual void Echo(const char* pBuffer, int nBufferLen);
    # <> </include>
    # void @sn<current_class>::Echo(const char* pBuffer, int nBufferLen)
    # {
    #     CVolMem mem(pBuffer,nBufferLen);
    #     @<收到数据>(mem);
    # }
    # @end

    方法 执行命令 <公开 类型 = 逻辑型 注释 = "可以执行实时回显的命令，例如" 注释 = "ping www.baidu.com -t" @嵌入式方法 = "">
    参数 要执行的命令 <类型 = 文本型 注释 = "例如 tree /f c:\\a">
    参数 是否使用CMD <类型 = 逻辑型 注释 = "是否以 cmd /C 开头，如果为真，则完整的运行命令为  cmd /C tree /f c:\\a" @默认值 = 真>
    {
        @ ProcessTool_RunCmdEcho(@<要执行的命令>,&@sn<this>)

    }

    方法 收到数据 <公开 定义事件 类型 = 整数>
    参数 收到的字节集 <类型 = 字节集类>
    {



    }
}

类 "//CMD回显扩展类" <公开 折叠 @视窗.后缀文本 = "public CProcessToolCMDEchoBaseEx">
{

    # @begin
    # <> <include>
    #  virtual void Echo(void* hWrite,const char* pBuffer, int nBufferLen);
    # <> </include>
    # void @sn<current_class>::Echo(void* hWrite,const char* pBuffer, int nBufferLen)
    # {
    #     CVolMem mem(pBuffer,nBufferLen);
    #     @<收到数据>((INT_P)hWrite,mem);
    # }
    # @end

    方法 启动进程 <公开 类型 = 逻辑型 注释 = "可以执行实时回显的命令，例如 telent" 折叠 @嵌入式方法 = "">
    参数 要启动的进程 <类型 = 文本型 注释 = "telent">
    {
        @ ProcessTool_RunCmdEchoEx(@<要启动的进程>,&@sn<this>)

    }

    方法 _执行命令 <类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 写句柄 <类型 = 变整数>
    参数 命令指针 <类型 = 变整数>
    参数 命令大小 <类型 = 整数>
    {
        @ ProcessTool_WriteEchoEx((void*)@<写句柄>,(const char*)@<命令指针>,@<命令大小>)

    }

    方法 执行命令 <公开 类型 = 逻辑型 折叠>
    参数 写句柄 <类型 = 变整数>
    参数 命令文本 <类型 = 文本型>
    参数 是否UTF8编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 命令 <类型 = 字节集类>
        如果 (是否UTF8编码)
        {
            命令 = 文本到UTF8 (命令文本)
        }
        否则
        {
            命令 = 文本到多字节 (命令文本)
        }

        返回 (_执行命令 (写句柄, 取字节集指针 (命令), 取字节集长度 (命令) - 1))

    }

    方法 收到数据 <公开 定义事件 类型 = 整数>
    参数 写句柄 <类型 = 变整数>
    参数 收到的字节集 <类型 = 字节集类>
    {

    }
}
