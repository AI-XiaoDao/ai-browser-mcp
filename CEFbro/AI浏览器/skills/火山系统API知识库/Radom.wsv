    方法 随机_UserAgent <公开 静态 类型 = 文本型 注释 = "火友 小蜗牛 提供" 折叠>
    {
        变量 NT <类型 = 文本型>
        变量 操作系统 <类型 = 文本型>
        变量 AppleWebKit <类型 = 文本型>
        变量 Chrome <类型 = 文本型>
        NT = 多项选择 (取随机数 (0, 5), "6.0", "6.1", "6.2", "6.3", "6.4", "10.0")
        操作系统 = 多项选择 (取随机数 (0, 2), "Win32; x32", "Win64; x64", "WOW64")
        AppleWebKit = 到文本 (取随机数 (530, 540)) + "." + 到文本 (取随机数 (10, 99))
        Chrome = 到文本 (取随机数 (62, 89)) + "." + 到文本 (取随机数 (0, 9)) + "." + 到文本 (取随机数 (1000, 5000)) + "." + 到文本 (取随机数 (1, 99))
        返回 ("Mozilla/5.0 (Windows NT " + NT + "; " + 操作系统 + ") AppleWebKit/" + AppleWebKit + " (KHTML, like Gecko) Chrome/" + Chrome + " Safari/" + AppleWebKit)
    }

    方法 随机_百家姓F <公开 静态 类型 = 文本型 注释 = "随机得到一个百家姓" 折叠>
    {
        常量 百家姓 <类型 = 文本型
