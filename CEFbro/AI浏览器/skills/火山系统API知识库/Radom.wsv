    方法 随机_汉字F <公开 类型 = 文本型 注释 = "//https://www.qqxiuzi.cn/zh/hanzi-unicode-bianma.php" 折叠>
    参数 数量 <类型 = 整数>
    {
        变量 结果 <类型 = 文本型>
        置文本预分配字符数 (结果, 数量)
        循环 (0, 数量)
        {
            加入字符 (结果, (字符)取随机数f (0x4E00, 0x9FEF))
        }
        返回 (结果)

    }
}

类 随机数测试 <公开>
{
    方法 开始测试 <公开>
    {
        变量 i <类型 = 整数>
        变量 k <类型 = 整数>
        变量 统计表 <类型 = "整数 [10]">
        变量 ""
        变量 统计结果 <类型 = 文本型>
        调试输出 ("---- 开始随机数测试")

        置随机种子f (取启动时间_整数 ())
        // 统计100万次,来观察分布概率

        循环 (0, 1000000, i, 1)
        {
            k = 取随机数f (0, 9)
            统计表 [k] = 统计表 [k] + 1

        }

        循环 (0, 10, i, 1)
        {
            统计结果 = 统计结果 + 到文本 (i) + "    " + 到文本 (统计表 [i]) + "\r\n"

        }

        调试输出 (统计结果)
        调试输出 ("---- 结束随机数测试")



        变量 不重复随机数 <类型 = 随机数类_不重复f>
        调试输出 ("---- 开始测试  不重复随机数")
        不重复随机数.创建 (0, 10)
        判断循环 (不重复随机数.是否为空 () == 假)
        {
            调试输出 (不重复随机数.取随机数 ())
        }
        调试输出 ("---- 结束测试  不重复随机数")


    }

    #
}
