    方法 获取硬件信息 <公开 类型 = 文本型>
    {
        变量 kv <类型 = 键值表>
        kv.置整数 ("机器码", 系统_取硬件特征F ())
        kv.置整数 ("CPU核心数", 系统_取CPU核心数F ())
        kv.置小数 ("内存总大小", 系统_取内存大小F ())
        kv.置逻辑值 ("是否64位", 系统_是否64位 ())
        kv.置文本 ("CKCTime", 时间_取日期时间 ())  // 是 Client Key Create Time 的缩写,客户端 创建 机器码的时间

        变量 加密后的文本 <类型 = 文本型>
        // 调试输出 ("加密前的文本", kv.到文本 ())
        密码学_RSA_PKCS1v15_公钥加密 (成员_硬件信息加密公钥, kv.到文本 (), 加密后的文本)
        // 调试输出 ("加密后的文本", 加密后的文本)
        返回 (加密后的文本)

    }

    方法 验证注册码是否有效 <公开 类型 = 逻辑型 折叠>
    参数 注册码 <类型 = 文本型 注释 = "这个参数必须对应  生成授权类.生成注册码  开头的函数的返回值">
    {
        变量 解密后的硬件信息 <类型 = 文本型>
        变量 授权信息 <类型 = 键值表>

        密码学_RSA_PKCS1v15_私钥解密 (成员_授权信息密钥, 注册码, 解密后的硬件信息)
        // 调试输出 ("aaa", 解密后的硬件信息)
        授权信息.从文本载入 (解密后的硬件信息)
        如果 (授权信息.取整数 ("机器码") != 系统_取硬件特征F ())
        {
            返回 (假)
        }

        变量 授权类型 <类型 = 整数>
        授权类型 = 授权信息.取整数 ("type")
        // 调试输出 ("授权类型", 授权类型)
        如果 (授权类型 == 0)
        {
            // 延时 (3000)
            // 到期就不能用咯
            变量 到期时间 <类型 = 文本型>
            到期时间 = 授权信息.取文本 ("time")
            // 调试输出 ("到期时间", 到期时间)
            // 调试输出 ("本机时间", 时间_取日期时间 ())
            // 调试输出 ("时间间隔", 时间_取时间间隔f (时间_取日期时间 (), 到期时间, 时间间隔常量.秒))

            如果 (时间_取时间间隔f (时间_取日期时间 (), 到期时间, 时间间隔常量.秒) > 0)
            {
                返回 (真)
            }
            否则
            {
                返回 (假)
            }

        }
        否则 (授权类型 == 1)
        {
            如果 (授权信息.取逻辑值 ("a"))
            {
                返回 (真)
            }
            否则
            {
                返回 (假)
            }

        }
        否则 (授权类型 == 2)
        {
            如果 (授权信息.是否存在 ("u"))
            {
                成员_会员等级 = 授权信息.取整数 ("u")
                返回 (真)
            }
            否则
            {
                返回 (假)
            }


        }

        返回 (假)

    }

    方法 取会员等级 <公开 类型 = 整数>
    {
        返回 (成员_会员等级)

    }

    #
}

类 "//一些测试例子哦"
{
    方法 生成到期不能用的例子 <折叠>
    {
        变量 验证 <类型 = 验证授权类>
        变量 生成 <类型 = 生成授权类>
        变量 硬件信息 <类型 = 文本型>
        变量 注册码 <类型 = 文本型>
        硬件信息 = 验证.获取硬件信息 ()
        注册码 = 生成.生成注册码_到期不能用 (硬件信息, 时间_取日期时间 ())

        如果 (验证.验证注册码是否有效 (注册码))
        {
            调试输出 ("注册码有效")
        }
        否则
        {
            调试输出 ("注册码无效")

        }


    }

    方法 生成终身vip的例子 <折叠>
    {
        变量 验证 <类型 = 验证授权类>
        变量 生成 <类型 = 生成授权类>
        变量 硬件信息 <类型 = 文本型>
        变量 注册码 <类型 = 文本型>
        硬件信息 = 验证.获取硬件信息 ()
        注册码 = 生成.生成注册码_生成永久有效 (硬件信息)

        如果 (验证.验证注册码是否有效 (注册码))
        {
            调试输出 ("注册码有效")
        }
        否则
