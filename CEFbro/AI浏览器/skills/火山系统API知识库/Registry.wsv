    方法 注册表_置文本 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 键值 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        // LONG RegSetValueEx(  HKEY hKey,           // handle to key
        // LPCTSTR lpValueName, // value name  DWORD Reserved,      // reserved
        // DWORD dwType,        // value type  CONST BYTE *lpData,  // value data
        // DWORD cbData         // size of value data);

        变量 缓冲区指针 <类型 = 变整数>
        变量 写入长度 <类型 = 整数>
        缓冲区指针 = 取文本指针 (键值)
        写入长度 = 取文本长度 (键值) * 2

        @     REGSAM  option = KEY_WRITE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;

        @  HKEY hSubKey;
        @  LONG lResult = RegCreateKeyEx((HKEY)@<根节点>,@<键路径>, 0, NULL, REG_OPTION_NON_VOLATILE, option, NULL, &hSubKey, NULL);
        // @  LONG lResult = RegOpenKeyEx((HKEY)@<根节点>,@<键路径>,0,KEY_SET_VALUE|KEY_CREATE_SUB_KEY,&hSubKey);
        @ 
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return false;
        @  }
        @ 
        @  lResult = RegSetValueEx(hSubKey,@<键名称> , NULL, REG_SZ ,(LPBYTE)@<缓冲区指针>,@<写入长度>);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return false;
        @  }
        @  RegCloseKey(hSubKey);
        @  return true;

    }

