    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        @  DWORD dwOperat = REG_CREATED_NEW_KEY;
        @     HKEY hTestKey;
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;

        @  HKEY  hKey;
        @  LONG  lResult  = RegCreateKeyEx((HKEY)@<根节点>,@<键路径>,NULL,NULL,NULL,option,NULL,&hKey,&dwOperat); 
        @  if(lResult != ERROR_SUCCESS)
        @  {
        @   RegCloseKey(hKey);
        @   SetLastError(lResult);
        @   return false;
        @  }
        @  RegCloseKey(hKey);
        @ return true;


    }

    方法 注册表_枚举健 <公开 静态 折叠>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 输出_用来保存键数组 <类型 = 文本数组类>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        输出_用来保存键数组.删除所有成员 ()
        @ HKEY hKey = (HKEY)@<根节点>;
        @ LPCTSTR lpsubkey = (LPCTSTR)@<键路径>;
        @ #define MAX_KEY_LENGTH 255
        @ #define MAX_VALUE_NAME 16383
        @     HKEY hTestKey;
        @     REGSAM  option = KEY_READ;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @     if (RegOpenKeyEx(hKey, lpsubkey, 0, option, &hTestKey) != ERROR_SUCCESS) return;
        @ 
        @     TCHAR    achKey[MAX_KEY_LENGTH];   // buffer for subkey name
        @     DWORD    cbName;                   // size of name string 
        @     TCHAR    achClass[MAX_PATH] = TEXT("");  // buffer for class name 
        @     DWORD    cchClassName = MAX_PATH;  // size of class string 
        @     DWORD    cSubKeys = 0;               // number of subkeys 
        @     DWORD    cbMaxSubKey;              // longest subkey size 
        @     DWORD    cchMaxClass;              // longest class string 
        @     DWORD    cValues;              // number of values for key 
        @     DWORD    cchMaxValue;          // longest value name 
        @     DWORD    cbMaxValueData;       // longest value data 
        @     DWORD    cbSecurityDescriptor; // size of security descriptor 
        @     FILETIME ftLastWriteTime;      // last write time 
        @ 
        @     DWORD i, retCode;
        @ 
        @     //TCHAR  achValue[MAX_VALUE_NAME];
        @     DWORD cchValue = MAX_VALUE_NAME;
        @ 
        @     // Get the class name and the value count. 
        @     retCode = RegQueryInfoKey(
        @         hTestKey,                    // key handle 
        @         achClass,                // buffer for class name 
        @         &cchClassName,           // size of class string 
        @         NULL,                    // reserved 
        @         &cSubKeys,               // number of subkeys 
        @         &cbMaxSubKey,            // longest subkey size 
        @         &cchMaxClass,            // longest class string 
        @         &cValues,                // number of values for this key 
        @         &cchMaxValue,            // longest value name 
        @         &cbMaxValueData,         // longest value data 
        @         &cbSecurityDescriptor,   // security descriptor 
        @         &ftLastWriteTime);       // last write time 
        @ 
        @     // Enumerate the subkeys, until RegEnumKeyEx fails.
        @ 
        @     if (cSubKeys)
        @     {
        @         //printf("\nNumber of subkeys: %d\n", cSubKeys);
        @ 
        @         for (i = 0; i < cSubKeys; i++)
        @         {
        @             cbName = MAX_KEY_LENGTH;
        @             retCode = RegEnumKeyEx(hTestKey, i,
        @                 achKey,
        @                 &cbName,
        @                 NULL,
        @                 NULL,
        @                 NULL,
        @                 &ftLastWriteTime);
        @             if (retCode == ERROR_SUCCESS)
        @             {
        @                 @<输出_用来保存键数组>.data ().Add2 (achKey);
        @             }
        @         }
        @     }
        @ 
        @     RegCloseKey(hTestKey);



    }

    方法 注册表_枚举值 <公开 静态 折叠>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 输出_用来保存键数组 <类型 = 文本数组类>
    参数 输出_用来保存值类型数组 <类型 = 整数数组类 注释 = "如果传递空对象，则忽略此参数" @默认值 = 空对象>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {

        输出_用来保存键数组.删除所有成员 ()
        如果 (输出_用来保存值类型数组 != 空对象)
        {
            输出_用来保存值类型数组.删除所有成员 ()
        }
        @ HKEY hKey = (HKEY)@<根节点>;
        @ LPCTSTR lpsubkey = (LPCTSTR)@<键路径>;
        @ #define MAX_KEY_LENGTH 255
        @ #define MAX_VALUE_NAME 16383
        @     HKEY hTestKey;
        @     REGSAM  option = KEY_READ;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @     if (RegOpenKeyEx(hKey, lpsubkey, 0, option, &hTestKey) != ERROR_SUCCESS) return;
        @ 
        @     TCHAR    achKey[MAX_KEY_LENGTH];   // buffer for subkey name
        @     DWORD    cbName;                   // size of name string 
        @     TCHAR    achClass[MAX_PATH] = TEXT("");  // buffer for class name 
        @     DWORD    cchClassName = MAX_PATH;  // size of class string 
        @     DWORD    cSubKeys = 0;               // number of subkeys 
        @     DWORD    cbMaxSubKey;              // longest subkey size 
        @     DWORD    cchMaxClass;              // longest class string 
        @     DWORD    cValues;              // number of values for key 
        @     DWORD    cchMaxValue;          // longest value name 
        @     DWORD    cbMaxValueData;       // longest value data 
        @     DWORD    cbSecurityDescriptor; // size of security descriptor 
        @     FILETIME ftLastWriteTime;      // last write time 
        @ 
        @     DWORD i, retCode;
        @ 
        @     TCHAR  achValue[MAX_VALUE_NAME];
        @     DWORD cchValue = MAX_VALUE_NAME;
        @ 
        @     // Get the class name and the value count. 
        @     retCode = RegQueryInfoKey(
        @         hTestKey,                    // key handle 
        @         achClass,                // buffer for class name 
        @         &cchClassName,           // size of class string 
        @         NULL,                    // reserved 
        @         &cSubKeys,               // number of subkeys 
        @         &cbMaxSubKey,            // longest subkey size 
        @         &cchMaxClass,            // longest class string 
        @         &cValues,                // number of values for this key 
        @         &cchMaxValue,            // longest value name 
        @         &cbMaxValueData,         // longest value data 
        @         &cbSecurityDescriptor,   // security descriptor 
        @         &ftLastWriteTime);       // last write time 
        @ 
        @     // Enumerate the subkeys, until RegEnumKeyEx fails.
        @ 
        @     if (cValues)
        @     {
        @         for (i = 0, retCode = ERROR_SUCCESS; i < cValues; i++)
        @         {
        @             DWORD dwValueType = 0;
        @             cchValue = MAX_VALUE_NAME;
        @             achValue[0] = '\0';
        @             retCode = RegEnumValue(hTestKey, i,achValue,&cchValue,NULL,&dwValueType,NULL,NULL);
        @ 
        @             if (retCode == ERROR_SUCCESS)
        @             {
        @                 @<输出_用来保存键数组>.data ().Add2 (achValue);
        @             }
        @             if( !@<输出_用来保存值类型数组>.IsNullObject () )
        @             {
        @                  @<输出_用来保存值类型数组>.data().Add2((INT)dwValueType);   
        @             }
        @         }
        @     }
        @ 
        @     RegCloseKey(hTestKey);



    }

    # @begin
    # LONG DeleteSubKeyTree(HKEY hKey, LPCTSTR lpSubKey,BOOL b64bit)
    # {
