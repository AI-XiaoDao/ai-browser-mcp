包 火山.原创软件 <@文档 = "category = \"windows.注册表\"" "">

类 注册表根类型_常量类 <公开 @常量类 = 变整数>
{
    常量 HKEY_CLASSES_ROOT <公开 值 = @"@(INT_P)HKEY_CLASSES_ROOT" "">
    常量 HKEY_CURRENT_CONFIG <公开 值 = @"@(INT_P)HKEY_CURRENT_CONFIG">
    常量 HKEY_CURRENT_USER <公开 值 = @"@(INT_P)HKEY_CURRENT_USER">
    常量 HKEY_LOCAL_MACHINE <公开 值 = @"@(INT_P)HKEY_LOCAL_MACHINE">
    常量 HKEY_USERS <公开 值 = @"@(INT_P)HKEY_USERS">

    #
    #
}

类 注册表打开方式_常量类 <公开 折叠>
{
    常量 KEY_CREATE_LINK <公开 类型 = 整数 值 = @KEY_CREATE_LINK "">
    常量 创建子键 <公开 类型 = 整数 值 = @KEY_CREATE_SUB_KEY>
    常量 枚举子键 <公开 类型 = 整数 值 = @KEY_ENUMERATE_SUB_KEYS>
    常量 KEY_EXECUTE <公开 类型 = 整数 值 = @KEY_EXECUTE>
    常量 KEY_NOTIFY <公开 类型 = 整数 值 = @KEY_NOTIFY>
    常量 查询值 <公开 类型 = 整数 值 = @KEY_QUERY_VALUE>
    常量 设置值 <公开 类型 = 整数 值 = @KEY_SET_VALUE>
    常量 所有方式 <公开 类型 = 整数 值 = @KEY_ALL_ACCESS>
    常量 读 <公开 类型 = 整数 值 = @KEY_READ>
    常量 KEY_WOW64_64KEY <公开 类型 = 整数 值 = @KEY_WOW64_64KEY>
    常量 KEY_WOW64_32KEY <公开 类型 = 整数 值 = @KEY_WOW64_32KEY>
    常量 写 <公开 类型 = 整数 值 = @KEY_WRITE>

    #
}

类 "//注册表基础_全局类" <公开 注释 = "https://docs.microsoft.com/en-us/windows/win32/api/winreg/nf-winreg-regenumkeyexw"
        注释 = "https://docs.microsoft.com/en-us/windows/win32/sysinfo/determining-the-registry-size" 折叠 折叠2>
{
    方法 打开 <公开 类型 = 整数 返回值注释 = "0 表示成功 ERROR_SUCCESS" @嵌入式方法 = "">
    参数 根类型 <类型 = 注册表根类型_常量类 "">
    参数 子键名称 <类型 = 文本型>
    参数 打开方式 <类型 = 整数 注释 = "请使用 注册表打开方式_常量类 相关的常量">
    参数 输出_键句柄 <类型 = 变整数>
    {
        @ RegOpenKeyExW( (HKEY)@<根类型>,@<子键名称>,0,(REGSAM)@<打开方式>,(PHKEY)&@<输出_键句柄>)
    }

    方法 关闭 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 键句柄 <类型 = 变整数>
    {
        @ RegCloseKey((HKEY)@<键句柄>)
    }

    方法 枚举键 <公开 静态 @禁止流程检查 = 真>
    参数 根类型 <类型 = 注册表根类型_常量类 "">
    参数 索引 <类型 = 整数 注释 = "如果第一次调用，请填写0">
    参数 子键名称 <类型 = 文本型>
    参数 用户定义类名 <类型 = 文本型 @默认值 = 空对象>
    {
        @ wchar_t buffer[MAX_PATH] = {0}
        @ DWORD dwKeySize = 0;
        @ wchar_t lpClass[MAX_PATH] = {0}
        @ DWORD dwClass = 0;
        @ LSTATUS nState = RegEnumKeyExW((HKEY)@<根类型>,(DWORD)@<索引>,buffer,dwKeySize,NULL,lpClass,&dwClass,NULL);
        如果 (用户定义类名 != 空对象)
        {
            @ @<用户定义类名> =  lpClass;
        }
        @ return nState;
    }

    #
    #
}

类 ______注册表操作_全局类 <公开 @全局类 = 真>
{
    方法 注册表_取文本 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型 @默认值 = "">
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;

        @  HKEY hSubKey;
        @  TCHAR buffer[4096] = {0};
        @ DWORD dwBufferSize = sizeof(TCHAR)*sizeof(buffer);
        @  LONG lResult = RegOpenKeyEx((HKEY)@<根节点>,@<键路径>,0,option,&hSubKey);
        @ 
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return buffer;
        @  }
        @ 
        @  lResult = RegQueryValueEx(hSubKey,@<键名称> , NULL, NULL ,(LPBYTE)buffer,&dwBufferSize);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return buffer;
        @  }
        @  RegCloseKey(hSubKey);
        @  return buffer;

    }

    方法 注册表_取整数 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 返回值 <类型 = 整数>
        @     REGSAM  option = KEY_QUERY_VALUE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;

        @  HKEY hSubKey;
        @ DWORD dwBufferSize = 4;
        @  LONG lResult = RegOpenKeyEx((HKEY)@<根节点>,@<键路径>,0,option,&hSubKey);
        @ 
        @  if( ERROR_SUCCESS != lResult )
        @  {
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @ 
        @  lResult = RegQueryValueEx(hSubKey,@<键名称> , NULL, NULL ,(LPBYTE)&@<返回值>,&dwBufferSize);
        @  if(ERROR_SUCCESS != lResult)
        @  {
        @   RegCloseKey(hSubKey);
        @   SetLastError(lResult);
        @   return -1;
        @  }
        @  RegCloseKey(hSubKey);
        返回 (返回值)
    }

