    方法 "//注册表_删除键2" <公开 静态 类型 = 整数 @禁止流程检查 = 真>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        @ return DeleteSubKeyTree((HKEY)@<根节点>,@<键路径>.GetText(),@<是否64位>);

    }

    方法 注册表_删除值 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 根节点 <类型 = 注册表根类型_常量类 注释 = "具体请看 注册表根类型_常量类">
    参数 键路径 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 是否64位 <类型 = 逻辑型 @默认值 = 假>
    {
        @  HKEY  hKey;
        @  DWORD dwOperat = REG_CREATED_NEW_KEY;
        @     REGSAM  option = KEY_WRITE;
        @     if(@<是否64位>)
        @      option|=KEY_WOW64_64KEY;
        @     else
        @      option|=KEY_WOW64_32KEY;
        @  LONG  lResult  = RegCreateKeyEx((HKEY)@<根节点>,@<键路径>,NULL,NULL,NULL,option,NULL,&hKey,&dwOperat); 
        @  if(lResult != ERROR_SUCCESS)
        @  {
        @   RegCloseKey(hKey);
        @   SetLastError(lResult);
        @   return false;
        @  }
        @  BOOL bOK = FALSE;
        @  lResult = RegDeleteValue(hKey,@<键名称>);
        @  if(lResult != ERROR_SUCCESS)
        @  {
        @   RegCloseKey(hKey);
        @   SetLastError(lResult);
        @   return false;
        @  }
        @  RegCloseKey(hKey);
        @ return true;


    }

    方法 注册表_定位 <公开 静态 注释 = "注意，需要管理员权限" 折叠 @视窗.附属文件 = "Registry\\regjump.exe">
    参数 定位位置 <类型 = 文本型>
    {
        调试输出 ("注意!!!! 注册表_定位  需要管理员权限，否则不会成功")
        注册表_置整数 (注册表根类型_常量类.HKEY_CURRENT_USER, "Software\\Sysinternals\\Regjump", "EulaAccepted", 1)
        运行f ("regjump " + 定位位置, 假, 4)







    }
}

类 _____辅助注册表 <公开 注释 = "本模块由  绿茶(858058286)   提供" @全局类 = 真>
{
    方法 打开__RegOpenKeyExW <静态 类型 = 整数 注释 = "成功返回非零的数键句柄  ,  用于其他函数调用 以及调用后关闭句柄" 返回值注释 = "如果<=0   要么是打开失败, 要么是键路径不正确" 折叠
            @禁止流程检查 = 真>
    参数 参_键路径 <类型 = 文本型>
    参数 参_KEY <类型 = 整数 注释 = "1= HKEY_CLASSES_ROOT" 注释 = "2= HKEY_CURRENT_USER" 注释 = "3= HKEY_LOCAL_MACHINE" 注释 = "4= HKEY_USERS"
            注释 = "5= HKEY_CURRENT_CONFIG">
    参数 参_是否64 <类型 = 逻辑型 @默认值 = 真>
    {
        @ HKEY WKey = NULL;
        @ switch (@<参_KEY>)
        @ {
        @     case 1:
        @         WKey = HKEY_CLASSES_ROOT;
        @         break;
        @     case 2:
        @         WKey = HKEY_CURRENT_USER;
        @         break;
        @     case 3:
        @         WKey = HKEY_LOCAL_MACHINE;
        @         break;
        @     case 4:
        @         WKey = HKEY_USERS;
        @         break;
        @     case 5:
        @         WKey = HKEY_CURRENT_CONFIG;
        @         break;
        @     default:
        @         break;
        @ }
        @ if ( (INT_PTR) WKey >=0) return 0;
        @ REGSAM X86X64 = @<参_是否64> ? KEY_WOW64_64KEY : KEY_WOW64_32KEY;
        @ HKEY Hwndkey;
        @ if ( RegOpenKeyExW(WKey, @<参_键路径>.GetText(), 0, X86X64 | KEY_ALL_ACCESS,   (PHKEY)&Hwndkey) != ERROR_SUCCESS)  return 0;
        @ return (INT_PTR) Hwndkey;
    }

    方法 注册表_删除 <公开 静态 类型 = "逻辑型  " 注释 = "成功返回真" 返回值注释 = "不存在也返回真" @禁止流程检查 = 真>
    参数 参__根节点 <类型 = 整数 注释 = "1= CLASSES_ROOT、2= CURRENT_USER、3=LOCAL_MACHINE、4=USERS、5=CURRENT_CONFIG">
    参数 参__键路径 <类型 = 文本型 注释 = "例如： SOFTWARE\\XXXXX     后缀有无反斜杠都可以">
    参数 参__是否64位 <类型 = 逻辑型 注释 = "真=64,  假=32" @默认值 = 真>
    {
        变量 局__键句柄 <类型 = 变整数>
        局__键句柄 = 打开__RegOpenKeyExW (参__键路径, 参__根节点, 参__是否64位)
        @ if (@<局__键句柄> <=0)  return true;//  键不存在  或 打开失败,  参数都填写正确的情况下打开失败的几率应该不会有吧....
        @ if( RegDeleteKeyW((HKEY)@<局__键句柄>, _T("")) ==ERROR_SUCCESS ) return true;// 先用这个删除不包含子项的函数删除, 如果删除成功也就用不到下面的递归函数删除了
        如果 (RegDeleteTreeWwW (局__键句柄) == 0)
        {
            @ SHChangeNotify(SHCNE_ASSOCCHANGED, SHCNF_IDLIST, NULL, NULL);//  删除成功后应该得刷新下注册表吧,   测试的时候不刷新也没事
            @ if( RegDeleteKeyW((HKEY)@<局__键句柄>, _T("")) ==ERROR_SUCCESS ) return true;// 递归删除子项之后 再删除指定的键路径就可以删除了
            @  RegCloseKey ((HKEY)@<局__键句柄>);// 删除失败之后 关闭键句柄
            @  return false;
        }
        @  RegCloseKey ((HKEY)@<局__键句柄>);// 删除失败之后 关闭键句柄
        @  return false;

    }

    方法 RegDeleteTreeWwW <静态 类型 = 变整数 注释 = "成功返回0,   递归删除指定键路径下的所有子项 , 提供的键路径不会删除" @输出名 = "RegDeleteTreeW"
            @视窗.输入 = "Advapi32.dll">
    参数 参__键句柄 <类型 = 变整数 "">
    参数 参__键路径 <类型 = 变整数 @默认值 = 0>
    {

    }

    #
}
