<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"开源库.树结构\"" "" @视窗.外部头文件 = "TreeStruct\\TreeTool\\TreeStruct.h"
        @视窗.外部源文件 = "TreeStruct\\TreeTool\\TreeStruct.cpp">

类 ______树结构 <公开 @全局类 = 真>
{
    方法 树结构_创建 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    {
        @ (@dt<变整数>)TreeStruct_Create()
    }

    方法 树结构_销毁 <公开 静态 @嵌入式方法 = "">
    参数 树结构句柄 <类型 = 变整数>
    {
        @ TreeStruct_Destory((CTreeStruct*)@<树结构句柄>)
    }

    方法 树结构_置文本 <公开 静态 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 文本内容 <类型 = 文本型>
    {
        @ TreeStruct_SetText((CTreeStruct*)@<节点句柄>,@<文本内容>)
    }

    方法 树结构_取文本 <公开 静态 类型 = 文本型 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ CVolString(TreeStruct_GetText((CTreeStruct*)@<节点句柄>))
    }

    方法 树结构_取子节点数量 <公开 静态 类型 = 整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ (int)TreeStruct_GetChildCount((CTreeStruct*)@<节点句柄>)
    }

    方法 树结构_取子节点 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 子节点索引 <类型 = 整数>
    {
        @ (@dt<变整数>)TreeStruct_GetChild( (CTreeStruct*)@<节点句柄> ,@<子节点索引>)
    }

    方法 树结构_插入子节点 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 插入位置 <类型 = 整数>
    参数 新节点内容 <类型 = 文本型 @默认值 = "">
    {
        @ (@dt<变整数>)TreeStruct_InsertChild(  (CTreeStruct*)@<节点句柄> ,@<插入位置> ,@<新节点内容>)
    }

    方法 树结构_添加子节点 <公开 静态 类型 = 变整数 返回值注释 = "返回新增加的子节点句柄" @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 子节点内容 <类型 = 文本型>
    {
        @ (@dt<变整数>)TreeStruct_AddChildText( (CTreeStruct*)@<节点句柄> ,@<子节点内容>)
    }

    方法 树结构_删除子节点 <公开 静态 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 子节点索引 <类型 = 整数 注释 = "从0开始">
    {
        @ TreeStruct_DeleteChild((CTreeStruct*)@<节点句柄> ,@<子节点索引>)
    }

    方法 树结构_取根节点 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)TreeStruct_GetRoot((CTreeStruct*)@<节点句柄>)
    }

    方法 树结构_取父节点 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)TreeStruct_GetParent((CTreeStruct*)@<节点句柄>)
    }

    方法 树结构_到字节集 <公开 静态 类型 = 字节集类 @禁止流程检查 = 真>
    参数 节点句柄 <类型 = 变整数>
    {
        @ std::string data = TreeStruct_ToBin( (CTreeStruct*)@<节点句柄> );
        @ CVolMem mem(data.data(),data.size());
        @ return mem;
    }

    方法 树结构_从字节集载入 <公开 静态>
    参数 节点句柄 <类型 = 变整数>
    参数 数据 <类型 = 字节集类>
    {
        TreeStruct_FromBin (节点句柄, 数据.取字节集指针 (), 数据.取字节集长度 ())

    }

    方法 TreeStruct_FromBin <静态 折叠 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @ TreeStruct_FromBin( (CTreeStruct*)@<节点句柄>,(void*)@<数据指针> ,@<数据大小> )

    }

    方法 树结构_置附加数据1 <公开 静态 折叠 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 附加数据 <类型 = 变整数>
    {
        @ TreeStruct_SetUserData1( (CTreeStruct*)@<节点句柄> ,(void*)@<附加数据>);
    }

    方法 树结构_置附加数据2 <公开 静态 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    参数 附加数据 <类型 = 变整数>
    {
        @ TreeStruct_SetUserData2( (CTreeStruct*)@<节点句柄> ,(void*)@<附加数据>);
    }

    方法 树结构_取附加数据1 <公开 静态 类型 = 变整数类 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)TreeStruct_GetUserData1( (CTreeStruct*)@<节点句柄>)
    }

    方法 树结构_取附加数据2 <公开 静态 类型 = 变整数 @嵌入式方法 = "">
    参数 节点句柄 <类型 = 变整数>
    {
        @ (@dt<变整数>)TreeStruct_GetUserData2( (CTreeStruct*)@<节点句柄>)


    }

    方法 树结构_从键值表载入 <公开 静态 类型 = 变整数 折叠>
    参数 kv <类型 = 键值表>
    {
        变量 根节点 <类型 = 变整数>
        根节点 = 树结构_创建 ()
        树结构_键值表到树结构 (根节点, kv)
        返回 (根节点)

    }

    方法 树结构_键值表到树结构 <静态 折叠>
    参数 节点句柄 <类型 = 变整数>
    参数 kv <类型 = 键值表>
    {
        树结构_置文本 (节点句柄, kv.取文本 ("v"))
        变量 list <类型 = 键值列表>
        kv.取列表 ("c", list)
        树结构_键值列表到树结构 (节点句柄, list)



    }

    方法 树结构_键值列表到树结构 <静态 折叠>
    参数 节点句柄 <类型 = 变整数>
    参数 list <类型 = 键值列表>
    {
        变量 i <类型 = 整数>
        循环 (0, list.取数量 (), i)
        {
            变量 kv <类型 = 键值表>
            变量 子节点句柄 <类型 = 变整数>
            list.取键值表 (i + 1, kv)
            子节点句柄 = 树结构_添加子节点 (节点句柄, "")
            树结构_键值表到树结构 (子节点句柄, kv)

        }

    }

    方法 树结构_到键值表 <公开 静态 折叠>
    参数 节点句柄 <类型 = 变整数>
    参数 kv <类型 = 键值表>
    {
        变量 list <类型 = 键值列表>
        kv.置文本 ("v", 树结构_取文本 (节点句柄))
        树结构_到键值列表 (节点句柄, list)
        如果 (list.取数量 () > 0)
        {
            kv.置列表 ("c", list)
        }

    }

    方法 树结构_到键值列表 <静态 折叠>
    参数 节点句柄 <类型 = 变整数>
    参数 list <类型 = 键值列表>
    {
        变量 i <类型 = 整数>
        循环 (0, 树结构_取子节点数量 (节点句柄), i)
        {
            变量 kv <类型 = 键值表>
            变量 子节点句柄 <类型 = 变整数>
            子节点句柄 = 树结构_取子节点 (节点句柄, i)
            如果 (子节点句柄 != 0)
            {
                树结构_到键值表 (子节点句柄, kv)
                list.添加键值表 (kv)
            }

        }




    }

    方法 打印节点 <静态>
    参数 节点句柄 <类型 = 变整数>
    参数 缩进数 <类型 = 整数>
    {
        变量 i <类型 = 整数>
        变量 空格文本 <类型 = 文本型>
        循环 (0, 缩进数, i)
        {
            空格文本 = 空格文本 + " "

        }
        空格文本 = 空格文本 + 树结构_取文本 (节点句柄)
        调试输出 (空格文本)


    }

    方法 树结构_打印输出 <公开 静态>
    参数 节点句柄 <类型 = 变整数>
    参数 缩进数 <类型 = 整数>
    {

        变量 i <类型 = 整数>
        变量 子节点句柄 <类型 = 变整数>
        循环 (0, 树结构_取子节点数量 (节点句柄), i)
        {
            子节点句柄 = 树结构_取子节点 (节点句柄, i)
            打印节点 (子节点句柄, 缩进数)

            如果 (树结构_取子节点数量 (子节点句柄) != 0)
            {
                树结构_打印输出 (子节点句柄, 缩进数 + 1)
            }


        }


    }

    #
    #
}
