类 线性布局器基本类
{
    变量 成员_控件数组 <类型 = 窗口组件数组>

    方法 添加控件 <公开 类型 = 整数 "">
    参数 控件类型 <类型 = 窗口组件>
    {
        返回 (成员_控件数组.加入成员 (控件类型))
    }
}

类 布局器_网格类 <公开 基础类 = 线性布局器基本类>
{
    方法 _到对齐方式 <类型 = 网格布局对齐方式类 @嵌入式方法 = "">
    参数 对齐方式指针 <类型 = 变整数>
    {
        @ *((@dt<网格布局对齐方式类>*)@<对齐方式指针>)
    }

    方法 _创建对象 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 数据类型 <@需求类型 = 数据类型 @匹配类型 = 所有类型>
    {
        @ (INT_P) new @<数据类型>
    }

    方法 _销毁对象 <折叠 @嵌入式方法 = "">
    参数 对象指针 <类型 = 变整数>
    {
        @ delete ( (@dt<网格布局对齐方式类>*) @<对象指针>)
    }

    方法 _创建布局方式类 <类型 = 变整数>
    参数 对齐方式常量 <类型 = 整数>
    {
        如果 (对齐方式常量 == 0)
        {
            返回 (_创建对象 (网格布局对齐方式_左上角))
        }
        否则 (对齐方式常量 == 1)
        {
            返回 (_创建对象 (网格布局对齐方式_右上角))
        }
        否则 (对齐方式常量 == 2)
        {
            返回 (_创建对象 (网格布局对齐方式_左下角))
        }
        否则 (对齐方式常量 == 3)
        {
            返回 (_创建对象 (网格布局对齐方式_右下角))
        }
        否则 (对齐方式常量 == 4)
        {
            返回 (_创建对象 (网格布局对齐方式_左对齐垂直居中))
        }
        否则 (对齐方式常量 == 5)
        {
            返回 (_创建对象 (网格布局对齐方式_右对齐垂直居中))
        }
        否则 (对齐方式常量 == 6)
        {
            返回 (_创建对象 (网格布局对齐方式_顶对齐水平居中))
        }
        否则 (对齐方式常量 == 7)
        {
            返回 (_创建对象 (网格布局对齐方式_底对齐水平居中))
        }
        否则 (对齐方式常量 == 8)
        {
            返回 (_创建对象 (网格布局对齐方式_水平居中垂直居中))
        }
        否则 (对齐方式常量 == 9)
        {
            返回 (_创建对象 (网格布局对齐方式_高度不变_宽度填充单元格_上对齐))
        }
        否则 (对齐方式常量 == 10)
        {
            返回 (_创建对象 (网格布局对齐方式_高度不变_宽度填充单元格_垂直居中))
        }
        否则 (对齐方式常量 == 11)
        {
            返回 (_创建对象 (网格布局对齐方式_高度不变_宽度填充单元格_下对齐))
        }
        否则 (对齐方式常量 == 12)
        {
            返回 (_创建对象 (网格布局对齐方式_宽度不变_高度填充单元格_左对齐))
        }
        否则 (对齐方式常量 == 13)
        {
            返回 (_创建对象 (网格布局对齐方式_宽度不变_高度填充单元格_水平居中))
        }
        否则 (对齐方式常量 == 14)
        {
            返回 (_创建对象 (网格布局对齐方式_宽度不变_高度填充单元格_右对齐))
        }
        否则 (对齐方式常量 == 15)
        {
            返回 (_创建对象 (网格布局对齐方式_宽高填充单元格))
        }


        返回 (0)
    }

    方法 取列最大宽度 <公开 类型 = 整数 折叠>
    参数 列数 <类型 = 整数>
    参数 列索引 <类型 = 整数>
    {
        变量 计数器 <类型 = 整数>
        变量 列计次 <类型 = 整数>
        变量 列最大宽度 <类型 = 整数>
        判断循环 (计数器 < 成员_控件数组.取成员数 ())
        {
            循环 (0, 列数, 列计次)
            {
                如果 (列计次 == 列索引)
                {
                    如果 (成员_控件数组.取成员 (计数器 + 列计次).宽度 > 列最大宽度)
                    {
                        列最大宽度 = 成员_控件数组.取成员 (计数器 + 列计次).宽度
                    }
                }
            }
            计数器 = 计数器 + 列数
        }
        返回 (列最大宽度)


    }

    方法 调整位置_多行_列单元格等宽_行单元格等高 <公开 注释 = "计算方法：" 注释 = "统计所有行的第0列 第1列 一直到 第n列" 注释 = "是根据所有行的列最大宽度来对齐的">
    参数 列数 <类型 = 整数>
    参数 布局横坐标 <类型 = 整数>
    参数 布局纵坐标 <类型 = 整数>
    参数 行间隔 <类型 = 整数 @默认值 = 2>
    参数 列间隔 <类型 = 整数 @默认值 = 2>
    参数 对齐方式常量 <类型 = 整数 注释 = "0  左上角" 注释 = "1  右上角" 注释 = "2  左下脚" 注释 = "3  右下角" 注释 = "4  左对齐垂直居中" 注释 = "5  右对齐垂直居中"
            注释 = "6  顶对齐水平居中" 注释 = "7  底对齐水平居中" 注释 = "8  水平垂直居中" 注释 = "9  高度不变_宽度填充单元格_上对齐" 注释 = "10 高度不变_宽度填充单元格_垂直居中"
            注释 = "11 高度不变_宽度填充单元格_下对齐" 注释 = "12 宽度不变_高度填充单元格_左对齐" 注释 = "13 宽度不变_高度填充单元格_水平居中" 注释 = "14 宽度不变_高度填充单元格_右对齐"
            注释 = "15 宽高填充单元格" @默认值 = 8>
    {
        如果 (成员_控件数组.取成员数 () < 1)
        {
            返回
        }

        变量 计数器 <类型 = 整数>
        变量 列计次 <类型 = 整数>
        变量 控件横坐标 <类型 = 整数>
        变量 控件纵坐标 <类型 = 整数>
        变量 列最大宽度数组 <类型 = 整数数组类>
        变量 对齐方式指针 <类型 = 变整数>
        控件横坐标 = 布局横坐标
        控件纵坐标 = 布局纵坐标
        循环 (0, 列数, 列计次)
        {
            列最大宽度数组.加入成员 (取列最大宽度 (列数, 列计次))
        }
        对齐方式指针 = _创建布局方式类 (对齐方式常量)
        判断循环 (计数器 < 成员_控件数组.取成员数 ())
        {

            变量 单元格宽度 <类型 = 整数>
            变量 单元格高度 <类型 = 整数>
            循环 (0, 列数, 列计次)  // 统计行的最大高度
            {
                如果 (成员_控件数组.取成员 (计数器 + 列计次).高度 > 单元格高度)
                {
                    单元格高度 = 成员_控件数组.取成员 (计数器 + 列计次).高度
                }
            }

            循环 (0, 列数, 列计次)
            {
                单元格宽度 = 列最大宽度数组.取成员 (列计次)
                变量 控件 <类型 = 窗口组件>
                变量 控件位置 <类型 = 矩形类>
                控件 = 成员_控件数组.取成员 (计数器 + 列计次)
                _到对齐方式 (对齐方式指针).计算 (单元格宽度, 单元格高度, 控件.宽度, 控件.高度)
                控件位置.左边 = 控件横坐标 + _到对齐方式 (对齐方式指针).取横坐标 ()
                控件位置.顶边 = 控件纵坐标 + _到对齐方式 (对齐方式指针).取纵坐标 ()
                控件位置.宽度 = _到对齐方式 (对齐方式指针).取宽度 ()
                控件位置.高度 = _到对齐方式 (对齐方式指针).取高度 ()
                控件.组件位置 = 控件位置
                控件横坐标 = 控件横坐标 + 列间隔 + 单元格宽度
            }
            控件横坐标 = 布局横坐标
            控件纵坐标 = 控件纵坐标 + 行间隔 + 单元格高度
            计数器 = 计数器 + 列数

        }

        _销毁对象 (对齐方式指针)

    }

    方法 "//调整位置_单行_所有列对齐" <公开 注释 = "只会统计第一行的所有控件的最大宽度和高度来对齐的" 折叠>
    参数 列数 <类型 = 整数>
    参数 布局横坐标 <类型 = 整数>
    参数 布局纵坐标 <类型 = 整数>
    参数 行间隔 <类型 = 整数 @默认值 = 2>
    参数 列间隔 <类型 = 整数 @默认值 = 2>
    {
        变量 计数器 <类型 = 整数>
        变量 列计次 <类型 = 整数>
        变量 控件横坐标 <类型 = 整数>
        变量 控件纵坐标 <类型 = 整数>
        如果 (成员_控件数组.取成员数 () < 1)
        {
            返回
        }
        控件横坐标 = 布局横坐标
        控件纵坐标 = 布局纵坐标

        判断循环 (计数器 < 成员_控件数组.取成员数 ())
        {

            变量 单元格宽度 <类型 = 整数>
            变量 单元格高度 <类型 = 整数>
            循环 (0, 列数, 列计次)
            {
                如果 (成员_控件数组.取成员 (计数器 + 列计次).高度 > 单元格高度)
                {
                    单元格高度 = 成员_控件数组.取成员 (计数器 + 列计次).高度
                }

                如果 (成员_控件数组.取成员 (计数器 + 列计次).宽度 > 单元格宽度)
                {
                    单元格宽度 = 成员_控件数组.取成员 (计数器 + 列计次).宽度
                }
            }

            循环 (0, 列数, 列计次)
            {
                变量 控件 <类型 = 窗口组件>
                变量 控件位置 <类型 = 矩形类>
                控件 = 成员_控件数组.取成员 (计数器 + 列计次)
                控件位置.左边 = 控件横坐标
                控件位置.顶边 = 控件纵坐标
                控件位置.宽度 = 控件.宽度
                控件位置.高度 = 控件.高度
                控件.组件位置 = 控件位置
                控件横坐标 = 控件横坐标 + 列间隔 + 单元格宽度

            }

            控件横坐标 = 布局横坐标
            控件纵坐标 = 控件纵坐标 + 行间隔 + 单元格高度
            计数器 = 计数器 + 列数

        }



    }

    方法 调整位置_单行_单元格等宽高 <公开 注释 = "只有一行的情况下，以此行中最大的高度">
    参数 布局横坐标 <类型 = 整数>
    参数 布局纵坐标 <类型 = 整数>
    参数 列间隔 <类型 = 整数 @默认值 = 2>
    参数 对齐方式常量 <类型 = 整数 注释 = "0  左上角" 注释 = "1  右上角" 注释 = "2  左下脚" 注释 = "3  右下角" 注释 = "4  左对齐垂直居中" 注释 = "5  右对齐垂直居中"
            注释 = "6  顶对齐水平居中" 注释 = "7  底对齐水平居中" 注释 = "8  水平垂直居中" 注释 = "9  高度不变_宽度填充单元格_上对齐" 注释 = "10 高度不变_宽度填充单元格_垂直居中"
            注释 = "11 高度不变_宽度填充单元格_下对齐" 注释 = "12 宽度不变_高度填充单元格_左对齐" 注释 = "13 宽度不变_高度填充单元格_水平居中" 注释 = "14 宽度不变_高度填充单元格_右对齐"
            注释 = "15 宽高填充单元格" @默认值 = 8>
    {
        如果 (成员_控件数组.取成员数 () < 1)
        {
            返回
        }

        变量 计数器 <类型 = 整数>
        变量 单元格宽度 <类型 = 整数>
        变量 单元格高度 <类型 = 整数>
        循环 (0, 成员_控件数组.取成员数 (), 计数器)
        {
            如果 (成员_控件数组.取成员 (计数器).高度 > 单元格高度)
            {
                单元格高度 = 成员_控件数组.取成员 (计数器).高度
            }

            如果 (成员_控件数组.取成员 (计数器).宽度 > 单元格宽度)
            {
                单元格宽度 = 成员_控件数组.取成员 (计数器).宽度
            }
        }


        变量 控件横坐标 <类型 = 整数>
        变量 控件纵坐标 <类型 = 整数>
        变量 对齐方式指针 <类型 = 变整数>
        控件横坐标 = 布局横坐标
        控件纵坐标 = 布局纵坐标
        计数器 = 0
        对齐方式指针 = _创建布局方式类 (对齐方式常量)

        判断循环 (计数器 < 成员_控件数组.取成员数 ())
        {

            变量 控件 <类型 = 窗口组件>
            变量 控件位置 <类型 = 矩形类>
            控件 = 成员_控件数组.取成员 (计数器)
            _到对齐方式 (对齐方式指针).计算 (单元格宽度, 单元格高度, 控件.宽度, 控件.高度)
            控件位置.左边 = 控件横坐标 + _到对齐方式 (对齐方式指针).取横坐标 ()
            控件位置.顶边 = 控件纵坐标 + _到对齐方式 (对齐方式指针).取纵坐标 ()
            控件位置.宽度 = _到对齐方式 (对齐方式指针).取宽度 ()
            控件位置.高度 = _到对齐方式 (对齐方式指针).取高度 ()
            控件.组件位置 = 控件位置
            控件横坐标 = 控件横坐标 + 列间隔 + 单元格宽度
            计数器 = 计数器 + 1

        }

        _销毁对象 (对齐方式指针)

    }

    方法 调整位置_多行_列单元格等分_行单元格等分 <公开 注释 = "用对齐方式来对齐" 折叠>
    参数 列数 <类型 = 整数>
    参数 布局横坐标 <类型 = 整数>
    参数 布局纵坐标 <类型 = 整数>
    参数 布局宽度 <类型 = 整数>
    参数 布局高度 <类型 = 整数>
    参数 行间隔 <类型 = 整数 @默认值 = 2>
    参数 列间隔 <类型 = 整数 @默认值 = 2>
    参数 对齐方式常量 <类型 = 整数 注释 = "0  左上角" 注释 = "1  右上角" 注释 = "2  左下脚" 注释 = "3  右下角" 注释 = "4  左对齐垂直居中" 注释 = "5  右对齐垂直居中"
            注释 = "6  顶对齐水平居中" 注释 = "7  底对齐水平居中" 注释 = "8  水平垂直居中" 注释 = "9  高度不变_宽度填充单元格_上对齐" 注释 = "10 高度不变_宽度填充单元格_垂直居中"
            注释 = "11 高度不变_宽度填充单元格_下对齐" 注释 = "12 宽度不变_高度填充单元格_左对齐" 注释 = "13 宽度不变_高度填充单元格_水平居中" 注释 = "14 宽度不变_高度填充单元格_右对齐"
            注释 = "15 宽高填充单元格" @默认值 = 8>
    {
        如果 (成员_控件数组.取成员数 () < 1)
        {
            返回
        }
        变量 计数器 <类型 = 整数>
        变量 列计次 <类型 = 整数>
        变量 控件横坐标 <类型 = 整数>
        变量 控件纵坐标 <类型 = 整数>
        变量 对齐方式指针 <类型 = 变整数>
        控件横坐标 = 布局横坐标
        控件纵坐标 = 布局纵坐标
        对齐方式指针 = _创建布局方式类 (对齐方式常量)

        变量 行数量 <类型 = 整数>
        行数量 = 成员_控件数组.取成员数 () / 列数
        如果 (成员_控件数组.取成员数 () % 列数 != 0)
        {
            行数量 = 行数量 + 1
        }


        变量 单元格宽度 <类型 = 整数>
        变量 单元格高度 <类型 = 整数>
        单元格宽度 = 布局宽度 / 列数
        单元格高度 = 布局高度 / 行数量

        判断循环 (计数器 < 成员_控件数组.取成员数 ())
        {

            循环 (0, 列数, 列计次)
            {
                变量 控件 <类型 = 窗口组件>
                变量 控件位置 <类型 = 矩形类>
                控件 = 成员_控件数组.取成员 (计数器 + 列计次)
                _到对齐方式 (对齐方式指针).计算 (单元格宽度, 单元格高度, 控件.宽度, 控件.高度)
                控件位置.左边 = 控件横坐标 + _到对齐方式 (对齐方式指针).取横坐标 ()
                控件位置.顶边 = 控件纵坐标 + _到对齐方式 (对齐方式指针).取纵坐标 ()
                控件位置.宽度 = _到对齐方式 (对齐方式指针).取宽度 ()
                控件位置.高度 = _到对齐方式 (对齐方式指针).取高度 ()
                控件.组件位置 = 控件位置

                控件横坐标 = 控件横坐标 + 列间隔 + 单元格宽度


            }

            控件横坐标 = 布局横坐标
            控件纵坐标 = 控件纵坐标 + 行间隔 + 单元格高度
            计数器 = 计数器 + 列数

        }

        _销毁对象 (对齐方式指针)



    }

    方法 取成员数 <公开 类型 = 整数>
    {
        返回 (成员_控件数组.取成员数 ())
    }

