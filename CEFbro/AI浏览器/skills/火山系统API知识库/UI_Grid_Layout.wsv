<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"界面.布局\"">

类 窗口组件数组 <公开 基础类 = 对象数组模板类 @模板实现类 = "窗口组件">

类 网格布局对齐方式类
{
    变量 成员_控件横坐标 <类型 = 整数>
    变量 成员_控件纵坐标 <类型 = 整数>
    变量 成员_控件宽度 <类型 = 整数>
    变量 成员_控件高度 <类型 = 整数>

    方法 取横坐标 <公开 类型 = 整数>
    {
        返回 (成员_控件横坐标)
    }

    方法 取纵坐标 <公开 类型 = 整数>
    {
        返回 (成员_控件纵坐标)
    }

    方法 取宽度 <公开 类型 = 整数>
    {
        返回 (成员_控件宽度)
    }

    方法 取高度 <公开 类型 = 整数>
    {
        返回 (成员_控件高度)
    }

    方法 计算 <公开 @虚拟方法 = 可覆盖>
    参数 单元格宽度 <类型 = 整数>
    参数 单元格高度 <类型 = 整数>
    参数 控件宽度 <类型 = 整数>
    参数 控件高度 <类型 = 整数>
    {

    }

    #
}

类 网格布局对齐方式_左上角 <基础类 = 网格布局对齐方式类>
{
    方法 计算 <公开 @虚拟方法 = 可覆盖>
    参数 单元格宽度 <类型 = 整数>
    参数 单元格高度 <类型 = 整数>
    参数 控件宽度 <类型 = 整数>
    参数 控件高度 <类型 = 整数>
    {
        成员_控件横坐标 = 0
        成员_控件纵坐标 = 0
        成员_控件宽度 = 控件宽度
        成员_控件高度 = 控件高度
    }
}

类 网格布局对齐方式_右上角 <基础类 = 网格布局对齐方式类>
{
    方法 计算 <公开 @虚拟方法 = 可覆盖>
    参数 单元格宽度 <类型 = 整数>
    参数 单元格高度 <类型 = 整数>
    参数 控件宽度 <类型 = 整数>
    参数 控件高度 <类型 = 整数>
    {
        成员_控件横坐标 = 单元格宽度 - 控件宽度
        成员_控件纵坐标 = 0

        成员_控件宽度 = 控件宽度
        成员_控件高度 = 控件高度

    }
}

