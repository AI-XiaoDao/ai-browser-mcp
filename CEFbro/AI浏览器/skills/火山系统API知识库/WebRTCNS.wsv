<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"开源库.音频降噪\"">

类 ______音频降噪 <公开 @全局类 = 真>
{
    方法 音频降噪_指针数据 <公开 静态 类型 = 整数 返回值注释 = "-1 表示失败 1表示成功" 折叠 折叠2 @嵌入式方法 = "" @视窗.外部头文件 = "WebRTCNS\\WebRTCNSTool.h"
            @视窗.外部库.win32 = "WebRTCNS\\WebRTCNSToolx86.lib" @视窗.附属文件.win32 = "WebRTCNS\\WebRTCNSToolx86.dll"
            @视窗.外部库.x64 = "WebRTCNS\\WebRTCNSToolx64.lib" @视窗.附属文件.x64 = "WebRTCNS\\WebRTCNSToolx64.dll">
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    参数 采样率 <类型 = 整数 注释 = "8000 16000 只能是这两个其中一个">
    参数 声道数 <类型 = 整数 注释 = "1 2">
    参数 降噪级别 <类型 = 整数 注释 = "可选值 0 1 2 3" @默认值 = 0>
    {
        @ WebRTCNSTool_nsProcess((void*)@<缓冲区指针>,@<采样率>,@<缓冲区大小>/2,@<声道数>,@<降噪级别>)
    }

    方法 音频降噪2_指针数据 <公开 静态 类型 = 整数 注释 = "只能处理16000 1声道的" 返回值注释 = "-1 表示失败 1表示成功" 折叠 折叠2 @嵌入式方法 = ""
            @视窗.外部头文件 = "WebRTCNS\\WebRTC_NS_CPP_Tool.h" @视窗.外部库.win32 = "WebRTCNS\\WebRTC_NS_CPP_Toolx86.lib"
            @视窗.附属文件.win32 = "WebRTCNS\\WebRTC_NS_CPP_Toolx86.dll" @视窗.外部库.x64 = "WebRTCNS\\WebRTC_NS_CPP_Toolx64.lib"
            @视窗.附属文件.x64 = "WebRTCNS\\WebRTC_NS_CPP_Toolx64.dll">
    参数 缓冲区指针 <类型 = 变整数>
    参数 缓冲区大小 <类型 = 整数>
    参数 采样率 <类型 = 整数 注释 = "16000">
    参数 声道数 <类型 = 整数 注释 = "1">
    参数 降噪级别 <类型 = 整数 注释 = "可选值 0 1 2 3" @默认值 = 0>
    {
        @ WebRTCNSTool_nsProc((void*)@<缓冲区指针>,@<缓冲区大小>/2,@<采样率>,@<声道数>,@<降噪级别>)


    }

    #
}
