    }

    方法 HP_HTTP服务器_客户进入 <接收事件 类型 = 整数 注释 = "  当客户连接到服务器后,将会触发本事件,请注意,本事件下的连接并非是正式连接,"
            注释 = "只有该连接通过\"完成握手\"事件,才可以与服务器建立正式连接,本事件返回值拥有具体意义,请参考返回值说明." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 将触发\"完成握手\"事件."
            返回值注释 = "  1 = 忽略本次操作, 将触发\"完成握手\"事件." 返回值注释 = "  2 = 本次操作错误, 服务器主动与当前连接ID断开连接." 折叠 折叠2>
    参数 来源对象 <类型 = HP_HTTP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        返回 (Websocket客户进入 (连接ID))
    }

    方法 HP_HTTP服务器_客户离开 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_HTTP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        返回 (Websocket客户离开 (连接ID))
    }

    方法 HP_HTTP服务器_协议升级 <接收事件 类型 = 整数 注释 = "" 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 协议类型 <类型 = HPHTTP协议升级类型>
    {
        变量 请求体 <类型 = 字节集类>
        变量 WS升级头 <类型 = HP请求头数组类>
        如果 (协议类型 == HPHTTP协议升级类型.HTTP隧道)
        {
            来源对象.回复请求 (连接ID, 200, "Connection Established", WS升级头, 请求体)
        }
        否则 (协议类型 == HPHTTP协议升级类型.WebSocket)
        {
            变量 Accept <类型 = 文本型>
            变量 临时Key <类型 = 文本型>
            临时Key = 来源对象.取请求头值 (连接ID, "Sec-WebSocket-Key") + 验证
            Accept = 字节集到BASE64文本 (十六进制文本到字节集 (加解密类.取数据SHA1 (文本到UTF8 (临时Key, 假))))
            如果 (文本是否为空 (Accept))
            {
                返回 (-1)  // 握手失败
            }
            变量 头 <类型 = HP请求头类>
            头.名称 = "Upgrade"
            头.值 = "websocket"
            WS升级头.加入成员 (头)
            头.名称 = "Connection"
            头.值 = "Upgrade"
            WS升级头.加入成员 (头)
            头.名称 = "Sec-WebSocket-Accept"
            头.值 = Accept
            WS升级头.加入成员 (头)
            如果 (来源对象.取请求头值 (连接ID, "Sec-WebSocket-Protocol") != "")
            {
                头.名称 = "Sec-WebSocket-Protocol"
                头.值 = 来源对象.取请求头值 (连接ID, "Sec-WebSocket-Protocol")
                WS升级头.加入成员 (头)

            }

            如果 (来源对象.回复请求 (连接ID, 101, "", WS升级头, 请求体))
            {
                返回 (0)
            }
            否则
            {
                返回 (-1)  // 握手失败
            }
        }
        返回 (0)
    }
}
