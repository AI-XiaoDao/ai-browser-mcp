<火山程序 类型 = "通常" 版本 = 1 />

包 FOFWEBSCOKET.com

类 FOFWebsocket客户端 <公开 折叠>
{
    变量 客户端 <公开 类型 = HP_HTTP客户端 折叠>
    变量 请求路径 <类型 = 文本型>
    变量 服务器地址 <类型 = 文本型>
    变量 端口号 <类型 = 短整数>
    变量 附加协议头 <类型 = 文本数组类>

    方法 连接Websocket <公开 类型 = 逻辑型 折叠>
    参数 地址 <类型 = 文本型 注释 = "例如:ws://localhost:9010/ajaxchattest">
    参数 附加头 <类型 = 文本数组类 注释 = "提供连接所欲使用的附加请求头,一个成员表示一组,例如:\"Origin:http://0.0.0.0\"." @默认值 = 空对象>
    {
        端口号 = 内部_解析地址 (地址, 服务器地址, 请求路径)
        如果 (端口号 < 0 || 文本是否为空 (服务器地址))
        {
            返回 (假)
        }
        附加协议头 = 附加头
        返回 (客户端.启动 (服务器地址, 端口号, 假))
    }

    方法 发送字节集 <公开 类型 = 逻辑型 返回值注释 = "返回发送结果." 折叠>
    参数 字节集数据 <类型 = 字节集类 注释 = "提供所欲发送的数据.">
    {
        变量 掩码 <类型 = 字节集类>
        掩码.添加值到字节集 (0x1)
        掩码.添加值到字节集 (0x2)
        掩码.添加值到字节集 (0x3)
        掩码.添加值到字节集 (0x4)
        返回 (客户端.发WebSocket消息 (真, 0, 2, 掩码, 字节集数据, 字节集数据.取字节集长度 (), 0))
    }

    方法 关闭Websocket <公开 类型 = 逻辑型 注释 = "断开可以使用连接命令重新链接" 折叠>
    {
        返回 (客户端.停止 ())
    }

    方法 Websocket握手处理 <类型 = 整数 折叠>
    {
        变量 WS升级头 <类型 = HP请求头数组类>
        变量 头 <类型 = HP请求头类>
        头.名称 = "Upgrade"
        头.值 = "websocket"
        WS升级头.加入成员 (头)
        头.名称 = "Connection"
        头.值 = "Upgrade"
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Key"
        头.值 = "MTIzNDU2Nzg5MDExMTExMQ=="
        WS升级头.加入成员 (头)
        头.名称 = "Origin"
        头.值 = "http://" + 服务器地址
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Version"
        头.值 = "13"
        WS升级头.加入成员 (头)
        如果 (是否为空对象 (附加协议头) == 假 && 附加协议头.取成员数 () > 0)
        {
            变量 i <类型 = 整数>
            循环 (, 附加协议头.取成员数 (), i)
            {
                变量 起始位置 <类型 = 整数>
                起始位置 = 寻找文本 (附加协议头.取成员 (i), ":")
                头.名称 = 取文本左边 (附加协议头.取成员 (i), 起始位置)
                头.值 = 取文本右边 (附加协议头.取成员 (i), 取文本长度 (附加协议头.取成员 (i)) - 起始位置 - 1)
                WS升级头.加入成员 (头)
            }
        }
        变量 握手结果 <类型 = 逻辑型>
        握手结果 = 客户端.发送请求 ("GET", 请求路径, WS升级头)
        返回 (选择 (握手结果, 0, 2))
    }

    方法 Websocket收到数据 <公开 定义事件 类型 = 整数 折叠>
    参数 数据 <类型 = 字节集类>

    方法 Websocket连接断开 <公开 定义事件 类型 = 整数>

    方法 Websocket连接完成 <公开 定义事件 类型 = 整数 折叠>
    {
        // ====

    }

    方法 内部_解析地址 <类型 = 短整数 返回值注释 = "正确返回端口号,必定>0,否则返回-1." 折叠>
    参数 地址 <类型 = 文本型>
    参数 服务器 <类型 = 文本型>
    参数 路径 <类型 = 文本型>
    {
        变量 端口 <类型 = 短整数 值 = -1>
        变量 协议名 <类型 = 文本型>
        如果 (是否以文本开头 (地址, "ws://"))
        {
            协议名 = "ws://"
        }
        否则 (是否以文本开头 (地址, "wss://"))
        {
            协议名 = "wss://"
        }
        否则
        {
            返回 (端口)
        }
        变量 路径符位置 <类型 = 整数>
        变量 服务器和端口 <类型 = 文本型>
        变量 端口位置 <类型 = 整数>
        路径符位置 = 寻找文本 (地址, "/", 取文本长度 (协议名))
        如果 (路径符位置 != -1)
        {
            服务器和端口 = 取文本中间 (地址, 取文本长度 (协议名), 路径符位置 - 取文本长度 (协议名))
            路径 = 取文本右边 (地址, 取文本长度 (地址) - 路径符位置 - 1)
        }
        否则
        {
            服务器和端口 = 取文本右边 (地址, 取文本长度 (地址) - 取文本长度 (协议名))
        }
        端口位置 = 寻找文本 (服务器和端口, ":")
        如果 (端口位置 != -1)
        {
            服务器 = 取文本左边 (服务器和端口, 端口位置)
            端口 = (短整数)文本到整数 (取文本右边 (服务器和端口, 取文本长度 (服务器和端口) - 端口位置 - 1))
        }
        否则
        {
            服务器 = 服务器和端口
            端口 = 80

        }

        返回 (端口)
    }

    方法 HP_HTTP客户端_开始握手 <接收事件 类型 = 整数 注释 = "当前客户端将与服务端握手时将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接." 折叠>
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        返回 (Websocket握手处理 ())
    }

    方法 HP_HTTP客户端_协议升级 <接收事件 类型 = 整数 注释 = "  当客户端主动升级协议后,将会触发本事件." 注释 = "  当客户端从HTTP1.0协议升级为HTTP1.1协议后,服务器将通过本事件通知" 注释 = "用户."
            注释 = "  本事件返回值拥有具体意义,请您参考如下返回值:" 注释 = "    0  - 本次操作成功,默认返回值." 注释 = "    -1 - 本次操作失败,主动与客户断开连接."
            注释 = "  请注意:如果本事件返回-1,将会触发事件\"解析错误\",您可以忽略本次\"解析" 注释 = "错误\"事件." 返回值注释 = "返回-1则会关闭该连接." 折叠 折叠2>
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 协议类型 <类型 = HPHTTP协议升级类型>
    {
        如果 (协议类型 == HPHTTP协议升级类型.WebSocket)
        {
            Websocket连接完成 ()
        }
        返回 (0)
    }

    方法 HP_HTTP客户端_收到WS数据体 <接收事件 类型 = 整数 注释 = "当接收到WebSocket数据包体时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接." 折叠>
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 数据 <类型 = 字节集类>
    参数 长度 <类型 = 整数>
    {
        返回 (Websocket收到数据 (数据))
    }

    方法 HP_HTTP客户端_通信发生错误 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件." 折叠>
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        Websocket连接断开 ()
        返回 (0)
    }
}

