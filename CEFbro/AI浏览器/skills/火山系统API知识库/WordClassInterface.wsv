    }

    方法 激活文档 <公开 注释 = "激活文档集合中的一个文档">
    参数 索引号 <类型 = 整数 注释 = "二选一,对象的索引号.从1开始,表示文档在文档集中的位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.索引号不为0时忽略该参数." @默认值 = "">
    {
        如果 (索引号 == 0)
        {
            Application对象.读无参数对象型属性 ("Documents", COM对象类).读对象型属性 ("Item", COM对象类, 名称).无参数及返回值方法 ("Activate")  // 从文档名激活
