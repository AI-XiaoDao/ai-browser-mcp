    常量 点划 <公开 值 = @wdUnderlineDotDash 注释 = "点划相间线">
    常量 点点划 <公开 值 = @wdUnderlineDotDotDash 注释 = "点-点-划线相间模式">
    常量 单波浪 <公开 值 = @wdUnderlineWavy 注释 = "单波浪线">
    常量 粗点 <公开 值 = @wdUnderlineDottedHeavy 注释 = "粗点">
    常量 粗划 <公开 值 = @wdUnderlineDashHeavy 注释 = "粗划线">
    常量 粗点划 <公开 值 = @wdUnderlineDotDashHeavy 注释 = "粗点划相间线">
    常量 粗点点划 <公开 值 = @wdUnderlineDotDotDashHeavy 注释 = "粗点-点-划线相间模式">
    常量 粗波浪 <公开 值 = @wdUnderlineWavyHeavy 注释 = "粗波浪线">
    常量 长 <公开 值 = @wdUnderlineDashLong 注释 = "长划线">
