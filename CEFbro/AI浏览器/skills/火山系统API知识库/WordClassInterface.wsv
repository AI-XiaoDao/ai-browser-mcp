    参数 方向 <类型 = 整数 注释 = "0 左边;1 上边;2 右边.">
    参数 所欲设置的值 <类型 = 整数 注释 = "装订线距离">
    {
        Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("GutterPos", 方向)  // 设置装订线方向
        Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("Gutter", 所欲设置的值)  // 设置方向装订线距离
    }

