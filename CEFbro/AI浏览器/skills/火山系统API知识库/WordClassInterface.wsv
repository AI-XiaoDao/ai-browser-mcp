    方法 运行宏 <公开 注释 = "运行Visual Basic 宏">
    参数 宏名 <类型 = 文本型 注释 = "宏的名称,参数可以是任意模板,模块和宏名的组合.">
    参数 文本数组参数 <类型 = 文本数组类 注释 = "二选一,宏参数值.最多可以给指定宏传递30个参数值." @默认值 = 空对象>
    参数 整数数组参数 <类型 = 整数数组类 注释 = "二选一,宏参数值.最多可以给指定宏传递30个参数值." @默认值 = 空对象>
    {
        变量 变体型数组 <类型 = COM变体型数组类>
        变量 参数数量 <类型 = 整数>
        如果 (文本数组参数.取成员数 () > 0)
        {
            文本数组参数.枚举循环 ()
            {
                如果 (文本数组参数.取枚举索引 () > 29)  // 最多30个参数
                {
                    跳出循环
                }
                变体型数组.加入并返回新成员 (COM变体型).赋值 (文本数组参数.取枚举值 (), )  // 加入新成员并对新成员赋值
            }
        }
        否则
        {
            整数数组参数.枚举循环 ()
            {
                如果 (整数数组参数.取枚举索引 () > 29)  // 最多30个参数
                {
                    跳出循环
                }
                变体型数组.加入并返回新成员 (COM变体型).赋值 (整数数组参数.取枚举值 (), )  // 加入新成员并对新成员赋值
            }
        }
        参数数量 = 变体型数组.取成员数 ()  // 取出有多少个参数
        计次循环 (30 - 参数数量)
        {
            变体型数组.加入新成员 (COM变体型)  // 没有的参数赋为空对象
        }
        Application对象.无返回值方法 ("Run", 宏名, 变体型数组.取成员 (0), 变体型数组.取成员 (1), 变体型数组.取成员 (2), 变体型数组.取成员 (3), 变体型数组.取成员 (4), 变体型数组.取成员 (5), 变体型数组.取成员 (6), 变体型数组.取成员 (7), 变体型数组.取成员 (8), 变体型数组.取成员 (9), 变体型数组.取成员 (10), 变体型数组.取成员 (11), 变体型数组.取成员 (12), 变体型数组.取成员 (13), 变体型数组.取成员 (14), 变体型数组.取成员 (15), 变体型数组.取成员 (16), 变体型数组.取成员 (17), 变体型数组.取成员 (18), 变体型数组.取成员 (19), 变体型数组.取成员 (20), 变体型数组.取成员 (21), 变体型数组.取成员 (22), 变体型数组.取成员 (23), 变体型数组.取成员 (24), 变体型数组.取成员 (25), 变体型数组.取成员 (26), 变体型数组.取成员 (27), 变体型数组.取成员 (28), 变体型数组.取成员 (29))
