<火山程序 类型 = "通常" 版本 = 1 />

包 火山.Word2021支持库 <@视窗.外部头文件 = "lib\\Wordconstant.h">

类 Word保存选项 <公开 注释 = "指定应该如何处理待定的更改" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 提示更改 <公开 值 = @wdPromptToSaveChanges 注释 = "提示用户保存待定更改" "">
    常量 自动保存 <公开 值 = @wdSaveChanges 注释 = "自动保存待定更改,而不提示用户" "">
    常量 不保存 <公开 值 = @wdDoNotSaveChanges 注释 = "不保存待定的更改">
}

类 Word保存格式 <公开 注释 = "指定文档格式.在保存文档时通常使用此枚举." @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 文档 <公开 值 = @wdWordDocument 注释 = "Word文档格式">
    常量 原格式 <公开 值 = @wdOriginalDocumentFormat 注释 = "原始文档格式">
    常量 提示选择 <公开 值 = @wdPromptUser 注释 = "提示用户选择文档格式">
}

类 Word警告 <公开 注释 = "指定运行宏时产生的一些警告和消息的处理方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 仅消息框 <公开 值 = @wdAlertsMessageBox 注释 = "仅显示消息框,同时捕获错误并将其返回宏.">
    常量 显示 <公开 值 = @wdAlertsAll 注释 = "显示所有的消息框和警告,并将错误返回宏.">
    常量 不显示 <公开 值 = @wdAlertsNone 注释 = "不显示任何警告或消息框.如果出现消息框,宏将选择默认值并继续运行.">
}

类 Word窗口状态 <公开 注释 = "指定窗口的状态" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 正常 <公开 值 = @wdWindowStateNormal 注释 = "正常">
    常量 最大化 <公开 值 = @wdWindowStateMaximize 注释 = "最大化">
    常量 最小化 <公开 值 = @wdWindowStateMinimize 注释 = "最小化">
}

类 Word创建类型 <公开 注释 = "指定要创建的新文档的类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 空白文档 <公开 值 = @wdNewBlankDocument 注释 = "空白文档">
    常量 网页 <公开 值 = @wdNewWebPage 注释 = "网页">
    常量 电子邮件 <公开 值 = @wdNewEmailMessage 注释 = "电子邮件">
    常量 框架 <公开 值 = @wdNewFrameset 注释 = "框架集">
    常量 XML文档 <公开 值 = @wdNewXMLDocument 注释 = "XML 文档">
}

类 Word格式化 <公开 注释 = "指定打开文档时要使用的格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 自动识别 <公开 值 = @wdOpenFormatAuto 注释 = "自动识别">
    常量 Word <公开 值 = @wdOpenFormatDocument 注释 = "Word格式">
    常量 Word模板 <公开 值 = @wdOpenFormatTemplate 注释 = "用作Word模板">
    常量 RTF <公开 值 = @wdOpenFormatRTF 注释 = "RTF格式">
    常量 TXT文本 <公开 值 = @wdOpenFormatText 注释 = "TXT文本文件">
    常量 Unicode <公开 值 = @wdOpenFormatUnicodeText 注释 = "Unicode文本格式">
    常量 兼容Word <公开 值 = @wdOpenFormatAllWord 注释 = "与Word早期版本向后兼容的Word格式">
    常量 HTML <公开 值 = @wdOpenFormatWebPages 注释 = "HTML格式">
    常量 XML <公开 值 = @wdOpenFormatXML 注释 = "XML格式">
    常量 XML文档 <公开 值 = @wdOpenFormatXMLDocument 注释 = "XML文档格式">
    常量 宏XML文档 <公开 值 = @wdOpenFormatXMLDocumentMacroEnabled 注释 = "启用了宏的XML文档格式">
    常量 XML模板 <公开 值 = @wdOpenFormatXMLTemplate 注释 = "XML模板格式">
    常量 宏XML模板 <公开 值 = @wdOpenFormatXMLTemplateMacroEnabled 注释 = "启用了宏的XML模板格式">
    常量 兼容模板 <公开 值 = @wdOpenFormatAllWordTemplates 注释 = "兼容早期版本Word模板格式">
    常量 系列化XML <公开 值 = @wdOpenFormatXMLDocumentSerialized 注释 = "打开XML文件格式保存为一个XML文件">
    常量 宏系列化XML <公开 值 = @wdOpenFormatXMLDocumentMacroEnabledSerialized 注释 = "打开XML文件格式启用了宏保存为一个XML文件">
}

类 Word编码 <公开 注释 = "指定用什么编码方式打开文件.以下罗列互联网编码格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 泰文 <公开 值 = @windows874 注释 = "泰文(Windows)">
    常量 日文 <公开 值 = @iso2022jp 注释 = "日文(Shift-JIS)">
    常量 简体中文 <公开 值 = @gb2312 注释 = "简体中文(GB2312)">
    常量 韩语 <公开 值 = @ksc56011987 注释 = "韩语韩语">
    常量 繁体中文 <公开 值 = @big5 注释 = "繁体中文(Big5)">
    常量 中欧 <公开 值 = @windows1250 注释 = "中欧字符(Windows)">
    常量 西里尔文 <公开 值 = @windows1251 注释 = "西里尔文(Windows)">
    常量 西欧 <公开 值 = @windows1252 注释 = "西欧(Windows)">
    常量 希腊 <公开 值 = @windows1253 注释 = "希腊语(Windows)">
    常量 土耳其 <公开 值 = @windows1254 注释 = "土耳其语(Windows)">
    常量 希伯来文 <公开 值 = @windows1255 注释 = "希伯来文(Windows)">
    常量 阿拉伯文 <公开 值 = @windows1256 注释 = "阿拉伯文(Windows)">
    常量 波罗的海 <公开 值 = @windows1257 注释 = "波罗的海字符(Windows)">
    常量 越南 <公开 值 = @windows1258 注释 = "越南语(Windows)">
    常量 ASCII <公开 值 = @ASCII 注释 = "ASCII编码">
    常量 拉丁文 <公开 值 = @iso88593 注释 = "拉丁文3(ISO)">
    常量 塞瑞利克 <公开 值 = @iso88595 注释 = "塞瑞利克字符(ISO)">
    常量 阿拉伯语 <公开 值 = @iso88596 注释 = "阿拉伯语(ISO)">
    常量 日语 <公开 值 = @eucjp 注释 = "日语(EUC)">
    常量 朝鲜 <公开 值 = @euckr 注释 = "朝鲜语(EUC)">
    常量 简体中文HZ <公开 值 = @hzgb2312 注释 = "简体中文(HZ)">
    常量 UTF7 <公开 值 = @word_utf7 注释 = "Unicode(UTF-7)">
    常量 UTF8 <公开 值 = @word_utf8 注释 = "Unicode(UTF-8)">
}

类 Word另存格式 <公开 注释 = "指定要在保存文档时使用的格式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 标准 <公开 值 = @wdFormatDocument 注释 = "Word97-2003文件格式">
    常量 模板 <公开 值 = @wdFormatTemplate 注释 = "Word模板格式">
    常量 文本 <公开 值 = @wdFormatText 注释 = "Microsoft Windows文本格式">
    常量 文本换行 <公开 值 = @wdFormatTextLineBreaks 注释 = "保留换行符的Windows文本格式">
    常量 DOS <公开 值 = @wdFormatDOSText 注释 = "MicrosoftDOS文本格式">
    常量 DOS换行 <公开 值 = @wdFormatDOSTextLineBreaks 注释 = "保留了换行符的Microsoft DOS文本">
    常量 RTF <公开 值 = @wdFormatRTF 注释 = "富文本格式(RTF)">
    常量 Unicode <公开 值 = @wdFormatUnicodeText 注释 = "Unicode文本格式">
    常量 HTML <公开 值 = @wdFormatHTML 注释 = "标准HTML格式">
    常量 Web <公开 值 = @wdFormatWebArchive 注释 = "网络存档格式">
    常量 HTML过滤 <公开 值 = @wdFormatFilteredHTML 注释 = "过滤的HTML格式">
    常量 XML <公开 值 = @wdFormatXML 注释 = "可扩展标记语言(XML)格式">
    常量 XML文档 <公开 值 = @wdFormatXMLDocument 注释 = "XML文档格式">
    常量 宏XML文档 <公开 值 = @wdFormatXMLDocumentMacroEnabled 注释 = "启用宏的XML文档格式">
    常量 XML模板 <公开 值 = @wdFormatXMLTemplate 注释 = "XML模板格式">
    常量 宏模板 <公开 值 = @wdFormatXMLTemplateMacroEnabled 注释 = "启用宏的XML模板格式">
    常量 默认 <公开 值 = @wdFormatDocumentDefault 注释 = "Word默认文档文件格式">
    常量 PDF <公开 值 = @wdFormatPDF 注释 = "PDF格式">
    常量 XPS <公开 值 = @wdFormatXPS 注释 = "XPS格式">
    常量 单个XML <公开 值 = @wdFormatFlatXML 注释 = "打开XML文件格式保存为单个XML文件">
    常量 宏平面XML <公开 值 = @wdFormatFlatXMLMacroEnabled 注释 = "打开启用宏的XML文件格式保存为单个XML文件">
    常量 平面模板 <公开 值 = @wdFormatFlatXMLTemplate 注释 = "打开XML模板格式保存为XML单个文件">
    常量 宏平面模板 <公开 值 = @wdFormatFlatXMLTemplateMacroEnabled 注释 = "打开启用宏的XML模板格式保存为单个XML文件">
    常量 OpenDocument文本 <公开 值 = @wdFormatOpenDocumentText
            注释 = "OpenDocument格式基于XML,用于保存字处理(Text),表格处理(SpreadSheet),图表(Graphics),简报文档(Presentation)等文档.">
    常量 OpenDocument文档 <公开 值 = @wdFormatStrictOpenXMLDocument 注释 = "严格的OpenXML文档格式">
}

类 Word路径类型 <公开 注释 = "为与Microsoft Word相关的文件指定默认文件夹" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 文档 <公开 值 = @wdDocumentsPath 注释 = "文档路径">
    常量 图片 <公开 值 = @wdPicturesPath 注释 = "图片路径">
    常量 模板 <公开 值 = @wdUserTemplatesPath 注释 = "用户模板路径">
    常量 工作组模板 <公开 值 = @wdWorkgroupTemplatesPath 注释 = "工作组模板路径">
    常量 用户选项 <公开 值 = @wdUserOptionsPath 注释 = "用户选项路径">
    常量 恢复文件 <公开 值 = @wdAutoRecoverPath 注释 = "自动恢复文件的路径">
    常量 工具 <公开 值 = @wdToolsPath 注释 = "工具路径">
    常量 教程 <公开 值 = @wdTutorialPath 注释 = "教程路径">
    常量 启动 <公开 值 = @wdStartupPath 注释 = "启动路径">
    常量 程序 <公开 值 = @wdProgramPath 注释 = "程序路径">
    常量 图形 <公开 值 = @wdGraphicsFiltersPath 注释 = "图形过滤器路径">
    常量 文字 <公开 值 = @wdTextConvertersPath 注释 = "文字转换器路径">
    常量 校对工具 <公开 值 = @wdProofingToolsPath 注释 = "校对工具路径">
    常量 临时文件 <公开 值 = @wdTempFilePath 注释 = "临时文件路径">
    常量 当前文件 <公开 值 = @wdCurrentFolderPath 注释 = "当前文件夹路径">
    常量 样式库 <公开 值 = @wdStyleGalleryPath 注释 = "样式库路径">
    常量 艺术边框 <公开 值 = @wdBorderArtPath 注释 = "艺术型边框路径">
}

类 Word自动宏 <公开 注释 = "指定存储在文档中的自动宏" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 运行 <公开 值 = @wdAutoExec 注释 = "运行">
    常量 新建 <公开 值 = @wdAutoNew 注释 = "新建">
    常量 打开 <公开 值 = @wdAutoOpen 注释 = "打开">
    常量 关闭 <公开 值 = @wdAutoClose 注释 = "关闭">
    常量 退出 <公开 值 = @wdAutoExit 注释 = "退出">
    常量 同步 <公开 值 = @wdAutoSync 注释 = "同步">
}

