类 Word宏 <公开 注释 = "代表VB宏对象">
{
    变量 VBComponents对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 参_VBComponents对象 <类型 = COM对象类 注释 = "VBComponents对象">
    {
        VBComponents对象 = 参_VBComponents对象
        返回 (VBComponents对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Word提供的VB宏对象.与\"COM对象\"数据类型兼容,可交互操作." "">
    {
        返回 (VBComponents对象)
    }

    方法 工作区数量 <公开 属性读 类型 = 整数 注释 = "获取宏工作区数量" "">
    {
        返回 (VBComponents对象.读无参数属性 ("Count", 整数))
    }

    方法 取工作区名称 <公开 类型 = 文本型 注释 = "取宏工作区对象名称" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号,从1开始.">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("Name", 文本型))
    }

    方法 取工作区类型 <公开 类型 = Word宏类型 注释 = "取宏工作区对象类型" "">
    参数 索引号 <类型 = 整数 注释 = "工作区索引号">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 索引号).读无参数属性 ("Type", Word宏类型))
    }

    方法 插入行代码 <公开 注释 = "在指定工作区对应行增加代码,原代码后移.增加代码不理会和判断插入处代码的内容.当指定行大于最后一行行号时,在最后一行的后面插入." "">
    参数 区名 <类型 = 文本型>
    参数 行号 <类型 = 整数>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("InsertLines", 行号, 代码内容)
    }

    方法 添加代码 <公开 注释 = "在指定工作区第一个过程前面的行开始增加代码,原代码后移." "">
    参数 区名 <类型 = 文本型>
    参数 代码内容 <类型 = 文本型>
    {
        VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).无返回值方法 ("AddFromString", 代码内容)
    }

    方法 添加模块 <公开 注释 = "向VB工作区中添加模块">
    参数 模块名称 <类型 = 文本型 @默认值 = "">
    参数 类型 <类型 = Word宏类型 @默认值 = Word宏类型.模块>
    {
        变量 局_模块对象 <类型 = COM对象类>
        局_模块对象 = VBComponents对象.方法 ("Add", COM对象类, 类型)
        如果 (模块名称 != "")
        {
            局_模块对象.写属性 ("Name", 模块名称)
        }
    }

    方法 取代码行数 <公开 类型 = 整数 注释 = "获取工作区代码总行数" "">
    参数 区名 <类型 = 文本型>
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读无参数属性 ("CountOfLines", 整数))
    }

    方法 取代码内容 <公开 类型 = 文本型 注释 = "获取工作区宏代码内容" "">
    参数 区名 <类型 = 文本型 注释 = "对象名称,如模块名称.">
    参数 开始行 <类型 = 整数 注释 = "欲取出代码区开始行">
    参数 结束行 <类型 = 整数 注释 = "欲取出代码区结束行">
    {
        返回 (VBComponents对象.方法 ("Item", COM对象类, 区名).读无参数对象型属性 ("CodeModule", COM对象类).读属性 ("Lines", 文本型, 开始行, 结束行))
    }

    方法 移除模块 <公开 注释 = "根据宏模块名称移除宏模块">
    参数 模块名 <类型 = 文本型 @默认值 = "">
    {
        变量 COM变体 <类型 = COM变体型>
        COM变体 = VBComponents对象.方法 ("Item", COM变体型, 模块名)  // 根据名称取出对象
        VBComponents对象.无返回值方法 ("Remove", COM变体)
    }

    方法 导入文件 <公开 注释 = "将VB宏代码文件导入宏工作区中" "">
    参数 文件名 <类型 = 文本型 注释 = "欲导入的宏文件">
    {
        VBComponents对象.无返回值方法 ("Import", 文件名)
    }
}

类 Word文档集 <公开 注释 = " 当前在Word程序内打开的所有Word文档集合">
{
    变量 Documents对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 集合对象 <类型 = COM对象类 注释 = "Word文档集">
    {
        Documents对象 = 集合对象
        返回 (Documents对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Word提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Documents对象)
    }

    方法 新建文档 <公开 类型 = Word文档 注释 = "新建一个文档.新文档将成为活动文档.">
    参数 模板 <类型 = 文本型 注释 = "确定如何创建新文档.如果此参数为指定现有Word文件名的字符串,那么创建新文档将以该指定的文件作为模板." @默认值 = "">
    参数 作为模板 <类型 = 逻辑型 注释 = "如果为真,则将文档作为模板打开." @默认值 = 假>
    参数 类型 <类型 = Word创建类型 注释 = "Word创建类型.*" @默认值 = Word创建类型.空白文档>
    参数 可视 <类型 = 逻辑型 注释 = "设置新建文档窗口是否可见" @默认值 = 真>
    {
        变量 局_文档 <类型 = Word文档>
        局_文档.置对象 (Documents对象.对象型方法 ("Add", COM对象类, 模板, 作为模板, 类型, 可视))
        返回 (局_文档)
    }

    方法 关闭 <公开 注释 = "关闭所有文档">
    参数 选项 <类型 = Word保存选项 注释 = "Word保存选项.*,指定内容有更改时保存文档的操作方式." @默认值 = Word保存选项.自动保存>
    参数 格式 <类型 = Word保存格式 注释 = "Word保存格式.*,指定保存文档的格式." @默认值 = Word保存格式.原格式>
    {
        Documents对象.无返回值方法 ("Close", 选项, 格式)
    }

    方法 打开 <公开 类型 = Word文档 注释 = "打开一个文档" "">
    参数 文件名 <类型 = 文本型 注释 = "要打开的文档的文件名">
    参数 转换文件 <类型 = 逻辑型 注释 = "如果为真,且该文件不是\"Word\"格式时将显示\"转换文件\"对话框." @默认值 = 假>
    参数 只读模式 <类型 = 逻辑型 注释 = "如果为真,则以只读模式打开文档." @默认值 = 假>
    参数 添加到最近 <类型 = 逻辑型 注释 = "如果为真,则将该文档添加到最近使用的文件列表中." @默认值 = 假>
    参数 密码 <类型 = 文本型 注释 = "包含打开受保护文档所需密码的字符串.如果省略此参数并且文档需要密码,则会提示用户输入密码." @默认值 = "">
    参数 模板密码 <类型 = 文本型 注释 = "包含打开受保护模板所需密码的字符串.如果省略此参数并且文档需要密码,则将提示用户输入密码." @默认值 = "">
    参数 写密码 <类型 = 文本型 注释 = "用于保存文档更改的密码" @默认值 = "">
    参数 模板写密码 <类型 = 文本型 注释 = "用于保存模板更改的密码" @默认值 = "">
    参数 打开操作 <类型 = 逻辑型 注释 = "控制打开文档时会进行什么操作.如果为真,则放弃对打开文档的任何未保存更改并重新打开文件.如果为假,则激活打开的文档." @默认值 = 假>
    参数 格式化方式 <类型 = Word格式化 注释 = "Word格式化.*,指定打开文档时要使用的格式." @默认值 = Word格式化.自动识别>
    参数 语言编码 <类型 = Word编码 注释 = "Word编码.*,指定的文本来源编码方式." @默认值 = Word编码.简体中文>
    参数 可视 <类型 = 逻辑型 注释 = "设置打开接程序时窗口是否可见" @默认值 = 真>
    {
        变量 局_Word文档 <类型 = Word文档>
        局_Word文档.置对象 (Documents对象.对象型方法 ("Open", COM对象类, 文件名, 转换文件, 只读模式, 添加到最近, 密码, 模板密码, 打开操作, 写密码, 模板写密码, 格式化方式, 语言编码, 可视))
        返回 (局_Word文档)
    }

    方法 文档数量 <公开 属性读 类型 = 整数 注释 = "返回文档集合中文档的数量">
    {
        返回 (Documents对象.读无参数属性 ("Count", 整数))
    }

    方法 保存 <公开 注释 = "保存文档集合中的所有文档.如果此文档以前未保存过,则弹出\"另存为\"对话框并提示用户键入文件名.">
    参数 自动保存 <类型 = 逻辑型 注释 = "如果为真,自动保存的所有文档.如果为假,则将提示用户保存已更改的每个文档." @默认值 = 假>
    参数 格式 <类型 = Word保存格式 注释 = "Word保存格式.*,指定Word保存格式." @默认值 = Word保存格式.原格式>
    {
        Documents对象.无返回值方法 ("Save", 自动保存, 格式)
    }

    方法 取文档 <公开 类型 = Word文档 注释 = "从文档集合中返回一个文档">
    参数 索引号 <类型 = 整数 注释 = "二选一,从1开始,对象在文档集合的索引号.为0时.忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "二选一,对象的名称.索引号不为0时.忽略该参数." @默认值 = "">
    {
        变量 局_文档 <类型 = Word文档>
        如果 (索引号 == 0)
        {
            如果 (名称 != "")  // 名称不为空时根据名称取出文档
            {
                局_文档.置对象 (Documents对象.对象型方法 ("Item", COM对象类, 名称))  // 使用名称
            }
        }
        否则
        {
            局_文档.置对象 (Documents对象.对象型方法 ("Item", COM对象类, 索引号))  // 使用索引号
        }
        返回 (局_文档)
    }
}

类 Word文档 <公开 注释 = "代表一个Word文档">
{
    变量 Document对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Document对象 <类型 = COM对象类>
    {
        Document对象 = 参_Document对象
        返回 (Document对象.是否为空 () == 假)
    }

    方法 置页边距 <公开 注释 = "设置页面左上右下边缘与正文文本边界之间的距离">
    参数 方向 <类型 = 整数 注释 = "0 左边距;1 上边距;2 右边距;3 下边距." "">
    参数 所欲设置的值 <类型 = 整数 注释 = "距离,以磅为单位.">
    {
        分支判断 (方向)
        {
            分支 (0)
            {
                Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("LeftMargin", 所欲设置的值)  // 设置页面左边的缘与正文文本的左边的界之间的距离
                跳出分支 ()
            }
            分支 (1)
            {
                Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("TopMargin", 所欲设置的值)  // 设置页面的上边缘与正文文本上部边界之间的距离
                跳出分支 ()
            }
            分支 (2)
            {
                Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("RightMargin", 所欲设置的值)  // 设置页面的右边缘与正文文本的右边界之间的距离
                跳出分支 ()
            }
            分支 (3)
            {
                Document对象.读无参数对象型属性 ("PageSetup", COM对象类).写属性 ("BottomMargin", 所欲设置的值)  // 设置页面的下边缘与正文文本边界之间的距离
            }
        }
    }

    方法 取页边距 <公开 类型 = 整数 注释 = "返回页面左上右下边缘与正文文本上部边界之间的距离" 返回值注释 = "距离,以磅为单位.">
    参数 方向 <类型 = 整数 注释 = "0 左边距;1 上边距;2 右边距;3 下边距." "">
    {
        变量 局_距离 <类型 = 整数>
        分支判断 (方向)
        {
            分支 (0)
            {
                局_距离 = Document对象.读无参数对象型属性 ("PageSetup", COM对象类).读无参数属性 ("LeftMargin", 整数)  // 返回页面左边的缘与正文文本的左边的界之间的距离
                跳出分支 ()
            }
            分支 (1)
            {
                局_距离 = Document对象.读无参数对象型属性 ("PageSetup", COM对象类).读无参数属性 ("TopMargin", 整数)  // 返回页面的上边缘与正文文本上部边界之间的距离
                跳出分支 ()
            }
            分支 (2)
            {
                局_距离 = Document对象.读无参数对象型属性 ("PageSetup", COM对象类).读无参数属性 ("RightMargin", 整数)  // 返回页面的右边缘与正文文本的右边界之间的距离
                跳出分支 ()
            }
            分支 (3)
            {
                局_距离 = Document对象.读无参数对象型属性 ("PageSetup", COM对象类).读无参数属性 ("BottomMargin", 整数)  // 返回页面的下边缘与正文文本边界之间的距离
            }
        }
        返回 (局_距离)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Word提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Document对象)
    }

    方法 关闭 <公开 注释 = "关闭对象">
    参数 选项 <类型 = Word保存选项 注释 = "Word保存选项.*,指定保存文档的操作." @默认值 = Word保存选项.自动保存>
    参数 格式 <类型 = Word保存格式 注释 = "Word保存格式.*,保存此文件名下的更改." @默认值 = Word保存格式.原格式>
    {
        Document对象.无返回值方法 ("Close", 选项, 格式)
    }

    方法 激活 <公开 注释 = "激活该文档,使其成为活动文档.">
    {
        Document对象.无参数及返回值方法 ("Activate")
    }

    方法 查找 <公开 类型 = 整数 注释 = "查找当前文档中所指定文本所处索引位置,未找到则返回-1." "">
    参数 查找文本 <类型 = 文本型 注释 = "用作查找文本">
    参数 区分大小写 <类型 = 逻辑型 注释 = "英文字母是否区分大小写" @默认值 = 真>
    参数 开始位置 <类型 = 整数 注释 = "查找开始位置,默认为文档开头." @默认值 = 1>
    参数 结束位置 <类型 = 整数 注释 = "查找结束位置,为0时,代表查找到文档结束的位置." @默认值 = 0>
    {
        变量 局_文本区 <类型 = Word文本区 注释 = "//用于储存查找选区">
        局_文本区 = 取文本区 (, )  // 取整个文档
        如果 (结束位置 == 0)
        {
            局_文本区 = 取文本区 (开始位置, 局_文本区.结束位置)  // 从开始位置到文档最后位置取出文本区
        }
        否则
        {
            局_文本区 = 取文本区 (开始位置, 结束位置)  // 从开始位置到结束位置取出文本区
        }
        如果 (局_文本区.查找 (查找文本, 区分大小写))  // 开始查找文本
        {
            返回 (局_文本区.开始位置)  // 返回找到文本在文档中开始位置
        }
        返回 (-1)  // 找不到
    }

    方法 插入组合框 <公开 注释 = "在当前光标位置插入下拉列表框并设置下拉列表框中内容">
    参数 内容数组 <类型 = 文本数组类>
    参数 占位符 <类型 = 文本型 注释 = "设置在用户输入自己的文本之前显示在内容控件中的占位符文本" @默认值 = "">
    参数 标题 <类型 = 文本型 注释 = "选中时是否在组合框上方出现标题" @默认值 = "">
    参数 颜色 <类型 = 整数 注释 = "设置选中时边框及阴影颜色" @默认值 = 颜色类.黑色>
    {
        变量 局_组合框对象 <类型 = COM对象类>
        变量 局_对象 <类型 = COM对象类>
        局_组合框对象 = Document对象.读无参数对象型属性 ("ContentControls", COM对象类).对象型方法 ("Add", COM对象类, 4)
        局_组合框对象.无返回值方法 ("SetPlaceholderText", 局_对象, 局_对象, 占位符)
        局_组合框对象.写属性 ("Title", 标题)
        局_组合框对象.写属性 ("Color", 颜色)
        内容数组.枚举循环 ()
        {
            局_组合框对象.读无参数对象型属性 ("DropdownListEntries", COM对象类).无返回值方法 ("Add", 内容数组.取枚举值 ())
        }
    }

    方法 添加到收藏夹 <公开 注释 = "创建文档或超链接的快捷方式,并将其添加到\"收藏夹\".">
    {
        Document对象.无参数及返回值方法 ("AddToFavorites")
    }

    方法 语法检查 <公开 注释 = "开始对指定的文档或区域执行拼写和语法检查">
