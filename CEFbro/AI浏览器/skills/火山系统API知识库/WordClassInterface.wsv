    }

    方法 清除所有字符格式 <公开 注释 = "从所选文本中删除所有字符格式(包括通过字符样式应用的格式和手动应用的格式)" "">
    {
        Selection对象.无参数及返回值方法 ("ClearCharacterAllFormatting")
    }

    方法 清除字符格式 <公开 注释 = "取消所选文本的字符格式,即通过功能区上的按钮或对话框手动应用的格式." "">
    {
        Selection对象.无参数及返回值方法 ("ClearCharacterDirectFormatting")
    }

    方法 取消字符样式 <公开 注释 = "从所选文本中删除通过字符样式应用的字符格式" "">
    {
        Selection对象.无参数及返回值方法 ("ClearCharacterStyle")
    }

    方法 清除格式 <公开 注释 = "清除所选内容的文本格式和段落格式" "">
    {
        Selection对象.无参数及返回值方法 ("ClearFormatting")
    }

    方法 清除所有段落格式 <公开 注释 = "从所选文本中删除所有段落格式(包括通过段落样式应用的格式和手动应用的格式)" "">
    {
        Selection对象.无参数及返回值方法 ("ClearParagraphAllFormatting")
    }

    方法 清除段落格式 <公开 注释 = "从所选文本中删除通过功能区上的按钮或者对话框手动应用的段落格式" "">
    {
        Selection对象.无参数及返回值方法 ("ClearParagraphDirectFormatting")
    }

    方法 清除段落样式 <公开 注释 = "从所选文本中删除通过段落样式应用的段落格式" "">
    {
        Selection对象.无参数及返回值方法 ("ClearParagraphStyle")
    }

    方法 折叠 <公开 注释 = "将选定内容折叠到起始位置或结束位置.折叠之后起始位置和结束位置相同." "">
    参数 折叠方向 <类型 = 整数 注释 = "指定某范围或所选内容的折叠方向." 注释 = "0 将该范围折叠到结束点." 注释 = "1 将该范围折叠到起始点." @默认值 = 0>
    {
        Selection对象.无返回值方法 ("Collapse", 折叠方向)
    }

    方法 文本转表格 <公开 注释 = "将范围内的文本转换为表格.作为表对象返回的表." "">
    参数 分隔符 <类型 = 整数 注释 = "指定用于将文本分隔成单元格的字符." 注释 = "0 段落标记;1 制表符;2 一个逗号;3 默认列表分隔符." @默认值 = 2>
    参数 行数 <类型 = 整数 注释 = "表格中的行数.默认值为0,表示将根据该范围的内容设置行数." @默认值 = 0>
    参数 列数 <类型 = 整数 注释 = "表格中的列数.默认值为0,表示将根据该范围的内容设置列数." @默认值 = 0>
    参数 列宽 <类型 = 整数 注释 = "每一列的初始宽度,以磅为单位.默认值为0,表示将计算并调整列宽,以使表格填满页面." @默认值 = 0>
    参数 格式 <类型 = Word表格格式 注释 = "Word表格格式.*,指定表格自动套用格式." @默认值 = Word表格格式.无格式>
    参数 自动列宽 <类型 = 逻辑型 注释 = "设置是否自动调整大小以适合内容(自动调整)表中的单元格" @默认值 = 假>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 行数变体 <类型 = COM变体型>
        变量 列数变体 <类型 = COM变体型>
        变量 列宽变体 <类型 = COM变体型>
        如果 (行数 != 0)
        {
            行数变体.赋值 (行数, )
        }
        如果 (列数 != 0)
        {
            列数变体.赋值 (列数, )
        }
        如果 (列宽 != 0)
        {
            列宽变体.赋值 (列数, )
        }
        Selection对象.无返回值方法 ("ConvertToTable", 分隔符, 行数变体, 列数变体, 列宽变体, 格式, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, 1, 自动列宽)
    }

    方法 计算公式 <公开 类型 = 小数 注释 = "计算所选内容中的数学表达式.返回\"小数型\"计算结果." "">
    {
        返回 (Selection对象.无参数方法 ("Calculate", 小数))
    }

    方法 单击 <公开 注释 = "单击该段落" "">
    {
        Selection对象.无参数及返回值方法 ("DoClick")
    }

    方法 复制 <公开 注释 = "复制该段落到剪贴板上" "">
    {
        Selection对象.无参数及返回值方法 ("Copy")
    }

