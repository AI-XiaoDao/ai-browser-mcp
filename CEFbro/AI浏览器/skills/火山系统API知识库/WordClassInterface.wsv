        Selection对象.无参数及返回值方法 ("PasteFormat")
    }

    方法 粘贴Excel表格 <公开 注释 = "粘贴复制到的Excel表格" "">
    参数 链接源目标 <类型 = 逻辑型 注释 = "为链接到原始Excel文件粘贴的表格,以便对Excel文件所做的更改将反映在Word中." @默认值 = 假>
    参数 设置格式 <类型 = 逻辑型 注释 = "为目录设置格式,使用Word文档中的格式设置.如果为假,则根据原始Excel文件的格式设置." @默认值 = 假>
    参数 富文本格式 <类型 = 逻辑型 注释 = "如果为真,则将粘贴使用丰富文本格式(RTF)表.如果为假,则将Excel表格粘贴为HTML." @默认值 = 真>
    {
        Selection对象.无返回值方法 ("PasteExcelTable", 链接源目标, 设置格式, 富文本格式)
    }

    方法 删除 <公开 注释 = "删除该文本区内容" "">
    {
        Selection对象.无参数及返回值方法 ("Delete")
    }

    方法 剪切 <公开 注释 = "剪切该段落到剪贴板上" "">
    {
        Selection对象.无参数及返回值方法 ("Cut")
    }

    方法 复制为图片 <公开 注释 = "将内容复制为图片" "">
    {
        Selection对象.无参数及返回值方法 ("CopyAsPicture")
    }

    方法 复制字符格式 <公开 注释 = "复制选定文字第一个字符的字符格式" "">
    {
        Selection对象.无参数及返回值方法 ("CopyFormat")
    }

    方法 创建文本框 <公开 注释 = "在选定内容周围添加一个默认大小的文本框,如果所选内容是一个光标插入点,本方法将鼠标指针设为十字型指针,以便绘制一个文本框." "">
    {
        Selection对象.无参数及返回值方法 ("CreateTextbox")
    }

    方法 按建到头尾 <公开 类型 = 整数 注释 = "将选定内容移动或扩展到指定单位的开头或末尾" 返回值注释 = "返回所选内容实际移动的字符数,如果移动不成功,则返回 0." "">
    参数 移动单位 <类型 = Word度量单位 注释 = "Word度量单位.*" @默认值 = Word度量单位.当前行>
    参数 移动方式 <类型 = 整数 注释 = "0 将所选内容折叠到光标插入点中并移到指定单位的末尾." 注释 = "1 将所选内容的末尾扩展到指定单位的末尾." @默认值 = 0>
    参数 到头 <类型 = 逻辑型 注释 = "如果为真,移动到头." 注释 = "如果为假,移动到尾." @默认值 = 假>
    {
        变量 字符数 <类型 = 整数>
        如果 (到头)
        {
            字符数 = Selection对象.方法 ("HomeKey", 整数, 移动单位, 移动方式)  // 相当于按下Home键产生的效果
        }
        否则
        {
            字符数 = Selection对象.方法 ("EndKey", 整数, 移动单位, 移动方式)  // 相当于按下End键产生的效果
        }
        返回 (字符数)
    }

    方法 移动 <公开 类型 = 整数 注释 = "将选定内容移动或扩展到指定单位" 返回值注释 = "返回所选内容实际移动的字符数,如果移动不成功,则返回 0." "">
    参数 单位 <类型 = Word度量单位 注释 = "Word度量单位.*,移动度量单位." 注释 = "移动方向为上下时可用的有:段落、当前行、屏幕尺寸、窗口." 注释 = "移动方向为左右时可用的有:字符单位、单词、句子."
            @默认值 = Word度量单位.当前行>
    参数 移动距离 <类型 = 整数 注释 = "要移动的单位数" @默认值 = 1>
    参数 移动或扩展 <类型 = 逻辑型 注释 = "如果为假,则将所选内容折叠到光标插入点中并移到指定单位的末尾." 注释 = "如果为真,则将所选内容的末尾扩展到指定单位的末尾." @默认值 = 假>
    参数 移动方向 <类型 = 整数 注释 = "1 上;2 下;3 左;4 右." @默认值 = 4>
    {
        变量 局_返回值 <类型 = 整数 值 = 0>
        如果 (移动方向 == 1)
        {
            局_返回值 = Selection对象.方法 ("MoveUp", 整数, 单位, 移动距离, 选择 (移动或扩展, 1, 0))
        }
        如果 (移动方向 == 2)
        {
            局_返回值 = Selection对象.方法 ("MoveDown", 整数, 单位, 移动距离, 选择 (移动或扩展, 1, 0))
        }
        如果 (移动方向 == 3)
        {
            局_返回值 = Selection对象.方法 ("MoveLeft", 整数, 单位, 移动距离, 选择 (移动或扩展, 1, 0))
        }
        如果 (移动方向 == 4)
        {
            局_返回值 = Selection对象.方法 ("MoveRight", 整数, 单位, 移动距离, 选择 (移动或扩展, 1, 0))
        }
        返回 (局_返回值)
    }

    方法 取消选定 <公开 注释 = "取消某种模式,如取消扩展或列选定模式(与按ESC相同)." "">
    {
        Selection对象.无参数及返回值方法 ("EscapeKey")
    }

    方法 移动到尾部 <公开 注释 = "将区域或选定内容的结束字符位置移动或扩展至最近的一个指定文本单元末尾" "">
    参数 单位 <类型 = Word度量单位 注释 = "Word度量单位.*,结束字符位置移至的单元.除.行以外的其他度量单位." @默认值 = Word度量单位.句子>
    参数 移动或扩展 <类型 = 逻辑型 注释 = "如果为假,则将所选内容折叠到光标插入点中并移到指定单位的末尾." 注释 = "如果为真,则将所选内容的末尾扩展到指定单位的末尾." @默认值 = 假>
    {
        Selection对象.无返回值方法 ("Endof", 单位, 选择 (移动或扩展, 1, 0))
    }

    方法 取扩展字数 <公开 类型 = 整数 注释 = "扩展指定的区域或所选内容.返回添至该区域或所选内容的字符数." "">
    参数 单位 <类型 = Word度量单位 注释 = "Word度量单位.*,代表要扩大范围的度量单位." @默认值 = Word度量单位.字符单位>
    {
        返回 (Selection对象.方法 ("Expand", 整数, 单位))
    }

    方法 跳转 <公开 注释 = "将光标插入点跳转到文档中某一位置" "">
    参数 类型 <类型 = Word项目类型 注释 = "Word项目类型.*,指定区域或选定内容要跳转到的项的类别." @默认值 = Word项目类型.书签>
    参数 位置 <类型 = Word项目位置 注释 = "Word项目位置.*,指定区域或选定内容要跳转到的项." @默认值 = Word项目位置.下一个>
    参数 跳转量 <类型 = 整数 注释 = "跳转量" @默认值 = 1>
    参数 项名称 <类型 = 文本型 注释 = "如果\"项目类型\"参数是书签、批注、域或对象,则本参数指定名称." @默认值 = "">
    {
        Selection对象.无返回值方法 ("GoTo", 类型, 位置, 跳转量, 项名称)
    }

    方法 前后跳转 <公开 注释 = "将光标插入点跳转到下一个项目或指定内容的前后位置" "">
    参数 类型 <类型 = Word项目类型 注释 = "Word项目类型.*,指定的区域或选定内容将被跳转到的项." @默认值 = Word项目类型.行>
    参数 前后 <类型 = 逻辑型 注释 = "如果为真,则向前跳转." 注释 = "如果为假,则向后跳转." @默认值 = 假>
    {
        如果 (前后)
        {
            Selection对象.无返回值方法 ("GoToPrevious", 类型)
        }
        否则
        {
            Selection对象.无返回值方法 ("GoToNext", 类型)
        }
    }

    方法 插入文本 <公开 注释 = "将指定文本插入范围或所选内容的前面或末尾" "">
    参数 内容 <类型 = 文本型 注释 = "要插入的文本" "">
    参数 前或后 <类型 = 逻辑型 注释 = "如果为真,则在前面插入." 注释 = "如果为假,则在后面插入." @默认值 = 假>
    {
        如果 (前或后)
        {
            Selection对象.无返回值方法 ("InsertBefore", 内容)
        }
        否则
        {
            Selection对象.无返回值方法 ("InsertAfter", 内容)
        }
    }

    方法 插入回车符 <公开 注释 = "将回车符插入范围或所选内容的末尾" "">
    {
        Selection对象.无返回值方法 ("InsertAfter", "\r\n")
    }

    方法 插入文件 <公开 注释 = "插入指定文件的全部或一部分" "">
    参数 文件名 <类型 = 文本型 注释 = "要插入的文件的路径及文件名.如果没有指定路径,则Word假定文件位于当前文件夹中." "">
    参数 范围 <类型 = 文本型 注释 = "如果指定的文件是Word文档,则此参数代表书签.如果该文件为其他类型(例如,Excel工作表),则此参数代表命名区域或单元格区域(例如,R1C1:R3C4)." @默认值 = "">
    参数 其他格式 <类型 = 逻辑型 注释 = "如果为真,则让Word提示您确认时插入Word文档格式之外的其他格式文件的转换,如文本文件." @默认值 = 假>
    {
        变量 局_范围 <类型 = COM变体型>
        如果 (范围 != "")
        {
            局_范围.赋值 (范围, )
        }
        Selection对象.无返回值方法 ("InsertFile", 文件名, 局_范围, 其他格式, 真)
    }

    方法 插入分隔符 <公开 注释 = "插入分页符、分栏符或分节符." "">
    参数 分隔符类型 <类型 = Word分隔符 注释 = "Word分隔符.*,要插入的分隔符的类型." "">
    {
        Selection对象.无返回值方法 ("InsertBreak", 分隔符类型)
    }

    方法 插入标题 <公开 注释 = "紧靠在指定的所选内容之前或之后插入题注" "">
    参数 标签 <类型 = 文本型 注释 = "要插入的题注标签" "">
    参数 标题 <类型 = 文本型 注释 = "要紧接在题注标签之后插入的字符串">
    参数 标签在上方 <类型 = 逻辑型 注释 = "题注标签加在上方" @默认值 = 真>
    参数 包含标签 <类型 = 逻辑型 注释 = "是否显示题注标签" @默认值 = 真>
    {
        Selection对象.无返回值方法 ("InsertCaption", 标签, 标题, 选择 (标签在上方, 0, 1), 包含标签)
    }
}

类 Word文本区 <公开 注释 = "代表文档中的一个段落中的指定文本区域内容">
{
    变量 Range对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作." "">
    参数 局_Range对象 <类型 = COM对象类 注释 = "Word文档集">
    {
        Range对象 = 局_Range对象
        返回 (Range对象.是否为空 () == 假)
    }

    方法 取对象 <公开 类型 = COM对象类 注释 = "获取Word提供的对象.与\"COM对象类\"数据类型兼容,可交互操作." "">
    {
        返回 (Range对象)
    }

    方法 删除 <公开 注释 = "删除该文本区内容" "">
    {
        Range对象.无参数及返回值方法 ("Delete")
    }

    方法 复制 <公开 注释 = "复制文本区内容到剪贴板上" "">
    {
        Range对象.无参数及返回值方法 ("Copy")
    }

    方法 粘贴 <公开 注释 = "将\"剪贴板\"的内容插入指定的选择范围处" "">
    {
        Range对象.无参数及返回值方法 ("Paste")
    }

    方法 选择性粘贴 <公开 注释 = "将\"剪贴板\"的内容插入指定的选择范围处" "">
    参数 格式 <类型 = Word粘贴格式 注释 = "Word粘贴格式.*" @默认值 = Word粘贴格式.默认>
    {
        Range对象.无返回值方法 ("PasteAndFormat", 格式)
    }

    方法 粘贴Excel表格 <公开 注释 = "粘贴复制到的Excel表格" "">
    参数 链接源目标 <类型 = 逻辑型 注释 = "为链接到原始Excel文件粘贴的表格,以便对Excel文件所做的更改将反映在Word中." @默认值 = 假>
    参数 设置格式 <类型 = 逻辑型 注释 = "为目录设置格式,使用Word文档中的格式设置.如果为假,则根据原始Excel文件格式设置." @默认值 = 假>
    参数 富文本格式 <类型 = 逻辑型 注释 = "如果为真,则将粘贴使用丰富文本格式(RTF)表.如果为假,则将Excel表格粘贴为HTML." @默认值 = 真>
    {
        Range对象.无返回值方法 ("PasteExcelTable", 链接源目标, 设置格式, 富文本格式)
    }

    方法 复制为图片 <公开 注释 = "将内容复制为图片" "">
    {
        Range对象.无参数及返回值方法 ("CopyAsPicture")
    }

    方法 选定 <公开 注释 = "选中该文本区" "">
    {
        Range对象.无参数及返回值方法 ("Select")
    }

    方法 插入文本 <公开 注释 = "将指定文本插入文本区的前面或末尾" "">
    参数 内容 <类型 = 文本型 注释 = "要插入的文本" "">
    参数 前插 <类型 = 逻辑型 注释 = "如果为真,则在前面插入." 注释 = "如果为假,则在后面插入." @默认值 = 假>
    {
        如果 (前插)
        {
            Range对象.无返回值方法 ("InsertBefore", 内容)
        }
        否则
        {
            Range对象.无返回值方法 ("InsertAfter", 内容)
        }
    }

    方法 插入回车符 <公开 注释 = "将回车符插入范围或所选内容的末尾" "">
    {
        Range对象.无返回值方法 ("InsertAfter", "\r\n")
    }

    方法 文本转表格 <公开 注释 = "将范围内的文本转换为表格.作为表对象返回的表." "">
    参数 分隔符 <类型 = 整数 注释 = "指定用于将文本分隔成单元格的字符.0 段落标记;1 制表符;2 一个逗号;3 默认列表分隔符." @默认值 = 2>
    参数 行数 <类型 = 整数 注释 = "表格中的行数.默认值为0,表示将根据该范围的内容设置行数." @默认值 = 0>
    参数 列数 <类型 = 整数 注释 = "表格中的列数.默认值为0,表示将根据该范围的内容设置列数." @默认值 = 0>
    参数 列宽 <类型 = 整数 注释 = "每一列的初始宽度,以磅为单位.默认值为0,表示将计算并调整列宽,以使表格填满页面." @默认值 = 0>
    参数 格式 <类型 = Word表格格式 注释 = "Word表格格式.*,指定表格自动套用格式." @默认值 = Word表格格式.无格式>
    参数 自动列宽 <类型 = 逻辑型 注释 = "设置是否自动调整大小以适合内容(自动调整)表中的单元格" @默认值 = 假>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 行数变体 <类型 = COM变体型>
        变量 列数变体 <类型 = COM变体型>
        变量 列宽变体 <类型 = COM变体型>
        如果 (行数 != 0)
        {
            行数变体.赋值 (行数, )
        }
        如果 (列数 != 0)
        {
            列数变体.赋值 (列数, )
        }
        如果 (列宽 != 0)
        {
            列宽变体.赋值 (列数, )
        }
        Range对象.无返回值方法 ("ConvertToTable", 分隔符, 行数变体, 列数变体, 列宽变体, 格式, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, 1, 自动列宽)
    }

    方法 插入分隔符 <公开 注释 = "插入分页符、分栏符或分节符.如果您不想替换该范围,请使用该方法之前使用折叠方法." "">
    参数 分隔符类型 <类型 = Word分隔符 注释 = "Word分隔符.*,要插入的分隔符的类型." "">
    {
        Range对象.无返回值方法 ("InsertBreak", 分隔符类型)
    }

    方法 插入标题 <公开 注释 = "紧靠在指定的所选内容之前或之后插入题注" "">
    参数 标签 <类型 = 文本型 注释 = "要插入的题注标签" "">
    参数 标题 <类型 = 文本型 注释 = "要紧接在题注标签之后插入的字符串">
    参数 标签在上方 <类型 = 逻辑型 注释 = "题注标签加在上方" @默认值 = 真>
    参数 包含标签 <类型 = 逻辑型 注释 = "是否显示题注标签" @默认值 = 真>
    {
        Range对象.无返回值方法 ("InsertCaption", 标签, 标题, 选择 (标签在上方, 0, 1), 包含标签)
    }

    方法 折叠 <公开 注释 = "将选区内容折叠到起始位置或结束位置.折叠之后起始位置和结束位置相同." "">
    参数 折叠方向 <类型 = 整数 注释 = "指定某范围或所选内容的折叠方向." 注释 = " 0 将该范围折叠到结束点." 注释 = " 1 将该范围折叠到起始点." @默认值 = 0>
    {
        Range对象.无返回值方法 ("Collapse", 折叠方向)
    }

    方法 跳转 <公开 注释 = "从当前选区位置跳转到下一个项目或指定内容的前后位置,并将当前选区设置为跳转到的位置." "">
    参数 类型 <类型 = Word项目类型 注释 = "Word项目类型.*,指定区域或选定内容要跳转到的项的类别." @默认值 = Word项目类型.书签>
    参数 位置 <类型 = Word项目位置 注释 = "Word项目位置.*,指定区域或选定内容要跳转到的项." @默认值 = Word项目位置.下一个>
    参数 跳转量 <类型 = 整数 注释 = "跳转量" @默认值 = 1>
    参数 项名称 <类型 = 文本型 注释 = "如果\"项目类型\"参数是书签、批注、域或对象,则本参数指定名称." @默认值 = "">
    {
        Range对象.无返回值方法 ("GoTo", 类型, 位置, 跳转量, 项名称)
    }

    方法 跳转前后 <公开 注释 = "从当前选区位置跳转到下一个项目或指定内容的前后位置,并将当前选区设置为跳转到的位置." "">
    参数 类型 <类型 = Word项目类型 注释 = "Word项目类型.*,指定的区域或选定内容将被跳转到的项." @默认值 = Word项目类型.行>
    参数 前后 <类型 = 逻辑型 注释 = "如果为真,则向前跳转." 注释 = "如果为假,则向后跳转." @默认值 = 假>
    {
        如果 (前后)
        {
            Range对象.无返回值方法 ("GoToPrevious", 类型)
        }
        否则
        {
            Range对象.无返回值方法 ("GoToNext", 类型)
        }
    }

    方法 移动到尾部 <公开 注释 = "将区域的结束字符位置移动或扩展到最近的一个指定文本单位末尾" "">
    参数 单位 <类型 = Word度量单位 注释 = "Word度量单位.*,结束字符位置移至的单元.除\"Word度量单位.行\"以外的其他度量单位." @默认值 = Word度量单位.句子>
    参数 移动或扩展 <类型 = 逻辑型 注释 = "如果为真,则将所选内容的末尾扩展到指定单位的末尾." 注释 = "如果为假,则将所选内容折叠到光标插入点中并移到指定单位的末尾." @默认值 = 假>
    {
        Range对象.无返回值方法 ("Endof", 单位, 选择 (移动或扩展, 1, 0))
    }

    方法 剪切 <公开 注释 = "剪切该段落到剪贴板上" "">
    {
        Range对象.无参数及返回值方法 ("Cut")
    }

    方法 字符数量 <公开 属性读 类型 = 整数 注释 = "返回该段落上的字符数量" "">
    {
        返回 (Range对象.无参数对象型方法 ("Characters", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取中间字符 <公开 类型 = 文本型 注释 = "根据文本区中字符的索引号取出单个字符内容" "">
    参数 位置 <类型 = 整数>
    {
        返回 (Range对象.无参数对象型方法 ("Characters", COM对象类).方法 ("Item", 文本型, 位置))
    }

    方法 置区域 <公开 注释 = "重新设置文本区为当前文本区中某个开始位置到结束位置的区域">
    参数 参_开始位置 <类型 = 整数 注释 = "开始字符位置">
    参数 参_结束位置 <类型 = 整数 注释 = "结束字符位置">
    {
        Range对象.无返回值方法 ("SetRange", 开始位置 + 参_开始位置, 开始位置 + 参_结束位置)
    }

    方法 重置区域 <公开 注释 = "重新设置文本区为文档中开始位置到结束位置的文本区">
    参数 参_开始位置 <类型 = 整数 注释 = "开始字符位置">
    参数 参_结束位置 <类型 = 整数 注释 = "结束字符位置">
    {
        Range对象.无返回值方法 ("SetRange", 参_开始位置, 参_结束位置)
    }

    方法 置边框线条 <公开 注释 = "向区域边框添加线条,并设置边框线条样式.">
    参数 边框 <类型 = Word边框 注释 = "Excel边框.*,它代表单元格区域或样式的边框之一." @默认值 = Word边框.下边>
    参数 线条样式 <类型 = Word线条样式 注释 = "Excel线条样式.*,它代表边框的线条样式." @默认值 = Word线条样式.单线>
    {
        变量 Borders <类型 = COM对象类>
        变量 Border <类型 = COM对象类>
        Borders = Range对象.读无参数对象型属性 ("Borders", COM对象类)
        Border = Borders.读对象型属性 ("Item", COM对象类, 边框)
        Border.写属性 ("LineStyle", 线条样式)
    }

    方法 置编号 <公开 注释 = "适用于指定的一组列表格式特征">
    参数 模板索引号 <类型 = 整数 注释 = "列表模板索引号." 注释 = "1 项目符号;2 编号;3 多级列表.">
    参数 样式索引号 <类型 = 整数 注释 = "通常为 1-7,三种模板中包含样式索引号.">
    参数 继续编码 <类型 = 逻辑型 注释 = "如果为真,则继续编排页码从前面的列表." 注释 = "如果为假,则启动一个新的列表." @默认值 = 假>
    参数 范围 <类型 = Word列表范围 注释 = "Word列表范围.*" @默认值 = Word列表范围.选择区>
    {
        变量 局_模板 <类型 = COM对象类>
        变量 局_样式 <类型 = COM变体型>
        局_模板 = Range对象.读无参数对象型属性 ("Application", COM对象类).读无参数对象型属性 ("ListGalleries", COM对象类).方法 ("Item", COM对象类, 模板索引号)  // 取出 Word 中三种模板其中一种
        局_样式 = 局_模板.读无参数对象型属性 ("ListTemplates", COM对象类).方法 ("Item", COM变体型, 样式索引号)  // 取出模板样式作为欲设置参数
        Range对象.读无参数对象型属性 ("ListFormat", COM对象类).无返回值方法 ("ApplyListTemplate", 局_样式, 继续编码, 范围)
    }

