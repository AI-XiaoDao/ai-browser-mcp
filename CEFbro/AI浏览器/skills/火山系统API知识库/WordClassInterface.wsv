    参数 查找文本 <类型 = 文本型 注释 = "用作查找文本">
    参数 替换文本 <类型 = 文本型 注释 = "用作替换文本">
    参数 替换所有 <类型 = 逻辑型 注释 = "如果为假,表示只替换遇到的第一个匹配项." @默认值 = 真>
    参数 区分大小写 <类型 = 逻辑型 注释 = "英文是否区分大小写" @默认值 = 真>
    参数 全文替换 <类型 = 逻辑型 注释 = "是否忽略当前选区而向全文档搜索替换" @默认值 = 假>
    {
        变量 Find <类型 = COM对象类>
        变量 COM变体 <类型 = COM变体型>
        Find = Range对象.读无参数对象型属性 ("Find", COM对象类)
        Find.写属性 ("Text", 查找文本)  // 设置查找文本
        Find.写属性 ("Forward", 真)  // 向前替换
        Find.写属性 ("MatchCase", 区分大小写)  // 英文是否区分大小写
        Find.无参数及返回值方法 ("ClearFormatting")  // 取消在查找或替换操作中所指定文本的文本格式和段落格式
        Find.读无参数对象型属性 ("Replacement", COM对象类).写属性 ("Text", 替换文本)  // 设置替换文本
        Find.无返回值方法 ("Execute", COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, COM变体, 选择 (全文替换, 1, 0), COM变体, COM变体, 选择 (替换所有, 2, 1))
    }

    方法 查找 <公开 类型 = 逻辑型 注释 = "查找文本区中对应的文本内容,注意:如果返回真时,文本区将被覆盖为找到区域." "">
    参数 查找文本 <类型 = 文本型 注释 = "用作查找文本">
    参数 区分大小写 <类型 = 逻辑型 注释 = "英文字母是否区分大小写" @默认值 = 真>
    {
        变量 Find <类型 = COM对象类>
        Find = Range对象.读无参数对象型属性 ("Find", COM对象类)
        Find.无参数及返回值方法 ("ClearFormatting")  // 取消在查找操作中所指定文本的文本格式和段落格式
        Find.写属性 ("Text", 查找文本)  // 设置查找文本
        Find.写属性 ("MatchCase", 区分大小写)  // 设置英文字母是否区分大小写
        返回 (Find.无参数方法 ("Execute", 逻辑型))
    }

    方法 段落数 <公开 属性读 类型 = 整数 注释 = "返回当前文本区中段落数量,代表当前选区中段落数量.注意:当前文本区,非整个文档.">
    {
        返回 (Range对象.读无参数对象型属性 ("Paragraphs", COM对象类).读无参数属性 ("Count", 整数))
    }

    方法 取段落 <公开 类型 = Word段落 注释 = "返回一个\"Word段落\"类,代表当前文本区中段落集合中根据索引号对应的一段段落.注意:当前文本区,非整个文档.">
    参数 索引号 <类型 = 整数 注释 = "欲取出选区中的段落索引号">
    {
        变量 局_Word段落 <类型 = Word段落>
        局_Word段落.置对象 (Range对象.读无参数对象型属性 ("Paragraphs", COM对象类).对象型方法 ("Item", COM对象类, 索引号))
        返回 (局_Word段落)
    }
}

类 Word图形 <公开>
{
    变量 Shape对象 <类型 = COM对象类>

    方法 置对象 <公开 类型 = 逻辑型 注释 = "将COM对象置入本对象中,可交互操作.">
    参数 参_Shape对象 <类型 = COM对象类>
    {
        Shape对象 = 参_Shape对象
        返回 (Shape对象.是否为空 () == 假)
    }

    方法 删除 <公开 注释 = "删除指定区域的形状" "">
    {
        Shape对象.无参数及返回值方法 ("Delete")
    }

    方法 取节点文本 <公开 类型 = 文本型 注释 = "当对象为智能图表时,返回智能图表节点文本." "">
    参数 节点索引 <类型 = 整数 注释 = "智能图表节点索引号">
    {
        变量 局_节点 <类型 = COM对象类>
        变量 局_文本区 <类型 = COM对象类>
        局_节点 = Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引)  // 取节点对象
        局_文本区 = 局_节点.读无参数对象型属性 ("TextFrame2", COM对象类).读无参数对象型属性 ("TextRange", COM对象类)  // 取节点文本区
        返回 (局_文本区.读无参数属性 ("Text", 文本型))
    }

    方法 置节点文本位置 <公开 注释 = "当对象为智能图表时,设置智能图表节点文本位置." "">
    参数 节点索引 <类型 = 整数 "">
    参数 上 <类型 = 整数 注释 = "设置文本框架顶端与文本所在形状的内接矩形顶端之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 下 <类型 = 整数 注释 = "设置文本框架底端与文本所在形状的内接矩形底端之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 左 <类型 = 整数 注释 = "设置文本框架左边缘与文本所在形状的内接矩形左边缘之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    参数 右 <类型 = 整数 注释 = "设置文本框架右边缘与文本所在形状的内接矩形右边缘之间的距离(以磅为单位),如果值为-1,则忽略该参数." @默认值 = -1>
    {
        变量 局_文本区 <类型 = COM对象类>
        局_文本区 = Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引).读无参数对象型属性 ("TextFrame2", COM对象类)  // 取节点文本区对象
        如果 (上 != -1)
        {
            局_文本区.写属性 ("MarginTop", 上)
        }
        如果 (下 != -1)
        {
            局_文本区.写属性 ("MarginBottom", 下)
        }
        如果 (左 != -1)
        {
            局_文本区.写属性 ("MarginLeft", 左)
        }
        如果 (右 != -1)
        {
            局_文本区.写属性 ("MarginRight", 右)
        }
    }

    方法 置节点文本 <公开 注释 = "当对象为智能图表时,设置智能图表节点文本." "">
    参数 节点索引 <类型 = 整数 注释 = "智能图表节点索引号">
    参数 内容 <类型 = 文本型 注释 = "智能图表节点所欲设置的内容">
    参数 字体名称 <类型 = 文本型 注释 = "设置字体名称,如果值为\"\",则忽略该参数." @默认值 = "">
    参数 字体大小 <类型 = 整数 注释 = "设置字体大小,如果值为-1,则忽略该参数." @默认值 = -1>
    参数 字体颜色 <类型 = 整数 注释 = "设置字体颜色,如果值为-1,则忽略该参数." @默认值 = -1>
    参数 加粗 <类型 = 逻辑型 注释 = "设置字体是否加粗" @默认值 = 假>
    参数 透明度 <类型 = 小数 注释 = "设置透明度的指定填充形状为0.0(不透明)到1.0(透明)之间的值" @默认值 = 0>
    {
        变量 局_节点 <类型 = COM对象类>
        变量 局_文本区 <类型 = COM对象类>
        局_节点 = Shape对象.读无参数对象型属性 ("SmartArt", COM对象类).读无参数对象型属性 ("AllNodes", COM对象类).对象型方法 ("Item", COM对象类, 节点索引)  // 取节点对象
        局_文本区 = 局_节点.读无参数对象型属性 ("TextFrame2", COM对象类).读无参数对象型属性 ("TextRange", COM对象类)  // 取节点文本区
        局_文本区.写属性 ("Text", 内容)
        如果 (字体名称 != "")
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("NameFarEast", 字体名称)  // 设置字体名称
        }
        如果 (字体大小 != -1)
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("Size", 字体大小)  // 设置字体大小
        }
        如果 (字体颜色 != -1)
        {
            局_文本区.读无参数对象型属性 ("Font", COM对象类).读无参数对象型属性 ("Fill", COM对象类).读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 字体颜色)  // 填充字体颜色
        }
        局_文本区.读无参数对象型属性 ("Font", COM对象类).写属性 ("Bold", 加粗)  // 设置字体加粗
        局_文本区.读无参数对象型属性 ("Font", COM对象类).读无参数对象型属性 ("Fill", COM对象类).写属性 ("Transparency", 透明度)  // 设置透明度
    }

    方法 节点数量 <公开 属性读 类型 = 整数 注释 = "当对象为智能图表时,返回智能图表节点的总数量." "">
