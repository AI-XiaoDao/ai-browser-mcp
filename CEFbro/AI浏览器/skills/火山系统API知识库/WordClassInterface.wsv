类 Word垂直对齐 <公开 注释 = "指定要应用的垂直对齐方式的类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 顶对齐 <公开 值 = @wdAlignVerticalTop 注释 = "顶端垂直对齐">
    常量 居中 <公开 值 = @wdAlignVerticalCenter 注释 = "居中垂直对齐">
    常量 两端 <公开 值 = @wdAlignVerticalJustify 注释 = "两端垂直对齐">
    常量 底对齐 <公开 值 = @wdAlignVerticalBottom 注释 = "底端垂直对齐">
}

类 Word段落对齐 <公开 注释 = "指定段落的对齐方式" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 左对齐 <公开 值 = @wdAlignParagraphLeft 注释 = "左对齐">
    常量 居中 <公开 值 = @wdAlignParagraphCenter 注释 = "居中">
    常量 右对齐 <公开 值 = @wdAlignParagraphRight 注释 = "右对齐">
