    }

    方法 添加段落 <公开 类型 = Word段落 注释 = "根据已有段落索引及实际字符位置添加新的空段落到文档中并返回新添加段落">
    参数 段落索引 <类型 = 整数 注释 = "新的段落不替换该区域从1开始,默认为0表示在文档最后位置添加新段落." @默认值 = 0>
    参数 字符位置 <类型 = 整数 注释 = "段落索引中字符位置,从1开始,新的段落不替换该区域.默认为段落索引位置向上添加新段落." @默认值 = 1>
    {
        变量 局_段落 <类型 = Word段落>
        变量 局_文本区 <类型 = COM变体型>
        如果 (段落索引 == 0)
        {
            局_段落.置对象 (Document对象.读无参数对象型属性 ("Paragraphs", COM对象类).无参数对象型方法 ("Add", COM对象类))  // 得到的是新增前最后的段落
            局_段落.到下一段 ()  // 移动到新增后的段落
        }
        否则
        {
            局_文本区 = 取段落 (段落索引).文本区.取对象 ().无参数对象型方法 ("Characters", COM对象类).方法 ("Item", COM变体型, 选择 (字符位置 < 1, 1, 字符位置))  // 取出 段落索引 上的位置用做传入参数,当字符位置小于0时 则以第一个字符作为参照.
            局_段落.置对象 (Document对象.读无参数对象型属性 ("Paragraphs", COM对象类).对象型方法 ("Add", COM对象类, 局_文本区))
        }
        返回 (局_段落)
    }

    方法 取文本区 <公开 类型 = Word文本区 注释 = "取文档中间文本区">
    参数 开始位置 <类型 = 整数 注释 = "开始字符位置,结束位置为0时忽略该参数." @默认值 = 1>
    参数 结束位置 <类型 = 整数 注释 = "结束字符位置,为0时表示取整个文档." @默认值 = 0>
    {
        变量 局_Word文本区 <类型 = Word文本区>
        如果 (结束位置 == 0)
        {
            局_Word文本区.置对象 (Document对象.无参数对象型方法 ("Range", COM对象类))  // 没有设置结束位置则取出所有文本区域
        }
        否则
        {
            局_Word文本区.置对象 (Document对象.对象型方法 ("Range", COM对象类, 开始位置, 结束位置))
        }
        返回 (局_Word文本区)
    }

    方法 取特定选区 <公开 类型 = Word文本区 注释 = "取文档中特定选区">
