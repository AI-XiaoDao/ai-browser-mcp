    方法 窗口反激活 <公开 定义事件 类型 = 整数 注释 = "在文档窗口成为非活动窗口时发生">
    参数 参_Word文档 <类型 = Word文档 注释 = "非活动窗口中显示的文档">
    参数 参_窗口对象 <类型 = COM对象类 注释 = "Word提供的Window对象类,代表非活动窗口对象.">

    方法 窗口尺寸被改变 <公开 定义事件 类型 = 整数 注释 = "在对应用程序窗口进行大小调整或移动时发生">
    参数 参_Word文档 <类型 = Word文档 注释 = "大小正在调整的窗口中的文档">
    参数 参_窗口对象 <类型 = COM对象类 注释 = "Word提供的Window对象类,代表大小正在调整的窗口对象.">

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出.事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        变量 局_返回值 <类型 = 整数 值 = 0>
        如果 (来源对象 == Application事件)
        {
            如果 (事件方法ID == 2)
            {
                局_返回值 = 程序被退出 ()
            }
            如果 (事件方法ID == 3)  // 活动文档被改变
            {
                活动文档被改变 ()
            }
            如果 (事件方法ID == 4)  // 文档被打开
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文档对象, )  // 第一个参数为被打开的文档对象
                局_Word文档.置对象 (文档对象)
                文档被打开 (局_Word文档)
            }
            如果 (事件方法ID == 6)  // 文档即将关闭
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (文档对象, )  // 第二个参数为被打开的文档对象
                局_Word文档.置对象 (文档对象)
                局_返回值 = 文档即将关闭 (局_Word文档)
                事件参数.取成员 (0).赋值 (选择 (局_返回值 == 1, 真, 假), )
                局_返回值 = 1
            }
            如果 (事件方法ID == 8)  // 文档保存前
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                事件参数.取成员 (2).取COM对象 (文档对象, )  // 第一个参数为被打开的文档对象
                局_Word文档.置对象 (文档对象)
                局_返回值 = 文档即将保存 (局_Word文档)
                事件参数.取成员 (0).赋值 (选择 (局_返回值 == 1, 真, 假), )  // 第三个参数设置是否保存文档
                局_返回值 = 1
            }
            如果 (事件方法ID == 9)  // 新建文档
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                事件参数.取成员 (0).取COM对象 (文档对象, )  // 第一个参数为新文档对象
                局_Word文档.置对象 (文档对象)
                局_返回值 = 新建文档 (局_Word文档)
            }
            如果 (事件方法ID == 10)  // 窗口被激活
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (文档对象, )  // 第二个参数为新文档对象
                局_Word文档.置对象 (文档对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第一个参数为windows对象
                局_返回值 = 窗口被激活 (局_Word文档, windows对象)
            }
            如果 (事件方法ID == 11)  // 窗口反激活
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (文档对象, )  // 第二个参数为新文档对象
                局_Word文档.置对象 (文档对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第一个参数为windows对象
                局_返回值 = 窗口反激活 (局_Word文档, windows对象)
            }
            如果 (事件方法ID == 25)  // 窗口尺寸被改变
            {
                变量 局_Word文档 <类型 = Word文档>
                变量 文档对象 <类型 = COM对象类>
                变量 windows对象 <类型 = COM对象类>
                事件参数.取成员 (1).取COM对象 (文档对象, )  // 第一个参数为新文档对象
                局_Word文档.置对象 (文档对象)
                事件参数.取成员 (0).取COM对象 (windows对象, )  // 第二个参数为windows对象
                局_返回值 = 窗口尺寸被改变 (局_Word文档, windows对象)
            }
        }
        返回 (局_返回值)
    }

    方法 取可用打印机 <公开 类型 = 整数 注释 = "返回本地可用打印机数量" @禁止流程检查 = 真>
    参数 打印机名 <类型 = 文本参考数组类 注释 = "本地可用打印机名称集合">
    参数 打印机端口 <类型 = 文本参考数组类 注释 = "本地可用打印机名称对应端口集合">
    {
        变量 局_打印机名 <类型 = 文本型>
        变量 局_打印机端口 <类型 = 文本型>
        @ DWORD dwSize = 0, dwPrinters;
        @ ::EnumPrinters(PRINTER_ENUM_CONNECTIONS | PRINTER_ENUM_LOCAL, NULL, 5, NULL, 0, &dwSize, &dwPrinters);
        @ if (dwSize == 0)  return 0;
        @ BYTE* pBuffer = new BYTE[dwSize];
        @ dwPrinters = 0;
        @ ::EnumPrinters(PRINTER_ENUM_CONNECTIONS | PRINTER_ENUM_LOCAL, NULL, 5, pBuffer, dwSize, &dwSize, &dwPrinters);
        @ _PRINTER_INFO_5W* pPrnInfo = (_PRINTER_INFO_5W*)pBuffer;
        @ for (DWORD i = 0; i<dwPrinters; i++)
        @ {
        @     @<局_打印机名>.SetText (pPrnInfo->pPrinterName);
        @     @<局_打印机端口>.SetText (pPrnInfo->pPortName);
        打印机名.加入成员 (局_打印机名)
        打印机端口.加入成员 (局_打印机端口)
        @     pPrnInfo++;
        @ }
        @ delete[]pBuffer;
        @ return dwPrinters;
    }

    方法 打印 <公开 注释 = "打印全部或部分指定文档">
    参数 运行宏 <类型 = 逻辑型 注释 = "设置为真,打印文档同时继续运行宏." @默认值 = 真>
    参数 文件追加 <类型 = 逻辑型 注释 = "如果该参数为真,则将指定文档添至由输出文件参数所指定的文件中.如果为假,则覆盖输出文件所指定文件的内容." @默认值 = 假>
    参数 范围 <类型 = Word打印范围 注释 = "Word打印范围..*,指定打印页面范围." @默认值 = Word打印范围.整个文档>
    参数 开始页号 <类型 = 整数 注释 = "打印的开始页号.当\"打印范围\"设置为\"指定范围\"时生效." @默认值 = 0>
    参数 终止页号 <类型 = 整数 注释 = "打印的终止页号.当\"打印范围\"设置为\"指定范围\"时生效." @默认值 = 0>
    参数 项目 <类型 = Word打印项目 注释 = "指定要打印的项目" @默认值 = Word打印项目.文档内容>
    参数 打印份数 <类型 = 整数 注释 = "打印份数" @默认值 = 1>
    参数 打印页码 <类型 = 文本型 注释 = "例如,\"2,6-10\"表示打印第2页以及第6至第10页.当\"打印范围\"设置为\"当前页面\"或\"页面范围\"时生效." @默认值 = "">
    参数 页面类型 <类型 = 整数 注释 = "要打印的页面类型.可为下列常量之一:0、所有页;1、只有奇数页;2、只有偶数页." @默认值 = 0>
    参数 打印到文件 <类型 = 逻辑型 注释 = "如果为真,则将打印指令发送到文件.请确保由输出文件参数指定了文件名." @默认值 = 假>
    参数 输出文件名 <类型 = 文本型 注释 = "如果\"打印到文件\"的值为真,此参数将指定输出文件的路径和文件名称." @默认值 = "">
    参数 副本 <类型 = 逻辑型 注释 = "在打印文档的多份副本时,若此参数为真,则打印完一份副本之后再打印下一份副本." @默认值 = 真>
    参数 文件名 <类型 = 文本型 注释 = "要打印的文档的路径和文件名称.如果值为空文本时,表示将打印活动文档." @默认值 = "">
    参数 水平页数 <类型 = 整数 注释 = "1-4与垂直页数同时设置表示Word在一页纸上水平放置的页数.可在单张纸上打印多页文档." @默认值 = 0>
    参数 垂直页数 <类型 = 整数 注释 = "1-4与水平页数同时设置表示Word在一页纸上垂直放置的页数.可在单张纸上打印多页文档." @默认值 = 0>
    参数 缩放宽度 <类型 = 整数 注释 = "指定将待打印页面缩放到的宽度,以缇为单位(20缇=1磅;72磅=1英寸)." @默认值 = 0>
    参数 缩放高度 <类型 = 整数 注释 = "指定将打印页面缩放到的高度,以缇为单位(20缇=1磅;72磅=1英寸)." @默认值 = 0>
    {
        变量 COM变体 <类型 = COM变体型>
        变量 局_水平页数 <类型 = COM变体型>
        变量 局_垂直页数 <类型 = COM变体型>
        变量 局_打印页码 <类型 = COM变体型>
        变量 局_输出文件名 <类型 = COM变体型>
        变量 局_缩放宽度 <类型 = COM变体型>
        变量 局_缩放高度 <类型 = COM变体型>
        变量 局_文件名 <类型 = COM变体型>
        变量 局_开始页号 <类型 = COM变体型>
        变量 局_终止页号 <类型 = COM变体型>
        如果 (水平页数 > 0)
        {
            局_水平页数.赋值 (水平页数, )  // 多页合并到单页打印时水平页数
        }
        如果 (垂直页数 > 0)
        {
            局_垂直页数.赋值 (垂直页数, )  // 多页合并到单页打印时垂直页数
        }
        如果 (打印页码 != "")
        {
            局_打印页码.赋值 (打印页码, )
        }
        如果 (输出文件名 != "")
        {
            局_输出文件名.赋值 (输出文件名, )
        }
        如果 (文件名 != "")
        {
            局_文件名.赋值 (文件名, )
        }
        如果 (缩放宽度 != 0)
        {
            局_缩放宽度.赋值 (缩放宽度)
        }
        如果 (缩放高度 != 0)
        {
            局_缩放高度.赋值 (缩放高度)
        }
        如果 (开始页号 != 0)
        {
            局_开始页号.赋值 (开始页号, )
        }
        如果 (终止页号 != 0)
        {
            局_终止页号.赋值 (终止页号, )
        }
        Application对象.无返回值方法 ("PrintOut", 运行宏, 文件追加, 范围, 局_输出文件名, 局_开始页号, 局_终止页号, 项目, 打印份数, 局_打印页码, 页面类型, 打印到文件, 副本, 局_文件名, COM变体, COM变体, 局_水平页数, 局_垂直页数, 局_缩放宽度, 局_缩放高度)
    }

