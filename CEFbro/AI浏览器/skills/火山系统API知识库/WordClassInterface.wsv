    方法 添加图形 <公开 类型 = Word图形 注释 = "当类型为\"画布\"时,向画布中添加一个图形,并返回新建的图形.">
    参数 形状 <类型 = Word图形形状 注释 = "Word图形形状.*">
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Shape对象.读无参数对象型属性 ("CanvasItems", COM对象类).对象型方法 ("AddShape", COM对象类, 形状, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

