    }

    方法 取图形 <公开 类型 = Word图形 注释 = "取出代表某个范围中的形状的Word图形类">
    参数 索引号 <类型 = 整数 注释 = "对象的索引号.从1开始,表示图形在文档图形集合中位置.为0时忽略该参数." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "对象的名称.索引号不为0时忽略该参数." @默认值 = "">
    {
        变量 局_图形 <类型 = Word图形>
        如果 (索引号 == 0)
        {
            如果 (名称 != "")
            {
                局_图形.置对象 (Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("Range", COM对象类, 名称))  // 名称取Word图形
            }
        }
        否则
        {
            局_图形.置对象 (Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("Range", COM对象类, 索引号))  // 索引号取Word图形
        }
        返回 (局_图形)
    }

    方法 添加艺术字 <公开 类型 = Word图形 注释 = "将艺术字形状添加到绘图画布上">
    参数 内容 <类型 = 文本型 注释 = "艺术字中的文字">
    参数 文本效果 <类型 = 整数 注释 = "预设文本效果." 注释 = "-2 表示混合." 注释 = "0-29 表示30个文本效果." @默认值 = 0>
    参数 字体名称 <类型 = 文本型 注释 = "艺术字中所用字体的名称" @默认值 = "宋体">
    参数 字体大小 <类型 = 整数 注释 = "艺术字中所用字体的大小" @默认值 = 36>
    参数 加粗 <类型 = 逻辑型 注释 = "艺术字字体是否加粗" @默认值 = 假>
    参数 斜体 <类型 = 逻辑型 注释 = "以斜体显示艺术字" @默认值 = 假>
    参数 左边 <类型 = 小数 注释 = "设置艺术字左边缘的位置,以磅为单位." @默认值 = 1>
    参数 上边 <类型 = 小数 注释 = "设置艺术字左边缘的位置,以磅为单位." @默认值 = 1>
    {
        变量 局_Word图形 <类型 = Word图形>
        局_Word图形.置对象 (Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddTextEffect", COM对象类, 文本效果, 内容, 字体名称, 字体大小, 选择 (加粗, -1, 0), 选择 (斜体, -1, 0), 左边, 上边))
        返回 (局_Word图形)
    }

    方法 添加画布 <公开 类型 = Word图形 注释 = "在文档中添加绘图画布">
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddCanvas", COM对象类, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

    方法 添加直线 <公开 类型 = Word图形 注释 = "向文档中添加一条直线图形,并返回新建的图形.">
    参数 起点横坐标 <类型 = 小数 注释 = "线条起点相对于文档左边缘水平位置,以磅为单位." "">
    参数 起点纵坐标 <类型 = 小数 注释 = "线条起点相对于文档上边缘垂直位置,以磅为单位." "">
    参数 终点横坐标 <类型 = 小数 注释 = "线条终点相对于文档左边缘水平位置,以磅为单位." "">
    参数 终点纵坐标 <类型 = 小数 注释 = "线条终点相对于文档上边缘垂直位置,以磅为单位." "">
    参数 颜色 <类型 = 整数 注释 = "设置新建图形的颜色,默认为黑色." @默认值 = 0>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddLine", COM对象类, 起点横坐标, 起点纵坐标, 终点横坐标, 终点纵坐标)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        局_Word图形.边框颜色 = 颜色
        返回 (局_Word图形)
    }

    方法 添加图形 <公开 类型 = Word图形 注释 = "向文档中添加一个图形,并返回新建的图形.">
    参数 形状 <类型 = Word图形形状 注释 = "Word图形形状.*.">
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddShape", COM对象类, 形状, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

    方法 添加智能图表 <公开 类型 = Word图形 注释 = "向文档中添加智能图表,并返回新建的图形.">
    参数 版式索引 <类型 = 整数 注释 = "智能图表样式索引号,索引号不能大于图表总数量.智能图表数量可通过\"Word程序.图表版式数\"获得." @默认值 = 1>
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        变量 局_版式 <类型 = COM变体型>
        局_版式 = Document对象.读无参数对象型属性 ("Application", COM对象类).读无参数对象型属性 ("SmartArtLayouts", COM对象类).方法 ("Item", COM变体型, 版式索引)
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddSmartArt", COM对象类, 局_版式, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

    方法 添加批注 <公开 类型 = Word图形 注释 = "向文档中添加添加无框线的标注,并返回新建的图形.">
    参数 内容 <类型 = 文本型 注释 = "批注中文本内容" @默认值 = "">
    参数 线 <类型 = Word标注线 注释 = "Word标注线.*,标注的类型." @默认值 = Word标注线.单段>
    参数 左边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置新建图形左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置新建图形的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置新建图形的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddCallout", COM对象类, 线, 左边, 上边, 宽度, 高度)
        局_图形.读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).写属性 ("Text", 内容)  // 向批注写入内容
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

    方法 添加文本框 <公开 类型 = Word图形 注释 = "在绘图画布上添加一个文本框">
    参数 内容 <类型 = 文本型 注释 = "艺术字中的文字">
    参数 方向 <类型 = Word文本方向 注释 = "文本的方向.其中某些常量可能不可用,这取决于您所选择或安装的语言支持." @默认值 = Word文本方向.水平>
    参数 左边 <类型 = 小数 注释 = "设置文本框左边缘的位置,以磅为单位." @默认值 = 0>
    参数 上边 <类型 = 小数 注释 = "设置文本框左边缘的位置,以磅为单位." @默认值 = 0>
    参数 宽度 <类型 = 小数 注释 = "设置文本框的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置文本框的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddTextbox", COM对象类, 方向, 左边, 上边, 宽度, 高度)
        局_图形.读无参数对象型属性 ("TextFrame", COM对象类).读无参数对象型属性 ("TextRange", COM对象类).写属性 ("Text", 内容)  // 向文本框中写入内容
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

    方法 添加图片 <公开 类型 = Word图形 注释 = "向文档中添加一个图片,并返回新建图片的Word图形类.">
    参数 图片文件名 <类型 = 文本型 注释 = "图片的路径和文件名">
    参数 链接到文件 <类型 = 逻辑型 注释 = "如果为真,则要将图片链接到创建它的文件.如果为假,则使图片文件成为独立副本." @默认值 = 真>
    参数 文档中存储 <类型 = 逻辑型 注释 = "是否随文档一起保存链接的图片" @默认值 = 假>
    参数 左边 <类型 = 小数 注释 = "设置图片左边缘的位置,以磅为单位." @默认值 = 100>
    参数 上边 <类型 = 小数 注释 = "设置图片左边缘的位置,以磅为单位." @默认值 = 100>
    参数 宽度 <类型 = 小数 注释 = "设置图片的宽度,以磅为单位." @默认值 = 100>
    参数 高度 <类型 = 小数 注释 = "设置图片的高度,以磅为单位." @默认值 = 100>
    参数 名称 <类型 = 文本型 注释 = "指定所添加对象的名称" @默认值 = "">
    {
        变量 局_图形 <类型 = COM对象类>
        变量 局_Word图形 <类型 = Word图形>
        局_图形 = Document对象.读无参数对象型属性 ("Shapes", COM对象类).对象型方法 ("AddPicture", COM对象类, 图片文件名, 链接到文件, 文档中存储, 左边, 上边, 宽度, 高度)
        如果 (名称 != "")
        {
            局_图形.写属性 ("Name", 名称)
        }
        局_Word图形.置对象 (局_图形)
        返回 (局_Word图形)
    }

