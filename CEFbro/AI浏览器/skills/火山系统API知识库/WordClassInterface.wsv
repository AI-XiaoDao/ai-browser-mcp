    }

    方法 置主题 <公开 注释 = "将主题应用于打开的文档">
    参数 主题 <类型 = Word主题 注释 = "Word主题.*,主题是不包含路径的文件夹名称,一般位于\"C:\\Program Files\\Common Files\\Microsoft Shared\\Themes\"下面." "">
    参数 鲜艳颜色 <类型 = 逻辑型 注释 = "表示要激活的主题鲜艳颜色" @默认值 = 真>
    参数 动态图形 <类型 = 逻辑型 注释 = "表示要激活的主题动态图形" @默认值 = 假>
    参数 背景图像 <类型 = 逻辑型 注释 = "表示要激活的主题背景图像" @默认值 = 假>
    {
        变量 局_主题 <类型 = 文本型>
        局_主题 = (文本型)主题 + " " + 选择 (鲜艳颜色, "1", "0") + 选择 (动态图形, "1", "0") + 选择 (背景图像, "1", "0")
        Document对象.无返回值方法 ("ApplyTheme", 局_主题)
    }

    方法 另存为 <公开 注释 = "将文档保存到其他位置" 编辑时信息 = "152A95, 0, 0, 0">
    参数 保存文件名 <类型 = 文本型 注释 = "文档的名称.默认值为当前文件夹和文件名.如果从未保存过文档,将使用默认名称(例如,Doc1.doc).如果已经存在具有指定文件名的文档,则覆盖该文档,并且在覆盖前不提示用户."
            编辑时信息 = "152A95, 0, 0, 0" @默认值 = "">
    参数 格式 <类型 = Word另存格式 注释 = "Word另存格式.*,保存文件时使用的文件格式.有关有效选项的列表,对于现有文件,默认采用上一次指定的文件格式;对于新文件,默认采用当前所用Word版本的格式."
            编辑时信息 = "152A95, 0, 0, 0" @默认值 = Word另存格式.标准>
    参数 锁定注释 <类型 = 逻辑型 注释 = "如果为真,则锁定文档注释." @默认值 = 假>
    参数 密码 <类型 = 文本型 注释 = "它是一个区分大小写的字符串(最长不超过15个字符),用于指定文件的保护密码." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = "">
    参数 写权限密码 <类型 = 文本型 注释 = "一个表示文件写保护密码的字符串.如果文件保存时带有密码,但打开文件时不输入密码,则该文件以只读方式打开." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = "">
    参数 只读方式 <类型 = 逻辑型 注释 = "如果为真,则在打开文件时显示一条消息,提示该文件以只读方式打开." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = 假>
    参数 编码语言 <类型 = Word编码 注释 = "Word编码.*,指定的文本来源编码方式." @默认值 = Word编码.简体中文>
    参数 文本换行符 <类型 = 逻辑型 注释 = "在将文档保存为文本文件时,如果该属性值为真,则在每一行文本后插入换行符." @默认值 = 真>
    参数 使用列表 <类型 = 逻辑型 注释 = "如果为真,则将该文档添加到最近使用的文件列表中." @默认值 = 假>
    {
        Document对象.无返回值方法 ("SaveAs2", 保存文件名, 格式, 锁定注释, 密码, 使用列表, 写权限密码, 只读方式, 真, 真, 假, 假, 编码语言, 文本换行符, 假)
    }

    方法 导出PDF <公开 注释 = "以PDF或XPS格式保存文档">
    参数 导出文件名 <类型 = 文本型 注释 = "文档的名称.默认值为当前文件夹和文件名.如果从未保存过文档,将使用默认名称(例如,Doc1.doc).如果已经存在具有指定文件名的文档,则覆盖该文档,并且在覆盖前不提示用户."
            编辑时信息 = "152A95, 0, 0, 0" "">
    参数 格式 <类型 = Word另存格式 注释 = "指定采用\"Word另存格式.PDF\"格式或\"Word另存格式.XPS\"格式." 编辑时信息 = "152A95, 0, 0, 0" @默认值 = Word另存格式.PDF>
    参数 打开 <类型 = 逻辑型 注释 = "导出内容后打开新文件" @默认值 = 假>
    参数 优化 <类型 = 逻辑型 注释 = "指定导出文档的分辨率和质量,值为假时,表示针对屏幕显示进行导出,质量较差,值为真时,表示以较高的质量导出." @默认值 = 真>
    参数 导出范围 <类型 = Word导出范围 注释 = "Word导出范围.*, 指定导出区域是整个文档、当前页面、文本区域还是当前所选内容.默认值为导出整个文档." @默认值 = Word导出范围.整个文档>
    参数 开始页 <类型 = 整数 注释 = "当导出范围为\"页范围\"时,则指定开始页码." @默认值 = -1>
    参数 结束页 <类型 = 整数 注释 = "当导出范围为\"页范围\"时,则指定结束页码." @默认值 = -1>
    参数 包含标记 <类型 = 逻辑型 注释 = "指定导出过程是只包括文本还是包括文本和标记" @默认值 = 假>
    参数 包括属性 <类型 = 逻辑型 注释 = "指定在最新导出的文件中是否包括文档属性" @默认值 = 假>
    参数 IRM权限 <类型 = 逻辑型 注释 = "指定是否将IRM权限复制到XPS文档,如果在源文档具有IRM保护.如果导出格式为\"PDF\",则此标志还指定是否将标签复制到PDF." @默认值 = 真>
    参数 书签 <类型 = 整数 注释 = "如果值为0,则表示不在导出的文档中创建书签." 注释 = "如果值为1,则表示在导出的文档中为每个标题创建一个书签,标题只包含主文档和文本框中的标题,不包含页眉、页脚、尾注、脚注或注释中的标题."
            注释 = "如果值为2,则表示在导出的文档中为每个书签创建一个书签,书签包括除页眉和页脚中所含书签以外的所有书签." @默认值 = 0>
    {
        变量 局_开始页 <类型 = COM变体型>
        变量 局_结束页 <类型 = COM变体型>
        如果 (开始页 != -1)
        {
            局_开始页.赋值 (开始页)
        }
        如果 (结束页 != -1)
        {
            局_结束页.赋值 (结束页)
        }
        Document对象.无返回值方法 ("ExportAsFixedFormat", 导出文件名, 格式, 打开, 选择 (优化, 0, 1), 导出范围, 局_开始页, 局_结束页, 选择 (包含标记, 7, 0), 包括属性, IRM权限, 书签)
    }

    方法 保存 <公开 注释 = "保存对指定文档所做的更改,如果此文档以前未保存过,则弹出\"另存为\"对话框并提示用户键入文件名.">
    {
        Document对象.无参数及返回值方法 ("Save")
    }

    方法 取段落 <公开 类型 = Word段落 注释 = "返回一个\"Word段落\"类,根据段落索引号取出文档中一段段落.">
    参数 索引号 <类型 = 整数 注释 = "欲取出的段落索引号,默认为0时,表示取出最后段落." @默认值 = 0>
    {
        变量 局_Word段落 <类型 = Word段落>
        如果 (索引号 == 0)
        {
            局_Word段落.置对象 (Document对象.读无参数对象型属性 ("Paragraphs", COM对象类).对象型方法 ("Last", COM对象类, 索引号))  // 表示取出的段落集合中的最后一项
        }
        否则
        {
            局_Word段落.置对象 (Document对象.读无参数对象型属性 ("Paragraphs", COM对象类).对象型方法 ("Item", COM对象类, 索引号))  // 根据段落索引号取出段落集合中的一项
        }
        返回 (局_Word段落)
    }

