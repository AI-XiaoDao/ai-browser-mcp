    方法 置字体阴影 <公开 注释 = "设置当前选区字体是否加粗">
    参数 大小 <类型 = 小数 注释 = "二选一,指定阴影大小,为0时忽略该参数." @默认值 = 0>
    参数 类型 <类型 = 整数 注释 = "二选一,范围1-20指定与形状一起显示的阴影类型.根据它们在\"绘图\"工具栏的\"阴影样式\"集合内的顺序(从左到右、从上到下)进行编号." @默认值 = 1>
    参数 颜色 <类型 = 整数 注释 = "指定阴影颜色,默认为-1,表示不指定颜色,不指定时为灰色." @默认值 = -1>
    参数 透明度 <类型 = 小数 注释 = "指定阴影透明度" @默认值 = 0>
    参数 水平偏移量 <类型 = 小数 注释 = "按指定磅值改变阴影的水平偏移量" @默认值 = 0>
    参数 垂直偏移量 <类型 = 小数 注释 = "按指定磅值更改阴影的垂直偏移量" @默认值 = 0>
    {
        变量 ShadowFormat <类型 = COM对象类>
        ShadowFormat = Range对象.读无参数对象型属性 ("Font", COM对象类).读无参数对象型属性 ("TextShadow", COM对象类)
        如果 (大小 == 0)
        {
            ShadowFormat.写属性 ("Type", 类型)  // 指定阴影大小
        }
        否则
        {
            ShadowFormat.写属性 ("Size", 大小)  // 指定阴影类型
        }
        如果 (颜色 != -1)
        {
            ShadowFormat.读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 颜色)  // 指定阴影颜色
        }
        ShadowFormat.写属性 ("Transparency", 透明度)  // 指定阴影透明度
        ShadowFormat.无返回值方法 ("IncrementOffsetX", 水平偏移量)
        ShadowFormat.无返回值方法 ("IncrementOffsetY", 垂直偏移量)
    }

