    参数 背景色 <类型 = 整数 注释 = "背景色" @默认值 = 颜色类.白色>
    {
        背景可视 = 真  // 设置背景可视为真
        Shape对象.读无参数对象型属性 ("Fill", COM对象类).读无参数对象型属性 ("ForeColor", COM对象类).写属性 ("RGB", 前景色)
        Shape对象.读无参数对象型属性 ("Fill", COM对象类).读无参数对象型属性 ("BackColor", COM对象类).写属性 ("RGB", 背景色)
        Shape对象.读无参数对象型属性 ("Fill", COM对象类).无返回值方法 ("Patterned", 图案)
    }

