    方法 置顶窗口 <公开 注释 = "设置窗口置顶状态">
    参数 索引号 <类型 = 整数 注释 = "要置顶窗口索引号" @默认值 = 1>
    参数 取消 <类型 = 逻辑型 注释 = "为真是取消窗口置顶状态" @默认值 = 假>
    {
        变量 hwnd <类型 = 变整数>
        hwnd = Application对象.读无参数对象型属性 ("Windows", COM对象类).对象型方法 ("Item", COM对象类, 1).读无参数属性 ("Hwnd", 变整数)  // 取出窗口句柄
        如果 (取消)
        {
            @ SetWindowPos((HWND)@<hwnd>, HWND_NOTOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE);
        }
        否则
        {
            @ SetWindowPos((HWND)@<hwnd>, HWND_TOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE);
        }
    }

