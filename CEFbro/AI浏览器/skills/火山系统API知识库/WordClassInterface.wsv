类 Word程序 <公开 注释 = "代表整个Word应用程序">
{
    变量 Application对象 <类型 = COM对象类>
    变量 Application事件 <类型 = COM对象事件类>

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建Word对象" 返回值注释 = "成功返回真." 返回值注释 = "失败返回假,没有安装Microsoft Office Word程序." "">
    {
        返回 (Application对象.创建 ("Word.Application", ""))
    }

    方法 获取 <公开 类型 = 逻辑型 注释 = "获取当前操作系统中已经存在的\"Word对象\"填入本对象中,本对象中的原有内容将被覆盖.">
    {
