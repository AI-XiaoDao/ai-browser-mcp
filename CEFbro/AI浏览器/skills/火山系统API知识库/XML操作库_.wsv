        {
            解析索引路径_ (节点路径).无返回值方法 ("removeAttribute", 属性名称)
        }
        否则
        {
            对象型方法 ("selectSingleNode", COM对象类, 节点路径).无返回值方法 ("removeAttribute", 属性名称)
        }
    }

    方法 取缩进源码_ <公开 类型 = 文本型 折叠>
    参数 源码文本 <类型 = 文本型>
    参数 换行文本 <类型 = 文本型>
    参数 缩进文本 <类型 = 文本型>
    参数 节点路径 <类型 = 文本型>
    参数 搜索位置 <类型 = 整数>
    参数 缩进层级 <类型 = 整数>
    {
        变量 源码文本2 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 子节点 <类型 = COM对象类>
        变量 节点名 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 j <类型 = 整数>
        源码文本2 = 源码文本
        判断循环 (真)
        {
            如果 (索引 == 0)
            {
                子节点 = 对象型方法 ("selectSingleNode", COM对象类, 节点路径).读无参数对象型属性 ("firstChild", COM对象类)
            }
            否则
            {
                子节点 = 子节点.读无参数对象型属性 ("nextSibling", COM对象类)
            }
            如果 (子节点.是否为空 ())
            {
                返回 ("")
            }
            索引 = 索引 + 1
            节点名 = 子节点.读无参数属性 ("nodeName", 文本型)
            如果 (取文本左边 (节点名, 1) == "#")
            {
                到循环尾
            }
            i = 寻找文本 (源码文本2, "<" + 节点名, 搜索位置 + 1)
            如果 (i == -1)
            {
                返回 ("")
            }
            j = 倒找文本 (源码文本2, ">")
            如果 (j != -1)
            {
                文本替换 (源码文本2, i, 取文本长度 ("<" + 节点名), 换行文本 + 取重复文本 (缩进文本, 缩进层级) + "<" + 节点名)
            }
            取缩进源码_ (源码文本2, 换行文本, 缩进文本, 节点路径 + "/" + 节点名, i, 缩进层级 + 1)
            i = 寻找文本 (源码文本2, "</" + 节点名, 搜索位置 + 1)
            如果 (i != -1)
            {
                文本替换 (源码文本2, i, 取文本长度 ("</" + 节点名), 取重复文本 (缩进文本, 缩进层级) + "</" + 节点名)
            }
            如果 (子节点.是否为空 ())
            {
                跳出循环
            }
        }
        返回 (源码文本2)
    }

    方法 插入节点_ <公开 折叠>
    参数 节点路径 <类型 = 文本型>
    参数 节点名 <类型 = 文本型>
    参数 节点值 <类型 = 文本型 @默认值 = "">
    {
        变量 新节点 <类型 = COM对象类>
        新节点 = 对象型方法 ("createElement", COM对象类, 节点名)
        如果 (文本是否为空 (节点值) == 假)
        {
            新节点.写属性 ("text", 节点值)
        }
        如果 (寻找文本 (节点路径, "@") != -1)
        {
            解析索引路径_ (节点路径).无返回值方法 ("appendChild", 新节点)
        }
        否则
        {
            对象型方法 ("selectSingleNode", COM对象类, 节点路径).无返回值方法 ("appendChild", 新节点)
        }
    }

    方法 插入属性_ <公开 折叠>
    参数 节点路径 <类型 = 文本型>
    参数 属性名 <类型 = 文本型>
    参数 属性值 <类型 = 文本型>
    {
        变量 新属性 <类型 = COM对象类>
        新属性 = 对象型方法 ("createAttribute", COM对象类, 属性名)
        新属性.写属性 ("Text", 属性值)
        如果 (寻找文本 (节点路径, "@") != -1)
        {
            解析索引路径_ (节点路径).无返回值方法 ("setAttributeNode", 新属性)
        }
        否则
        {
            对象型方法 ("selectSingleNode", COM对象类, 节点路径).无返回值方法 ("setAttributeNode", 新属性)
        }
    }

    方法 取所有节点名_ <公开 类型 = 文本数组类 折叠>
    {
        返回 (递归取节点名_ (取根节点名_ ()))
    }

    方法 递归取节点名_ <公开 类型 = 文本数组类 折叠>
    参数 节点路径 <类型 = 文本型 注释 = "例如：\"body/data/row\"、\"body/data/row[1]\"">
    {
        变量 存放变量 <类型 = 文本数组类>
        变量 索引 <类型 = 整数>
        变量 节点名 <类型 = 文本型>
        变量 子节点 <类型 = COM对象类>
        判断循环 (真)
        {
            如果 (索引 == 0)
            {
                子节点 = 对象型方法 ("selectSingleNode", COM对象类, 节点路径).读无参数对象型属性 ("firstChild", COM对象类)
            }
            否则
            {
                子节点 = 子节点.读无参数对象型属性 ("nextSibling", COM对象类)
            }
            如果 (子节点.是否为空 ())
            {
                跳出循环
            }
            索引 = 索引 + 1
            节点名 = 子节点.读无参数属性 ("nodeName", 文本型)
            如果 (取文本左边 (节点名, 1) == "#")
            {
                到循环尾
            }
            节点名 = 节点路径 + "/" + 节点名
            存放变量.加入成员 (节点名)
            存放变量.添加数组 (递归取节点名_ (节点名))
            如果 (子节点.是否为空 ())
            {
                跳出循环
            }
        }
        返回 (存放变量)
    }
}
