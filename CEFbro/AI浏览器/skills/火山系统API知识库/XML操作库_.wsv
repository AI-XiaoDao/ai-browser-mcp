    方法 到源码_ <公开 类型 = 文本型 折叠>
    参数 文本编码 <类型 = 文本型 @默认值 = "UTF-16">
    参数 换行文本 <类型 = 文本型 注释 = "\\r\\n" @默认值 = "">
    参数 缩进文本 <类型 = 文本型 注释 = "\\t" @默认值 = "">
    {
        变量 缓存文本 <类型 = 文本型>
        变量 文本位置1 <类型 = 整数>
        变量 文本位置2 <类型 = 整数>
        // <?xml version="1.0" encoding="UTF-8" standalone="no" ?>
        缓存文本 = 读无参数属性 ("xml", 文本型)
        文本位置1 = 寻找文本 (缓存文本, "encoding=\"", , 真)
        文本位置2 = 寻找文本 (缓存文本, "\"", 文本位置1 + 10)
        如果 (文本位置1 != -1 && 文本位置2 != -1)
        {
            文本替换 (缓存文本, 文本位置1, 文本位置2 - 文本位置1 + 1, "encoding=\"" + 文本编码 + "\"")
        }
        否则
        {
            子文本替换 (缓存文本, "?>", "encoding=\"" + 文本编码 + "\" ?>", , 1)
        }
        如果 (文本是否为空 (换行文本) == 假)
        {
            子文本替换 (缓存文本, "\r", "")
            子文本替换 (缓存文本, "\n", "")
            子文本替换 (缓存文本, "</", 换行文本 + "</")
            子文本替换 (缓存文本, "?>", "?>" + 换行文本)
        }
        如果 (文本是否为空 (缩进文本) == 假)
        {
            文本位置1 = 寻找文本 (缓存文本, "<")
            如果 (文本位置1 != -1)
            {
                取缩进源码_ (缓存文本, "\r\n", " ", 取根节点名_ (), 文本位置1 + 取文本长度 (取根节点名_ ()), 1)
            }
        }
        返回 (缓存文本)
    }

