    方法 解析索引路径_ <公开 类型 = COM对象类 折叠>
    参数 节点路径 <类型 = 文本型>
    {
        变量 单个路径 <类型 = 文本数组类>
        变量 根部节点 <类型 = COM对象类>
        变量 儿子节点 <类型 = COM对象类>
        变量 孙子节点 <类型 = COM对象类>
        变量 节点数量 <类型 = 整数>
        变量 节点名称 <类型 = 文本型>
        变量 路径类型 <类型 = 逻辑型>
        变量 索引数组 <类型 = 整数数组类>
        变量 节点索引 <类型 = 整数>
        分割子文本 (节点路径, "/", 单个路径)
        根部节点 = 读无参数对象型属性 ("documentElement", COM对象类)
        单个路径.枚举循环 ()
        {
            如果 (单个路径.取枚举索引 () > 0)
            {
                索引数组.删除所有成员 ()
                路径类型 = 取文本左边 (单个路径.取枚举值 (), 1) == "@"
                节点数量 = 根部节点.读无参数对象型属性 ("childNodes", COM对象类).读无参数属性 ("length", 整数)
                计次循环 (节点数量)
                {
                    如果 (取循环索引 () == 0)
                    {
                        儿子节点 = 根部节点.读无参数对象型属性 ("firstChild", COM对象类)
                    }
                    否则
                    {
                        儿子节点 = 儿子节点.读无参数对象型属性 ("nextSibling", COM对象类)
                    }
                    节点名称 = 儿子节点.读无参数属性 ("nodeName", 文本型)
                    如果 (取文本左边 (节点名称, 1) != "#")
                    {
                        如果 (路径类型)
                        {
                            索引数组.加入成员 (取循环索引 ())
                        }
                        否则 (节点名称 == 单个路径.取枚举值 ())
                        {
                            根部节点 = 根部节点.读无参数对象型属性 ("childNodes", COM对象类).读对象型属性 ("item", COM对象类, 取循环索引 ())
                            跳出循环
                        }
                    }
                }
                如果 (路径类型)
                {
                    节点索引 = 文本到整数 (取文本右边 (单个路径.取枚举值 (), 取文本长度 (单个路径.取枚举值 ()) - 1)) - 1
                    如果 (节点索引 < 0)
                    {
                        节点索引 = 0
                    }
                    如果 (节点索引 > 索引数组.取最大索引 ())
                    {
                        节点索引 = 索引数组.取最大索引 ()
                    }
                    如果 (节点索引 >= 0)
                    {
                        根部节点 = 根部节点.读无参数对象型属性 ("childNodes", COM对象类).读对象型属性 ("item", COM对象类, 索引数组.取成员 (节点索引))
                    }
                }
            }
        }
        返回 (根部节点)
    }

