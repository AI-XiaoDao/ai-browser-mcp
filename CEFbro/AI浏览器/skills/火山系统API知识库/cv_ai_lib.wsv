类 CV多目标跟踪器TLD <公开 注释 = "MultiTracker,多目标跟踪器,头文件冲突暂时无法使用.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::legacy::MultiTracker> obj;
    # <> </include>
    # @end

    方法 添加_单个目标 <公开 类型 = 逻辑型 注释 = "add,加入成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 加入跟踪器 <类型 = CV单目标跟踪器>
    参数 初始图像 <类型 = CV矩阵类>
    参数 初始ROI <类型 = CV矩形类小数>
    {
        @ if(obj == nullptr) return false;
        @ return obj->add(@<加入跟踪器>.obj,@<初始图像>.obj, @<初始ROI>.obj);
    }

    方法 添加_多个目标 <类型 = 逻辑型 注释 = "add,加入成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 加入跟踪器 <类型 = CV单目标跟踪器容器>
    参数 初始图像 <类型 = CV矩阵类>
    参数 初始ROI <类型 = CV矩形类小数容器>
    {
        @ if(obj == nullptr) return false;
        @ return obj->add(@<加入跟踪器>.obj,@<初始图像>.obj, @<初始ROI>.obj);
    }

    方法 更新ROI <公开 类型 = 逻辑型 注释 = "update,更新成功返回真,否则返回假,更新后用函数  获取目标ROI 获得跟踪框." @禁止流程检查 = 真>
    参数 更新图像 <类型 = CV矩阵类>
    {
        @ if(obj==nullptr)return false;
        @ return obj->update(@<更新图像>.obj);
    }

    方法 更新ROI_1 <公开 类型 = 逻辑型 注释 = "update,更新成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 更新图像 <类型 = CV矩阵类>
    参数 输出目标ROI <类型 = CV矩形类小数容器>
    {
        @ if(obj==nullptr)return false;
        @ return obj->update(@<更新图像>.obj, @<输出目标ROI>.obj);
    }

    方法 获取目标ROI <公开 类型 = CV矩形类小数容器>
    {
        变量 返回容器 <类型 = CV矩形类小数容器>
        @ if(obj!=nullptr)
        @     @<返回容器>.obj = obj->getObjects();
        返回 (返回容器)
    }
}

类 CV直方图比较方法常量 <公开 注释 = "HistCompMethods" @常量类 = 整数>
{
    常量 相关性 <公开 值 = 0 注释 = "0,HISTCMP_CORREL,相互关系.">
    常量 卡方检验 <公开 值 = 1 注释 = "1,HISTCMP_CHISQR,卡方检验.">
    常量 交集 <公开 值 = 2 注释 = "2,HISTCMP_INTERSECT,交集.">
    常量 巴氏距离 <公开 值 = 3 注释 = "3,HISTCMP_BHATTACHARYYA, 巴氏距离(实际上是OpenCV计算 Hellinger距离,这与 巴氏距离 系数有关. ).">
    常量 Hellinger距离 <公开 值 = 3 注释 = "3,HISTCMP_HELLINGER,同 巴氏距离.">
    常量 纹理比较 <公开 值 = 4 注释 = "4,HISTCMP_CHISQR_ALT,这个替代公式经常用于纹理比较.">
    常量 相对熵散度 <公开 值 = 5 注释 = "5,HISTCMP_KL_DIV,Kullback-Leibler 相对熵散度.">
}

类 CV图像分割掩膜常量 <公开 注释 = "GrabCutModes" @常量类 = 整数>
{
    常量 确定背景 <公开 值 = 0 注释 = "0,GC_BGD,确定的背景像素.">
    常量 确定前景 <公开 值 = 1 注释 = "1,GC_FGD,确定的前景像素.">
    常量 不确定背景 <公开 值 = 2 注释 = "2,GC_PR_BGD,可能的背景像素.">
    常量 不确定前景 <公开 值 = 3 注释 = "3,GC_PR_FGD,可能的前景像素.">
}

类 CV漫水填充常量 <公开 注释 = "FloodFillFlags" @常量类 = 整数>
{
    常量 固定范围 <公开 值 = 65536 注释 = "65536,FLOODFILL_FIXED_RANGE,如果设置,则考虑当前像素与种子像素之间的差值. 否则考虑相邻像素之间的差异(即范围是浮动的).">
    常量 仅使用掩膜 <公开 值 = 131072 注释 = "131072,FLOODFILL_MASK_ONLY,如果设置了,函数不会改变图像(newVal被忽略),只填充使用前面描述的标志位8-16中指定的值的掩码."
            注释 = "此选项只会使用于有mask参数的函数变体.">
}

类 CV图像分割模式常量 <公开 注释 = "GrabCutModes" "">
{
    变量 用矩形初始化 <公开 静态 类型 = 整数 值 = 0 注释 = "0，GC_INIT_WITH_RECT，该函数使用提供的矩形初始化状态和掩码，之后它运行算法的iterCount迭代">
    变量 用掩膜初始化 <公开 静态 类型 = 整数 值 = 1 注释 = "1，该函数使用提供的掩码初始化状态，请注意,初始化矩形掩膜和 初始化掩膜 可以组合使用。" 注释 = "ROI之外的所有像素为使用GC_BGD自动初始化。">
    变量 执行分割 <公开 静态 类型 = 整数 值 = 2 注释 = "2，GC_EVAL,这个值意味着算法会继续。">
    变量 使用固定模式运行 <公开 静态 类型 = 整数 值 = 3 注释 = "3，GC_EVAL_FREEZE_MODEL,该值意味着算法应该只使用固定模型运行grabCut算法(一次迭代)。">
}

类 CV比较类型常量 <公开 注释 = "CmpTypes" @常量类 = 整数>
{
    常量 等于 <公开 值 = 0 注释 = "0,CMP_EQ,等于.">
    常量 大于 <公开 值 = 1 注释 = "1,CMP_GT,大于.">
    常量 大于等于 <公开 值 = 2 注释 = "2,CMP_GE,大于等于.">
    常量 小于 <公开 值 = 3 注释 = "3,CMP_LT,小于.">
    常量 小于等于 <公开 值 = 4 注释 = "4,CMP_LE,小于等于.">
    常量 不等于 <公开 值 = 5 注释 = "5,CMP_NE,不等于.">
}

类 CV矩阵分解常量 <公开 注释 = "DecompTypes" @常量类 = 整数>
{
    常量 高斯消元法 <公开 值 = 0 注释 = "0,DECOMP_LU,选择最佳主元的高斯消元法.">
    常量 奇异值分解法 <公开 值 = 1 注释 = "1,DECOMP_SVD,奇异值分解法;系统可以被过度定义和/或矩阵Src1可以是单数.">
    常量 特征值分解 <公开 值 = 2 注释 = "2,DECOMP_EIG,特征值分解;矩阵src1必须是对称的.">
    常量 柯列斯基分解法 <公开 值 = 3 注释 = "3,DECOMP_CHOLESKY,柯列斯基\\ f $ LL ^ T \\ f $分解;矩阵src1必须是对称且正的.">
    常量 QR分解 <公开 值 = 4 注释 = "4,DECOMP_QR,QR分解;系统可以是过定义的,并且/或者矩阵src1可以是奇异的.">
    常量 标准分解法 <公开 值 = 16 注释 = "16,DECOMP_NORMAL,虽然前面的所有标志都是互斥的,但此标志可以与之一起使用先前的:先前的任何一个;这意味着法线方程"
            注释 = "${src1}^T\\cdot{src1}\\cdot{dst}={src1}^T{src2}$是解决了,而不是原来的系统${src1}\\cdot{dst}={src2}$.">
}

类 CV归一化常量 <公开 注释 = "NormTypes" @常量类 = 整数>
{
    常量 无穷大归一化 <公开 值 = 1 注释 = "1,NORM_INF,beta值无用；输出矩阵的数值为,原始矩阵数值除以矩阵最大值的结果,alpha可以控制倍数.">
    常量 L1归一化 <公开 值 = 2 注释 = "2,NORM_L1,beta值无用；输出矩阵的数值为,原始矩阵数值除以矩阵数据绝对值和的结果,alpha可以控制倍数.">
    常量 L2归一化 <公开 值 = 4 注释 = "4,NORM_L2,beta值无用；输出矩阵的数值为,原始矩阵数值除以矩阵数据平方和再开根号的结果,alpha可以控制倍数.">
    常量 L2平方根归一化 <公开 值 = 5 注释 = "5,NORM_L2SQR,类似于L2归一化,并将 L2归一化结果作平方根处理.">
    常量 汉明窗口归一化 <公开 值 = 6 注释 = "6,NORM_HAMMING,使用汉明窗口归一化,在只有一个输入数组的情况下,计算数组从零到汉明距离," 注释 = "在两个输入数组的情况下,计算数组之间的汉明距离.">
    常量 汉明窗口归一化2 <公开 值 = 7 注释 = "7,NORM_HAMMING2,与  汉明窗口归一化  类似,但在计算中,输入序列的每两个位都将被添加," 注释 = "并作为单个位在与  汉明窗口归一化  相同的计算中使用.">
    常量 类型掩膜归一化 <公开 值 = 7 注释 = "7,NORM_TYPE_MASK,同汉明窗口归一化.">
    常量 相对归一化 <公开 值 = 8 注释 = "8,NORM_RELATIVE,使用相对归一化.">
    常量 最值归一化 <公开 值 = 32 注释 = "9,NORM_MINMAX,alpha和beta的最大值是归一化的最大值,两者的最小值是归一化的最小值,alpha为1,beta为0,同alpha为0,beta为1,是一致的.">
}

