    }

    方法 获取元素数量 <公开 类型 = 整数 注释 = "getWTA_K" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getWTA_K();
    }

    方法 设置得分类型 <公开 注释 = "setScoreType">
    参数 值 <类型 = 整数 注释 = "HARRIS_SCORE=0,哈里斯得分" 注释 = "FAST_SCORE=1    ,快速分值">
    {
        @ if(obj == nullptr) return;
        @ if(@<值>==0){ obj->setScoreType(cv::ORB::ScoreType::HARRIS_SCORE);}
        @ else{ obj->setScoreType(cv::ORB::ScoreType::FAST_SCORE);}
    }

    方法 获取得分类型 <公开 类型 = 整数 注释 = "getScoreType" 返回值注释 = "HARRIS_SCORE=0,哈里斯得分" 返回值注释 = "FAST_SCORE=1    ,快速分值" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ cv::ORB::ScoreType rr = obj->getScoreType();
        @ if(rr==cv::ORB::ScoreType::HARRIS_SCORE){return 0;}
        @ else{return 1;}
    }

    方法 设置斑块尺寸 <公开 注释 = "setPatchSize">
