    参数 输出置信度 <类型 = 小数类 注释 = "推理结果的置信度,其值范围为 0-1,如果如果未成功预测时  输出置信度==-1.">
    {
        @ if(obj == nullptr) return;
        @ lite::types::Age age;
        @ obj->detect(@<输入图像>.obj, age);
        @ if(age.flag==false){@<输出年龄.值> = -1;@<输出置信度.值> = -1;}
        @ else{@<输出年龄.值> = age.age;@<输出置信度.值> = age.interval_prob;}
    }
}

