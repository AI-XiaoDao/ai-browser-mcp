    常量 顶部起始 <公开 值 = 1 注释 = "1,CC_STAT_TOP,最上边的(y)坐标,它是边界框在水平方向上的起始点.">
    常量 边框宽度 <公开 值 = 2 注释 = "2,CC_STAT_WIDTH,边框的水平大小.">
    常量 边框高度 <公开 值 = 3 注释 = "3,CC_STAT_HEIGHT,边框的垂直大小.">
    常量 连接总面积 <公开 值 = 4 注释 = "4,CC_STAT_AREA,连接组件的总面积(以像素为单位).">
    常量 最大枚举值 <公开 值 = 5 注释 = "5,CC_STAT_MAX,最大枚举值. 仅在内部用于内存分配.">
}

类 CV连通域算法常量 <公开 注释 = "ConnectedComponentsAlgorithmsTypes" @常量类 = 整数>
{
    常量 默认 <公开 值 = -1 注释 = "-1,CCL_DEFAULT,8-邻域使用BBDT算法,4-邻域用SAUF算法.">
    常量 WU算法 <公开 值 = 0 注释 = "0,CCL_WU,8-邻域和4-邻域均用SAUF算法.">
    常量 GRANA算法 <公开 值 = 1 注释 = "1,CCL_GRANA,8-邻域使用BBDT算法,4-邻域用SAUF算法.">
    常量 BOLELLI算法 <公开 值 = 2 注释 = "2,CCL_BOLELLI,8-邻域使用Bolelli2019算法,4-邻域用Bolelli2021算法.">
    常量 SAUF算法 <公开 值 = 3 注释 = "3,CCL_SAUF,和WU算法相同.">
    常量 BBDT算法 <公开 值 = 4 注释 = "4,CCL_BBDT,和GRANA算法相同.">
    常量 SPAGHETTI算法 <公开 值 = 5 注释 = "5,CCL_SPAGHETTI,和BOLELLI算法算法相同.">
}

类 CV轮廓提取算法常量 <公开 注释 = "RetrievalModes" @常量类 = 整数>
{
    常量 只检测最外层轮廓 <公开 值 = 0 注释 = "0,RETR_EXTERNAL,只检索最外部轮廓.">
    常量 检测所有轮廓 <公开 值 = 1 注释 = "1,RETR_LIST检索所有轮廓而不建立任何层次关系.">
    常量 检测所有轮廓并建双层立层次关系 <公开 值 = 2 注释 = "2,RETR_CCOMP检索所有轮廓并将其组织为两级层次结构. 在顶层,有组件的外部边界.  在第二层,有洞的边界."
            注释 = "如果一个连接组件的孔内有另一个轮廓,它仍然放在顶层 .">
    常量 检测所有轮廓并建立完整层次关系 <公开 值 = 3 注释 = "3,RETR_TREE,检索所有轮廓并重新构造嵌套轮廓的完整层次结构.">
    常量 使用漫水填充提取轮廓 <公开 值 = 4 注释 = "4,RETR_FLOODFILL,漫水填充算法.">
}

类 CV轮廓逼近算法常量 <公开 注释 = "ContourApproximationModes" @常量类 = 整数>
{
    常量 无近似逼近 <公开 值 = 1 注释 = "1,CHAIN_APPROX_NONE,存储所有的等高线点. 也就是任意2个后续点(x1,y1)和" 注释 = "等高线的(x2,y2)为水平、垂直或对角相邻,即:"
            注释 = "Max(abs (x1, x2)), abs (y2-y1)) = = 1.">
    常量 近似逼近 <公开 值 = 2 注释 = "2,CHAIN_APPROX_SIMPLE,压缩水平、垂直和对角线段,只留下它们的端点." 注释 = "例如,一个直立的矩形轮廓用4个点编码.">
    常量 链近似算法_L1 <公开 值 = 3 注释 = "3,CHAIN_APPROX_TC89_L1,应用了一种Teh-Chin链近似算法@cite TehChin89.">
    常量 链近似算法_KCOS <公开 值 = 4 注释 = "4,CHAIN_APPROX_TC89_KCOS,应用了一种Teh-Chin链近似算法@cite TehChin89.">
}

类 CV形状匹配方法常量 <公开 注释 = "ShapeMatchModes" @常量类 = 整数>
{
    常量 算法1 <公开 值 = 1
            注释 = "1,CONTOURS_MATCH_I1,f[I_1(A,B) =  \\sum _{i=1...7}  \\left |  \\frac{1}{m^A_i} -  \\frac{1}{m^B_i} \\right |].">
    常量 算法2 <公开 值 = 2 注释 = "2,CONTOURS_MATCH_I2,f[I_2(A,B) =  \\sum _{i=1...7}  \\left | m^A_i - m^B_i  \\right |].">
    常量 算法3 <公开 值 = 3
            注释 = "3,CONTOURS_MATCH_I3,f[I_3(A,B) =  \\max _{i=1...7}  \\frac{ \\left| m^A_i - m^B_i \\right| }{ \\left| m^A_i \\right| }].">
}

类 CV霍夫变换方法常量 <公开 注释 = "HoughModes" @常量类 = 整数>
{
    常量 标准变换 <公开 值 = 0 注释 = "0,HOUGH_STANDARD,经典或标准霍夫变换.  每行由两个浮点数表示"
            注释 = "     数字 $(\\rho, \\theta)$ ,其中 $\\rho$ 是 (0,0) 点和线之间的距离," 注释 = "     $\\theta$ 是 x 轴与直线法线之间的角度.  因此,矩阵必须"
            注释 = "     是(创建的序列将是)浮点2通道32位 类型.">
    常量 概率变换 <公开 值 = 1 注释 = "1,HOUGH_PROBABILISTIC,概率霍夫变换(如果图片包含几长线性段).  它返回线段而不是整条线."
            注释 = " 每个段都是由起点和终点表示,并且矩阵必须是(创建的序列将是) CV_32SC4 类型.">
    常量 多尺度缩放 <公开 值 = 2 注释 = "2,HOUGH_MULTI_SCALE,经典霍夫变换的多尺度变体.  这些行的编码方式与     HOUGH_STANDARD 相同.">
    常量 梯度变换 <公开 值 = 3 注释 = "3,HOUGH_GRADIENT,使用梯度变换提取.">
    常量 梯度变换高精度 <公开 值 = 4 注释 = "4,HOUGH_GRADIENT_ALT,梯度变换 的变体,可以获得更好的精度.">
}

类 CV直线检测LSD方法常量 <公开 注释 = "LineSegmentDetectorModes" @常量类 = 整数>
{
    常量 未细分应用 <公开 值 = 0 注释 = "0,LSD_REFINE_NONE,未细分应用.">
    常量 应用标准细化 <公开 值 = 1 注释 = "1,LSD_REFINE_STD,应用标准细化.  例如.  将拱门分解成更小的直线近似值.">
    常量 进阶细化 <公开 值 = 2 注释 = "2,LSD_REFINE_ADV,进阶细化.  计算误报数量,通过增加精度、减小尺寸等来细化线条.">
}

类 CV直线检测LSD <注释 = "LineSegmentDetector">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::LineSegmentDetector> obj;
    # <> </include>
    # @end

    方法 检测图像 <公开 注释 = "detect,检测灰度图像中存在的直线.">
    参数 源图像 <类型 = CV矩阵类 注释 = "必须为灰度(CV_8UC1)输入图像">
    参数 输出直线向量 <类型 = CV向量容器4f 注释 = "输出的向量如     向量[x1,y1, x2,y2],其方向与梯度变化方向相关.">
    {
        @ if(obj ==nullptr)return;
        @ obj->detect(@<源图像>.obj, @<输出直线向量>.obj);
    }

    方法 绘制线段 <公开 注释 = "drawSegments,在指定图像中绘制线段.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制到的图像">
    参数 输入直线向量 <类型 = CV向量容器4f 注释 = "欲绘制的线段">
    {
        @ if(obj ==nullptr)return;
        @ obj->drawSegments(@<源图像>.obj, @<输入直线向量>.obj);
    }

    方法 绘制两线段非交集 <公开 注释 = "compareSegments,可以用蓝色和红色绘制两组线(可选项),计算非重叠(不匹配)像素.">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "两组线段所在的图像尺寸">
    参数 输入线段1 <类型 = CV向量容器4f 注释 = "欲绘制的线段1">
    参数 输入线段2 <类型 = CV向量容器4f 注释 = "欲绘制的线段2">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制到的图像,为空时不绘制出线段." @默认值 = 空对象>
    {
        @ if(obj ==nullptr)return;
        如果 (源图像 != 空对象)
        {
            @ obj->compareSegments(@<图像尺寸>.obj, @<输入线段1>.obj, @<输入线段2>.obj, @<源图像>.obj);
        }
        否则
        {
            @ obj->compareSegments(@<图像尺寸>.obj, @<输入线段1>.obj, @<输入线段2>.obj);
        }
    }

    方法 创建LSD直线检测器 <公开 注释 = "createLineSegmentDetector,创建一个LSD直线检测器.">
    参数 直线检测器方法 <类型 = CV直线检测LSD方法常量 @默认值 = CV直线检测LSD方法常量.应用标准细化>
    参数 缩放因子 <类型 = 小数 注释 = "用于寻找线条的图像的比例. 范围(0 . . 1)" @默认值 = 0.8>
    参数 高斯滤波sigma缩放因子 <类型 = 小数 注释 = "sigma = 高斯滤波sigma缩放因子/缩放因子" @默认值 = 0.6>
    参数 量化误差 <类型 = 小数 注释 = "量化绑定到梯度范数上的量化误差" @默认值 = 2>
    参数 角度误差 <类型 = 小数 注释 = "以十进制度为单位的梯度角度公差" @默认值 = 22.5>
    参数 检测阈值 <类型 = 小数 注释 = "-log10(检测阈值) , 仅在选择高级细化时使用." @默认值 = 0>
    参数 最小密度 <类型 = 小数 注释 = "在外接矩形中对齐区域点的最小密度" @默认值 = 0.7>
    参数 bins数量 <类型 = 整数 注释 = "梯度模伪排序中的bins数量" @默认值 = 1024>
    {
        @ obj = cv::createLineSegmentDetector(@<直线检测器方法>, @<缩放因子>, @<高斯滤波sigma缩放因子>, @<量化误差>, @<角度误差>, @<检测阈值>, @<最小密度>, @<bins数量>);
    }
}

类 CV单目标跟踪器容器 <注释 = "std::vector<cv::Ptr<cv::Ptr<cv::legacy::Tracker>>">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # std::vector<cv::Ptr<cv::legacy::Tracker>> obj;
    # <> </include>
    # @end

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV单目标跟踪器 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "返回指定索引的 CV单目标跟踪器" @禁止流程检查 = 真>
    参数 成员索引 <类型 = 整数>
    {
        变量 返回跟踪器 <类型 = CV单目标跟踪器>
        @  @<返回跟踪器>.obj =  obj[@<成员索引>];
        返回 (返回跟踪器)
    }

    方法 加入成员 <公开 注释 = "将一个所指定类型的成员值加入到本容器(数组)的尾部">
    参数 新值 <类型 = CV单目标跟踪器>
    {
        @ obj.push_back(@<新值>.obj);
    }

    方法 清除成员 <公开 注释 = "清除容器内的所有成员">
    {
        @ obj.clear();
    }
}

类 CV目标跟踪器 <公开 注释 = "Tracker,基本跟踪器,可以创建多种跟踪器算法跟踪目标.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::Tracker> obj;
    # <> </include>
    # @end

    方法 初始化 <公开 注释 = "init,初始化跟踪器,确定目标位置,初始图像.">
    参数 初始图像 <类型 = CV矩阵类>
    参数 初始ROI <类型 = CV矩形类>
    {
        @ if(obj == nullptr) return;
        @ obj->init(@<初始图像>.obj, @<初始ROI>.obj);
    }

    方法 更新跟踪器 <公开 注释 = "update,更新跟踪器.">
    参数 更新图像 <类型 = CV矩阵类>
    参数 更新ROI <类型 = CV矩形类 注释 = "输出目标矩形">
    {
        @ if(obj == nullptr) return;
        @ obj->update(@<更新图像>.obj, @<更新ROI>.obj);
    }

    方法 创建MIL跟踪器 <公开 注释 = "TrackerMIL::create">
    {
        @ obj = cv::TrackerMIL::create();
    }

    方法 创建GOTURN跟踪器 <公开 注释 = "TrackerGOTURN::create">
    {
        @ obj = cv::TrackerGOTURN::create();
    }

    方法 创建DaSiamRPN跟踪器 <公开 注释 = "TrackerDaSiamRPN::create">
    {
        @ obj = cv::TrackerDaSiamRPN::create();
    }

    方法 创建KFC跟踪器 <公开 注释 = "TrackerKCF::create">
    {
        @ obj = cv::TrackerKCF::create();
    }

    方法 创建CSRT跟踪器 <公开 注释 = "TrackerCSRT::create">
    {
        @ obj = cv::TrackerCSRT::create();
    }
}

类 CV单目标跟踪器 <注释 = "cv::legacy::Tracker,可以加入到 CV多目标跟踪器TLD 中,实现多目标的跟踪.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::legacy::Tracker> obj;
    # <> </include>
    # @end

    方法 初始化 <公开 注释 = "init,初始化跟踪器,确定目标位置,初始图像.">
    参数 初始图像 <类型 = CV矩阵类>
    参数 初始ROI <类型 = CV矩形类>
    {
        @ if(obj == nullptr) return;
        @ obj->init(@<初始图像>.obj, @<初始ROI>.obj);
    }

    方法 更新跟踪器 <公开 注释 = "update,更新跟踪器.">
    参数 更新图像 <类型 = CV矩阵类>
    参数 更新ROI <类型 = CV矩形类 注释 = "输出目标矩形">
    {
        @ if(obj == nullptr) return;
        @ cv::Rect2d newRoi((double)@<更新ROI>.obj.x, (double)@<更新ROI>.obj.y, (double)@<更新ROI>.obj.width, (double)@<更新ROI>.obj.height);
        @ obj->update(@<更新图像>.obj, newRoi);
        @ @<更新ROI>.obj = cv::Rect((int)newRoi.x, (int)newRoi.y, (int)newRoi.width, (int)newRoi.height);
    }

    方法 创建MIL跟踪器 <公开 注释 = "TrackerMIL::create">
    {
        @ obj = cv::legacy::TrackerMIL::create();
    }

    方法 创建KFC跟踪器 <公开 注释 = "TrackerKCF::create">
    {
        @ obj = cv::legacy::TrackerKCF::create();
    }

    方法 创建Boosting跟踪器 <公开 注释 = "TrackerBoosting::create">
    {
        @ obj = cv::legacy::TrackerBoosting::create();
    }
}

类 CV目标跟踪器_CSRT参数结构体类 <注释 = "TrackerCSRT::Params">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::tracking::TrackerCSRT::Params obj;
    # <> </include>
    # @end

    方法 使用Hog检测 <公开 属性写 注释 = "use_hog">
    参数 使用 <类型 = 逻辑型>
    {
        @ obj.use_hog = @<使用>;
    }

    方法 使用颜色命名 <公开 属性写 注释 = "use_color_names">
    参数 使用 <类型 = 逻辑型>
    {
        @ obj.use_hog = @<使用>;
    }

    方法 使用灰度图 <公开 属性写 注释 = "use_gray">
