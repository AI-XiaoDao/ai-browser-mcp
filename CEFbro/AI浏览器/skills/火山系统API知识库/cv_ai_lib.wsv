    方法 两斑点最小距离 <公开 属性读 类型 = 小数 注释 = "minDistBetweenBlobs" @禁止流程检查 = 真>
    {
        @ return obj.minDistBetweenBlobs;
    }

    方法 颜色过滤 <公开 属性读 类型 = 逻辑型 注释 = "filterByColor" 返回值注释 = "为真时过滤颜色" @禁止流程检查 = 真>
    {
        @ return obj.filterByColor;
    }

    方法 斑点颜色值 <公开 属性读 类型 = 整数 注释 = "blobColor" @禁止流程检查 = 真>
    {
        @ return obj.blobColor;
    }

    方法 面积过滤 <公开 属性读 类型 = 逻辑型 注释 = "filterByArea" 返回值注释 = "为真时过滤面积" @禁止流程检查 = 真>
    {
        @ return obj.filterByArea;
    }

    方法 最小面积 <公开 属性读 类型 = 小数 注释 = "minArea" @禁止流程检查 = 真>
    {
        @ return obj.minArea;
    }

    方法 最大面积 <公开 属性读 类型 = 小数 注释 = "maxArea" @禁止流程检查 = 真>
    {
        @ return obj.maxArea;
    }

    方法 圆完整度过滤 <公开 属性读 类型 = 逻辑型 注释 = "filterByCircularity" 返回值注释 = "为真时过滤圆完整度" @禁止流程检查 = 真>
    {
        @ return obj.filterByCircularity;
    }

    方法 最小圆完整度 <公开 属性读 类型 = 小数 注释 = "minCircularity" @禁止流程检查 = 真>
