        @ if(obj==nullptr)return -1;
        @ return obj->getNLevels();
    }

    方法 设置边缘阈值 <公开 注释 = "setEdgeThreshold">
    参数 值 <类型 = 整数>
    {
        @ if(obj == nullptr) return;
        @ obj->setEdgeThreshold(@<值>);
    }

    方法 获取边缘阈值 <公开 类型 = 整数 注释 = "getEdgeThreshold" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getEdgeThreshold();
    }

    方法 设置第一个层级 <公开 注释 = "setFirstLevel">
    参数 值 <类型 = 整数>
    {
        @ if(obj == nullptr) return;
        @ obj->setFirstLevel(@<值>);
    }

    方法 获取第一个层级 <公开 类型 = 整数 注释 = "getFirstLevel" @禁止流程检查 = 真>
