类 CV迭代算法标志类 <公开 注释 = "TermCriteria,指示算法停止条件、迭代次数等.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::TermCriteria obj;
    # <> </include>
    # @end

    方法 构建 <公开 静态 类型 = CV迭代算法标志类 注释 = "cv::TermCriteria,构建一个算法迭代标志.">
    参数 算法类型 <类型 = 整数 注释 = "算法类型," 注释 = "1、COUNT=1" 注释 = "2、EPS=2" 注释 = "3、MAX_ITER=COUNT=1,最大迭代"
            注释 = "可以用两个算法,如 1+2 = 3    或者   位或(MAX_ITER, EPS)">
    参数 迭代次数 <类型 = 整数>
    参数 停止精度 <类型 = 小数>
    {
        变量 返回标志 <类型 = CV迭代算法标志类>
        @ @<返回标志>.obj = cv::TermCriteria(@<算法类型>, @<迭代次数>, @<停止精度>);
        返回 (返回标志)
    }
}

类 CV坐标容器 <公开 注释 = "std::vector<cv::Point>,存储CV坐标点的容器(数组).">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # std::vector<cv::Point> obj;
    # <> </include>
    # @end

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" 返回值注释 = "返回成员个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV坐标点 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "CV坐标点">
    参数 成员索引 <类型 = 整数>
    {
        变量 坐标 <类型 = CV坐标点>
        @ @<坐标>.obj = obj[@<成员索引>];
        返回 (坐标)
    }

    方法 加入成员 <公开 注释 = "将一个所指定类型的成员值加入到本容器(数组)的尾部">
    参数 被加入点 <类型 = CV坐标点>
    {
        @ obj.push_back(@<被加入点>.obj);
    }

    方法 清除成员 <公开 注释 = "清除容器内的所有成员">
    {
        @ obj.clear();
    }
}

类 CV坐标2f容器 <公开 注释 = "std::vector<cv::Point2f>,存储CV坐标点2f的容器(数组).">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
