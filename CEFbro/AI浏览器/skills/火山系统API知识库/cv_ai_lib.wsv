    }

    方法 设置非裁剪比例 <公开 注释 = "setUnclipRatio,设置网络非裁剪比例参数.">
    参数 非裁剪比例 <类型 = 小数 注释 = "它决定输出ROI区域的大小,参数值范围0-1." @默认值 = 0.5>
    {
        @ if(obj == nullptr) return;
        @ static_cast<cv::dnn::TextDetectionModel_DB*>(obj)->setUnclipRatio((float)@<非裁剪比例>);
    }

    方法 获取非裁剪比例 <公开 类型 = 小数 注释 = "getUnclipRatio,获取非裁剪比例参数." @禁止流程检查 = 真>
    {
        @ if(obj == nullptr) return -1;
        @ return static_cast<cv::dnn::TextDetectionModel_DB*>(obj)->getUnclipRatio();
    }

    方法 设置最大候选个数 <公开 注释 = "setMaxCandidates,设置网络最大候选个数.">
    参数 候选目标个数 <类型 = 整数 注释 = "设定输出结果的最大数目">
    {
        @ if(obj == nullptr) return;
        @ static_cast<cv::dnn::TextDetectionModel_DB*>(obj)->setMaxCandidates(@<候选目标个数>);
    }

    方法 获取最大候选个数 <公开 类型 = 整数 注释 = "getMaxCandidates,获取最大候选个数." @禁止流程检查 = 真>
    {
        @ if(obj == nullptr) return -1;
        @ return static_cast<cv::dnn::TextDetectionModel_DB*>(obj)->getMaxCandidates();
    }
}

类 DNN神经网络 <公开 注释 = "DNN,原生的DNN模型输入输出均是矩阵,操作比较麻烦,在4.x后衍生了简易的模型:" 注释 = "DNN模型类、DNN分类模型、DNN关键点检测模型、DNN语义分割模型、DNN对象检测模型."
        @禁止创建对象 = 真>
{
    方法 读入DarkNet <公开 静态 类型 = NET网络类 注释 = "readNetFromDarknet,读入DarkNet框架训练的模型文件." 返回值注释 = "返回网络NET网络类">
