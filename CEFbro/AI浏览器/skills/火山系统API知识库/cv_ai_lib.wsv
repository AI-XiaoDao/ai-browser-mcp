类 CV参数表类 <公开 注释 = "结构体表示statmodel参数的对数网格范围" 注释 = "它通过改变模型参数来优化状态模型的精度,通过交叉验证来计算精度估计.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # Ptr<cv::ml::ParamGrid> obj;
    # <> </include>
    # @end

    方法 创建参数表 <公开 类型 = CV参数表类>
    参数 最小值 <类型 = 小数 注释 = "statmodel参数的最小值. 缺省值为0" @默认值 = 0>
    参数 最大值 <类型 = 小数 注释 = "statmodel参数的最大值. 默认值为0" @默认值 = 0>
    参数 对数 <类型 = 小数 注释 = "网格是对数的,因此 logStep 必须始终大于 1. 默认值为 1." @默认值 = 1>
    {
        @ obj = new cv::ml::ParamGrid(@<最小值>, @<最大值>, @<对数>);
        返回 (本对象)
    }

    方法 最小值 <公开 属性读 类型 = 小数 @禁止流程检查 = 真>
    {
        @ return obj->minVal;
    }

    方法 最大值 <公开 属性读 类型 = 小数 @禁止流程检查 = 真>
    {
        @ return obj->maxVal;
    }

    方法 最小值 <公开 属性写>
    参数 值 <类型 = 小数>
    {
        @ obj->minVal = @<值>;
    }

    方法 最大值 <公开 属性写>
    参数 值 <类型 = 小数>
    {
        @ obj->maxVal= @<值>;
    }

    方法 对数 <公开 属性读 类型 = 小数 注释 = "网格确定   静态模型  参数值的以下迭代序列:"
            注释 = "[(minVal, minVal*step, minVal*{step}^2, \\dots, minVal*{logStep}^n),]"
            注释 = "是满足的最大索引[\\textt {minVal} * \\textt {logStep} ^n < \\textt {maxVal}]" 注释 = "网格是对数的,因此logStep必须总是大于1. 缺省值为1."
            @禁止流程检查 = 真>
    {
        @ return obj->logStep;
    }

    方法 对数 <公开 属性写>
    参数 值 <类型 = 小数>
    {
        @ obj->logStep = @<值>;
    }
}

类 CV贝叶斯分类器 <公开 注释 = "NormalBayesClassifier,朴素贝叶斯分类器.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # Ptr<cv::ml::NormalBayesClassifier> obj;
    # <> </include>
    # @end

    方法 获取变量数量 <公开 类型 = 整数 注释 = "getVarCount" @禁止流程检查 = 真>
    {
        @ return obj->getVarCount();
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty" 返回值注释 = "为空返回真" @禁止流程检查 = 真>
    {
        @ return obj->empty();
    }

    方法 是否已训练 <公开 类型 = 逻辑型 注释 = "isTrained" 返回值注释 = "已训练返回真" @禁止流程检查 = 真>
    {
        @ return obj->isTrained();
    }

    方法 是否为分类器 <公开 类型 = 逻辑型 注释 = "isClassifier" 返回值注释 = "为分类器返回真,为回归模型返回假." @禁止流程检查 = 真>
    {
        @ return obj->isClassifier();
    }

    方法 训练模型_从训练数据 <公开 注释 = "train,使用 CV训练数据类 训练分类器.">
    参数 训练样本 <类型 = CV训练数据类 注释 = "存储了多个训练样本的 CV训练数据类">
    参数 训练标志 <类型 = 整数 注释 = "可选标志,这取决于模型. 控件可以更新一些模型新的训练样本,不完全覆盖." 注释 = "参数值如下:" 注释 = "UPDATE_MODEL = 1,更新模型."
            注释 = "RAW_OUTPUT=1, 使方法返回原始结果(和),而不是类标签." 注释 = "COMPRESSED_INPUT=2,压缩的输入样本." 注释 = "PREPROCESSED_INPUT=4,预处理的输入样本."
            @默认值 = 0>
    {
        @ obj->train(@<训练样本>.obj, @<训练标志>);
    }

    方法 训练模型_从矩阵 <公开 注释 = "train,使用 CV矩阵类 样本训练分类器.">
    参数 训练样本 <类型 = CV矩阵类 注释 = "存储了多个样本的矩阵">
    参数 训练类型 <类型 = CV样本类型常量 注释 = "指定是行样本还是列样本" "">
    参数 响应矩阵 <类型 = CV矩阵类 注释 = "放标签一类的矩阵">
    {
        @ obj->train(@<训练样本>.obj, @<训练类型>,@<响应矩阵>.obj);
    }

    方法 获取误差 <公开 注释 = "calcError,该方法使用 预测 来计算误差. 对于回归模型,误差计算为RMS,用于分类器-作为误分类样本的百分比(0%-100%).">
    参数 训练样本 <类型 = CV训练数据类 注释 = "存储了多个训练样本的 CV训练数据类">
    参数 测试子集误差 <类型 = 逻辑型 注释 = "如果为真,则在数据的测试子集上计算误差,否则在数据的训练子集上计算误差. 请注意,如果您加载了一个完全不同的数据集来评估已经训练的分类器,"
            注释 = "您可能根本不希望使用  CV训练数据类.设置训练样本比例    设置测试子集并指定 测试=假,以便为整个新集计算偏差." "">
    参数 输出响应矩阵 <类型 = CV矩阵类>
    {
        @ obj->calcError(@<训练样本>.obj, @<测试子集误差>, @<输出响应矩阵>.obj);
    }

    方法 预测 <公开 类型 = 小数 注释 = "predict,对矩阵作预测." @禁止流程检查 = 真>
    参数 欲预测矩阵 <类型 = CV矩阵类 注释 = "可以是一维的多通道矩阵">
    参数 输出结果 <类型 = CV矩阵类 @默认值 = 空对象>
    参数 标志 <类型 = 整数 @默认值 = 0>
    {
        @ if(@<输出结果>==NULL){return obj->predict(@<欲预测矩阵>.obj, noArray(), @<标志>);}
        @ else{return obj->predict(@<欲预测矩阵>.obj, @<输出结果>.obj, @<标志>);}
    }

    方法 创建模型 <公开 注释 = "create">
    {
        @ obj = cv::ml::NormalBayesClassifier::create();
    }

    方法 载入模型 <公开 注释 = "load,从文件中载入模型.">
    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件">
    参数 节点文件 <类型 = 文本型 注释 = "包含节点名的文件" @默认值 = "">
    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ obj=  cv::ml::NormalBayesClassifier::load(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<节点文件>.GetText (), memBuf2, NULL));
    }

    方法 保存模型 <公开 注释 = "save,保存模型到文件.">
    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件">
    {
        @ @an<CVolMem> memBuf1;
        @ obj->save(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL));
    }
}

