    # <> </include>
    # @end

    方法 创建风格迁移分类器 <公开>
    参数 模型权重文件 <类型 = 文本型 注释 = "onnx格式模型文件,现成的开源模型有以下几个：" 注释 = "style-mosaic-8.onnx：马赛克风格." 注释 = "style-pointilism-8.onnx：点描风格."
            注释 = "style-udnie-8.onnx：世界名画《udnie》风格." 注释 = "style-rain-princess-8.onnx：世界名画《rain princess》风格.">
    参数 线程数 <类型 = 整数 注释 = "一般设置为1个线程,并不是线程越多速度越快,需要多次试验调试获取最佳速度." @默认值 = 1>
    {
        @ if (obj!=nullptr) delete obj;
        @ @an<CVolMem> memBuf1;
        @ obj = new lite::onnxruntime::cv::style::FastStyleTransfer(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL),@<线程数>);
    }

    方法 预测图像 <公开 注释 = "对输入的图像作推理">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲作风格迁移的图像">
    参数 输出迁移风格图像 <类型 = CV矩阵类 注释 = "迁移后的风格图像">
    参数 推理成功 <类型 = 逻辑型类 注释 = "推理成功时输出值为真,否则为假.">
    {
        @ if(obj == nullptr) return;
        @ lite::types::StyleContent style_;
        @ obj->detect(@<输入图像>.obj, style_);@<推理成功.值>=style_.flag;
        @ if(style_.flag==true){style_.mat.copyTo( @<输出迁移风格图像>.obj); }
    }
}

