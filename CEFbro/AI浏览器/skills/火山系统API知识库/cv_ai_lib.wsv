类 DNN计算后端常量 <公开 注释 = "Backend" @常量类 = 整数>
{
    常量 自动指定设备 <公开 值 = 0 注释 = "0,DNN_BACKEND_DEFAULT,自动指定设备." "">
    常量 OpenGL管道 <公开 值 = 1 注释 = "1,DNN_BACKEND_HALIDE,采用OpenGL的管道图像处理." "">
    常量 英特尔推理引擎 <公开 值 = 2 注释 = "2,DNN_BACKEND_INFERENCE_ENGINE,采用英特尔推理引擎." "">
    常量 Opencv推理引擎 <公开 值 = 3 注释 = "3,DNN_BACKEND_OPENCV,采用Opencv推理引擎." "">
    常量 VKCOM推理引擎 <公开 值 = 4 注释 = "4,DNN_BACKEND_VKCOM,采用VKCOM推理引擎." "">
    常量 英伟达CUDA推理引擎 <公开 值 = 5 注释 = "5,DNN_BACKEND_CUDA,采用英伟达CUDA推理引擎." "">
}

类 DNN计算目标常量 <公开 注释 = "Target" @常量类 = 整数>
{
    常量 CPU推理 <公开 值 = 0 注释 = "0,DNN_TARGET_CPU,使用CPU推理." "">
    常量 OPENCL推理 <公开 值 = 1 注释 = "1,DNN_TARGET_OPENCL,使用OPENCL推理." "">
    常量 OPENCL_FP16推理 <公开 值 = 2 注释 = "2,DNN_TARGET_OPENCL_FP16,使用OPENCL_FP16推理." "">
    常量 MYRIAD推理 <公开 值 = 3 注释 = "3,DNN_TARGET_MYRIAD,使用MYRIAD推理." "">
    常量 VULKAN推理 <公开 值 = 4 注释 = "4,DNN_TARGET_VULKAN,使用VULKAN推理." "">
    常量 FPGA推理 <公开 值 = 5 注释 = "5,DNN_TARGET_FPGA,使用FPGA推理." "">
    常量 英伟达CUDA推理 <公开 值 = 6 注释 = "6,DNN_TARGET_CUDA,使用英伟达CUDA推理.">
    常量 英伟达CUDA_FP16推理 <公开 值 = 7 注释 = "7,DNN_TARGET_CUDA_FP16,使用英伟达CUDA_FP16推理.">
}

类 NET网络类 <公开 注释 = "NET,DNN神经网络类.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::dnn::Net obj;
    # <> </include>
    # @end

    方法 设置后端计算设备 <公开 注释 = "setPreferableBackend,当支持指定设备时,将后端计算设备设置为该设备.">
    参数 计算设备 <类型 = DNN计算后端常量 @默认值 = DNN计算后端常量.自动指定设备>
    {
        如果 (计算设备 == DNN计算后端常量.自动指定设备)
        {
            @ obj.setPreferableBackend(cv::dnn::DNN_BACKEND_DEFAULT);
        }
        如果 (计算设备 == DNN计算后端常量.VKCOM推理引擎)
        {
            @ obj.setPreferableBackend(cv::dnn::DNN_BACKEND_VKCOM);
        }
        如果 (计算设备 == DNN计算后端常量.英伟达CUDA推理引擎)
        {
            @ obj.setPreferableBackend(cv::dnn::DNN_BACKEND_CUDA);
        }
        如果 (计算设备 == DNN计算后端常量.OpenGL管道)
        {
            @ obj.setPreferableBackend(cv::dnn::DNN_BACKEND_HALIDE);
        }
        如果 (计算设备 == DNN计算后端常量.Opencv推理引擎)
        {
            @ obj.setPreferableBackend(cv::dnn::DNN_BACKEND_OPENCV);
        }
    }

    方法 设置目标计算设备 <公开 注释 = "setPreferableTarget,当支持指定设备时,将目标结果计算设备设置为该设备.">
    参数 计算设备 <类型 = DNN计算目标常量>
    {
        如果 (计算设备 == DNN计算目标常量.CPU推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_CPU);
        }
        如果 (计算设备 == DNN计算目标常量.英伟达CUDA推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_CUDA);
        }
        如果 (计算设备 == DNN计算目标常量.FPGA推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_FPGA);
        }
        如果 (计算设备 == DNN计算目标常量.MYRIAD推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_MYRIAD);
        }
        如果 (计算设备 == DNN计算目标常量.OPENCL推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_OPENCL);
        }
        如果 (计算设备 == DNN计算目标常量.VULKAN推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_VULKAN);
        }
        如果 (计算设备 == DNN计算目标常量.英伟达CUDA_FP16推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_CUDA_FP16);
        }
        如果 (计算设备 == DNN计算目标常量.OPENCL_FP16推理)
        {
            @ obj.setPreferableTarget(cv::dnn::DNN_TARGET_OPENCL_FP16);
        }
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty,为空时返回真." @禁止流程检查 = 真>
    {
        @ return obj.empty();
    }

    方法 转存 <公开 类型 = 文本型 注释 = "dump, 具有结构、超参数、后端、目标和融合的字符串 setInput() 之后的调用方法.  在 forward() 之后查看正确的后端、目标和融合运行." @禁止流程检查 = 真>
    {
        @ return obj.dump().c_str();
    }

    方法 转存到文件 <公开 注释 = "dumpToFile,将网络保存到文件.">
    参数 输出文件 <类型 = 文本型 注释 = "欲保存的文件路径">
    {
        @ @an<CVolMem> memBuf1;
        @ obj.dumpToFile( GetMbsText (@<输出文件>.GetText (), memBuf1, NULL));
    }

    方法 添加层 <公开 类型 = 整数 注释 = "addLayer,在网络中添加网络层." 返回值注释 = "返回层的唯一 ID,失败时返回-1." @禁止流程检查 = 真>
    参数 层名 <类型 = 文本型>
    参数 类型 <类型 = 文本型>
    参数 层参数 <类型 = DNN层参数类>
    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ return obj.addLayer(GetMbsText (@<层名>.GetText (), memBuf1, NULL), GetMbsText (@<类型>.GetText (), memBuf2, NULL), @<层参数>.obj);
    }

    方法 添加层到最后 <公开 类型 = 整数 注释 = "addLayerToPrev,将网络层添加到网络最后." 返回值注释 = "返回层的唯一 ID,失败时返回-1." @禁止流程检查 = 真>
    参数 层名 <类型 = 文本型>
    参数 类型 <类型 = 文本型>
    参数 层参数 <类型 = DNN层参数类>
    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ return obj.addLayerToPrev(GetMbsText (@<层名>.GetText (), memBuf1, NULL), GetMbsText (@<类型>.GetText (), memBuf2, NULL), @<层参数>.obj);
    }

    方法 获取层ID <公开 类型 = 整数 注释 = "getLayerId" 返回值注释 = "返回网络层的ID" @禁止流程检查 = 真>
    参数 层名 <类型 = 文本型 注释 = "需要获取层的名称">
    {
        @ @an<CVolMem> memBuf1;
        @ return obj.getLayerId(GetMbsText (@<层名>.GetText (), memBuf1, NULL));
    }

    方法 获取所有层名称 <公开 类型 = CV文本容器 注释 = "getLayerNames" 返回值注释 = "返回所有层的名称的文本数组(容器)">
    {
        变量 返回容器 <类型 = CV文本容器>
        @ @<返回容器>.obj = obj.getLayerNames();
        返回 (返回容器)
    }

    方法 设置输入张量名 <公开 注释 = "setInputsNames">
    参数 张量名数组 <类型 = CV文本容器 注释 = "包含张量名称的文本数组(容器)">
    {
        @ obj.setInputsNames(@<张量名数组>.obj);
    }

    方法 设置输入尺寸 <公开 注释 = "setInputShape,设置输入张量的尺寸.">
    参数 张量名 <类型 = 文本型 注释 = "需要设置的张量名称">
    参数 尺寸 <类型 = CV整数容器 注释 = "需要设置的尺寸">
    {
        @ @an<CVolMem> memBuf1;
        @ obj.setInputShape(GetMbsText (@<张量名>.GetText (), memBuf1, NULL), @<尺寸>.obj);
    }

    方法 前向运算 <公开 类型 = CV矩阵类 注释 = "forward,针对单输出的网络." 返回值注释 = "返回预测张量">
    参数 输出张量名 <类型 = 文本型 注释 = "输出层名" @默认值 = "">
    {
        变量 输出张量 <类型 = CV矩阵类>
        @ @an<CVolMem> memBuf1;
        @ @<输出张量>.obj = obj.forward(GetMbsText (@<输出张量名>.GetText (), memBuf1, NULL));
        返回 (输出张量)
    }

    方法 前向运算多输出层 <公开 注释 = "forward,针对多输出的网络.">
    参数 输出张量 <类型 = CV矩阵类容器>
    参数 输出张量名 <类型 = CV文本容器 注释 = "需要获取所有输出层名">
    {
        @ obj.forward(@<输出张量>.obj, @<输出张量名>.obj);
    }

    方法 前向运算多输出张量 <公开 注释 = "forward,针对多输出的网络.">
    参数 输出张量 <类型 = CV矩阵类容器>
    参数 输出层名称 <类型 = 文本型 注释 = "指定输出层,当为空时对整个网络前向运算" @默认值 = "">
    {
        @ @an<CVolMem> memBuf1;
        @ obj.forward(@<输出张量>.obj, GetMbsText (@<输出层名称>.GetText (), memBuf1, NULL));
    }

    方法 设置输入张量 <公开 注释 = "setInput,在这个函数后接  前向运算  函数就可以获得推理结果了.">
    参数 输入张量 <类型 = CV矩阵类 注释 = "使用DNN中的函数 创建输入张量从图像 创建的张量.">
    参数 输入层名 <类型 = 文本型 注释 = "默认为空,张量的输入层名  input layer." @默认值 = "">
    参数 缩放比例 <类型 = 小数 注释 = "对输入张量作缩放处理的缩放因子,一般为1不缩放." @默认值 = 1.0>
    参数 图像均值 <类型 = CV标量类 注释 = "为空时不做处理,图像将减去这个标量,必须与输入张量有相同的维度." @默认值 = 空对象>
    {
        变量 临时_图像均值 <类型 = CV标量类>
        如果 (图像均值 != 空对象)
        {
            临时_图像均值 = 图像均值
        }
        @ @an<CVolMem> memBuf1;
        @ obj.setInput(@<输入张量>.obj, GetMbsText (@<输入层名>.GetText (), memBuf1, NULL), @<缩放比例>, @<临时_图像均值>.obj);
    }

    方法 设置层参数 <公开 注释 = "setParam,为一个层设置新的参数.">
    参数 层名 <类型 = 文本型 注释 = "网络层的名称">
    参数 参数索引 <类型 = 整数 注释 = "网络层中参数的索引">
    参数 输入张量 <类型 = CV矩阵类 注释 = "需要设置的参数">
    {
        @ @an<CVolMem> memBuf1;
        @ obj.setParam(GetMbsText (@<层名>.GetText (), memBuf1, NULL), @<参数索引>, @<输入张量>.obj);
    }

    方法 获取层参数 <公开 类型 = CV矩阵类 注释 = "getParam,获取指定层名的指定索引的参数." 返回值注释 = "返回网络层参数矩阵">
    参数 层名 <类型 = 文本型 注释 = "网络层的名称">
    参数 参数索引 <类型 = 整数 注释 = "网络层中参数的索引">
    {
        变量 返回Blob <类型 = CV矩阵类>
        @ @an<CVolMem> memBuf1;
        @ @<返回Blob>.obj = obj.getParam(GetMbsText (@<层名>.GetText (), memBuf1, NULL), @<参数索引>);
        返回 (返回Blob)
    }

    方法 获取所有未连接层ID <公开 类型 = CV整数容器 注释 = "getUnconnectedOutLayers,返回所有未连接的网络层索引.">
    {
        变量 返回容器 <类型 = CV整数容器>
        @ @<返回容器>.obj = obj.getUnconnectedOutLayers();
        返回 (返回容器)
    }

    方法 获取所有未连接层名称 <公开 类型 = CV文本容器 注释 = "getUnconnectedOutLayersNames,返回所有未连接的网络层名称.">
    {
        变量 返回容器 <类型 = CV文本容器>
        @ @<返回容器>.obj = obj.getUnconnectedOutLayersNames();
        返回 (返回容器)
    }
}

类 DNN模型类 <注释 = "Model,简化了DNN输入输出操作." @禁止创建对象 = 真>
{

    # @begin
    # <> <include>
    # cv::dnn::Model *obj=nullptr;
    # inline_ void @an<_OnCleanupExtra>() { if (obj != nullptr) delete obj; }
    # <> </include>
    # @end

    方法 设置后端计算设备 <公开 注释 = "setPreferableBackend,当支持指定设备时,将后端计算设备设置为该设备.">
    参数 计算设备 <类型 = DNN计算后端常量 @默认值 = DNN计算后端常量.自动指定设备>
    {
        @ if(obj == nullptr) return;
        如果 (计算设备 == DNN计算后端常量.自动指定设备)
        {
            @ obj->setPreferableBackend(cv::dnn::DNN_BACKEND_DEFAULT);
        }
        如果 (计算设备 == DNN计算后端常量.VKCOM推理引擎)
        {
            @ obj->setPreferableBackend(cv::dnn::DNN_BACKEND_VKCOM);
        }
        如果 (计算设备 == DNN计算后端常量.英伟达CUDA推理引擎)
        {
            @ obj->setPreferableBackend(cv::dnn::DNN_BACKEND_CUDA);
        }
        如果 (计算设备 == DNN计算后端常量.OpenGL管道)
        {
            @ obj->setPreferableBackend(cv::dnn::DNN_BACKEND_HALIDE);
        }
        如果 (计算设备 == DNN计算后端常量.Opencv推理引擎)
        {
            @ obj->setPreferableBackend(cv::dnn::DNN_BACKEND_OPENCV);
        }
    }

    方法 设置目标计算设备 <公开 注释 = "setPreferableTarget,当支持指定设备时,将目标结果计算设备设置为该设备.">
    参数 计算设备 <类型 = DNN计算目标常量>
    {
        @ if(obj == nullptr) return;
        如果 (计算设备 == DNN计算目标常量.CPU推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_CPU);
        }
        如果 (计算设备 == DNN计算目标常量.英伟达CUDA推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_CUDA);
        }
        如果 (计算设备 == DNN计算目标常量.FPGA推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_FPGA);
        }
        如果 (计算设备 == DNN计算目标常量.MYRIAD推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_MYRIAD);
        }
        如果 (计算设备 == DNN计算目标常量.OPENCL推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_OPENCL);
        }
        如果 (计算设备 == DNN计算目标常量.VULKAN推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_VULKAN);
        }
        如果 (计算设备 == DNN计算目标常量.英伟达CUDA_FP16推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_CUDA_FP16);
        }
        如果 (计算设备 == DNN计算目标常量.OPENCL_FP16推理)
        {
            @ obj->setPreferableTarget(cv::dnn::DNN_TARGET_OPENCL_FP16);
        }
    }

    方法 设置输入尺寸 <公开 注释 = "setInputSize,设置输入张量尺寸.">
    参数 宽度 <类型 = 整数 注释 = "张量(矩阵)宽度">
    参数 高度 <类型 = 整数 注释 = "张量(矩阵)高度">
    {
        @ if(obj == nullptr) return;
        @ obj->setInputSize(@<宽度>, @<高度>);
    }

    方法 设置输入均值 <公开 注释 = "setInputMean,设置输入值张量各通道均值.">
    参数 均值 <类型 = CV标量类 注释 = "每个通道的均值,需要根据网络设置文件设置.">
    {
        @ if(obj == nullptr) return;
        @ obj->setInputMean(@<均值>.obj);
    }

    方法 设置输入缩放因子 <公开 注释 = "setInputScale,设置输入张量缩放因子.">
    参数 缩放因子 <类型 = 小数 注释 = "对输入的张量元素值作缩放的缩放因子">
    {
        @ if(obj == nullptr) return;
        @ obj->setInputScale(@<缩放因子>);
    }

    方法 设置输入是否裁剪 <公开 注释 = "setInputCrop,设置是否对输入张量作裁剪.">
    参数 是否裁剪 <类型 = 逻辑型 注释 = "crop标志,表示图像在调整大小后是否被裁剪." @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->setInputCrop(@<是否裁剪>);
    }

    方法 设置输入是否调换BR通道 <公开 注释 = "setInputSwapRB,有的网络输入是RGB排列," 注释 = "但opencv的通道是BGR排列,则需要调BR换通道.">
    参数 是否调换 <类型 = 逻辑型 注释 = "swapRB交换第一个和最后一个通道的标志" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->setInputSwapRB(@<是否调换>);
    }

    方法 设置模型参数 <公开 注释 = "setInputParams,设置输入张量的参数.">
    参数 缩放比例 <类型 = 小数 注释 = "将图片减去平均值之后,还可以对剩下的像素值进行一定的尺度缩放,它的默认值是1,如果希望减去平均像素之后的值." @默认值 = 1.0>
    参数 网络尺寸 <类型 = CV尺寸类 注释 = "这个参数是我们神经网络在训练的时候要求输入的图片尺寸" "">
    参数 颜色均值 <类型 = CV标量类 注释 = "设置输入张量的各通道均值" "">
    参数 图像RB顺序 <类型 = 逻辑型 注释 = "OpenCV中认为我们的图片通道顺序是BGR,但是我平均值假设的顺序是RGB,所以如果需要交换R和G,那么就要使 图像RB顺序=true." @默认值 = 假>
    参数 裁剪图像 <类型 = 逻辑型 注释 = "指示图像在调整大小后是否裁剪" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->setInputParams(@<缩放比例>, @<网络尺寸>.obj, @<颜色均值>.obj, @<图像RB顺序>, @<裁剪图像>);
    }

    方法 预测图像 <公开 注释 = "predict,使用DNN模型预测图像">
    参数 输入张量 <类型 = CV矩阵类 注释 = "欲预测的张量">
    参数 输出结果 <类型 = CV矩阵类 注释 = "输出的结果矩阵,矩阵为一维向量,需要根据模型获取其输出结果.">
    {
        @ if(obj == nullptr) return;
        @ obj->predict(@<输入张量>.obj, @<输出结果>.obj);
    }
}

类 DNN分类模型 <公开 基础类 = DNN模型类 注释 = "ClassificationModel,简化输出的图像分类模型.">
{

    # @ <include>
    # @ inline_ void @an<_OnCleanupExtra>() { if (obj != nullptr) { delete (cv::dnn::ClassificationModel*)obj; obj = nullptr; } }
    # @ </include>

    方法 创建模型从文件 <公开 注释 = "从支持的网络格式的文件创建一个网络模型">
    参数 模型权重文件 <类型 = 文本型 注释 = "包含网络各层权重的文件">
    参数 网络设置文件 <类型 = 文本型 注释 = "包含网络层设置描述的文件,有的模型不需要该文件所以为空." @默认值 = "">
    {
        @ if (obj != nullptr) delete (cv::dnn::ClassificationModel*)obj;
        @ @an<CVolMem> memBuf1,memBuf2;
        @ obj =new cv::dnn::ClassificationModel(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<网络设置文件>.GetText (), memBuf2, NULL));
    }

    方法 创建模型从NET <公开 注释 = "从NET类中创建分类网络">
    参数 输入网络 <类型 = NET网络类 注释 = "需要从其中创建分类网络的NET">
    {
        @ if (obj != nullptr) delete (cv::dnn::ClassificationModel*)obj;
        @ obj =new cv::dnn::ClassificationModel(@<输入网络>.obj);
    }

    方法 分类预测 <公开 注释 = "classify,对图像作分类.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲检测图像">
    参数 输出ID <类型 = 整数 注释 = "输出分类结果ID,如第3类就输出结果就是3.">
    参数 输出置信度 <类型 = 小数类 注释 = "输出结果的置信度">
    {
        @ if(obj == nullptr) return;
        @ float confidence=-1.0;
        @ static_cast<cv::dnn::ClassificationModel*>(obj)->classify(@<输入图像>.obj, @<输出ID>, confidence);
        @ @<输出置信度.值> = confidence;
    }
}

