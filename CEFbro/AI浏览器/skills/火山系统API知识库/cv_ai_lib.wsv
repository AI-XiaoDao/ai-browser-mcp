类 CV视频 <公开 注释 = "VideoCapture,可以操作相机、视频文件."
        "@视窗.附属文件.release-x64" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460_64.dll"
        "@视窗.附属文件.debug-x64" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460d.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460_64.dll"
        "@视窗.附属文件.release-win32" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460.dll"
        "@视窗.附属文件.debug-win32" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460d.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460.dll">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     cap = objCopyFrom.cap;
    # }
    # cv::VideoCapture cap;
    # inline_ void @an<_OnCleanupExtra> (){if(cap.isOpened()) cap.release();};
    # <> </include>
    # @end

    方法 关闭 <公开 注释 = "release,释放视频(或者相机).">
    {
        @ if(cap.isOpened()) cap.release();
    }

    方法 打开视频 <公开 类型 = 逻辑型 注释 = "open,打开一个视频文件." 返回值注释 = "打开成功返回真,否则返回假" @禁止流程检查 = 真 "">
    参数 视频地址 <类型 = 文本型 注释 = "可以是一个视频,或者是一个网络视频地址" 注释 = "protocol: //host:port/script_name?script_params|auth">
    参数 设备类型 <类型 = CV视频设备类型常量 @默认值 = CV视频设备类型常量.任意设备>
    {
        @ @an<CVolMem> memBuf1;
        @ return (cap.isOpened() ? FALSE : cap.open(GetMbsText (@<视频地址>.GetText (), memBuf1, NULL),(int)@<设备类型>));
    }

    方法 打开相机 <公开 类型 = 逻辑型 注释 = "open,打开一个相机驱动设备." 返回值注释 = "打开成功返回真,否则返回假" @禁止流程检查 = 真>
    参数 相机索引 <类型 = 整数 注释 = "欲打开的相机索引">
    参数 设备类型 <类型 = CV视频设备类型常量 @默认值 = CV视频设备类型常量.任意设备>
    {
        @ return (cap.isOpened() ? FALSE : cap.open(@<相机索引>,(int)@<设备类型>));
    }

    方法 打开视频_多参数 <公开 类型 = 逻辑型 注释 = "open,打开一个视频文件." 返回值注释 = "打开成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 视频地址 <类型 = 文本型 注释 = "可以是一个视频,或者是一个网络视频地址" 注释 = "protocol: //host:port/script_name?script_params|auth">
    参数 设备类型 <类型 = CV视频设备类型常量 @默认值 = CV视频设备类型常量.任意设备>
    参数 打开参数 <类型 = CV整数容器 注释 = "具体参数查看  CV视频属性常量, 格式为[属性1,属性值1,属性2,属性值2]">
    {
        @ @an<CVolMem> memBuf1;
        @ return (cap.isOpened() ? FALSE : cap.open(GetMbsText (@<视频地址>.GetText (), memBuf1, NULL),(int)@<设备类型>, @<打开参数>.obj));
    }

    方法 打开相机_多参数 <公开 类型 = 逻辑型 注释 = "open,打开一个相机驱动设备." 返回值注释 = "打开成功返回真,否则返回假" @禁止流程检查 = 真>
    参数 相机索引 <类型 = 整数 注释 = "欲打开的相机索引">
    参数 设备类型 <类型 = CV视频设备类型常量 @默认值 = CV视频设备类型常量.任意设备>
    参数 打开参数 <类型 = CV整数容器 注释 = "具体参数查看  CV视频属性常量, 格式为[属性1,属性值1,属性2,属性值2]">
    {
        @ return (cap.isOpened() ? FALSE : cap.open(@<相机索引>,(int)@<设备类型>, @<打开参数>.obj));
    }

    方法 是否已打开 <公开 类型 = 逻辑型 注释 = "isOpened,判断视频是否已经打开." 返回值注释 = "如果已打开返回真,否则返回假" @禁止流程检查 = 真>
    {
        @ return cap.isOpened();
    }

    方法 取当前帧 <公开 类型 = 逻辑型 注释 = "获取视频(相机)的当前帧图像(矩阵)" 返回值注释 = "获取成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 当前帧图片 <类型 = CV矩阵类 注释 = "输出当前帧图像(矩阵)">
    {
        @ return cap.read(@<当前帧图片>.obj);
    }

    方法 当前帧时间戳 <公开 属性读 类型 = 小数 注释 = "视频当前点的毫秒值或视频捕捉的时间戳" @禁止流程检查 = 真>
    {
        @ return cap.get(cv::CAP_PROP_POS_MSEC);
    }

    方法 总帧数 <公开 属性读 类型 = 小数 注释 = "下次将被捕获的0基索引的帧" 返回值注释 = "返回视频的总帧数" @禁止流程检查 = 真>
    {
        @ return cap.get(cv::CAP_PROP_FRAME_COUNT);
    }

    方法 帧率 <公开 属性读 类型 = 小数 返回值注释 = "返回视频的帧率" @禁止流程检查 = 真>
    {
        @ return cap.get(cv::CAP_PROP_FPS);
    }

    方法 宽度 <公开 属性读 类型 = 整数 注释 = "视频流帧的宽度" 返回值注释 = "返回视频流图像(矩阵)的宽度" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_FRAME_WIDTH);
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "视频流帧的高度" 返回值注释 = "返回视频流图像(矩阵)的高度" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_FRAME_HEIGHT);
    }

    方法 亮度 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回取相机的亮度参数" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_BRIGHTNESS);
    }

    方法 对比度 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回相机的对比度参数" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_CONTRAST);
    }

    方法 饱和度 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回相机的饱和度参数" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_SATURATION);
    }

    方法 色调 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回相机的色调参数" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_HUE);
    }

    方法 增益 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回相机的增益(gain)参数" @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_GAMMA);
    }

    方法 曝光 <公开 属性读 类型 = 整数 注释 = "只对相机" 返回值注释 = "返回相机的曝光参数(有的相机为us,有的为负数,根据不同厂家的设置有所不同)." @禁止流程检查 = 真>
    {
        @ return (@dt<整数>)cap.get(cv::CAP_PROP_EXPOSURE);
    }

    方法 读设备属性 <公开 类型 = 小数 注释 = "get" 返回值注释 = "返回相机(视频)的属性值" @禁止流程检查 = 真>
    参数 属性名 <类型 = CV视频属性常量 注释 = "欲获取的属性名称">
    {
        @ return cap.get((int)@<属性名>);
    }

    方法 置设备属性 <公开 注释 = "set">
    参数 属性名 <类型 = CV视频属性常量 注释 = "欲设置的属性名称">
    参数 值 <类型 = 整数 注释 = "欲设置的属性值">
    {
        @ cap.set((int)@<属性名>, @<值>);
    }

    方法 抓取 <公开 类型 = 逻辑型 注释 = "grab,抓取一帧,然后使用函数  抓取并解码  获取流." 返回值注释 = "抓取成功返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ return cap.grab();
    }

    方法 抓取并解码 <公开 类型 = 逻辑型 注释 = "retrieve,解码并返回抓取的视频帧" 返回值注释 = "抓取解码成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 输出图像 <类型 = CV矩阵类>
    参数 抓取参数 <类型 = 整数 注释 = "它可以是帧索引或特定于驱动程序的标志" @默认值 = 0>
    {
        @ return cap.retrieve(@<输出图像>.obj, @<抓取参数>);
    }

    方法 抓取下一帧 <公开 类型 = 逻辑型 注释 = "抓取、解码并返回下一个视频帧" 返回值注释 = "抓取解码成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 输出图像 <类型 = CV矩阵类>
    {
        @ return cap.read(@<输出图像>.obj);
    }

    方法 获取后端名称 <公开 类型 = 文本型 注释 = "getBackendName,获取视频后端支持的名称." @禁止流程检查 = 真>
    {
        @ return cap.getBackendName().c_str();
    }

    方法 设置异常模式 <公开 注释 = "setExceptionMode,设置当发生异常时是抛出异常还是只输出错误代码.">
    参数 抛出异常 <类型 = 逻辑型 注释 = "为真时抛出异常,为假时只静默输出错误代码.">
    {
        @ cap.setExceptionMode(@<抛出异常>);
    }

    方法 获取异常模式 <公开 类型 = 逻辑型 注释 = "getExceptionMode,获取当发生异常时是抛出异常还是只输出错误代码." 返回值注释 = "为真时抛出异常,为假时只静默输出错误代码." @禁止流程检查 = 真>
    {
        @ return cap.getExceptionMode();
    }
}

类 CV泊松克隆算法常量 <公开 注释 = "seamlessClone  用于函数 泊松克隆" @常量类 = 整数>
{
    常量 标准克隆 <公开 值 = 1 注释 = "1,NORMAL_CLONE,当将具有复杂轮廓的对象插入到新的背景中时,该方法的能力得到了充分的体现.">
    常量 混合克隆 <公开 值 = 2 注释 = "2,MIXED_CLONE,经典的方法、基于颜色的选择和 alpha 遮罩可能会很耗时,并且经常会留下不希望出现的光晕."
            注释 = "无缝克隆,即使与原始图像平均,也无效.  基于松散选择的混合无缝克隆被证明是有效的.">
    常量 黑白迁移 <公开 值 = 3 注释 = "3,MONOCHROME_TRANSFER,单色传输允许用户轻松地用替代特征替换一个对象的某些特征.">
}

类 CV视频属性常量 <公开 注释 = "打开或者操作相机、视频的属性" @常量类 = 长整数>
{
    常量 寄存器关闭 <公开 值 = -4 注释 = "CV_CAP_PROP_DC1394_OFF,控制寄存器的模式(可以是:自动,手动,自动单推,绝对后推,任何其他模式允许).">
    常量 寄存器手动模式 <公开 值 = -3 注释 = "CV_CAP_PROP_DC1394_MODE_MANUAL,控制寄存器的模式(可以是:自动,手动,自动单推,绝对后推,任何其他模式允许).">
    常量 寄存器自动模式 <公开 值 = -2 注释 = "CV_CAP_PROP_DC1394_MODE_AUTO,控制寄存器的模式(可以是:自动,手动,自动单推,绝对后推,任何其他模式允许).">
    常量 寄存器自动推触发一次 <公开 值 = -1 注释 = "CV_CAP_PROP_DC1394_MODE_ONE_PUSH_AUTO控制寄存器的模式(可以是:自动,手动,自动单推,绝对后推,任何其他模式允许).">
    常量 当前帧时间 <公开 值 = 0 注释 = "CV_CAP_PROP_POS_MSEC,当前帧毫秒时间.">
    常量 下一帧索引 <公开 值 = 1 注释 = "CV_CAP_PROP_POS_FRAMES,将被下一步解压/获取的帧索引,以0为起点.">
    常量 视频文件相对位置 <公开 值 = 2 注释 = "CV_CAP_PROP_POS_AVI_RATIO,视频文件的相对位置(0 - 影片的开始,1 - 影片的结尾).">
    常量 宽度 <公开 值 = 3 注释 = "CV_CAP_PROP_FRAME_WIDTH,流宽度.">
    常量 高度 <公开 值 = 4 注释 = "CV_CAP_PROP_FRAME_HEIGHT,流高度.">
    常量 帧率 <公开 值 = 5 注释 = "CV_CAP_PROP_FPS,帧率.">
    常量 编码格式 <公开 值 = 6 注释 = "CV_CAP_PROP_FOURCC,表示codec的四个字符.">
    常量 视频文件总帧数 <公开 值 = 7 注释 = "CV_CAP_PROP_FRAME_COUNT,视频文件中帧的总数.">
    常量 CV矩阵格式 <公开 值 = 8 注释 = "CV_CAP_PROP_FORMAT,检索()返回的Mat对象的格式.">
    常量 捕获模式 <公开 值 = 9 注释 = "CV_CAP_PROP_MODE,后端特定的值,表示当前捕获模式.">
    常量 图像亮度 <公开 值 = 10 注释 = "CV_CAP_PROP_BRIGHTNESS,图像亮度(仅适用于相机).">
    常量 图像对比度 <公开 值 = 11 注释 = "CV_CAP_PROP_CONTRAST,图像的对比度(仅适用于相机).">
    常量 图像饱和度 <公开 值 = 12 注释 = "CV_CAP_PROP_SATURATION,图像饱和度(仅适用于相机).">
    常量 图像色调 <公开 值 = 13 注释 = "CV_CAP_PROP_HUE,图像的色调(仅适用于相机).">
    常量 图像增益 <公开 值 = 14 注释 = "CV_CAP_PROP_GAIN,图像增益(仅适用于相机).">
    常量 曝光时间 <公开 值 = 15 注释 = "CV_CAP_PROP_EXPOSURE,曝光时间(仅适用于相机).">
    常量 转换到RGB <公开 值 = 16 注释 = "CV_CAP_PROP_CONVERT_RGB,指示图像是否应该转换为RGB的布尔标记.">
    常量 白平衡蓝增益 <公开 值 = 17 注释 = "CV_CAP_PROP_WHITE_BALANCE_BLUE_U,白平衡蓝增益.">
    常量 矫正图像 <公开 值 = 18 注释 = "CV_CAP_PROP_RECTIFICATION,矫正图像.">
    常量 单色图像 <公开 值 = 19 注释 = "CV_CAP_PROP_MONOCHROME,单色图像.">
    常量 清晰度 <公开 值 = 20 注释 = "CV_CAP_PROP_SHARPNESS,清晰度.">
    常量 自动曝光 <公开 值 = 21 注释 = "CV_CAP_PROP_AUTO_EXPOSURE,自动曝光.">
    常量 伽马增益 <公开 值 = 22 注释 = "CV_CAP_PROP_GAMMA,伽马增益.">
    常量 相机温度 <公开 值 = 23 注释 = "CV_CAP_PROP_TEMPERATURE,相机温度.">
    常量 触发 <公开 值 = 24 注释 = "CV_CAP_PROP_TRIGGER,触发.">
    常量 延迟触发 <公开 值 = 25 注释 = "CV_CAP_PROP_TRIGGER_DELAY,延迟触发.">
    常量 白平衡红增益 <公开 值 = 26 注释 = "CV_CAP_PROP_WHITE_BALANCE_RED_V,白平衡红增益.">
    常量 缩放 <公开 值 = 27 注释 = "CV_CAP_PROP_ZOOM,缩放.">
    常量 焦距 <公开 值 = 28 注释 = "CV_CAP_PROP_FOCUS,焦距.">
    常量 标识符 <公开 值 = 29 注释 = "CV_CAP_PROP_GUID,标识符.">
    常量 光学防抖 <公开 值 = 30 注释 = "CV_CAP_PROP_ISO_SPEED,光学防抖.">
    常量 寄存器最大值 <公开 值 = 31 注释 = "CV_CAP_PROP_MAX_DC1394,寄存器最大值.">
    常量 背光 <公开 值 = 32 注释 = "CV_CAP_PROP_BACKLIGHT,背光.">
    常量 移动拍摄 <公开 值 = 33 注释 = "CV_CAP_PROP_PAN,移动拍摄.">
    常量 倾斜度 <公开 值 = 34 注释 = "CV_CAP_PROP_TILT,倾斜度.">
    常量 卷帘 <公开 值 = 35 注释 = "CV_CAP_PROP_ROLL,卷帘.">
    常量 虹膜 <公开 值 = 36 注释 = "CV_CAP_PROP_IRIS,虹膜.">
    常量 设置 <公开 值 = 37 注释 = "CV_CAP_PROP_SETTINGS,设置.">
    常量 内存大小 <公开 值 = 38 注释 = "CV_CAP_PROP_BUFFERSIZE,内存大小.">
    常量 自动对焦 <公开 值 = 39 注释 = "CV_CAP_PROP_AUTOFOCUS,自动对焦.">
    常量 孔径编号 <公开 值 = 40 注释 = "CV_CAP_PROP_SAR_NUM,孔径编号.">
    常量 孔径点 <公开 值 = 41 注释 = "CV_CAP_PROP_SAR_DEN,孔径点.">
    常量 当前后端 <公开 值 = 42 注释 = "CAP_PROP_BACKEND,当前后端(枚举VideoCaptureAPI).只读属性.">
    常量 通道索引 <公开 值 = 43 注释 = "CAP_PROP_CHANNEL,视频输入,或频道号(仅适用于支持的摄像机).">
    常量 自动白平衡 <公开 值 = 44 注释 = "CAP_PROP_AUTO_WB,禁用或启用自动白平衡.">
    常量 白平衡色温 <公开 值 = 45 注释 = "CAP_PROP_WB_TEMPERATURE">
    常量 编码器像素格式 <公开 值 = 46 注释 = "CAP_PROP_CODEC_PIXEL_FORMAT,(只读)编解码器的像素格式.">
    常量 比特率 <公开 值 = 47 注释 = "CAP_PROP_BITRATE,(只读)视频比特率(kbits/s).">
    常量 帧方向元数据 <公开 值 = 48 注释 = "CAP_PROP_ORIENTATION_META,(只读)由流元定义的帧旋转(仅适用于FFmpeg后端).">
    常量 帧方向自动 <公开 值 = 49 注释 = "CAP_PROP_ORIENTATION_AUTO,如果为true(1),则考虑视频文件的 帧方向元数据 CV视频 的输出帧(仅适用于FFmpeg后端).">
    常量 硬件加速 <公开 值 = 50
            注释 = "CAP_PROP_HW_ACCELERATION,(**仅打开**)硬件加速类型(请参阅#VideoAccelerationType)。仅通过CV视频.打开_多参数 方法中的“参数数组”参数支持设置。默认值是后端特定的。">
    常量 硬件设备索引 <公开 值 = 51 注释 = "CAP_PROP_HW_DEVICE,(**仅打开**)指定硬件设备索引(如果多个可用,请选择GPU)。设备枚举特定加速类型。">
    常量 使用OPENCL加速 <公开 值 = 52 注释 = "CAP_PROP_HW_ACCELERATION_USE_OPENCL,(**仅打开**)如果非零,则创建新的OpenCL上下文并将其绑定到当前线程。">
    常量 打开超时 <公开 值 = 53 注释 = "CAP_PROP_OPEN_TIMEOUT_MSEC,(**仅限打开**)打开视频捕获的超时(毫秒)(仅适用于FFmpeg后端).">
    常量 读入超时 <公开 值 = 54 注释 = "CAP_PROP_READ_TIMEOUT_MSEC,(**仅限打开**)从视频捕获读取超时(毫秒)(仅适用于FFmpeg后端).">
    常量 打开时间戳 <公开 值 = 55 注释 = "CAP_PROP_STREAM_OPEN_TIME_USEC,自1970年1月1日流打开以来的(只读)时间(微秒)。仅适用于FFmpeg后端。适用于RTSP和其他直播流">
    常量 视频通道数 <公开 值 = 56 注释 = "CAP_PROP_VIDEO_TOTAL_CHANNELS,(只读)视频频道数">
