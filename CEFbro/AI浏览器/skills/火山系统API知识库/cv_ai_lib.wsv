    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" 返回值注释 = "返回成员个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV向量6i类 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "返回指定索引的 CV向量6i类">
    参数 成员索引 <类型 = 整数>
    {
        变量 坐标 <类型 = CV向量6i类>
        @ @<坐标>.obj = obj[@<成员索引>];
        返回 (坐标)
    }

    方法 加入成员 <公开 注释 = "将一个所指定类型的成员值加入到本容器(数组)的尾部">
    参数 欲加入向量 <类型 = CV向量6i类>
    {
        @ obj.push_back(@<欲加入向量>.obj);
    }

    方法 清除成员 <公开 注释 = "清除容器内的所有成员">
    {
        @ obj.clear();
    }
}

