类 CV关键点类 <公开 注释 = "KeyPoint">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::KeyPoint obj;
    # <> </include>
    # @end

    方法 初始化关键点 <公开 类型 = CV关键点类 注释 = "KeyPoint">
    参数 坐标点 <类型 = CV坐标点2f 注释 = "关键点坐标">
    参数 直径 <类型 = 小数 注释 = "关键点直径" @默认值 = 1>
    参数 角度 <类型 = 小数 注释 = "关键点角度" @默认值 = -1>
    参数 强度 <类型 = 小数 注释 = "关键点检测器对关键点的响应(即关键点的强度)" @默认值 = 0>
    参数 倍频 <类型 = 整数 注释 = "检测到关键点的金字塔倍频度" @默认值 = 0>
    参数 ID <类型 = 整数 注释 = "指定关键点索引" @默认值 = -1>
    {
        @ obj = cv::KeyPoint(@<坐标点>.obj, (float)@<直径>, (float)@<角度>, (float)@<强度>, @<倍频>, @<ID>);
        返回 (本对象)
    }

    方法 关键点到向量 <公开 静态 注释 = "convert,转换关键点到向量.">
    参数 关键点容器 <类型 = CV关键点容器类 注释 = "欲转换的关键点容器">
    参数 输出坐标向量 <类型 = CV坐标2f容器 注释 = "转换都的坐标点容器">
    参数 输出索引数组 <类型 = CV整数容器 注释 = "关键点的索引数组(容器)">
    {
        @ cv::KeyPoint::convert(@<关键点容器>.obj, @<输出坐标向量>.obj, @<输出索引数组>.obj);
    }

    方法 向量到关键点 <公开 静态 注释 = "convert,将向量容器转换到关键点容器.">
    参数 输入向量 <类型 = CV坐标2f容器 注释 = "欲转换的坐标点容器">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "转换后的关键点容器">
    参数 直径 <类型 = 小数 注释 = "关键点直径" @默认值 = 1>
    参数 强度 <类型 = 小数 注释 = "关键点检测器对关键点的响应(即关键点的强度)" @默认值 = 0>
    参数 金字塔层级 <类型 = 整数 @默认值 = 0>
    参数 ID <类型 = 整数 注释 = "为-1时不指定ID,否则指定ID." @默认值 = -1>
    {
        @ cv::KeyPoint::convert(@<输入向量>.obj, @<输出关键点容器>.obj, (float)@<直径>, (float)@<强度>, @<金字塔层级>, @<ID>);
    }

    方法 计算两关键点重叠度 <公开 静态 类型 = 小数 注释 = "overlap,此方法计算关键点对的重叠. 重叠是关键点区域的交集面积与关键点区域的并集面积之比(将关键点区域视为圆)."
            注释 = "如果它们不重叠,我们得到零. 如果它们在相同的位置以相同的大小重合,我们得到 1." 返回值注释 = "返回重叠度" @禁止流程检查 = 真>
    参数 点1 <类型 = CV关键点类>
    参数 点2 <类型 = CV关键点类>
    {
        @ return  cv::KeyPoint::overlap(@<点1>.obj, @<点2>.obj);
    }

    方法 坐标点 <公开 属性读 类型 = CV坐标点2f 返回值注释 = "返回关键点的坐标点">
    {
        变量 坐标_临时 <类型 = CV坐标点2f>
        @ @<坐标_临时>.obj = obj.pt;
        返回 (坐标_临时)
    }

    方法 坐标点 <公开 属性写 注释 = "置关键点的坐标点">
    参数 值 <类型 = CV坐标点2f>
    {
        @ obj.pt = @<值>.obj;
    }

    方法 直径 <公开 属性读 类型 = 小数 返回值注释 = "返回关键点直径">
    {
        变量 坐标_临时 <类型 = 小数>
        @ @<坐标_临时> = obj.size;
        返回 (坐标_临时)
    }

    方法 直径 <公开 属性写 注释 = "设置关键点直径">
    参数 值 <类型 = 小数>
    {
        @ obj.size = (float)@<值>;
    }

    方法 强度 <公开 属性读 类型 = 小数 返回值注释 = "返回关键点强度" @禁止流程检查 = 真>
    {
        @ return obj.response;
    }

    方法 强度 <公开 属性写 注释 = "设置关键点强度">
    参数 值 <类型 = 小数>
    {
        @ obj.response = (float)@<值>;
    }

    方法 金字塔层级 <公开 属性读 类型 = 整数 返回值注释 = "返回关键点金字塔层级">
    {
        变量 坐标_临时 <类型 = 整数>
        @ @<坐标_临时> = obj.octave;
        返回 (坐标_临时)
    }

