    常量 掩膜尺寸为5 <公开 值 = 5 注释 = "5,DIST_MASK_5,掩膜尺寸为5.">
    常量 精确计算 <公开 值 = 2 注释 = "2,DIST_MASK_PRECISE,精确计算.">
}

类 CV距离变换标签常量 <公开 注释 = "DistanceTransformLabelTypes" @常量类 = 整数>
{
    常量 连接邻近组件标签 <公开 值 = 0 注释 = "0,DIST_LABEL_CCOMP,源图像中的每个连接的零组件(以及最接近的所有非零像素连接的组件)将被分配相同的标签.">
    常量 邻近组件独立标签 <公开 值 = 1 注释 = "1,DIST_LABEL_PIXEL,每个零像素(以及最接近它的所有非零像素)都有自己的标签.">
