    方法 创建输入张量从图像 <公开 静态 注释 = "blobFromImage,从CV矩阵创建输入张量.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "需要使用创建张量的图像">
    参数 输出张量 <类型 = CV矩阵类 注释 = "输出创建的张量">
    参数 缩放比例 <类型 = 小数 注释 = "将图片减去平均值之后,还可以对剩下的像素值进行一定的尺度缩放,它的默认值是1,如果希望减去平均像素之后的值." @默认值 = 1.0>
    参数 网络尺寸 <类型 = CV尺寸类 注释 = "这个参数是我们神经网络在训练的时候要求输入的图片尺寸" "">
    参数 颜色均值 <类型 = CV标量类 注释 = "根据网络设计,需要设置各通道颜色均值." "">
    参数 图像RB顺序 <类型 = 逻辑型 注释 = "OpenCV中认为我们的图片通道顺序是BGR,但是我平均值假设的顺序是RGB,所以如果需要交换R和G,那么就要使 图像RB顺序=true." @默认值 = 假>
    参数 裁剪图像 <类型 = 逻辑型 注释 = "指示图像在调整大小后是否裁剪" @默认值 = 假>
    参数 输出格式 <类型 = CV数值类型 注释 = "选择  CV_32位浮点型 或 CV_8位无符号整数" @默认值 = CV数值类型.CV_32位浮点型>
    {
        @ cv::dnn::blobFromImage(@<输入图像>.obj, @<输出张量>.obj, @<缩放比例>, @<网络尺寸>.obj, @<颜色均值>.obj, @<图像RB顺序>, @<裁剪图像>, @<输出格式>);
    }

    方法 创建输入张量从图像1 <公开 静态 类型 = CV矩阵类 注释 = "blobFromImage,从CV矩阵创建输入张量,并返回张量." 返回值注释 = "返回张量矩阵">
    参数 输入图像 <类型 = CV矩阵类 注释 = "需要使用创建张量的图像">
    参数 缩放比例 <类型 = 小数 注释 = "将图片减去平均值之后,还可以对剩下的像素值进行一定的尺度缩放,它的默认值是1,如果希望减去平均像素之后的值." @默认值 = 1.0>
    参数 网络尺寸 <类型 = CV尺寸类 注释 = "这个参数是我们神经网络在训练的时候要求输入的图片尺寸" "">
    参数 颜色均值 <类型 = CV标量类 注释 = "根据网络设计,需要设置各通道颜色均值." "">
    参数 图像RB顺序 <类型 = 逻辑型 注释 = "OpenCV中认为我们的图片通道顺序是BGR,但是我平均值假设的顺序是RGB,所以如果需要交换R和G,那么就要使 图像RB顺序=true." @默认值 = 假>
    参数 裁剪图像 <类型 = 逻辑型 注释 = "指示图像在调整大小后是否裁剪" @默认值 = 假>
    参数 输出格式 <类型 = CV数值类型 注释 = "选择  CV_32位浮点型 或 CV_8位无符号整数" @默认值 = CV数值类型.CV_32位浮点型>
    {
        变量 输出张量 <类型 = CV矩阵类>
        @ @<输出张量>.obj = cv::dnn::blobFromImage(@<输入图像>.obj, @<缩放比例>, @<网络尺寸>.obj, @<颜色均值>.obj, @<图像RB顺序>, @<裁剪图像>, @<输出格式>);
        返回 (输出张量)
    }

    方法 缩减Caffe权重 <公开 静态 注释 = "shrinkCaffeModel,将Caffe网络的所有权值转换为半精度浮点.">
    参数 输入权重文件 <类型 = 文本型 注释 = "包含网络各层权重的文件,通常以caffemodel为后缀.">
    参数 输出权重文件 <类型 = 文本型 注释 = "输出缩减后的caffe权重文件">
    参数 缩减层名 <类型 = CV文本容器 注释 = "需要缩减的网络层名称">
    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ cv::dnn::shrinkCaffeModel(GetMbsText (@<输入权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<输出权重文件>.GetText (), memBuf2, NULL), @<缩减层名>.obj);
    }

    方法 创建二进制权重文本 <公开 静态 注释 = "writeTextGraph,创建以协议缓冲区格式存储的二进制网络的文本表示形式.">
    参数 输入权重文件 <类型 = 文本型 注释 = "需要转换到二进制权重文件的权重文件">
