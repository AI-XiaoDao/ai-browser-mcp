        @ @an<CVolMem> memBuf1;
        @ @<返回矩形>.obj = cv::getWindowImageRect(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL));
        返回 (返回矩形)
    }

    方法 获取窗口鼠标滚轮增量 <公开 静态 类型 = 整数 注释 = "getMouseWheelDelta,在窗口鼠标事件中,获取鼠标滚动距离." @禁止流程检查 = 真>
    参数 事件标志 <类型 = 整数>
    {
        @ return cv::getMouseWheelDelta(@<事件标志>);
    }

    方法 选择ROI <公开 静态 类型 = CV矩形类 注释 = "selectROI,允许用户在窗口中选择ROI" 注释 = "按下 空格键/回车键 完成选取, 按下 C键 取消选取.">
    参数 窗口名称 <类型 = 文本型 注释 = "需要操作的窗口名称">
    参数 输入图像 <类型 = CV矩阵类 注释 = "作为显示参考的图像">
    参数 显示十字准星 <类型 = 逻辑型 注释 = "为真时显示准星" @默认值 = 真>
    参数 从中心开始 <类型 = 逻辑型 注释 = "为真时将以鼠标点击位置为中心初始化一个矩形框,否则以鼠标点击位置为左上角初始化矩形." @默认值 = 假>
    {
        变量 返回矩形 <类型 = CV矩形类>
        @ @an<CVolMem> memBuf1;
        @ @<返回矩形>.obj = cv::selectROI(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL), @<输入图像>.obj, @<显示十字准星>, @<从中心开始>);
        返回 (返回矩形)
    }

    方法 选择ROI多个 <公开 静态 注释 = "selectROIs,允许用户在窗口中选择多个ROI" 注释 = "按下 空格键/回车键 完成选取, 按下 ESC键 取消选取.">
    参数 窗口名称 <类型 = 文本型 注释 = "需要操作的窗口名称">
    参数 输入图像 <类型 = CV矩阵类 注释 = "作为显示参考的图像">
    参数 输出ROI容器 <类型 = CV矩形类容器 注释 = "输出ROI容器">
    参数 显示十字准星 <类型 = 逻辑型 注释 = "为真时显示准星" @默认值 = 真>
    参数 从中心开始 <类型 = 逻辑型 注释 = "为真时将以鼠标点击位置为中心初始化一个矩形框,否则以鼠标点击位置为左上角初始化矩形." @默认值 = 假>
    {
        @ @an<CVolMem> memBuf1;
        @ cv::selectROIs(GetMbsText (@<窗口名称>.GetText(), memBuf1, NULL), @<输入图像>.obj, @<输出ROI容器>.obj, @<显示十字准星>, @<从中心开始>);
    }

    方法 获取滑块位置 <公开 静态 类型 = 整数 注释 = "getTrackbarPos,获取指定滑块的当前位置." @禁止流程检查 = 真>
    参数 滑块名称 <类型 = 文本型 注释 = "滑块的名称,它在同一个窗口中是唯一的标识.">
