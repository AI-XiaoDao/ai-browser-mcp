    {
        @ obj.queryIdx = @<值>;
    }

    方法 训练索引 <公开 属性读 类型 = 整数 注释 = "trainIdx" @禁止流程检查 = 真>
    {
        @ return obj.trainIdx;
    }

    方法 训练索引 <公开 属性写 注释 = "trainIdx">
