类 CV标定方法常量 <公开 @常量类 = 整数>
{
    常量 内参 <公开 值 = 18 注释 = "18, CALIB_NINTRINSIC">
    常量 使用内参预估 <公开 值 = 0x00001 注释 = "0x00001,CALIB_USE_INTRINSIC_GUESS">
    常量 校准固定长宽比 <公开 值 = 0x00002 注释 = "0x00002,CALIB_FIX_ASPECT_RATIO">
    常量 解算主点 <公开 值 = 0x00004 注释 = "0x00004,CALIB_FIX_PRINCIPAL_POINT">
    常量 零切点距离 <公开 值 = 0x00008 注释 = "0x00008,CALIB_ZERO_TANGENT_DIST">
    常量 固定焦距 <公开 值 = 0x00010 注释 = "0x00010,CALIB_FIX_FOCAL_LENGTH">
    常量 固定K1 <公开 值 = 0x00020 注释 = "0x00020,CALIB_FIX_K1">
    常量 固定K2 <公开 值 = 0x00040 注释 = "0x00040,CALIB_FIX_K2">
    常量 固定K3 <公开 值 = 0x00080 注释 = "0x00080,CALIB_FIX_K3">
    常量 固定K4 <公开 值 = 0x00800 注释 = "0x00800,CALIB_FIX_K4">
    常量 固定K5 <公开 值 = 0x01000 注释 = "0x01000,CALIB_FIX_K5">
    常量 固定K6 <公开 值 = 0x02000 注释 = "0x02000,CALIB_FIX_K6">
    常量 有理数模式 <公开 值 = 0x04000 注释 = "0x04000,CALIB_RATIONAL_MODEL">
    常量 薄棱镜模型 <公开 值 = 0x08000 注释 = "0x08000,CALIB_THIN_PRISM_MODEL">
    常量 固定_S1_S2_S3_S4 <公开 值 = 0x10000 注释 = "0x10000,CALIB_FIX_S1_S2_S3_S4">
    常量 倾斜模型 <公开 值 = 0x40000 注释 = "0x40000,CALIB_TILTED_MODEL">
    常量 固定陶XY <公开 值 = 0x80000 注释 = "0x80000,CALIB_FIX_TAUX_TAUY">
    常量 QR分解 <公开 值 = 0x100000 注释 = "0x100000,CALIB_USE_QR,用QR代替SVD分解求解. 速度更快,但可能不够精确">
    常量 固定正切距离 <公开 值 = 0x200000 注释 = "0x200000,CALIB_FIX_TANGENT_DIST">
    常量 双目固定内参 <公开 值 = 0x00100 注释 = "0x00100,CALIB_FIX_INTRINSIC,只针对双目立体相机">
    常量 双目固定焦距 <公开 值 = 0x00200 注释 = "0x00200,CALIB_SAME_FOCAL_LENGTH,只针对双目立体相机">
    常量 双目零差距 <公开 值 = 0x00400 注释 = "0x00400,CALIB_ZERO_DISPARITY,只针对双目立体相机">
    常量 双目LU分解 <公开 值 = 131072 注释 = "131072,CALIB_USE_LU,只针对双目立体相机">
    常量 双目外部预估 <公开 值 = 4194304 注释 = "4194304,CALIB_USE_EXTRINSIC_GUESS,只针对双目立体相机">
}

类 CV特征检测SIFT <公开 注释 = "SIFT特征检测类">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<SIFT> obj;
    # <> </include>
    # @end

    方法 检测图像1 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "输出检测结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 检测并计算相关性 <公开 注释 = "detectAndCompute,检测图像并匹配描述符特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域,可以用新建对象(CV矩阵类)创建空掩膜." "">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "当参数 不输出关键点  为假时输出">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点相关性矩阵">
    参数 不输出关键点 <类型 = 逻辑型 注释 = "为假时输出参数 输出关键点容器" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->detectAndCompute(@<源图像>.obj, @<掩膜>.obj, @<输出关键点容器>.obj, @<输出相关性>.obj, @<不输出关键点>);
    }

    方法 检测图像2 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类数组 注释 = "输出结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 创建 <公开 注释 = "create,创建一个特征检测器.">
    参数 保留数量 <类型 = 整数 注释 = "保留最佳特性的数量" @默认值 = 0>
    参数 金字塔层级 <类型 = 整数 注释 = "每个金字塔层级中的层数.  3 是 D. Lowe 论文中使用的值. 金字塔层级的数量是根据图像分辨率自动计算的" @默认值 = 3>
    参数 对比度阈值 <类型 = 小数 注释 = "对比度阈值用于过滤半均匀图像中的弱特征(低对比度)地区. 阈值越大,检测器产生的特征越少,当应用过滤时,对比度阈值将被  层级 除." @默认值 = 0.04>
    参数 边缘阈值 <类型 = 小数 注释 = "用于过滤出边缘特征的阈值" @默认值 = 10>
    参数 sigma <类型 = 小数 注释 = "金字塔第0层图像高斯滤波系数" @默认值 = 1.6>
    参数 描述符数值类型 <类型 = CV数值类型 注释 = "只支持3位浮点和无符号8位整数" @默认值 = CV数值类型.无符号8位整数>
    {
        @ obj = cv::SIFT::create(@<保留数量>,@<金字塔层级>,@<对比度阈值>,@<边缘阈值>,@<sigma>,@<描述符数值类型>);
    }

    方法 计算描述符1 <公开 注释 = "compute,计算描述符相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类 注释 = "欲计算的关键点容器">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点相关性矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 计算描述符2 <公开 注释 = "compute,计算描述符相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类数组 注释 = "欲计算的关键点容器数组">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点相关性矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 写出检测器 <公开 注释 = "write,保存检测器到文件.">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存的文件路径">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->write((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 读入检测器 <公开 注释 = "read,从文件读入检测器,读入前先创建.">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->read((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }
}

类 CV特征检测SURF <公开 注释 = "SURF特征检测类">
