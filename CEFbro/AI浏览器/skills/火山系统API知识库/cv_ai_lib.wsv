    方法 设置标量 <公开 注释 = "setTo">
    参数 标量值 <类型 = CV标量类 注释 = "与原矩阵有相同的维度">
    参数 掩膜 <类型 = CV矩阵类 注释 = "与原矩阵具有相同大小的操作掩码. 它的非零元素表示哪个矩阵" 注释 = "元素需要被复制. 掩码必须是CV_8U类型,可以有一个或多个通道.">
    {
        @ obj.setTo(@<标量值>.obj, @<掩膜>.obj);
    }

    方法 重置尺寸 <公开 类型 = CV矩阵类 注释 = "reshape" 返回值注释 = "返回新矩阵">
    参数 通道数 <类型 = 整数 注释 = "为0时通道数不变">
    参数 行数 <类型 = 整数 注释 = "为0时行数不变">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.reshape(@<通道数>, @<行数>);
        返回 (返回矩阵)
    }

    方法 转置 <公开 类型 = CV矩阵类 注释 = "t" 返回值注释 = "返回转置矩阵">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj =obj.t();
        返回 (返回矩阵)
    }

    方法 逆 <公开 类型 = CV矩阵类 注释 = "inv" 返回值注释 = "返回逆矩阵">
    参数 运算方法 <类型 = CV矩阵分解常量 @默认值 = CV矩阵分解常量.高斯消元法>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.inv(@<运算方法>);
        返回 (返回矩阵)
    }

    方法 乘 <公开 类型 = CV矩阵类 注释 = "mul" 返回值注释 = "返回乘积矩阵">
    参数 输入矩阵 <类型 = CV矩阵类>
    参数 缩放因子 <类型 = 小数 @默认值 = 1.0>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.mul(@<输入矩阵>.obj, @<缩放因子>);
        返回 (返回矩阵)
    }

    方法 叉乘 <公开 类型 = CV矩阵类 注释 = "cross" 注释 = "计算两个３元素向量的叉乘的积. 被操作向量必须是３元素浮点型的具有相同形状和尺寸的向量." 注释 = "结果也是与被操作对象的具有相同形状和大小的浮点型３元素向量.">
    参数 输入向量 <类型 = CV矩阵类>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj =obj.cross(@<输入向量>.obj);
        返回 (返回矩阵)
    }

