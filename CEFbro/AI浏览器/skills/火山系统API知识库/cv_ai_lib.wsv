    }

    方法 从指针载入 <公开 类型 = CV矩阵类 注释 = "从内存图片的指针载入,实际就是个简化的函数 图像解码从字节集." 返回值注释 = "返回本对象">
    参数 矩阵高度 <类型 = 整数 注释 = "欲创建的矩阵高度">
    参数 矩阵宽度 <类型 = 整数 注释 = "欲创建的矩阵宽度">
    参数 通道类型 <类型 = CV矩阵通道类型常量 注释 = "欲创建的矩阵通道类型" @默认值 = CV矩阵通道类型常量.无符号8位整数3通道>
    参数 数据指针 <类型 = 变整数 注释 = "注意,这个指针不能为字节集的指针,它应该指向完全为数据的指针,字节集有部分数据是描述字节集状态的.">
    {
        @ obj = cv::Mat(@<矩阵高度>, @<矩阵宽度>, @<通道类型>, (void*)@<数据指针>);
        返回 (本对象)
    }

    方法 取图片数据指针 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (@dt<变整数>)obj.data;
    }

    方法 取数值类型 <公开 类型 = 整数 注释 = "depth,也就是位深度." 返回值注释 = "    0-   8位无符号整数 - 8-bit 无符号整数 ( 0..255 )."
            返回值注释 = "    1-   8位有符号整数 - 8-bit 有符号整数 ( -128..127 )." 返回值注释 = "    2-   16位无符号整数 - 16-bit 无符号整数 ( 0..65535 )."
            返回值注释 = "    3-   16位有符号整数 - 16-bit 有符号整数 ( -32768..32767 )."
            返回值注释 = "    4-   32位有符号整数 - 32-bit 有符号整数 ( -2147483648..2147483647 )."
            返回值注释 = "    5-   32位浮点型 - 32-bit 浮点型 ( -FLT_MAX..FLT_MAX, INF, NAN )."
            返回值注释 = "    6-   64位浮点型 - 64-bit 浮点型 ( -DBL_MAX..DBL_MAX, INF, NAN )." @禁止流程检查 = 真>
    {
        @ return obj.depth();
    }

    方法 图片数据指针 <公开 属性读 类型 = 变整数 注释 = "data" @禁止流程检查 = 真>
    {
        @ return (@dt<变整数>)obj.data;
    }

    方法 数据类型转换 <公开 注释 = "convertTo,将本矩阵的数值类型转换为新的数值类.">
    参数 目标矩阵 <类型 = CV矩阵类 注释 = "输出的矩阵">
    参数 数据类型 <类型 = CV数值类型 注释 = "欲转换到的数值类型">
    参数 缩放 <类型 = 小数 注释 = "欲缩放的值,转换完成后结果矩阵会乘以该值" @默认值 = 1>
    参数 偏置 <类型 = 小数 注释 = "欲偏置的值,转换完成后结果矩阵会加上该值" @默认值 = 0>
    {
        @ obj.convertTo(@<目标矩阵>.obj, @<数据类型>, @<缩放>,@<偏置>);
    }

    方法 画到图像 <公开 注释 = "将指定的矩阵画到本对象矩阵里面">
    参数 画出图像 <类型 = CV矩阵类 注释 = "欲画出的图像(矩阵)">
    参数 ROI区域 <类型 = CV矩形类 注释 = "欲画出的矩形范围ROI">
    {
        @ @<画出图像>.obj.copyTo(obj(@<ROI区域>.obj));
    }

    方法 转CV单精度小数容器 <公开 类型 = CV单精度小数容器 注释 = "将矩阵转换为单精度小数容器" 返回值注释 = "返回数值容器">
    {
        变量 返回容器 <类型 = CV单精度小数容器>
        @ @<返回容器>.obj = (std::vector<float>)(obj.reshape(1, 1));
        返回 (返回容器)
    }

    方法 转CV整数容器 <公开 类型 = CV整数容器 注释 = "将矩阵转换为整数容器" 返回值注释 = "返回数值容器">
