<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序 <注释 = "本模块对计算机视觉cv库进行了封装." 注释 = "注意: 使用本模块功能的用户程序必须将项目选项里面的\"使用静态C++运行时库\"属性值设置为假."
        注释 = "AI工具现成的模型权重文件下载地址: https://pan.baidu.com/s/1hoCiwqV1lal7TQYcV1p0Xg?pwd=cnwt" @视窗.头文件搜寻目录 = "libs\\opencv\\include"
        @视窗.头文件搜寻目录 = "libs\\opencv\\include\\opencv2" @视窗.库文件搜寻目录 = "libs\\opencv\\$(p)\\vc16\\lib" @视窗.外部头文件 = "libs\\vol_cv.h"
        @视窗.外部库.debug = "opencv_world460d.lib" @视窗.外部库.release = "opencv_world460.lib" ""
        @视窗.头文件搜寻目录 = "libs\\liteAI\\include\\lite" @视窗.头文件搜寻目录 = "libs\\liteAI\\include" @视窗.库文件搜寻目录 = "libs\\liteAI\\lib"
        @视窗.库文件搜寻目录 = "libs\\liteAI" "@视窗.外部库.debug-x64" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkitd.lib"
        "@视窗.外部库.release-x64" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkit.lib"
        "@视窗.外部库.debug-win32" = "libs\\liteAI\\lib\\win32\\lite.ai.toolkitd.lib"
        "@视窗.外部库.release-win32" = "libs\\liteAI\\lib\\win32\\lite.ai.toolkit.lib"
        @视窗.外部库 = "libs\\liteAI\\lib\\$(p)\\onnxruntime.lib"
        "@视窗.附属文件.release-x64" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkit.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_cuda.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_shared.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_world460.dll"
        "@视窗.附属文件.debug-x64" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkitd.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_cuda.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_shared.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_world460d.dll"
        "@视窗.附属文件.release-win32" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkit.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_shared.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_world460.dll"
        "@视窗.附属文件.debug-win32" = "libs\\liteAI\\lib\\$(p)\\lite.ai.toolkitd.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime.dll\r\nlibs\\liteAI\\lib\\$(p)\\onnxruntime_providers_shared.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_world460d.dll"
        @视窗.需求VS版本 = "16-" @视窗.使用静态运行时库 = 假>

# @ <global>
# @ <include>
# @ using namespace cv;
# @ using namespace std;
# @ </include>
# @ </global>

类 CV颜色映射型常量 <公开 注释 = "ColormapTypes,主要是将黑白图映射为伪彩色图,与Matlab具有等效的颜色." @常量类 = 整数>
{
    常量 秋季 <公开 值 = 0 注释 = "0,COLORMAP_AUTUMN.">
    常量 骨色 <公开 值 = 1 注释 = "1,COLORMAP_BONE.">
    常量 JET <公开 值 = 2 注释 = "2,COLORMAP_JET.">
    常量 冬季 <公开 值 = 3 注释 = "3,COLORMAP_WINTER.">
    常量 彩虹 <公开 值 = 4 注释 = "4,COLORMAP_RAINBOW.">
    常量 海洋 <公开 值 = 5 注释 = "5,COLORMAP_OCEAN.">
    常量 夏季 <公开 值 = 6 注释 = "6,COLORMAP_SUMMER.">
    常量 春季 <公开 值 = 7 注释 = "7,COLORMAP_SPRING.">
    常量 冷色 <公开 值 = 8 注释 = "8,COLORMAP_COOL.">
    常量 HSV色彩 <公开 值 = 9 注释 = "9,COLORMAP_HSV.">
    常量 粉红 <公开 值 = 10 注释 = "10,COLORMAP_PINK.">
    常量 艳丽 <公开 值 = 11 注释 = "11,COLORMAP_HOT.">
    常量 森莺 <公开 值 = 12 注释 = "12,COLORMAP_PARULA.">
    常量 岩浆 <公开 值 = 13 注释 = "13,COLORMAP_MAGMA.">
    常量 地狱 <公开 值 = 14 注释 = "14,COLORMAP_INFERNO.">
    常量 血色 <公开 值 = 15 注释 = "15,COLORMAP_PLASMA.">
    常量 翠绿 <公开 值 = 16 注释 = "16,COLORMAP_VIRIDIS.">
    常量 便服 <公开 值 = 17 注释 = "17,COLORMAP_CIVIDIS.">
    常量 黄昏 <公开 值 = 18 注释 = "18,COLORMAP_TWILIGHT.">
    常量 转移黄昏 <公开 值 = 19 注释 = "19,COLORMAP_TWILIGHT_SHIFTED.">
    常量 加压 <公开 值 = 20 注释 = "20,COLORMAP_TURBO.">
    常量 墨绿 <公开 值 = 21 注释 = "21,COLORMAP_DEEPGREEN.">
}

类 CV二值化阈值类型常量 <公开 注释 = "ThresholdTypes" "">
{
    常量 二进制阈值化 <公开 类型 = 整数 值 = 0 注释 = "0,THRESH_BINARY,大于阈值的像素为 最大阈值 小于阈值的像素为0.">
    常量 反二进制阈值化 <公开 类型 = 整数 值 = 1 注释 = "1,THRESH_BINARY_INV,大于阈值的像素为0 小于阈值的像素为最大阈值 .">
    常量 截断阈值化 <公开 类型 = 整数 值 = 2 注释 = "2,THRESH_TRUNC,大于阈值的像素改变为阈值,小于阈值的像素不变.">
    常量 阈值化为0 <公开 类型 = 整数 值 = 3 注释 = "3,THRESH_TOZERO,阈值化为0,大于阈值的像素不变,小于阈值的像素全为0.">
    常量 反阈值化为0 <公开 类型 = 整数 值 = 4 注释 = "4,THRESH_TOZERO_INV,大于阈值的像素为0,小于阈值的像素不变.">
    常量 掩膜分割 <公开 类型 = 整数 值 = 7 注释 = "7,THRESH_MASK.">
    常量 最大方差分割 <公开 类型 = 整数 值 = 8 注释 = "8,THRESH_OTSU,也就是自动找到最高分布的直方图,用该值作分割,对有多个波峰的图效果不好.">
    常量 三角形阈值分割 <公开 类型 = 整数 值 = 16 注释 = "16,THRESH_TRIANGLE.">
}

类 CV图像颜色空间转换常量 <公开 注释 = "ColorConversionCodes,转换规则为：" 注释 = "常量前缀      原颜色空间        转         目标颜色空间"
        注释 = "COLOR_            BGR              2             BGRA" @常量类 = 整数>
