类 CV支持向量机核心类 <注释 = "v::ml::SVM::Kernel">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::ml::SVM::Kernel> obj;
    # <> </include>
    # @end
}

类 CV训练数据类 <公开 注释 = "TrainData">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<cv::ml::TrainData> obj;
    # <> </include>
    # @end

    方法 从CSV文件载入 <公开 类型 = CV训练数据类 注释 = "loadFromCSV">
    参数 文件路径 <类型 = 文本型>
    参数 表头行数 <类型 = 整数 @默认值 = 1>
    参数 响应起始ID <类型 = 整数 注释 = "如果：" 注释 = "2,      1.4, 5.7, 6.6, 0.2" 注释 = "^                  ^" 注释 = "label          data"
            注释 = "则起始ID为0,结束ID为1." @默认值 = -1>
    参数 响应结束ID <类型 = 整数 @默认值 = -1>
    参数 指定变量规则 <类型 = 文本型 注释 = "指定变量类型的可选文本字符串. 它的格式为 `ord[n1-n2,n3,n4-n5,...]cat[n6,n7-n8,...]`."
            注释 = "也就是说,从“n1 到 n2”(包括范围)、“n3”、“n4 到 n5”……的变量被认为是有序的," 注释 = "“n6”、“n7 到 n8”……被认为是分类的."
            注释 = "范围`[n1..n2] + [n3] + [n4..n5] + ... + [n6] + [n7..n8]`" 注释 = " 应该涵盖所有变量. 如果未指定 varTypeSpec,则算法使用以下规则："
            注释 = "        - 默认情况下,所有输入变量都被认为是有序的. 如果某些列包含非数值,例如\'apple\', \'pear\', \'apple\', \'apple\', \'mango\',对应的变量被认为是分类变量."
            注释 = "        - 如果有多个输出变量,它们都被认为是有序的. 使用非数值时报错." 注释 = "        - 如果有一个输出变量,那么如果它的值是非数字的或者都是整数,那么它被认为是分类的. 否则,它被认为是有序的."
            @默认值 = "">
    参数 分隔符 <类型 = 字符 @默认值 = ','>
    参数 无效字符 <类型 = 字符 注释 = "用于指定抛弃的字符. 它不应该是一个数字." @默认值 = '?'>
    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ std::string ord = GetMbsText (@<指定变量规则>.GetText (), memBuf2, NULL);
        @ if(ord=="")
        @     obj = cv::ml::TrainData::loadFromCSV( GetMbsText (@<文件路径>.GetText (), memBuf1, NULL), @<表头行数>, @<响应起始ID>, @<响应结束ID>, std::string(), (char)@<分隔符>, (char)@<无效字符>);
        @ else
        @     obj = cv::ml::TrainData::loadFromCSV(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL), @<表头行数>, @<响应起始ID>, @<响应结束ID>, ord, (char)@<分隔符>, (char)@<无效字符>);
        返回 (本对象)
    }

    方法 创建训练样本 <公开 类型 = CV训练数据类 注释 = "create">
    参数 输入样本 <类型 = CV矩阵类 注释 = "样本的样本矩阵. 它应该为 32位浮点型  类型">
    参数 样本类型 <类型 = CV样本类型常量>
    参数 响应矩阵 <类型 = CV矩阵类 注释 = "响应矩阵.  如果响应是标量的,则应将它们存储为单行或单列." 注释 = " 矩阵应具有 32位浮点型 或 32位有符号整数 类型"
            注释 = "(在前一种情况下,默认情况下将响应视为有序；在后一种情况下 - 作为分类).">
    参数 变量容器 <类型 = CV整数容器 注释 = "指定用于训练的变量.  它可以是包含从 0 开始的变量索引的整数向量 (32位有符号整数)," 注释 = "也可以是包含活动变量掩码的字节向量 (8位无符号整数)." @默认值 = 空对象>
    参数 标签容器 <类型 = CV整数容器 @默认值 = 空对象>
    参数 样本权重 <类型 = CV向量容器2f 注释 = "包含每个样本的权重. 它应该具有CV_32F类型" @默认值 = 空对象>
    参数 变量类型 <类型 = CV矩阵类 注释 = "类型无符号8位整数,大小\' <number_of_variables_in_samples> +<number_of_variables_in_responses> \',"
            注释 = "包含每个输入和输出变量的类型." @默认值 = 空对象>
    {
        @ obj = cv::ml::TrainData::create(@<输入样本>.obj, @<样本类型>, @<响应矩阵>.obj,@<变量容器>.obj,@<标签容器>.obj,  @<样本权重>.obj, @<变量类型>.obj);
        返回 (本对象)
    }

    方法 获取样本类型 <公开 类型 = 整数 注释 = "getLayout" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getLayout();
    }

    方法 获取训练样本数量 <公开 类型 = 整数 注释 = "getNTrainSamples" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getNTrainSamples();
    }

    方法 获取测试样本数量 <公开 类型 = 整数 注释 = "getNTestSamples" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getNTestSamples();
    }

    方法 获取样本数量 <公开 类型 = 整数 注释 = "getNSamples" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getNSamples();
    }

    方法 获取变量数量 <公开 类型 = 整数 注释 = "getNVars" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getNVars();
    }

    方法 获取所有变量数量 <公开 类型 = 整数 注释 = "getNAllVars" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getNAllVars();
    }

    方法 获取训练样本 <公开 类型 = CV矩阵类 注释 = "getTrainSamples">
    参数 样本类型 <类型 = CV样本类型常量 @默认值 = CV样本类型常量.行样本>
    参数 压缩样本 <类型 = 逻辑型 注释 = "如果为真,函数只返回训练样本." @默认值 = 真>
    参数 压缩变量 <类型 = 逻辑型 注释 = "如果为真,函数返回较短的训练样本,只包含活跃的变量." @默认值 = 真>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTrainSamples(@<样本类型>, @<压缩样本>, @<压缩变量>);
        返回 (返回矩阵)
    }

    方法 获取训练响应矩阵 <公开 类型 = CV矩阵类 注释 = "getTrainResponses">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTrainResponses();
        返回 (返回矩阵)
    }

    方法 获取测试响应矩阵 <公开 类型 = CV矩阵类 注释 = "getTestResponses">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTestResponses();
        返回 (返回矩阵)
    }

    方法 获取响应矩阵 <公开 类型 = CV矩阵类 注释 = "getResponses">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getResponses();
        返回 (返回矩阵)
    }

    方法 获取样本权重 <公开 类型 = CV矩阵类 注释 = "getSampleWeights">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getSampleWeights();
        返回 (返回矩阵)
    }

    方法 获取训练样本权重 <公开 类型 = CV矩阵类 注释 = "getTrainSampleWeights">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTrainSampleWeights();
        返回 (返回矩阵)
    }

    方法 获取测试样本权重 <公开 类型 = CV矩阵类 注释 = "getTestSampleWeights">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTestSampleWeights();
        返回 (返回矩阵)
    }

    方法 获取训练样本索引 <公开 类型 = CV矩阵类 注释 = "getTrainSampleIdx">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTrainSampleIdx();
        返回 (返回矩阵)
    }

    方法 获取测试样本索引 <公开 类型 = CV矩阵类 注释 = "getTestSampleIdx">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTestSampleIdx();
        返回 (返回矩阵)
    }

    方法 设置训练样本比例 <公开 注释 = "setTrainTestSplit">
    参数 训练样本比例 <类型 = 整数 注释 = "范围值1-100,如为50,比例就是百分之50.">
    参数 是否乱序 <类型 = 逻辑型 注释 = "为真时,打乱样本顺序." @默认值 = 假>
    {
        @ if(obj ==nullptr)return;
        @ obj->setTrainTestSplit(@<训练样本比例>, @<是否乱序>);
    }

    方法 打乱样本顺序 <公开 注释 = "shuffleTrainTest">
    {
        @ if(obj ==nullptr)return;
        @ obj->shuffleTrainTest();
    }

    方法 获取测试样本 <公开 类型 = CV矩阵类 注释 = "getTestSamples">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getTestSamples();
        返回 (返回矩阵)
    }

    方法 获取标签 <公开 类型 = CV矩阵类 注释 = "getClassLabels">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getClassLabels();
        返回 (返回矩阵)
    }

    方法 获取CSV样本名称 <公开 注释 = "getNames">
    参数 输出名称数组 <类型 = CV文本容器>
    {
        @ obj->getNames(@<输出名称数组>.obj);
    }

    方法 获取子向量 <公开 类型 = CV矩阵类 注释 = "getSubVector">
    参数 输入向量 <类型 = CV矩阵类 注释 = "有符号32位整数, 32位浮点型, 64位浮点型.">
    参数 一维索引 <类型 = CV矩阵类>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getSubVector(@<输入向量>.obj, @<一维索引>.obj);
        返回 (返回矩阵)
    }

    方法 获取子矩阵 <公开 类型 = CV矩阵类 注释 = "getSubMatrix">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "有符号32位整数, 32位浮点型, 64位浮点型">
    参数 一维索引 <类型 = CV矩阵类>
    参数 样本类型 <类型 = CV样本类型常量>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getSubMatrix(@<输入矩阵>.obj, @<一维索引>.obj, @<样本类型>);
        返回 (返回矩阵)
    }
}

类 CV智能剪刀类 <公开 注释 = "IntelligentScissorsMB,这个类用于找到两点之间的路径(轮廓)可用于图像分割.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::segmentation::IntelligentScissorsMB obj;
    # <> </include>
    # @end

    方法 设置权重 <公开 类型 = CV智能剪刀类 注释 = "setWeights,设置智能剪刀的相关权重,离散动态规划(DP)的目标是使像素间的计算难度最小.">
    参数 边缘权重 <类型 = 小数 注释 = "指定非边缘像素的权重(默认值:0.43f)" @默认值 = 0.43>
    参数 梯度权重 <类型 = 小数 注释 = "指定梯度方向函数的权重(默认值:0.43f)" @默认值 = 0.43>
    参数 梯度振幅权重 <类型 = 小数 注释 = "指定梯度幅度函数的权重(默认值:0.14f)" @默认值 = 0.43>
    {
        @ obj = obj.setWeights((float)@<边缘权重>, (float)@<梯度权重>, (float)@<梯度振幅权重>);
        返回 (本对象)
    }

    方法 设置梯度振幅最大阈值 <公开 类型 = CV智能剪刀类 注释 = "setGradientMagnitudeMaxLimit,指定梯度幅度最大值阈值.">
    参数 梯度振幅最大阈值 <类型 = 小数 @默认值 = 0.0>
    {
        @ obj = obj.setGradientMagnitudeMaxLimit((float)@<梯度振幅最大阈值>);
        返回 (本对象)
    }

    方法 设置拉普拉斯交零点值参数 <公开 类型 = CV智能剪刀类
            注释 = "setEdgeFeatureZeroCrossingParameters,切换到“拉普拉斯交零点值(Laplacian Zero-Crossing)”边缘特征提取器并指定其参数.">
    参数 梯度振幅最大阈值 <类型 = 小数 注释 = "指定梯度幅度最大值阈值(默认值:0,禁用)." @默认值 = 0>
    {
        @ obj = obj.setEdgeFeatureZeroCrossingParameters((float)@<梯度振幅最大阈值>);
        返回 (本对象)
    }

    方法 设置Canny边缘检测参数 <公开 类型 = CV智能剪刀类 注释 = "setEdgeFeatureCannyParameters,切换边缘特征提取采用Canny边缘检测并设置其参数.">
    参数 低阈值 <类型 = 小数 注释 = "迟滞过程的第一个阈值">
    参数 高阈值 <类型 = 小数 注释 = "迟滞过程的第二个阈值">
    参数 孔径尺寸 <类型 = 整数 注释 = "这里指 Sobel算子的孔径大小" @默认值 = 3>
    参数 查找高精度 <类型 = 逻辑型 注释 = "是否使用高精度的查找,为真时使用高精度查找." @默认值 = 假>
    {
        @ obj = obj.setEdgeFeatureCannyParameters(@<低阈值>, @<高阈值>, @<孔径尺寸>, @<查找高精度>);
        返回 (本对象)
    }

    方法 使用智能剪刀 <公开 类型 = CV智能剪刀类 注释 = "applyImage,应用智能剪刀处理图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "需要处理的图像,类型为#无符号8位整数1通道 / #无符号8位整数3通道.">
    {
        @ obj = obj.applyImage(@<源图像>.obj);
        返回 (本对象)
    }

    方法 使用特征智能剪刀 <公开 类型 = CV智能剪刀类 注释 = "applyImageFeatures,应用智能剪刀处理图像,为函数  使用智能剪刀  的变体.">
    参数 非边缘掩膜 <类型 = CV矩阵类 注释 = "指定非边缘像素的开销. 类型是CV_8UC1">
    参数 梯度方向特征 <类型 = CV矩阵类 注释 = "指定梯度方向特性">
    参数 梯度振幅 <类型 = CV矩阵类 注释 = "指定梯度幅度函数的代价:类型为浮点1通道32位">
    参数 源图像 <类型 = CV矩阵类 注释 = "* *可选参数* *图像. 如果指定了特性子集,则必须指定(未指定的特性在内部计算)." @默认值 = 空对象>
    {
        @ obj = obj.applyImage(@<源图像>.obj);
        返回 (本对象)
    }

    方法 建立映射 <公开 注释 = "buildMap,为图像上给定的源点准备一个最优路径的映射.">
    参数 映射原点 <类型 = CV坐标点 注释 = "作为智能查找边缘轮廓的原点(起始点)">
    {
        @ obj.buildMap(@<映射原点>.obj);
    }

    方法 获取轮廓 <公开 注释 = "getContour,提取图像上给定    目标点  与 映射原点   的最优轮廓.">
    参数 目标点 <类型 = CV坐标点>
    参数 输出轮廓 <类型 = CV坐标容器>
    参数 是否倒序 <类型 = 逻辑型 注释 = "为真时,输出的轮廓点顺序为 目标点--->映射原点." @默认值 = 假>
    {
        @ obj.getContour(@<目标点>.obj, @<输出轮廓>.obj, @<是否倒序>);
    }
}

类 CV支持向量机核心类型 <公开 注释 = "KernelTypes" @常量类 = 整数>
{
    常量 自定义内核 <公开 值 = -1 注释 = "-1,CUSTOM,自定义内核.">
    常量 线性内核 <公开 值 = 0 注释 = "0,LINEAR,线性内核. 相当于不进行映射处理,在原始特征空间中进行线性判别(或回归). 这是运行速度最快的选择,但是拟合程度不高.">
    常量 多项式的内核 <公开 值 = 1 注释 = "1,POLY,多项式的内核 ；参数：[GAMMA,COEF,DEGREE].">
    常量 径向基函数内核 <公开 值 = 2 注释 = "2,RBF,径向基函数(RBF)是一种很好的选择；参数：[GAMMA].">
    常量 Sigmoid内核 <公开 值 = 3 注释 = "3,SIGMOID,Sigmoid kernel；参数：[GAMMA,COEF].">
    常量 Chi2指数核 <公开 值 = 4 注释 = "4,CHI2,Chi2指数核,类似于RBF核；参数：[GAMMA].">
    常量 直方图相交的内核 <公开 值 = 5 注释 = "5,INTER,直方图相交的内核. 一种快速的内核.">
}

类 CV支持向量机模型类型 <公开 注释 = "Types" @常量类 = 整数>
{
    常量 C支持向量分类 <公开 值 = 100 注释 = "100,C_SVC,C支持向量分类. n类分类(n≥2),允许对异常值使用惩罚乘子C进行不完全分类.">
    常量 ν支持向量分类 <公开 值 = 101 注释 = "101,NU_SVC,ν支持向量分类. n类分类,可能不完全分离. 参数ν(范围0-1、值越大,决策边界越平滑),用来代替C.">
    常量 分布估计 <公开 值 = 102 注释 = "102,ONE_CLASS,分布估计(一类支持向量机). 所有的训练数据都来自同一类,支持向量机建立了一个边界,将类从特征空间的其余部分分离出来.">
    常量 ϵ支持向量回归 <公开 值 = 103 注释 = "103,EPS_SVR,ϵ支持向量回归. 从训练集到拟合超平面的特征向量之间的距离必须小于p. 对于异常值,使用惩罚乘法器C.">
    常量 ν支持向量回归 <公开 值 = 104 注释 = "104,NU_SVR,ν支持向量回归. ν代替p.">
}

类 CV支持向量机参数类型 <公开 注释 = "ParamTypes" @常量类 = 整数>
{
    常量 C <公开 值 = 0 注释 = "0,C">
    常量 伽马 <公开 值 = 1 注释 = "1,GAMMA">
    常量 P <公开 值 = 2 注释 = "2,P">
    常量 ν <公开 值 = 3 注释 = "3,NU">
    常量 相关系数 <公开 值 = 4 注释 = "4,COEF">
    常量 度数 <公开 值 = 5 注释 = "5,DEGREE">
}

类 CVKMean算法常量 <公开 注释 = "KmeansFlags" @常量类 = 整数>
{
    常量 不指定 <公开 值 = -1 注释 = "极个别算法有效">
    常量 随机中心点 <公开 值 = 0 注释 = "0,KMEANS_RANDOM_CENTERS,在每次尝试中随机选择初始中心.">
    常量 指定中心点 <公开 值 = 2 注释 = "2,KMEANS_PP_CENTERS,使用KMean++中心初始化由Arthur和Vassilvitskii [Arthur2007].">
    常量 使用标签初始化中心点 <公开 值 = 1 注释 = "1,KMEANS_USE_INITIAL_LABELS,在第一次(也可能是唯一一次)尝试时,使用."
            注释 = "用户提供的标签,而不是从初始中心计算它们. 对于第二个和进一步尝试,使用随机或半随机中心." 注释 = "使用KMEANS_CENTERS标志之一指定精确的方法.">
}

类 CV矩阵简化常量 <公开 注释 = "ReduceTypes" @常量类 = 整数>
{
    常量 不指定 <公开 值 = -1 注释 = "-1,极个别算法有效.">
    常量 矩阵之和 <公开 值 = 0 注释 = "0,REDUCE_SUM,输出是矩阵所有行/列的和.">
    常量 矩阵均值 <公开 值 = 1 注释 = "1,REDUCE_AVG,输出是矩阵所有行/列的平均向量.">
    常量 矩阵最大值 <公开 值 = 2 注释 = "2,REDUCE_MAX,输出是矩阵所有行/列的最大值(按列/行).">
    常量 矩阵最小值 <公开 值 = 3 注释 = "3,REDUCE_MIN,输出是矩阵中所有行/列的最小值(按列/行).">
}

类 CV排序方法常量 <公开 注释 = "SortFlags" @常量类 = 整数>
{
    常量 行独立排序 <公开 值 = 0 注释 = "0,SORT_EVERY_ROW,每个矩阵行都是独立排序的.">
    常量 列独立排序 <公开 值 = 1 注释 = "1,SORT_EVERY_COLUMN,每个矩阵列独立排序； 这个标志和前一个标志是互斥的.">
    常量 行升序排列 <公开 值 = 0 注释 = "0,SORT_ASCENDING,每个矩阵行按升序排序.">
    常量 行降序排列 <公开 值 = 16 注释 = "16,SORT_DESCENDING,每个矩阵行按降序排序； 这个标志和前一个标志也是互斥的.">
}

