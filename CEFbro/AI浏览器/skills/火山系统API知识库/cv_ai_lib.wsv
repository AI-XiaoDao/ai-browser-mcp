    {
        @ @an<CVolMem> memBuf1,memBuf2;
        @ cv::dnn::writeTextGraph(GetMbsText (@<输入权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<输出文本文件>.GetText (), memBuf2, NULL));
    }

    方法 抑制Boxs正交矩形 <公开 静态 注释 = "NMSBoxes,非极大值抑制Box.">
    参数 输入矩形容器 <类型 = CV矩形类容器 注释 = "需要被抑制的矩形数组(容器)">
    参数 置信度容器 <类型 = CV单精度小数容器 注释 = "输出抑制后置信度数组(容器)">
    参数 置信度阈值 <类型 = 小数 注释 = "大于该阈值的目标被保留,0≤置信度阈值≤1.">
    参数 非极大值抑制阈值 <类型 = 小数 注释 = "非极大值抑制的阈值,0≤非极大值抑制阈值≤1.">
    参数 保留索引 <类型 = CV整数容器 注释 = "输出抑制后保留索引">
    参数 eta系数 <类型 = 小数 注释 = "自适应阈值公式中的Eta系数：_threshold_{i+1}=eta\\cdot nms\\_threshold_i" @默认值 = 1.0>
    参数 最大保留 <类型 = 整数 注释 = "为0时不指定,指定后只保留指定的结果个数." @默认值 = 0>
    {
        @ cv::dnn::NMSBoxes(@<输入矩形容器>.obj, @<置信度容器>.obj, (float)@<置信度阈值>, (float)@<非极大值抑制阈值>, @<保留索引>.obj, (float)@<eta系数>, @<最大保留>);
    }

    方法 抑制Boxs正交矩形小数 <公开 静态 注释 = "NMSBoxes,非极大值抑制Box.">
    参数 输入矩形容器 <类型 = CV矩形类小数容器 注释 = "需要被抑制的矩形数组(容器)">
    参数 置信度容器 <类型 = CV单精度小数容器 注释 = "输出抑制后置信度数组(容器)">
    参数 置信度阈值 <类型 = 小数 注释 = "大于该阈值的目标被保留,0≤置信度阈值≤1.">
    参数 非极大值抑制阈值 <类型 = 小数 注释 = "非极大值抑制的阈值,0≤非极大值抑制阈值≤1.">
    参数 保留索引 <类型 = CV整数容器 注释 = "抑制后保留索引">
    参数 eta系数 <类型 = 小数 注释 = "自适应阈值公式中的Eta系数：_threshold_{i+1}=eta\\cdot nms\\_threshold_i" @默认值 = 1.0>
    参数 最大保留 <类型 = 整数 注释 = "为0时不指定,指定后只保留指定的结果个数." @默认值 = 0>
    {
        @ cv::dnn::NMSBoxes(@<输入矩形容器>.obj, @<置信度容器>.obj, (float)@<置信度阈值>, (float)@<非极大值抑制阈值>, @<保留索引>.obj, (float)@<eta系数>, @<最大保留>);
    }

    方法 抑制Boxs自由矩形 <公开 静态 注释 = "NMSBoxes,非极大值抑制Box.">
    参数 输入矩形容器 <类型 = CV自由矩形类容器 注释 = "需要被抑制的矩形数组(容器)">
    参数 置信度容器 <类型 = CV单精度小数容器 注释 = "输出抑制后置信度数组(容器)">
    参数 置信度阈值 <类型 = 小数 注释 = "大于该阈值的目标被保留,0≤置信度阈值≤1.">
    参数 非极大值抑制阈值 <类型 = 小数 注释 = "非极大值抑制的阈值,0≤非极大值抑制阈值≤1.">
    参数 保留索引 <类型 = CV整数容器 注释 = "抑制后保留索引">
    参数 eta系数 <类型 = 小数 注释 = "自适应阈值公式中的Eta系数：_threshold_{i+1}=eta\\cdot nms\\_threshold_i" @默认值 = 1.0>
    参数 最大保留 <类型 = 整数 注释 = "为0时不指定,指定后只保留指定的结果个数." @默认值 = 0>
    {
        @ cv::dnn::NMSBoxes(@<输入矩形容器>.obj, @<置信度容器>.obj, (float)@<置信度阈值>, (float)@<非极大值抑制阈值>, @<保留索引>.obj, (float)@<eta系数>, @<最大保留>);
