        @ obj = cv::Mat(@<输入容器>.obj);
    }

    方法 创建矩阵从尺寸 <公开 静态 类型 = CV矩阵类 注释 = "eye,根据矩阵尺寸创建一个矩阵.">
    参数 宽 <类型 = 整数 注释 = "欲创建的矩阵宽度">
    参数 高 <类型 = 整数 注释 = "欲创建的矩阵高度">
