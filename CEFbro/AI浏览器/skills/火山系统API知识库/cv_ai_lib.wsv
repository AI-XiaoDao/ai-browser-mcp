类 CV窗口属性名称常量 <公开 注释 = "WindowPropertyFlags,可以在设置窗口属性时使用." @常量类 = 整数>
{
    常量 全屏 <公开 值 = 0 注释 = "0,WND_PROP_FULLSCREEN,全屏.">
    常量 自动大小 <公开 值 = 1 注释 = "1,WND_PROP_AUTOSIZE,自动大小.">
    常量 保持图像显示比例 <公开 值 = 2 注释 = "2,WND_PROP_ASPECT_RATIO,保持图像显示比例.">
    常量 启用opengl支持 <公开 值 = 3 注释 = "3,WND_PROP_OPENGL,opengl的支持.">
    常量 是否可见 <公开 值 = 4 注释 = "4,WND_PROP_VISIBLE,是否可见.">
    常量 保持窗口在最上层 <公开 值 = 5 注释 = "5,WND_PROP_TOPMOST,属性以将普通窗口切换为最上方或非最上方.">
}

类 CV窗口属性值 <公开 注释 = "WindowFlags,可以在设置窗口属性时使用." @常量类 = 整数>
{
    常量 标准窗口 <公开 值 = 0x00000000 注释 = "WINDOW_NORMAL,用户可以调整窗口的大小(没有限制)/也可以将全屏窗口切换到正常大小.">
    常量 自动大小 <公开 值 = 0x00000001 注释 = "WINDOW_AUTOSIZE,用户无法调整窗口的大小,大小受所显示图像的限制.">
    常量 启用opengl支持 <公开 值 = 0x00001000 注释 = "WINDOW_OPENGL,支持opengl的窗口.">
    常量 全屏显示 <公开 值 = 1 注释 = "WINDOW_FULLSCREEN,将窗口更改为全屏.">
    常量 自由偏差 <公开 值 = 0x00000100 注释 = "WINDOW_FREERATIO,图像尽可能多地消耗(没有比例限制).">
    常量 保证显示比例 <公开 值 = 0x00000000 注释 = "WINDOW_KEEPRATIO,图像的比例得到保证.">
    常量 显示状态栏 <公开 值 = 0x00000000 注释 = "WINDOW_GUI_EXPANDED,状态栏和工具栏.">
    常量 旧标准窗口 <公开 值 = 0x00000010 注释 = "WINDOW_GUI_NORMAL,老fashious方式.">
}

