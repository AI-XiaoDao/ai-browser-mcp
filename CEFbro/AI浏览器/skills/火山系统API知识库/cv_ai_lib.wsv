    方法 克隆 <公开 类型 = CV矩阵类 注释 = "clone,克隆的矩阵与原矩阵具有相同指针." 返回值注释 = "返回一个矩阵,与原矩阵具有相同指针">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.clone();
        返回 (返回矩阵)
    }

    方法 复制 <公开 类型 = CV矩阵类 注释 = "copyTo,与克隆不同,复制的对象具有独立的指针." 返回值注释 = "返回一个矩阵,拥有独立指针">
    参数 掩膜 <类型 = CV矩阵类 注释 = "如果为空对象则全部复制,否则只复制掩膜区域" @默认值 = 空对象>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(@<掩膜>==NULL){obj.copyTo(@<返回矩阵>.obj);}
        @ else{ obj.copyTo(@<返回矩阵>.obj, @<掩膜>.obj);}
        返回 (返回矩阵)
    }

    方法 取行数据 <公开 类型 = CV矩阵类 注释 = "row,从矩阵中获取指定索引行的数据." 返回值注释 = "返回的矩阵与原矩阵的数据行具有相同的指针,对其进行操作会修改原矩阵的数据.">
    参数 索引 <类型 = 整数 注释 = "第几行">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.row(@<索引>);
        返回 (返回矩阵)
    }

    方法 取列数据 <公开 类型 = CV矩阵类 注释 = "col,从矩阵中获取指定索引列的数据." 返回值注释 = "返回的矩阵与原矩阵的数据行具有相同的指针,对其进行操作会修改原矩阵的数据.">
    参数 索引 <类型 = 整数 注释 = "第几列">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.col(@<索引>);
        返回 (返回矩阵)
    }

    方法 从文件加载 <公开 类型 = CV矩阵类 注释 = "imread,就是读入文件." 返回值注释 = "返回本对象">
    参数 文件路径 <类型 = 文本型 注释 = "欲读入的文件路径">
    参数 读入方式 <类型 = CV图像读入常量 注释 = "欲读入的图像(矩阵)颜色空间类型" @默认值 = CV图像读入常量.转彩色图>
    {
        @ @an<CVolMem> memBuf1;
        @ obj = cv::imread(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL),@<读入方式>);
        返回 (本对象)
    }

