类 人脸信息类 <公开 注释 = "lite::types::FaceContent,人脸特征类,用于比对人脸相似度,也就是人脸识别.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # lite::types::FaceContent obj;
    # <> </include>
    # @end

    方法 取人脸特征 <公开 类型 = 字节集类 注释 = "获取字节集人脸信息,方便存储." 返回值注释 = "返回人脸信息">
    {
        变量 返回数据 <类型 = 字节集类>
        变量 小数容器 <类型 = CV单精度小数容器>
        @ @<小数容器>.obj.assign(obj.embedding.begin(), obj.embedding.end());
        返回数据.分配字节集 (小数容器.取成员数 () * 4)
        计次循环 (小数容器.取成员数 ())
        {
            返回数据.置字节集单精度小数 (取循环索引 () * 4, (单精度小数)小数容器.取成员 (取循环索引 ()))
        }
        返回 (返回数据)
    }

    方法 取标志状态 <公开 类型 = 逻辑型 注释 = "特征存在则返回真" @禁止流程检查 = 真>
    {
        @ return obj.flag;
    }

    方法 置人脸特征 <公开 注释 = "从存储的字节集载入人脸信息">
    参数 输入特征 <类型 = 字节集类 注释 = "以往提取保存的字节集人脸特征">
    {
        变量 小数容器 <类型 = CV单精度小数容器>
        计次循环 (输入特征.取字节集单精度小数数目 ())
        {
            小数容器.加入成员 (输入特征.取字节集单精度小数 (取循环索引 () * 4))
        }
        @ obj.embedding.assign(@<小数容器>.obj.begin(), @<小数容器>.obj.end());
        @ obj.flag = true;
    }

    方法 比对人脸信息 <公开 静态 类型 = 小数 注释 = "对两个人脸图信息做比对,计算其欧式距离差值,并返回其相似度." 返回值注释 = "返回两个人脸信息的相似度,0≤返回值≤1." @禁止流程检查 = 真>
    参数 输入待比对人脸1 <类型 = 人脸信息类 注释 = "欲比对的人脸信息1">
    参数 输入待比对人脸2 <类型 = 人脸信息类 注释 = "欲比对的人脸信息2">
    {
        变量 返回相似度 <类型 = 小数 值 = 0.0>
        @  if (@<输入待比对人脸1>.obj.flag &&  @<输入待比对人脸2>.obj.flag)
        @        return lite::utils::math::cosine_similarity<float>(@<输入待比对人脸1>.obj.embedding,  @<输入待比对人脸2>.obj.embedding);
        返回 (返回相似度)
    }
}

