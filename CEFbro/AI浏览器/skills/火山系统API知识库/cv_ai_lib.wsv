类 CV卡尔曼滤波类 <公开 注释 = "KalmanFilter">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::KalmanFilter obj;
    # <> </include>
    # @end

    方法 初始化滤波器 <公开 类型 = CV卡尔曼滤波类 注释 = "KalmanFilter">
    参数 状态维度 <类型 = 整数>
    参数 测量维度 <类型 = 整数>
    参数 控制向量维度 <类型 = 整数 @默认值 = 0>
    参数 矩阵类型 <类型 = CV数值类型 注释 = "CV_32位浮点型 或 CV_64位浮点型." @默认值 = CV数值类型.CV_32位浮点型>
    {
        @ obj = cv::KalmanFilter(@<状态维度>, @<测量维度>, @<控制向量维度>, @<矩阵类型>);
        返回 (本对象)
    }

    方法 预测状态矩阵 <公开 属性写 注释 = "statePre,(x\'(k)): x(k)=A*x(k-1)+B*u(k).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.statePre = @<值>.obj;
    }

    方法 修正状态矩阵 <公开 属性写 注释 = "statePost,(x(k)): x(k)=x\'(k)+K(k)*(z(k)-H*x\'(k)).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.statePost = @<值>.obj;
    }

    方法 状态转移矩阵 <公开 属性写 注释 = "transitionMatrix, 状态转移矩阵(A).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.transitionMatrix = @<值>.obj;
    }

    方法 控制矩阵 <公开 属性写 注释 = "controlMatrix,控制矩阵(B)(没有控制时不使用).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.controlMatrix = @<值>.obj;
    }

    方法 测量矩阵 <公开 属性写 注释 = "measurementMatrix,测量矩阵(H).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.measurementMatrix = @<值>.obj;
    }

    方法 过程噪声协方差矩阵 <公开 属性写 注释 = "processNoiseCov,过程噪声协方差矩阵(Q).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.processNoiseCov = @<值>.obj;
    }

    方法 测量噪声协方差矩阵 <公开 属性写 注释 = "measurementNoiseCov,测量噪声协方差矩阵(R).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.measurementNoiseCov = @<值>.obj;
    }

    方法 先验误差估计协方差矩阵 <公开 属性写 注释 = "errorCovPre,先验误差估计协方差矩阵P\'(k).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.errorCovPre = @<值>.obj;
    }

    方法 卡尔曼滤波增益矩阵 <公开 属性写 注释 = "gain,卡尔曼滤波增益矩阵(K (K)): K (K) = P”(K) * Ht *inv(H * P \' (K) * Ht + R).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.gain = @<值>.obj;
    }

    方法 后验误差估计协方差矩阵 <公开 属性写 注释 = "errorCovPost,后验误差估计协方差矩阵(P(k)): P(k)=(I-K(k)*H)*P\'(k).">
    参数 值 <类型 = CV矩阵类>
    {
        @ obj.errorCovPost = @<值>.obj;
    }

    方法 预测状态矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "statePre,(x\'(k)): x(k)=A*x(k-1)+B*u(k).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.statePre;
        返回 (值)
    }

    方法 修正状态矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "statePost,(x(k)): x(k)=x\'(k)+K(k)*(z(k)-H*x\'(k)).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.statePost;
        返回 (值)
    }

    方法 状态转移矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "transitionMatrix, 状态转移矩阵(A).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.transitionMatrix;
        返回 (值)
    }

    方法 控制矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "controlMatrix,控制矩阵(B)(没有控制时不使用).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.controlMatrix;
        返回 (值)
    }

    方法 测量矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "measurementMatrix,测量矩阵(H).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.measurementMatrix;
        返回 (值)
    }

    方法 过程噪声协方差矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "processNoiseCov,过程噪声协方差矩阵(Q).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.processNoiseCov;
        返回 (值)
    }

    方法 测量噪声协方差矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "measurementNoiseCov,测量噪声协方差矩阵(R).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.measurementNoiseCov;
        返回 (值)
    }

    方法 先验误差估计协方差矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "errorCovPre,先验误差估计协方差矩阵P\'(k).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.errorCovPre;
        返回 (值)
    }

    方法 卡尔曼滤波增益矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "gain,卡尔曼滤波增益矩阵(K (K)): K (K) = P”(K) * Ht *inv(H * P \' (K) * Ht + R).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.gain;
        返回 (值)
    }

    方法 后验误差估计协方差矩阵 <公开 属性读 类型 = CV矩阵类 注释 = "errorCovPost,后验误差估计协方差矩阵(P(k)): P(k)=(I-K(k)*H)*P\'(k).">
    {
        变量 值 <类型 = CV矩阵类>
        @ @<值>.obj = obj.errorCovPost;
        返回 (值)
    }

    方法 预测 <公开 类型 = CV矩阵类 注释 = "predict()" 返回值注释 = "返回包含测量结果的矩阵">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.predict();
        返回 (返回矩阵)
    }

    方法 校准 <公开 类型 = CV矩阵类 注释 = "correct()" 返回值注释 = "返回包含校准结果的矩阵">
    参数 测量矩阵 <类型 = CV矩阵类>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.correct(@<测量矩阵>.obj);
        返回 (返回矩阵)
    }
}

类 CV仿射变换常量类 <公开 注释 = "MOTION" @常量类 = 整数>
{
    常量 平移 <公开 值 = 0 注释 = "0,MOTION_TRANSLATION,将第一幅图像平移(x, y)得到第二幅图像. 我们只需要估算两个参数x和y.">
    常量 平移及旋转 <公开 值 = 1
            注释 = "1,MOTION_EUCLIDEAN,第一幅图像是第二幅图像的旋转和移位版本. 所以有三个参数——x,y和角度. 你会注意到在图2中,当一个正方形经过欧几里德(Euclidean)变换时,大小不变,平行线保持平行,直角在变换后保持不变.">
    常量 平移及旋转和缩放 <公开 值 = 2 注释 = "2,MOTION_AFFINE,仿射变换是旋转、平移、缩放和剪切的组合. 该变换有六个参数. 当正方形经过仿射变换时,平行线保持平行,但以直角相交的线不再保持正交.">
    常量 三维变换 <公开 值 = 3
            注释 = "3,MOTION_HOMOGRAPHY,上述所有变换都是2D变换. 它们不考虑3D效果. 而单应性变换则可以解释一些3D效果(但不是全部). 该转换有8个参数. 使用单应变换时,正方形可以变成任何四边形.">
}

类 CV绘制匹配标志常量类 <公开 注释 = "DrawMatchesFlags" @常量类 = 整数>
