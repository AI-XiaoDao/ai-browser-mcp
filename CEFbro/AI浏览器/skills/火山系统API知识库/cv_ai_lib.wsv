    方法 写中文图像文本 <公开 静态 注释 = "自定义函数,可以将中文、英文写到图像中.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "将要写入文本的图像">
    参数 绘制文本 <类型 = 文本型 注释 = "需要绘制的文本">
    参数 X坐标 <类型 = 整数 注释 = "在输入图像中的左上角X坐标">
    参数 Y坐标 <类型 = 整数 注释 = "在输入图像中的左上角Y坐标">
    参数 颜色 <类型 = CV标量类 注释 = "文本的颜色">
    参数 字体尺寸 <类型 = 整数 注释 = "字体尺寸,单位为磅.">
    参数 字体名称 <类型 = 文本型 注释 = "指定字体,为空文本表示使用系统默认GUI字体." @默认值 = "">
    参数 斜体 <类型 = 逻辑型 注释 = "是否使用斜体" @默认值 = 假>
    参数 下划线 <类型 = 逻辑型 注释 = "是否绘制下划线" @默认值 = 假>
    参数 粗体 <类型 = 逻辑型 注释 = "是否使用粗体" @默认值 = 假>
    {
        @ putTextZH(@<输入图像>.obj, @<绘制文本>.GetText (), Point(@<X坐标>, @<Y坐标>), @<颜色>.obj, @<字体尺寸>, @<字体名称>.GetText (), @<斜体>, @<下划线>, @<粗体>);
    }

    方法 显示图像 <公开 静态 注释 = "如果不存在“输入窗口标题”相同的CV窗口,则重新创建一个.">
    参数 输入窗口标题 <类型 = 文本型>
    参数 输入图像 <类型 = CV矩阵类 注释 = "必须是无符号整数1通道或者3通道的矩阵">
    参数 输入窗口宽度 <类型 = 整数 注释 = "为-1时自动设置窗口大小" @默认值 = -1>
    参数 输入窗口高度 <类型 = 整数 注释 = "为-1时自动设置窗口大小" @默认值 = -1>
    {
        @ @an<CVolMem> memBuf1;
        @ const char* hd = GetMbsText (@<输入窗口标题>.GetText (), memBuf1, NULL);
        @ if(@<输入窗口宽度> != -1 && @<输入窗口高度> != -1){
        @     cv::namedWindow(hd,cv::WINDOW_NORMAL);
        @     cv::resizeWindow(hd,@<输入窗口宽度>,@<输入窗口高度>);}
        @ else {
        @     cv::namedWindow(hd,cv::WINDOW_AUTOSIZE);}
        @ cv::imshow(hd, @<输入图像>.obj);
    }

    方法 创建CV窗口 <公开 静态 类型 = 变整数 注释 = "在控件中嵌入一个CV窗口,注意,嵌入窗口后," 注释 = "所有CV窗口回调事件将无效,且无法在在其它线程显示图像." @禁止流程检查 = 真>
    参数 窗口标题 <类型 = 文本型 注释 = "//此标题将作为显示图像的标识" @默认值 = "CVWindow">
    参数 窗口宽度 <类型 = 整数 注释 = "为-1时自动指定,否则以指定值为窗口宽度" @默认值 = -1>
    参数 窗口高度 <类型 = 整数 注释 = "为-1时自动指定,否则以指定值为窗口高度" @默认值 = -1>
    参数 父窗口组件句柄 <类型 = 变整数 注释 = "作为CV窗口 父窗口的 组件句柄">
    {
        @ @an<CVolMem> memBuf1;
        @ const char* hd = GetMbsText (@<窗口标题>.GetText (), memBuf1, NULL);
        @ if( @<窗口宽度> != -1 && @<窗口高度> != -1){
        @     cv::namedWindow(hd,cv::WINDOW_NORMAL);
        @     cv::resizeWindow(hd,@<窗口宽度>,@<窗口高度>);}
        @ else{
        @     cv::namedWindow(hd,cv::WINDOW_AUTOSIZE);}
        @ HWND m_wincv = (HWND)cvGetWindowHandle(hd);//获取opencv窗口句柄
        @ HWND hParent1 = GetParent(m_wincv);//取窗口的父窗口句柄
        @ HWND hwnd1 = (HWND)@<父窗口组件句柄>;
        @ HWND hw = SetParent(m_wincv, hwnd1); // 设置新的父窗口句柄
        @ ::ShowWindow(hParent1, SW_HIDE);//隐藏原openCV窗口的边框
        @ return (INT_P)m_wincv;
    }

    方法 读入图像 <公开 静态 类型 = CV矩阵类 注释 = "imread,从文件中读入一个矩阵.">
    参数 文件名 <类型 = 文本型 注释 = "欲读入的图像文件路径">
    参数 图像读入方式 <类型 = CV图像读入常量 注释 = "欲读入的图像颜色空间类型" @默认值 = CV图像读入常量.转彩色图>
    {
        变量 返回图像 <类型 = CV矩阵类>
        @ @an<CVolMem> memBuf1;
        @ @<返回图像>.obj =cv::imread(GetMbsText (@<文件名>.GetText (), memBuf1, NULL), @<图像读入方式>);
        返回 (返回图像)
    }

    方法 置矩阵尺寸 <公开 静态 注释 = "resize,重置矩阵的尺寸.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲重置尺寸的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "重置尺寸后的矩阵">
    参数 输入重置尺寸 <类型 = CV尺寸类 注释 = "欲重置的尺寸">
    参数 输入插值方式 <类型 = CV插值方式常量 @默认值 = CV插值方式常量.双线性插值>
    {
        @ cv::resize(@<输入矩阵>.obj, @<输出矩阵>.obj, @<输入重置尺寸>.obj,@<输入插值方式>);
    }

    方法 取矩阵数据指针 <公开 静态 类型 = 变整数 注释 = "data,获取矩阵的指针." @禁止流程检查 = 真>
    参数 输入矩阵 <类型 = CV矩阵类>
    {
        @ return (@dt<变整数>)@<输入矩阵>.obj.data;
    }

    方法 截取图像矩形区域 <公开 静态 类型 = CV矩阵类 注释 = "截取一个矩形范围的图像为新图像" 返回值注释 = "返回截取图像">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲截取的图像(矩阵)">
    参数 输入矩形 <类型 = CV矩形类 注释 = "欲截取的矩形范围ROI">
    {
        变量 返回图像 <类型 = CV矩阵类>
        @ @<返回图像>.obj = @<输入图像>.obj(@<输入矩形>.obj);
        返回 (返回图像)
    }

    方法 修补图像 <公开 静态 注释 = "inpaint,可以修复指定ROI范围的图像纹理.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲处理的图像,输入8位,16位无符号或32位浮动1通道或8位3通道图像">
    参数 输入遮罩 <类型 = CV矩阵类 注释 = "需要修复的部位">
    参数 输出修复图像 <类型 = CV矩阵类 注释 = "修复完成的图像">
    参数 输入邻域半径 <类型 = 整数 注释 = "采用相邻半径内的元素修复图像">
    参数 输入算法 <类型 = CV修复常量>
    {
        @ cv::inpaint(@<输入图像>.obj, @<输入遮罩>.obj, @<输出修复图像>.obj,@<输入邻域半径>, @<输入算法>);
    }

    方法 二值化 <公开 静态 注释 = "threshold,将灰度图处理为二值图.">
    参数 输入源图像 <类型 = CV矩阵类 注释 = "必须是单通道8位的灰度图像">
    参数 输出二值图 <类型 = CV矩阵类 注释 = "只包含两个值的元素的矩阵,如(0,1) / (0,高阈值)">
    参数 阈值 <类型 = 小数 注释 = "对大于或者小于阈值的矩阵元素作相应处理">
    参数 最大值 <类型 = 小数 注释 = "当满足条件时,满足条件的元素改变为该值.">
    参数 计算类型 <类型 = 整数 注释 = "见CV二值化阈值类型常量,可以多个类型组合使用.">
    {
        @ cv::threshold(@<输入源图像>.obj, @<输出二值图>.obj, @<阈值>, @<最大值>, @<计算类型>);
    }

    方法 等待按键 <公开 静态 类型 = 整数 注释 = "waitKey,程序等待在窗口中按下按键后继续" 返回值注释 = "返回键代码" @禁止流程检查 = 真>
    参数 延时毫秒 <类型 = 整数 注释 = "为0时无限制等待" @默认值 = 0>
    {
        @ return cv::waitKey(@<延时毫秒>);
    }

    方法 写图像文本 <公开 静态 注释 = "putText,将文本写到图像中,该方法不支持中文,如果需要写入中文请使用 写图像文本中文.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 绘制文本 <类型 = 文本型 注释 = "将要写入的文本内容">
    参数 X坐标 <类型 = 整数 注释 = "文本的左上角X">
    参数 Y坐标 <类型 = 整数 注释 = "文本的左上角Y">
    参数 字体 <类型 = CV字体常量>
    参数 字体比例 <类型 = 小数 注释 = "注意不是字体大小,字体比例因子,乘以字体特定的基础大小,字体大小等于 参数 字体  的 大小 *  字体比例.">
    参数 颜色 <类型 = CV标量类 注释 = "文本颜色">
    参数 线条粗细 <类型 = 整数 @默认值 = 1>
    {
        @ @an<CVolMem> memBuf1;
        @ cv::putText(@<源图像>.obj,GetMbsText (@<绘制文本>.GetText (), memBuf1, NULL), Point(@<X坐标>, @<Y坐标>), @<字体>, @<字体比例>, @<颜色>.obj, @<线条粗细>);
    }

    方法 画直线 <公开 静态 注释 = "line,在图像中绘制一条直线.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 起点坐标 <类型 = CV坐标点 注释 = "直线的起点坐标">
    参数 终点坐标 <类型 = CV坐标点 注释 = "直线的终点坐标">
    参数 颜色 <类型 = CV标量类 注释 = "线条的颜色">
    参数 线条粗细 <类型 = 整数 注释 = "直线的线条粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "直线的线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::line(@<源图像>.obj, @<起点坐标>.obj, @<终点坐标>.obj, @<颜色>.obj, @<线条粗细>, @<线条类型>, @<小数位数>);
    }

    方法 画圆 <公开 静态 注释 = "circle,在图像中绘制一个空心圆.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 中心坐标 <类型 = CV坐标点 注释 = "圆中心坐标">
    参数 半径 <类型 = 整数 注释 = "圆半径">
    参数 颜色 <类型 = CV标量类 注释 = "绘制颜色">
    参数 线条粗细 <类型 = 整数 注释 = "形状线条粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "形状线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::circle(@<源图像>.obj, @<中心坐标>.obj, @<半径>, @<颜色>.obj, @<线条粗细>, @<线条类型>, @<小数位数>);
    }

    方法 画十字线 <公开 静态 注释 = "自定义函数,也可以用函数 画标记点 替代.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 中心坐标 <类型 = CV坐标点 注释 = "十字中心位置">
    参数 颜色 <类型 = CV标量类 注释 = "十字形的颜色">
    参数 半宽 <类型 = 整数 注释 = "十字的半宽">
    参数 线条粗细 <类型 = 整数 注释 = "十字线线条类型" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "十字线线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    {
        @ cv::line(@<源图像>.obj, cv::Point(@<中心坐标>.obj.x - @<半宽>, @<中心坐标>.obj.y - @<半宽>),  cv::Point(@<中心坐标>.obj.x + @<半宽>, @<中心坐标>.obj.y + @<半宽>), @<颜色>.obj, @<线条粗细>, @<线条类型>, 0);
        @ cv::line(@<源图像>.obj, cv::Point(@<中心坐标>.obj.x + @<半宽>, @<中心坐标>.obj.y - @<半宽>), cv::Point(@<中心坐标>.obj.x - @<半宽>, @<中心坐标>.obj.y + @<半宽>), @<颜色>.obj, @<线条粗细>, @<线条类型>, 0);
    }

    方法 画箭头 <公开 静态 注释 = "arrowedLine,绘制一个箭头到图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 起点 <类型 = CV坐标点 注释 = "箭头的起点">
    参数 终点 <类型 = CV坐标点 注释 = "箭头的终点">
    参数 颜色 <类型 = CV标量类 注释 = "绘制颜色">
    参数 线条粗细 <类型 = 整数 注释 = "形状线条的粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "形状线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    参数 箭头占比 <类型 = 小数 注释 = "箭头长度所占整个线条长度的比例" @默认值 = 0.1>
    {
        @ cv::arrowedLine(@<源图像>.obj, @<起点>.obj, @<终点>.obj, @<颜色>.obj, @<线条粗细>, @<线条类型>, @<小数位数>, @<箭头占比>);
    }

    方法 画椭圆 <公开 静态 注释 = "ellipse,在图中绘制一个椭圆.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 中心坐标 <类型 = CV坐标点 注释 = "椭圆中心坐标">
    参数 轴长 <类型 = CV尺寸类 注释 = "包含椭圆两个轴的长度的Size">
    参数 旋转角度 <类型 = 小数 注释 = "十进制度">
    参数 起始角 <类型 = 小数 注释 = "十进制度">
    参数 终止角 <类型 = 小数 注释 = "十进制度">
    参数 颜色 <类型 = CV标量类 注释 = "绘制形状的颜色">
    参数 线条粗细 <类型 = 整数 注释 = "形状线条的粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "形状线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::ellipse(@<源图像>.obj, @<中心坐标>.obj, @<轴长>.obj, @<旋转角度>, @<起始角>, @<终止角>, @<颜色>.obj, @<线条粗细>, @<线条类型>, @<小数位数>);
    }

    方法 画椭圆_从矩形 <公开 静态 注释 = "ellipse,根据自由矩形的形态在图中绘制一个椭圆.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 矩形 <类型 = CV自由矩形类 注释 = "带旋转角度、轴长的矩形">
    参数 颜色 <类型 = CV标量类 注释 = "绘制颜色">
    参数 线条粗细 <类型 = 整数 @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 @默认值 = CV线条常量.八倍抗锯齿>
    {
        @ cv::ellipse(@<源图像>.obj, @<矩形>.obj, @<颜色>.obj, @<线条粗细>, @<线条类型>);
    }

    方法 画标记点 <公开 静态 注释 = "drawMarker,在图上绘制mark点.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 中心点 <类型 = CV坐标点 注释 = "要绘制到的中心点">
    参数 颜色 <类型 = CV标量类 注释 = "标记点颜色">
    参数 标记类型 <类型 = CVMark标记类型 注释 = "十字、圆圈、三角等形状" @默认值 = CVMark标记类型.十字形>
    参数 标记尺寸 <类型 = 整数 注释 = "标记点的尺寸" @默认值 = 20>
    参数 线条粗细 <类型 = 整数 注释 = "标记点线条粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "标记点线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    {
        @ cv::drawMarker(@<源图像>.obj, @<中心点>.obj, @<颜色>.obj, @<标记类型>, @<标记尺寸>, @<线条粗细>, @<线条类型>);
    }

    方法 绘制填充凸多边形 <公开 静态 注释 = "fillConvexPoly,绘制填充一个多边形,并拉平其凹陷部分.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 轮廓点 <类型 = CV坐标容器数组 注释 = "包含轮廓的点集数组,包含多个轮廓.">
    参数 颜色 <类型 = CV标量类 注释 = "需要绘制的颜色">
    参数 线条类型 <类型 = CV线条常量 注释 = "多边形线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::fillConvexPoly(@<源图像>.obj ,@<轮廓点>.obj, @<颜色>.obj,  @<线条类型>, @<小数位数>);
    }

    方法 绘制填充多边形 <公开 静态 注释 = "fillPoly,绘制填充一个多边形.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 轮廓点 <类型 = CV坐标容器数组 注释 = "包含轮廓的点集数组,包含多个轮廓">
    参数 线条类型 <类型 = CV线条常量 注释 = "多边形线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::fillPoly(@<源图像>.obj, @<轮廓点>.obj, @<线条类型>, @<小数位数>);
    }

    方法 绘制多边形 <公开 静态 注释 = "polylines,将一个多边形绘制到图像(矩阵).">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 轮廓点 <类型 = CV坐标容器数组 注释 = "包含轮廓的点集数组,包含多个轮廓">
    参数 是否闭合 <类型 = 逻辑型 注释 = "为真时,将未闭合的同组轮廓闭合">
    参数 颜色 <类型 = CV标量类 注释 = "轮廓颜色">
    参数 线条粗细 <类型 = 整数 注释 = "多边形线条粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "多边形线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 小数位数 <类型 = 整数 注释 = "坐标小数位数" @默认值 = 0>
    {
        @ cv::polylines(@<源图像>.obj, @<轮廓点>.obj, @<是否闭合>,@<颜色>.obj,@<线条粗细>,@<线条类型>,@<小数位数>);
    }

    方法 绘制轮廓 <公开 静态 注释 = "drawContours,将轮廓绘制到图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "将要绘制到的源图像">
    参数 轮廓点 <类型 = CV坐标容器数组 注释 = "包含轮廓的点集数组,包含多个轮廓.">
    参数 绘制指数 <类型 = 整数 注释 = "-1表示全部绘制" @默认值 = -1>
    参数 颜色 <类型 = CV标量类 注释 = "轮廓颜色">
    参数 线条粗细 <类型 = 整数 注释 = "轮廓线条粗细" @默认值 = 1>
    参数 线条类型 <类型 = CV线条常量 注释 = "轮廓线条类型" @默认值 = CV线条常量.八倍抗锯齿>
    参数 拓扑信息 <类型 = CV矩阵类 注释 = "可以从 寻找轮廓  函数得到,为空时不指定" @默认值 = 空对象>
    参数 最大层级 <类型 = 整数 注释 = "轮廓的最大层级" @默认值 = 100000000>
    {
        @ cv::drawContours(@<源图像>.obj, @<轮廓点>.obj, @<绘制指数>,@<颜色>.obj,@<线条粗细>, @<线条类型>,@<拓扑信息>.obj, @<最大层级>);
    }

    方法 裁剪线段 <公开 静态 类型 = 逻辑型 注释 = "clipLine,截取矩形范围内的线段." 返回值注释 = "如果线段在矩形内,则返回真." @禁止流程检查 = 真>
    参数 矩形 <类型 = CV矩形类 注释 = "欲裁剪的矩形范围">
    参数 第一个点 <类型 = CV坐标点 注释 = "输入时为线段第一个点,输出时为线段第一个点.">
    参数 第二个点 <类型 = CV坐标点 注释 = "输入时为线段第二个点,输出时为线段第二个点.">
    {
        @ return cv::clipLine(@<矩形>.obj, @<第一个点>.obj, @<第二个点>.obj);
    }

    方法 生成近似椭圆轮廓点 <公开 静态 注释 = "ellipse2Poly,生成近似线段椭圆的线段轮廓点.">
    参数 中心点 <类型 = CV坐标点 注释 = "椭圆的中点">
    参数 椭圆轴长 <类型 = CV尺寸类 注释 = "包含椭圆两个轴的长度的尺寸">
    参数 倾斜角度 <类型 = 整数 注释 = "十进制度">
    参数 起始角 <类型 = 整数 注释 = "十进制度">
    参数 终止角 <类型 = 整数 注释 = "十进制度">
    参数 顶点角度 <类型 = 整数 注释 = "十进制度">
    参数 输出轮廓点 <类型 = CV坐标容器 注释 = "计算得到的椭圆轮廓坐标点">
    {
        @ cv::ellipse2Poly(@<中心点>.obj, @<椭圆轴长>.obj, @<倾斜角度>, @<起始角>, @<终止角>, @<顶点角度>, @<输出轮廓点>.obj);
    }

    方法 提取ROI区域图像 <公开 静态 注释 = "截取指定矩形范围内的图像到新矩阵">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲抠图的源图像(矩阵)">
    参数 截取范围 <类型 = CV矩形类 注释 = "感兴趣的ROI范围">
    参数 输出图像 <类型 = CV矩阵类 注释 = "截取到的图像">
    {
        @ @<输出图像>.obj = @<源图像>.obj(@<截取范围>.obj);
    }

    方法 画到图像 <公开 静态 注释 = "copyTo,将一个图像画到另一个里面.">
    参数 源图像 <类型 = CV矩阵类 注释 = "图像将被画到该 图像 中">
    参数 画出图像 <类型 = CV矩阵类 注释 = "将要画到 源图像 中的图像">
    参数 ROI区域 <类型 = CV矩形类 注释 = "需要画到 源图像 的位置">
    {
        @ @<画出图像>.obj.copyTo(@<源图像>.obj(@<ROI区域>.obj));
    }

    方法 寻找轮廓 <公开 静态 注释 = "findContours,从二值图像中寻找轮廓.">
    参数 输入二值图像 <类型 = CV矩阵类 注释 = "8位单通道“二值”图像">
    参数 输出轮廓点 <类型 = CV坐标容器数组 注释 = "包含多个轮廓的轮廓数组">
    参数 输出拓扑信息 <类型 = CV向量容器4i 注释 = "为空时不输出拓扑层次结构" 注释 = "[0]:与当前轮廓处于同一层级的下一条轮廓" 注释 = "[1]:与当前轮廓处于同一层级的上一条轮廓"
            注释 = "[2]:当前轮廓的第一条子轮廓" 注释 = "[3]:当前轮廓的父轮廓" @默认值 = 空对象>
    参数 提取算法 <类型 = CV轮廓提取算法常量 @默认值 = CV轮廓提取算法常量.检测所有轮廓并建立完整层次关系>
    参数 逼近算法 <类型 = CV轮廓逼近算法常量 @默认值 = CV轮廓逼近算法常量.无近似逼近>
    {
        如果 (输出拓扑信息 == 空对象)
        {
            @ cv::findContours(@<输入二值图像>.obj, @<输出轮廓点>.obj, @<提取算法>, @<逼近算法>);
        }
        否则
        {
            @ cv::findContours(@<输入二值图像>.obj, @<输出轮廓点>.obj, @<输出拓扑信息>.obj, @<提取算法>, @<逼近算法>);
        }
    }

    方法 拟合多边形 <公开 静态 注释 = "approxPolyDP,近似拟合一个多边形.">
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 输出轮廓点 <类型 = CV坐标容器 注释 = "拟合完成的多边形轮廓点">
    参数 最大距离 <类型 = 小数 注释 = "原始曲线与其近似值之间的最大距离">
    参数 是否闭合 <类型 = 逻辑型 注释 = "如果为真,则闭合轮廓计算,否则不闭合计算.">
    {
        @ cv::approxPolyDP(@<输入轮廓点>.obj, @<输出轮廓点>.obj, @<最大距离>, @<是否闭合>);
    }

    方法 计算轮廓长度 <公开 静态 类型 = 小数 注释 = "arcLength,计算一个轮廓的长度." @禁止流程检查 = 真>
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 是否闭合 <类型 = 逻辑型 注释 = "如果为真,则闭合轮廓计算,否则不闭合计算.">
    {
        @ return cv::arcLength(@<输入轮廓点>.obj, @<是否闭合>);
    }

    方法 计算轮廓最小外接正交矩形 <公开 静态 类型 = CV矩形类 注释 = "boundingRect" 返回值注释 = "返回最小外接正交矩形">
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    {
        变量 返回矩形 <类型 = CV矩形类>
        @ @<返回矩形>.obj = cv::boundingRect(@<输入轮廓点>.obj);
        返回 (返回矩形)
    }

    方法 计算轮廓面积 <公开 静态 类型 = 小数 注释 = "contourArea,计算轮廓的面积." 返回值注释 = "返回轮廓面积" @禁止流程检查 = 真>
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    {
        @ return cv::contourArea(@<输入轮廓点>.obj);
    }

    方法 计算轮廓最小外接自由矩形 <公开 静态 类型 = CV自由矩形类 注释 = "minAreaRect" 返回值注释 = "返回最小外接自由矩形">
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    {
        变量 返回矩形 <类型 = CV自由矩形类>
        @ @<返回矩形>.obj = cv::minAreaRect(@<输入轮廓点>.obj);
        返回 (返回矩形)
    }

    方法 取自由矩形坐标点 <公开 静态 注释 = "boxPoints,取出旋转的自由矩形的四个顶点坐标,输出的点可以直接用函数 绘制轮廓 绘制出来.">
    参数 输入矩形 <类型 = CV自由矩形类 注释 = "欲获取其坐标点的自由矩形">
    参数 输出点容器 <类型 = CV坐标容器 注释 = "获取的自由矩形坐标点">
    {
        @ cv::boxPoints(@<输入矩形>.obj, @<输出点容器>.obj);
    }

    方法 计算轮廓最小外接圆 <公开 静态 注释 = "minEnclosingCircle,计算一组轮廓的最小外接圆,并输出圆的几何特征.">
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 输出中心坐标 <类型 = CV坐标点2f 注释 = "输出最小外接圆的中心坐标点">
    参数 输出半径 <类型 = 小数类 注释 = "输出最小外接圆的半径,其原型是单精度小数.">
    {
        @ float r=0;
        @ cv::minEnclosingCircle(@<输入轮廓点>.obj, @<输出中心坐标>.obj, r);
        @ @<输出半径.值> = r;
    }

    方法 计算轮廓最小外接三角形 <公开 静态 类型 = 小数 注释 = "minEnclosingTriangle,近似拟合一个多边形." 返回值注释 = "返回三角形面积" @禁止流程检查 = 真>
    参数 输入轮廓点 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 输出轮廓点 <类型 = CV坐标容器 注释 = "三角形轮廓">
    {
        @ return cv::minEnclosingTriangle(@<输入轮廓点>.obj, @<输出轮廓点>.obj);
    }

    方法 计算两轮廓相似度 <公开 静态 类型 = 小数 注释 = "matchShapes,用形状模板匹配的方法比对两个轮廓的相似度." 返回值注释 = "返回方差,方差越小,轮廓越相似." @禁止流程检查 = 真>
    参数 输入轮廓1 <类型 = CV坐标容器 注释 = "欲比较的轮廓点1">
    参数 输入轮廓2 <类型 = CV坐标容器 注释 = "欲比较的轮廓点2">
    参数 匹配方法 <类型 = CV形状匹配方法常量 注释 = "轮廓匹配的方法" @默认值 = CV形状匹配方法常量.算法1>
    参数 特定参数 <类型 = 小数 注释 = "暂时还未支持该参数" @默认值 = 0>
    {
        @ return cv::matchShapes(@<输入轮廓1>.obj, @<输入轮廓2>.obj, @<匹配方法>, @<特定参数>);
    }

    方法 计算轮廓凸包_点集 <公开 静态 注释 = "convexHull,计算一个点集的凸包.">
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 输出轮廓 <类型 = CV坐标容器 注释 = "按指定顺序方向输出轮廓点集">
    参数 是否顺时针 <类型 = 逻辑型 注释 = "为真时顺时针排序" @默认值 = 真>
    {
        @ cv::convexHull(@<输入轮廓>.obj, @<输出轮廓>.obj, @<是否顺时针>);
    }

    方法 计算轮廓凸包_顺序 <公开 静态 注释 = "convexHull,计算一个点集的凸包的顺序.">
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲计算的轮廓点">
    参数 输出索引 <类型 = CV整数容器 注释 = "按指定顺序方向输出轮廓的索引">
    参数 是否顺时针 <类型 = 逻辑型 注释 = "为真时顺时针排序" @默认值 = 真>
    {
        @ cv::convexHull(@<输入轮廓>.obj, @<输出索引>.obj, @<是否顺时针>);
    }

    方法 计算轮廓凸包_矩阵 <公开 静态 注释 = "convexHull,计算一个点集的凸包.">
    参数 输入轮廓 <类型 = CV矩阵类 注释 = "欲计算的轮廓点,以矩阵存储.">
    参数 输出轮廓 <类型 = CV矩阵类 注释 = "输入轮廓  所有凹陷的区域都被拉平">
    参数 是否顺时针 <类型 = 逻辑型 注释 = "为真时顺时针排列轮廓" @默认值 = 真>
    参数 是否输出索引 <类型 = 逻辑型 注释 = "如果为真,则在输出轮廓中返回点的索引." @默认值 = 真>
    {
        @ cv::convexHull(@<输入轮廓>.obj, @<输出轮廓>.obj, @<是否顺时针>, @<是否输出索引>);
    }

    方法 是否为凸包 <公开 静态 类型 = 逻辑型 注释 = "isContourConvex,计算点集是否为凸包." 返回值注释 = "返回是否为凸包" @禁止流程检查 = 真>
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲判断的轮廓点">
    {
        @ return cv::isContourConvex(@<输入轮廓>.obj);
    }

    方法 计算两轮廓交集 <公开 静态 类型 = 小数 注释 = "intersectConvexConvex,求两轮廓交集." 返回值注释 = "返回相交轮廓的面积" @禁止流程检查 = 真>
    参数 输入轮廓1 <类型 = CV坐标容器>
    参数 输入轮廓2 <类型 = CV坐标容器>
    参数 输出交集 <类型 = CV坐标容器 注释 = "如果存在交集,则输出轮廓的点集.">
    参数 是否嵌套 <类型 = 逻辑型
            注释 = "当为真时,如果一个多边形完全包含在另一个多边形中,则找到一个交点.  如果为 false,则找不到交集.  如果多边形共享一条边或一个多边形的顶点位于另一个多边形的边上,则它们不被视为嵌套,无论handleNested 的值如何,都将找到交点."
            @默认值 = 真>
    {
        @ return cv::intersectConvexConvex(@<输入轮廓1>.obj, @<输入轮廓2>.obj, @<输出交集>.obj, @<是否嵌套>);
    }

    方法 拟合椭圆 <公开 静态 类型 = CV自由矩形类 注释 = "fitEllipse,将轮廓拟合为椭圆." 返回值注释 = "返回一个自由矩形,注意,并不是椭圆.">
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲拟合的轮廓点">
    {
        变量 返回矩形 <类型 = CV自由矩形类>
        @ @<返回矩形>.obj = cv::fitEllipse(@<输入轮廓>.obj);
        返回 (返回矩形)
    }

    方法 拟合椭圆_AMS <公开 静态 类型 = CV自由矩形类 注释 = "fitEllipseAMS,将轮廓拟合为椭圆,使用AMS近似算法." 返回值注释 = "返回一个自由矩形,注意,并不是椭圆.">
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲拟合的轮廓点">
    {
        变量 返回矩形 <类型 = CV自由矩形类>
        @ @<返回矩形>.obj = cv::fitEllipseAMS(@<输入轮廓>.obj);
        返回 (返回矩形)
    }

    方法 拟合直线2D <公开 静态 注释 = "fitLine,将点轮廓拟合为一条直线.">
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "欲拟合的轮廓点">
    参数 输出直线向量 <类型 = CV向量容器4f 注释 = "直线方程 y = kx+b" 注释 = "输出直线向量[0]:y方向截距" 注释 = "输出直线向量[1]:x方向截距" 注释 = "输出直线向量[2]:x0"
            注释 = "输出直线向量[3]:y0" 注释 = "斜率 k = x方向截距 / y方向截距,偏导 b = y0-k*x0" 注释 = "如已知 x = 100则" 注释 = "y = k*100 + b">
    参数 距离类型 <类型 = CV距离变换常量 注释 = "M估计器使用的距离">
    参数 距离参数 <类型 = 小数 注释 = "某些距离的数值参数(C). 如果是0,则选择最优值.">
    参数 径向精度 <类型 = 小数 注释 = "对半径(坐标原点到直线之间的距离)有足够的精度">
    参数 角度精度 <类型 = 小数 注释 = "弧度,角度有足够的精度. 0.01将是一个良好的默认值.">
    {
        @ cv::fitLine(@<输入轮廓>.obj, @<输出直线向量>.obj, @<距离类型>, @<距离参数>, @<径向精度>, @<角度精度>);
    }

    方法 拟合直线3D <公开 静态 注释 = "fitLine,将点轮廓拟合为一条直线.">
    参数 输入轮廓 <类型 = CV矩阵类 注释 = "欲拟合的轮廓点,以矩阵存储.">
    参数 输出直线向量 <类型 = CV向量容器6f 注释 = "输出直线向量[0]:y方向距离" 注释 = "输出直线向量[1]:x方向距离" 注释 = "输出直线向量[2]:z方向距离" 注释 = "输出直线向量[3]:x坐标"
            注释 = "输出直线向量[4]:y坐标" 注释 = "输出直线向量[5]:z坐标">
    参数 距离类型 <类型 = CV距离变换常量 注释 = "需要使用的距离变换类型">
    参数 距离参数 <类型 = 小数 注释 = "某些距离的数值参数(C). 如果是0,则选择最优值.">
    参数 径向精度 <类型 = 小数 注释 = "对半径(坐标原点到直线之间的距离)有足够的精度">
    参数 角度精度 <类型 = 小数 注释 = "弧度,角度有足够的精度. 0.01将是一个良好的默认值.">
    {
        @ cv::fitLine(@<输入轮廓>.obj, @<输出直线向量>.obj, @<距离类型>, @<距离参数>, @<径向精度>, @<角度精度>);
    }

    方法 计算点是否在轮廓内 <公开 静态 类型 = 小数 注释 = "pointPolygonTest,计算点是否位于轮廓内部."
            返回值注释 = "当  是否测量距离  参数为真时,若返回值为正,表示点在多边形内部,返回值为负,表示在多边形外部,返回值为0,表示在多边形上."
            返回值注释 = "当  是否测量距离  参数为真时,若返回值为1,表示点在多边形内部,返回值为-1,表示在多边形外部,返回值为0,表示在多边形上." @禁止流程检查 = 真>
    参数 输入轮廓 <类型 = CV坐标容器 注释 = "需要计算的范围轮廓">
    参数 输入点坐标 <类型 = CV坐标点2f 注释 = "欲判断的坐标点">
    参数 是否测量距离 <类型 = 逻辑型 注释 = "当  是否测量距离  参数为真时,若返回值为正,表示点在多边形内部,返回值为负,表示在多边形外部,返回值为0,表示在多边形上."
            注释 = "当  是否测量距离  参数为真时,若返回值为1,表示点在多边形内部,返回值为-1,表示在多边形外部,返回值为0,表示在多边形上." @默认值 = 真>
    {
        @ return cv::pointPolygonTest(@<输入轮廓>.obj, @<输入点坐标>.obj, @<是否测量距离>);
    }

    方法 计算两自由矩形交集 <公开 静态 类型 = 整数 注释 = "rotatedRectangleIntersection,求两个自由矩形的交集." 返回值注释 = "返回0代表无交集,返回1代表有部分交集,返回2代表其中一个完全被包含."
            @禁止流程检查 = 真>
    参数 矩形1 <类型 = CV自由矩形类>
    参数 矩形2 <类型 = CV自由矩形类>
    参数 交集轮廓点 <类型 = CV坐标2f容器 注释 = "输出两个自由矩形的交集">
    {
        @ return cv::rotatedRectangleIntersection(@<矩形1>.obj, @<矩形2>.obj, @<交集轮廓点>.obj);
    }

    方法 使用色彩映射_指定色彩样式 <公开 静态 注释 = "applyColorMap, 在给定的图像上应用GNU Octave/MATLAB等效的颜色映射,相当于伪彩色.">
    参数 源图像 <类型 = CV矩阵类 注释 = "灰度或彩色类型无符号8位整数1通道或无符号8位整数3通道">
    参数 输出图像 <类型 = CV矩阵类 注释 = "映射完成的图像">
    参数 映射颜色 <类型 = CV颜色映射型常量 注释 = "需要映射的颜色类型" "">
    {
        @ cv::applyColorMap(@<源图像>.obj, @<输出图像>.obj, @<映射颜色>);
    }

    方法 使用色彩映射_指定色彩矩阵 <公开 静态 注释 = "applyColorMap, 在给定的图像上应用GNU Octave/MATLAB等效的颜色映射,相当于伪彩色.">
    参数 源图像 <类型 = CV矩阵类 注释 = "灰度或彩色类型无符号8位整数1通道或无符号8位整数3通道">
    参数 输出图像 <类型 = CV矩阵类 注释 = "映射完成的图像">
    参数 映射颜色 <类型 = CV矩阵类 注释 = "无符号8位整数1通道或无符号8位整数3通道,大小为256矩阵" "">
    {
        @ cv::applyColorMap(@<源图像>.obj, @<输出图像>.obj, @<映射颜色>.obj);
    }

    方法 保存到文件 <公开 静态 类型 = 逻辑型 注释 = "imwrite,保存矩阵到文件." 返回值注释 = "保存成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲保存的矩阵(图像)">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存图像的文件路径">
    {
        @ @an<CVolMem> memBuf1;
        @ return cv::imwrite(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL),@<源图像>.obj);
    }

    方法 图像解码从字节集 <公开 静态 类型 = CV矩阵类 注释 = "imdecode,从内存中指定的缓冲区读取图像. 如果缓冲区太短或包含无效数据,"
            注释 = "函数将返回一个空矩阵,如果是从函数 读入文件 得到的字节集,转换速度慢,如果是位图的字节集转换速度快." 返回值注释 = "返回转换结果">
    参数 字节图像 <类型 = 字节集类 注释 = "欲转换到CV矩阵的字节集图像">
    参数 读入方式 <类型 = CV图像解码常量 注释 = "指定转换后的颜色空间" @默认值 = CV图像解码常量.转彩色>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ _InputArray pic_arr((uchar*)(INT_P)@<字节图像>.GetPtr (), (int)@<字节图像>.GetSize());
        @ @<返回矩阵>.obj = cv::imdecode(pic_arr, @<读入方式>);
        返回 (返回矩阵)
    }

    方法 矩阵到字节集 <公开 静态 类型 = 逻辑型 注释 = "将矩阵的数据指针转换到字节集" 返回值注释 = "如果转换成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 文件格式 <类型 = 文本型 注释 = ".png  .jpg ,必须加 \".\" 符号.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "将要转换的矩阵">
    参数 数据字节集 <类型 = 字节集类 注释 = "输出字节集图像">
    {
        @ std::vector<uchar> buff;
        @ @an<CVolMem> memBuf1;
        @ if(cv::imencode(GetMbsText (@<文件格式>.GetText (), memBuf1, NULL), @<源矩阵>.obj, buff)==true){
        @     @<数据字节集>.CopyFrom (buff.data(), (INT)buff.size());buff.clear(); return true;}
        @ return false;
    }

    方法 画矩形 <公开 静态 注释 = "rectangle,使用整数坐标绘制矩形.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制矩形框的图像">
    参数 矩形 <类型 = CV矩形类 注释 = "欲绘制到图像的矩形框">
    参数 颜色 <类型 = CV标量类 注释 = "欲绘制矩形框的颜色">
    参数 线条粗细 <类型 = 整数 注释 = "绘制矩形框的线条粗细" @默认值 = 2>
    参数 线条类型 <类型 = CV线条常量 注释 = "如果为 FILLED 则填充整个矩形" @默认值 = CV线条常量.八倍抗锯齿>
    {
        @ cv::rectangle(@<源图像>.obj, @<矩形>.obj, @<颜色>.obj, @<线条粗细>, @<线条类型>);
    }

    方法 画矩形小数 <公开 静态 注释 = "rectangle,使用小数坐标绘制矩形.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制矩形框的图像">
    参数 矩形 <类型 = CV矩形类小数 注释 = "欲绘制到图像的矩形框">
    参数 颜色 <类型 = CV标量类 注释 = "欲绘制矩形框的颜色">
    参数 线条粗细 <类型 = 整数 注释 = "绘制矩形框的线条粗细" @默认值 = 2>
    参数 线条类型 <类型 = CV线条常量 注释 = "如果为 FILLED 则填充整个矩形" @默认值 = CV线条常量.八倍抗锯齿>
    {
        @ cv::rectangle(@<源图像>.obj, @<矩形>.obj, @<颜色>.obj, @<线条粗细>, @<线条类型>);
    }

    方法 分离通道 <公开 静态 注释 = "split,将多通道的矩阵分离到CV矩阵类容器.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲分离通道的图像">
    参数 输出矩阵容器 <类型 = CV矩阵类容器 注释 = "容器内的图像具有相同的数值类型,且宽高都相同.">
    {
        @ cv::split(@<源图像>.obj,@<输出矩阵容器>.obj);
    }

    方法 分离通道到矩阵数组 <公开 静态 注释 = "split,将多通道的矩阵分离到矩阵数组.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲分离通道的图像">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "容器内的图像具有相同的数值类型,且宽高都相同.">
    {
        @ cv::split(@<源图像>.obj, (cv::Mat *)&@<输出矩阵>.obj);
    }

    方法 合并通道 <公开 静态 注释 = "merge,合并多个通道图矩阵到一个多通道矩阵.">
    参数 输入矩阵容器 <类型 = CV矩阵类容器 注释 = "容器内的图像必须具有相同的数值类型,且宽高都相同.">
    参数 合并图像 <类型 = CV矩阵类 注释 = "合并后的图像">
    {
        @ cv::merge(@<输入矩阵容器>.obj, @<合并图像>.obj);
    }

    方法 颜色空间转换 <公开 静态 注释 = "cvtColor,针对图像不同颜色模型的相互转换.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲转换颜色空间的图像">
    参数 处理后的图片 <类型 = CV矩阵类 注释 = "转换颜色空间后的图像">
    参数 转换方式 <类型 = CV图像颜色空间转换常量 注释 = "颜色空间转换方式" @默认值 = CV图像颜色空间转换常量.BGR转灰度>
    参数 通道数 <类型 = 整数 注释 = "为0时自动指定,一般为0." @默认值 = 0>
    {
        @ cv::cvtColor(@<源图像>.obj,@<处理后的图片>.obj, @<转换方式>,@<通道数>);
    }

    方法 矩阵相加 <公开 静态 注释 = "add,矩阵的加法.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "被加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "矩阵的和">
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::add(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, cv::Mat());
        }
        否则
        {
            @ cv::add(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<计算掩膜>.obj);
        }
    }

    方法 矩阵缩放相加 <公开 静态 注释 = "scaleAdd,对矩阵1每个元素做缩放处理的相加.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "被加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵1乘数 <类型 = 小数 注释 = "矩阵1=矩阵1 * 矩阵1乘数">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "与输入数组具有相同的通道大小和数量的输出数组">
    {
        @ cv::scaleAdd(@<矩阵1>.obj, @<矩阵1乘数>, @<矩阵2>.obj, @<输出结果>.obj);
    }

    方法 矩阵相加_权重 <公开 静态 注释 = "addWeighted,带权重的矩阵相加,可以做图像亮度调整、混合图像.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "被加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵1乘数 <类型 = 小数 注释 = "矩阵1=矩阵1 * 矩阵1乘数">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "加数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵2乘数 <类型 = 小数 注释 = "矩阵2=矩阵2 * 矩阵2乘数">
    参数 伽马值 <类型 = 小数 注释 = "每个和相加的标量">
    参数 输出结果 <类型 = CV矩阵类 注释 = "与输入数组具有相同的通道大小和数量的输出数组">
    参数 期望位深度 <类型 = CV数值类型 注释 = "默认不改变位深度" @默认值 = CV数值类型.不指定>
    {
        @ cv::addWeighted(@<矩阵1>.obj, @<矩阵1乘数>, @<矩阵2>.obj, @<矩阵2乘数>, @<伽马值>, @<输出结果>.obj, @<期望位深度>);
    }

    方法 矩阵相减 <公开 静态 注释 = "subtract,两个矩阵的减法运算.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "被减数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "减数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "矩阵的差">
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::subtract(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, cv::Mat(), -1);
        }
        否则
        {
            @ cv::subtract(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<计算掩膜>.obj, -1);
        }
    }

    方法 矩阵相减绝对值 <公开 静态 注释 = "absdiff,相减后的差值如果是负数,则取其绝对值.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类 注释 = "矩阵的差值">
    {
        @ cv::absdiff(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj);
    }

    方法 矩阵绝对值 <公开 静态 类型 = CV矩阵类 注释 = "abs,求矩阵的绝对值.">
    参数 矩阵 <类型 = CV矩阵类 注释 = "待计算的矩阵">
    {
        变量 输出结果 <类型 = CV矩阵类>
        @  @<输出结果>.obj = cv::abs(@<矩阵>.obj);
        返回 (输出结果)
    }

    方法 矩阵相乘 <公开 静态 注释 = "multiply,矩阵与矩阵乘法.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "被乘数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "乘数,矩阵1与矩阵2具有相同的通道、类型、尺寸.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "乘积">
    参数 缩放比例 <类型 = 小数 注释 = "对乘积作缩放处理,即 输出结果 = 输出结果*缩放比例." @默认值 = 1>
    参数 期望位深度 <类型 = CV数值类型 注释 = "默认不改变位深度" @默认值 = CV数值类型.不指定>
    {
        @ cv::multiply(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj,@<缩放比例>,  @<期望位深度>);
    }

    方法 矩阵相除 <公开 静态 注释 = "divide,矩阵与矩阵除法.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类 注释 = "矩阵的商">
    参数 缩放比例 <类型 = 小数 注释 = "输出的结果将乘以该缩放比例以改变元素值,为1时不改变." @默认值 = 1>
    参数 期望位深度 <类型 = CV数值类型 注释 = "默认不改变位深度" @默认值 = CV数值类型.不指定>
    {
        @ cv::divide(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj,@<缩放比例>,  @<期望位深度>);
    }

    方法 矩阵比较 <公开 静态 注释 = "compare,满足条件时结果矩阵元素值为255,否为0.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类 注释 = "比较结果矩阵">
    参数 比较方式 <类型 = CV比较类型常量>
    {
        @ cv::compare(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<比较方式>);
    }

    方法 矩阵逻辑或运算 <公开 静态 注释 = "例如矩阵1某个元素是128,矩阵2对应位置的元素是0,则它们进行bitwise_or的结果,对应位置是128"
            注释 = "如果矩阵2对应位置的元素是1,那么结果对应位置就是129(因为128最后一位是0,和1的最后一位(也就是1)相或后得到1,128的前边的位数都保留了,得到129).">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类 注释 = "计算结果矩阵">
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::bitwise_or(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, cv::Mat());
        }
        否则
        {
            @ cv::bitwise_or(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<计算掩膜>.obj);
        }
    }

    方法 矩阵逻辑与运算 <公开 静态 注释 = "bitwise_and,计算两个数组的按位连接(输出结果 = 矩阵1 & 矩阵2)" 注释 = "计算两个数组或数组与标量的每个元素按位连接.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类 注释 = "计算结果矩阵">
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::bitwise_and(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, cv::Mat());
        }
        否则
        {
            @ cv::bitwise_and(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<计算掩膜>.obj);
        }
    }

    方法 矩阵逻辑非运算 <公开 静态 注释 = "bitwise_not,反转数组的每一位.">
    参数 源矩阵 <类型 = CV矩阵类>
    参数 输出结果 <类型 = CV矩阵类>
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::bitwise_not(@<源矩阵>.obj,  @<输出结果>.obj, cv::Mat());
        }
        否则
        {
            @ cv::bitwise_not(@<源矩阵>.obj, @<输出结果>.obj, @<计算掩膜>.obj);
        }
    }

    方法 矩阵逻辑异或运算 <公开 静态 注释 = "bitwise_xor,异或运算就是相同为1,不同为0,也就是 0 ^ 0 = 1 , 1 ^ 1 = 1 , 另外2个为0.">
    参数 矩阵1 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 矩阵2 <类型 = CV矩阵类 注释 = "矩阵1与矩阵2具有相同的通道、类型、尺寸">
    参数 输出结果 <类型 = CV矩阵类>
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "为空时计算所有元素,否则只计算掩膜区域内的元素." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::bitwise_xor(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, NULL);
        }
        否则
        {
            @ cv::bitwise_xor(@<矩阵1>.obj, @<矩阵2>.obj, @<输出结果>.obj, @<计算掩膜>.obj);
        }
    }

    方法 泊松克隆 <公开 静态 注释 = "seamlessClone,两个图像结合的边缘将被过渡处理,使其看起来更像一副正常的图像.">
    参数 输入前景图像 <类型 = CV矩阵类 注释 = "必须为3通道8位图像">
    参数 输入背景图像 <类型 = CV矩阵类 注释 = "必须为3通道8位图像">
    参数 输入融合掩膜 <类型 = CV矩阵类 注释 = "输入8位1或3通道图像(前景图像将要融合到的区域),注意是前景图像的掩膜">
    参数 中心点 <类型 = CV坐标点 注释 = "前景图像的中心在背景图像上的坐标！注意是前景图像的中心！">
    参数 输出融合图像 <类型 = CV矩阵类 注释 = "融合后的图像">
    参数 融合算法 <类型 = CV泊松克隆算法常量 注释 = "使用的融合算法" @默认值 = CV泊松克隆算法常量.混合克隆>
    {
        @ cv::seamlessClone(@<输入前景图像>.obj, @<输入背景图像>.obj , @<输入融合掩膜>.obj, @<中心点>.obj, @<输出融合图像>.obj, @<融合算法>);
    }

    方法 调整图像区域颜色 <公开 静态 注释 = "colorChange,对感兴趣区域颜色进行调整.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输入掩膜区域 <类型 = CV矩阵类 注释 = "感兴趣区域,单通道或者3通道二值图,与原图像必须有相同的宽高.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "调整亮度后的矩阵(图像)">
    参数 R通道调整系数 <类型 = 小数 注释 = "0.5-2.5">
    参数 B通道调整系数 <类型 = 小数 注释 = "0.5-2.5">
    参数 G通道调整系数 <类型 = 小数 注释 = "0.5-2.5">
    {
        @ cv::colorChange(@<输入图像>.obj , @<输入掩膜区域>.obj , @<输出结果>.obj , (float)@<R通道调整系数> , (float)@<B通道调整系数> , (float)@<G通道调整系数>);
    }

    方法 调整图像区域亮度 <公开 静态 注释 = "illuminationChange,对选区内部的梯度场应用适当的非线性变换,然后用泊松求解器积分,局部修改图像的表观照明.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输入掩膜区域 <类型 = CV矩阵类 注释 = "感兴趣区域,单通道或者3通道二值图,与原图像必须有相同的宽高.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "调整亮度后的矩阵(图像)">
    参数 alpha <类型 = 小数 注释 = "0-2">
    参数 beta <类型 = 小数 注释 = "0-2">
    {
        @ cv::illuminationChange(@<输入图像>.obj , @<输入掩膜区域>.obj , @<输出结果>.obj ,(float)@<alpha> , (float)@<beta>);
    }

    方法 调整图像区域纹理 <公开 静态 注释 = "textureFlattening,纹理扁平化,边缘检测器选取的边缘越少(选择性越强),边缘映射就越稀疏,扁平化效果就越明显.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输入掩膜区域 <类型 = CV矩阵类 注释 = "感兴趣区域,单通道或者3通道二值图,与原图像必须有相同的宽高.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理后的图像">
    参数 低阈值 <类型 = 小数 注释 = "0-100" @默认值 = 30>
    参数 高阈值 <类型 = 小数 注释 = "必须大于低阈值" @默认值 = 45>
    参数 核心尺寸 <类型 = 整数 注释 = "处理纹理时的核心尺寸,必须为大于0的奇数." @默认值 = 3>
    {
        @ cv::textureFlattening(@<输入图像>.obj , @<输入掩膜区域>.obj , @<输出结果>.obj ,(float)@<低阈值> , (float)@<高阈值> , @<核心尺寸>);
    }

    方法 滤波_边缘保护 <公开 静态 注释 = "edgePreservingFilter,保边滤波器(Edge Preserving Filter)是指在滤波过程中能够有效的保留图像中的边缘信息的一类特殊滤波器."
            注释 = "其中双边滤波器(Bilateral filter)、引导滤波器(Guided image filter)、加权最小二乘法滤波器(Weighted least square filter)为几种比较广为人知的保边滤波器.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 过滤方法 <类型 = CV边缘保护滤波算法常量 注释 = "边缘过滤时保护方法" @默认值 = CV边缘保护滤波算法常量.递归过滤>
    参数 sigma_s <类型 = 小数 注释 = "0-200,当sigma_r 取值不变时候,窗口 sigma_s 越大图像模糊效果越明显." @默认值 = 60>
    参数 sigma_r <类型 = 小数 注释 = "0-1, 当 sigma_s 取值不变时候,sigma_r 越大图像滤波效果越明显." @默认值 = 0.4>
    {
        @ cv::edgePreservingFilter(@<输入图像>.obj ,  @<输出结果>.obj ,@<过滤方法> , (float)@<sigma_s> , (float)@<sigma_r>);
    }

    方法 滤波_边缘增强 <公开 静态 注释 = "detailEnhance,过滤器可以增强细节,使图像更清晰.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 sigma_s <类型 = 小数 注释 = "0-200,当sigma_r 取值不变时候,窗口 sigma_s 越大图像模糊效果越明显." @默认值 = 10>
    参数 sigma_r <类型 = 小数 注释 = "0-1, 当 sigma_s 取值不变时候,sigma_r 越大图像滤波效果越明显." @默认值 = 0.15>
    {
        @ cv::detailEnhance(@<输入图像>.obj ,  @<输出结果>.obj , (float)@<sigma_s> , (float)@<sigma_r>);
    }

    方法 滤波_铅笔素描 <公开 静态 注释 = "pencilSketch,此滤波器生成的输出看起来像铅笔草图." 注释 = "有两个输出,一个是将滤波应用于颜色输入图像的结果,另一个是将其应用于输入图像的灰度版本的结果.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输出灰度结果 <类型 = CV矩阵类 注释 = "单通道8位图像">
    参数 输出彩色结果 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 sigma_s <类型 = 小数 注释 = "0-200,当sigma_r 取值不变时候,窗口 sigma_s 越大图像模糊效果越明显." @默认值 = 60>
    参数 sigma_r <类型 = 小数 注释 = "0-1, 当 sigma_s 取值不变时候,sigma_r 越大图像滤波效果越明显." @默认值 = 0.07>
    参数 阴影因子 <类型 = 小数 注释 = "该参数决定了阴影所占比重" @默认值 = 0.02>
    {
        @ cv::pencilSketch(@<输入图像>.obj ,  @<输出灰度结果>.obj , @<输出彩色结果>.obj , (float)@<sigma_s> , (float)@<sigma_r>, (float)@<阴影因子>);
    }

    方法 滤波_风格化 <公开 静态 注释 = "stylization,风格化滤波器产生的输出图像看起来像使用水彩绘制的图像.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "3通道8位图像">
    参数 sigma_s <类型 = 小数 注释 = "0-200,当sigma_r 取值不变时候,窗口 sigma_s 越大图像模糊效果越明显." @默认值 = 10>
    参数 sigma_r <类型 = 小数 注释 = "0-1, 当 sigma_s 取值不变时候,sigma_r 越大图像滤波效果越明显." @默认值 = 0.15>
    {
        @ cv::stylization(@<输入图像>.obj ,  @<输出结果>.obj , (float)@<sigma_s> , (float)@<sigma_r>);
    }

    方法 去噪_快速非均衡局部灰度图 <公开 静态 注释 = "fastNlMeansDenoising,对图像作非均衡去噪.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "1通道8位图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "去噪后的图像">
    参数 去噪强度 <类型 = 小数 注释 = "亮度元件滤波强度调节参数. 较大的  去噪强度   值可以很好地去除噪声但也可以去除图像细节," 注释 = "较小的  去噪强度  值可以保留细节但也可以保留一些噪声." @默认值 = 3>
    参数 权重模板尺寸 <类型 = 整数 注释 = "用于计算权重的模板窗口的大小(以像素为单位)" @默认值 = 7>
    参数 加权窗格尺寸 <类型 = 整数 注释 = "用于计算加权平均值的窗口大小(以像素为单位)给定像素" @默认值 = 21>
    {
        @ cv::fastNlMeansDenoising(@<输入图像>.obj ,  @<输出结果>.obj , (float)@<去噪强度> , @<权重模板尺寸>, @<加权窗格尺寸>);
    }

    方法 去噪_快速非均衡局部彩色图 <公开 静态 注释 = "fastNlMeansDenoisingColored,对图像作非均衡去噪.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "输入8位3通道图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "去噪后的图像">
    参数 去噪强度 <类型 = 小数 注释 = "亮度元件滤波强度调节参数. 较大的  去噪强度   值可以很好地去除噪声但也可以去除图像细节," 注释 = "较小的  去噪强度  值可以保留细节但也可以保留一些噪声." @默认值 = 3>
    参数 颜色去噪强度 <类型 = 小数 注释 = "与    去噪强度  相同,但是对于颜色组件." @默认值 = 3>
    参数 权重模板尺寸 <类型 = 整数 注释 = "用于计算权重的模板窗口的大小(以像素为单位)" @默认值 = 7>
    参数 加权窗格尺寸 <类型 = 整数 注释 = "用于计算加权平均值的窗口大小(以像素为单位)给定像素" @默认值 = 21>
    {
        @ cv::fastNlMeansDenoisingColored(@<输入图像>.obj ,  @<输出结果>.obj , (float)@<去噪强度> , (float)@<颜色去噪强度> , @<权重模板尺寸>, @<加权窗格尺寸>);
    }

    方法 去噪_快速非均衡局部灰度_多图 <公开 静态 注释 = "fastNlMeansDenoisingMulti,综合多个图的特征对输入的一个图像做非均衡局部去噪处理.">
    参数 输入图像组 <类型 = CV矩阵类容器 注释 = "多个图像必须是具有相同的尺寸和类型">
    参数 输出结果 <类型 = CV矩阵类 注释 = "去噪后的图像">
    参数 目标图像索引 <类型 = 整数 注释 = "要处理的图像索引">
    参数 作为参考的图像个数 <类型 = 整数 注释 = "参考去噪的图像个数">
    参数 去噪强度 <类型 = 小数 注释 = "亮度元件滤波强度调节参数. 较大的  去噪强度   值可以很好地去除噪声但也可以去除图像细节," 注释 = "较小的  去噪强度  值可以保留细节但也可以保留一些噪声." @默认值 = 3>
    参数 权重模板尺寸 <类型 = 整数 注释 = "用于计算权重的模板窗口的大小(以像素为单位)" @默认值 = 7>
    参数 加权窗格尺寸 <类型 = 整数 注释 = "用于计算加权平均值的窗口大小(以像素为单位)给定像素" @默认值 = 21>
    {
        @ cv::fastNlMeansDenoisingMulti(@<输入图像组>.obj, @<输出结果>.obj, @<目标图像索引>, @<作为参考的图像个数>, (float)@<去噪强度>, @<权重模板尺寸>, @<加权窗格尺寸>);
    }

    方法 去噪_快速非均衡局部彩色_多图 <公开 静态 注释 = "fastNlMeansDenoisingColoredMulti,综合多个图的特征对输入的一个图像做非均衡局部去噪处理.">
    参数 输入图像组 <类型 = CV矩阵类容器 注释 = "多个图像必须是具有相同的尺寸和类型">
    参数 输出结果 <类型 = CV矩阵类 注释 = "去噪后的图像">
    参数 目标图像索引 <类型 = 整数 注释 = "要处理的图像索引">
    参数 作为参考的图像个数 <类型 = 整数 注释 = "参考去噪的图像个数">
    参数 去噪强度 <类型 = 小数 注释 = "亮度元件滤波强度调节参数. 较大的  去噪强度   值可以很好地去除噪声但也可以去除图像细节," 注释 = "较小的  去噪强度  值可以保留细节但也可以保留一些噪声." @默认值 = 3>
    参数 颜色去噪强度 <类型 = 小数 注释 = "与    去噪强度  相同,但是对于颜色组件." @默认值 = 3>
    参数 权重模板尺寸 <类型 = 整数 注释 = "用于计算权重的模板窗口的大小(以像素为单位)" @默认值 = 7>
    参数 加权窗格尺寸 <类型 = 整数 注释 = "用于计算加权平均值的窗口大小(以像素为单位)给定像素" @默认值 = 21>
    {
        @ cv::fastNlMeansDenoisingColoredMulti(@<输入图像组>.obj, @<输出结果>.obj, @<目标图像索引>, @<作为参考的图像个数>, (float)@<去噪强度>, (float)@<颜色去噪强度>, @<权重模板尺寸>, @<加权窗格尺寸>);
    }

    方法 获取高斯滤波核 <公开 静态 类型 = CV矩阵类 注释 = "getGaussianKernel,创建一个高斯滤波核.">
    参数 核心尺寸 <类型 = 整数 注释 = "指定导数核的尺寸,必须为大于0的奇数.">
    参数 平滑系数 <类型 = 小数>
    参数 数值类型 <类型 = CV数值类型 注释 = "只支持 CV_32位浮点型 和 CV_64位浮点型" @默认值 = CV数值类型.CV_64位浮点型>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::getGaussianKernel(@<核心尺寸>, @<平滑系数>, @<数值类型>);
        返回 (返回矩阵)
    }

    方法 获取导数核 <公开 静态 注释 = "getDerivKernels,也就是创建一个导数核.">
    参数 输出x方向滤波矩阵 <类型 = CV矩阵类>
    参数 输出y方向滤波矩阵 <类型 = CV矩阵类>
    参数 x方向导数 <类型 = 整数>
    参数 y方向导数 <类型 = 整数>
    参数 核心尺寸 <类型 = 整数 注释 = "指定导数核的尺寸,必须为大于0的奇数.">
    参数 是否归一化 <类型 = 逻辑型 注释 = "为真时作归一化处理">
    参数 数值类型 <类型 = CV数值类型 注释 = "只支持 CV_32位浮点型 和 CV_64位浮点型" @默认值 = CV数值类型.CV_32位浮点型>
    {
        @ cv::getDerivKernels(@<输出x方向滤波矩阵>.obj, @<输出y方向滤波矩阵>.obj, @<x方向导数>, @<y方向导数>, @<核心尺寸>, @<是否归一化>, @<数值类型>);
    }

    方法 获取Gabor滤波核 <公开 静态 类型 = CV矩阵类 注释 = "getGaborKernel,也就是创建一个Gabor滤波核.">
    参数 滤波核尺寸 <类型 = CV尺寸类 注释 = "检测时核心的尺寸">
    参数 标准偏差 <类型 = 小数 注释 = "sigma 高斯包络的标准偏差.">
    参数 法线方向 <类型 = 小数 注释 = "theta, Gabor 函数的平行条纹的法线方向.">
    参数 波长 <类型 = 小数 注释 = "lambd,正弦因子的波长.">
    参数 空间纵横比 <类型 = 小数 注释 = "gamma">
    参数 相位偏移 <类型 = 小数 注释 = "psi" @默认值 = 1.5707963>
    参数 数值类型 <类型 = CV数值类型 注释 = "可以是 32位浮点型 或 64位浮点型" @默认值 = CV数值类型.CV_64位浮点型>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::getGaborKernel(@<滤波核尺寸>.obj, @<标准偏差>, @<法线方向>, @<波长>, @<空间纵横比>, @<相位偏移>, @<数值类型>);
        返回 (返回矩阵)
    }

    方法 角点检测特征映射 <公开 静态 注释 = "preCornerDetect,使用边缘映射的方法检测角点特征.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "输入8位整型或32位浮点单通道图像">
    参数 输出图像 <类型 = CV矩阵类 注释 = "输出类型为CV_32F且大小与输入图像相同的图像.">
    参数 核心尺寸 <类型 = 整数 注释 = "检测时核心的尺寸,必须为大于0的奇数." @默认值 = 3>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "需要映射的边缘类型" @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::preCornerDetect(@<输入图像>.obj, @<输出图像>.obj, @<核心尺寸>, @<边缘类型>);
    }

    方法 角点检测亚像素 <公开 静态 注释 = "cornerSubPix,使用亚像素的角点检测方法检测角点.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "输入8位整型或32位浮点单通道图像">
    参数 输出结果 <类型 = CV坐标2f容器 注释 = "输出角点的坐标点">
    参数 搜索半径 <类型 = CV尺寸类 注释 = "检测时核心的尺寸">
    参数 角点半径 <类型 = CV尺寸类 注释 = "搜索区域中间的角点大小的一半,在该区域上未进行以下公式中的求和.  它有时用于避免自相关矩阵可能出现的奇异性." 注释 = " (-1,-1) 的值表示没有这样的大小.">
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "即指定迭代次数和迭代停止条件">
    {
        @ cv::cornerSubPix(@<输入图像>.obj, @<输出结果>.obj, @<搜索半径>.obj, @<角点半径>.obj, @<迭代算法>.obj);
    }

    方法 角点检测强特征 <公开 静态 注释 = "goodFeaturesToTrack,使用强梯度特征检测角点.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "输入8位整型或32位浮点单通道图像">
    参数 输出结果 <类型 = CV坐标2f容器 注释 = "输出角点的坐标点">
    参数 最大目标个数 <类型 = 整数 注释 = "指定最多可以返回多少个目标点">
    参数 角点质量 <类型 = 小数 注释 = "0.1-1.0" @默认值 = 0.5>
    参数 角点最小距离 <类型 = 小数 注释 = "角点与角点的最小距离">
    参数 指定检测区域 <类型 = CV矩阵类 注释 = "为空时不使用ROI" @默认值 = 空对象>
    参数 运算核心尺寸 <类型 = 整数 注释 = "检测时核心的尺寸,核心尺寸必须是大于0的奇数" @默认值 = 3>
    参数 是否采用Harris角点检测 <类型 = 逻辑型 注释 = "为真时使用Harris角点检测" @默认值 = 真>
    参数 Harris角点系数 <类型 = 小数 注释 = "如果使用的Harris算法,则指定Harris角点的系数值." @默认值 = 0.04>
    {
        如果 (指定检测区域 != 空对象)
        {
            @ cv::goodFeaturesToTrack(@<输入图像>.obj, @<输出结果>.obj, @<最大目标个数>, @<角点质量>, @<角点最小距离>, @<指定检测区域>.obj, @<运算核心尺寸>, @<是否采用Harris角点检测>, @<Harris角点系数>);
        }
        否则
        {
            @ cv::goodFeaturesToTrack(@<输入图像>.obj, @<输出结果>.obj, @<最大目标个数>, @<角点质量>, @<角点最小距离>, cv::Mat(), @<运算核心尺寸>, @<是否采用Harris角点检测>, @<Harris角点系数>);
        }
    }

    方法 角点检测梯度强特征 <公开 静态 注释 = "goodFeaturesToTrack,使用强梯度特征检测角点.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "输入8位整型或32位浮点单通道图像">
    参数 输出结果 <类型 = CV坐标2f容器 注释 = "输出角点的坐标点">
    参数 最大目标个数 <类型 = 整数 注释 = "指定最多可以返回多少个目标点">
    参数 角点质量 <类型 = 小数 注释 = "0.1-1.0" @默认值 = 0.5>
    参数 角点最小距离 <类型 = 小数 注释 = "角点与角点的最小距离">
    参数 指定检测区域 <类型 = CV矩阵类 注释 = "为空时不使用ROI,不为空时只在ROI范围内查找." @默认值 = 空对象>
    参数 输出角点质量 <类型 = CV单精度小数容器 注释 = "输出每个角点的质量,范围0-1.">
    参数 运算核心尺寸 <类型 = 整数 注释 = "检测时核心的尺寸,核心尺寸必须是大于0的奇数" @默认值 = 3>
    参数 梯度 <类型 = 整数 注释 = "运算时下降的梯度值,梯度值必须是大于0的奇数" @默认值 = 3>
    参数 是否采用Harris角点检测 <类型 = 逻辑型 注释 = "为真时使用Harris角点检测,否则不使用." @默认值 = 假>
    参数 Harris角点系数 <类型 = 小数 注释 = "如果使用的Harris算法,则指定Harris角点的系数值." @默认值 = 0.04>
    {
        如果 (指定检测区域 != 空对象)
        {
            @ cv::goodFeaturesToTrack(@<输入图像>.obj, @<输出结果>.obj, @<最大目标个数>, @<角点质量>, @<角点最小距离>, @<指定检测区域>.obj, @<输出角点质量>.obj,@<运算核心尺寸>, @<梯度>,@<是否采用Harris角点检测>, @<Harris角点系数>);
        }
        否则
        {
            @ cv::goodFeaturesToTrack(@<输入图像>.obj, @<输出结果>.obj, @<最大目标个数>, @<角点质量>, @<角点最小距离>, cv::noArray(), @<输出角点质量>.obj,@<运算核心尺寸>, @<梯度>,@<是否采用Harris角点检测>, @<Harris角点系数>);
        }
    }

    方法 霍夫标准直线检测从二值图 <公开 静态 注释 = "HoughLines,使用概率变换在二值图像中找到线段,得到的直线端点可能在图像外.">
    参数 输入二值图 <类型 = CV矩阵类 注释 = "欲处理的图像,必须为二值图像.">
    参数 输出结果 <类型 = CV向量容器2f 注释 = "说明说是可以用2-3维的向量,存储的是边缘直线在极坐标空间下的rho和theta值,在图像空间(直角坐标系下)只能体现出一个点"
            注释 = " //以该点为基准,利用theta与斜率之间的关系,找出该直线上的其他两个点(可能不在图像上).">
    参数 距离步长 <类型 = 小数 注释 = "搜索距离步长">
    参数 角度步长 <类型 = 小数 注释 = "搜索角度步长 弧度">
    参数 阈值 <类型 = 整数 注释 = "累加器阈值参数,大于该阈值的点被保留.">
    参数 srn <类型 = 小数 注释 = "srn 对于多尺度变换,它是 距离步长 rho 的除数."
            注释 = "粗略的累加器 距离步长 为 rho ,准确的累加器分辨率为 rho/srn .  如果 srn=0 和 stn=0 ,则使用经典的变换.  否则,这两个参数都应该是正数." @默认值 = 0>
    参数 stn <类型 = 小数 注释 = "对于多尺度变换,srn表示第四个参数进步尺寸的单位角度theta的除数距离. 且如果srn和stn同时为0,就表示使用经典的变换. 否则,这两个参数应该都为正数." @默认值 = 0>
    参数 最小角度 <类型 = 小数 注释 = "min_theta,弧度制." @默认值 = 0>
    参数 最大角度 <类型 = 小数 注释 = "max_theta,弧度制." @默认值 = 3.1415926>
    {
        @ cv::HoughLines(@<输入二值图>.obj, @<输出结果>.obj, @<距离步长>, @<角度步长>, @<阈值>, @<srn>,@<stn>, @<最小角度>,@<最大角度>);
    }

    方法 霍夫概率直线检测从二值图 <公开 静态 注释 = "HoughLinesP,使用概率霍夫变换在二值图像中找到线段.">
    参数 输入二值图 <类型 = CV矩阵类 注释 = "欲处理的图像,必须为二值图像.">
    参数 输出结果 <类型 = CV向量容器4i 注释 = "起点x = 输出结果[0] 起点y = 输出结果[1]" 注释 = "终点x = 输出结果[2] 终点y = 输出结果[3]">
    参数 距离步长 <类型 = 小数 注释 = "搜索距离步长">
    参数 角度步长 <类型 = 小数 注释 = "搜索角度步长 弧度">
    参数 阈值 <类型 = 整数 注释 = "大于阈值的结果被保留">
    参数 最小长度 <类型 = 小数 注释 = "线段的最小长度">
    参数 最大长度 <类型 = 小数 注释 = "线段的最大长度">
    {
        @ cv::HoughLinesP(@<输入二值图>.obj, @<输出结果>.obj, @<距离步长>, @<角度步长>, @<阈值>, @<最小长度>,@<最大长度>);
    }

    方法 霍夫直线检测从点 <公开 静态 注释 = "HoughLinesPointSet()">
    参数 输入点数组 <类型 = CV坐标2f容器 注释 = "欲检测的点数组(容器)">
    参数 输出结果 <类型 = CV向量容器2f 注释 = "输出找到的直线结果">
    参数 最大目标个数 <类型 = 整数 注释 = "指定最大的返回结果个数">
    参数 阈值 <类型 = 整数 注释 = "累加器阈值参数. 只有那些得到足够多信息的行才会被返回">
    参数 最小距离 <类型 = 小数 注释 = "min_rho累加器的最小距离值,以像素为单位.">
    参数 最大距离 <类型 = 小数 注释 = "max_rho累加器的最大距离值,以像素为单位.">
    参数 距离步长 <类型 = 小数 注释 = "检测距离的步长">
    参数 最小角度 <类型 = 小数 注释 = "弧度,累加器的最小角度.">
    参数 最大角度 <类型 = 小数 注释 = "弧度,累加器的最大角度.">
    参数 角度步长 <类型 = 小数 注释 = "搜索角度步长">
    {
        @ cv::HoughLinesPointSet(@<输入点数组>.obj, @<输出结果>.obj, @<最大目标个数>, @<阈值>, @<最小距离>, @<最大距离>,@<距离步长>, @<最小角度>, @<最大角度>, @<角度步长>);
    }

    方法 霍夫圆检测 <公开 静态 注释 = "HoughCircles, 使用霍夫变换在灰度图像中查找圆.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲处理的图像,必须为二值图像.">
    参数 输出结果 <类型 = CV向量容器3f 注释 = "所找到圆的输出向量. 每个向量被编码为3或4个元素的浮点向量.">
    参数 变换方法 <类型 = CV霍夫变换方法常量 注释 = "霍夫变换的方法" "">
    参数 dp <类型 = 整数 注释 = "累加器分辨率与图像分辨率的反比,例如,如果 dp=1 ,则累加器具有与输入图像相同的分辨率." 注释 = "如果 dp=2 ,累加器的宽度和高度只有一半.">
    参数 最小距离 <类型 = 小数 注释 = "圆与圆之间的最小距离">
    参数 参数1 <类型 = 小数 注释 = "第一个特定于方法的参数.  在  #梯度变换 和#梯度变换高精度 的情况下：" 注释 = "        它是传递给Canny边缘检测器的两者中较高的阈值(较低的阈值小两倍)."
            注释 = "注意#梯度变换高精度 使用#Scharr算法计算图像导数,因此阈值应该 通常更高,例如 300 或正常曝光和对比度的图像." @默认值 = 100>
    参数 参数2 <类型 = 小数 注释 = "第二个方法特定的参数.  在#梯度变换 的情况下,它是检测阶段圆心的累加器阈值.  它越小,可能检测到的错误圆圈就越多.  与较大的累加器值相对应的圆圈将首先返回."
            注释 = " 在#梯度变换高精度 算法的情况下,这是圆形“完美度”度量. 它越接近 1,表示圆形算法选择的形状越好.  在大多数情况下,0.9 应该没问题."
            注释 = "如果想要更好地检测小圆,可以将其降低到 0.85、0.8 甚至更小. 但是也可以尝试限制搜索范围 [minRadius, maxRadius] 以避免出现很多错误的圆." @默认值 = 100>
    参数 最小半径 <类型 = 整数 注释 = "检测到圆的最小半径" @默认值 = 0>
    参数 最大半径 <类型 = 整数 注释 = "如果小于等于0,则使用最大图像尺寸作为其最大半径." @默认值 = 0>
    {
        @ cv::HoughCircles(@<输入图像>.obj, @<输出结果>.obj, @<变换方法>, @<dp>, @<最小距离>, @<参数1>, @<参数2>, @<最小半径>, @<最大半径>);
    }

    方法 腐蚀 <公开 静态 注释 = "erode,腐蚀图像,即减少图像的灰度值.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲腐蚀的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "腐蚀完成的图像">
    参数 输入结构元素 <类型 = CV矩阵类 注释 = "用函数 获取结构元素 得到">
    参数 锚点 <类型 = CV坐标点 注释 = "为空对象时表示锚点在结构的中心" @默认值 = 空对象>
    参数 迭代次数 <类型 = 整数 注释 = "计算迭代次数" @默认值 = 1>
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.不变>
    参数 颜色值 <类型 = CV标量类 注释 = "指定边界的颜色" @默认值 = 空对象>
    {
        变量 临时_锚点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_锚点.X = -1
            临时_锚点.Y = -1
        }
        否则
        {
            临时_锚点 = 锚点
        }
        如果 (颜色值 == 空对象)
        {
            @ cv::erode(@<源图像>.obj, @<输出结果>.obj, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, cv::morphologyDefaultBorderValue());
        }
        否则
        {
            @ cv::erode(@<源图像>.obj, @<输出结果>.obj, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, @<颜色值>.obj);
        }
    }

    方法 膨胀 <公开 静态 注释 = "dilate,对图像做膨胀,即增加图像的灰度值.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理后的图像">
    参数 输入结构元素 <类型 = CV矩阵类 注释 = "用函数 获取结构元素 得到">
    参数 锚点 <类型 = CV坐标点 注释 = "为空对象时表示锚点在结构的中心" @默认值 = 空对象>
    参数 迭代次数 <类型 = 整数 注释 = "迭代运算次数" @默认值 = 1>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "指定边缘的类型,类型不同得到的效果是不同的." @默认值 = CV边缘类型.不变>
    参数 颜色值 <类型 = CV标量类 注释 = "指定边界的颜色" @默认值 = 空对象>
    {
        变量 临时_锚点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_锚点.X = -1
            临时_锚点.Y = -1
        }
        否则
        {
            临时_锚点 = 锚点
        }
        如果 (颜色值 == 空对象)
        {
            @ cv::dilate(@<源图像>.obj, @<输出结果>.obj, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, cv::morphologyDefaultBorderValue());
        }
        否则
        {
            @ cv::dilate(@<源图像>.obj, @<输出结果>.obj, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, @<颜色值>.obj);
        }
    }

    方法 形态学运算 <公开 静态 注释 = "cv::morphologyEx,包含了腐蚀、膨胀、开运算、闭运算、顶帽、底帽.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像,必须是单通道的二值图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理后的图像">
    参数 形态学操作 <类型 = CV形态学常量 注释 = "即 腐蚀、膨胀、开运算、闭运算、顶帽、底帽">
    参数 输入结构元素 <类型 = CV矩阵类 注释 = "用函数 获取结构元素 得到">
    参数 锚点 <类型 = CV坐标点 注释 = "为空对象时表示锚点在结构的中心" @默认值 = 空对象>
    参数 迭代次数 <类型 = 整数 注释 = "运算迭代次数" @默认值 = 1>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "指定边缘的类型,类型不同得到的效果是不同的." @默认值 = CV边缘类型.不变>
    参数 颜色值 <类型 = CV标量类 注释 = "morphologyDefaultBorderValue()" @默认值 = 空对象>
    {
        变量 临时_锚点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_锚点.X = -1
            临时_锚点.Y = -1
        }
        否则
        {
            临时_锚点 = 锚点
        }
        如果 (颜色值 == 空对象)
        {
            @ cv::morphologyEx(@<源图像>.obj, @<输出结果>.obj, @<形态学操作>, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, cv::morphologyDefaultBorderValue());
        }
        否则
        {
            @ cv::morphologyEx(@<源图像>.obj, @<输出结果>.obj, @<形态学操作>, @<输入结构元素>.obj, @<临时_锚点>.obj , @<迭代次数>, @<边缘类型>, @<颜色值>.obj);
        }
    }

    方法 获取结构元素 <公开 静态 类型 = CV矩阵类 注释 = "getStructuringElement,获取结构元素,用于形态学计算等.">
    参数 内核形状 <类型 = CV内核形状常量 注释 = "指定内核的几何形状" @默认值 = CV内核形状常量.矩形>
    参数 结构尺寸 <类型 = CV尺寸类 注释 = "指定内核的尺寸">
    参数 锚点 <类型 = CV坐标点 注释 = "为空时指定其锚点在中心" @默认值 = 空对象>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        如果 (锚点 == 空对象)
        {
            @ @<返回矩阵>.obj = cv::getStructuringElement(@<内核形状>, @<结构尺寸>.obj, cv::Point(-1,-1));
        }
        否则
        {
            @ @<返回矩阵>.obj = cv::getStructuringElement(@<内核形状>, @<结构尺寸>.obj, @<锚点>.obj);
        }
        返回 (返回矩阵)
    }

    方法 中值模糊 <公开 静态 注释 = "medianBlur,使用中值模糊算法处理图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 滤波核尺寸 <类型 = 整数 注释 = "处理图像时使用的滤波核尺寸,必须为大于0的奇数.">
    {
        @ cv::medianBlur(@<源图像>.obj, @<输出结果>.obj, @<滤波核尺寸>);
    }

    方法 高斯模糊 <公开 静态 注释 = "GaussianBlur,该函数将源图像与指定的高斯核进行卷积.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 滤波核尺寸 <类型 = CV尺寸类 注释 = "处理图像时使用的滤波核尺寸">
    参数 SigmaX <类型 = 小数 注释 = "X 方向的 sigmaX 高斯核标准差">
    参数 sigmaY <类型 = 小数 注释 = "Y方向的sigmaY高斯核标准差； 如果 sigmaY 为零,则设置为等于 sigmaX,如果两个 sigma 均为零,"
            注释 = "则分别从 滤波核尺寸.宽度 和 滤波核尺寸.高度 计算(详见#getGaussianKernel)；" 注释 = "为了完全控制结果,无论将来可能对所有这些语义进行修改,"
            注释 = "建议指定所有 ksize、sigmaX 和 sigmaY." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::GaussianBlur(@<源图像>.obj, @<输出结果>.obj, @<滤波核尺寸>.obj, @<SigmaX>, @<sigmaY>, @<边缘类型>);
    }

    方法 双边滤波 <公开 静态 注释 = "bilateralFilter,使用双边滤波算法处理图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 邻域直径 <类型 = 整数 注释 = "过滤期间使用的每个像素邻域的直径.  如果是非正数,则从 sigma空间 计算.">
    参数 Sigma颜色 <类型 = 小数 注释 = "过滤颜色空间中的 sigma.  较大的参数值意味着像素邻域内更远的颜色(参见 sigma空间)将混合在一起,从而产生更大的半等色区域.">
    参数 sigma空间 <类型 = 小数 注释 = "在坐标空间中过滤 sigma.  较大的参数值意味着更远的像素会相互影响,只要它们的颜色足够接近(参见 Sigma颜色).  当 邻域直径\\>0 时,"
            注释 = "它指定邻域大小,而与 sigma空间 无关.  否则,邻域直径 与 sigma空间 成比例.">
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::bilateralFilter(@<源图像>.obj, @<输出结果>.obj, @<邻域直径>, @<Sigma颜色>, @<sigma空间>, @<边缘类型>);
    }

    方法 方框滤波 <公开 静态 注释 = "boxFilter, 使用归一化方框滤镜模糊图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 目标深度 <类型 = 整数 注释 = "depth目标图像的期望深度">
    参数 滤波核尺寸 <类型 = CV尺寸类 注释 = "处理图像时使用的滤波核尺寸">
    参数 是否使用归一化 <类型 = 逻辑型 注释 = "为真时将作归一化处理">
    参数 锚点 <类型 = CV坐标点 注释 = "在内核中的锚点位置, 默认值$(-1,-1)$表示锚在内核中心." @默认值 = 空对象>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        变量 临时_坐标点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_坐标点.X = -1
            临时_坐标点.Y = -1
            @ cv::boxFilter(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核尺寸>.obj, @<临时_坐标点>.obj,@<是否使用归一化>,  @<边缘类型>);
        }
        否则
        {
            @ cv::boxFilter(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核尺寸>.obj,  @<锚点>.obj, @<是否使用归一化>,@<边缘类型>);
        }
    }

    方法 平方方框滤波 <公开 静态 注释 = "sqrBoxFilter, 使用平方归一化框滤镜模糊图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 滤波核尺寸 <类型 = CV尺寸类 注释 = "处理图像时使用的滤波核尺寸">
    参数 是否使用归一化 <类型 = 逻辑型 注释 = "为真时将作归一化处理">
    参数 锚点 <类型 = CV坐标点 注释 = "在内核中的锚点位置, 默认值$(-1,-1)$表示锚在内核中心." @默认值 = 空对象>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        变量 临时_坐标点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_坐标点.X = -1
            临时_坐标点.Y = -1
            @ cv::sqrBoxFilter(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核尺寸>.obj, @<临时_坐标点>.obj, @<是否使用归一化>, @<边缘类型>);
        }
        否则
        {
            @ cv::sqrBoxFilter(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核尺寸>.obj, @<锚点>.obj, @<是否使用归一化>, @<边缘类型>);
        }
    }

    方法 标准模糊 <公开 静态 注释 = "blur, 使用标准模糊算法模糊图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 滤波核尺寸 <类型 = CV尺寸类 注释 = "处理图像时使用的滤波核尺寸">
    参数 锚点 <类型 = CV坐标点 注释 = "在内核中的锚点位置, 默认值$(-1,-1)$表示锚在内核中心." @默认值 = 空对象>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        变量 临时_坐标点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_坐标点.X = -1
            临时_坐标点.Y = -1
            @ cv::blur(@<源图像>.obj, @<输出结果>.obj, @<滤波核尺寸>.obj, @<临时_坐标点>.obj, @<边缘类型>);
        }
        否则
        {
            @ cv::blur(@<源图像>.obj, @<输出结果>.obj, @<滤波核尺寸>.obj, @<锚点>.obj, @<边缘类型>);
        }
    }

    方法 任意线性滤波 <公开 静态 注释 = "filter2D,使用任意线性滤波处理图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "处理完成的图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 滤波核 <类型 = CV矩阵类 注释 = "滤波核">
    参数 锚点 <类型 = CV坐标点 注释 = "在内核中的锚点位置, 默认值$(-1,-1)$表示锚在内核中心." @默认值 = 空对象>
    参数 delta <类型 = 小数 注释 = "delta在存储过滤结果之前添加到它们的值." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        变量 临时_坐标点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_坐标点.X = -1
            临时_坐标点.Y = -1
            @ cv::filter2D(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核>.obj, @<临时_坐标点>.obj, @<delta>, @<边缘类型>);
        }
        否则
        {
            @ cv::filter2D(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<滤波核>.obj, @<锚点>.obj, @<delta>, @<边缘类型>);
        }
    }

    方法 任意线性滤波可分解卷积核 <公开 静态 注释 = "sepFilter2D,参数 kernelX kernelY用函数 获取导数核 或者 获取高斯滤波核 得到.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 kernelX <类型 = CV矩阵类 注释 = "kernelX用于过滤每一行的系数. 一维矩阵">
    参数 kernelY <类型 = CV矩阵类 注释 = "kernelY用于过滤每一行的系数. 一维矩阵">
    参数 锚点 <类型 = CV坐标点 注释 = "在内核中的锚点位置, 默认值$(-1,-1)$表示锚在内核中心." @默认值 = 空对象>
    参数 delta <类型 = 小数 注释 = "delta在存储过滤结果之前添加到它们的值." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        变量 临时_坐标点 <类型 = CV坐标点>
        如果 (锚点 == 空对象)
        {
            临时_坐标点.X = -1
            临时_坐标点.Y = -1
            @ cv::sepFilter2D(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<kernelX>.obj, @<kernelY>.obj, @<临时_坐标点>.obj, @<delta>, @<边缘类型>);
        }
        否则
        {
            @ cv::sepFilter2D(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<kernelX>.obj, @<kernelY>.obj, @<锚点>.obj, @<delta>, @<边缘类型>);
        }
    }

    方法 边缘检测Sobel <公开 静态 注释 = "Sobel,使Sobel算子检测图像的边缘.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 x方向导数 <类型 = 整数 注释 = "在图像X方向上使用的导数,为0时只输出y方向结果.">
    参数 y方向导数 <类型 = 整数 注释 = "在图像Y方向上使用的导数,为0时只输出x方向结果.">
    参数 孔径尺寸 <类型 = 整数 注释 = "计算二阶导数滤波器的孔径大小,必须为大于0的奇数." @默认值 = 1>
    参数 缩放比例 <类型 = 小数 注释 = "缩放可选缩放因子为计算的导数值;默认情况下,不应用缩放." @默认值 = 1>
    参数 delta增量 <类型 = 小数 注释 = "在   输出结果  中存储结果之前,在结果中添加的增量值." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::Sobel(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<x方向导数>, @<y方向导数>, @<孔径尺寸>, @<缩放比例>, @<delta增量>, @<边缘类型>);
    }

    方法 图像梯度计算 <公开 静态 注释 = "spatialGradient, 使用Sobel算子计算x和y的一阶图像导数相当于调用：" 注释 = "边缘检测Sobel( src, dx, CV_16SC1, 1, 0, 3 );"
            注释 = "边缘检测Sobel( src, dy, CV_16SC1, 0, 1, 3 ).">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出x方向梯度 <类型 = CV矩阵类 注释 = "x的一阶导数的输出图像">
    参数 输出y方向梯度 <类型 = CV矩阵类 注释 = "y的一阶导数的输出图像">
    参数 Sobel核大小 <类型 = 整数 注释 = "Sobel核大小,必须为大于0的奇数." @默认值 = 3>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::spatialGradient(@<源图像>.obj, @<输出x方向梯度>.obj, @<输出y方向梯度>.obj, @<Sobel核大小>, @<边缘类型>);
    }

    方法 边缘检测Scharr <公开 静态 注释 = "Scharr,使用Scharr算法检测边缘.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 x方向导数 <类型 = 整数 注释 = "在图像X方向上使用的导数">
    参数 y方向导数 <类型 = 整数 注释 = "在图像Y方向上使用的导数">
    参数 缩放比例 <类型 = 小数 注释 = "缩放可选缩放因子为计算的导数值;默认情况下,不应用缩放." @默认值 = 1>
    参数 delta增量 <类型 = 小数 注释 = "在dst中存储结果之前,在结果中添加的增量值." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::Scharr(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<x方向导数>, @<y方向导数>, @<缩放比例>, @<delta增量>, @<边缘类型>);
    }

    方法 拉普斯算子 <公开 静态 注释 = "Laplacian, 该函数通过将使用Sobel算子计算出的x和y二阶导数相加来计算源图像的拉普拉斯算子.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像">
    参数 目标深度 <类型 = CV数值类型 注释 = "depth目标图像的期望深度">
    参数 孔径尺寸 <类型 = 整数 注释 = "计算二阶导数滤波器的孔径大小,必须为大于0的奇数." @默认值 = 1>
    参数 缩放比例 <类型 = 小数 注释 = "缩放可选缩放因子为计算的导数值;默认情况下,不应用缩放." @默认值 = 1>
    参数 delta增量 <类型 = 小数 注释 = "在dst中存储结果之前,在结果中添加的增量值." @默认值 = 0>
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::Laplacian(@<源图像>.obj, @<输出结果>.obj, @<目标深度>, @<孔径尺寸>, @<缩放比例>, @<delta增量>, @<边缘类型>);
    }

    方法 边缘检测Canny <公开 静态 注释 = "Canny,使用Canny算法检测边缘.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像,必须为8位深度.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像,必须为8位深度.">
    参数 低阈值 <类型 = 小数 注释 = "迟滞过程的第一个阈值">
    参数 高阈值 <类型 = 小数 注释 = "迟滞过程的第二个阈值">
    参数 孔径尺寸 <类型 = 整数 注释 = "这里指 Sobel算子的孔径大小,必须为大于1的奇数.">
    参数 查找高精度 <类型 = 逻辑型 注释 = "是否使用高精度的查找,为真时使用高精度查找." @默认值 = 假>
    {
        @ cv::Canny(@<源图像>.obj, @<输出结果>.obj, @<低阈值>, @<高阈值>, @<孔径尺寸>, @<查找高精度>);
    }

    方法 边缘检测自定义梯度Canny <公开 静态 注释 = "Canny,使用Canny算法加自定义梯度检测边缘.">
    参数 源图像1 <类型 = CV矩阵类 注释 = "输入图像(CV_16SC1或CV_16SC3)的16位x导数.">
    参数 源图像2 <类型 = CV矩阵类 注释 = "输入图像(CV_16SC1或CV_16SC3)的16位y导数.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "检测结果图像">
    参数 低阈值 <类型 = 小数 注释 = "迟滞过程的第一个阈值">
    参数 高阈值 <类型 = 小数 注释 = "迟滞过程的第二个阈值">
    参数 查找高精度 <类型 = 逻辑型 注释 = "是否使用高精度的查找,为真时使用高精度查找." @默认值 = 假>
    {
        @ cv::Canny(@<源图像1>.obj, @<源图像2>.obj,  @<输出结果>.obj, @<低阈值>, @<高阈值>, @<查找高精度>);
    }

    方法 角点检测局部最小值 <公开 静态 注释 = "cornerMinEigenVal,函数类似于cornerEigenValsAndVecs,但它只计算和存储导数协方差矩阵的最小特征值,"
            注释 = "即$\\min(\\lambda_1, \\lambda_2)$,以cornerEigenValsAndVecs描述的公式表示.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测角点的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "类型为CV_32位浮点型,输出的角点元素值不为0.">
    参数 邻域尺寸 <类型 = 整数 注释 = "计算时采用的相邻的像素点距离">
    参数 孔径尺寸 <类型 = 整数 注释 = "检测时Sobel算子孔径,必须为大于0的奇数.">
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::cornerMinEigenVal(@<源图像>.obj, @<输出结果>.obj, @<邻域尺寸>, @<孔径尺寸>, @<边缘类型>);
    }

    方法 角点检测Harris <公开 静态 注释 = "cornerHarris,使用Harris算法检测角点.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测角点的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "类型为CV_32位浮点型,输出的角点元素值不为0.">
    参数 邻域尺寸 <类型 = 整数 注释 = "计算时采用的相邻的像素点距离">
    参数 孔径尺寸 <类型 = 整数 注释 = "检测时Sobel算子孔径,必须为大于0的奇数.">
    参数 Harris参数 <类型 = 小数 注释 = "计算时Harris算子参数">
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::cornerHarris(@<源图像>.obj, @<输出结果>.obj, @<邻域尺寸>, @<孔径尺寸>, @<Harris参数>, @<边缘类型>);
    }

    方法 自定义角点检测 <公开 静态 注释 = "cornerEigenValsAndVecs,使用自定义参数检测角点.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测角点的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "类型为CV_32位浮点型,输出的角点元素值不为0.">
    参数 邻域尺寸 <类型 = 整数 注释 = "计算时采用的相邻的像素点距离">
    参数 孔径尺寸 <类型 = 整数 注释 = "检测时Sobel算子孔径,必须为大于0的奇数.">
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::cornerEigenValsAndVecs(@<源图像>.obj, @<输出结果>.obj, @<邻域尺寸>, @<孔径尺寸>, @<边缘类型>);
    }

    方法 局部最大值角点检测 <公开 静态 注释 = "preCornerDetect,使用局部最大值检测角点.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测角点的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "类型为CV_32位浮点型,输出的角点元素值不为0.">
    参数 孔径尺寸 <类型 = 整数 注释 = "检测时Sobel算子孔径,必须为大于0的奇数.">
    参数 边缘类型 <类型 = CV边缘类型 注释 = "不支持#用另一边的像素来补偿填充" @默认值 = CV边缘类型.不变>
    {
        @ cv::preCornerDetect(@<源图像>.obj, @<输出结果>.obj, @<孔径尺寸>, @<边缘类型>);
    }

    方法 翻转矩阵 <公开 静态 注释 = "flip,镜像翻转图像(矩阵).">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲翻转的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "完成翻转的矩阵">
    参数 镜像方式 <类型 = CV翻转矩阵常量 注释 = "指定按上下或者左右翻转">
    {
        @ cv::flip(@<输入矩阵>.obj,@<输出矩阵>.obj,@<镜像方式>);
    }

    方法 旋转矩阵 <公开 静态 注释 = "rotate,只支持90 180 270 度,如果需要自由旋转角度请使用函数 旋转矩阵_自由角度.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲旋转的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "完成旋转的矩阵">
    参数 旋转角度 <类型 = CV旋转矩阵常量 注释 = "旋转角度">
    {
        @ cv::rotate(@<输入矩阵>.obj,@<输出矩阵>.obj,@<旋转角度>);
    }

    方法 复制矩阵阵列 <公开 静态 注释 = "repeat,将一个矩阵图像复制成像表格一样排列的矩阵.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲复制的矩阵">
    参数 横向复制次数 <类型 = 整数 注释 = "在X方向上复制次数" "">
    参数 纵向复制次数 <类型 = 整数 注释 = "在Y方向上复制次数">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出复制排列的矩阵">
    {
        @ cv::repeat(@<输入矩阵>.obj,@<横向复制次数>,@<纵向复制次数>,@<输出矩阵>.obj);
    }

    方法 水平拼接矩阵 <公开 静态 注释 = "hconcat,将两个矩阵横向拼接.">
    参数 输入矩阵1 <类型 = CV矩阵类 注释 = "位于左边的矩阵">
    参数 输入矩阵2 <类型 = CV矩阵类 注释 = "位于右边的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "拼接完成的矩阵">
    {
        @ cv::hconcat(@<输入矩阵1>.obj, @<输入矩阵2>.obj, @<输出矩阵>.obj);
    }

    方法 垂直拼接矩阵 <公开 静态 注释 = "vconcat,将两个矩阵垂直拼接.">
    参数 输入矩阵1 <类型 = CV矩阵类 注释 = "位于上部的矩阵">
    参数 输入矩阵2 <类型 = CV矩阵类 注释 = "位于下部的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "拼接完成的矩阵">
    {
        @ cv::vconcat(@<输入矩阵1>.obj, @<输入矩阵2>.obj, @<输出矩阵>.obj);
    }

    方法 复制到图像 <公开 静态 注释 = "copyTo,将一个图像画到另一个里面,和函数 画到图像 一样的功能.">
    参数 源图像 <类型 = CV矩阵类 注释 = "作为底图的源图像">
    参数 输出图像 <类型 = CV矩阵类 注释 = "输出复制结果">
    参数 输入蒙版图像 <类型 = CV矩阵类 注释 = "这个图像将被绘制在源图像上">
    {
        @ cv::copyTo(@<源图像>.obj, @<输出图像>.obj, @<输入蒙版图像>.obj);
    }

    方法 多通道二值化 <公开 静态 注释 = "inRange,在指定 低阈值 与 高阈值 范围之间的元素被置为255.">
    参数 源图像 <类型 = CV矩阵类 注释 = "多通道的图像(矩阵)">
    参数 低阈值 <类型 = CV标量类 注释 = "作为二值化阈值下限的颜色标量">
    参数 高阈值 <类型 = CV标量类 注释 = "作为二值化阈值上限的颜色标量">
    参数 输出图像 <类型 = CV矩阵类 注释 = "输出二值图像">
    {
        @ cv::inRange(@<源图像>.obj, @<低阈值>.obj, @<高阈值>.obj, @<输出图像>.obj);
    }

    方法 求两矩阵最小值 <公开 静态 注释 = "min,将输出一个矩阵,这个矩阵的每个元素对应的值为两个矩阵中对应的元素的最小值.">
    参数 输入矩阵1 <类型 = CV矩阵类 注释 = "欲计算的矩阵1">
    参数 输入矩阵2 <类型 = CV矩阵类 注释 = "欲计算的矩阵2">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出两矩阵最小值矩阵">
    {
        @ cv::min(@<输入矩阵1>.obj, @<输入矩阵2>.obj, @<输出矩阵>.obj);
    }

    方法 求两矩阵最大值 <公开 静态 注释 = "max,将输出一个矩阵,这个矩阵的每个元素对应的值为两个矩阵中对应的元素的最大值.">
    参数 输入矩阵1 <类型 = CV矩阵类 注释 = "欲计算的矩阵1">
    参数 输入矩阵2 <类型 = CV矩阵类 注释 = "欲计算的矩阵2">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出两矩阵最大值矩阵">
    {
        @ cv::max(@<输入矩阵1>.obj, @<输入矩阵2>.obj, @<输出矩阵>.obj);
    }

    方法 求矩阵平方根 <公开 静态 注释 = "sqrt,将输出一个矩阵,这个矩阵的每个元素为原矩阵的平方根.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "计算得到的源矩阵平方根矩阵">
    {
        @ cv::sqrt(@<输入矩阵>.obj, @<输出矩阵>.obj);
    }

    方法 求矩阵幂次 <公开 静态 注释 = "pow,将每个数组元素提升为幂.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输入幂指数 <类型 = 小数 注释 = "指定计算的幂指数">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出源矩阵幂次的矩阵">
    {
        @ cv::pow(@<输入矩阵>.obj, @<输入幂指数>, @<输出矩阵>.obj);
    }

    方法 求矩阵指数 <公开 静态 注释 = "exp">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出源矩阵的指数矩阵">
    {
        @ cv::exp(@<输入矩阵>.obj, @<输出矩阵>.obj);
    }

    方法 求矩阵对数 <公开 静态 注释 = "log">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "输出源矩阵的对数矩阵">
    {
        @ cv::log(@<输入矩阵>.obj, @<输出矩阵>.obj);
    }

    方法 极坐标系到直角坐标系 <公开 静态 注释 = "polarToCart,极坐标系坐标转换到笛卡尔坐标系.">
    参数 输入点数组 <类型 = CV矩阵类 注释 = "需要转换的直角坐标点矩阵">
    参数 输入角度数组 <类型 = CV矩阵类 注释 = "需要转换的角度矩阵">
    参数 输出X坐标 <类型 = CV矩阵类 注释 = "输出直角坐标X">
    参数 输出Y坐标 <类型 = CV矩阵类 注释 = "输出直角坐标Y">
    参数 是否为十进制度 <类型 = 逻辑型 注释 = "为真时使用十进制度,否则使用弧度制." @默认值 = 假>
    {
        @ cv::polarToCart(@<输入点数组>.obj, @<输入角度数组>.obj, @<输出X坐标>.obj, @<输出Y坐标>.obj, @<是否为十进制度>);
    }

    方法 直角坐标系到极坐标系 <公开 静态 注释 = "cartToPolar,笛卡尔坐标系坐标转换到极坐标系.">
    参数 输入X坐标 <类型 = CV矩阵类 注释 = "必须为单通道的矩阵">
    参数 输入Y坐标 <类型 = CV矩阵类 注释 = "必须为单通道的矩阵">
    参数 输出点数组 <类型 = CV矩阵类 注释 = "输出转换后的极坐标点矩阵">
    参数 输出角度数组 <类型 = CV矩阵类 注释 = "输出转换后的角度矩阵">
    参数 是否为十进制度 <类型 = 逻辑型 注释 = "为真时使用十进制度,否则使用弧度制." @默认值 = 假>
    {
        @ cv::cartToPolar(@<输入X坐标>.obj, @<输入Y坐标>.obj, @<输出点数组>.obj, @<输出角度数组>.obj, @<是否为十进制度>);
    }

    方法 计算方向场 <公开 静态 注释 = "phase,计算二维向量的方向场.">
    参数 输入X <类型 = CV矩阵类 注释 = "x分量的输入数组,与参数 输入Y 具有相同尺寸.">
    参数 输入Y <类型 = CV矩阵类 注释 = "y分量的输入数组,与参数 输入X 具有相同尺寸.">
    参数 输出方向场 <类型 = CV矩阵类 注释 = "输出方向场矩阵">
    参数 是否为十进制度 <类型 = 逻辑型 注释 = "为真时使用十进制度,否则使用弧度制." @默认值 = 假>
    {
        @ cv::phase(@<输入X>.obj, @<输入Y>.obj, @<输出方向场>.obj, @<是否为十进制度>);
    }

    方法 计算向量幅值 <公开 静态 注释 = "magnitude">
    参数 输入X <类型 = CV矩阵类 注释 = "表示矢量的浮点型X坐标值,也表示复数中的实部.">
    参数 输入Y <类型 = CV矩阵类 注释 = "表示矢量的浮点型Y坐标值,也表示复数中的虚部.">
    参数 输出幅值 <类型 = CV矩阵类 注释 = "输出的幅值,同第一个参数x有着同样的尺寸和类型.">
    {
        @ cv::magnitude(@<输入X>.obj, @<输入Y>.obj, @<输出幅值>.obj);
    }

    方法 检查矩阵无效值 <公开 静态 注释 = "checkRange,检查每个数组元素既不是NaN也不是infinite.">
    参数 输入向量 <类型 = CV矩阵类 注释 = "欲检查的矩阵向量">
    参数 是否静默输出 <类型 = 逻辑型 注释 = "为真时静默输出" @默认值 = 真>
    参数 输出坐标点 <类型 = CV坐标点 注释 = "输出有问题的点坐标">
    参数 排除下限值 <类型 = 小数 注释 = "欲排除的数值下限" @默认值 = -1.79769e+308>
    参数 排除上限值 <类型 = 小数 注释 = "欲排除的数值上限" @默认值 = 1.79769e+308>
    {
        @ cv::checkRange(@<输入向量>.obj, @<是否静默输出>, (cv::Point *)(& @<输出坐标点>.obj), @<排除下限值>, @<排除上限值>);
    }

    方法 将Nan转换到指定值 <公开 静态 注释 = "patchNaNs,即将缺失值转换为指定的值.">
    参数 欲处理向量 <类型 = CV矩阵类>
    参数 值 <类型 = 小数>
    {
        @ cv::patchNaNs(@<欲处理向量>.obj, @<值>);
    }

    方法 广义矩阵乘法 <公开 静态 注释 = "gemm">
    参数 源矩阵1 <类型 = CV矩阵类>
    参数 源矩阵2 <类型 = CV矩阵类>
    参数 alpha <类型 = 小数 注释 = "源矩阵1*源矩阵2*alpha">
    参数 源矩阵3 <类型 = CV矩阵类 注释 = "第三个可选的delta矩阵加到矩阵乘积上;它的类型应该与 源矩阵1  和 源矩阵2  相同">
    参数 beta <类型 = 小数 注释 = "源矩阵3*beta">
    参数 输出矩阵 <类型 = CV矩阵类>
    参数 转置 <类型 = CV广义矩阵乘法标志常量 注释 = "默认不对源矩阵做转置" @默认值 = CV广义矩阵乘法标志常量.不转置任何源>
    {
        @ cv::gemm(@<源矩阵1>.obj, @<源矩阵2>.obj, @<alpha>, @<源矩阵3>.obj, @<beta>, @<输出矩阵>.obj, @<转置>);
    }

    方法 求矩阵乘积及其转置矩阵 <公开 静态 注释 = "mulTransposed" 注释 = "该函数用于计算协方差矩阵." 注释 = "当B= a时,它可以作为一般矩阵乘积a \\*B的一个更快的替代品.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "计算结果输出矩阵">
    参数 乘法顺序 <类型 = 逻辑型 注释 = "如果 乘法顺序=true" 注释 = "{输出矩阵} = {缩放因子} ( {源矩阵} - {减数矩阵} )^T ( {源矩阵} - {减数矩阵} )" 注释 = "如果 乘法顺序=false"
            注释 = "{输出矩阵} = {缩放因子} ( {源矩阵} - {减数矩阵} ) ( {源矩阵} - {减数矩阵} )^T">
    参数 减数矩阵 <类型 = CV矩阵类 注释 = "乘法前从  源矩阵  中减去的可选增量矩阵,可空." @默认值 = 空对象>
    参数 缩放因子 <类型 = 小数 注释 = "计算后对元素作缩放,默认为1不改变元素值." @默认值 = 1.0>
    参数 数值类型 <类型 = CV数值类型 注释 = "为不指定时保持不变" @默认值 = CV数值类型.不指定>
    {
        如果 (减数矩阵 == 空对象)
        {
            变量 空矩阵 <类型 = CV矩阵类>
            减数矩阵 = 空矩阵
        }
        @ cv::mulTransposed(@<源矩阵>.obj, @<输出矩阵>.obj, @<乘法顺序>, @<减数矩阵>.obj, @<缩放因子>, @<数值类型>);
    }

    方法 转置矩阵 <公开 静态 注释 = "transpose" 注释 = " {输出矩阵} (i,j) =  {源矩阵} (j,i)">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲转置的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "转置后的结果矩阵">
    {
        @ cv::transpose(@<源矩阵>.obj ,@<输出矩阵>.obj);
    }

    方法 变换矩阵每个元素 <公开 静态 注释 = "transform,计算任意线性图像变换" 注释 = "当 输入M矩阵.宽=源矩阵.通道数 ：" 注释 = "{输出矩阵} =  {输入M矩阵} cdot {源矩阵}" 注释 = ""
            注释 = "当 输入M矩阵.宽=源矩阵.通道数+1 ：" 注释 = "{输出矩阵}=  {输入M矩阵} cdot {源矩阵}" 注释 = ""
            注释 = "N通道数组src的每个元素都被解释为N个元素的向量,使用M × N或M × (N+1)矩阵M变换到" 注释 = "m元素向量-输出数组dst的对应元素.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲作变换的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "变换后的矩阵">
    参数 输入M矩阵 <类型 = CV矩阵类 注释 = "变换2x2或2x3浮点矩阵" 注释 = "行数必须与  源矩阵  的通道数相同,或者为通道数加一,"
            注释 = "在第二种情况下,源矩阵 中的通道空间向量将自动扩展1维,并将扩展元素赋值1.0.">
    {
        @ cv::transform(@<源矩阵>.obj ,@<输出矩阵>.obj,@<输入M矩阵>.obj);
    }

    方法 透视变换矩阵向量 <公开 静态 注释 = "perspectiveTransform,对向量作透视变换" 注释 = "该函数对二维或三维向量的稀疏集合进行变换. 如果您想要使用透视图转换来转换图像,请使用warpPerspective."
            注释 = "如果您有一个相反的问题,也就是说,您想要计算几个对应点对中最有可能的透视变换,您可以使用  获取投影变换矩阵 .">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲作变换的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "透视变换后的矩阵">
    参数 输入M矩阵 <类型 = CV矩阵类 注释 = "变换2x2或2x3浮点矩阵的变换矩阵" 注释 = "行数必须与  源矩阵  的通道数相同,或者为通道数加一,"
            注释 = "在第二种情况下,源矩阵 中的通道空间向量将自动扩展1维,并将扩展元素赋值1.0.">
    {
        @ cv::perspectiveTransform(@<源矩阵>.obj ,@<输出矩阵>.obj,@<输入M矩阵>.obj);
    }

    方法 矩阵对角复制 <公开 静态 注释 = "completeSymm,其另一个一半. 矩阵对角线保持不变:" 注释 = "_____" 注释 = "|\\     |" 注释 = "|  \\   |" 注释 = "|___\\|"
            注释 = "将矩阵一半的角的元素复制到其对角.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲复制的矩阵,既是输入也是输出,经过对角复制后将改变原矩阵.">
    参数 计算标志 <类型 = 逻辑型 注释 = "如果为真,则将下半部分复制到上半部分. 否则,将上半部分复制到下半部分." @默认值 = 假>
    {
        @ cv::completeSymm(@<输入矩阵>.obj, @<计算标志>);
    }

    方法 初始化缩放标识矩阵 <公开 静态 注释 = "setIdentity" 注释 = "该函数也可以使用矩阵初始化器和矩阵表达式来模拟：" 注释 = "Mat src(CV尺寸类(4, 4), CV_8UC1);"
            注释 = "初始化缩放标识矩阵(src, CV标量(10))" 注释 = "src：" 注释 = "[ 10,   0,   0,   0;" 注释 = "   0,  10,   0,   0;"
            注释 = "   0,   0,  10,   0;" 注释 = "   0,   0,   0,  10].">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "不一定是正方形的">
    参数 标量值 <类型 = CV标量类 注释 = "分配给对角线元素,标量值.B = 1.">
    {
        @ cv::setIdentity(@<输入矩阵>.obj, @<标量值>.obj);
    }

    方法 求矩阵行列式 <公开 静态 类型 = 小数 注释 = "determinant" 注释 = "计算并返回指定矩阵的行列式. 对于小矩阵 ( mtx.cols=mtx.rows\\<=3 ),"
            注释 = "使用直接方法. 对于较大的矩阵,该函数使用带有部分旋转的 LU 分解." 返回值注释 = "返回计算结果" @禁止流程检查 = 真>
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    {
        @ return cv::determinant(@<源矩阵>.obj);
    }

    方法 求矩阵的迹 <公开 静态 类型 = CV标量类 注释 = " trace" 注释 = "返回矩阵 mtx 的对角线元素之和" 返回值注释 = "返回计算结果">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    {
        变量 返回标量 <类型 = CV标量类>
        @ @<返回标量>.obj = cv::trace(@<源矩阵>.obj);
        返回 (返回标量)
    }

    方法 求矩阵的逆 <公开 静态 类型 = 小数 注释 = "invert" 注释 = "求矩阵的逆或伪逆" @禁止流程检查 = 真>
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲计算的矩阵">
    参数 输出逆矩阵 <类型 = CV矩阵类 注释 = "计算的逆矩阵结果">
    参数 计算方式 <类型 = CV矩阵分解常量 注释 = "需要计算矩阵的算法" @默认值 = CV矩阵分解常量.高斯消元法>
    {
        @ return cv::invert(@<源矩阵>.obj, @<输出逆矩阵>.obj, @<计算方式>);
    }

    方法 求解线性系统 <公开 静态 类型 = 逻辑型 注释 = "solve" 注释 = "解决一个或多个线性系统或最小二乘问题.  A*X=B" 返回值注释 = "源矩阵1 不是奇异矩阵(奇异矩阵行列式为0 ,没有逆矩阵)则返回真,否则返回假."
            @禁止流程检查 = 真>
    参数 源矩阵1 <类型 = CV矩阵类 注释 = "线性系统的左侧 A">
    参数 源矩阵2 <类型 = CV矩阵类 注释 = "线性系统的右侧 B">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "解决方案 X">
    参数 计算方式 <类型 = CV矩阵分解常量 注释 = "需要计算矩阵的算法" @默认值 = CV矩阵分解常量.高斯消元法>
    {
        @ return cv::solve(@<源矩阵1>.obj, @<源矩阵2>.obj, @<输出矩阵>.obj, @<计算方式>);
    }

    方法 矩阵排序 <公开 静态 注释 = "sort" 注释 = "对矩阵的每一行或每一列进行排序">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "需要排序的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "排序完成的矩阵">
    参数 排序方式 <类型 = CV排序方法常量 注释 = "使用排序的方法">
    {
        @ cv::sort(@<源矩阵>.obj, @<输出矩阵>.obj, @<排序方式>);
    }

    方法 矩阵排序ID <公开 静态 注释 = "sortIdx" 注释 = "对矩阵的每一行或每一列进行排序,输出的结果矩阵是元素的索引,而不是矩阵本身.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "需要排序的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "包含元素排序后的索引的矩阵">
    参数 排序方式 <类型 = CV排序方法常量 注释 = "使用排序的方法">
    {
        @ cv::sortIdx(@<源矩阵>.obj, @<输出矩阵>.obj, @<排序方式>);
    }

    方法 求三次方程的实根 <公开 静态 注释 = "solveCubic">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "coeffs 方程系数,3 或 4 个元素的数组.">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "根输出具有 1 或 3 个元素的实根数组.">
    {
        @ cv::solveCubic(@<源矩阵>.obj, @<输出矩阵>.obj);
    }

    方法 求多项式方程复根 <公开 静态 类型 = 小数 注释 = "solvePoly,求多项式方程的实根或复根." @禁止流程检查 = 真>
    参数 源矩阵 <类型 = CV矩阵类 注释 = "coeffs 多项式系数数组.">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "根输出(复数)根数组">
    参数 最大迭代次数 <类型 = 整数 注释 = "算法执行的最大迭代次数.">
    {
        @ return cv::solvePoly(@<源矩阵>.obj, @<输出矩阵>.obj, @<最大迭代次数>);
    }

    方法 计算对称矩阵特征 <公开 静态 注释 = "eigen,计算对称矩阵的特征值和特征向量.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "输入矩阵(浮点1通道32位或CV_64FC1类型)">
    参数 特征向量 <类型 = CV矩阵类 注释 = "特征值特征值的输出向量(类型与源矩阵类型相同)">
    参数 向量矩阵 <类型 = CV矩阵类 注释 = "特征向量的特征向量输出矩阵(类型与源矩阵类型相同)">
    {
        @ cv::eigen(@<源矩阵>.obj, @<特征向量>.obj, @<向量矩阵>.obj);
    }

    方法 计算非对称矩阵特征 <公开 静态 注释 = "eigenNonSymmetric,计算非对称矩阵的特征值和特征向量.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "输入矩阵(浮点1通道32位或CV_64FC1类型)">
    参数 特征向量 <类型 = CV矩阵类 注释 = "特征值特征值的输出向量(类型与源矩阵类型相同)">
    参数 向量矩阵 <类型 = CV矩阵类 注释 = "特征向量的特征向量输出矩阵(类型与源矩阵类型相同)">
    {
        @ cv::eigenNonSymmetric(@<源矩阵>.obj, @<特征向量>.obj, @<向量矩阵>.obj);
    }

    方法 计算矩阵协方差矩阵 <公开 静态 注释 = "calcCovarMatrix,计算一组向量的协方差矩阵.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "作为单个矩阵的行/列存储的样本">
    参数 输出协方差矩阵 <类型 = CV矩阵类 注释 = "输出的协方差矩阵,类型为ctype和平方大小.">
    参数 输出均值矩阵 <类型 = CV矩阵类 注释 = "输入或输出(取决于参数4 )数组作为输入向量的平均值">
    参数 计算标志 <类型 = 整数 注释 = "    COVAR_SCRAMBLED = 0,  快速PCA“scrambled\"协方差." 注释 = "    COVAR_NORMAL  = 1,计算均值和协方差."
            注释 = "    COVAR_USE_AVG   = 2,输入均值而不是计算均值." 注释 = "    COVAR_SCALE    = 4, 重新缩放输出的协方差矩阵.  输出均值矩阵    应该是单行向量"
            注释 = "    COVAR_ROWS    = 8,向量由矩阵行组成." 注释 = "    COVAR_COLS      = 16,向量由矩阵列组成.">
    参数 目标数值类型 <类型 = CV数值类型 @默认值 = CV数值类型.CV_64位浮点型>
    {
        @ cv::calcCovarMatrix(@<源矩阵>.obj, @<输出协方差矩阵>.obj, @<输出均值矩阵>.obj, @<计算标志>, @<目标数值类型>);
    }

    方法 计算两向量马氏距离 <公开 静态 注释 = "Mahalanobis,计算两个向量的马氏距离.">
    参数 源矩阵1 <类型 = CV矩阵类 注释 = "欲计算距离的矩阵1">
    参数 源矩阵2 <类型 = CV矩阵类 注释 = "欲计算距离的矩阵2">
    参数 输出协方差矩阵 <类型 = CV矩阵类 注释 = "伊柯瓦尔逆协方差矩阵">
    {
        @ cv::Mahalanobis(@<源矩阵1>.obj, @<源矩阵2>.obj, @<输出协方差矩阵>.obj);
    }

    方法 傅里叶变换 <公开 静态 注释 = "dft,对输入矩阵做傅里叶变换.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲作傅里叶变换的矩阵">
    参数 输出结果 <类型 = CV矩阵类 注释 = "傅里叶变换结果">
    参数 变换类型 <类型 = CV傅里叶变换常量 注释 = "需要使用的傅里叶变换类型">
    参数 处理行数 <类型 = 整数 注释 = "当参数不为0时,函数假设只有输入数组的第一个非零行(没有设置#DFT_INVERSE)或只有输出数组的第一个非零行(设置了#DFT_INVERSE)包含非零,"
            注释 = "因此,函数可以更有效地处理其余行,节省一些时间;该技术对于利用DFT计算阵列的互相关或卷积非常有用." @默认值 = 0>
    {
        @ cv::dft(@<源矩阵>.obj, @<输出结果>.obj, @<变换类型>, @<处理行数>);
    }

    方法 反向傅里叶变换 <公开 静态 注释 = "idft,对输入矩阵做反向傅里叶变换.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "已作傅里叶变换的矩阵">
    参数 输出结果 <类型 = CV矩阵类 注释 = "反向变换结果矩阵">
    参数 变换类型 <类型 = CV傅里叶变换常量 注释 = "需要使用的傅里叶变换类型">
    参数 处理行数 <类型 = 整数 注释 = "当参数不为0时,函数假设只有输入数组的第一个非零行(没有设置#DFT_INVERSE)或只有输出数组的第一个非零行(设置了#DFT_INVERSE)包含非零,"
            注释 = "因此,函数可以更有效地处理其余行,节省一些时间;该技术对于利用DFT计算阵列的互相关或卷积非常有用." @默认值 = 0>
    {
        @ cv::idft(@<源矩阵>.obj, @<输出结果>.obj, @<变换类型>, @<处理行数>);
    }

    方法 离散余弦变换 <公开 静态 注释 = "dct,对一维或二维数组执行正向或反向离散余弦变换.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "必须是16F、32F、64F的浮点型矩阵">
    参数 输出结果 <类型 = CV矩阵类 注释 = "输出类型与原矩阵相同">
    参数 变换类型 <类型 = CV傅里叶变换常量 注释 = "需要使用的傅里叶变换类型">
    {
        @ cv::dct(@<源矩阵>.obj, @<输出结果>.obj, @<变换类型>);
    }

    方法 逆离散余弦变换 <公开 静态 注释 = "idct,对一维或二维数组执行逆离散余弦变换.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "必须是16F、32F、64F的浮点型矩阵">
    参数 输出结果 <类型 = CV矩阵类 注释 = "傅里叶变换结果矩阵,输出类型与原矩阵相同.">
    参数 变换类型 <类型 = CV傅里叶变换常量 注释 = "需要使用的傅里叶变换类型">
    {
        @ cv::idct(@<源矩阵>.obj, @<输出结果>.obj, @<变换类型>);
    }

    方法 傅里叶光谱乘法 <公开 静态 注释 = "mulSpectrums,执行两个傅里叶光谱的每个元素相乘.">
    参数 源矩阵1 <类型 = CV矩阵类 注释 = "已经经过傅里叶变换的矩阵">
    参数 源矩阵2 <类型 = CV矩阵类 注释 = "已经经过傅里叶变换的矩阵">
    参数 输出结果 <类型 = CV矩阵类 注释 = "傅里叶变换结果矩阵">
    参数 变换类型 <类型 = CV傅里叶变换常量 注释 = "需要使用的傅里叶变换类型">
    参数 共轭 <类型 = 逻辑型 注释 = "在乘法运算之前共轭第二个输入数组的可选标志(true)或(false)" @默认值 = 假>
    {
        @ cv::mulSpectrums(@<源矩阵1>.obj, @<源矩阵2>.obj, @<输出结果>.obj, @<变换类型>, @<共轭>);
    }

    方法 获取优化器傅里叶尺寸 <公开 静态 类型 = 整数 注释 = "getOptimalDFTSize,返回给定矢量大小的最佳DFT(傅里叶变换)大小." @禁止流程检查 = 真>
    参数 向量尺寸 <类型 = 整数>
    {
        @ return cv::getOptimalDFTSize(@<向量尺寸>);
    }

    方法 置随机数种子 <公开 静态 注释 = "setRNGSeed,置随机数种子.">
    参数 种子值 <类型 = 整数 注释 = "设置为随机数种子的值">
    {
        @ cv::setRNGSeed(@<种子值>);
    }

    方法 生成随机均匀分布数组 <公开 静态 注释 = "randu,生成一个均匀分布的随机数或随机数数组.">
    参数 欲生成的矩阵 <类型 = CV矩阵类 注释 = "必须先指定行列宽度、通道数">
    参数 最低值 <类型 = CV标量类 注释 = "生成随机数下限">
    参数 最高值 <类型 = CV标量类 注释 = "生成随机数上限">
    {
        @ cv::randu(@<欲生成的矩阵>.obj, @<最低值>.obj, @<最高值>.obj);
    }

    方法 生成随机高斯分布数组 <公开 静态 注释 = "randn,生成一个均匀分布的随机数或随机数数组.">
    参数 欲生成的矩阵 <类型 = CV矩阵类 注释 = "必须先指定行列宽度、通道数">
    参数 最低值 <类型 = CV标量类 注释 = "生成随机数下限">
    参数 最高值 <类型 = CV标量类 注释 = "生成随机数上限">
    {
        @ cv::randn(@<欲生成的矩阵>.obj, @<最低值>.obj, @<最高值>.obj);
    }

    方法 生成随机乱序数组 <公开 静态 注释 = "randShuffle,随机乱序数组元素.">
    参数 欲生成的矩阵 <类型 = CV矩阵类 注释 = "必须为单行或单列的矩阵">
    参数 比例因子 <类型 = 小数 注释 = "交换比例因子,决定随机交换操作的数量." @默认值 = 1.0>
    参数 随机数种子 <类型 = 整数 注释 = "设置为随机数种子的值">
    {
        @ cv::randShuffle(@<欲生成的矩阵>.obj, @<比例因子>, &(cv::RNG(@<随机数种子>)));
    }

    方法 归一化矩阵_掩膜 <公开 静态 注释 = "normalize,对指定范围的元素作归一化处理.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲归一化处理的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "归一化处理后的矩阵">
    参数 alpha <类型 = 小数 注释 = "作用：" 注释 = "1.用来规范值;" 注释 = "2.规范范围,并且是下限." @默认值 = 1>
    参数 beta <类型 = 小数 注释 = "只用来规范范围并且是上限" @默认值 = 0>
    参数 算法 <类型 = CV归一化常量 注释 = "归一化算法" @默认值 = CV归一化常量.L2归一化>
    参数 通道类型 <类型 = CV矩阵通道类型常量 注释 = "指定输出归一化矩阵的通道类型" @默认值 = CV矩阵通道类型常量.不指定>
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时全矩阵处理,否则只处理掩膜区域." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            变量 临时_掩膜 <类型 = CV矩阵类>
            掩膜 = 临时_掩膜
        }
        @ cv::normalize(@<输入矩阵>.obj, @<输出矩阵>.obj, @<alpha>, @<beta>, @<算法>, @<通道类型>, @<掩膜>.obj);
    }

    方法 归一化矩阵 <公开 静态 注释 = "normalize,对矩阵内所有元素作归一化处理.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲归一化处理的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "归一化处理后的矩阵">
    参数 alpha <类型 = 小数 注释 = "归一化目标值,范围归一化中的下边界." @默认值 = 1>
    参数 beta <类型 = 小数 注释 = "范围归一化中的上边界,其他情况无效." @默认值 = 0>
    参数 算法 <类型 = CV归一化常量 注释 = "归一化算法" @默认值 = CV归一化常量.L2归一化>
    参数 期望位深度 <类型 = CV数值类型 注释 = "希望输出的矩阵数值类型,一般不指定." @默认值 = CV数值类型.不指定>
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时全矩阵计算,否则只计算掩膜区域." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            @ cv::normalize(@<输入矩阵>.obj, @<输出矩阵>.obj, @<alpha>, @<beta>, @<算法>, @<期望位深度>);
        }
        否则
        {
            @ cv::normalize(@<输入矩阵>.obj, @<输出矩阵>.obj, @<alpha>, @<beta>, @<算法>, @<期望位深度>, @<掩膜>.obj);
        }
    }

    方法 求矩阵最值 <公开 静态 注释 = "minMaxLoc,适用于二维矩阵.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "必须是单通道矩阵">
    参数 输出最小值 <类型 = 变整数 注释 = "小数变量  变量指针">
    参数 输出最大值 <类型 = 变整数 注释 = "小数变量  变量指针">
    参数 最小值坐标 <类型 = 变整数 注释 = "CV坐标点 变量指针">
    参数 最大值坐标 <类型 = 变整数 注释 = "CV坐标点 变量指针">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时全矩阵搜索,否则只搜索掩膜区域." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            @ cv::minMaxLoc(@<输入矩阵>.obj, (double *)@<输出最小值>, (double *)@<输出最大值>, (cv::Point*)@<最小值坐标>, (cv::Point*)@<最大值坐标>);
        }
        否则
        {
            @ cv::minMaxLoc(@<输入矩阵>.obj, (double *)@<输出最小值>, (double *)@<输出最大值>, (cv::Point*)@<最小值坐标>, (cv::Point*)@<最大值坐标>, @<掩膜>.obj);
        }
    }

    方法 求矩阵最值ID <公开 静态 注释 = "minMaxIdx,适用于单行或者单列矩阵.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "必须是单通道矩阵">
    参数 输出最小值 <类型 = 变整数 注释 = "小数变量  变量指针">
    参数 输出最大值 <类型 = 变整数 注释 = "小数变量  变量指针">
    参数 最小值索引 <类型 = 变整数 注释 = "整数变量  变量指针">
    参数 最大值索引 <类型 = 变整数 注释 = "整数变量  变量指针">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时全矩阵搜索,否则只搜索掩膜区域." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            变量 临时_掩膜 <类型 = CV矩阵类>
            掩膜 = 临时_掩膜
        }
        @ cv::minMaxIdx(@<输入矩阵>.obj, (double *)@<输出最小值>, (double *)@<输出最大值>,  (int *)@<最小值索引>, (int *)@<最大值索引>,  @<掩膜>.obj);
    }

    方法 简化矩阵到向量 <公开 静态 注释 = "reduce,将矩阵转换到一维的矩阵向量.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲简化的矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "由于火山不支持泛型,需要手动再转换到向量.">
    参数 维度 <类型 = 整数 注释 = "矩阵减少的维度索引.  0 表示矩阵缩减为单行.  1 表示矩阵缩减为单列. -1表示自动指定">
    参数 简化方法 <类型 = CV矩阵简化常量 注释 = "需要采样的简化方法">
    参数 通道类型 <类型 = CV矩阵通道类型常量 注释 = "不指定时,通道保持与源矩阵相同." @默认值 = CV矩阵通道类型常量.不指定>
    {
        @ cv::reduce(@<源矩阵>.obj, @<输出矩阵>.obj, @<维度>, @<简化方法>, @<通道类型>);
    }

    方法 合并矩阵 <公开 静态 注释 = "merge,和合并通道相同,不同的是,这里的输入是矩阵数组,原型是Mat* .">
    参数 输入多维矩阵 <类型 = 变整数 注释 = "用   CV矩阵类.取矩阵指针() 获取指针传入该参数">
    参数 合并个数 <类型 = 整数 注释 = "需要指定矩阵数组中包含的矩阵个数">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "合并后的矩阵">
    {
        @ cv::merge((cv::Mat*)&@<输入多维矩阵>,@<合并个数>,@<输出矩阵>.obj);
    }

    方法 合并矩阵数组 <公开 静态 注释 = "merge,从多个矩阵合并为一个矩阵.">
    参数 输入矩阵容器 <类型 = CV矩阵类容器 注释 = "需要合并的矩阵容器">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "合并后的矩阵">
    {
        @ cv::merge(@<输入矩阵容器>.obj, @<输出矩阵>.obj);
    }

    方法 复制到指定通道 <公开 静态 注释 = "mixChannels,将输入数组中的指定通道复制到输出数组的指定通道.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "会从该矩阵复制出数据">
    参数 输出结果矩阵 <类型 = CV矩阵类 注释 = "输出结果">
    参数 欲复制到的通道 <类型 = CV整数容器 注释 = "指定复制哪些通道以及复制到哪里的索引对数组">
    {
        @ cv::mixChannels(@<源矩阵>.obj, @<输出结果矩阵>.obj , @<欲复制到的通道>.obj);
    }

    方法 取矩阵指定通道矩阵 <公开 静态 注释 = "extractChannel,从多通道矩阵中取出一个通道的矩阵.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "多通道矩阵">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "单通道矩阵">
    参数 通道索引 <类型 = 整数 注释 = "需要取出的通道索引">
    {
        @ cv::extractChannel(@<源矩阵>.obj, @<输出矩阵>.obj , @<通道索引>);
    }

    方法 插入矩阵通道 <公开 静态 注释 = "insertChannel,将一个单通道矩阵插入另一个矩阵的通道中.">
    参数 用于插入的矩阵 <类型 = CV矩阵类 注释 = "输入,必须是单通道矩阵">
    参数 被插入的矩阵 <类型 = CV矩阵类 注释 = "参数1的矩阵将插入到该矩阵中,输入输出">
    参数 通道索引 <类型 = 整数 注释 = "需要插入的通道索引">
    {
        @ cv::insertChannel(@<用于插入的矩阵>.obj, @<被插入的矩阵>.obj , @<通道索引>);
    }

    方法 交换矩阵 <公开 静态 注释 = "swap,将两个矩阵交换">
    参数 源矩阵1 <类型 = CV矩阵类>
    参数 源矩阵2 <类型 = CV矩阵类>
    {
        @ cv::swap(@<源矩阵1>.obj, @<源矩阵2>.obj );
    }

    方法 KMeans聚类 <公开 静态 注释 = "kmeans,常用的邻近值聚类算法.">
    参数 输入聚类数据 <类型 = CV矩阵类 注释 = "Data用于聚类的数据. 需要一个具有浮点坐标的n维点数组" 注释 = "Mat points(count, 2, 32位浮点型).">
    参数 聚类个数 <类型 = 整数 注释 = "分割聚类的个数,也就是簇的概念.">
    参数 输出标签 <类型 = CV矩阵类 注释 = "含有标签的矩阵,表名数据所在的簇.">
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "欲使用的迭代算法">
    参数 尝试次数 <类型 = 整数 注释 = "attempts标志用于指定使用不同的初始标记执行算法的次数." @默认值 = 3>
    参数 计算方法 <类型 = CVKMean算法常量 @默认值 = CVKMean算法常量.指定中心点>
    参数 输出中心坐标 <类型 = CV矩阵类 注释 = "簇中心的输出矩阵,每个簇中心一行.">
    {
        @ cv::kmeans(@<输入聚类数据>.obj, @<聚类个数>, @<输出标签>.obj, @<迭代算法>.obj, @<尝试次数>, @<计算方法>, @<输出中心坐标>.obj);
    }

    方法 目标跟踪_CamShift <公开 静态 类型 = CV自由矩形类 注释 = "CamShift,基于颜色的跟踪算法.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "当前跟踪图像">
    参数 输出矩形 <类型 = CV矩形类 注释 = "既为输入前一帧的目标框,也为输出当前帧的目标框.">
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "欲使用的迭代算法">
    {
        变量 返回矩形 <类型 = CV自由矩形类>
        @ @<返回矩形>.obj = cv::CamShift(@<输入图像>.obj, @<输出矩形>.obj, @<迭代算法>.obj);
        返回 (返回矩形)
    }

    方法 目标跟踪_meanShift <公开 静态 类型 = 整数 注释 = "meanShift,使用均值平移算法跟踪目标." @禁止流程检查 = 真>
    参数 输入图像 <类型 = CV矩阵类 注释 = "需要检测目标的图像">
    参数 目标矩形 <类型 = CV矩形类 注释 = "既为输入前一帧的目标框,也为输出当前帧的目标框.">
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "包含迭代次数、迭代算法方式的标志">
    {
        @ return cv::meanShift(@<输入图像>.obj, @<目标矩形>.obj, @<迭代算法>.obj);
    }

    方法 构建光流金字塔 <公开 静态 类型 = 整数 注释 = "buildOpticalFlowPyramid,构建一个光流金字塔." 返回值注释 = "返回层级" 编辑时信息 = "F6266, 0, 0, 0" @禁止流程检查 = 真>
    参数 输入图像 <类型 = CV矩阵类 注释 = "作为第一帧基准流追踪" 编辑时信息 = "F6266, 0, 0, 0">
    参数 输出金字塔 <类型 = CV矩阵类容器 注释 = "包含光流金字塔信息的矩阵容器" 编辑时信息 = "F6266, 0, 0, 0">
    参数 光流窗口大小 <类型 = CV尺寸类 注释 = "光流窗口大小  光流算法的窗口大小. 必须不小于 计算光流 的  光流窗口大小  参数." 注释 = "它需要计算所需的填充金字塔的水平" 编辑时信息 = "F6266, 0, 0, 0">
    参数 最大层级 <类型 = 整数 编辑时信息 = "F6266, 0, 0, 0">
    参数 设置梯度 <类型 = 逻辑型 注释 = "设置为预计算每个金字塔层次的梯度." 注释 = "如果金字塔没有梯度,那么  计算光流  将在内部计算它们." 编辑时信息 = "F6266, 0, 0, 0" @默认值 = 真>
    参数 金字塔边缘类型 <类型 = CV边缘类型 编辑时信息 = "F6266, 0, 0, 0" @默认值 = CV边缘类型.以边界为对称轴反射复制像素>
    参数 渐变边缘类型 <类型 = CV边缘类型 编辑时信息 = "F6266, 0, 0, 0" @默认值 = CV边缘类型.不变>
    参数 是否捕获ROI <类型 = 逻辑型 注释 = "如果为true ,将输入图像的ROI放入金字塔中.  你可以传递false  强制数据拷贝." 编辑时信息 = "F6266, 0, 0, 0" @默认值 = 真>
    {
        @ return cv::buildOpticalFlowPyramid(@<输入图像>.obj, @<输出金字塔>.obj, @<光流窗口大小>.obj, @<最大层级>, @<设置梯度>, @<金字塔边缘类型>, @<渐变边缘类型>, @<是否捕获ROI>);
    }

    方法 计算光流 <公开 静态 注释 = "calcOpticalFlowPyrLK,计算两幅图像的光流.">
    参数 前一帧图像 <类型 = CV矩阵类 注释 = "以该图片为基准流追踪">
    参数 后一帧图像 <类型 = CV矩阵类 注释 = "用来获得追踪结果的图片">
    参数 基准光流 <类型 = CV坐标2f容器 注释 = "以该数组点为基准就行流追踪,单位单精度浮点数.">
    参数 输出光流 <类型 = CV坐标2f容器 注释 = "当 光流算法 为 使用初始光流 时,必须与原 基准点数组 具有相同的大小.">
    参数 输出特征状态 <类型 = CV整数容器 注释 = "找到时其值为1,否则为0.">
    参数 输出特征误差 <类型 = CV单精度小数容器 注释 = "向量的每个元素都设置为对应特征的误差,误差度量的类型可以在 flags 参数中设置；" 注释 = " 如果未找到流,则未定义错误(使用 status 参数查找此类情况).">
    参数 光流窗口大小 <类型 = CV尺寸类 注释 = "计算时滑动光流窗口的大小">
    参数 最大层级 <类型 = 整数 @默认值 = 3>
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "原型函数默认为 CV迭代算法标志类.构建(COUNT+TEPS, 30, 0.01).">
    参数 光流算法 <类型 = CV光流金字塔算法常量 @默认值 = CV光流金字塔算法常量.默认的>
    参数 最小特征 <类型 = 小数 注释 = "计算一个 2x2 光流方程法线矩阵的最小特征值" @默认值 = 1e-4>
    {
        @ return cv::calcOpticalFlowPyrLK(@<前一帧图像>.obj, @<后一帧图像>.obj, @<基准光流>.obj, @<输出光流>.obj, @<输出特征状态>.obj, @<输出特征误差>.obj, @<光流窗口大小>.obj, @<最大层级>, @<迭代算法>.obj, @<光流算法>, @<最小特征>);
    }

    方法 计算稠密光流 <公开 静态 注释 = "calcOpticalFlowFarneback,计算矩阵所有光流所以慢.">
    参数 前一帧图像 <类型 = CV矩阵类 注释 = "以该图片为基准流追踪">
    参数 后一帧图像 <类型 = CV矩阵类 注释 = "用来获得追踪结果的图片">
    参数 输出光流 <类型 = CV坐标2f容器 注释 = "本质就是坐标点">
    参数 金字塔尺度关系 <类型 = 小数 注释 = "pyr_scale 参数,指定图像比例(\\<1)为每个图像构建金字塔；" 注释 = "pyr_scale=0.5 表示经典金字塔,其中下一层比上一层小两倍.">
    参数 金字塔层级 <类型 = 整数 注释 = "金字塔采样层级,层级越高特征越少,速度越快.">
    参数 光流窗口大小 <类型 = 整数 注释 = "计算时滑动光流窗口的大小">
    参数 迭代次数 <类型 = 整数 注释 = "指定计算迭代次数">
    参数 poly_n <类型 = 整数 注释 = "poly_n大小的像素邻域用于在每个像素中找到多项式展开" 注释 = "像素领域大小,一般为5,7等.">
    参数 poly_sigma <类型 = 小数 注释 = "高斯标准差,一般为1-1.5.">
    参数 光流算法 <类型 = CV光流金字塔算法常量 注释 = "需要使用的光流算法">
    {
        @ cv::calcOpticalFlowFarneback(@<前一帧图像>.obj, @<后一帧图像>.obj, @<输出光流>.obj, @<金字塔尺度关系>, @<金字塔层级>, @<光流窗口大小>, @<迭代次数>, @<poly_n>, @<poly_sigma>, @<光流算法>);
    }

    方法 预估点集最佳仿射变换 <公开 静态 类型 = CV矩阵类 注释 = "estimateRigidTransform,计算两个二维点集之间的最佳仿射变换.">
    参数 输入点集1 <类型 = CV矩阵类 注释 = "向量转成矩阵">
    参数 输入点集2 <类型 = CV矩阵类 注释 = "向量转成矩阵">
    参数 全仿射变换 <类型 = 逻辑型 注释 = "为真时 全仿射变换,为假时带有约束的仿射变换" @默认值 = 真>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::estimateRigidTransform(@<输入点集1>.obj, @<输入点集2>.obj, @<全仿射变换>);
        返回 (返回矩阵)
    }

    方法 计算两图像增强相关系数 <公开 静态 类型 = 小数 注释 = "computeECC" @禁止流程检查 = 真>
    参数 输入模板图像 <类型 = CV矩阵类 注释 = "只能为单通道CV_8U or 32位浮点型">
    参数 输入比度图像 <类型 = CV矩阵类 注释 = "需要比对的图像,与 输入模板图像 类型相同.">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时全图对比,否则只对比掩膜区域." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            变量 临时_矩阵 <类型 = CV矩阵类>
            掩膜 = 临时_矩阵
        }
        @ return computeECC(@<输入模板图像>.obj, @<输入比度图像>.obj, @<掩膜>.obj);
    }

    方法 ECC对齐运动图像 <公开 静态 类型 = 小数 注释 = "findTransformECC,根据ECC准则计算两幅图像之间的几何变换(翘曲)." @禁止流程检查 = 真>
    参数 输入模板图像 <类型 = CV矩阵类 注释 = "只能为单通道CV_8U or 32位浮点型">
    参数 输入比度图像 <类型 = CV矩阵类 注释 = "需要比对的图像,与 输入模板图像 类型相同.">
    参数 输出仿射变换矩阵 <类型 = CV矩阵类 注释 = "矩阵维度必须与参数 仿射变换类型 对应,应该先创建再输入.">
    参数 仿射变换类型 <类型 = CV仿射变换常量类>
    参数 算法标志 <类型 = CV迭代算法标志类 注释 = "包含迭代次数、迭代算法类型的标志">
    参数 输入掩膜 <类型 = CV矩阵类 @默认值 = 空对象>
    参数 高斯滤波核尺寸 <类型 = 整数 注释 = "-1时不使用高斯滤波,必须为奇数." @默认值 = -1>
    {
        如果 (输入掩膜 == 空对象)
        {
            变量 临时_矩阵 <类型 = CV矩阵类>
            输入掩膜 = 临时_矩阵
        }
        @ if(@<高斯滤波核尺寸>==-1){return findTransformECC(@<输入模板图像>.obj, @<输入比度图像>.obj, @<输出仿射变换矩阵>.obj, @<仿射变换类型>, @<算法标志>.obj, @<输入掩膜>.obj); }
        @ else{return findTransformECC(@<输入模板图像>.obj, @<输入比度图像>.obj, @<输出仿射变换矩阵>.obj, @<仿射变换类型>, @<算法标志>.obj, @<输入掩膜>.obj, @<高斯滤波核尺寸>);}
    }

    方法 读入光流文件 <公开 静态 类型 = CV矩阵类 注释 = "readOpticalFlow">
    参数 文件路径 <类型 = 文本型 注释 = "后缀 .flo">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @an<CVolMem> memBuf1;
        @ @<返回矩阵>.obj = readOpticalFlow(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
        返回 (返回矩阵)
    }

    方法 写出光流文件 <公开 静态 注释 = "writeOpticalFlow">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存的路径">
    参数 欲保存的光流矩阵 <类型 = CV矩阵类 注释 = "欲保存的光流矩阵">
    {
        @ @an<CVolMem> memBuf1;
        @ writeOpticalFlow(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL), @<欲保存的光流矩阵>.obj);
    }

    方法 绘制关键点 <公开 静态 注释 = "drawKeypoints,与 画标记点 相似.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制的图像">
    参数 关键点 <类型 = CV关键点容器类 注释 = "欲绘制到图像的关键点">
    参数 输出图像 <类型 = CV矩阵类 注释 = "输出绘制的结果">
    参数 绘制颜色 <类型 = CV标量类 注释 = "关键点的颜色">
    参数 绘制类型 <类型 = CV绘制匹配标志常量类 注释 = "绘制的关键点类型" @默认值 = CV绘制匹配标志常量类.默认>
    {
        @ if(@<绘制类型>==0)
        @     drawKeypoints(@<源图像>.obj, @<关键点>.obj, @<输出图像>.obj, @<绘制颜色>.obj, cv::DrawMatchesFlags::DEFAULT);
        @ else if(@<绘制类型>==1)
        @     drawKeypoints(@<源图像>.obj, @<关键点>.obj, @<输出图像>.obj, @<绘制颜色>.obj, cv::DrawMatchesFlags::DRAW_OVER_OUTIMG);
        @ else if(@<绘制类型>==2)
        @     drawKeypoints(@<源图像>.obj, @<关键点>.obj, @<输出图像>.obj, @<绘制颜色>.obj, cv::DrawMatchesFlags::NOT_DRAW_SINGLE_POINTS);
        @ else if(@<绘制类型>==4)
        @     drawKeypoints(@<源图像>.obj, @<关键点>.obj, @<输出图像>.obj, @<绘制颜色>.obj, cv::DrawMatchesFlags::DRAW_RICH_KEYPOINTS);
    }

    方法 匹配关键点_GMS <公开 静态 注释 = "matchGMS,基于网格形变的匹配,由于GMS在特性数量较大时工作良好,我们建议使用ORB特性并将 快速阈值 设置为0以快速获得尽可能多的特性.">
    参数 图像1尺寸 <类型 = CV尺寸类>
    参数 图像2尺寸 <类型 = CV尺寸类>
    参数 关键点1 <类型 = CV关键点容器类>
    参数 关键点2 <类型 = CV关键点容器类>
    参数 输入邻近描述符 <类型 = CV关键点描述符容器类>
    参数 输出GMS描述符 <类型 = CV关键点描述符容器类>
    参数 考虑旋转 <类型 = 逻辑型 注释 = "考虑网格的旋转" @默认值 = 假>
    参数 考虑缩放 <类型 = 逻辑型 注释 = "考虑网格的缩放" @默认值 = 假>
    参数 阈值 <类型 = 小数 @默认值 = 6.0>
    {
        @ cv::xfeatures2d::matchGMS(@<图像1尺寸>.obj, @<图像2尺寸>.obj, @<关键点1>.obj, @<关键点2>.obj, @<输入邻近描述符>.obj, @<输出GMS描述符>.obj, @<考虑旋转>, @<考虑缩放>, @<阈值>);
    }

    方法 匹配关键点_LOGOS <公开 静态 注释 = "matchLOGOS, Logo(高离群值空间验证的局部几何支持)特征匹配策略.">
    参数 关键点1 <类型 = CV关键点容器类>
    参数 关键点2 <类型 = CV关键点容器类>
    参数 描述符质心1 <类型 = CV整数容器 注释 = "image1每个描述符最近的BoW质心索引">
    参数 描述符质心2 <类型 = CV整数容器 注释 = "image2每个描述符最近的BoW质心索引">
    参数 输出描述符 <类型 = CV关键点描述符容器类 注释 = "关键点1与关键点2的相关性描述符">
    {
        @ cv::xfeatures2d::matchLOGOS(@<关键点1>.obj, @<关键点2>.obj, @<描述符质心1>.obj, @<描述符质心2>.obj, @<输出描述符>.obj);
    }

    方法 绘制描述符相关性 <公开 静态 注释 = "drawMatches,将两幅图像的关键点用线连接起来.">
    参数 图像1 <类型 = CV矩阵类>
    参数 关键点容器1 <类型 = CV关键点容器类 注释 = "在图像1 中的关键点">
    参数 图像2 <类型 = CV矩阵类>
    参数 关键点容器2 <类型 = CV关键点容器类 注释 = "在图像2 中的关键点">
    参数 描述符容器 <类型 = CV关键点描述符容器类 注释 = "关键点1与关键点2的相关性描述符">
    参数 输出图像 <类型 = CV矩阵类 注释 = "图像1 与 图像2 横向拼接并绘制了相连接的关键点的图像">
    {
        @ drawMatches(@<图像1>.obj, @<关键点容器1>.obj, @<图像2>.obj, @<关键点容器2>.obj, @<描述符容器>.obj, @<输出图像>.obj,Scalar::all(-1),Scalar::all(-1),std::vector<char>(), DrawMatchesFlags::DEFAULT);
    }

    方法 旋转矩阵_自由角度 <公开 静态 类型 = CV矩阵类 注释 = "自定义函数,使用仿射变换旋转图像(矩阵).">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲旋转的矩阵(图像)">
    参数 旋转角度 <类型 = 小数 注释 = "十进制度">
    参数 是否改变尺寸 <类型 = 逻辑型 注释 = "为真时改变输出矩阵的尺寸,否则保持原始尺寸(超出边界的部分图像被裁剪)." @默认值 = 假>
    {
        变量 返回结果 <类型 = CV矩阵类>
        变量 中心点 <类型 = CV坐标点2f>
        变量 变换矩阵 <类型 = CV矩阵类>
        变量 变换后宽 <类型 = 小数>
        变量 变换后高 <类型 = 小数>
        变量 画布矩阵 <类型 = CV矩阵类>
        变量 ROI <类型 = CV矩形类>
        变量 横向偏移 <类型 = 小数>
        变量 纵向偏移 <类型 = 小数>
        如果 (是否改变尺寸 == 真)
        {
            变量 绝对值角度 <类型 = 小数>
            如果 (旋转角度 > 360)
            {
                旋转角度 = (小数)((整数)旋转角度 % 360) + 旋转角度 - (小数)取整 (旋转角度)
            }
            如果 (旋转角度 > 0 && 旋转角度 < 90)
            {
                绝对值角度 = 旋转角度
            }
            如果 (旋转角度 <= 0 && 旋转角度 >= -90)
            {
                绝对值角度 = 旋转角度 * -1
            }
            如果 (旋转角度 >= 90 && 旋转角度 <= 180)
            {
                绝对值角度 = 180 - 旋转角度
            }
            如果 (旋转角度 <= -90 && 旋转角度 >= -180)
            {
                绝对值角度 = -(180 + 旋转角度)
            }
            如果 (旋转角度 >= 180 && 旋转角度 <= 270)
            {
                绝对值角度 = 旋转角度 - 180
            }
            如果 (旋转角度 > 270 && 旋转角度 <= 360)
            {
                绝对值角度 = 360 - 旋转角度
            }
            如果 (旋转角度 < -180 && 旋转角度 >= -270)
            {
                绝对值角度 = -(旋转角度 + 180)
            }
            如果 (旋转角度 < -270 && 旋转角度 >= -360)
            {
                绝对值角度 = 360 + 旋转角度
            }
            变换后宽 = (小数)绝对取整 (求余弦 (角度到弧度 (绝对值角度)) * (小数)源矩阵.宽度) + (小数)绝对取整 (求正弦 (角度到弧度 (绝对值角度)) * (小数)源矩阵.高度)
            变换后高 = (小数)绝对取整 (求正弦 (角度到弧度 (绝对值角度)) * (小数)源矩阵.宽度) + (小数)绝对取整 (求余弦 (角度到弧度 (绝对值角度)) * (小数)源矩阵.高度)
            中心点.置坐标位置 ((小数)源矩阵.宽度 / 2, (小数)源矩阵.高度 / 2)
            变换矩阵 = CV核心.获取旋转变换矩阵 (中心点, 旋转角度, 1)
            横向偏移 = (变换后宽 - (小数)源矩阵.宽度) / 2 + 变换矩阵.取元素值一通道1d (0, 2)
            纵向偏移 = (变换后高 - (小数)源矩阵.高度) / 2 + 变换矩阵.取元素值一通道1d (1, 2)
            变换矩阵.置元素值一通道1d (0, 2, 横向偏移)
            变换矩阵.置元素值一通道1d (1, 2, 纵向偏移)
        }
        否则
        {
            中心点.置坐标位置 ((小数)源矩阵.宽度 / 2, (小数)源矩阵.高度 / 2)
            变换后宽 = 源矩阵.宽度
            变换后高 = 源矩阵.高度
            变换矩阵 = CV核心.获取旋转变换矩阵 (中心点, 旋转角度, 1)
        }
        CV核心.仿射变换 (源矩阵, 返回结果, 变换矩阵, CV尺寸类.创建尺寸 ((整数)变换后宽, (整数)变换后高), , CV边缘类型.不变, CV标量类.新建三通道 (0, 0, 0))
        返回 (返回结果)
    }

    方法 模板匹配 <公开 静态 注释 = "matchTemplate,只找和模板一样角度的目标.">
    参数 源图像 <类型 = CV矩阵类 注释 = "必须是8位通道灰度图">
    参数 模板图像 <类型 = CV矩阵类 注释 = "必须是8位通道灰度图">
    参数 匹配结果 <类型 = CV矩阵类 注释 = "32F类型,该结果尺寸与原图相同,每个元素就是得分值" 注释 = "其宽度为 源图像.宽度-模板图像.宽度,高度与宽度计算方法类似,"
            注释 = "矩阵的每个元素值就是匹配度,其坐标是目标的矩形框左上角," 注释 = "不同的匹配方法判断匹配度的方法不同,请查看  CV模板匹配方法常量类  的说明.">
    参数 模板匹配方法 <类型 = CV模板匹配方法常量类 注释 = "不同的匹配方法判断匹配度的方法不同" @默认值 = CV模板匹配方法常量类.标准归一化系数相关性>
    参数 掩膜 <类型 = CV矩阵类 @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            @ cv::matchTemplate(@<源图像>.obj, @<模板图像>.obj, @<匹配结果>.obj, @<模板匹配方法>);
        }
        否则
        {
            @ cv::matchTemplate(@<源图像>.obj, @<模板图像>.obj, @<匹配结果>.obj, @<模板匹配方法>, @<掩膜>.obj);
        }
    }

    方法 模板匹配多目标 <公开 静态 类型 = CV矩形类容器 注释 = "自定义函数,函数  模板匹配   的简化版." 返回值注释 = "返回包含目标位置的矩形容器">
    参数 源图像 <类型 = CV矩阵类 注释 = "待寻找目标的图像">
    参数 模板图像 <类型 = CV矩阵类 注释 = "欲寻找的目标模板">
    参数 匹配结果 <类型 = CV矩阵类 注释 = "32F类型,每个元素就是得分值." 注释 = "其宽度为 源图像.宽度-模板图像.宽度,高度与宽度计算方法类似," 注释 = "矩阵的每个元素值就是匹配度,其坐标是目标的矩形框左上角,"
            注释 = "不同的匹配方法判断匹配度的方法不同,请查看  CV模板匹配方法常量类  的说明.">
    参数 最小置信度 <类型 = 小数 注释 = "0-1.0" @默认值 = 0.8>
    参数 模板匹配方法 <类型 = CV模板匹配方法常量类 注释 = "推荐 归一化相关性、标准归一化系数相关性 匹配方法" @默认值 = CV模板匹配方法常量类.归一化相关性>
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时对全图搜索,否则只搜索掩膜范围内的图像." @默认值 = 空对象>
    参数 输出置信度 <类型 = CV小数容器 注释 = "存储匹配结果的置信度">
    {
        变量 返回容器 <类型 = CV矩形类容器>
        如果 (掩膜 == 空对象)
        {
            @ cv::matchTemplate(@<源图像>.obj, @<模板图像>.obj, @<匹配结果>.obj, @<模板匹配方法>);
        }
        否则
        {
            @ cv::matchTemplate(@<源图像>.obj, @<模板图像>.obj, @<匹配结果>.obj, @<模板匹配方法>, @<掩膜>.obj);
        }
        变量 阈值 <类型 = 小数>
        变量 最小值 <类型 = 小数>
        变量 最大值 <类型 = 小数>
        变量 最小值坐标 <类型 = CV坐标点>
        变量 最大值坐标 <类型 = CV坐标点>
        变量 row <类型 = 整数>
        变量 col <类型 = 整数>
        变量 w <类型 = 整数>
        变量 h <类型 = 整数>
        CV核心.求矩阵最值 (匹配结果, 取变量地址 (最小值), 取变量地址 (最大值), 最小值坐标.取坐标指针 (), 最大值坐标.取坐标指针 ())
        w = 模板图像.宽度
        h = 模板图像.高度
        如果 (模板匹配方法 == CV模板匹配方法常量类.平方差 || 模板匹配方法 == CV模板匹配方法常量类.归一化平方差)
        {
            阈值 = 最大值 - 最大值 * 最小置信度
        }
        否则
        {
            阈值 = 最大值 * 最小置信度
        }
        // 根据结果矩阵处理结果
        计次循环 (源图像.高度 - h)
        {
            row = 取循环索引 ()
            如果 (row == 0)
            {
                到循环尾
            }
            计次循环 (源图像.宽度 - w)
            {
                col = 取循环索引 ()
                如果 (col == 0)
                {
                    到循环尾
                }
                变量 临时_置信度 <类型 = 小数>
                临时_置信度 = 匹配结果.取元素值一通道1f (row, col)
                如果 (模板匹配方法 == CV模板匹配方法常量类.平方差 || 模板匹配方法 == CV模板匹配方法常量类.归一化平方差)
                {
                    如果 (临时_置信度 > 阈值)
                    {
                        到循环尾
                    }
                    如果 (匹配结果.取元素值一通道1f (row - 1, col) > 临时_置信度 && 匹配结果.取元素值一通道1f (row - 1, col - 1) > 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col - 1) > 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col + 1) > 临时_置信度 && 匹配结果.取元素值一通道1f (row - 1, col + 1) > 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col) > 临时_置信度 && 匹配结果.取元素值一通道1f (row, col - 1) > 临时_置信度 && 匹配结果.取元素值一通道1f (row, col + 1) > 临时_置信度)
                    {
                        变量 临时_矩形 <类型 = CV矩形类>
                        临时_矩形 = CV矩形类.创建矩形 (col, row, w, h)
                        返回容器.加入成员 (临时_矩形)
                        输出置信度.加入成员 (1 - 临时_置信度 / 最大值)
                    }
                    到循环尾
                }
                否则
                {
                    如果 (临时_置信度 < 阈值)
                    {
                        到循环尾
                    }

                }
                // 使用3*3的邻域抑制结果
                如果 (匹配结果.取元素值一通道1f (row - 1, col) < 临时_置信度 && 匹配结果.取元素值一通道1f (row - 1, col - 1) < 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col - 1) < 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col + 1) < 临时_置信度 && 匹配结果.取元素值一通道1f (row - 1, col + 1) < 临时_置信度 && 匹配结果.取元素值一通道1f (row + 1, col) < 临时_置信度 && 匹配结果.取元素值一通道1f (row, col - 1) < 临时_置信度 && 匹配结果.取元素值一通道1f (row, col + 1) < 临时_置信度)
                {
                    变量 临时_矩形 <类型 = CV矩形类>
                    临时_矩形 = CV矩形类.创建矩形 (col, row, w, h)
                    返回容器.加入成员 (临时_矩形)
                    输出置信度.加入成员 (临时_置信度)
                }
            }
        }
        返回 (返回容器)
    }

    方法 候选框分组1 <公开 静态 注释 = "groupRectangles,对候选的矩形框分组.">
    参数 矩形容器 <类型 = CV矩形类容器 注释 = "既是输入,也是输出.">
    参数 阈值 <类型 = 整数 注释 = "值为可能的最小矩形数减1. 在一组矩形中使用阈值来保留它">
    参数 相对差值 <类型 = 小数 注释 = "将矩形合并为一组时,矩形两边的相对差值." @默认值 = 0.2>
    {
        @ cv::groupRectangles(@<矩形容器>.obj, @<阈值>, @<相对差值>);
    }

    方法 候选框分组2 <公开 静态 注释 = "groupRectangles,对候选的矩形框分组.">
    参数 矩形容器 <类型 = CV矩形类容器 注释 = "既是输入,也是输出.">
    参数 输出权重 <类型 = CV整数容器>
    参数 阈值 <类型 = 整数 注释 = "值为可能的最小矩形数减1. 在一组矩形中使用阈值来保留它">
    参数 相对差值 <类型 = 小数 注释 = "将矩形合并为一组时,矩形两边的相对差值." @默认值 = 0.2>
    {
        @ cv::groupRectangles(@<矩形容器>.obj, @<输出权重>.obj, @<阈值>, @<相对差值>);
    }

    方法 候选框分组3 <公开 静态 注释 = "groupRectangles,对候选的矩形框分组.">
    参数 矩形容器 <类型 = CV矩形类容器 注释 = "既是输入,也是输出.">
    参数 阈值 <类型 = 整数 注释 = "值为可能的最小矩形数减1. 在一组矩形中使用阈值来保留它">
    参数 相对差值 <类型 = 小数 注释 = "将矩形合并为一组时,矩形两边的相对差值." @默认值 = 0.2>
    参数 输出权重 <类型 = CV整数容器>
    参数 输出权重等级 <类型 = CV小数容器>
    {
        @ cv::groupRectangles(@<矩形容器>.obj, @<阈值>, @<相对差值>, &@<输出权重>.obj, &@<输出权重等级>.obj);
    }

    方法 候选框分组_meanshift <公开 静态 注释 = "groupRectangles_meanshift,对候选的矩形框分组meanshift算法.">
    参数 矩形容器 <类型 = CV矩形类容器 注释 = "既是输入,也是输出.">
    参数 输入权重 <类型 = CV小数容器>
    参数 输入缩放尺度 <类型 = CV小数容器>
    参数 输出权重 <类型 = 小数>
    参数 检测窗口尺寸 <类型 = CV尺寸类 注释 = "如果为空时,尺寸为 64, 128." @默认值 = 空对象>
    {
        变量 尺寸 <类型 = CV尺寸类>
        如果 (检测窗口尺寸 == 空对象)
        {
            尺寸.宽度 = 64
            尺寸.高度 = 128
        }
        否则
        {
            尺寸 = 检测窗口尺寸
        }
        @ cv::groupRectangles_meanshift(@<矩形容器>.obj, @<输入权重>.obj, @<输入缩放尺度>.obj, @<输出权重>, @<尺寸>.obj);
    }

    方法 设置CV窗口回调函数 <公开 静态 注释 = "cvSetMouseCallback,设置CV窗口的回调事件.">
    参数 窗口名称 <类型 = 文本型 注释 = "需要操作的窗口名称">
    参数 函数指针 <类型 = 变整数 注释 = "函数格式 void on_Mouse(int event, int x, int y, int flags, void* param).">
    参数 参数指针 <类型 = 变整数 @默认值 = 0>
    {
        @ @an<CVolMem> memBuf1;
        @ cv::setMouseCallback(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL), (MouseCallback)@<函数指针>, (void*)@<参数指针>);
    }

    方法 获取窗口显示矩形 <公开 静态 类型 = CV矩形类 注释 = "getWindowImageRect,返回客户端窗口坐标、图像渲染区域的宽度和高度.">
    参数 窗口名称 <类型 = 文本型 注释 = "需要操作的窗口名称">
