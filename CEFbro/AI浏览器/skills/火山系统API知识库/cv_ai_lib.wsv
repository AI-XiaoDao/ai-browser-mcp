类 DNN文本识别模型 <公开 基础类 = DNN模型类 注释 = "TextRecognitionModel,简化的目文本识别模型,支持CNN\\RNN\\CRNN.">
{

    # @ <include>
    # @ inline_ void @an<_OnCleanupExtra>() { if (obj != nullptr) { delete (cv::dnn::TextRecognitionModel*)obj; obj = nullptr; } }
    # @ </include>

    方法 创建模型从文件 <公开 注释 = "从支持的网络格式的文件创建一个网络模型">
    参数 模型权重文件 <类型 = 文本型 注释 = "包含网络各层权重的文件">
    参数 网络设置文件 <类型 = 文本型 注释 = "包含网络层设置描述的文件,有的模型不需要该文件所以为空." @默认值 = "">
    {
        @ if (obj != nullptr) delete (cv::dnn::TextRecognitionModel*)obj;
        @ @an<CVolMem> memBuf1,memBuf2;
        @ obj =new cv::dnn::TextRecognitionModel(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<网络设置文件>.GetText (), memBuf2, NULL));
    }

    方法 创建模型从NET <公开 注释 = "从NET类中创建目标检测网络">
    参数 输入网络 <类型 = NET网络类 注释 = "需要从其中创建目标检测网络的NET">
    {
        @ if (obj != nullptr) delete (cv::dnn::TextRecognitionModel*)obj;
        @ obj =new cv::dnn::TextRecognitionModel(@<输入网络>.obj);
    }

    方法 置解码类型 <公开 注释 = "setDecodeType,设置文本识别的网络解码方法.">
    参数 解码类型 <类型 = 文本型 注释 = "" 注释 = "1.\"CTC-greedy\",基于CTC方法输出的贪婪解码." 注释 = "2.\"CTC-prefix-beam-search\",基于CTC方法输出的前缀波束搜索解码."
            @默认值 = "CTC-greedy">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ static_cast<cv::dnn::TextRecognitionModel*>(obj)->setDecodeType(GetMbsText (@<解码类型>.GetText (),memBuf1, NULL));
    }

    方法 取解码类型 <公开 类型 = 文本型 注释 = "getDecodeType,设置文本识别的网络解码方法." 返回值注释 = "返回类型:" 返回值注释 = "1.\"CTC-greedy\",基于CTC方法输出的贪婪解码."
            返回值注释 = "2.\"CTC-prefix-beam-search\",基于CTC方法输出的前缀波束搜索解码." @禁止流程检查 = 真>
    {
        @ if(obj == nullptr) return "";
        @ return static_cast<cv::dnn::TextRecognitionModel*>(obj)->getDecodeType().c_str();
    }

    方法 设置CTC前缀波束搜索参数 <公开 注释 = "setDecodeOptsCTCPrefixBeamSearch,如果  置解码类型  为\"CTC-prefix-beam-search\","
            注释 = "则可以用该函数设置其相关优化参数.">
    参数 波束尺寸 <类型 = 整数>
    参数 优化搜索尺寸 <类型 = 整数 注释 = "默认为0,不做修建优化,在每个搜索步骤中仅使用顶部  优化搜索尺寸 标记" @默认值 = 0>
    {
        @ if(obj == nullptr) return;
        @ static_cast<cv::dnn::TextRecognitionModel*>(obj)->setDecodeOptsCTCPrefixBeamSearch(@<波束尺寸>, @<优化搜索尺寸>);
    }

    方法 置词汇表 <公开 注释 = "setVocabulary,设置文本识别的词汇表">
    参数 词汇表路径 <类型 = 文本型 注释 = "每行一个类别名称的文本文件">
    {
        @ if(obj == nullptr) return;
        @ std::ifstream vocFile;
        @ @an<CVolMem> memBuf1;
        @ vocFile.open(samples::findFile(GetMbsText (@<词汇表路径>.GetText (),memBuf1, NULL)));
        @ CV_Assert(vocFile.is_open());
        @ String vocLine;
        @ std::vector<String> vocabulary;
        @ while (std::getline(vocFile, vocLine)) { vocabulary.push_back(vocLine);}
        @ static_cast<cv::dnn::TextRecognitionModel*>(obj)->setVocabulary(vocabulary);
    }

    方法 获取词汇表 <公开 类型 = CV文本容器 注释 = "getVocabulary,获取文本识别的词汇表">
    {
        变量 词汇表 <类型 = CV文本容器>
        @ if(obj != nullptr)
        @     @<词汇表>.obj = static_cast<cv::dnn::TextRecognitionModel*>(obj)->getVocabulary();
        返回 (词汇表)
    }

    方法 识别单行文本 <公开 类型 = 文本型 注释 = "recognize,对输入的图像(只包含了一行文本的图像)做识别" 返回值注释 = "返回识别结果" @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲识别的图像">
    {
        @ if(obj == nullptr) return "";
        @ return static_cast<cv::dnn::TextRecognitionModel*>(obj)->recognize(@<源图像>.obj).c_str();
    }

    方法 识别多行文本 <公开 注释 = "recognize,对输入的图像(只包含了多行文本的图像)做识别">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲识别的图像">
    参数 ROI列表 <类型 = CV坐标容器数组 注释 = "使用 DNN文本检测模型 检测到的结果">
    参数 输出识别结果 <类型 = CV文本容器 注释 = "返回识别结果">
    {
        @ if(obj == nullptr) return;
        @  static_cast<cv::dnn::TextRecognitionModel*>(obj)->recognize(@<源图像>.obj, @<ROI列表>.obj, @<输出识别结果>.obj);
    }
}

