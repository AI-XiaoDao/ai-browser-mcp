        @ obj.height = (float)@<高度>;
    }

    方法 X <公开 属性读 类型 = 小数 注释 = "左上角横坐标" @禁止流程检查 = 真>
    {
        @ return obj.x;
    }

    方法 X <公开 属性写 注释 = "左上角横坐标">
    参数 X坐标 <类型 = 小数>
    {
        @ obj.x = (float)@<X坐标>;
    }

    方法 Y <公开 属性读 类型 = 小数 注释 = "左上角纵坐标" @禁止流程检查 = 真>
    {
        @ return obj.y;
    }

    方法 Y <公开 属性写 注释 = "左上角纵坐标">
    参数 Y坐标 <类型 = 小数>
    {
        @ obj.y =(float)@<Y坐标>;
    }

    方法 宽度 <公开 属性读 类型 = 小数 @禁止流程检查 = 真>
    {
        @ return obj.width;
    }

    方法 宽度 <公开 属性写>
    参数 宽 <类型 = 小数>
    {
        @ obj.width =(float)@<宽>;
    }

    方法 高度 <公开 属性读 类型 = 小数 @禁止流程检查 = 真>
    {
        @ return obj.height;
    }

    方法 高度 <公开 属性写>
    参数 高 <类型 = 小数>
    {
        @ obj.height =(float)@<高>;
    }
}

类 CV插值方式常量 <公开 @常量类 = 整数>
{
    常量 邻近值插值 <公开 值 = 0 注释 = "0,INTER_NEAREST,邻近值插值.">
    常量 双线性插值 <公开 值 = 1 注释 = "1,INTER_LINEAR,双线性插值.">
    常量 三次方插值 <公开 值 = 2 注释 = "2,INTER_CUBIC,三次方插值.">
    常量 重采样插值 <公开 值 = 3 注释 = "3,INTER_AREA,重采样插值.">
    常量 Lanczos插值 <公开 值 = 4 注释 = "4,INTER_LANCZOS4,Lanczos插值.">
    常量 精确双线性插值 <公开 值 = 5 注释 = "5,INTER_LINEAR_EXACT,精确双线性插值.">
    常量 掩码插值 <公开 值 = 7 注释 = "7,INTER_MAX,掩码插值.">
    常量 填充插值 <公开 值 = 8 注释 = "8,WARP_FILL_OUTLIERS,填充插值,异常点被设置为0.">
    常量 逆变矩阵插值 <公开 值 = 16 注释 = "16,WARP_INVERSE_MAP,逆变矩阵插值.">
}

类 CV尺寸类 <公开 注释 = "Szie,宽高属性值均为整数.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Size obj;
    # <> </include>
    # @end

    方法 取尺寸指针 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return  (INT_P)&obj;
    }

    方法 创建尺寸 <公开 静态 类型 = CV尺寸类>
    参数 宽 <类型 = 整数>
    参数 高 <类型 = 整数>
    {
        变量 返回尺寸 <类型 = CV尺寸类>
        @ @<返回尺寸>.obj = cv::Size(@<宽>, @<高>);
        返回 (返回尺寸)
    }

    方法 置尺寸整数 <公开>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ obj.height = @<高度>;
        @ obj.width = @<高度>;
    }

    方法 置尺寸小数 <公开>
    参数 宽度 <类型 = 小数>
    参数 高度 <类型 = 小数>
    {
        @ obj.height = (int)@<高度>;
        @ obj.width = (int)@<高度>;
    }

    方法 宽度 <公开 属性读 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return obj.width;
    }

    方法 宽度 <公开 属性写>
    参数 宽 <类型 = 整数>
    {
        @ obj.width = @<宽>;
    }

    方法 高度 <公开 属性读 类型 = 整数 @禁止流程检查 = 真>
    {
        @ return obj.height;
    }

    方法 高度 <公开 属性写>
    参数 高 <类型 = 整数>
    {
        @ obj.height = @<高>;
    }

    方法 新建尺寸 <公开 静态 类型 = CV尺寸类 注释 = "返回一个空尺寸">
    {
        变量 返回尺寸 <类型 = CV尺寸类>
        @ @<返回尺寸>.obj = cv::Size();
        返回 (返回尺寸)
    }
}

