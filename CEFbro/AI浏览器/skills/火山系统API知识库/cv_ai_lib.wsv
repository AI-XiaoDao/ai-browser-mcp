        @ try{@<返回网络>.obj = cv::dnn::readNet( GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL), GetMbsText (@<网络设置文件>.GetText (), memBuf2, NULL), GetMbsText (@<网络格式>.GetText (), memBuf3, NULL)); }
        @ catch(const cv::Exception& ex){throw CVolException (ex.code, (@dt<文本型>)ex.what());}
        返回 (返回网络)
    }

