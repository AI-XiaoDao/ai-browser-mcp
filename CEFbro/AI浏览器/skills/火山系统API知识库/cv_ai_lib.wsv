类 CV数值类型 <公开 注释 = "S = 符号整型 U = 无符号整型 F = 浮点型" @常量类 = 整数>
{
    常量 不指定 <公开 值 = -1 注释 = "-1,默认或不改变.">
    常量 无符号8位整数 <公开 值 = 0 注释 = "0,CV_8U,范围0-255.">
    常量 有符号8位整数 <公开 值 = 1 注释 = "1,CV_8S,范围-128~127.">
    常量 无符号16位整数 <公开 值 = 2 注释 = "2,CV_16U,范围0-65535.">
    常量 有符号16位整数 <公开 值 = 3 注释 = "3,CV_16S,范围-32768~32767.">
    常量 有符号32位整数 <公开 值 = 4 注释 = "4,CV_32S,范围-2147483648~2147483647.">
    常量 CV_32位浮点型 <公开 值 = 5 注释 = "5,CV_32F,32位浮点型.">
    常量 CV_64位浮点型 <公开 值 = 6 注释 = "6,CV_64F,64位浮点型.">
    常量 CV_16位浮点型 <公开 值 = 7 注释 = "7,CV_16F,16位浮点型.">
}

