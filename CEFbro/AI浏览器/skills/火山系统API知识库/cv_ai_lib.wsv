    {
        @ obj.trainIdx = @<值>;
    }

    方法 图像索引 <公开 属性读 类型 = 整数 注释 = "imgIdx" @禁止流程检查 = 真>
    {
        @ return obj.imgIdx;
    }

    方法 图像索引 <公开 属性写 注释 = "imgIdx">
    参数 值 <类型 = 整数>
    {
        @ obj.imgIdx = @<值>;
    }

    方法 距离 <公开 属性读 类型 = 小数 注释 = "distance" @禁止流程检查 = 真>
    {
        @ return obj.distance;
    }

