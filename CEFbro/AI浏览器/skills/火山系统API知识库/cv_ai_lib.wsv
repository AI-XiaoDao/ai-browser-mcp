类 CV关键点描述符类 <公开 注释 = "DMatch">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::DMatch obj;
    # <> </include>
    # @end

    方法 初始化关键点描述符1 <公开>
    参数 查询索引 <类型 = 整数>
    参数 训练索引 <类型 = 整数>
    参数 距离 <类型 = 小数>
    {
        @ obj = cv::DMatch(@<查询索引>, @<训练索引>, (float)@<距离>);
    }

    方法 初始化关键点描述符2 <公开>
    参数 查询索引 <类型 = 整数>
    参数 训练索引 <类型 = 整数>
    参数 图像索引 <类型 = 整数>
    参数 距离 <类型 = 小数>
    {
        @ obj = cv::DMatch(@<查询索引>, @<训练索引>, @<图像索引>, (float)@<距离>);
    }

    方法 查询索引 <公开 属性读 类型 = 整数 注释 = "queryIdx" @禁止流程检查 = 真>
    {
        @ return obj.queryIdx;
    }

