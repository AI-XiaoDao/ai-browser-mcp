    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件" 编辑时信息 = "2CEC2, 0, 0, 0">
    {
        @ @an<CVolMem> memBuf1;
        @ obj = cv::ml::ANN_MLP::load(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL));
    }

    方法 保存模型 <公开 注释 = "save,保存模型到文件.">
    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->save(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL));
    }

    方法 设置训练算法 <公开 注释 = "setTrainMethod">
    参数 算法类型 <类型 = 整数 注释 = "算法参数值如下:" 注释 = "BACKPROP=0 误差反向传播算法" 注释 = "RPROP = 1      弹性反向传播算法" 注释 = "ANNEAL = 2   模拟退火算法">
    参数 参数1 <类型 = 小数 注释 = "对于 RPROP 传递给 设置弹性反向传播算法DW0值." 注释 = "对于 BACKPROP 传递给 设置误差反向传播权重." 注释 = "对于 ANNEAL 传递给 设置退火算法初始温度."
            @默认值 = 0>
    参数 参数2 <类型 = 小数 注释 = "对于 RPROP 传递给 设置弹性反向传播算法最小DW." 注释 = "对于 BACKPROP 传递给 设置误差反向传播动量." 注释 = "对于 ANNEAL 传递给 设置退火算法初始温度."
            @默认值 = 0>
    {
        @ if(obj == nullptr) return;
        @ obj->setTrainMethod(@<算法类型>, @<参数1>, @<参数2>);
    }

    方法 获取训练算法 <公开 类型 = 整数 注释 = "getTrainMethod" 返回值注释 = "算法参数值如下:" 返回值注释 = "BACKPROP=0 误差反向传播算法"
            返回值注释 = "RPROP = 1      弹性反向传播算法" 返回值注释 = "ANNEAL = 2   模拟退火算法" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getTrainMethod();
    }

    方法 设置激活函数 <公开 注释 = "setActivationFunction">
    参数 激活函数类型 <类型 = 整数 注释 = "        IDENTITY = 0,对称函数激活方法."
            注释 = "        SIGMOID_SYM = 1,如果您使用默认的sigmoid激活函数和默认的参数值fparam1=0和fparam2=0,那么使用的函数是y = 1.7159\\*tanh(2/3 \\* x),因此输出范围将从[-1.7159,1.7159]而不是[0,1]."
            注释 = "        GAUSSIAN = 2, 高斯分布激活方法." 注释 = "        RELU = 3,  RELU激活方法." 注释 = "        LEAKYRELU= 4.">
    参数 参数1 <类型 = 小数>
    参数 参数2 <类型 = 小数>
    {
        @ if(obj == nullptr) return;
        @ obj->setActivationFunction(@<激活函数类型>, @<参数1>, @<参数2>);
    }

    方法 设置神经元个数 <公开 注释 = "setLayerSizes">
    参数 神经元个数 <类型 = 整数 注释 = "每层感知机的神经元个数">
    {
        @ if(obj == nullptr) return;
        @ obj->setLayerSizes(@<神经元个数>);
    }

    方法 获取神经元个数 <公开 类型 = CV矩阵类 注释 = "setLayerSizes" 返回值注释 = "每层感知机的神经元个数">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getLayerSizes();
        返回 (返回矩阵)
    }

    方法 获取算法迭代标志 <公开 类型 = CV迭代算法标志类 注释 = "getTermCriteria">
    {
        变量 返回标志 <类型 = CV迭代算法标志类>
        @ if(obj !=nullptr)
        @     @<返回标志>.obj = obj->getTermCriteria();
        返回 (返回标志)
    }

    方法 设置算法迭代标志 <公开 注释 = "setTermCriteria,模型类型为C_SVC问题中的可选权重,分配给特定的类.">
    参数 算法标志 <类型 = CV迭代算法标志类>
    {
        @ if(obj == nullptr) return;
        @ obj->setTermCriteria(@<算法标志>.obj);
    }

    方法 获取误差反向传播权重 <公开 类型 = 小数 注释 = "getBackpropWeightScale" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getBackpropWeightScale();
    }

    方法 设置误差反向传播权重 <公开 注释 = "setBackpropWeightScale">
    参数 值 <类型 = 小数>
    {
        @ if(obj == nullptr) return;
        @ obj->setBackpropWeightScale(@<值>);
    }

    方法 获取误差反向传播动量 <公开 类型 = 小数 注释 = "getBackpropMomentumScale" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getBackpropMomentumScale();
    }

    方法 设置误差反向传播动量 <公开 注释 = "setBackpropMomentumScale">
    参数 值 <类型 = 小数 注释 = "动量项的强度(前两次迭代的权重之差). 该参数提供了一些惯性来平滑权重的随机波动. 它可以从 0(该功能被禁用)到 1 及以上不等. 值 0.1 左右就足够了.">
    {
        @ if(obj == nullptr) return;
        @ obj->setBackpropMomentumScale(@<值>);
    }

    方法 获取弹性反向传播算法DW0值 <公开 类型 = 小数 注释 = "getRpropDW0" @禁止流程检查 = 真>
