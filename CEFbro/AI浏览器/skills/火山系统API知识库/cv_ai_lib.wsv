    # inline_ void @an<_OnCleanupExtra>() { if (obj != nullptr) delete obj; }
    # <> </include>
    # @end

    方法 创建VGG16年龄分类器 <公开>
    参数 模型权重文件 <类型 = 文本型 注释 = "onnx格式模型文件">
    参数 线程数 <类型 = 整数 注释 = "一般设置为1个线程,并不是线程越多速度越快,需要多次试验调试获取最佳速度." @默认值 = 1>
    {
        @ if (obj!=nullptr) delete obj;
        @ @an<CVolMem> memBuf1;
        @ obj = new lite::onnxruntime::cv::face::attr::VGG16Age(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL),@<线程数>);
    }

    方法 预测图像 <公开 注释 = "对输入的图像作推理">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲检测的人脸图像,可以用人脸检测器检测得到.">
