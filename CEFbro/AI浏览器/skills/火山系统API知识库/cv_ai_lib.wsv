        @ if (obj != nullptr) delete obj;
        @ @an<CVolMem> memBuf1;
        @ obj = new lite::cv::face::detect::UltraFace(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL),@<线程数>);
    }

    方法 预测图像 <公开 注释 = "对输入图像进行目标检测">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 最小置信度 <类型 = 小数 注释 = "0≤最小置信度≤1,大于等于 最小置信度  的目标被保留." @默认值 = 0.25>
    参数 IOU阈值 <类型 = 小数 注释 = "0≤最小置信度≤1,即非极大值抑制的阈值," 注释 = "当多个检测框重复选择目标时可以抑制多余的检测框." @默认值 = 0.45>
    参数 目标最多个数 <类型 = 整数 注释 = "即TopK算法系数,如已确定最多、最少目标个数时,可以将参数" 注释 = " “抑制方法” 的值设置为 1,混合TopK算法抑制目标." @默认值 = 100>
    参数 抑制方法 <类型 = 整数 注释 = "当抑制方法为以下值时:" 注释 = "0：严格的抑制方法." 注释 = "1：混合 目标最多个数 的抑制方法,此时要指定参数  目标最多个数." 注释 = "2：偏移度量抑制方法." @默认值 = 2>
    参数 输出AI目标检测框容器 <类型 = AI目标检测框容器类 注释 = "返回找到的目标检测框数组(容器)">
    {
        @ if(obj == nullptr) return;
        @ obj->detect(@<输入图像>.obj, @<输出AI目标检测框容器>.obj, (float)@<最小置信度>, (float)@<IOU阈值>, @<目标最多个数>, @<抑制方法>);
    }
}

