类 CV特征检测ORB <公开 注释 = "ORB特征检测类">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<ORB> obj;
    # <> </include>
    # @end

    方法 检测图像1 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "输出结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 检测并计算相关性 <公开 注释 = "detectAndCompute,检测图像并匹配描述符特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域,可以用新建对象(CV矩阵类)创建空掩膜.">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "当参数 不输出关键点  为假时输出">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点的相关性矩阵">
    参数 不输出关键点 <类型 = 逻辑型 注释 = "为假时输出参数 输出关键点容器" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->detectAndCompute(@<源图像>.obj, @<掩膜>.obj, @<输出关键点容器>.obj, @<输出相关性>.obj, @<不输出关键点>);
    }

    方法 检测图像2 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类数组 注释 = "输出结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 创建 <公开 注释 = "create,创建一个特征检测器.">
    参数 保留数量 <类型 = 整数 注释 = "保留最佳特性的数量" @默认值 = 0>
    参数 金字塔采样比例 <类型 = 小数 注释 = "==2表示经典金字塔,每一个下一关的像素比前一关少4倍,但如此大的比例因素将显著降低特征匹配分数." @默认值 = 1.2>
    参数 金字塔层级 <类型 = 整数 注释 = "每个金字塔层级中的层数.  3 是 D. Lowe 论文中使用的值. 金字塔层级的数量是根据图像分辨率自动计算的" @默认值 = 8>
    参数 边缘阈值 <类型 = 整数 注释 = "用于过滤出边缘特征的阈值" @默认值 = 31>
    参数 第一个层级 <类型 = 整数 注释 = "放置源图像的金字塔的级别" @默认值 = 0>
    参数 元素数量 <类型 = 整数 注释 = "生成面向BRIEF描述符的每个元素的点的数量" @默认值 = 2>
    参数 得分类型 <类型 = 整数 注释 = "HARRIS_SCORE=0" 注释 = "FAST_SCORE=1" @默认值 = 0>
    参数 斑块尺寸 <类型 = 整数 注释 = "面向BRIEF描述符使用的补丁大小" @默认值 = 31>
    参数 快速阈值 <类型 = 整数 @默认值 = 20>
    {
        @ if(@<得分类型>==0){obj = cv::ORB::create(@<保留数量>,(float)@<金字塔采样比例>,@<金字塔层级>,@<边缘阈值>,@<第一个层级>,@<元素数量>,cv::ORB::ScoreType::HARRIS_SCORE,@<斑块尺寸>,@<快速阈值>);  }
        @ else{obj = cv::ORB::create(@<保留数量>,(float)@<金字塔采样比例>,@<金字塔层级>,@<边缘阈值>,@<第一个层级>,@<元素数量>,cv::ORB::ScoreType::FAST_SCORE,@<斑块尺寸>,@<快速阈值>);}
    }

    方法 匹配描述符1 <公开 注释 = "compute,计算匹配图像与描述符相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类 注释 = "欲计算的关键点容器">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点相关性矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 匹配描述符2 <公开 注释 = "compute,计算匹配图像与描述符相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类数组 注释 = "欲计算的关键点容器数组">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出关键点相关性矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 写出检测器 <公开 注释 = "write,保存检测器到文件.">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存的文件路径">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->write((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 读入检测器 <公开 注释 = "read,从文件读入检测器,读入前先创建.">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->read((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 设置最大保留特征数量 <公开 注释 = "setMaxFeatures">
    参数 值 <类型 = 整数>
    {
        @ if(obj == nullptr) return;
        @ obj->setMaxFeatures(@<值>);
    }

    方法 获取最大保留特征数量 <公开 类型 = 整数 注释 = "getMaxFeatures" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getMaxFeatures();
    }

    方法 设置采样比例 <公开 注释 = "setScaleFactor">
    参数 值 <类型 = 小数>
    {
        @ if(obj == nullptr) return;
