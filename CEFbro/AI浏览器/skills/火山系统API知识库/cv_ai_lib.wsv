    方法 CV整数容器转多维矩阵 <公开 注释 = "自定义函数,将数值容器转换为矩阵.">
    参数 输入容器 <类型 = CV整数容器 注释 = "欲转换的数值容器">
    参数 输入通道数 <类型 = 整数 注释 = "欲转换到的矩阵通道数">
    参数 输入行数 <类型 = 整数 注释 = "欲转换到的矩阵行数">
    {
        @ cv::Mat newMat = cv::Mat(@<输入容器>.obj);
        @ obj = newMat.reshape(@<输入通道数>, @<输入行数>).clone();
    }

