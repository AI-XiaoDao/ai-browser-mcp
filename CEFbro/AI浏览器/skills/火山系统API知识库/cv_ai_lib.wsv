        @ if(obj==nullptr)return -1;
        @ return obj->getFirstLevel();
    }

    方法 设置元素数量 <公开 注释 = "setWTA_K">
    参数 值 <类型 = 整数>
    {
        @ if(obj == nullptr) return;
