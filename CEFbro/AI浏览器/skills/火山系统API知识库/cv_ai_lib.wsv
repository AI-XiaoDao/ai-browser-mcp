类 CV傅里叶变换常量 <公开 注释 = "DftFlags" @常量类 = 整数>
{
    常量 逆变换 <公开 值 = 1 注释 = "1,用一维或者二维逆变矩阵替代正向变换.">
    常量 缩放变换 <公开 值 = 2 注释 = "2,DFT_SCALE,输出结果均乘以缩放因子.">
    常量 行变换 <公开 值 = 4 注释 = "4,DFT_ROWS,对输入矩阵的行作正向或反向变换.">
    常量 复数正向变换 <公开 值 = 16 注释 = "16,DFT_COMPLEX_OUTPUT,对一维或二维实数矩阵作正向变换.">
    常量 实数正向变换 <公开 值 = 32 注释 = "32,DFT_REAL_OUTPUT,对一维或二维复数矩阵作正向变换.">
    常量 DFT_COMPLEX_INPUT <公开 值 = 64 注释 = "64,指定输入矩阵为复数输入.">
    常量 DCT_INVERSE <公开 值 = 1 注释 = "1,执行逆1D或2D变换,而不是默认的正向变换.">
    常量 DCT_ROWS <公开 值 = 4 注释 = "4,对输入的每一行执行正向或反向转换矩阵.">
}

类 CV图像解码常量 <公开 注释 = "ImreadModes,原文件说明为兼容3.x版本CV." @常量类 = 整数>
{
    常量 不改变 <公开 值 = -1 注释 = "-1,CV_LOAD_IMAGE_UNCHANGED,不改变.">
    常量 转灰度 <公开 值 = 0 注释 = "0,CV_LOAD_IMAGE_GRAYSCALE,转灰度.">
    常量 转彩色 <公开 值 = 1 注释 = "1,CV_LOAD_IMAGE_COLOR,转彩色.">
    常量 转任意深度 <公开 值 = 2 注释 = "2,CV_LOAD_IMAGE_ANYDEPTH,转任意深度.">
    常量 转任意颜色通道 <公开 值 = 4 注释 = "4,CV_LOAD_IMAGE_ANYCOLOR,转任意颜色通道.">
    常量 忽略定向 <公开 值 = 128 注释 = "128,CV_LOAD_IMAGE_IGNORE_ORIENTATION,忽略定向.">
}

类 CV图像写出类型常量 <公开 注释 = "ImwriteFlags,原文件说明为兼容3.x版本CV" @常量类 = 整数>
{
    常量 JPEG_图像质量 <公开 值 = 1 注释 = "1,CV_IMWRITE_JPEG_QUALITY,JPG图像质量,从1-100,默认95." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 JPEG_启用特性 <公开 值 = 2 注释 = "2,CV_IMWRITE_JPEG_PROGRESSIVE,启用JPEG特性,0或1,默认为False." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 JPEG_启用优化 <公开 值 = 3 注释 = "3,CV_IMWRITE_JPEG_OPTIMIZE,启用JPEG优化,0或1,默认为False." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 JPEG_重启间隔 <公开 值 = 4 注释 = "4,CV_IMWRITE_JPEG_RST_INTERVAL,JPEG重启间隔,0 - 65535,默认为0 -不重启." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 JPEG_单独亮度质量等级 <公开 值 = 5 注释 = "5,CV_IMWRITE_JPEG_LUMA_QUALITY,单独亮度质量等级,0 - 100,默认为0 -不使用." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 JPEG_分开色度质量等级 <公开 值 = 6 注释 = "6,CV_IMWRITE_JPEG_CHROMA_QUALITY,分开色度质量等级,0 - 100,默认是0 -不使用." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_压缩等级 <公开 值 = 16 注释 = "16,CV_IMWRITE_PNG_COMPRESSION, 对于PNG,可以是0到9的压缩级别. 值越高,文件大小越小,压缩时间越长. 如果指定了,"
            注释 = "则将策略修改为IMWRITE_PNG_STRATEGY_DEFAULT (Z_DEFAULT_STRATEGY). 默认值为1(最佳速度设置)." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_策略 <公开 值 = 17 注释 = "17,CV_IMWRITE_PNG_STRATEGY,cv::ImwritePNGFlags之一,默认为 IMWRITE_PNG_STRATEGY_RLE."
            编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_二进制级别 <公开 值 = 18 注释 = "18,CV_IMWRITE_PNG_BILEVEL,二进制级别PNG, 0或1,默认为0." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_默认策略 <公开 值 = 0 注释 = "0,CV_IMWRITE_PNG_STRATEGY_DEFAULT,对于PPM、PGM或PBM,它可以是二进制格式标志,0或1. 缺省值为1."
            编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_过滤策略 <公开 值 = 1 注释 = "1,CV_IMWRITE_PNG_STRATEGY_FILTERED,将此值用于筛选器(或预测变量)生成的数据. 筛选后的数据主要由具有某种随机分布的小值组成."
            注释 = "在这种情况下,压缩算法经过调整以更好地压缩它们." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_强制霍夫曼编码 <公开 值 = 2 注释 = "2,CV_IMWRITE_PNG_STRATEGY_HUFFMAN_ONLY,使用此值仅强制霍夫曼编码(无字符串匹配)." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_强制距离为1 <公开 值 = 3 注释 = "3,CV_IMWRITE_PNG_STRATEGY_RLE,使用此值可将匹配距离限制为 1(运行长度编码)." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PNG_禁止动态霍夫曼编码 <公开 值 = 4 注释 = "4,CV_IMWRITE_PNG_STRATEGY_FIXED,使用此值可防止使用动态霍夫曼码,从而为特殊应用提供更简单的解码器."
            编辑时信息 = "27FFD, 0, 0, 0">
    常量 二进制格式 <公开 值 = 32 注释 = "32,CV_IMWRITE_PXM_BINARY,对于 PPM、PGM 或 PBM,它可以是二进制格式标志 0 或 1. 默认值为 1." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 EXR_存储类型 <公开 值 = 48 注释 = "48,CV_IMWRITE_EXR_TYPE,覆盖 EXR 存储类型(默认为 FLOAT (FP32) )." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 WEBP_质量 <公开 值 = 64
            注释 = "64,CV_IMWRITE_WEBP_QUALITY,对于 WEBP,它可以是从 1 到 100 的质量(越高越好). 默认情况下(没有任何参数),对于高于 100 的质量,将使用无损压缩."
            编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_元组类型 <公开 值 = 128 注释 = "128,CV_IMWRITE_PAM_TUPLETYPE,对于 PAM,将 TUPLETYPE 字段设置为为格式定义的相应字符串值." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_不指定格式 <公开 值 = 0 注释 = "0,CV_IMWRITE_PAM_FORMAT_NULL,无指定." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_转黑白二值图 <公开 值 = 1 注释 = "1,CV_IMWRITE_PAM_FORMAT_BLACKANDWHITE,黑白二值." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_转灰度图 <公开 值 = 2 注释 = "2,CV_IMWRITE_PAM_FORMAT_GRAYSCALE,转灰度." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_转灰度图带阿尔法通道 <公开 值 = 3 注释 = "3,CV_IMWRITE_PAM_FORMAT_GRAYSCALE_ALPHA,带阿尔法通道灰度图." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_转彩色图 <公开 值 = 4 注释 = "4,CV_IMWRITE_PAM_FORMAT_RGB,RGB彩色图." 编辑时信息 = "27FFD, 0, 0, 0">
    常量 PAM_转彩色图带阿尔法通道 <公开 值 = 5 注释 = "5,CV_IMWRITE_PAM_FORMAT_RGB_ALPHA,RGB+阿尔法通道图." 编辑时信息 = "27FFD, 0, 0, 0">
}

类 CV边缘类型 <公开 注释 = "BorderTypes" @常量类 = 整数>
{
    常量 不变 <公开 值 = 0 注释 = "0,BORDER_CONSTANT,iiiiii|abcdefgh|iiiiiii,需要指定 ’ i ’ 即就是边沿像素用i替换.">
    常量 复制边界像素 <公开 值 = 1 注释 = "1,BORDER_REPLICATE,aaaaaa|abcdefgh|hhhhhhh,复制边界像素.">
    常量 反射复制边界像素 <公开 值 = 2 注释 = "2,BORDER_REFLECT,fedcba|abcdefgh|hgfedcb,反射复制边界像素.">
    常量 用另一边的像素来补偿填充 <公开 值 = 3 注释 = "3,BORDER_WRAP,cdefgh|abcdefgh|abcdefg,用另一边的像素来补偿填充.">
    常量 以边界为对称轴反射复制像素 <公开 值 = 4 注释 = "4,BORDER_REFLECT_101,gfedcb|abcdefgh|gfedcba,以边界为对称轴反射复制像素.">
    常量 边界将以阴影过渡 <公开 值 = 5 注释 = "5,BORDER_TRANSPARENT,uvwxyz|abcdefgh|ijklmno,边界将以阴影过渡.">
    常量 以边界为对称轴反射复制像素1 <公开 值 = 4 注释 = "4,BORDER_REFLECT101,同  以边界为对称轴反射复制像素.">
    常量 默认边缘 <公开 值 = 4 注释 = "4,BORDER_DEFAULT, 同  以边界为对称轴反射复制像素.">
    常量 不计算ROI之外的部分 <公开 值 = 16 注释 = "16,BORDER_ISOLATED,不计算ROI之外的部分.">
}

