    常量 在半对数极空间中映射图像 <公开 值 = 256 注释 = "256,WARP_POLAR_LOG,在半对数极空间中映射图像.">
}

类 CV距离变换常量 <公开 注释 = "DistanceTypes" @常量类 = 整数>
{
    常量 自定义的距离 <公开 值 = -1 注释 = "-1,DIST_USER,自定义的距离.">
    常量 曼哈顿距离 <公开 值 = 1 注释 = "1,DIST_L1,曼哈顿距离,distance = |x1-x2| + |y1-y2|.">
    常量 欧式距离 <公开 值 = 2 注释 = "2,DIST_L2,简易欧几里得距离.">
    常量 棋盘距离 <公开 值 = 3 注释 = "3,DIST_C,distance = max(|x1-x2|,|y1-y2|).">
    常量 合并距离 <公开 值 = 4 注释 = "4,DIST_L12,合并了  曼哈顿距离  欧式距离, L1-L2 metric: distance = 2(sqrt(1+x*x/2) - 1)).">
    常量 等价距离 <公开 值 = 5 注释 = "5,DIST_FAIR,distance = c^2(|x|/c-log(1+|x|/c)), c = 1.3998.">
    常量 韦尔斯距离 <公开 值 = 6 注释 = "6,DIST_WELSCH,distance = c^2/2(1-exp(-(x/c)^2)), c = 2.9846.">
    常量 胡贝尔距离 <公开 值 = 7 注释 = "7,DIST_HUBER,distance = |x|<c ? x^2/2 : c(|x|-c/2), c=1.345.">
}

