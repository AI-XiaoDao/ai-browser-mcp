    参数 C参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.C)">
    参数 GAMMA参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.GAMMA)">
    参数 P参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.P)">
    参数 NU参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.NU)">
    参数 COEF参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.COEF)">
    参数 DEGREE参数表 <类型 = CV参数表类 注释 = "可以用     获取默认参数表(CV支持向量机参数类型.DEGREE)">
    参数 平衡样本 <类型 = 逻辑型 注释 = "为真时,如果问题是2类分类,则该方法创建更平衡的交叉验证子集,子集中的类之间的比例接近于整个训练数据集中的比例." @默认值 = 假>
    {
        @ if(obj==nullptr)return false;
        @ return obj->trainAuto(@<训练数据>.obj, @<样本类型>, @<响应矩阵>.obj, @<交叉验证参数>, @<C参数表>.obj, @<GAMMA参数表>.obj, @<P参数表>.obj, @<NU参数表>.obj, @<COEF参数表>.obj, @<DEGREE参数表>.obj, @<平衡样本>);
    }

    方法 获取所有向量 <公开 类型 = CV矩阵类 注释 = "getSupportVectors,该方法以浮点矩阵的形式返回所有支持向量,其中支持向量存储为矩阵 行.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getSupportVectors();
        返回 (返回矩阵)
    }

    方法 获取未压缩向量 <公开 类型 = CV矩阵类
            注释 = "getUncompressedSupportVectors,该方法返回用于预测的压缩支持向量源自的线性 %SVM 的所有未压缩支持向量. 它们以浮点矩阵的形式返回,其中支持向量存储为矩阵行.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ if(obj !=nullptr)
        @     @<返回矩阵>.obj = obj->getUncompressedSupportVectors();
        返回 (返回矩阵)
    }

    方法 检索决策函数 <公开 注释 = "getDecisionFunction">
    参数 i <类型 = 整数 注释 = "决策函数的索引">
    参数 输出权重 <类型 = CV矩阵类 注释 = "可选的输出向量为权值,对应不同的支持向量. 在线性SVM的情况下,所有的都是1.">
    参数 输出索引 <类型 = CV矩阵类 注释 = "支持向量矩阵中支持向量索引的可选输出向量(可以通过 SVM::getSupportVectors 检索). 在线性 %SVM 的情况下,每个决策函数都由单个“压缩”支持向量组成.">
    {
        @ if(obj == nullptr) return;
        @ obj->getDecisionFunction(@<i>, @<输出权重>.obj, @<输出索引>.obj);
    }

    方法 获取默认参数表 <公开 类型 = CV参数表类 注释 = "getDefaultGridPtr">
    参数 类型 <类型 = CV支持向量机参数类型>
    {
        变量 参数表 <类型 = CV参数表类>
        @ if(obj !=nullptr)
        @     @<参数表>.obj = cv::ml::SVM::getDefaultGridPtr(@<类型>);
        返回 (参数表)
    }
}

类 CVKNN分类器 <公开 注释 = "KNearest,邻近值分类器.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # Ptr<cv::ml::KNearest> obj;
    # <> </include>
    # @end

    方法 获取变量数量 <公开 类型 = 整数 注释 = "getVarCount" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getVarCount();
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty" 返回值注释 = "为空返回真" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return true;
        @ return obj->empty();
    }

    方法 是否已训练 <公开 类型 = 逻辑型 注释 = "isTrained" 返回值注释 = "已训练返回真" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return false;
        @ return obj->isTrained();
    }

    方法 是否为分类器 <公开 类型 = 逻辑型 注释 = "isClassifier" 返回值注释 = "为分类器返回真,为回归模型返回假." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return false;
        @ return obj->isClassifier();
    }

    方法 训练模型_从训练数据 <公开 注释 = "train,使用 CV训练数据类 训练分类器.">
    参数 训练样本 <类型 = CV训练数据类 注释 = "存储了多个训练样本的 CV训练数据类">
    参数 训练标志 <类型 = 整数 注释 = "可选标志,这取决于模型. 控件可以更新一些模型新的训练样本,不完全覆盖." 注释 = "参数值如下:" 注释 = "UPDATE_MODEL = 1,更新模型."
            注释 = "RAW_OUTPUT=1, 使方法返回原始结果,而不是类标签." 注释 = "COMPRESSED_INPUT=2,压缩的输入样本." 注释 = "PREPROCESSED_INPUT=4,预处理的输入样本." @默认值 = 0>
    {
        @ if(obj == nullptr) return;
        @ obj->train(@<训练样本>.obj, @<训练标志>);
    }

    方法 训练模型_从矩阵 <公开 注释 = "train,使用 CV矩阵类 样本训练分类器.">
    参数 训练样本 <类型 = CV矩阵类 注释 = "存储了多个训练样本的矩阵">
    参数 训练类型 <类型 = CV样本类型常量 注释 = "指定是行样本还是列样本" "">
    参数 响应矩阵 <类型 = CV矩阵类 注释 = "放标签一类的矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->train(@<训练样本>.obj, @<训练类型>,@<响应矩阵>.obj);
    }

    方法 获取误差 <公开 注释 = "calcError,该方法使用 预测 来计算误差. 对于回归模型,误差计算为RMS,用于分类器-作为误分类样本的百分比(0%-100%).">
    参数 训练样本 <类型 = CV训练数据类 注释 = "存储了多个训练样本的 CV训练数据类">
    参数 测试子集误差 <类型 = 逻辑型 注释 = "如果为真,则在数据的测试子集上计算误差,否则在数据的训练子集上计算误差. 请注意,如果您加载了一个完全不同的数据集来评估已经训练的分类器,"
            注释 = "您可能根本不希望使用  CV训练数据类.设置训练样本比例    设置测试子集并指定 测试=假,以便为整个新集计算偏差." "">
    参数 输出响应矩阵 <类型 = CV矩阵类>
    {
        @ if(obj == nullptr) return;
        @ obj->calcError(@<训练样本>.obj, @<测试子集误差>, @<输出响应矩阵>.obj);
    }

    方法 预测 <公开 类型 = 小数 注释 = "predict,对输入的矩阵样本做预测." @禁止流程检查 = 真>
    参数 欲预测矩阵 <类型 = CV矩阵类 注释 = "可以是一维的多通道矩阵">
    参数 输出结果 <类型 = CV矩阵类 @默认值 = 空对象>
    参数 标志 <类型 = 整数 @默认值 = 0>
    {
        @ if(obj==nullptr)return -1;
        @ if(@<输出结果>==NULL){return obj->predict(@<欲预测矩阵>.obj, noArray(), @<标志>);}
        @ else{return obj->predict(@<欲预测矩阵>.obj, @<输出结果>.obj, @<标志>);}
    }

    方法 创建模型 <公开 注释 = "create">
    {
        @ obj = cv::ml::KNearest::create();
    }

    方法 载入模型 <公开 注释 = "load,从文件载入模型." 编辑时信息 = "2CEC2, 0, 0, 0">
    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件" 编辑时信息 = "2CEC2, 0, 0, 0">
    {
        @ @an<CVolMem> memBuf1;
        @ obj = cv::ml::KNearest::load(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL));
    }

    方法 保存模型 <公开 注释 = "save,保存模型到文件.">
    参数 权重文件 <类型 = 文本型 注释 = "序列化的文件">
    {
        @ @an<CVolMem> memBuf1;
        @ obj->save(GetMbsText (@<权重文件>.GetText (), memBuf1, NULL));
    }

    方法 获取Emax <公开 类型 = 整数 注释 = "getEmax,获取KDTree实现的参数." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getEmax();
    }

    方法 设置Emax <公开 注释 = "setEmax,设置KDTree实现的参数.">
    参数 值 <类型 = 整数>
    {
        @ if(obj == nullptr) return;
        @ obj->setEmax(@<值>);
    }

    方法 获取算法类型 <公开 类型 = 整数 注释 = "getAlgorithmType" 返回值注释 = "返回值如下:" 返回值注释 = "BRUTE_FORCE=1," 返回值注释 = "KDTREE=2." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getAlgorithmType();
    }

    方法 设置算法类型 <公开 注释 = "setAlgorithmType">
    参数 值 <类型 = 整数 注释 = "设置参数值如下:" 注释 = "BRUTE_FORCE=1," 注释 = "KDTREE=2.">
    {
        @ if(obj == nullptr) return;
        @ obj->setAlgorithmType(@<值>);
    }

    方法 寻找邻近值 <公开 注释 = "findNearest">
    参数 输入被矩阵 <类型 = CV矩阵类 注释 = "按行存储的输入样本. 它是一个单精度浮点矩阵.">
    参数 输入邻近值个数 <类型 = 整数 注释 = "使用的最近邻值个数. 应该大于1.">
    参数 输出预测结果 <类型 = CV矩阵类 注释 = "每个输入的预测结果(回归或分类)向量样本">
    参数 输出邻近值 <类型 = CV矩阵类>
    参数 输出距离 <类型 = CV矩阵类>
    {
        @ if(obj == nullptr) return;
        @ obj->findNearest(@<输入被矩阵>.obj, @<输入邻近值个数>, @<输出邻近值>.obj, @<输出距离>.obj);
    }
}

