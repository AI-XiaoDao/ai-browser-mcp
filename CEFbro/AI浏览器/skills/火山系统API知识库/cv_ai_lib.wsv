        @ obj.minConvexity = (float)@<值>;
    }

    方法 最大凸度 <公开 属性写 注释 = "maxConvexity">
    参数 值 <类型 = 小数 注释 = "0-1.0">
    {
        @ obj.maxConvexity = (float)@<值>;
    }

    方法 分割阈值步长 <公开 属性读 类型 = 小数 注释 = "thresholdStep" @禁止流程检查 = 真>
    {
        @ return obj.thresholdStep;
    }

    方法 最小阈值 <公开 属性读 类型 = 小数 注释 = "minThreshold" @禁止流程检查 = 真>
    {
        @ return obj.minThreshold;
    }

    方法 最大阈值 <公开 属性读 类型 = 小数 注释 = "maxThreshold" @禁止流程检查 = 真>
    {
        @ return obj.maxThreshold;
    }

    方法 最小重复性 <公开 属性读 类型 = 整数 注释 = "minRepeatability" @禁止流程检查 = 真>
    {
        @ return (int)obj.minRepeatability;
