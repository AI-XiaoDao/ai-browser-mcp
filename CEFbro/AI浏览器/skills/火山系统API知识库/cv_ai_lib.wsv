    }
}

类 CV斑点检测类 <公开 注释 = "SimpleBlobDetector,对图像作blob分析,过滤出想要的结果.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<SimpleBlobDetector> obj;
    # <> </include>
    # @end

    方法 创建 <公开 注释 = "create">
    参数 检测参数 <类型 = CV斑点检测参数结构体类 注释 = "包含斑点特征的参数结构体">
    {
        @ obj = cv::SimpleBlobDetector::create(@<检测参数>.obj);
    }

    方法 检测图像1 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "输出检测结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 检测并计算相关性 <公开 注释 = "detectAndCompute,检测图像并关键点特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 掩膜 <类型 = CV矩阵类 注释 = "确定需要检测的范围">
    参数 输出关键点容器 <类型 = CV关键点容器类 注释 = "当参数 不输出关键点  为假时输出">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出特征之间相关性计算值的矩阵">
    参数 不输出关键点 <类型 = 逻辑型 注释 = "为假时输出参数 输出关键点容器" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        @ obj->detectAndCompute(@<源图像>.obj, @<掩膜>.obj, @<输出关键点容器>.obj, @<输出相关性>.obj, @<不输出关键点>);
    }

    方法 检测图像2 <公开 注释 = "detect,检测图像特征.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出关键点容器 <类型 = CV关键点容器类数组 注释 = "包含关键点的输出结果">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时全图检测,否则只检测掩膜区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj);
        }
        否则
        {
            @ obj->detect(@<源图像>.obj, @<输出关键点容器>.obj, @<掩膜>.obj);
        }
    }

    方法 匹配描述符1 <公开 注释 = "compute,计算匹配图像与一组关键点相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类 注释 = "包含关键点的输出结果">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出特征之间相关性计算值的矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 匹配描述符2 <公开 注释 = "compute,计算匹配图像与多组关键点相关性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输入关键点容器 <类型 = CV关键点容器类数组 注释 = "包含多组关键点的容器数组">
    参数 输出相关性 <类型 = CV矩阵类 注释 = "输出特征之间相关性计算值的矩阵">
    {
        @ if(obj == nullptr) return;
        @ obj->compute(@<源图像>.obj, @<输入关键点容器>.obj, @<输出相关性>.obj);
    }

    方法 写出检测器 <公开 注释 = "write,保存检测器到文件.">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存的文件路径">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->write((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 读入检测器 <公开 注释 = "read,从文件读入检测器.">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->read((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }
}

类 CV条码检测类 <公开 注释 = "BarcodeDetector">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::barcode::BarcodeDetector obj;
    # <> </include>
    # @end

    方法 载入模型 <公开 注释 = "BarcodeDetector,载入深度学习超分辨率模型,不载入则使用普通的检测手段.">
    参数 网络协议文件 <类型 = 文本型>
    参数 网络权重文件 <类型 = 文本型>
    {
        @ @an<CVolMem> memBuf1 , memBuf2;
        @ obj = cv::barcode::BarcodeDetector(GetMbsText (@<网络协议文件>.GetText (), memBuf1, NULL), GetMbsText (@<网络权重文件>.GetText (), memBuf2, NULL));
    }

    方法 检测条码 <公开 注释 = "detect,检测图像中的条码.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 检测结果 <类型 = CV矩阵类 注释 = "为空时不返回检测结果矩阵. 如果检测到N个条码,那么维度应该是[N][4][2]," 注释 = "矩阵的元素值为坐标点,从左下角开始排列.">
    {
        @ obj.detect(@<源图像>.obj, @<检测结果>.obj);
    }

    方法 解码条码 <公开 注释 = "decode,对检测的目标结果进行解码.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲解码的图像">
    参数 检测结果 <类型 = CV矩阵类 注释 = "由函数 检测条码 得到的矩阵">
    参数 输出解码信息 <类型 = CV文本容器 注释 = "包含可能多个条码信息">
    参数 输出条码类型 <类型 = CV文本容器 注释 = "对应   输出解码信息  其条码类型">
    {
        @ std::vector<barcode::BarcodeType> types;@<输出条码类型>.obj.clear();
        @ obj.decode(@<源图像>.obj, @<检测结果>.obj, @<输出解码信息>.obj,  types);
        @ for(int i=0;i<types.size();i++){
        @   barcode::BarcodeType barcode_type= types[i];
        @    switch (barcode_type)
        @    {
        @        case barcode::BarcodeType::EAN_8:
        @            @<输出条码类型>.obj.push_back( "EAN_8");
        @            break;
        @        case barcode::BarcodeType::EAN_13:
        @             @<输出条码类型>.obj.push_back( "EAN_13");
        @            break;
        @        case barcode::BarcodeType::UPC_E:
        @            @<输出条码类型>.obj.push_back( "UPC_E");
        @            break;
        @        case barcode::BarcodeType::UPC_A:
        @            @<输出条码类型>.obj.push_back( "UPC_A");
        @            break;
        @        case barcode::BarcodeType::UPC_EAN_EXTENSION:
        @            @<输出条码类型>.obj.push_back( "UPC_EAN_EXTENSION");
        @            break;
        @        default:
        @            @<输出条码类型>.obj.push_back( "NONE");
        @    }
        @ }
    }

    方法 检测并解码条码 <公开 注释 = "detectAndDecode,检测图像条码,并解码.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测并解码的图像">
    参数 输出解码信息 <类型 = CV文本容器 注释 = "包含可能多个条码信息">
    参数 输出条码类型 <类型 = CV文本容器 注释 = "对应   输出解码信息  其条码类型">
    参数 检测结果 <类型 = CV矩阵类 注释 = "为空时不返回检测结果矩阵. 如果检测到N个条码,那么维度应该是[N][4][2]," 注释 = "矩阵的元素值为坐标点,从左下角开始排列." @默认值 = 空对象>
    {
        @ std::vector<barcode::BarcodeType> types;
        @ obj.detectAndDecode(@<源图像>.obj, @<输出解码信息>.obj,  types, @<检测结果>.obj);
        @ for(int i=0;i<types.size();i++){
        @   barcode::BarcodeType barcode_type= types[i];
        @    switch (barcode_type)
        @    {
        @        case barcode::BarcodeType::EAN_8:
        @            @<输出条码类型>.obj.push_back( "EAN_8");
        @            break;
        @        case barcode::BarcodeType::EAN_13:
        @             @<输出条码类型>.obj.push_back( "EAN_13");
        @            break;
        @        case barcode::BarcodeType::UPC_E:
        @            @<输出条码类型>.obj.push_back( "UPC_E");
        @            break;
        @        case barcode::BarcodeType::UPC_A:
        @            @<输出条码类型>.obj.push_back( "UPC_A");
        @            break;
        @        case barcode::BarcodeType::UPC_EAN_EXTENSION:
        @            @<输出条码类型>.obj.push_back( "UPC_EAN_EXTENSION");
        @            break;
        @        default:
        @            @<输出条码类型>.obj.push_back( "NONE");
        @    }
        @ }
    }
}

类 CV暴力匹配类 <公开 注释 = "BFMatcher,暴力匹配总是能找到最优的描述符匹配度.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Ptr<BFMatcher> obj;
    # <> </include>
    # @end

    方法 创建 <公开 注释 = "create,创建暴力匹配检测器.">
    参数 归一化方法 <类型 = CV归一化常量 注释 = "指定归一化方法" @默认值 = CV归一化常量.L2归一化>
    参数 检测验证 <类型 = 逻辑型 注释 = "为真时检测验证,否则不验证." @默认值 = 假>
    {
        @ obj = cv::BFMatcher::create(@<归一化方法>, @<检测验证>);
    }

    方法 添加描述符样本 <公开 注释 = "add,添加样本.">
    参数 描述符 <类型 = CV矩阵类>
    {
        @ if(obj == nullptr) return;
        @ obj->add(@<描述符>.obj);
    }

    方法 获取训练样本 <公开 类型 = CV矩阵类容器 注释 = "getTrainDescriptors" 返回值注释 = "返回描述符训练样本">
    {
        变量 返回容器 <类型 = CV矩阵类容器>
        @ if(obj!=nullptr)
        @     @<返回容器>.obj = obj->getTrainDescriptors();
        返回 (返回容器)
    }

    方法 清除训练样本 <公开 注释 = "clear,清除所有描述符训练样本.">
    {
        @ if(obj == nullptr) return;
        @ obj->clear();
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty" 返回值注释 = "为空时返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return true;
        @ return  obj->empty();
    }

    方法 是否支持屏蔽 <公开 类型 = 逻辑型 注释 = "isMaskSupported, 如果描述符匹配器支持屏蔽允许的匹配,则返回真." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return false;
        @ return  obj->isMaskSupported();
    }

    方法 训练 <公开 注释 = "train,如果已存在描述符样本,则进入训练.">
    {
        @ if(obj == nullptr) return;
        @ obj->train();
    }

    方法 匹配 <公开 注释 = "match">
    参数 描述符1 <类型 = CV矩阵类 注释 = "欲匹配的描述符1">
    参数 描述符2 <类型 = CV矩阵类 注释 = "欲匹配的描述符2">
    参数 输出描述符 <类型 = CV关键点描述符容器类 注释 = "输出  描述符1与描述符2  的相关性的描述符容器">
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空对象时不指定匹配区域,否则指定匹配区域." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->match(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj);
        }
        否则
        {
            @ obj->match(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj, @<掩膜>.obj);
        }
    }

    方法 匹配_KNN <公开 注释 = "knnMatch,使用KNN邻近值算法匹配.">
    参数 描述符1 <类型 = CV矩阵类 注释 = "欲匹配的描述符1">
    参数 描述符2 <类型 = CV矩阵类 注释 = "欲匹配的描述符2">
    参数 输出描述符 <类型 = CV关键点描述符容器类数组 注释 = "输出  描述符1与描述符2  的相关性的描述符容器">
    参数 邻近值 <类型 = 整数 注释 = "即KNN算法中的K值">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定匹配范围,为空时全部匹配." @默认值 = 空对象>
    参数 压缩结果 <类型 = 逻辑型 注释 = "为真时将压缩结果" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->knnMatch(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj, @<邻近值>, cv::Mat(), @<压缩结果>);
        }
        否则
        {
            @ obj->knnMatch(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj, @<邻近值>, @<掩膜>.obj, @<压缩结果>);
        }
    }

    方法 匹配_半径 <公开 注释 = "radiusMatch,对于每个查询描述符,查找不超过指定距离的训练描述符.">
    参数 描述符1 <类型 = CV矩阵类 注释 = "欲匹配的描述符1">
    参数 描述符2 <类型 = CV矩阵类 注释 = "欲匹配的描述符2">
    参数 输出描述符 <类型 = CV关键点描述符容器类数组 注释 = "输出  描述符1与描述符2  的相关性的描述符容器">
    参数 半径 <类型 = 小数 注释 = "在半径范围内的描述符将认为是匹配的">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定匹配范围,为空时全部匹配." @默认值 = 空对象>
    参数 压缩结果 <类型 = 逻辑型 注释 = "为真时将压缩结果" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->radiusMatch(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj, (float)@<半径>, cv::Mat(), @<压缩结果>);
        }
        否则
        {
            @ obj->radiusMatch(@<描述符1>.obj, @<描述符2>.obj, @<输出描述符>.obj, (float)@<半径>, @<掩膜>.obj, @<压缩结果>);
        }
    }

    方法 匹配_已训练 <公开 注释 = "match,使用已训练的检测器匹配描述符.">
    参数 描述符 <类型 = CV矩阵类 注释 = "输入将要计算匹配的描述符">
    参数 输出描述符 <类型 = CV关键点描述符容器类 注释 = "输出  描述符  与  训练时的描述符  的相关性的描述符容器">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定匹配范围,为空时全部匹配." @默认值 = 空对象>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->match(@<描述符>.obj, @<输出描述符>.obj);
        }
        否则
        {
            @ obj->match(@<描述符>.obj, @<输出描述符>.obj, @<掩膜>.obj);
        }
    }

    方法 匹配_KNN_已训练 <公开 注释 = "knnMatch,使用已训练的检测器的KNN邻近值算法匹配.">
    参数 描述符 <类型 = CV矩阵类 注释 = "输入将要计算匹配的描述符">
    参数 输出描述符 <类型 = CV关键点描述符容器类数组 注释 = "输出  描述符  与  训练时的描述符  的相关性的描述符容器">
    参数 邻近值 <类型 = 整数 注释 = "即KNN算法中的K值">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定匹配范围,为空时全部匹配." @默认值 = 空对象>
    参数 压缩结果 <类型 = 逻辑型 注释 = "为真时将压缩结果" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->knnMatch(@<描述符>.obj,  @<输出描述符>.obj, @<邻近值>, cv::Mat(), @<压缩结果>);
        }
        否则
        {
            @ obj->knnMatch(@<描述符>.obj, @<输出描述符>.obj, @<邻近值>, @<掩膜>.obj, @<压缩结果>);
        }
    }

    方法 匹配_半径_已训练 <公开 注释 = "radiusMatch,对于每个查询描述符,查找不超过指定距离的训练描述符.">
    参数 描述符 <类型 = CV矩阵类 注释 = "输入将要计算匹配的描述符">
    参数 输出描述符 <类型 = CV关键点描述符容器类数组 注释 = "输出  描述符  与  训练时的描述符  的相关性的描述符容器">
    参数 半径 <类型 = 小数 注释 = "在半径范围内的描述符将认为是匹配的">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定匹配范围,为空时全部匹配." @默认值 = 空对象>
    参数 压缩结果 <类型 = 逻辑型 注释 = "为真时将压缩结果" @默认值 = 假>
    {
        @ if(obj == nullptr) return;
        如果 (掩膜 == 空对象)
        {
            @ obj->radiusMatch(@<描述符>.obj,  @<输出描述符>.obj, (float)@<半径>, cv::Mat(), @<压缩结果>);
        }
        否则
        {
            @ obj->radiusMatch(@<描述符>.obj, @<输出描述符>.obj, (float)@<半径>, @<掩膜>.obj, @<压缩结果>);
        }
    }

    方法 写出检测器 <公开 注释 = "write,保存检测器到文件.">
    参数 文件路径 <类型 = 文本型 注释 = "欲保存的文件路径">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->write((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 读入检测器 <公开 注释 = "read,从文件读入检测器,一定要创建后再读入.">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->read((cv::String)GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }
}

类 CV关键点容器类数组 <公开 注释 = "std::vector<std::vector<cv::KeyPoint>>,CV关键点容器类的数组(容器).">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # std::vector<std::vector<cv::KeyPoint>> obj;
    # <> </include>
    # @end

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" 返回值注释 = "返回成员个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV关键点容器类 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "返回 CV关键点容器类">
    参数 成员索引 <类型 = 整数>
    {
        变量 坐标 <类型 = CV关键点容器类>
        @ @<坐标>.obj = obj[@<成员索引>];
        返回 (坐标)
    }

    方法 加入成员 <公开 注释 = "将一个所指定类型的成员值加入到本容器(数组)的尾部">
    参数 欲加入的值 <类型 = CV关键点容器类>
    {
        @ obj.push_back(@<欲加入的值>.obj);
    }

    方法 清除成员 <公开 注释 = "清除容器内的所有成员">
    {
        @ obj.clear();
    }
}

类 CV级联分类器 <公开 注释 = "CascadeClassifier">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::CascadeClassifier obj;
    # <> </include>
    # @end

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty,判断模型是否加载." @禁止流程检查 = 真>
    {
        @ return obj.empty();
    }

    方法 载入模型 <公开 类型 = 逻辑型 注释 = "load,载入一个级联分类器,一般是XML格式." @禁止流程检查 = 真>
    参数 模型文件 <类型 = 文本型 注释 = "通常为xml后缀文件">
    {
        @ @an<CVolMem> memBuf1;
        @ return obj.load(GetMbsText (@<模型文件>.GetText (), memBuf1, NULL));
    }

    方法 检测图像1 <公开 注释 = "detectMultiScale,检测输入图像中不同大小的物体. 检测到的对象作为一个列表返回" 注释 = "的矩形.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出矩形容器 <类型 = CV矩形类容器 注释 = "检测到的结果,当重合、重复的矩形较多时,需要使用函数 候选框分组 做融合.">
    参数 缩放因子 <类型 = 小数 注释 = "对级联分类器尺寸的缩放因子" @默认值 = 1.1>
    参数 相邻个数 <类型 = 整数 注释 = "参数指定每个候选矩形应该有多少个相邻矩形" @默认值 = 3>
    参数 算法标志 <类型 = CV级联分类器算法常量类 注释 = "欲使用的算法" @默认值 = CV级联分类器算法常量类.Canny检测排除>
    参数 最小尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最小尺寸" @默认值 = 空对象>
    参数 最大尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最大尺寸" @默认值 = 空对象>
    {
        变量 min <类型 = CV尺寸类>
        变量 max <类型 = CV尺寸类>
        如果 (最小尺寸 != 空对象)
        {
            min = 最小尺寸
        }
        如果 (最大尺寸 != 空对象)
        {
            max = 最大尺寸
        }
        @ obj.detectMultiScale(@<源图像>.obj, @<输出矩形容器>.obj, @<缩放因子>, @<相邻个数>, @<算法标志>, @<最小尺寸>.obj, @<最大尺寸>.obj);
    }

    方法 检测图像2 <公开 注释 = "detectMultiScale,检测输入图像中不同大小的物体. 检测到的对象作为一个列表返回" 注释 = "的矩形.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出矩形容器 <类型 = CV矩形类容器 注释 = "检测到的结果,当重合、重复的矩形较多时,需要使用函数 候选框分组 做融合.">
    参数 输出检测数量 <类型 = CV整数容器 注释 = "对应对象的检测数向量.  对象的检测数是相邻的正分类矩形的数量,这些矩形被连接在一起形成对象.">
    参数 缩放因子 <类型 = 小数 注释 = "对级联分类器尺寸的缩放因子" @默认值 = 1.1>
    参数 相邻个数 <类型 = 整数 注释 = "参数指定每个候选矩形应该有多少个相邻矩形" @默认值 = 3>
    参数 算法标志 <类型 = CV级联分类器算法常量类 注释 = "欲使用的算法" @默认值 = CV级联分类器算法常量类.Canny检测排除>
    参数 最小尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最小尺寸" @默认值 = 空对象>
    参数 最大尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最大尺寸" @默认值 = 空对象>
    {
        变量 min <类型 = CV尺寸类>
        变量 max <类型 = CV尺寸类>
        如果 (最小尺寸 != 空对象)
        {
            min = 最小尺寸
        }
        如果 (最大尺寸 != 空对象)
        {
            max = 最大尺寸
        }
        @ obj.detectMultiScale(@<源图像>.obj, @<输出矩形容器>.obj, @<输出检测数量>.obj, @<缩放因子>, @<相邻个数>, @<算法标志>, @<最小尺寸>.obj, @<最大尺寸>.obj);
    }

    方法 检测图像3 <公开 注释 = "detectMultiScale,检测输入图像中不同大小的物体. 检测到的对象作为一个列表返回" 注释 = "的矩形,允许检索分类的最终阶段决策确定性.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出矩形容器 <类型 = CV矩形类容器 注释 = "检测到的结果,当重合、重复的矩形较多时,需要使用函数 候选框分组 做融合.">
    参数 输出排斥层级 <类型 = CV整数容器 注释 = "参数 是否输出排斥层级==真时输出">
    参数 输出层级权重 <类型 = CV小数容器 注释 = "参数 是否输出排斥层级==真时输出">
    参数 缩放因子 <类型 = 小数 注释 = "对级联分类器尺寸的缩放因子" @默认值 = 1.1>
    参数 相邻个数 <类型 = 整数 注释 = "参数指定每个候选矩形应该有多少个相邻矩形" @默认值 = 3>
    参数 算法标志 <类型 = CV级联分类器算法常量类 注释 = "欲使用的算法" @默认值 = CV级联分类器算法常量类.Canny检测排除>
    参数 最小尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最小尺寸" @默认值 = 空对象>
    参数 最大尺寸 <类型 = CV尺寸类 注释 = "可以被找到的最大尺寸" @默认值 = 空对象>
    参数 是否输出排斥层级 <类型 = 逻辑型 注释 = "如果为真,则输出参数  \"CV整数容器\"和 \"输出层级权重\"." @默认值 = 假>
    {
        变量 min <类型 = CV尺寸类>
        变量 max <类型 = CV尺寸类>
        如果 (最小尺寸 != 空对象)
        {
            min = 最小尺寸
        }
        如果 (最大尺寸 != 空对象)
        {
            max = 最大尺寸
        }
        @ obj.detectMultiScale(@<源图像>.obj, @<输出矩形容器>.obj, @<输出排斥层级>.obj, @<输出层级权重>.obj, @<缩放因子>, @<相邻个数>, @<算法标志>, @<最小尺寸>.obj, @<最大尺寸>.obj, @<是否输出排斥层级>);
    }
}

类 CV二维码检测类 <公开 注释 = "QRCodeDetector">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::QRCodeDetector obj;
    # <> </include>
    # @end

    方法 设置EpsX <公开 注释 = "setEpsX,设置 QR 码停止标记检测水平扫描期间使用的 epsilon.">
    参数 EpsX <类型 = 小数>
    {
        @ obj.setEpsX(@<EpsX>);
    }

    方法 设置EpsY <公开 注释 = "setEpsY,设置 QR 码停止标记检测垂直扫描期间使用的 epsilon.">
    参数 EpsY <类型 = 小数>
    {
        @ obj.setEpsY(@<EpsY>);
    }

    方法 检测单个二维码 <公开 类型 = 逻辑型 注释 = "detect,检测图像中的单个二维码,找到则返回真." 返回值注释 = "返回,是否找到二维码,找到返回真否则返回假." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测的图像">
    参数 输出点容器 <类型 = CV坐标容器 注释 = "找到二维码时,输出二维码轮廓.">
    {
        @ return obj.detect(@<源图像>.obj, @<输出点容器>.obj);
    }

    方法 解码单个二维码 <公开 类型 = 文本型 注释 = "decode,对单个二维码解码." 返回值注释 = "返回解码文本" @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲解码的图像">
    参数 输入点容器 <类型 = CV坐标容器 注释 = "检测到的轮廓点">
    参数 输出矫正二维码 <类型 = CV矩阵类 注释 = "当不为空对象时,输出矫正后的二维码." @默认值 = 空对象>
    {
        @ std::string txt = "";
        如果 (输出矫正二维码 == 空对象)
        {
            @ txt = obj.decode(@<源图像>.obj, @<输入点容器>.obj);
        }
        否则
        {
            @ txt = obj.decode(@<源图像>.obj, @<输入点容器>.obj, @<输出矫正二维码>.obj);
        }
        @ return txt.c_str();
    }

    方法 检测并解码单个二维码 <公开 类型 = 文本型 注释 = "detectAndDecode,对图像中的单个二维码检测并解码." 返回值注释 = "返回解码文本" @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测和解码的图像">
    参数 输出点容器 <类型 = CV坐标容器 注释 = "检测到的轮廓点">
    参数 输出矫正二维码 <类型 = CV矩阵类 注释 = "当不为空对象时,输出矫正后的二维码." @默认值 = 空对象>
    {
        @ std::string txt = "";
        如果 (输出矫正二维码 == 空对象)
        {
            @ txt = obj.detectAndDecode(@<源图像>.obj, @<输出点容器>.obj);
        }
        否则
        {
            @ txt = obj.detectAndDecode(@<源图像>.obj, @<输出点容器>.obj, @<输出矫正二维码>.obj);
        }
        @ return txt.c_str();
    }

    方法 检测并解码多个二维码 <公开 类型 = 逻辑型 注释 = "detectAndDecodeMulti,对图像中的多个二维码检测并解码." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲检测解码的图像,可能包含多个二维码.">
    参数 输出Codes <类型 = CV文本容器 注释 = "解码得到的文本数组(容器)">
    参数 输出点容器 <类型 = CV坐标容器 注释 = "检测得到的二维码轮廓">
    参数 输出矫正二维码 <类型 = CV矩阵类 注释 = "当不为空对象时,输出矫正后的二维码." @默认值 = 空对象>
    {
        变量 xxxx <类型 = 文本型>

        如果 (输出矫正二维码 == 空对象)
        {
            @ return obj.detectAndDecodeMulti(@<源图像>.obj, @<输出Codes>.obj, @<输出点容器>.obj);
        }
        否则
        {
            @ try{return obj.detectAndDecodeMulti(@<源图像>.obj, @<输出Codes>.obj, @<输出点容器>.obj, @<输出矫正二维码>.obj);}
            @ catch(const cv::Exception& ex){@<xxxx> = (@dt<文本型>)ex.what();}
            调试输出 (xxxx)
            @ return obj.detectAndDecodeMulti(@<源图像>.obj, @<输出Codes>.obj, @<输出点容器>.obj, @<输出矫正二维码>.obj);
        }
    }
}

类 CV人脸识别类 <公开 注释 = "FaceRecognizer">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # Ptr<cv::face::FaceRecognizer> obj;
    # <> </include>
    # @end

    方法 创建模型LBPH <公开 注释 = "LBPHFaceRecognizer::create">
    参数 半径 <类型 = 整数 @默认值 = 1>
    参数 采样数量 <类型 = 整数 @默认值 = 8>
    参数 水平网格数量 <类型 = 整数 @默认值 = 8>
    参数 垂直网格数量 <类型 = 整数 @默认值 = 8>
    参数 阈值 <类型 = 小数 @默认值 = 1.79769313486231570E+308>
    {
        @ obj =  cv::face::LBPHFaceRecognizer::create(@<半径>, @<采样数量>, @<水平网格数量>, @<垂直网格数量>, @<阈值>);
    }

    方法 创建模型Fisher <公开 注释 = "FisherFaceRecognizer::create">
    参数 保留数量 <类型 = 整数 注释 = "为0时全部保留,否则保留指定个数." @默认值 = 0>
    参数 阈值 <类型 = 小数 @默认值 = 1.79769313486231570E+308>
    {
        @ obj =  cv::face::FisherFaceRecognizer::create(@<保留数量>, @<阈值>);
    }

    方法 创建模型Eigen <公开 注释 = "EigenFaceRecognizer::create">
    参数 保留数量 <类型 = 整数 注释 = "为0时全部保留,否则保留指定个数." @默认值 = 0>
    参数 阈值 <类型 = 小数 @默认值 = 1.79769313486231570E+308>
    {
        @ obj =  cv::face::EigenFaceRecognizer::create(@<保留数量>, @<阈值>);
    }

    方法 训练 <公开 注释 = "train,使用多个图像训练模型,它会清空之前的数据集.">
    参数 训练样本图像 <类型 = CV矩阵类容器 注释 = "含有人脸的图像矩阵容器,必须与参数 训练样本标签  一一对应.">
    参数 训练样本标签 <类型 = CV整数容器 注释 = "对应图像的标签如0,1,2.">
    {
        @ if(obj == nullptr) return;
        @ obj->train(@<训练样本图像>.obj, @<训练样本标签>.obj);
    }

    方法 更新数据集 <公开 注释 = "update,使用多个图像训练模型,它不会清空以前的数据集.">
    参数 训练样本图像 <类型 = CV矩阵类容器 注释 = "含有人脸的图像矩阵容器,必须与参数 训练样本标签  一一对应.">
    参数 训练样本标签 <类型 = CV整数容器 注释 = "对应图像的标签如0,1,2.">
    {
        @ if(obj == nullptr) return;
        @ obj->update(@<训练样本图像>.obj, @<训练样本标签>.obj);
    }

    方法 预测图像1 <公开 类型 = 整数 注释 = "predict,对图像进行分类预测,并返回分类结果." 返回值注释 = "返回分类标签" @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "欲预测的人脸图像">
    {
        @ if(obj==nullptr)return -1;
        @ return obj->predict(@<源图像>.obj);
    }

    方法 预测图像2 <公开 注释 = "predict,对图像进行分类预测,并返回分类结果.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲预测的人脸图像">
    参数 输出分类标签 <类型 = 整数 注释 = "输出预测分类结果的标签(ID)">
    参数 输出置信度 <类型 = 小数 注释 = "输出预测结果的置信度,0-1.">
    {
        @ if(obj == nullptr) return;
        @ obj->predict(@<源图像>.obj, @<输出分类标签>, @<输出置信度>);
    }

    方法 写出模型 <公开 注释 = "write,将模型保存到XML文件." "">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->write(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 读入模型 <公开 注释 = "read,从XML文件读入一个模型,读入前先创建.">
    参数 文件路径 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->read(GetMbsText (@<文件路径>.GetText (), memBuf1, NULL));
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "empty,判断模型是否载入." 返回值注释 = "为真时没有载入" @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return true;
        @ return obj->empty();
    }

    方法 设置标签信息 <公开 注释 = "setLabelInfo,如果之前为指定的标签设置了字符串info,则该字符串info将被所提供的值替换.">
    参数 标签 <类型 = 整数 注释 = "就是第几类">
    参数 信息 <类型 = 文本型 注释 = "指定标签信息,可以是所属分类的名称.">
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->setLabelInfo(@<标签>, GetMbsText (@<信息>.GetText (), memBuf1, NULL));
    }

    方法 获取标签信息 <公开 类型 = 文本型 注释 = "getLabelInfo,获取指定分类标签的信息." 返回值注释 = "标签信息,可以是所属分类的名称." @禁止流程检查 = 真>
    参数 标签 <类型 = 整数 注释 = "就是第几类">
    {
        @ if(obj==nullptr)return "";
        @ return obj->getLabelInfo(@<标签>).c_str();
    }

    方法 查询索引 <公开 类型 = CV整数容器 注释 = "getLabelsByString,该函数在关联的字符串中搜索包含指定子字符串的标签索引.">
    参数 信息 <类型 = 文本型 注释 = "需要搜索的标签信息">
    {
        变量 返回容器 <类型 = CV整数容器>
        @ if(obj==nullptr){
        @     @an<CVolMem> memBuf1;
        @     @<返回容器>.obj = obj->getLabelsByString(GetMbsText (@<信息>.GetText (), memBuf1, NULL));}
        返回 (返回容器)
    }

    方法 获取阈值 <公开 类型 = 小数 注释 = "getThreshold,获取最小欧式距离距离的阈值." @禁止流程检查 = 真>
    {
        @ if(obj==nullptr)return -1;
        @ return obj->getThreshold();
    }

    方法 设置阈值 <公开 注释 = "setThreshold,设置最小欧式距离的阈值.">
    参数 阈值 <类型 = 小数>
    {
        @ if(obj == nullptr) return;
        @ obj->setThreshold(@<阈值>);
    }
}

类 CV人脸关键点检测类 <公开 注释 = "Facemark">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # Ptr<cv::face::Facemark> obj;
    # <> </include>
    # @end

    方法 载入模型 <公开 注释 = "loadModel,从文件中载入一个人脸关键点检测模型,载入前先创建.">
    参数 模型文件 <类型 = 文本型>
    {
        @ if(obj == nullptr) return;
        @ @an<CVolMem> memBuf1;
        @ obj->loadModel(GetMbsText (@<模型文件>.GetText (), memBuf1, NULL));
    }

    方法 检测图像 <公开 注释 = "fit,从图像中检测人脸关键点." 编辑时信息 = "2B138, 0, 0, 0">
    参数 源图像 <类型 = CV矩阵类 编辑时信息 = "2B138, 0, 0, 0">
    参数 人脸矩形容器 <类型 = CV矩形类容器 注释 = "使用级联分类器或者其它方式找到的人脸矩形ROI" 编辑时信息 = "2B138, 0, 0, 0">
    参数 输出关键点 <类型 = CV坐标容器数组 注释 = "根据模型可以得到单独的五官轮廓点">
    {
        @ if(obj == nullptr) return;
        @ obj->fit(@<源图像>.obj, @<人脸矩形容器>.obj, @<输出关键点>.obj);
    }

    方法 创建模型AAM <公开 注释 = "createFacemarkAAM">
    {
        @ obj = cv::face::createFacemarkAAM();
    }

    方法 创建模型LBF <公开 注释 = "createFacemarkLBF">
    {
        @ obj = cv::face::createFacemarkLBF();
    }

    方法 创建模型Kazemi <公开 注释 = "createFacemarkKazemi">
    {
        @ obj = cv::face::createFacemarkKazemi();
    }
}

类 CV模板匹配方法常量类 <公开 注释 = "TemplateMatchModes" @常量类 = 整数>
{
    常量 平方差 <公开 值 = 0 注释 = "0,TM_SQDIFF,平方差进行匹配,该方法使用平方差进行匹配,因此最佳的匹配结果在结果为0处,值越大匹配结果越差.">
    常量 归一化平方差 <公开 值 = 1 注释 = "1,TM_SQDIFF_NORMED,归一化的平方差进行匹配,该方法使用归一化的平方差进行匹配,最佳匹配也在结果为0处.">
    常量 相关性 <公开 值 = 2 注释 = "2,TM_CCORR,相关性匹配方法,即NCC,最佳匹配位置在值最大处,值越小匹配结果越差.">
    常量 标准归一化相关性 <公开 值 = 3 注释 = "3,TM_CCORR_NORMED,归一化的相关性匹配方法,与相关性匹配方法类似,最佳匹配位置也是在值最大处.">
    常量 归一化相关性 <公开 值 = 4 注释 = "4,TM_CCOEFF,归一化的相关性系数匹配方法,与相关性匹配方法类似,最佳匹配位置也是在值最大处.">
    常量 标准归一化系数相关性 <公开 值 = 5
            注释 = "5,TM_CCOEFF_NORMED,相关性系数匹配方法,该方法使用源图像与其均值的差、模板与其均值的差二者之间的相关性进行匹配,最佳匹配结果在值等于1处,最差匹配结果在值等于-1处,值等于0直接表示二者不相关.">
}

类 CV级联分类器算法常量类 <公开 注释 = "TemplateMatchModes" @常量类 = 整数>
{
    常量 Canny检测排除 <公开 值 = 1 注释 = "1,CASCADE_DO_CANNY_PRUNING,利用canny边缘检测来排除一些边缘很少或者很多的图像区域.">
    常量 正常比例检测 <公开 值 = 2 注释 = "2,CASCADE_SCALE_IMAGE,正常比例检测.">
    常量 检测最大的物体 <公开 值 = 4 注释 = "4,CASCADE_FIND_BIGGEST_OBJECT,只检测最大的物体.">
    常量 粗略的检测 <公开 值 = 8 注释 = "8,CASCADE_DO_ROUGH_SEARCH,粗略的检测.">
}

类 CV窗口鼠标事件类型常量 <公开 注释 = "MouseEventTypes,设置窗口鼠标回调函数时有用." @常量类 = 整数>
{
    常量 鼠标移动到窗口上方 <公开 值 = 0 注释 = "0,EVENT_MOUSEMOVE,指示鼠标指针已移动到窗口上方.">
    常量 鼠标左键被按下 <公开 值 = 1 注释 = "1,EVENT_LBUTTONDOWN,表示鼠标左键被按下.">
    常量 鼠标右键被按下 <公开 值 = 2 注释 = "2,EVENT_RBUTTONDOWN,表示鼠标右键被按下.">
    常量 鼠标中键被按下 <公开 值 = 3 注释 = "3,EVENT_MBUTTONDOWN,表示鼠标中键被按下.">
    常量 松开鼠标左键 <公开 值 = 4 注释 = "4,EVENT_LBUTTONUP,表示松开鼠标左键.">
    常量 松开鼠标右键 <公开 值 = 5 注释 = "5,EVENT_RBUTTONUP,表示松开鼠标右键.">
    常量 松开鼠标中键 <公开 值 = 6 注释 = "6,EVENT_MBUTTONUP,表示松开鼠标中键.">
    常量 双击鼠标左键 <公开 值 = 7 注释 = "7,EVENT_LBUTTONDBLCLK,表示双击鼠标左键.">
    常量 双击鼠标右键 <公开 值 = 8 注释 = "8,EVENT_RBUTTONDBLCLK,表示双击鼠标右键.">
    常量 双击鼠标中键 <公开 值 = 9 注释 = "9,EVENT_MBUTTONDBLCLK,表示双击鼠标中键.">
    常量 鼠标滚动前后 <公开 值 = 10 注释 = "10,EVENT_MOUSEWHEEL,鼠标滚动前后,正数和负数分别表示向前和向后滚动.">
    常量 鼠标滚动左右 <公开 值 = 11 注释 = "11,EVENT_MOUSEHWHEEL,鼠标滚动左右,正负值分别表示向右和向左滚动.">
}

类 CV窗口鼠标事件标志常量 <公开 注释 = "MouseEventFlags,设置窗口鼠标回调函数时有用." @常量类 = 整数>
