    }
}

类 VGG16性别分类器 <公开 注释 = "lite::onnxruntime::cv::face::attr::VGG16Gender," 注释 = "这是基于VGG16的人脸性别检测的深度神经网络模型,其本质还是分类模型."
        注释 = "AI工具现成的模型权重文件下载地址: https://pan.baidu.com/s/1hoCiwqV1lal7TQYcV1p0Xg?pwd=cnwt">
{

    # @begin
    # <> <include>
    # lite::onnxruntime::cv::face::attr::VGG16Gender *obj=nullptr;
    # inline_ void @an<_OnCleanupExtra>() { if (obj != nullptr) delete obj; }
    # <> </include>
    # @end

    方法 创建VGG16性别分类器 <公开>
    参数 模型权重文件 <类型 = 文本型 注释 = "onnx格式模型文件,现成的模型文件为：vgg_ilsvrc_16_gender_imdb_wiki.onnx.">
    参数 线程数 <类型 = 整数 注释 = "一般设置为1个线程,并不是线程越多速度越快,需要多次试验调试获取最佳速度." @默认值 = 1>
    {
        @ if (obj!=nullptr) delete obj;
        @ @an<CVolMem> memBuf1;
        @ obj = new lite::onnxruntime::cv::face::attr::VGG16Gender(GetMbsText (@<模型权重文件>.GetText (), memBuf1, NULL),@<线程数>);
    }

    方法 预测图像 <公开 注释 = "对输入的图像作推理">
    参数 输入图像 <类型 = CV矩阵类 注释 = "欲检测的人脸图像,可以用人脸检测器检测得到.">
    参数 输出标签 <类型 = 整数类 注释 = "推理得到的性别,如果未成功预测时  输出标签==-1," 注释 = "如果是模型vgg_ilsvrc_16_gender_imdb_wiki.onnx,分类0 为女性,分类1 为男性.">
    参数 输出置信度 <类型 = 小数类 注释 = "推理结果的置信度,其值范围为 0-1,如果如果未成功预测时  输出置信度==-1.">
    {
        @ if(obj == nullptr) return;
        @ lite::types::GenderType gender;
        @ obj->detect(@<输入图像>.obj, gender);
        @ if(gender.flag==false){@<输出标签.值> = -1;@<输出置信度.值> = -1;}
        @ else{@<输出标签.值> = gender.label;@<输出置信度.值> = gender.score;}
    }
}
