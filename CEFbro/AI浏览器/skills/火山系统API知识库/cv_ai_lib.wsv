    常量 使用初始光流 <公开 值 = 4 注释 = "4,使用初始估计,OPTFLOW_USE_INITIAL_FLOW.">
    常量 最小本征值 <公开 值 = 8 注释 = "8,使用最小本征值作为误差度量,OPTFLOW_LK_GET_MIN_EIGENVALS.">
    常量 高斯过滤器 <公开 值 = 256 注释 = "256,OPTFLOW_FARNEBACK_GAUSSIAN,使用Gaussian winsize×winsizewinsize×winsize过滤器代替光流估计的相同大小的盒子过滤器.">
}

