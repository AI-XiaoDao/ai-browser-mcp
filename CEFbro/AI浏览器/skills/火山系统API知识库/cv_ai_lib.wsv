    方法 仿射变换 <公开 静态 注释 = "warpAffine,仿射变换矩阵.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲变换的图像(矩阵)">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "变换后的图像(矩阵)">
    参数 输入变换矩阵 <类型 = CV矩阵类 注释 = "类型为 浮点32位1通道,可以使用函数 获取仿射变换矩阵 获得.">
    参数 指定输出尺寸 <类型 = CV尺寸类 注释 = "变换后图像的尺寸">
    参数 插值方式 <类型 = 整数 注释 = "见  CV插值方式常量" @默认值 = 1>
    参数 边界类型 <类型 = CV边缘类型 注释 = "边缘的算法" @默认值 = CV边缘类型.不变>
    参数 填充颜色 <类型 = CV标量类 注释 = "当变换后,边界有没有值的元素,需要用这个参数填充,如果不指定,则以0填充." @默认值 = 空对象>
    {
        变量 颜色 <类型 = CV标量类>
        如果 (填充颜色 == 空对象)
        {
            颜色.置标量值4通道 (0, 0, 0, 0)
        }
        否则
        {
            颜色 = 填充颜色
        }
        @ cv::warpAffine(@<输入矩阵>.obj, @<输出矩阵>.obj, @<输入变换矩阵>.obj, @<指定输出尺寸>.obj, @<插值方式>, @<边界类型>, @<颜色>.obj);
    }

    方法 透视变换 <公开 静态 注释 = "warpPerspective,透视变换矩阵,与仿射变换不同,变换的矩阵可以变形.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲变换的图像(矩阵)">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "变换后的图像(矩阵)">
    参数 输入变换矩阵 <类型 = CV矩阵类 注释 = "可以从函数 获取投影变换矩阵 得到">
    参数 指定输出尺寸 <类型 = CV尺寸类 注释 = "变换后图像的尺寸">
    参数 插值方式 <类型 = 整数 注释 = "见  CV插值方式常量" @默认值 = 1>
    参数 边界类型 <类型 = CV边缘类型 注释 = "边缘的算法" @默认值 = CV边缘类型.用另一边的像素来补偿填充>
    参数 填充颜色 <类型 = CV标量类 注释 = "当变换后,边界有没有值的元素,需要用这个参数填充,如果不指定,则以0填充." @默认值 = 空对象>
    {
        变量 颜色 <类型 = CV标量类>
        如果 (填充颜色 == 空对象)
        {
            颜色.置标量值4通道 (0, 0, 0, 0)
        }
        否则
        {
            颜色 = 填充颜色
        }
        @ cv::warpPerspective(@<输入矩阵>.obj, @<输出矩阵>.obj, @<输入变换矩阵>.obj, @<指定输出尺寸>.obj, @<插值方式>, @<边界类型>, @<颜色>.obj);
    }

    方法 几何变换 <公开 静态 注释 = "remap,一般几何变换矩阵.">
    参数 输入矩阵 <类型 = CV矩阵类 注释 = "欲变换的图像(矩阵)">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "变换后的图像(矩阵)">
    参数 映射矩阵1 <类型 = CV矩阵类 注释 = "映射矩阵1(x,y)点或仅x值的第一个映射类型为 有符号16位整数2通道,浮点32位小数1通道或浮点32位小数2通道.">
    参数 映射矩阵2 <类型 = CV矩阵类 注释 = "映射矩阵2类型为有符号16位整数、浮点1通道32位或无的y值的第二个映射(如果映射矩阵1是(x,y)点,则为空映射).">
    参数 插值方式 <类型 = 整数 注释 = "参考 CV插值方式常量" @默认值 = 1>
    参数 边界类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.用另一边的像素来补偿填充>
    参数 填充颜色 <类型 = CV标量类 注释 = "当变换后,边界有没有值的元素,需要用这个参数填充,如果不指定,则以0填充." @默认值 = 空对象>
    {
        变量 颜色 <类型 = CV标量类>
        如果 (填充颜色 == 空对象)
        {
            颜色.置标量值4通道 (0, 0, 0, 0)
        }
        否则
        {
            颜色 = 填充颜色
        }
        @ cv::remap(@<输入矩阵>.obj, @<输出矩阵>.obj, @<映射矩阵1>.obj, @<映射矩阵2>.obj, @<插值方式>, @<边界类型>, @<颜色>.obj);
    }

    方法 转换图像映射类型 <公开 静态 注释 = "convertMaps,将图像的映射类型转换到另一个类型.">
    参数 映射1 <类型 = CV矩阵类 注释 = "有符号16位整数2通道、整数32位1通道 或 整数32位2通道 类型的第一个输入映射.">
    参数 映射2 <类型 = CV矩阵类 注释 = "分别为 有符号16位整数1通道、整数32位1通道 或无(空矩阵)类型的第二个输入映射.">
    参数 输出映射1 <类型 = CV矩阵类>
    参数 输出映射2 <类型 = CV矩阵类>
    参数 数值类型 <类型 = CV数值类型 注释 = "指定输出矩阵的数值类型" "">
    参数 临近点插值 <类型 = 逻辑型 注释 = "指示定点映射是用于最近邻居还是用于更复杂的插值的标志" @默认值 = 假>
    {
        @ cv::convertMaps(@<映射1>.obj, @<映射2>.obj, @<输出映射1>.obj, @<输出映射2>.obj, @<数值类型>, @<临近点插值>);
    }

    方法 获取旋转变换矩阵 <公开 静态 类型 = CV矩阵类 注释 = "getRotationMatrix2D,获取一个旋转变换矩阵,可以用于仿射变换." 返回值注释 = "返回一个宽度为3,高度为2的矩阵.">
    参数 中心点 <类型 = CV坐标点2f 注释 = "需要旋转的中心点坐标">
    参数 旋转角度 <类型 = 小数 注释 = "十进制度">
    参数 缩放因子 <类型 = 小数 注释 = "需要缩放目标尺寸的比例,为1时不做缩放.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::getRotationMatrix2D(@<中心点>.obj, @<旋转角度>, @<缩放因子>);
        返回 (返回矩阵)
    }

    方法 获取仿射变换矩阵 <公开 静态 类型 = CV矩阵类 注释 = "getAffineTransform,从输入的坐标点计算获取仿射变换矩阵.">
    参数 原坐标数组 <类型 = CV坐标2f容器 注释 = "仿射变换前的坐标,成员个数必须是3个.">
    参数 目标坐标数组 <类型 = CV坐标2f容器 注释 = "需要变换到的目标坐标,成员个数必须是3个.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::getAffineTransform(@<原坐标数组>.obj, @<目标坐标数组>.obj);
        返回 (返回矩阵)
    }

    方法 获取反向仿射变换矩阵 <公开 静态 注释 = "invertAffineTransform,从一个仿射变换矩阵,获取其反向变换矩阵.">
    参数 输入原矩阵 <类型 = CV矩阵类 注释 = "已获取的变换矩阵">
    参数 输出反向矩阵 <类型 = CV矩阵类 注释 = "反向变换的变换矩阵">
    {
        @ cv::invertAffineTransform(@<输入原矩阵>.obj, @<输出反向矩阵>.obj);
    }

    方法 获取投影变换矩阵 <公开 静态 类型 = CV矩阵类 注释 = "getPerspectiveTransform,根据坐标几何关系计算一个投影变换矩阵.">
    参数 原坐标数组 <类型 = CV坐标2f容器 注释 = "原坐标,坐标成员必须是4个.">
    参数 目标坐标数组 <类型 = CV坐标2f容器 注释 = "需要变换到的新坐标,坐标成员必须是4个.">
    参数 矩阵分解方法 <类型 = CV矩阵分解常量 @默认值 = CV矩阵分解常量.高斯消元法>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::getPerspectiveTransform(@<原坐标数组>.obj, @<目标坐标数组>.obj, @<矩阵分解方法>);
        返回 (返回矩阵)
    }

    方法 获取亚像素区域图像 <公开 静态 注释 = "getRectSubPix,从图像中截取一个亚像素精度的矩形ROI图像.">
    参数 输入源图像 <类型 = CV矩阵类 注释 = "欲提取亚像素区域的图像">
    参数 提取宽高 <类型 = CV尺寸类 注释 = "需要提取的图像尺寸">
    参数 提取中心 <类型 = CV坐标点2f 注释 = "提取ROI的中心坐标">
    参数 输出图像 <类型 = CV矩阵类 注释 = "提取到的图像">
    参数 位深度 <类型 = CV数值类型 注释 = "默认为-1,表示与源图像具有相同的位深度." @默认值 = CV数值类型.不指定>
    {
        @ cv::getRectSubPix(@<输入源图像>.obj, @<提取宽高>.obj, @<提取中心>.obj, @<输出图像>.obj, @<位深度>);
    }

    方法 极坐标变换图像 <公开 静态 注释 = "warpPolar,将图像从笛卡尔坐标映射到极坐标空间.">
    参数 输入源图像 <类型 = CV矩阵类 注释 = "欲变换的图像">
    参数 输出图像 <类型 = CV矩阵类 注释 = "变换结果图像">
    参数 变换后尺寸 <类型 = CV尺寸类 注释 = "变换到的目标图像尺寸">
    参数 变换中心点 <类型 = CV坐标点2f 注释 = "极坐标变换的中心点">
    参数 变换半径 <类型 = 小数 注释 = "要变换的包围圆的半径. 它也决定了反量级缩放参数">
    参数 变换方法 <类型 = 整数 注释 = "CV极坐标变换常量">
    {
        @ cv::warpPolar(@<输入源图像>.obj, @<输出图像>.obj, @<变换后尺寸>.obj, @<变换中心点>.obj, @<变换半径>, @<变换方法>);
    }

    方法 计算图像积分 <公开 静态 注释 = "integral,计算整个矩阵的积分.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲计算的图像">
    参数 图像之和 <类型 = CV矩阵类>
    参数 图像平方 <类型 = CV矩阵类>
    参数 倾斜积分 <类型 = CV矩阵类>
    参数 积分位深度 <类型 = CV数值类型 注释 = "期望的积分深度和倾斜积分图像 有符号32位整数, 32位浮点型,或64位浮点型,默认保持与源图像一致." @默认值 = CV数值类型.不指定>
    参数 平方位深度 <类型 = CV数值类型 注释 = "平方像素值的积分图像的期望深度CV_32F或CV_64F,默认保持与源图像一致." @默认值 = CV数值类型.不指定>
    {
        @ cv::integral(@<源图像>.obj, @<图像之和>.obj, @<图像平方>.obj, @<倾斜积分>.obj, @<积分位深度>, @<平方位深度>);
    }

    方法 计算图像位移 <公开 静态 类型 = CV坐标点2f 注释 = "phaseCorrelate, 该函数用于检测两幅图像之间发生的平移位移.">
    参数 源图像1 <类型 = CV矩阵类 注释 = "浮点1通道32位 or CV_64FC1">
    参数 源图像2 <类型 = CV矩阵类 注释 = "浮点1通道32位 or CV_64FC1">
    参数 窗口 <类型 = CV矩阵类 注释 = "可以使用函数 创建汉宁窗口 创建,类型必须与源图像相同." @默认值 = 空对象>
    参数 输出信号功率 <类型 = 小数 注释 = "信号功率在5x5质心内峰值附近,0到1之间(可选).">
    {
        变量 返回坐标 <类型 = CV坐标点2f>
        @ @<返回坐标>.obj = cv::phaseCorrelate(@<源图像1>.obj, @<源图像2>.obj, @<窗口>.obj, &@<输出信号功率>);
        返回 (返回坐标)
    }

    方法 创建汉宁窗口 <公开 静态 注释 = "createHanningWindow,创建一个汉宁窗口.">
    参数 输出矩阵 <类型 = CV矩阵类 注释 = "创建的汉宁窗口矩阵">
    参数 窗口尺寸 <类型 = CV尺寸类 注释 = "即输出的汉宁窗口矩阵尺寸">
    参数 数值类型 <类型 = CV数值类型 注释 = "指定窗口矩阵的数值类型">
    {
        @ cv::createHanningWindow(@<输出矩阵>.obj, @<窗口尺寸>.obj, @<数值类型>);
    }

    方法 自适应二值化 <公开 静态 注释 = "adaptiveThreshold,对一个图像作自动二值化处理.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲处理的图像">
    参数 结果图像 <类型 = CV矩阵类 注释 = "二值化后的图像">
    参数 最大值 <类型 = 小数 注释 = "指定给满足条件的像素的非零值">
    参数 自适应阈值算法 <类型 = 整数 注释 = "CV自适应二值化算法常量">
    参数 二值化算法 <类型 = 整数 注释 = "CV二值化阈值类型常量">
    参数 相邻个数 <类型 = 整数 注释 = "一般3、5、7">
    参数 常数C <类型 = 小数 注释 = "C常数减去平均值或加权平均值(详见下文). 通常,它是正的,但也可能是零或负的.">
    {
        @ cv::adaptiveThreshold(@<源图像>.obj, @<结果图像>.obj, @<最大值>, @<自适应阈值算法>, @<二值化算法>, @<相邻个数>, @<常数C>);
    }

    方法 获取直线向量交点 <公开 静态 类型 = 逻辑型 注释 = "自定义函数,计算霍夫变换获得直线向量的交点." 返回值注释 = "相交返回真,平行返回假.">
    参数 直线1 <类型 = CV向量4i类 注释 = "欲获取交点的直线1">
    参数 直线2 <类型 = CV向量4i类 注释 = "欲获取交点的直线2">
    参数 输出交点 <类型 = CV坐标点2f 注释 = "输出两直线交点">
    {
        变量 k1 <类型 = 小数>
        变量 k2 <类型 = 小数>
        变量 c1 <类型 = 小数>
        变量 c2 <类型 = 小数>
        变量 x <类型 = 小数>
        变量 y <类型 = 小数>
        k1 = (小数)(直线1.取值 (3) - 直线1.取值 (1)) / (小数)(直线1.取值 (2) - 直线1.取值 (0))
        c1 = (小数)直线1.取值 (1) - (小数)直线1.取值 (0) * k1
        k2 = (小数)(直线2.取值 (3) - 直线2.取值 (1)) / (小数)(直线2.取值 (2) - 直线2.取值 (0))
        c2 = (小数)直线2.取值 (1) - (小数)直线2.取值 (0) * k1
        如果 (k2 == k1)
        {
            返回 (假)
        }
        x = (c1 - c2) / (k2 - k1)
        y = k1 * x + c1
        输出交点.X小数 = x
        输出交点.Y小数 = y
        返回 (真)
    }

    方法 创建滑块 <公开 静态 注释 = "createTrackbar,在CV窗口中创建一个滑块,可以添加回调函数.">
    参数 滑块名称 <类型 = 文本型 注释 = "滑块的名称,将作为查找标识.">
    参数 窗口名称 <类型 = 文本型 注释 = "需要创建滑块的窗口名称标识">
    参数 滑块位置参考 <类型 = 变整数 注释 = "是一个整数变量的地址,它可以是一个全局变量指针,当滑块刻度变化时,改变该变量的值为滑块刻度,为0时不指定.">
    参数 刻度范围 <类型 = 整数 注释 = "必须为大于0的整数">
    参数 函数指针 <类型 = 变整数 注释 = "函数格式   无返回值函数(整数, 变整数),其中参数1是滑块的刻度,参数2为用户指定参数.">
    {
        @ @an<CVolMem> memBuf1 ,memBuf2;
        @ cv::createTrackbar(GetMbsText (@<滑块名称>.GetText (), memBuf1, NULL), GetMbsText (@<窗口名称>.GetText (), memBuf2, NULL), (int*)@<滑块位置参考>, @<刻度范围>,  (TrackbarCallback)@<函数指针>, NULL);
    }

    方法 设置窗口显示回调函数 <公开 静态 注释 = "setOpenGlDrawCallback,设置窗口在每次显示时的回调函数.">
    参数 窗口名称 <类型 = 文本型 注释 = "欲设置的窗口名称">
    参数 函数指针 <类型 = 变整数 注释 = "函数格式   无返回值函数 (变整数),参数为用户指定值.">
    {
        @ @an<CVolMem> memBuf1;
        @ cv::setOpenGlDrawCallback(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL), (OpenGlDrawCallback)@<函数指针>, NULL);
    }

    方法 设置窗口OpenGL上下文 <公开 静态 注释 = "setOpenGlContext,设定窗口的OpenGL上下文.">
    参数 窗口名称 <类型 = 文本型 注释 = "欲设置的窗口名称">
    {
        @ @an<CVolMem> memBuf1;
        @ cv::setOpenGlContext(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL));
    }

    方法 更新窗口显示 <公开 静态 注释 = "updateWindow,更新窗口显示,并自动调用  设置窗口显示回调函数  设置的回调函数.">
    参数 窗口名称 <类型 = 文本型 注释 = "欲更新显示的窗口名称">
    {
        @ @an<CVolMem> memBuf1;
        @ cv::updateWindow(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL));
    }

    方法 显示文本 <公开 静态 注释 = "displayOverlay,将窗口图像上的文本显示为指定持续时间内的覆盖,它不会写到图像中去," 注释 = "只支持QT后端.">
    参数 窗口名称 <类型 = 文本型 注释 = "欲显示文本的窗口名称">
    参数 文本 <类型 = 文本型 注释 = "欲显示的文本">
    参数 周期 <类型 = 整数 注释 = "单位毫秒,为0时不自动消失." @默认值 = 0>
    {
        @ @an<CVolMem> memBuf1 ,memBuf2;
        @ cv::displayOverlay(GetMbsText (@<窗口名称>.GetText (), memBuf1, NULL), GetMbsText (@<文本>.GetText (), memBuf2, NULL), @<周期>);
    }

    方法 图像下采样 <公开 静态 注释 = "pyrDown,使用下采样方法模糊图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲下采样的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "采样结果图像">
    参数 输出结果图像的尺寸 <类型 = CV尺寸类 注释 = "输出图像的大小计算为  输出结果图像的尺寸= ((源图像.宽度+1)/2, (源图像.高度+1)/2).">
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::pyrDown(@<源图像>.obj, @<输出结果>.obj, @<输出结果图像的尺寸>.obj, @<边缘类型>);
    }

    方法 图像上采样 <公开 静态 注释 = "pyrUp,使用上采样方法模糊图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲上采样的图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "采样结果图像">
    参数 输出结果图像的尺寸 <类型 = CV尺寸类 注释 = "输出图像的大小计算为  输出结果图像的尺寸= ((源图像.宽度+1)*2, (源图像.高度+1)*2).">
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::pyrUp(@<源图像>.obj, @<输出结果>.obj, @<输出结果图像的尺寸>.obj, @<边缘类型>);
    }

    方法 构建高斯金字塔 <公开 静态 注释 = "buildPyramid,构建一个高斯金字塔"
            注释 = "该函数构造一个图像向量,并通过递归地将  图像下采样   应用到之前构建的金字塔层,从\' 结果[0]==源图像 \'开始构建高斯金字塔.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲构建金字塔的图像">
    参数 输出结果 <类型 = CV矩阵类容器 注释 = "输出结果[0]   将与 源图像 相同. 输出结果[1]是下一个金字塔层,一个平滑和缩小的  源图像,以此类推.">
    参数 金字塔层级 <类型 = 整数 注释 = "最后(最小)金字塔层的基于 金字塔层级 0的索引. 它必须是非负的">
    参数 边缘类型 <类型 = CV边缘类型 @默认值 = CV边缘类型.默认边缘>
    {
        @ cv::buildPyramid(@<源图像>.obj, @<输出结果>.obj, @<金字塔层级>, @<边缘类型>);
    }

    方法 计算直方图 <公开 静态 注释 = "calcHist,计算输入图像数组的直方图分布.">
    参数 源图像 <类型 = CV矩阵类 注释 = "8位无符号整数, 16位无符号整数或32位浮点型.">
    参数 计算通道索引 <类型 = 整数 注释 = "用于计算直方图的通道索引.">
    参数 掩膜 <类型 = CV矩阵类 注释 = "指定计算范围,默认为空对象全部计算." @默认值 = 空对象>
    参数 输出直方图 <类型 = CV矩阵类 注释 = "输出直方图,它是一个具有 \"直方图尺寸\" 行数,1列的矩阵.">
    参数 直方图维度 <类型 = 整数 注释 = "指定输出直方图的维度" @默认值 = 1>
    参数 直方图尺寸 <类型 = 整数 注释 = "指定直方图大小的数组">
    参数 像素值下限 <类型 = 小数 注释 = "每个维度的直方图bin边界的暗淡数组的数组">
    参数 像素值上限 <类型 = 小数>
    参数 是否均匀展现 <类型 = 逻辑型 注释 = "表示直方图是否均匀的标志." @默认值 = 真>
    {
        @ float range[] = {(float)@<像素值下限>, (float)@<像素值上限>};
        @ const float *histRanges = { range };
        如果 (掩膜 == 空对象)
        {
            @ cv::calcHist(&@<源图像>.obj, 1, &@<计算通道索引>, cv::noArray(), @<输出直方图>.obj, @<直方图维度>, &@<直方图尺寸>, &histRanges, @<是否均匀展现>, false);
        }
        否则
        {
            @ cv::calcHist(&@<源图像>.obj, 1, &@<计算通道索引>, @<掩膜>.obj, @<输出直方图>.obj, @<直方图维度>, &@<直方图尺寸>, &histRanges, @<是否均匀展现>, false);
        }
    }

    方法 计算直方图反向投影 <公开 静态 注释 = "calcBackProject,计算直方图的反向投影.">
    参数 图像源数组 <类型 = CV矩阵类容器 注释 = "它们都应该有相同的深度,8位无符号整数, 无符号16位整数或浮点32位,和相同的大小. 它们每个都可以有任意数量的通道.">
    参数 计算索引列表 <类型 = CV整数容器
            注释 = "用于计算直方图的通道列表. 第一个数组通道从0计数到图像[0].通道数()-1,第二个数组通道从图像[0].通道数()计数到图像[0].通道数() +图像[1].通道数()-1,依此类推.">
    参数 输入直方图 <类型 = CV矩阵类 注释 = "由函数 计算直方图 计算得到的结果">
    参数 输出结果 <类型 = CV矩阵类 注释 = "反向投影的直方图">
    参数 输出像素值区间范围 <类型 = CV单精度小数容器 注释 = "每个维度的直方图bin边界的暗淡数组的数组">
    参数 投影比例 <类型 = 小数 注释 = "可选投影输出的比例因子" @默认值 = 1>
    {
        @ cv::calcBackProject(@<图像源数组>.obj, @<计算索引列表>.obj, @<输入直方图>.obj, @<输出结果>.obj, @<输出像素值区间范围>.obj, @<投影比例>);
    }

    方法 比较直方图 <公开 静态 类型 = 小数 注释 = "compareHist,比较两个直方图,可以比较两个直方图的相似度、关系" 注释 = "虽然该函数可以很好地处理1-、2-、3-维密集直方图,但它可能不适用于高维稀疏直方图."
            @禁止流程检查 = 真>
    参数 输入直方图1 <类型 = CV矩阵类 注释 = "欲比对的直方图1">
    参数 输入直方图2 <类型 = CV矩阵类 注释 = "欲比对的直方图2">
    参数 比对方法 <类型 = CV直方图比较方法常量 注释 = "直方图比对方法" "">
    {
        @ return  cv::compareHist(@<输入直方图1>.obj, @<输入直方图2>.obj, @<比对方法>);
    }

    方法 直方图均衡化 <公开 静态 注释 = "equalizeHist,均衡化灰度图像的直方图.">
    参数 输入图像 <类型 = CV矩阵类 注释 = "必须为8位单通道图像即 无符号8位整数">
    参数 输出图像 <类型 = CV矩阵类 注释 = "均衡化之后的图像">
    {
        @ cv::equalizeHist(@<输入图像>.obj, @<输出图像>.obj);
    }

    方法 图像分割_分水岭 <公开 静态 注释 = "watershed,使用分水岭算法进行基于标记的图像分割.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入8位3通道图像">
    参数 输出掩膜 <类型 = CV矩阵类 注释 = "输入/输出32位单通道标记图像">
    {
        @ cv::watershed(@<源图像>.obj, @<输出掩膜>.obj);
    }

    方法 图像分割_MeanShift_初步处理 <公开 静态 注释 = "pyrMeanShiftFiltering,对图像进行meanshift分割的初始步骤.">
    参数 源图像 <类型 = CV矩阵类 注释 = "8 位3通道图像">
    参数 输出结果 <类型 = CV矩阵类 注释 = "分割后的结果图像">
    参数 sp <类型 = 小数 注释 = "空间窗口半径">
    参数 sw <类型 = 小数 注释 = "颜色窗口半径">
    参数 金字塔层级 <类型 = 整数 注释 = "用于分割的金字塔的最大级别">
    参数 迭代算法 <类型 = CV迭代算法标志类 注释 = "迭代算法标志">
    {
        @ cv::pyrMeanShiftFiltering(@<源图像>.obj, @<输出结果>.obj, @<sp>, @<sw>, @<金字塔层级>, @<迭代算法>.obj);
    }

    方法 图像分割_grabCut <公开 注释 = "grabCut,使用grabCut算法分割图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "8 位3通道图像">
    参数 掩膜 <类型 = CV矩阵类
            注释 = "掩码图像,如果使用掩码进行初始化,那么  掩码 保存初始化掩码信息；在执行分割的时候,也可以将用户交互所设定的前景与背景保存到mask中,然后再传入grabCut函数；在处理结束之后,mask中会保存结果. mask只能取以下四种值："
            注释 = "GCD_BGD(=0),背景；" 注释 = "GCD_FGD(=1),前景；" 注释 = "GCD_PR_BGD(=2),可能的背景；" 注释 = "GCD_PR_FGD(=3),可能的前景."
            注释 = "如果没有手工标记GCD_BGD或者GCD_FGD,那么结果只会有GCD_PR_BGD或GCD_PR_FGD.">
    参数 ROI范围 <类型 = CV矩形类 注释 = "可传入空矩形,用于限定需要进行分割的图像范围,只有该矩形窗口内的图像部分才被处理,该参数仅在mode==#GC_INIT_WITH_RECT时使用.">
    参数 背景模型 <类型 = CV矩阵类 注释 = "可传入空矩阵,背景模型,如果为null,函数内部会自动创建一个 背景模型；背景模型  必须是单通道浮点型(浮点1通道32位)图像,且行数只能为1,列数只能为13x5.">
    参数 前景模型 <类型 = CV矩阵类 注释 = "可传入空矩阵,前景模型,如果为null,函数内部会自动创建一个 前景模型；前景模型  必须是单通道浮点型(浮点1通道32位)图像,且行数只能为1,列数只能为13x5.">
    参数 分割方法 <类型 = 整数 注释 = "GCD_BGD(=0),背景；" 注释 = "GCD_FGD(=1),前景；" 注释 = "GCD_PR_BGD(=2),可能的背景；" 注释 = "GCD_PR_FGD(=3),可能的前景.">
    {
        @ cv::grabCut(@<源图像>.obj, @<掩膜>.obj, @<ROI范围>.obj, @<背景模型>.obj, @<前景模型>.obj, @<分割方法>);
    }

    方法 距离变换_标签 <公开 静态 注释 = "distanceTransform,计算源图像中每个像素到最近的零像素的距离.">
    参数 源图像 <类型 = CV矩阵类 注释 = "8位,单通道(二进制)源图像.">
    参数 变换结果 <类型 = CV矩阵类 注释 = "输出图像计算距离. 它是与  源图像 相同大小的8位或32位浮点单通道图像.">
    参数 输出标签 <类型 = CV矩阵类 注释 = "输出2D标签数组(离散Voronoi图). 它的类型为CV_32SC1  和   源图像  相同的大小.">
    参数 距离变换方法 <类型 = CV距离变换常量 注释 = "使用距离变换的方法">
    参数 掩膜尺寸 <类型 = 整数 注释 = "变换时采用的掩膜尺寸">
    参数 标签类型 <类型 = CV距离变换标签常量 注释 = "距离变换标签类型" @默认值 = CV距离变换标签常量.连接邻近组件标签>
    {
        @ cv::distanceTransform(@<源图像>.obj, @<变换结果>.obj, @<输出标签>.obj, @<距离变换方法>, @<掩膜尺寸>, @<标签类型>);
    }

    方法 距离变换 <公开 静态 注释 = "distanceTransform,计算源图像中每个像素到最近的零像素的距离.">
    参数 源图像 <类型 = CV矩阵类 注释 = "8位单通道(二进制)源图像">
    参数 变换结果 <类型 = CV矩阵类 注释 = "输出图像计算距离. 它是与  源图像 相同大小的8位或32位浮点单通道图像.">
    参数 距离变换方法 <类型 = CV距离变换常量 注释 = "使用距离变换的方法">
    参数 掩膜尺寸 <类型 = 整数 注释 = "变换时采用的掩膜尺寸">
    参数 目标位深度 <类型 = CV数值类型 注释 = "变换结果的矩阵数值类型" @默认值 = CV数值类型.CV_32位浮点型>
    {
        @ cv::distanceTransform(@<源图像>.obj, @<变换结果>.obj, @<距离变换方法>, @<掩膜尺寸>, @<目标位深度>);
    }

    方法 漫水填充_掩膜 <公开 静态 注释 = "floodFill,用给定的颜色填充连接的组件." 注释 = "函数用指定的颜色填充从种子点开始的连接组件. 连通性由相邻像素的颜色/亮度接近度决定.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入/输出1通道或3通道,8位或浮点图像. 除非在函数的第二个参数中设置了#FLOODFILL_MASK_ONLY标志,否则函数会修改它.">
    参数 掩膜 <类型 = CV矩阵类 注释 = "可以传入空矩阵,它是一个单通道8位图像,比图像宽2像素,高2像素. 如果传入一个空的矩阵,它将被自动创建."
            注释 = "边缘检测器输出可以作为一个 掩膜  来停止边缘填充. 在输出时,与图像中填充像素相对应的掩码中的像素被设置为1或标记中的指定值.">
    参数 种子坐标 <类型 = CV坐标点 注释 = "指定作为种子的坐标点">
    参数 填充颜色 <类型 = CV标量类 注释 = "作为填充的颜色标量">
    参数 边界矩形指针 <类型 = 变整数 注释 = "为0时不传出,可选输出参数,由函数设置为重绘区域的最小边框,该变量由 CV矩形类.取矩形指针()获得." @默认值 = 0>
    参数 低色差 <类型 = CV标量类 注释 = "可以为空标量,当前观察到的像素与属于该组件的相邻像素之间的最大较低亮度/色差,或添加到该组件的种子像素.">
    参数 高色差 <类型 = CV标量类 注释 = "可以为空标量,当前观察到的像素与属于该组件的相邻像素之间的最大亮度/色差,或添加到该组件的种子像素之间的最大亮度/色差.">
    参数 连通值 <类型 = 整数 注释 = "前8位包含一个连通值. 默认值" 注释 = "4表示只考虑最近邻的四个像素(共享一条边的像素). 连通值为8意味着将考虑8个最近邻像素(共享一个角的像素)."
            注释 = "接下来的8位(8-16)包含一个1到255之间的值来填充掩码(默认值是1)." 注释 = "例如,4 |(255 << 8)将考虑4个最近的邻居,并用255的值填充掩码.">
    {
        @ cv::floodFill(@<源图像>.obj, @<掩膜>.obj, @<种子坐标>.obj, @<填充颜色>.obj, (cv::Rect*)@<边界矩形指针>, @<低色差>.obj, @<高色差>.obj, @<连通值>);
    }

    方法 漫水填充 <公开 静态 注释 = "floodFill,用给定的颜色填充连接的组件." 注释 = "函数用指定的颜色填充从种子点开始的连接组件. 连通性由相邻像素的颜色/亮度接近度决定.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入/输出1通道或3通道,8位或浮点图像. 除非在函数的第二个参数中设置了#FLOODFILL_MASK_ONLY标志,否则函数会修改它.">
    参数 种子坐标 <类型 = CV坐标点 注释 = "指定作为种子的坐标点">
    参数 填充颜色 <类型 = CV标量类 注释 = "作为填充的颜色标量">
    参数 边界矩形指针 <类型 = 变整数 注释 = "为0时不传出,可选输出参数,由函数设置为重绘区域的最小边框,该变量由 CV矩形类.取矩形指针()获得." @默认值 = 0>
    参数 低色差 <类型 = CV标量类 注释 = "可以为空标量,当前观察到的像素与属于该组件的相邻像素之间的最大较低亮度/色差,或添加到该组件的种子像素.">
    参数 高色差 <类型 = CV标量类 注释 = "可以为空标量,当前观察到的像素与属于该组件的相邻像素之间的最大亮度/色差,或添加到该组件的种子像素之间的最大亮度/色差.">
    参数 连通值 <类型 = 整数 注释 = "前8位包含一个连通值. 默认值" 注释 = "4表示只考虑最近邻的四个像素(共享一条边的像素). 连通值为8意味着将考虑8个最近邻像素(共享一个角的像素)."
            注释 = "接下来的8位(8-16)包含一个1到255之间的值来填充掩码(默认值是1)." 注释 = "例如,4 |(255 << 8)将考虑4个最近的邻居,并用255的值填充掩码.">
    {
        @ cv::floodFill(@<源图像>.obj, @<种子坐标>.obj, @<填充颜色>.obj,  (cv::Rect*)@<边界矩形指针>, @<低色差>.obj, @<高色差>.obj, @<连通值>);
    }

    方法 线性混合 <公开 静态 注释 = "blendLinear,对两个图像做线性混合.">
    参数 源图像1 <类型 = CV矩阵类 注释 = "它的类型为CV_8UC(n)或CV_32FC(n),其中n为正整数.">
    参数 源图像2 <类型 = CV矩阵类 注释 = "必须与 源图像1 的通道类型、尺寸相同">
    参数 权重1 <类型 = CV矩阵类 注释 = "它的类型为浮点1通道32位,大小与 源图像1 相同.">
    参数 权重2 <类型 = CV矩阵类 注释 = "它的类型为浮点1通道32位,大小与 源图像2 相同.">
    参数 输出结果 <类型 = CV矩阵类 注释 = "混合后的结果图像">
    {
        @ cv::blendLinear(@<源图像1>.obj, @<源图像2>.obj, @<权重1>.obj, @<权重2>.obj, @<输出结果>.obj);
    }

    方法 颜色空间转换_YUV <公开 静态 注释 = "cvtColorTwoPlane,将图像从一个颜色空间转换为另一个颜色空间,其中源图像存储在两个平面中.">
    参数 源图像1 <类型 = CV矩阵类 注释 = "Y平面的8位图像(#8位无符号整数)">
    参数 源图像2 <类型 = CV矩阵类 注释 = "包含交错U/V平面的图像">
    参数 转换结果 <类型 = CV矩阵类 注释 = "转换后的结果图像">
    参数 转换类型 <类型 = CV图像颜色空间转换常量 注释 = "只支持以下转换形式：" 注释 = "- #YUV转BGR_NV12接口" 注释 = "- #YUV转RGB_NV12接口" 注释 = "- #YUV转BGRA_NV12接口"
            注释 = "- #YUV转RGBA_NV12接口" 注释 = "- #YUV转BGR_NV21接口" 注释 = "- #YUV转RGB_NV21接口" 注释 = "- #YUV转BGRA_NV21接口"
            注释 = "- #YUV转RGBA_NV21接口">
    {
        @ cv::cvtColorTwoPlane(@<源图像1>.obj, @<源图像2>.obj, @<转换结果>.obj, @<转换类型>);
    }

    方法 颜色空间转换_Bayer <公开 静态 注释 = "demosaicing,主要是去马赛克图像的转换.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲转换的图像">
    参数 转换结果 <类型 = CV矩阵类 注释 = "转换后的结果图像">
    参数 转换类型 <类型 = CV图像颜色空间转换常量 注释 = "使用双线性插值的去马赛克图像：" 注释 = "    #拜尔排布BG转BGR , #拜尔排布GB转BGR , #拜尔排布RG转BGR , #拜尔排布GR转BGR"
            注释 = "    #拜尔排布BG转灰度 , #拜尔排布GB转灰度 , #拜尔排布RG转灰度 , #拜尔排布GR转灰度." 注释 = "使用可变数量的梯度去马赛克图像："
            注释 = "    #拜尔排布BG转BGR_VNG接口 , #拜尔排布GB转BGR_VNG接口 , #拜尔排布RG转BGR_VNG接口, #拜尔排布GR转BGR_VNG接口." 注释 = "Edge-Aware去马赛克图像："
            注释 = "    #拜尔排布BG转BGR_EA接口 , #拜尔排布GB转BGR_EA接口 , #拜尔排布RG转BGR_EA接口 , #拜尔排布GR转BGR_EA接口." 注释 = "用alpha通道去马赛克图像："
            注释 = "   #拜尔排布BG转BGRA , #拜尔排布GB转BGRA , #拜尔排布RG转BGRA , #拜尔排布GR转BGRA.">
    参数 目标通道数 <类型 = 整数 注释 = "当为0时,根据 源图像 自动指定." @默认值 = 0>
    {
        @ cv::demosaicing(@<源图像>.obj, @<转换结果>.obj, @<转换类型>, @<目标通道数>);
    }

    方法 计算图像矩 <公开 静态 类型 = CV图像矩 注释 = "moments,计算多边形或栅格化形状的三阶以内的所有力矩.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲计算的图像">
    参数 是否采用二值化 <类型 = 逻辑型 注释 = "如果为真值,所有非零图像像素都被视为1." @默认值 = 假>
    {
        变量 返回图像矩 <类型 = CV图像矩>
        @ @<返回图像矩>.obj = cv::moments(@<源图像>.obj, @<是否采用二值化>);
        返回 (返回图像矩)
    }

    方法 计算图像矩Hu <公开 静态 注释 = "HuMoments,计算图像矩的7个   Hu   的值.">
    参数 欲计算的图像矩 <类型 = CV图像矩>
    参数 输出计算结果 <类型 = CV向量容器2d 注释 = "图像矩的7个   Hu   的值,它是一个包含7个元素的小数向量,这些值被证明对图像缩放,旋转和反射是不变量,除了第七个,它的符号被反射改变."
            注释 = "在图像分辨率无限的假设下,证明了这种不变性. 对于栅格图像,原始图像和变换后的图像计算的Hu不变量略有不同.">
    {
        @ cv::HuMoments(@<欲计算的图像矩>.obj, @<输出计算结果>.obj);
    }

    方法 估算标定板锐度 <公开 静态 类型 = CV标量类 注释 = "estimateChessboardSharpness,估计检测到的棋盘的锐度" 返回值注释 = "返回标量(平均清晰度,平均最小亮度,平均最大亮度,0)">
    参数 输入标定板图像 <类型 = CV矩阵类 注释 = "必须是单通道的灰度图像">
    参数 输入棋盘格行列数 <类型 = CV尺寸类 注释 = "找到的棋盘图案的大小">
    参数 输入角点 <类型 = CV坐标2f容器 注释 = "使用 寻找标定板角点_扇形查找/寻找标定板角点找到的角点">
    参数 上升距离 <类型 = 小数 注释 = "上升距离0.8表示最终信号强度的10%…90%">
    参数 计算垂直边缘 <类型 = 逻辑型 注释 = "为假时计算水平线的边缘响应,为真时计算垂直的边缘响应." @默认值 = 假>
    参数 输出锐度矩阵 <类型 = CV矩阵类 注释 = "锐度可选输出阵列,具有计算边缘响应的锐度值." @默认值 = 空对象>
    {
        变量 返回标量 <类型 = CV标量类>
        如果 (输出锐度矩阵 == 空对象)
        {
            @ @<返回标量>.obj = cv::estimateChessboardSharpness(@<输入标定板图像>.obj, @<输入棋盘格行列数>.obj, @<输入角点>.obj, (float)@<上升距离>, @<计算垂直边缘>);
        }
        否则
        {
            @ @<返回标量>.obj = cv::estimateChessboardSharpness(@<输入标定板图像>.obj, @<输入棋盘格行列数>.obj, @<输入角点>.obj, (float)@<上升距离>, @<计算垂直边缘>, @<输出锐度矩阵>.obj);
        }
        返回 (返回标量)
    }

    方法 寻找标定板角点_亚像素 <公开 静态 注释 = "find4QuadCornerSubpix,查找棋盘角的亚像素精确位置.">
    参数 源图像 <类型 = CV矩阵类 注释 = "必须是8位灰度图像(矩阵)">
    参数 输出坐标点 <类型 = CV坐标2f容器 注释 = "找到的棋盘格角点坐标点">
    参数 行列尺寸 <类型 = CV尺寸类 注释 = "棋盘格的格子的行数、列数">
    {
        @ cv::find4QuadCornerSubpix(@<源图像>.obj, @<输出坐标点>.obj, @<行列尺寸>.obj);
    }

    方法 绘制棋盘格角点 <公开 静态 注释 = "drawChessboardCorners,将找到的棋盘格角点绘制到图像.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制到的图像(矩阵)">
    参数 行列尺寸 <类型 = CV尺寸类 注释 = "棋盘格的格子的行数、列数">
    参数 输入坐标点 <类型 = CV坐标2f容器 注释 = "将要绘制的坐标点,找到的棋盘格角点坐标点.">
    参数 是否完整 <类型 = 逻辑型类 注释 = "输出是否找到完整的棋盘格,找到时为真否则为假.">
    {
        @ cv::drawChessboardCorners(@<源图像>.obj, @<行列尺寸>.obj, @<输入坐标点>.obj, @<是否完整.值>);
    }

    方法 寻找标定板角点_扇形查找 <公开 静态 类型 = 逻辑型 注释 = "findChessboardCornersSB,使用基于扇区的方法查找棋盘的内部角的位置." 返回值注释 = "找到时返回真,否则返回假." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "必须是8位灰度或者彩色图像(矩阵)">
    参数 行列尺寸 <类型 = CV尺寸类 注释 = "棋盘格的格子的行数、列数">
    参数 输出坐标点 <类型 = CV坐标2f容器 注释 = "将要绘制的坐标点,找到的棋盘格角点坐标点.">
    参数 查找算法 <类型 = 整数 注释 = "有以下查找方法：" 注释 = "CALIB_CB_ADAPTIVE_THRESH = 1          自适应阈值"
            注释 = "CALIB_CB_NORMALIZE_IMAGE = 2         归一化图像" 注释 = "CALIB_CB_FILTER_QUADS    = 4,              四边形滤波"
            注释 = "CALIB_CB_FAST_CHECK      = 8,               快速检测" 注释 = "CALIB_CB_EXHAUSTIVE      = 16,              详细检测"
            注释 = "CALIB_CB_ACCURACY        = 32,              精确查找" 注释 = "CALIB_CB_LARGER          = 64,                  大规模查找"
            注释 = "CALIB_CB_MARKER          = 128                靶点查找" 注释 = "可以组合使用如 1+2=3 参数输入3." @默认值 = 1>
    {
        @ return cv::findChessboardCornersSB(@<源图像>.obj, @<行列尺寸>.obj, @<输出坐标点>.obj, @<查找算法>);
    }

    方法 寻找标定板角点 <公开 静态 类型 = 逻辑型 注释 = "findChessboardCorners,查找棋盘的内部角的位置." 返回值注释 = "找到时返回真,否则返回假." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "必须是8位灰度或者彩色图像(矩阵)">
    参数 行列尺寸 <类型 = CV尺寸类 注释 = "棋盘格的格子的行数、列数">
    参数 输出坐标点 <类型 = CV坐标2f容器 注释 = "将要绘制的坐标点,找到的棋盘格角点坐标点.">
    参数 查找算法 <类型 = 整数 注释 = "默认算法为  1+2   有以下查找方法：" 注释 = "CALIB_CB_ADAPTIVE_THRESH = 1          自适应阈值"
            注释 = "CALIB_CB_NORMALIZE_IMAGE = 2         归一化图像" 注释 = "CALIB_CB_FILTER_QUADS    = 4,              四边形滤波"
            注释 = "CALIB_CB_FAST_CHECK      = 8,               快速检测" 注释 = "CALIB_CB_EXHAUSTIVE      = 16,              详细检测"
            注释 = "CALIB_CB_ACCURACY        = 32,              精确查找" 注释 = "CALIB_CB_LARGER          = 64,                  大规模查找"
            注释 = "CALIB_CB_MARKER          = 128                靶点查找" 注释 = "可以组合使用如 1+2=3 参数输入3." @默认值 = 3>
    {
        @ return cv::findChessboardCorners(@<源图像>.obj, @<行列尺寸>.obj, @<输出坐标点>.obj, @<查找算法>);
    }

    方法 检查是否存在标定板 <公开 静态 类型 = 逻辑型 注释 = "checkChessboard,检查图像中是否存在指定行列数的标定板." @禁止流程检查 = 真>
    参数 源图像 <类型 = CV矩阵类 注释 = "必须是8位灰度或者彩色图像(矩阵)">
    参数 行列尺寸 <类型 = CV尺寸类 注释 = "棋盘格的格子的行数、列数">
    {
        @ return cv::checkChessboard(@<源图像>.obj, @<行列尺寸>.obj);
    }

    方法 绘制坐标系轴线 <公开 静态 注释 = "drawFrameAxes,根据姿态估计绘制世界/物理坐标系的轴线.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲绘制的图像(矩阵)">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量,使用函数  计算物体姿态  获得.">
    参数 旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 平移矢量 <类型 = CV矩阵类 注释 = "坐标轴平移矢量(通常以米为单位),使用函数  计算物体姿态  获得.">
    参数 长度 <类型 = 小数 注释 = "与  平移矢量  相同单位的画轴长度(通常以米为单位)">
    参数 厚度 <类型 = 整数 注释 = "绘制的轴线厚度" @默认值 = 3>
    {
        @ cv::drawFrameAxes(@<源图像>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<旋转矢量>.obj, @<平移矢量>.obj, (float)@<长度>, @<厚度>);
    }

    方法 计算物体姿态 <公开 静态 类型 = 逻辑型 注释 = "solvePnP,从3D-2D的点对应中找到一个物体的姿态." 返回值注释 = "如果找到物体姿态返回真,否则返回假." @禁止流程检查 = 真>
    参数 世界坐标 <类型 = CV坐标3f容器 注释 = "在真实世界中的坐标点">
    参数 图像坐标 <类型 = CV坐标2f容器 注释 = "在图像中的坐标点">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    {
        @ return cv::solvePnP(@<世界坐标>.obj, @<图像坐标>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj);
    }

    方法 计算物体姿态_随机样本 <公开 静态 类型 = 逻辑型 注释 = "solvePnPRansac,使用随机样本算法从3D-2D的点对应中找到一个物体的姿态." 返回值注释 = "如果找到物体姿态返回真,否则返回假." @禁止流程检查 = 真>
    参数 世界坐标 <类型 = CV坐标3f容器 注释 = "在真实世界中的坐标点">
    参数 图像坐标 <类型 = CV坐标2f容器 注释 = "在图像中的坐标点">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    {
        @ return cv::solvePnPRansac(@<世界坐标>.obj, @<图像坐标>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj);
    }

    方法 求解目标姿态_从对应点 <公开 静态 类型 = 整数 注释 = "solveP3P,从3个3D-2D点对应关系中查找对象姿势." 返回值注释 = "原型未说明返回值的含义" @禁止流程检查 = 真>
    参数 目标坐标点 <类型 = CV矩阵类 注释 = "目标坐标空间中对象点的数组,Nx3 1通道或1xN/Nx1 3通道,其中N是点数.">
    参数 图像坐标点 <类型 = CV矩阵类 注释 = "对应图像点的阵列,Nx2 1通道或1xN/Nx1 2通道,其中N是点的数量.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "相机内部参数">
    参数 矫正系数 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类>
    参数 输出平移矢量 <类型 = CV矩阵类>
    参数 求解方法 <类型 = 整数 注释 = "求解方法:" 注释 = "SOLVEPNP_ITERATIVE= 0,使用非线性Levenberg-Marquardt最小化方案"
            注释 = "SOLVEPNP_EPNP        = 1,高效的透视n点相机姿态估计" 注释 = "SOLVEPNP_P3P           = 2,透视三点问题的完全解分类"
            注释 = "SOLVEPNP_DLS           = 3,执行失败使用此标志将回退到EPnP,PnP的直接最小二乘法"
            注释 = "SOLVEPNP_UPNP       = 4,执行失败使用此标志将回退到EPnP,鲁棒相机姿态和焦距估计的穷举线性化" 注释 = "SOLVEPNP_AP3P        = 5,透视三点问题的有效代数解法"
            注释 = "SOLVEPNP_IPPE        = 6,基于无穷小平面的姿态估计" 注释 = "SOLVEPNP_IPPE_SQUARE = 7,基于无穷小平面的姿态估计"
            注释 = "SOLVEPNP_SQPNP       = 8,透视n点问题的一致快速全局最优解">
    {
        @ return cv::solveP3P(@<目标坐标点>.obj, @<图像坐标点>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj, static_cast<cv::SolvePnPMethod>(@<求解方法>));
    }

    方法 求解目标姿态_LM <公开 静态 注释 = "solvePnPRefineLM,从初始解决方案开始," 注释 = "从3D-2D点对应关系优化姿势(将对象坐标系中表示的3D点转换为相机坐标系的平移和旋转).">
    参数 目标坐标点 <类型 = CV矩阵类 注释 = "目标坐标空间中对象点的数组,Nx3 1通道或1xN/Nx1 3通道,其中N是点数.">
    参数 图像坐标点 <类型 = CV矩阵类 注释 = "对应图像点的阵列,Nx2 1通道或1xN/Nx1 2通道,其中N是点的数量.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "相机内部参数">
    参数 矫正系数 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类>
    参数 输出平移矢量 <类型 = CV矩阵类>
    参数 迭代标志 <类型 = CV迭代算法标志类>
    {
        @ cv::solvePnPRefineLM(@<目标坐标点>.obj, @<图像坐标点>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj, @<迭代标志>.obj);
    }

    方法 求解目标姿态_VVS <公开 静态 注释 = "solvePnPRefineVVS,从初始解决方案开始," 注释 = "从3D-2D点对应关系优化姿态(将对象坐标系中表示的3D点转换为相机坐标系的平移和旋转).">
    参数 目标坐标点 <类型 = CV矩阵类 注释 = "目标坐标空间中对象点的数组,Nx3 1通道或1xN/Nx1 3通道,其中N是点数.">
    参数 图像坐标点 <类型 = CV矩阵类 注释 = "对应图像点的阵列,Nx2 1通道或1xN/Nx1 2通道,其中N是点的数量.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "相机内部参数">
    参数 矫正系数 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类>
    参数 输出平移矢量 <类型 = CV矩阵类>
    参数 迭代标志 <类型 = CV迭代算法标志类>
    参数 增益 <类型 = 小数 注释 = "虚拟视觉伺服控制律的增益,相当于阻尼高斯-牛顿公式中的α增益" @默认值 = 1.0>
    {
        @ cv::solvePnPRefineVVS(@<目标坐标点>.obj, @<图像坐标点>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj, @<迭代标志>.obj, @<增益>);
    }

    方法 求解目标姿态 <公开 静态 注释 = "solvePnPGeneric,从3D-2D点对应关系中查找对象姿势">
    参数 目标坐标点 <类型 = CV矩阵类 注释 = "目标坐标空间中对象点的数组,Nx3 1通道或1xN/Nx1 3通道,其中N是点数.">
    参数 图像坐标点 <类型 = CV矩阵类 注释 = "对应图像点的阵列,Nx2 1通道或1xN/Nx1 2通道,其中N是点的数量.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "相机内部参数">
    参数 矫正系数 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类>
    参数 输出平移矢量 <类型 = CV矩阵类>
    参数 是否优化 <类型 = 逻辑型 注释 = "用于SOLVEPNP_ITERATIVE求解方法,如果为真,函数将使用提供的旋转矢量和平移矢量值分别作为旋转矢量和平移矢量的初始近似值,并进一步优化它们" @默认值 = 假>
    参数 求解方法 <类型 = 整数 注释 = "求解方法:" 注释 = "SOLVEPNP_ITERATIVE= 0,使用非线性Levenberg-Marquardt最小化方案"
            注释 = "SOLVEPNP_EPNP        = 1,高效的透视n点相机姿态估计" 注释 = "SOLVEPNP_P3P           = 2,透视三点问题的完全解分类"
            注释 = "SOLVEPNP_DLS           = 3,执行失败使用此标志将回退到EPnP,PnP的直接最小二乘法"
            注释 = "SOLVEPNP_UPNP       = 4,执行失败使用此标志将回退到EPnP,鲁棒相机姿态和焦距估计的穷举线性化" 注释 = "SOLVEPNP_AP3P        = 5,透视三点问题的有效代数解法"
            注释 = "SOLVEPNP_IPPE        = 6,基于无穷小平面的姿态估计" 注释 = "SOLVEPNP_IPPE_SQUARE = 7,基于无穷小平面的姿态估计"
            注释 = "SOLVEPNP_SQPNP       = 8,透视n点问题的一致快速全局最优解" @默认值 = 0>
    {
        @ cv::solvePnPGeneric(@<目标坐标点>.obj, @<图像坐标点>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj, @<是否优化>, static_cast<cv::SolvePnPMethod>(@<求解方法>));
    }

    方法 计算相机内参 <公开 静态 类型 = CV矩阵类 注释 = "initCameraMatrix2D,从3D-2D点对应关系中找到一个初始相机内参矩阵" 注释 = "目前,该函数只支持平面校准模式,即每个目标点的z坐标为0的模式."
            返回值注释 = "返回一个相机的3*3内参矩阵">
    参数 世界坐标 <类型 = CV坐标3f容器 注释 = "在真实世界中的坐标点">
    参数 图像坐标 <类型 = CV坐标2f容器 注释 = "在图像中的坐标点">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "参数 图像坐标  所在的图像尺寸">
    参数 纵横比 <类型 = 小数 注释 = "如果为零或负值,f_x和f_y都是独立估计的." 注释 = "否则,f_x = f_y * 纵横比." @默认值 = 1>
    {
        变量 返回内参 <类型 = CV矩阵类>
        @ @<返回内参>.obj = cv::initCameraMatrix2D(@<世界坐标>.obj, @<图像坐标>.obj, @<图像尺寸>.obj, @<纵横比>);
        返回 (返回内参)
    }

    方法 计算相机参数 <公开 静态 类型 = 小数 注释 = "calibrateCamera,从校准模式的几个视图中查找相机的内部和外部参数." 返回值注释 = "返回整体RMS重投影误差" @禁止流程检查 = 真>
    参数 世界坐标数组 <类型 = CV坐标3f容器数组 注释 = "每一张标定板图像拥有一组坐标容器">
    参数 图像坐标数组 <类型 = CV坐标2f容器数组 注释 = "每一张标定板图像拥有一组坐标容器">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "参数 图像坐标  所在的图像尺寸">
    参数 输出相机内参 <类型 = CV矩阵类 注释 = "输出相机内部参数的3x3浮点矩阵">
    参数 输出矫正系数 <类型 = CV矩阵类 注释 = "失真系数输出向量">
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    {
        @ return cv::calibrateCamera(@<世界坐标数组>.obj, @<图像坐标数组>.obj, @<图像尺寸>.obj, @<输出相机内参>.obj, @<输出矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj);
    }

    方法 转换旋转矩阵与向量 <公开 静态 注释 = "Rodrigues,将旋转矩阵转换为旋转向量,反之亦然.">
    参数 输入旋转矢量 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类>
    参数 输出雅可比矩阵 <类型 = CV矩阵类 注释 = "可选输出雅可比矩阵" @默认值 = 空对象>
    {
        如果 (输出雅可比矩阵 == 空对象)
        {
            @ cv::Rodrigues(@<输入旋转矢量>.obj, @<输出旋转矢量>.obj);
        }
        否则
        {
            @ cv::Rodrigues(@<输入旋转矢量>.obj, @<输出旋转矢量>.obj, @<输出雅可比矩阵>.obj);
        }
    }

    方法 计算两平面透视变换矩阵 <公开 静态 类型 = CV矩阵类 注释 = "findHomography,查找两个平面之间的透视变换" 返回值注释 = "返回透视变换矩阵">
    参数 源坐标 <类型 = CV坐标2f容器 注释 = "变换前的坐标">
    参数 目标坐标 <类型 = CV坐标2f容器 注释 = "变换后的坐标">
    参数 计算方法 <类型 = 整数 注释 = "计算方法:" 注释 = "       LMEDS  = 4,  最小二乘法" 注释 = "       RANSAC = 8,  RANSAC算法"
            注释 = "       RHO    = 16,  RHO算法" 注释 = "       USAC_DEFAULT  = 32, USAC算法,默认算法"
            注释 = "       USAC_PARALLEL = 33,  USAC并行算法" 注释 = "       USAC_FM_8PTS = 34,   USAC基本矩阵8点算法"
            注释 = "       USAC_FAST = 35,          USAC快速算法" 注释 = "       USAC_ACCURATE = 36, USAC精确算法"
            注释 = "       USAC_PROSAC = 37,   USAC排序点且运行PROSAC" 注释 = "       USAC_MAGSAC = 38   USAC且运行MAGSAC++">
    参数 阈值 <类型 = 小数 注释 = "将点对视为内嵌的最大允许重投影错误" @默认值 = 3.0>
    参数 输出掩膜 <类型 = CV矩阵类 注释 = "算法(RANSAC或LMEDS)设置的可选输出掩膜,其它算法无效." @默认值 = 空对象>
    参数 最大迭代次数 <类型 = 整数 注释 = "RANSAC算法迭代的最大次数" @默认值 = 2000>
    参数 最小置信度 <类型 = 小数 注释 = "置信水平,介于0和1之间." @默认值 = 0.995>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        如果 (输出掩膜 == 空对象)
        {
            @ @<返回矩阵>.obj = cv::findHomography(@<源坐标>.obj, @<目标坐标>.obj, @<计算方法>, @<阈值>, noArray(), @<最大迭代次数>, @<最小置信度>);
        }
        否则
        {
            @ @<返回矩阵>.obj = cv::findHomography(@<源坐标>.obj, @<目标坐标>.obj, @<计算方法>, @<阈值>, @<输出掩膜>.obj, @<最大迭代次数>, @<最小置信度>);
        }
        返回 (返回矩阵)
    }

    方法 分解3X3矩阵_RQ <公开 静态 注释 = "RQDecomp3x3,计算3x3矩阵的RQ分解.">
    参数 输入矩阵 <类型 = CV矩阵类>
    参数 输出矩阵R <类型 = CV矩阵类>
    参数 输出矩阵Q <类型 = CV矩阵类>
    {
        @ cv::RQDecomp3x3(@<输入矩阵>.obj, @<输出矩阵R>.obj, @<输出矩阵Q>.obj);
    }

    方法 分解投影矩阵到相机姿态 <公开 静态 注释 = "decomposeProjectionMatrix,将投影矩阵分解为旋转矩阵和相机固有矩阵">
    参数 投影矩阵 <类型 = CV矩阵类>
    参数 输出相机内参 <类型 = CV矩阵类 注释 = "输出相机内部参数的3x3浮点矩阵">
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    {
        @ cv::decomposeProjectionMatrix(@<投影矩阵>.obj, @<输出相机内参>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj);
    }

    方法 计算相乘矩阵乘积偏导 <公开 静态 注释 = "matMulDeriv,计算每个相乘矩阵的矩阵乘积的偏导.">
    参数 矩阵A <类型 = CV矩阵类>
    参数 矩阵B <类型 = CV矩阵类>
    参数 偏导A <类型 = CV矩阵类>
    参数 偏导B <类型 = CV矩阵类>
    {
        @ cv::matMulDeriv(@<矩阵A>.obj, @<矩阵B>.obj, @<偏导A>.obj, @<偏导B>.obj);
    }

    方法 组合两个姿态 <公开 静态 注释 = "composeRT,将两个姿态组合到一起,形成新的姿态.">
    参数 输入平移矢量1 <类型 = CV矩阵类>
    参数 输入旋转矢量1 <类型 = CV矩阵类>
    参数 输入平移矢量2 <类型 = CV矩阵类>
    参数 输入旋转矢量2 <类型 = CV矩阵类>
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "组合得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "组合得到的坐标平移矢量">
    {
        @ cv::composeRT(@<输入平移矢量1>.obj, @<输入旋转矢量1>.obj, @<输入平移矢量2>.obj, @<输入旋转矢量2>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj);
    }

    方法 投影坐标 <公开 静态 注释 = "projectPoints,将3D点投影到图像平面.">
    参数 世界坐标 <类型 = CV坐标3f容器 注释 = "真实世界坐标点">
    参数 旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 输出图像坐标 <类型 = CV坐标2f容器 注释 = "输出世界坐标投影在图像中的坐标点">
    {
        @ cv::projectPoints(@<世界坐标>.obj, @<旋转矢量>.obj, @<平移矢量>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<输出图像坐标>.obj);
    }

    方法 计算矩阵范数 <公开 静态 类型 = 小数 注释 = "norm,矩阵范数求解." 返回值注释 = "返回范数" @禁止流程检查 = 真>
    参数 源矩阵 <类型 = CV矩阵类 注释 = "欲求解的矩阵">
    参数 计算方法 <类型 = CV归一化常量 @默认值 = CV归一化常量.L2归一化>
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时对对全矩阵计算,否则只计算掩膜范围内的矩阵元素." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            @ return cv::norm(@<源矩阵>.obj, @<计算方法>);
        }
        否则
        {
            @ return cv::norm(@<源矩阵>.obj, @<计算方法>, @<掩膜>.obj);
        }
    }

    方法 计算矩阵范数1 <公开 静态 类型 = 小数 注释 = "norm,计算两矩阵绝对差范数或相对差范数." 返回值注释 = "返回范数" @禁止流程检查 = 真>
    参数 源矩阵1 <类型 = CV矩阵类 注释 = "欲求解的矩阵1,与 原矩阵2 具有相同的数值类型.">
    参数 源矩阵2 <类型 = CV矩阵类 注释 = "欲求解的矩阵2,与 原矩阵1 具有相同的数值类型.">
    参数 计算方法 <类型 = CV归一化常量 @默认值 = CV归一化常量.L2归一化>
    参数 掩膜 <类型 = CV矩阵类 注释 = "为空时对对全矩阵计算,否则只计算掩膜范围内的矩阵元素." @默认值 = 空对象>
    {
        如果 (掩膜 == 空对象)
        {
            @ return cv::norm(@<源矩阵1>.obj, @<源矩阵2>.obj, @<计算方法>);
        }
        否则
        {
            @ return cv::norm(@<源矩阵1>.obj, @<源矩阵2>.obj, @<计算方法>, @<掩膜>.obj);
        }
    }

    方法 矫正图像 <公开 静态 注释 = "undistort,使用相机内参、矫正系数转换图像以补偿镜头径向畸变.">
    参数 源图像 <类型 = CV矩阵类 注释 = "欲矫正的图像">
    参数 输出矫正图像 <类型 = CV矩阵类 注释 = "已矫正的图像">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    {
        @ cv::undistort(@<源图像>.obj, @<输出矫正图像>.obj, @<相机内参>.obj, @<矫正系数>.obj);
    }

    方法 矫正坐标 <公开 静态 注释 = "undistortPoints,使用相机内参、矫正系数转换坐标以补偿镜头径向畸变.">
    参数 源矩阵 <类型 = CV矩阵类 注释 = "观测点坐标,2xN/Nx2 1通道或1xN/Nx1 2通道 浮点2通道32位 或者 浮点2通道64位.">
    参数 输出矫正坐标 <类型 = CV矩阵类 注释 = "输出已矫正的坐标点">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 R <类型 = CV矩阵类 注释 = "R对象空间(3x3矩阵)的整流变换,如果矩阵为空,则使用恒等变换." @默认值 = 空对象>
    参数 P <类型 = CV矩阵类 注释 = "新的相机矩阵(3x3)或新的投影矩阵(3x4),如果矩阵为空,则使用单位新相机矩阵." @默认值 = 空对象>
    {
        变量 r <类型 = CV矩阵类>
        变量 p <类型 = CV矩阵类>
        如果 (R != 空对象)
        {
            r = R
        }
        如果 (P != 空对象)
        {
            p = P
        }
        @ cv::undistortPoints(@<源矩阵>.obj, @<输出矫正坐标>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<r>.obj, @<p>.obj);
    }

    方法 计算矫正图像点位置 <公开 静态 注释 = "undistortImagePoints,计算未失真图像点的位置.">
    参数 输入观察点 <类型 = CV坐标2f容器数组 注释 = "观察点位置,2xN/Nx2 1通道或1xN/Nx1 2通道.">
    参数 输出矫正点 <类型 = CV坐标2f容器数组 注释 = "矫正点位置,2xN/Nx2 1通道或1xN/Nx1 2通道.">
    参数 相机内参 <类型 = CV矩阵类>
    参数 矫正系数 <类型 = CV矩阵类>
    参数 迭代标志 <类型 = CV迭代算法标志类>
    {
        @ cv::undistortImagePoints(@<输入观察点>.obj, @<输出矫正点>.obj, @<相机内参>.obj, @<矫正系数>.obj, @<迭代标志>.obj);
    }

    方法 获取新相机默认内参 <公开 静态 类型 = CV矩阵类 注释 = "getDefaultNewCameraMatrix,返回默认的新相机内参矩阵." "">
    参数 原相机内参 <类型 = CV矩阵类 注释 = "输入原相机内部参数的3x3浮点矩阵">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸,默认为空,不作改变." @默认值 = 空对象>
    参数 主点是否在中心 <类型 = 逻辑型 注释 = "新相机矩阵中主点的位置. 参数指示该位置是否应该位于图像中心" @默认值 = 假>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        如果 (图像尺寸 == 空对象)
        {
            变量 临时尺寸 <类型 = CV尺寸类>
            @ @<返回矩阵>.obj =  cv::getDefaultNewCameraMatrix(@<原相机内参>.obj, @<临时尺寸>.obj, @<主点是否在中心>);
        }
        否则
        {
            @ @<返回矩阵>.obj =  cv::getDefaultNewCameraMatrix(@<原相机内参>.obj, @<图像尺寸>.obj, @<主点是否在中心>);
        }
        返回 (返回矩阵)
    }

    方法 初始化广角映射源 <公开 静态 类型 = 小数 注释 = "initWideAngleProjMap,为广角的函数  几何变换 初始化映射,函数原型无基本注释." 返回值注释 = "返回" @禁止流程检查 = 真>
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 目标图像宽度 <类型 = 整数>
    参数 期望输出类型 <类型 = CV矩阵通道类型常量 注释 = "只支持 CV矩阵通道类型常量.浮点1通道32位 或 浮点2通道32位" "">
    参数 输出映射源1 <类型 = CV矩阵类>
    参数 输出映射源2 <类型 = CV矩阵类>
    参数 映射类型 <类型 = 整数 注释 = "参数值有以下类型" 注释 = "    PROJ_SPHERICAL_ORTHO  = 0,  正交模式." 注释 = "    PROJ_SPHERICAL_EQRECT = 1,平行四边形模式."
            "">
    参数 alpha <类型 = 小数 注释 = "函数原型未作注释与说明,默认值为0" @默认值 = 0>
    {
        @ return cv::initWideAngleProjMap(@<相机内参>.obj, @<矫正系数>.obj, @<图像尺寸>.obj, @<目标图像宽度>, @<期望输出类型>, @<输出映射源1>.obj, @<输出映射源2>.obj, @<映射类型>, @<alpha>);
    }

    方法 计算投影和逆变换映射 <公开 静态 注释 = "initInverseRectificationMap,计算投影和逆变换映射. 从本质上讲,这是#计算投影和正变换映射 的逆操作,以适应投影仪-相机对中投影仪(“反向相机”)的立体校正.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 R <类型 = CV矩阵类 注释 = "R对象空间(3x3矩阵)中的可选整流变换. R1或R2,由#计算两相机正交变换 计算,可以在这里传递. 如果矩阵为空,则假定恒等变换. 在初始化扭曲映射R假设是一个单位矩阵.">
    参数 新相机内参 <类型 = CV矩阵类 注释 = "由函数 获取新相机默认内参 获取">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 映射类型 <类型 = 整数 注释 = "参数值有以下类型" 注释 = "    PROJ_SPHERICAL_ORTHO  = 0,  正交模式." 注释 = "    PROJ_SPHERICAL_EQRECT = 1,平行四边形模式."
            "">
    参数 输出映射源1 <类型 = CV矩阵类>
    参数 输出映射源2 <类型 = CV矩阵类>
    {
        @ cv::initInverseRectificationMap(@<相机内参>.obj, @<矫正系数>.obj, @<R>.obj, @<新相机内参>.obj, @<图像尺寸>.obj, @<映射类型>, @<输出映射源1>.obj, @<输出映射源2>.obj);
    }

    方法 计算投影和正变换映射 <公开 静态 注释 = "initUndistortRectifyMap,计算投影和逆变换映射. 从本质上讲,这是#计算投影和正变换映射 的逆操作,以适应投影仪-相机对中投影仪(“反向相机”)的立体校正.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 R <类型 = CV矩阵类 注释 = "R对象空间(3x3矩阵)中的可选整流变换. R1或R2,由#计算两相机正交变换 计算,可以在这里传递. 如果矩阵为空,则假定恒等变换. 在初始化扭曲映射R假设是一个单位矩阵.">
    参数 新相机内参 <类型 = CV矩阵类 注释 = "由函数 获取新相机默认内参 获取">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 映射类型 <类型 = 整数 注释 = "参数值有以下类型" 注释 = "    PROJ_SPHERICAL_ORTHO  = 0,  正交模式." 注释 = "    PROJ_SPHERICAL_EQRECT = 1,平行四边形模式."
            "">
    参数 输出映射源1 <类型 = CV矩阵类>
    参数 输出映射源2 <类型 = CV矩阵类>
    {
        @ cv::initUndistortRectifyMap(@<相机内参>.obj, @<矫正系数>.obj, @<R>.obj, @<新相机内参>.obj, @<图像尺寸>.obj, @<映射类型>, @<输出映射源1>.obj, @<输出映射源2>.obj);
    }

    方法 计算两相机正交变换 <公开 静态 注释 = "stereoRectify,计算校正立体相机的每个镜头的校正变换.">
    参数 相机内参1 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵1">
    参数 矫正系数1 <类型 = CV矩阵类 注释 = "失真系数输入向量1">
    参数 相机内参2 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵2">
    参数 矫正系数2 <类型 = CV矩阵类 注释 = "失真系数输入向量2">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 R <类型 = CV矩阵类 注释 = "从第一摄像机的坐标系到第二摄像机的旋转矩阵">
    参数 T <类型 = CV矩阵类 注释 = "从第一摄像机的坐标系到第二摄像机的平移向量">
    参数 输出R1 <类型 = CV矩阵类 注释 = "输出第一个相机的3x3整流变换(旋转矩阵).">
    参数 输出R2 <类型 = CV矩阵类 注释 = "输出第二个相机的3x3整流变换(旋转矩阵).">
    参数 输出P1 <类型 = CV矩阵类 注释 = "输出3x4投影矩阵在新的(整流)坐标系的第一个相机">
    参数 输出P2 <类型 = CV矩阵类 注释 = "输出3x4投影矩阵在新的(整流)坐标系的第二个相机">
    参数 输出Q <类型 = CV矩阵类 注释 = "输出4x4差到深度的映射矩阵">
    {
        @ cv::stereoRectify(@<相机内参1>.obj, @<矫正系数1>.obj, @<相机内参2>.obj, @<矫正系数2>.obj, @<图像尺寸>.obj, @<R>.obj, @<T>.obj, @<输出R1>.obj, @<输出R2>.obj, @<输出P1>.obj, @<输出P2>.obj, @<输出Q>.obj);
    }

    方法 计算未标定相机正交变换 <公开 静态 类型 = 逻辑型 注释 = "stereoRectifyUncalibrated,为未标定的立体相机计算校正变换." 返回值注释 = "计算成功返回真,否则返回假." @禁止流程检查 = 真>
    参数 坐标点1 <类型 = CV矩阵类 注释 = "第一张图像中的特征点数组">
    参数 坐标点2 <类型 = CV矩阵类 注释 = "第二张图像中的特征点数组.">
    参数 F <类型 = CV矩阵类 注释 = "输入基本矩阵,它可以从相同的点对集合中计算# 计算基本矩阵_从对应点.">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 H1 <类型 = CV矩阵类 注释 = "输出第一张图像的整流单应性矩阵">
    参数 H2 <类型 = CV矩阵类 注释 = "输出第二幅图像的整流单应矩阵">
    参数 阈值 <类型 = 小数 注释 = "可选阈值,用于过滤异常值." @默认值 = 5>
    {
        @ return cv::stereoRectifyUncalibrated(@<坐标点1>.obj, @<坐标点2>.obj, @<F>.obj, @<图像尺寸>.obj, @<H1>.obj, @<H2>.obj, @<阈值>);
    }

    方法 计算基本矩阵_从对应点 <公开 静态 类型 = CV矩阵类 注释 = "findFundamentalMat, 从两个图像的对应点计算基本矩阵." 返回值注释 = "返回基本矩阵">
    参数 坐标点1 <类型 = CV矩阵类 注释 = "第一张图像中的特征点数组">
    参数 坐标点2 <类型 = CV矩阵类 注释 = "第二张图像中的特征点数组.">
    参数 采用算法 <类型 = 整数 注释 = "FM_7POINT = 1,  7点算法." 注释 = "FM_8POINT = 2,  8点算法." 注释 = "FM_LMEDS  = 4,  最小中值法. 采用7点算法."
            注释 = "FM_RANSAC = 8, 随机样本法. 至少需要15个点." @默认值 = 8>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::findFundamentalMat(@<坐标点1>.obj, @<坐标点2>.obj, @<采用算法>);
        返回 (返回矩阵)
    }

    方法 计算基本矩阵 <公开 静态 类型 = CV矩阵类 注释 = "findEssentialMat,从两幅图像中的对应点计算基本矩阵." 返回值注释 = "返回基本矩阵">
    参数 坐标点1 <类型 = CV矩阵类 注释 = "第一张图像中的特征点数组">
    参数 坐标点2 <类型 = CV矩阵类 注释 = "第二张图像中的特征点数组.">
    参数 相机内参 <类型 = CV矩阵类>
    参数 计算方法 <类型 = 整数 注释 = "计算方法:" 注释 = "       LMEDS  = 4,  最小二乘法" 注释 = "       RANSAC = 8,  RANSAC算法"
            注释 = "       RHO    = 16,  RHO算法" 注释 = "       USAC_DEFAULT  = 32, USAC算法,默认算法"
            注释 = "       USAC_PARALLEL = 33,  USAC并行算法" 注释 = "       USAC_FM_8PTS = 34,   USAC基本矩阵8点算法"
            注释 = "       USAC_FAST = 35,          USAC快速算法" 注释 = "       USAC_ACCURATE = 36, USAC精确算法"
            注释 = "       USAC_PROSAC = 37,   USAC排序点且运行PROSAC" 注释 = "       USAC_MAGSAC = 38   USAC且运行MAGSAC++">
    参数 期望置信度 <类型 = 小数 注释 = "参数仅用于RANSAC或LMedS方法,它规定了估计矩阵正确的期望置信度." @默认值 = 0.999>
    参数 阈值 <类型 = 小数 注释 = "阈值参数用于RANSAC.它是从一个点到外极线的最大距离(以像素为单位)," 注释 = "超过该距离,该点被视为离群值,不用于计算最终的基本矩阵.它可以设置为1-3,"
            注释 = "具体取决于点定位的精度,图像分辨率和图像噪声." @默认值 = 1.0>
    参数 最大迭代次数 <类型 = 整数 注释 = "迭代的最大次数" @默认值 = 1000>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = cv::findEssentialMat(@<坐标点1>.obj, @<坐标点2>.obj, @<相机内参>.obj, @<计算方法>, @<期望置信度>, @<阈值>, @<最大迭代次数>);
        返回 (返回矩阵)
    }

    方法 分解基本矩阵到矢量 <公开 静态 注释 = "decomposeEssentialMat,将基本矩阵分解为可能的旋转和平移矢量.">
    参数 输入基本矩阵 <类型 = CV矩阵类>
    参数 输出旋转矢量1 <类型 = CV矩阵类>
    参数 输出旋转矢量2 <类型 = CV矩阵类>
    参数 输出平移矢量 <类型 = CV矩阵类>
    {
        @ cv::decomposeEssentialMat(@<输入基本矩阵>.obj, @<输出旋转矢量1>.obj, @<输出旋转矢量2>.obj, @<输出平移矢量>.obj);
    }

    方法 从两相机对应点计算矢量 <公开 静态 注释 = "recoverPose,检查从两个不同相机的两个图像中的相应点恢复相机的相对旋转和平移." 注释 = "返回通过检查的内嵌线数.">
    参数 输入坐标点1 <类型 = CV矩阵类>
    参数 输入坐标点2 <类型 = CV矩阵类>
    参数 输入相机内参1 <类型 = CV矩阵类>
    参数 输入矫正系数1 <类型 = CV矩阵类>
    参数 输入相机内参2 <类型 = CV矩阵类>
    参数 输入矫正系数2 <类型 = CV矩阵类>
    参数 输出基本矩阵E <类型 = CV矩阵类>
    参数 输出旋转矩阵R <类型 = CV矩阵类>
    参数 输出平移矩阵T <类型 = CV矩阵类>
    参数 计算方法 <类型 = 整数 注释 = "计算方法:" 注释 = "       LMEDS  = 4,  最小二乘法" 注释 = "       RANSAC = 8,  RANSAC算法"
            注释 = "       RHO    = 16,  RHO算法" 注释 = "       USAC_DEFAULT  = 32, USAC算法,默认算法"
            注释 = "       USAC_PARALLEL = 33,  USAC并行算法" 注释 = "       USAC_FM_8PTS = 34,   USAC基本矩阵8点算法"
            注释 = "       USAC_FAST = 35,          USAC快速算法" 注释 = "       USAC_ACCURATE = 36, USAC精确算法"
            注释 = "       USAC_PROSAC = 37,   USAC排序点且运行PROSAC" 注释 = "       USAC_MAGSAC = 38   USAC且运行MAGSAC++">
    参数 期望置信度 <类型 = 小数 注释 = "参数仅用于RANSAC或LMedS方法,它规定了估计矩阵正确的期望置信度." @默认值 = 0.999>
    参数 阈值 <类型 = 小数 注释 = "阈值参数用于RANSAC.它是从一个点到外极线的最大距离(以像素为单位)," 注释 = "超过该距离,该点被视为离群值,不用于计算最终的基本矩阵.它可以设置为1-3,"
            注释 = "具体取决于点定位的精度,图像分辨率和图像噪声." @默认值 = 1.0>
    {
        @ cv::recoverPose(@<输入坐标点1>.obj, @<输入坐标点2>.obj, @<输入相机内参1>.obj, @<输入矫正系数1>.obj, @<输入相机内参2>.obj, @<输入矫正系数2>.obj, @<输出基本矩阵E>.obj, @<输出旋转矩阵R>.obj, @<输出平移矩阵T>.obj, @<计算方法>, @<期望置信度>, @<阈值>);
    }

    方法 计算对应延长线 <公开 静态 注释 = "computeCorrespondEpilines,对于立体对图像中的点,计算另一个图像中相应的外延线.">
    参数 输入坐标点 <类型 = CV矩阵类>
    参数 图像索引 <类型 = 整数 注释 = "包含坐标点的图像索引">
    参数 基本矩阵 <类型 = CV矩阵类 注释 = "使用函数 计算基本矩阵_从对应点 计算得到">
    参数 输出延长线 <类型 = CV矩阵类>
    {
        @ cv::computeCorrespondEpilines(@<输入坐标点>.obj, @<图像索引>, @<基本矩阵>.obj, @<输出延长线>.obj);
    }

    方法 重建三维坐标 <公开 静态 注释 = "triangulatePoints,此函数通过使用立体相机的观测值重建三维点(在均匀坐标中).">
    参数 投影矩阵1 <类型 = CV矩阵类 注释 = "第一台相机的投影矩阵">
    参数 投影矩阵2 <类型 = CV矩阵类 注释 = "第二台相机的投影矩" "">
    参数 特征点矩阵1 <类型 = CV矩阵类 注释 = "第一幅图像中2xN个特征点阵列">
    参数 特征点矩阵2 <类型 = CV矩阵类 注释 = "第二幅图像中2xN个特征点阵列">
    参数 输出重建坐标 <类型 = CV矩阵类 注释 = "同质坐标中重建点的4xN数组">
    {
        @ cv::triangulatePoints(@<投影矩阵1>.obj, @<投影矩阵2>.obj, @<特征点矩阵1>.obj, @<特征点矩阵2>.obj, @<输出重建坐标>.obj);
    }

    方法 匹配并更正坐标 <公开 静态 注释 = "correctMatches,匹配更正坐标点.">
    参数 输入基本矩阵 <类型 = CV矩阵类 注释 = "3X3的基本矩阵">
    参数 源坐标1 <类型 = CV矩阵类 注释 = "包含第一组点的1xN数组">
    参数 源坐标2 <类型 = CV矩阵类 注释 = "包含第二组点的1xN数组">
    参数 更正坐标1 <类型 = CV矩阵类>
    参数 更正坐标2 <类型 = CV矩阵类>
    {
        @ cv::correctMatches(@<输入基本矩阵>.obj, @<源坐标1>.obj, @<源坐标2>.obj, @<更正坐标1>.obj, @<更正坐标2>.obj);
    }

    方法 过滤视差图小波斑点 <公开 静态 注释 = "filterSpeckles,滤除视差图中的小噪波斑点.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入的16位有符号视差图像">
    参数 视差值 <类型 = 整数 注释 = "用于绘制斑点的视差值">
    参数 最大斑点尺寸 <类型 = 整数 注释 = "将其视为散斑的最大散斑大小,较大的斑点不受算法影响.">
    参数 最大视差 <类型 = 小数 注释 = "相邻视差像素之间的最大差值">
    {
        @ cv::filterSpeckles(@<源图像>.obj, @<视差值>, @<最大斑点尺寸>, @<最大视差>);
    }

    方法 计算有效视差ROI <公开 静态 注释 = "getValidDisparityROI," 注释 = "根据校正图像的有效ROI(一般由函数 双目矫正 传递)计算有效视差ROI.">
    参数 图像1ROI <类型 = CV矩形类>
    参数 图像2ROI <类型 = CV矩形类>
    参数 最小差异 <类型 = 整数>
    参数 差异数目 <类型 = 整数>
    参数 块尺寸 <类型 = 整数>
    {
        @ cv::getValidDisparityROI(@<图像1ROI>.obj, @<图像2ROI>.obj, @<最小差异>, @<差异数目>, @<块尺寸>);
    }

    方法 验证视差 <公开 静态 注释 = "validateDisparity,使用左右检查验证视差,矩阵“成本矩阵”应通过立体对应算法计算.">
    参数 输入视差矩阵 <类型 = CV矩阵类 注释 = "该矩阵会被更新输出">
    参数 成本矩阵 <类型 = CV矩阵类>
    参数 最小差异 <类型 = 整数>
    参数 差异数目 <类型 = 整数>
    参数 最大显示 <类型 = 整数 注释 = "原名称 disp12MaxDisp,未标注定义." @默认值 = 1>
    {
        @ cv::validateDisparity(@<输入视差矩阵>.obj, @<成本矩阵>.obj, @<最小差异>, @<差异数目>, @<最大显示>);
    }

    方法 投影图像到3D <公开 静态 注释 = "reprojectImageTo3D,将图像投影到三维.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入单通道8位无符号、16位有符号、32位有符号或32位浮点视差图像.">
    参数 输出结果 <类型 = CV矩阵类>
    参数 投影变换矩阵 <类型 = CV矩阵类 注释 = "可以用函数 计算两相机正交变换 获得的透视变换矩阵">
    参数 是否处理缺失值 <类型 = 逻辑型 注释 = "指示函数是否应处理缺失值(即未计算差异的点)" @默认值 = 假>
    {
        @ cv::reprojectImageTo3D(@<源图像>.obj, @<输出结果>.obj, @<投影变换矩阵>.obj, @<是否处理缺失值>);
    }

    方法 计算采样距离 <公开 静态 类型 = 小数 注释 = "sampsonDistance,计算两点之间的采样距离." 返回值注释 = "返回采样距离" @禁止流程检查 = 真>
    参数 坐标点1 <类型 = CV矩阵类 注释 = "第一个均匀2d点">
    参数 坐标点2 <类型 = CV矩阵类 注释 = "第二个均匀2d点">
    参数 基本矩阵 <类型 = CV矩阵类>
    {
        @ return cv::sampsonDistance(@<坐标点1>.obj, @<坐标点2>.obj, @<基本矩阵>.obj);
    }

    方法 计算3D点集最佳仿射变换 <公开 静态 类型 = 整数 注释 = "estimateAffine3D,计算两个3D点集之间的最佳仿射变换." 返回值注释 = "函数返回值原型未注释" @禁止流程检查 = 真>
    参数 输入原坐标点 <类型 = CV矩阵类>
    参数 输入目标坐标点 <类型 = CV矩阵类>
    参数 输出3D仿射变换矩阵 <类型 = CV矩阵类>
    参数 输出内嵌值 <类型 = CV矩阵类 注释 = "表示哪些点是inlier的输出向量(1-内嵌,0-离群)">
    参数 最大误差 <类型 = 小数 注释 = "RANSAC算法中将点视为内层的最大重投影误差" @默认值 = 3>
    参数 最小置信度 <类型 = 小数 注释 = "取值范围0-1" @默认值 = 0.9>
    {
        @ return cv::estimateAffine3D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, @<输出3D仿射变换矩阵>.obj, @<输出内嵌值>.obj, @<最大误差>, @<最小置信度>);
    }

    方法 计算3D点集最佳平移变换 <公开 静态 注释 = "estimateTranslation3D,计算两个三维点集之间的最佳平移.">
    参数 输入原坐标点 <类型 = CV矩阵类>
    参数 输入目标坐标点 <类型 = CV矩阵类>
    参数 输出3D平移变换矩阵 <类型 = CV矩阵类>
    参数 输出内嵌值 <类型 = CV矩阵类 注释 = "表示哪些点是inlier的输出向量(1-内嵌,0-离群)">
    参数 最大误差 <类型 = 小数 注释 = "RANSAC算法中将点视为内层的最大重投影误差" @默认值 = 3>
    参数 最小置信度 <类型 = 小数 注释 = "取值范围0-1" @默认值 = 0.9>
    {
        @ cv::estimateTranslation3D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, @<输出3D平移变换矩阵>.obj, @<输出内嵌值>.obj, @<最大误差>, @<最小置信度>);
    }

    方法 计算2D点集最佳仿射变换 <公开 静态 类型 = CV矩阵类 注释 = "estimateAffine2D,计算两个2D点集之间的最佳仿射变换." 返回值注释 = "返回仿射变换矩阵">
    参数 输入原坐标点 <类型 = CV矩阵类>
    参数 输入目标坐标点 <类型 = CV矩阵类>
    参数 输出内嵌值 <类型 = CV矩阵类 注释 = "为空时不输出,表示哪些点是inlier的输出向量(1-内嵌,0-离群)" @默认值 = 空对象>
    参数 计算方法 <类型 = 整数 注释 = "计算方法:" 注释 = "       LMEDS  = 4,  最小二乘法" 注释 = "       RANSAC = 8,  RANSAC算法"
            注释 = "       RHO    = 16,  RHO算法" 注释 = "       USAC_DEFAULT  = 32, USAC算法,默认算法"
            注释 = "       USAC_PARALLEL = 33,  USAC并行算法" 注释 = "       USAC_FM_8PTS = 34,   USAC基本矩阵8点算法"
            注释 = "       USAC_FAST = 35,          USAC快速算法" 注释 = "       USAC_ACCURATE = 36, USAC精确算法"
            注释 = "       USAC_PROSAC = 37,   USAC排序点且运行PROSAC" 注释 = "       USAC_MAGSAC = 38   USAC且运行MAGSAC++" @默认值 = 8>
    参数 最大误差 <类型 = 小数 注释 = "RANSAC算法中将点视为内层的最大重投影误差" @默认值 = 3>
    参数 最大迭代次数 <类型 = 整数 @默认值 = 2000>
    参数 最小置信度 <类型 = 小数 注释 = "取值范围0-1" @默认值 = 0.99>
    参数 细化迭代次数 <类型 = 整数 注释 = "细化算法的最大迭代次数(Levenberg-Marquardt)," 注释 = "传递0将禁用细化.因此输出矩阵将是鲁棒方法的输出.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        如果 (输出内嵌值 != 空对象)
        {
            @ @<返回矩阵>.obj = cv::estimateAffine2D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, @<输出内嵌值>.obj, @<计算方法>,@<最大误差>, @<最大迭代次数>, @<最小置信度>,@<细化迭代次数>);
        }
        否则
        {
            @ @<返回矩阵>.obj = cv::estimateAffine2D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, noArray(), @<计算方法>,@<最大误差>, @<最大迭代次数>, @<最小置信度>,@<细化迭代次数>);
        }
        返回 (返回矩阵)
    }

    方法 计算2D点集最佳平移变换 <公开 静态 类型 = CV矩阵类 注释 = "estimateAffinePartial2D,计算两个2D点集之间的最佳平移变换." 返回值注释 = "返回平移变换矩阵">
    参数 输入原坐标点 <类型 = CV矩阵类>
    参数 输入目标坐标点 <类型 = CV矩阵类>
    参数 输出内嵌值 <类型 = CV矩阵类 注释 = "为空时不输出,表示哪些点是inlier的输出向量(1-内嵌,0-离群)" @默认值 = 空对象>
    参数 计算方法 <类型 = 整数 注释 = "计算方法:" 注释 = "       LMEDS  = 4,  最小二乘法" 注释 = "       RANSAC = 8,  RANSAC算法"
            注释 = "       RHO    = 16,  RHO算法" 注释 = "       USAC_DEFAULT  = 32, USAC算法,默认算法"
            注释 = "       USAC_PARALLEL = 33,  USAC并行算法" 注释 = "       USAC_FM_8PTS = 34,   USAC基本矩阵8点算法"
            注释 = "       USAC_FAST = 35,          USAC快速算法" 注释 = "       USAC_ACCURATE = 36, USAC精确算法"
            注释 = "       USAC_PROSAC = 37,   USAC排序点且运行PROSAC" 注释 = "       USAC_MAGSAC = 38   USAC且运行MAGSAC++" @默认值 = 8>
    参数 最大误差 <类型 = 小数 注释 = "RANSAC算法中将点视为内层的最大重投影误差" @默认值 = 3>
    参数 最大迭代次数 <类型 = 整数 @默认值 = 2000>
    参数 最小置信度 <类型 = 小数 注释 = "取值范围0-1" @默认值 = 0.99>
    参数 细化迭代次数 <类型 = 整数 注释 = "细化算法的最大迭代次数(Levenberg-Marquardt)," 注释 = "传递0将禁用细化.因此输出矩阵将是鲁棒方法的输出.">
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        如果 (输出内嵌值 != 空对象)
        {
            @ @<返回矩阵>.obj = cv::estimateAffinePartial2D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, @<输出内嵌值>.obj, @<计算方法>,@<最大误差>, @<最大迭代次数>, @<最小置信度>,@<细化迭代次数>);
        }
        否则
        {
            @ @<返回矩阵>.obj = cv::estimateAffinePartial2D(@<输入原坐标点>.obj, @<输入目标坐标点>.obj, noArray(), @<计算方法>,@<最大误差>, @<最大迭代次数>, @<最小置信度>,@<细化迭代次数>);
        }
        返回 (返回矩阵)
    }

    方法 分解单应矩阵 <公开 静态 注释 = "decomposeHomographyMat,将单应矩阵分解为旋转、平移和平面法线.">
    参数 输入单应矩阵 <类型 = CV矩阵类 注释 = "两幅图像之间的输入单应矩阵">
    参数 输入相机固有矩阵 <类型 = CV矩阵类 注释 = "输入摄像机固有矩阵">
    参数 输出旋转矩阵数组 <类型 = CV矩阵类容器>
    参数 输出平移矩阵数组 <类型 = CV矩阵类容器>
    参数 输出法线矩阵数组 <类型 = CV矩阵类容器>
    {
        @ cv::decomposeHomographyMat(@<输入单应矩阵>.obj, @<输入相机固有矩阵>.obj, @<输出旋转矩阵数组>.obj, @<输出平移矩阵数组>.obj, @<输出法线矩阵数组>.obj);
    }

    方法 过滤单应分解矩阵 <公开 静态 注释 = "filterHomographyDecompByVisibleRefpoints,基于附加信息过滤单应分解.">
    参数 输入旋转矩阵数组 <类型 = CV矩阵类容器>
    参数 输入平移矩阵数组 <类型 = CV矩阵类容器>
    参数 输入矫正前的点 <类型 = CV矩阵类 注释 = "应用单应性之前(校正的)可见参考点矢量">
    参数 输入矫正后的点 <类型 = CV矩阵类>
    参数 输出索引向量 <类型 = CV矩阵类 注释 = "表示筛选后可行解集的整数索引向量">
    参数 计算掩膜 <类型 = CV矩阵类 注释 = "默认为空,计算全部区域." @默认值 = 空对象>
    {
        如果 (计算掩膜 == 空对象)
        {
            @ cv::filterHomographyDecompByVisibleRefpoints(@<输入旋转矩阵数组>.obj, @<输入平移矩阵数组>.obj, @<输入矫正前的点>.obj, @<输入矫正后的点>.obj, @<输出索引向量>.obj);
        }
        否则
        {
            @ cv::filterHomographyDecompByVisibleRefpoints(@<输入旋转矩阵数组>.obj, @<输入平移矩阵数组>.obj, @<输入矫正前的点>.obj, @<输入矫正后的点>.obj, @<输出索引向量>.obj, @<计算掩膜>.obj);
        }
    }

    方法 坐标到齐次坐标 <公开 静态 注释 = "convertPointsHomogeneous,将点转换到齐次坐标.">
    参数 源坐标 <类型 = CV矩阵类 注释 = "需要转换的坐标">
    参数 输出坐标 <类型 = CV矩阵类 注释 = "转换后的坐标">
    {
        @ cv::convertPointsHomogeneous(@<源坐标>.obj, @<输出坐标>.obj);
    }

    方法 齐次坐标到欧式坐标 <公开 静态 注释 = "convertPointsFromHomogeneous,将点从齐次空间坐标转换到欧氏空间坐标.">
    参数 源坐标 <类型 = CV矩阵类 注释 = "需要转换的坐标">
    参数 输出坐标 <类型 = CV矩阵类 注释 = "转换后的坐标">
    {
        @ cv::convertPointsFromHomogeneous(@<源坐标>.obj, @<输出坐标>.obj);
    }

    方法 欧式坐标到齐次坐标 <公开 静态 注释 = "convertPointsToHomogeneous,将点转换到齐次坐标.">
    参数 源坐标 <类型 = CV矩阵类 注释 = "需要转换的坐标">
    参数 输出坐标 <类型 = CV矩阵类 注释 = "转换后的坐标">
    {
        @ cv::convertPointsToHomogeneous(@<源坐标>.obj, @<输出坐标>.obj);
    }

    方法 手眼标定 <公开 静态 注释 = "calibrateHandEye,计算机器人世界/手眼标定">
    参数 旋转矩阵_夹具到机器 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将夹持器系中表示的点转换为机器人基坐标坐标系">
    参数 平移矩阵_夹具到机器 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将夹持器系中表示的点转换为机器人基坐标坐标系">
    参数 旋转矩阵_目标到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将目标点转换为相机框">
    参数 平移矩阵_目标到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将目标点转换为相机框">
    参数 输出旋转矩阵_图像到夹具 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将图像中表示的点转换为夹具坐标">
    参数 输出平移矩阵_图像到夹具 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将图像中表示的点转换为夹具坐标">
    参数 计算方法 <类型 = 整数 注释 = "参数值为：" 注释 = "    CALIB_HAND_EYE_TSAI         = 0, 全自动高效3D机器人手/眼标定新技术"
            注释 = "    CALIB_HAND_EYE_PARK         = 1, 机器人传感器标定:求解欧氏群上的AX = XB" 注释 = "    CALIB_HAND_EYE_HORAUD       = 2, 手眼标定"
            注释 = "    CALIB_HAND_EYE_ANDREFF      = 3, 在线手眼标定" 注释 = "    CALIB_HAND_EYE_DANIILIDIS   = 4 , 使用双四元数手眼校准" @默认值 = 0>
    {
        @ if(@<计算方法>==0)
        @     cv::calibrateHandEye(@<旋转矩阵_夹具到机器>.obj, @<平移矩阵_夹具到机器>.obj, @<旋转矩阵_目标到图像>.obj, @<平移矩阵_目标到图像>.obj, @<输出旋转矩阵_图像到夹具>.obj, @<输出平移矩阵_图像到夹具>.obj, CALIB_HAND_EYE_TSAI);
        @ else if(@<计算方法>==1)
        @     cv::calibrateHandEye(@<旋转矩阵_夹具到机器>.obj, @<平移矩阵_夹具到机器>.obj, @<旋转矩阵_目标到图像>.obj, @<平移矩阵_目标到图像>.obj, @<输出旋转矩阵_图像到夹具>.obj, @<输出平移矩阵_图像到夹具>.obj, CALIB_HAND_EYE_PARK);
        @ else if(@<计算方法>==2)
        @     cv::calibrateHandEye(@<旋转矩阵_夹具到机器>.obj, @<平移矩阵_夹具到机器>.obj, @<旋转矩阵_目标到图像>.obj, @<平移矩阵_目标到图像>.obj, @<输出旋转矩阵_图像到夹具>.obj, @<输出平移矩阵_图像到夹具>.obj, CALIB_HAND_EYE_HORAUD);
        @ else if(@<计算方法>==3)
        @     cv::calibrateHandEye(@<旋转矩阵_夹具到机器>.obj, @<平移矩阵_夹具到机器>.obj, @<旋转矩阵_目标到图像>.obj, @<平移矩阵_目标到图像>.obj, @<输出旋转矩阵_图像到夹具>.obj, @<输出平移矩阵_图像到夹具>.obj, CALIB_HAND_EYE_ANDREFF);
        @ else if(@<计算方法>==4)
        @     cv::calibrateHandEye(@<旋转矩阵_夹具到机器>.obj, @<平移矩阵_夹具到机器>.obj, @<旋转矩阵_目标到图像>.obj, @<平移矩阵_目标到图像>.obj, @<输出旋转矩阵_图像到夹具>.obj, @<输出平移矩阵_图像到夹具>.obj, CALIB_HAND_EYE_DANIILIDIS);
    }

    方法 手眼标定_世界坐标系 <公开 静态 注释 = "calibrateRobotWorldHandEye,计算机器人世界/手眼标定.">
    参数 旋转矩阵_世界到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,它将表示在世界帧中的点转换为相机帧.">
    参数 平移矩阵_世界到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将世界帧中表示的点转换为相机帧.">
    参数 旋转矩阵_机器到夹具 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将机器人基坐标系中表示的点转换为夹持器坐标系.">
    参数 平移矩阵_机器到夹具 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将机器人基坐标系中表示的点转换为夹持器坐标系.">
    参数 输出旋转矩阵_机器到世界 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将机器人基础坐标系中表示的点转换为世界坐标系.">
    参数 输出平移矩阵_机器到世界 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取平移部分,将机器人基坐标系中表示的点转换为世界坐标系.">
    参数 输出旋转矩阵_夹具到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的旋转部分,将夹持框中表示的点转换为相机框.">
    参数 输出平移矩阵_夹具到图像 <类型 = CV矩阵类 注释 = "从齐次矩阵中提取的平移部分,将夹持框中表示的点转换为相机框.">
    参数 计算方法 <类型 = 整数 注释 = "参数值为：" 注释 = "    CALIB_ROBOT_WORLD_HAND_EYE_SHAH = 0, 利用kronecker产品解决机器人世界/手眼校准问题."
            注释 = "    CALIB_ROBOT_WORLD_HAND_EYE_LI   = 1,  使用双四元数和克罗内克乘积同步标定机器人世界和手眼." @默认值 = 0>
    {
        @ if(@<计算方法>==0)
        @    cv::calibrateRobotWorldHandEye(@<旋转矩阵_世界到图像>.obj, @<平移矩阵_世界到图像>.obj, @<旋转矩阵_机器到夹具>.obj, @<平移矩阵_机器到夹具>.obj, @<输出旋转矩阵_机器到世界>.obj, @<输出平移矩阵_机器到世界>.obj, @<输出旋转矩阵_夹具到图像>.obj, @<输出平移矩阵_夹具到图像>.obj, CALIB_ROBOT_WORLD_HAND_EYE_SHAH);
        @ else
        @     cv::calibrateRobotWorldHandEye(@<旋转矩阵_世界到图像>.obj, @<平移矩阵_世界到图像>.obj, @<旋转矩阵_机器到夹具>.obj, @<平移矩阵_机器到夹具>.obj, @<输出旋转矩阵_机器到世界>.obj, @<输出平移矩阵_机器到世界>.obj, @<输出旋转矩阵_夹具到图像>.obj, @<输出平移矩阵_夹具到图像>.obj, CALIB_ROBOT_WORLD_HAND_EYE_LI);
    }

    方法 获取最优相机内参 <公开 静态 类型 = CV矩阵类 注释 = "getOptimalNewCameraMatrix,返回基于自由缩放参数的新的相机固有矩阵." 返回值注释 = "返回最优的新相机内参矩阵">
    参数 相机内参 <类型 = CV矩阵类 注释 = "输入相机内部参数的3x3浮点矩阵">
    参数 矫正系数 <类型 = CV矩阵类 注释 = "失真系数输入向量">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 alpha <类型 = 小数 注释 = "自由缩放参数介于0(当未失真图像中的所有像素都有效时)和1(当未失真图像中的所有源图像像素都保留时)之间">
    参数 新图像尺寸 <类型 = CV尺寸类>
    参数 主点是否在中心 <类型 = 逻辑型 注释 = "指示在新的相机内征矩阵中主点是否应位于图像中心">
    {
        变量 返回内参 <类型 = CV矩阵类>
        @ @<返回内参>.obj = cv::getOptimalNewCameraMatrix(@<相机内参>.obj, @<矫正系数>.obj, @<图像尺寸>.obj, @<alpha>, @<新图像尺寸>.obj, 0, @<主点是否在中心>);
        返回 (返回内参)
    }

    方法 双目相机标定 <公开 静态 注释 = "stereoCalibrate,这个函数找到两个相机的内部参数和两个相机之间的外部参数.">
    参数 世界坐标 <类型 = CV矩阵类 注释 = "标定点在真实世界坐标位置">
    参数 图像坐标1 <类型 = CV矩阵类 注释 = "标定点在在相机1中的坐标位置">
    参数 图像坐标2 <类型 = CV矩阵类 注释 = "标定点在在相机2中的坐标位置">
    参数 相机内参1 <类型 = CV矩阵类 注释 = "相机1的内参,既是输入也是输出 ,用函数 计算相机内参.">
    参数 矫正系数1 <类型 = CV矩阵类 注释 = "相机1的矫正系数,既是输入也是输出 ,用函数 计算相机内参.">
    参数 相机内参2 <类型 = CV矩阵类 注释 = "相机2的内参,既是输入也是输出 ,用函数 计算相机内参.">
    参数 矫正系数2 <类型 = CV矩阵类 注释 = "相机2的矫正系数,既是输入也是输出 ,用函数 计算相机内参.">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 输出R <类型 = CV矩阵类 注释 = "输出旋转矩阵">
    参数 输出T <类型 = CV矩阵类 注释 = "输出平移矩阵">
    参数 输出E <类型 = CV矩阵类 注释 = "输出基本矩阵">
    参数 输出F <类型 = CV矩阵类 注释 = "输出基本矩阵">
    参数 标定方法 <类型 = CV标定方法常量 @默认值 = CV标定方法常量.双目固定内参>
    {
        @ cv::stereoCalibrate(@<世界坐标>.obj, @<图像坐标1>.obj, @<图像坐标2>.obj, @<相机内参1>.obj, @<矫正系数1>.obj, @<矫正系数1>.obj, @<矫正系数2>.obj, @<图像尺寸>.obj, @<输出R>.obj, @<输出T>.obj, @<输出E>.obj, @<输出F>.obj, @<标定方法>);
    }

    方法 双目矫正 <公开 静态 注释 = "stereoRectify,作用是为每个摄像头计算立体校正的映射矩阵一." 注释 = "所以其运行结果并不是直接将图片进行立体矫正,而是得出进行立体矫正所需要的映射矩阵.">
    参数 相机内参1 <类型 = CV矩阵类 注释 = "相机1的内参,用函数 计算相机内参.">
    参数 矫正系数1 <类型 = CV矩阵类 注释 = "相机1的矫正系数,用函数 计算相机内参.">
    参数 相机内参2 <类型 = CV矩阵类 注释 = "相机2的内参,用函数 计算相机内参.">
    参数 矫正系数2 <类型 = CV矩阵类 注释 = "相机2的矫正系数,用函数 计算相机内参.">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 输入R <类型 = CV矩阵类 注释 = "摄像机坐标系间的旋转矩阵">
    参数 输入T <类型 = CV矩阵类 注释 = "摄像机坐标系间的平移向量">
    参数 输出R1 <类型 = CV矩阵类 注释 = "输出第一个相机的3x3整流变换(旋转矩阵)">
    参数 输出R2 <类型 = CV矩阵类 注释 = "输出第二个相机的3x3整流变换(旋转矩阵)">
    参数 输出P1 <类型 = CV矩阵类 注释 = "输出第一个相机3x4投影矩阵在新的(整流)坐标系">
    参数 输出P2 <类型 = CV矩阵类 注释 = "输出第二个相机3x4投影矩阵在新的(整流)坐标系">
    参数 输出Q <类型 = CV矩阵类 注释 = "输出4x4差异到深度映射矩阵">
    {
        @ cv::stereoRectify(@<相机内参1>.obj, @<矫正系数1>.obj, @<相机内参2>.obj, @<矫正系数2>.obj, @<图像尺寸>.obj, @<输入R>.obj, @<输入T>.obj, @<输出R1>.obj, @<输出R2>.obj, @<输出P1>.obj, @<输出P2>.obj, @<输出Q>.obj);
    }

    方法 标定相机特征 <公开 静态 注释 = "calibrationMatrixValues,从相机内参矩阵计算有用的相机特征.">
    参数 相机内参 <类型 = CV矩阵类 注释 = "相机的内参,用函数 计算相机内参.">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "相机采集图像尺寸">
    参数 光圈宽度 <类型 = 小数 注释 = "传感器的物理宽度,单位为毫米.">
    参数 光圈高度 <类型 = 小数 注释 = "传感器的物理高度,单位为毫米.">
    参数 输出X视场 <类型 = 小数类 注释 = "沿水平传感器轴以度表示的输出视场">
    参数 输出Y视场 <类型 = 小数类 注释 = "沿垂直传感器轴以度表示的输出视场">
    参数 输出焦距 <类型 = 小数类 注释 = "镜头焦距,单位为mm.">
    参数 输出基点 <类型 = CV坐标点2d 注释 = "基点(毫米)">
    参数 输出纵横比 <类型 = 小数类 注释 = "相机传感器纵横向比例">
    {
        @ cv::calibrationMatrixValues(@<相机内参>.obj, @<图像尺寸>.obj, @<光圈宽度>, @<光圈高度>,@<输出X视场.值>,@<输出Y视场.值>,@<输出焦距.值>, @<输出基点>.obj, @<输出纵横比.值>);
    }

    方法 计算相机参数_RO <公开 静态 类型 = 小数 注释 = "calibrateCameraRO,从校准模式的几个视图中查找相机的内部和外部参数." @禁止流程检查 = 真>
    参数 世界坐标数组 <类型 = CV坐标3f容器数组 注释 = "每一张标定板图像拥有一组坐标容器">
    参数 图像坐标数组 <类型 = CV坐标2f容器数组 注释 = "每一张标定板图像拥有一组坐标容器">
    参数 图像尺寸 <类型 = CV尺寸类 注释 = "参数 图像坐标  所在的图像尺寸">
    参数 固定点索引 <类型 = 整数 注释 = "世界坐标数组[0]中的3D对象点的索引是固定的,它还充当校准方法选择的开关.">
    参数 输出相机内参 <类型 = CV矩阵类 注释 = "输出相机内部参数的3x3浮点矩阵">
    参数 输出矫正系数 <类型 = CV矩阵类 注释 = "失真系数输出向量">
    参数 输出旋转矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标旋转矢量">
    参数 输出平移矢量 <类型 = CV矩阵类 注释 = "计算得到的坐标平移矢量(通常以米为单位)">
    参数 输出新坐标点 <类型 = CV矩阵类 注释 = "校正模式点的更新输出矢量. 坐标可以根据三个不动的点进行缩放. 只有上述三个不动点准确,返回的坐标才是准确的.">
    {
        @ return cv::calibrateCameraRO(@<世界坐标数组>.obj, @<图像坐标数组>.obj, @<图像尺寸>.obj, @<固定点索引>, @<输出相机内参>.obj, @<输出矫正系数>.obj, @<输出旋转矢量>.obj, @<输出平移矢量>.obj, @<输出新坐标点>.obj);
    }

    方法 寻找标定板_圆形 <公开 注释 = "findCirclesGrid,在圆形标定板中找到圆心.">
    参数 源图像 <类型 = CV矩阵类 注释 = "输入圆的图像网格视图;它必须是8位灰度或彩色图像">
    参数 标定板行列数 <类型 = CV尺寸类 注释 = "每行和每列的圆数">
    参数 输出坐标点 <类型 = CV坐标2f容器 注释 = "找到的标记点位置坐标">
    参数 计算方法 <类型 = 整数 注释 = "计算方法参数如下：" 注释 = "CALIB_CB_SYMMETRIC_GRID  = 1,   对称标点版."
            注释 = "CALIB_CB_ASYMMETRIC_GRID = 2,  非对称标点版." 注释 = "CALIB_CB_CLUSTERING      = 4     ,聚类.">
    参数 斑点检测器 <类型 = CV斑点检测类 注释 = "需要在斑点检测类中设置好标记点形态">
    参数 标点版参数 <类型 = CV圆形标定板查找参数类 注释 = "标定板描述参数">
    {
        @ cv::findCirclesGrid(@<源图像>.obj, @<标定板行列数>.obj, @<输出坐标点>.obj, @<计算方法>, @<斑点检测器>.obj, @<标点版参数>.obj);
    }
}

