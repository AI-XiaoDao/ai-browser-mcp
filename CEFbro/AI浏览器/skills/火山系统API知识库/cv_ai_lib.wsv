类 CV关键点描述符容器类数组 <公开 注释 = "std::vector<vector<cv::DMatch>>">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # std::vector<vector<cv::DMatch>> obj;
    # <> </include>
    # @end

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" 返回值注释 = "返回成员个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV关键点描述符容器类 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "返回 CV关键点描述符容器类">
    参数 成员索引 <类型 = 整数>
    {
        变量 坐标 <类型 = CV关键点描述符容器类>
