类 CV线条常量 <公开 注释 = "LineTypes" @常量类 = 整数>
{
    常量 普通线条 <公开 值 = -1 注释 = "-1,FILLED,普通线条.">
    常量 四倍抗锯齿 <公开 值 = 4 注释 = "4,LINE_4,4倍抗锯齿.">
    常量 八倍抗锯齿 <公开 值 = 8 注释 = "8,LINE_8,8倍抗锯齿.">
    常量 十六倍抗锯齿 <公开 值 = 16 注释 = "16,LINE_AA,16倍抗锯齿.">
}

类 CV视频写入类 <公开 注释 = "VideoWriter,一个将图片写入视频的类."
        "@视窗.附属文件.release-x64" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460_64.dll"
        "@视窗.附属文件.debug-x64" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460d.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460_64.dll"
        "@视窗.附属文件.release-win32" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460.dll"
        "@视窗.附属文件.debug-win32" = "libs\\opencv\\$(p)\\vc16\\bin\\opencv_img_hash460d.dll\r\nlibs\\opencv\\$(p)\\vc16\\bin\\opencv_videoio_ffmpeg460.dll">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::VideoWriter obj;
    # inline_ void @an<_OnCleanupExtra> (){if(obj.isOpened()) obj.release();};
    # <> </include>
    # @end

    方法 是否已经打开 <公开 类型 = 逻辑型 注释 = "isOpened" 返回值注释 = "如果已打开,返回真." @禁止流程检查 = 真>
    {
        @ return obj.isOpened();
    }

    方法 打开 <公开 类型 = 逻辑型 注释 = "open,打开码流,准备开始写入." @禁止流程检查 = 真>
    参数 欲保存的文件路径 <类型 = 文本型 注释 = "例如  c:\\\\aa.mp4">
    参数 视频类型 <类型 = 文本型 注释 = "只能为4字符文本,常用的有以下格式:" 注释 = "1.PIM1,MPEG-1格式,文件名后缀为.avi" 注释 = "2.I420,YUV编码格式,文件名后缀为.avi"
            注释 = "3.XVID,MPEG-4格式,文件名后缀为.mp4" 注释 = "4.DIVX,MPEG-4格式,文件名后缀为.mp4" 注释 = "5.THEO,Ogg Vorbis格式,文件名后缀为.ogv"
            注释 = "6.FLV1,Flash视频格式,文件名后缀为.flv">
    参数 帧率 <类型 = 小数 @默认值 = 15>
    参数 视频宽度 <类型 = 整数>
    参数 视频高度 <类型 = 整数>
    参数 是否彩色 <类型 = 逻辑型 注释 = "如果为真表示是彩色的,否则就是灰色的" @默认值 = 真>
    {
        @ if(obj.isOpened()) return FALSE;
        变量 临时视频类型 <类型 = 字节集类>
        变量 视频类型长度 <类型 = 整数>
        变量 视频类型指针 <类型 = 变整数>
        变量 类型字节1 <类型 = 字节>
        变量 类型字节2 <类型 = 字节>
        变量 类型字节3 <类型 = 字节>
        变量 类型字节4 <类型 = 字节>
        临时视频类型 = 文本到多字节 (视频类型)
        视频类型长度 = 取文本长度 (视频类型)
        视频类型指针 = 临时视频类型.取字节集指针 ()
        如果 (视频类型长度 >= 1)
        {
            类型字节1 = 临时视频类型.取字节集数据 (0, 字节)
        }
        如果 (视频类型长度 >= 2)
        {
            类型字节2 = 临时视频类型.取字节集数据 (1, 字节)
        }
        如果 (视频类型长度 >= 3)
        {
            类型字节3 = 临时视频类型.取字节集数据 (2, 字节)
        }
        如果 (视频类型长度 >= 4)
        {
            类型字节4 = 临时视频类型.取字节集数据 (3, 字节)
        }
        @ @an<CVolMem> memBuf1;
        @ int fourcc = cv::VideoWriter::fourcc(@<类型字节1>,@<类型字节2>,@<类型字节3>,@<类型字节4>);
        @ return obj.open (GetMbsText (@<欲保存的文件路径>.GetText (), memBuf1, NULL),fourcc,@<帧率>,cv::Size(@<视频宽度>,@<视频高度>),@<是否彩色>);
    }

    方法 打开_多参数 <公开 类型 = 逻辑型 注释 = "open,打开码流,准备开始写入." @禁止流程检查 = 真>
    参数 欲保存的文件路径 <类型 = 文本型 注释 = "例如  c:\\\\aa.mp4">
    参数 视频类型 <类型 = 文本型 注释 = "只能为4字符文本,常用的有以下格式:" 注释 = "1.PIM1,MPEG-1格式,文件名后缀为.avi" 注释 = "2.I420,YUV编码格式,文件名后缀为.avi"
            注释 = "3.XVID,MPEG-4格式,文件名后缀为.mp4" 注释 = "4.DIVX,MPEG-4格式,文件名后缀为.mp4" 注释 = "5.THEO,Ogg Vorbis格式,文件名后缀为.ogv"
            注释 = "6.FLV1,Flash视频格式,文件名后缀为.flv">
    参数 帧率 <类型 = 小数 @默认值 = 15>
    参数 视频宽度 <类型 = 整数>
    参数 视频高度 <类型 = 整数>
    参数 参数 <类型 = CV整数容器 注释 = "参见 CV视频写入属性常量" "">
    {
        @ if(obj.isOpened()) return FALSE;
        变量 临时视频类型 <类型 = 字节集类>
        变量 视频类型长度 <类型 = 整数>
        变量 视频类型指针 <类型 = 变整数>
        变量 类型字节1 <类型 = 字节>
        变量 类型字节2 <类型 = 字节>
        变量 类型字节3 <类型 = 字节>
        变量 类型字节4 <类型 = 字节>
        临时视频类型 = 文本到多字节 (视频类型)
        视频类型长度 = 取文本长度 (视频类型)
        视频类型指针 = 临时视频类型.取字节集指针 ()
        如果 (视频类型长度 >= 1)
        {
            类型字节1 = 临时视频类型.取字节集数据 (0, 字节)
        }
        如果 (视频类型长度 >= 2)
        {
            类型字节2 = 临时视频类型.取字节集数据 (1, 字节)
        }
        如果 (视频类型长度 >= 3)
        {
            类型字节3 = 临时视频类型.取字节集数据 (2, 字节)
        }
        如果 (视频类型长度 >= 4)
        {
            类型字节4 = 临时视频类型.取字节集数据 (3, 字节)
        }
        @ @an<CVolMem> memBuf1;
        @ int fourcc = cv::VideoWriter::fourcc(@<类型字节1>,@<类型字节2>,@<类型字节3>,@<类型字节4>);
        @ return obj.open (GetMbsText (@<欲保存的文件路径>.GetText (), memBuf1, NULL),fourcc,@<帧率>,cv::Size(@<视频宽度>,@<视频高度>),@<参数>.obj);
    }

    方法 写入图片 <公开 注释 = "write,在视频中写入一帧图像.">
    参数 图片 <类型 = CV矩阵类 注释 = "需要写入的图像">
    {
        @ obj.write(@<图片>.obj);
    }

    方法 关闭 <公开 注释 = "release,释放掉当前对象.">
    {
        @ if(obj.isOpened()) obj.release();
    }

    方法 设置视频属性 <公开 注释 = "set">
    参数 属性 <类型 = CV视频写入属性常量>
    参数 属性值 <类型 = 小数>
    {
        @ obj.set(@<属性>, @<属性值>);
    }

    方法 获取视频属性 <公开 类型 = 小数 注释 = "get" @禁止流程检查 = 真>
    参数 属性 <类型 = CV视频写入属性常量>
    {
        @ return obj.get(@<属性>);
    }
}

类 CV图像读入常量 <公开 @常量类 = 整数>
{
    常量 不指定 <公开 值 = -1 注释 = "-1,IMREAD_UNCHANGED,按原样返回加载的图像(使用Alpha通道,否则会被裁剪).">
    常量 转灰度图 <公开 值 = 0 注释 = "0,IMREAD_GRAYSCALE,始终将图像转换为单通道灰度图像(编解码器内部转换).">
    常量 转彩色图 <公开 值 = 1 注释 = "1,IMREAD_COLOR,请始终将图像转换为3通道BGR彩色图像.">
    常量 任意深度 <公开 值 = 2 注释 = "2,IMREAD_ANYDEPTH,在输入具有相应深度时返回16位/ 32位图像,否则将其转换为8位.">
    常量 任意颜色空间 <公开 值 = 4 注释 = "4,IMREAD_ANYCOLOR,以任何可能的颜色格式读取图像.">
    常量 使用GDAL加载 <公开 值 = 8 注释 = "8,IMREAD_LOAD_GDAL,使用gdal驱动程序加载图像.">
    常量 转灰度图减小到二分之一 <公开 值 = 16 注释 = "16,IMREAD_REDUCED_GRAYSCALE_2,始终将图像转换为单通道灰度图像,图像尺寸减小1/2.">
    常量 转彩色图减小到二分之一 <公开 值 = 17 注释 = "17,IMREAD_REDUCED_COLOR_2,始终将图像转换为3通道BGR彩色图像,图像尺寸减小1/2.">
    常量 转灰度图减小到四分之一 <公开 值 = 32 注释 = "32,IMREAD_REDUCED_GRAYSCALE_4,始终将图像转换为单通道灰度图像,图像尺寸减小1/4.">
    常量 转彩色图减小到四分之一 <公开 值 = 33 注释 = "33,IMREAD_REDUCED_COLOR_4,始终将图像转换为3通道BGR彩色图像,图像尺寸减小1/4.">
    常量 转灰度图减小到八分之一 <公开 值 = 64 注释 = "64,IMREAD_REDUCED_GRAYSCALE_8,始终将图像转换为单通道灰度图像,图像尺寸减小1/8.">
    常量 转彩色图减小到八分之一 <公开 值 = 65 注释 = "65,始终将图像转换为3通道BGR彩色图像,图像尺寸减小1/8.">
    常量 不根据拍摄信息旋转图像 <公开 值 = 128 注释 = "128,IMREAD_IGNORE_ORIENTATION,不要根据拍摄的方向标志旋转图像.">
}

类 CV字体常量 <公开 注释 = "HersheyFonts" @常量类 = 整数>
{
    常量 正常大小无衬线字体 <公开 值 = 0 注释 = "0,FONT_HERSHEY_SIMPLEX,正常大小无衬线字体." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 小号无衬线字体 <公开 值 = 1 注释 = "1,FONT_HERSHEY_PLAIN,小号无衬线字体." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 普通大小无衬线字体 <公开 值 = 2 注释 = "2,FONT_HERSHEY_DUPLEX,普通大小无衬线字体(比 正常大小无衬线字体 更复杂)." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 标准衬线字体 <公开 值 = 3 注释 = "3,FONT_HERSHEY_COMPLEX,标准衬线字体." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 正常大小的衬线字体 <公开 值 = 5 注释 = "4,FONT_HERSHEY_TRIPLEX,正常大小的衬线字体(比 标准衬线字体 更复杂) ." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 标准衬线字体小号 <公开 值 = 5 注释 = "5,FONT_HERSHEY_COMPLEX_SMALL,小号FONT_HERSHEY_COMPLEX." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 书写风格体 <公开 值 = 6 注释 = "6,FONT_HERSHEY_SCRIPT_SIMPLEX,书写风格体." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 斜体变体 <公开 值 = 7 注释 = "7,FONT_HERSHEY_SCRIPT_COMPLEX,斜体变体." 编辑时信息 = "0, 1DA58, 0, 0">
    常量 斜体 <公开 值 = 16 注释 = "16,FONT_ITALIC,斜体." 编辑时信息 = "0, 1DA58, 0, 0">
}

类 CV修复常量 <公开 注释 = "INPAINT" @常量类 = 整数>
{
    常量 梯度快速匹配修复 <公开 值 = 1 注释 = "1,INPAINT_TELEA,基于图像梯度的快速匹配方法." 编辑时信息 = "209D6, 6C4E5, 0, 0">
    常量 NS修复 <公开 值 = 0 注释 = "0,INPAINT_NS,基于Navier-Stokes的修复方法." 编辑时信息 = "209D6, 6C4E5, 0, 0">
}

类 CV视频写入属性常量 <公开 注释 = "VideoWriterProperties" @常量类 = 整数>
{
    常量 质量 <公开 值 = 1 注释 = "1,VIDEOWRITER_PROP_QUALITY,编码视频流的当前质量(0..100%). 在某些编解码器中可以动态调整." 编辑时信息 = "209D6, 144EB, 0, 0">
    常量 帧大小 <公开 值 = 2 注释 = "2,VIDEOWRITER_PROP_FRAMEBYTES,(只读):编码的视频帧的大小. 请注意,编码顺序可能与表示顺序不同." 编辑时信息 = "209D6, 144EB, 0, 0">
    常量 并行编码条纹数 <公开 值 = 3 注释 = "3,VIDEOWRITER_PROP_NSTRIPES,用于并行编码的条纹数. -1用于自动检测." 编辑时信息 = "0, 144EB, 0, 0">
    常量 使用彩色帧 <公开 值 = 4 注释 = "4,VIDEOWRITER_PROP_IS_COLOR,如果它不为零,编码器将期望和编码彩色帧,否则为灰度图." 编辑时信息 = "0, 144EB, 0, 0">
    常量 矩阵数值类型 <公开 值 = 5 注释 = "5,VIDEOWRITER_PROP_DEPTH,图像矩阵数值类型,默认为 8位无符号整数." 编辑时信息 = "0, 144EB, 0, 0">
    常量 硬件加速类型 <公开 值 = 6 注释 = "6,VIDEOWRITER_PROP_HW_ACCELERATION,(**仅打开时可以**)硬件加速类型(参见#VideoAccelerationType)"
            注释 = "只支持通过 CV视频写入类.打开()  方法中的\' params \'参数设置. 默认值是后端特定的." 编辑时信息 = "0, 144EB, 0, 0">
    常量 硬件设备索引 <公开 值 = 7 注释 = "7,VIDEOWRITER_PROP_HW_DEVICE,(**仅打开时可以**)硬件设备索引(有多个选择GPU). 设备枚举特定于加速类型." 编辑时信息 = "0, 144EB, 0, 0">
    常量 创建OpenCL上下文 <公开 值 = 8 注释 = "8,VIDEOWRITER_PROP_HW_ACCELERATION_USE_OPENCL,如果非零,则创建新的OpenCL上下文并将其绑定到当前线程."
            编辑时信息 = "0, 144EB, 0, 0">
}

类 CV矩阵类容器 <公开 注释 = "std::vector<cv::Mat>,矩阵的数组.">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # std::vector<cv::Mat> obj;
    # <> </include>
    # @end

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" 返回值注释 = "返回成员个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.size();
    }

    方法 取成员 <公开 类型 = CV矩阵类 注释 = "返回所指定索引位置处的成员值" 返回值注释 = "返回指定索引的 CV矩阵类">
    参数 成员索引 <类型 = 整数>
    {
        变量 坐标 <类型 = CV矩阵类>
        @ @<坐标>.obj = obj[@<成员索引>];
        返回 (坐标)
    }

    方法 加入成员 <公开 注释 = "将一个所指定类型的成员值加入到本容器(数组)的尾部">
    参数 欲加入的矩阵 <类型 = CV矩阵类>
    {
        @ obj.push_back(@<欲加入的矩阵>.obj);
    }

    方法 清除成员 <公开 注释 = "清除容器内的所有成员">
    {
        @ obj.clear();
    }
}

类 CV矩阵类 <公开 注释 = "cv::Mat">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     obj = objCopyFrom.obj;
    # }
    # cv::Mat obj;
    # <> </include>
    # @end

    方法 释放 <公开 注释 = "release,释放矩阵.">
    {
        @ obj.release();
    }

    方法 取矩阵指针 <公开 类型 = 变整数 注释 = "它取的指针是原生 cv::Mat对象的指针,也不是矩阵的数据指针,要注意区分" 返回值注释 = "返回矩阵指针" @禁止流程检查 = 真>
    {
        @ return  (INT_P)&obj;
    }

    方法 取矩阵尺寸 <公开 类型 = CV尺寸类 注释 = "size,获取矩阵的宽高尺寸." 返回值注释 = "返回矩阵的尺寸">
    {
        变量 尺寸 <类型 = CV尺寸类>
        @ @<尺寸>.obj =  obj.size();
        返回 (尺寸)
    }

    方法 是否为子矩阵 <公开 类型 = 逻辑型 注释 = "isSubmatrix,矩阵是否为另外个矩阵的子矩阵." 返回值注释 = "如果是子矩阵,则返回真" @禁止流程检查 = 真>
    {
        @ return obj.isSubmatrix();
    }

    方法 取矩阵类型 <公开 类型 = 整数 注释 = "type" 返回值注释 = " 返回矩阵通道类型" @禁止流程检查 = 真>
    {
        @ return obj.type();
    }

    方法 获取矩阵矩形 <公开 类型 = CV矩形类 返回值注释 = "返回矩阵以左上角坐标为(0,0), 矩形宽度高度为  矩阵宽度、高度的矩形.">
    {
        变量 返回矩形 <类型 = CV矩形类>
        @ @<返回矩形>.obj. x = 0;
        @ @<返回矩形>.obj. y = 0;
        @ @<返回矩形>.obj. width = obj.cols;
        @ @<返回矩形>.obj. height = obj.rows;
        返回 (返回矩形)
    }

    方法 创建对角线矩阵 <公开 类型 = CV矩阵类 注释 = "diag,从现有矩阵中创建一个对角线矩阵." 返回值注释 = "返回一个对角线矩阵">
    参数 对角线索引 <类型 = 整数 @默认值 = 0>
    {
        变量 返回矩阵 <类型 = CV矩阵类>
        @ @<返回矩阵>.obj = obj.diag(@<对角线索引>);
        返回 (返回矩阵)
    }

    方法 取矩阵元素个数 <公开 类型 = 整数 注释 = "total,获取所有通道的矩阵元素个数" @禁止流程检查 = 真>
    {
        @ return (int)obj.total();
    }

    方法 取矩阵指定通道元素个数 <公开 类型 = 整数 注释 = "total,获取指定通道的矩阵元素个数" @禁止流程检查 = 真>
    参数 通道索引 <类型 = 整数>
    {
        @ return (int)obj.total(@<通道索引>);
    }

    方法 检查矩阵向量 <公开 类型 = 整数 注释 = "checkVector,检查一个矩阵的向量数目." 返回值注释 = "返回向量数目,如果没找到向量返回-1." @禁止流程检查 = 真>
    参数 枚举数目 <类型 = 整数 注释 = "矩阵应具有的通道数或列数">
    参数 深度 <类型 = 整数 注释 = "矩阵应该具有的深度,使用任何深度时将其设置为-1." @默认值 = -1>
    参数 是否连续 <类型 = 逻辑型 注释 = "为真时,矩阵必须连续,否则应设置为假." @默认值 = 真>
    {
        @ return obj.checkVector(@<枚举数目>, @<深度>, @<是否连续>);
    }

    方法 定位矩阵ROI <公开 注释 = "locateROI,定位矩阵在父矩阵中的ROI位置信息">
    参数 输出整体尺寸 <类型 = CV尺寸类>
    参数 输出矩阵头坐标 <类型 = CV坐标点>
    {
        @ obj.locateROI(@<输出整体尺寸>.obj, @<输出矩阵头坐标>.obj);
    }

    方法 调整矩阵ROI <公开 注释 = "adjustROI,调整矩阵在父矩阵中的ROI位置信息">
    参数 顶部 <类型 = 整数>
    参数 底部 <类型 = 整数>
    参数 左边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    {
