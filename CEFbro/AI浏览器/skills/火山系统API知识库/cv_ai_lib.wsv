    常量 默认 <公开 值 = 0 注释 = "0,DEFAULT,输出图像矩阵将被创建.">
    常量 不创建输出矩阵 <公开 值 = 1 注释 = "1,DRAW_OVER_OUTIMG,将不会创建输出图像矩阵.">
    常量 不绘制单个关键点 <公开 值 = 2 注释 = "2,NOT_DRAW_SINGLE_POINTS,单个关键点不会被绘制.">
    常量 绘制完整关键点 <公开 值 = 4 注释 = "4,DRAW_RICH_KEYPOINTS,对于每个关键点,将绘制带有关键点大小和方向的圆.">
}

