    {

    }

    方法 连接断开 <公开 定义事件 类型 = 整数>
    {


    }

    方法 收到数据 <公开 定义事件 类型 = 整数>
    参数 数据 <类型 = 字节集类>
    {

    }

    方法 发送数据 <公开 类型 = 整数 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ return data().send((void*)@<数据>.GetPtr(),(int)@<数据>.GetSize())
    }

    方法 置重连
    参数 最小延时 <类型 = 整数>
    参数 最大延时 <类型 = 整数>
    参数 重连次数 <类型 = 整数>
    {
        @     hv::ReconnectInfo reconn;
        @     reconn.min_delay = @<最小延时>;
        @     reconn.max_delay = @<最大延时>;
        @     reconn.delay_policy = @<重连次数>;
        @     ws.setReconnect(&reconn);

    }

    方法 置心跳时间 <公开 @嵌入式方法 = "">
    参数 超时时间 <类型 = 整数>
    {
        @ @sn<this>.data().setPingInterval(@<超时时间>)
    }

    方法 连接 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 url <类型 = 文本型>
    {
        @ @sn<this>.data().open(GetMbsText(@<url>, CVolMem(), NULL))
    }

    方法 "//连接2" <公开 类型 = 整数 注释 = "这个是1.2.2以后的版本才支持" @禁止流程检查 = 真>
    参数 url <类型 = 文本型>
    参数 协议头 <类型 = 文本型 @默认值 = "">
    {
        变量 协议头数组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        分割子文本 (协议头, "\r\n", 协议头数组)
        循环 (0, 协议头数组.取成员数 (), i)
        {
            变量 临时文本 <类型 = 文本型>
            变量 键名称 <类型 = 文本型>
            变量 键值 <类型 = 文本型>
            临时文本 = 协议头数组.取成员 (i)
            键名称 = 文本_取左边_从左往右查找 (临时文本, ":")
            键值 = 删首尾空 (文本_取右边_从左往右查找 (临时文本, ":"))
            // 置单个协议头 (键名称, 键值)
            // http_headers headers;
            // headers["Host"] = "82.157.123.54:9010";
            // headers["Origin"] = "http://coolaf.com";

            @ http_headers headers;
            @ headers[GetMbsText(@<键名称>, CVolMem(), NULL)] = GetMbsText(@<键值>, CVolMem(), NULL);
            @ return data().open(GetMbsText(@<url>, CVolMem(), NULL),headers);
        }

        @ return data().open(GetMbsText(@<url>, CVolMem(), NULL))
    }

    #

    方法 断开 <公开 @嵌入式方法 = "">
    {
        @ @sn<this>.data().close()
    }

    #
}

