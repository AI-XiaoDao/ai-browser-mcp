类 HV事件池 <公开 基础类 = HV循环事件 折叠 @模板实现类 = "">
{

    # @begin
    # <> <include> 
    # static void Loop_CalBack(hevent_t* hHandle);
    # inline hevent_t* ToHandle(INT_P data) {    return (hevent_t*)data; } 
    # <> </include> 
    # void @sn<current_class>::Loop_CalBack(hevent_t* ev) 
    # { 
    #     @sn<current_class>::LOOP_USER_DATA* pExtra = (@sn<current_class>::LOOP_USER_DATA*)ev->userdata; 
    #     if(pExtra && pExtra->pThis) 
    #     { 
    #         pExtra->pThis->@<任务回调>((INT)ev->event_type-HEVENT_TYPE_CUSTOM,(INT_P)pExtra->userData,(INT_P)pExtra->wParam,(INT_P)pExtra->lParam); 
    #         delete pExtra;
    #     } 
    # } 
    #
    # @end

    方法 任务回调 <公开 定义事件 类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户参数 <类型 = 变整数>
    参数 用户参数2 <类型 = 变整数>
    参数 用户参数3 <类型 = 变整数>

    方法 投递事件 <公开>
    参数 标记值 <类型 = 整数>
    参数 用户参数 <类型 = 变整数>
    参数 用户参数2 <类型 = 变整数>
    参数 用户参数3 <类型 = 变整数>
    {
        @ LOOP_USER_DATA* pExtra = new LOOP_USER_DATA; 
        @ memset(pExtra,0,sizeof(*pExtra));
        @ pExtra->pThis = this;
        @ pExtra->userData = @<用户参数>;
        @ pExtra->wParam = @<用户参数2>;
        @ pExtra->lParam = @<用户参数3>;
        @ hevent_t ev;
        @ memset(&ev, 0, sizeof(ev));
        @ ev.event_type = (hevent_type_e)(HEVENT_TYPE_CUSTOM + @<标记值>);
        @ ev.cb = @sn<current_class>::Loop_CalBack;
        @ ev.userdata = (void*)pExtra;
        @ hloop_post_event(GetData(), &ev);


    }

    #
}

