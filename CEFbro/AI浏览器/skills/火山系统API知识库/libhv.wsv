类 HVWSServer <公开 基础类 = 空模板 注释 = "websocket 客户端" 折叠 @模板基础类 = 真>
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (WebSocketService)
    # <> <include>
    # websocket_server_t server;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ data().onopen = [this](const WebSocketChannelPtr& channel, const std::string& url) 
        @ {
        @         @dt<模板类型1>* ctx = channel->newContext<@dt<模板类型1>>();
        @         @dt<HVChannel> ch(channel); 
        @              this->@<连接成功>(ch,CVolString(url.c_str()),*ctx);
        @  };

        @ data().onmessage = [this](const WebSocketChannelPtr& channel, const std::string& msg)
        @ {
        @         @dt<模板类型1>* ctx = channel->getContext<@dt<模板类型1>>();
        @         @dt<HVChannel> ch(channel); 
        @         CVolMem bin(msg.data(),msg.size());
        @         this->@<收到数据>(ch,bin,*ctx);
        @  };
        @ data().onclose = [this](const WebSocketChannelPtr& channel)
        @ {
        @         @dt<模板类型1>* ctx = channel->getContext<@dt<模板类型1>>();
        @         @dt<HVChannel> ch(channel); 
        @         this->@<连接断开>(ch,*ctx);
        @         channel->deleteContext<@dt<模板类型1>>();
        @  };
    }

    方法 连接成功 <公开 定义事件 类型 = 整数>
    参数 通道 <类型 = HVChannel>
    参数 网址 <类型 = 文本型>
    参数 附加数据 <类型 = 模板类型1>
