    {
        @   m_channel->setConnectTimeout(@<连接超时>);
        @   m_channel->setCloseTimeout(@<关闭超时>);
        @   m_channel->setKeepaliveTimeout(@<KeeepAlive超时>);
    }

    方法 连接 <公开 @嵌入式方法 = "">
    参数 IP地址 <类型 = 文本型>
    参数 端口 <类型 = 整数>
    {
        @   @sn<this>.m_channel->startConnect(@<端口>,GetMbsText(@<IP地址>, CVolMem(), NULL))

    }

    方法 重连 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @   @sn<this>.m_channel->startConnect()
    }

    方法 是否已连接 <公开 类型 = 逻辑型 @嵌入式方法 = "">
    {
        @   @sn<this>.m_channel->isConnected()
    }

    #

    方法 取对等地址 <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @  CVolString(  @sn<this>.m_channel->peeraddr().c_str() )
    }

    方法 取本地地址 <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @  CVolString(  @sn<this>.m_channel->localaddr().c_str() )

    }

    #
    #
}

类 HVTcpServer <公开 基础类 = 空模板 折叠 @模板实现类 = "">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (hv::TcpServer)
    # @begin
    # <> <include>
    # <> </include>
    # @end
    #

    方法 类_初始化
    {
        @     data().onConnection = [this](const hv::SocketChannelPtr& channel)
        @     {
        @         @dt<HV套接字通道> ch(channel);
        @         if (channel->isConnected()) 
        @         {
        @             this->@<连接成功>(ch);
        @         } else 
        @         {
        @             this->@<断开连接>(ch);
        @         }
        @     };

        @     data().onMessage = [this](const hv::SocketChannelPtr& channel, hv::Buffer* buf) 
        @     {
        @         @dt<HV套接字通道> ch(channel);
        @         CVolMem mem(buf->data(),buf->size());
        @        this-> @<收到消息>(ch,mem);
        @     };

        @     data().onWriteComplete = [this](const hv::SocketChannelPtr& channel, hv::Buffer* buf)
        @    {
        @         @dt<HV套接字通道> ch(channel);
        @         CVolMem mem(buf->data(),buf->size());
        @         this->@<发送成功>(ch,mem);
        @     };

    }

    方法 连接成功 <公开 定义事件 类型 = 整数 折叠>
    参数 通道 <类型 = HV套接字通道>
    {

    }

    方法 断开连接 <公开 定义事件 类型 = 整数 折叠>
    参数 通道 <类型 = HV套接字通道>
    {

    }

    方法 收到消息 <公开 定义事件 类型 = 整数 折叠>
    参数 通道 <类型 = HV套接字通道>
    参数 数据 <类型 = 字节集类>
    {

    }

    方法 发送成功 <公开 定义事件 类型 = 整数>
    参数 通道 <类型 = HV套接字通道>
    参数 数据 <类型 = 字节集类>
    {

    }

    方法 置线程数 <公开 注释 = "必须要再启动前设置" @嵌入式方法 = "">
    参数 线程数 <类型 = 整数>
    {
        @    @sn<this>.data().setThreadNum(@<线程数>)

    }

    方法 创建 <公开 类型 = 整数 @嵌入式方法 = "">
    参数 IP <类型 = 文本型>
    参数 端口 <类型 = 整数>
    {
        @    @sn<this>.data().createsocket(@<端口>,GetMbsText(@<IP>, CVolMem(), NULL));
    }

    方法 启动 <公开 @嵌入式方法 = "">
    {
        @    @sn<this>.data().start()
    }

    方法 停止 <公开 @嵌入式方法 = "">
    参数 是否等待线程退出 <类型 = 逻辑型 @默认值 = 真>
    {
        @  @sn<this>.data().stop(@<是否等待线程退出>)
    }

    方法 置证书 <公开 @嵌入式方法 = "">
    参数 证书 <类型 = 文本型>
    参数 密钥 <类型 = 文本型>
    {
        @  @sn<this>.data().withTLS(GetMbsText(@<证书>, CVolMem(), NULL),GetMbsText(@<密钥>, CVolMem(), NULL))
    }

    #

    方法 广播 <公开 @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类>
    {
        @ return  data().stop( @<数据>.GetPtr(),@<数据>.GetSize() );
    }

    方法 枚举通道 <公开 @嵌入式方法 = "name = \"volhvforeachChannel\"\r\nbody_header = \"@none\"\r\nbody_tail = \"});\"\r\nhas_body = true">
    {
        @ @sn<this>.data().foreachChannel( [](const SocketChannelPtr& channel)
        @ {
        @    @dt<HV套接字通道> ch(channel);
    }

    方法 取通道 <公开 类型 = HV套接字通道 注释 = "只能再 枚举通道 的流程线包围的位置中使用" @嵌入式方法 = "parent = \"volhvforeachChannel\"">
    {
        @ ch
    }

    #
}

