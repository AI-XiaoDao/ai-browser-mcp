类 HV循环事件 <公开 基础类 = 空模板 注释 = "基础事件" 折叠 @模板基础类 = 真>
{

    # @begin
    # <> <include>
    #
    # typedef struct loopUserData
    # {
    #     @sn<current_class>* pThis;
    #     INT_P               userData;
    #     INT_P               wParam;
    #     INT_P               lParam;
    # }LOOP_USER_DATA;
    #
    # hloop_t* m_loop;
    # hloop_t* GetData()
    # {
    #     return m_loop;
    # }
    # void SetData(hloop_t* loop)
    # {
    #     m_loop = loop;
    # }
    # hloop_t** GetPointerPointer()
    # {
    #     return &m_loop;
    # }
    # struct loopUserData m_UserData;
    # <> </include>
    # @end
    #

    方法 创建 <公开>
    参数 标志 <类型 = 整数 注释 = "可选值有三个" 注释 = "0 默认 用户需手动释放" 注释 = "1 运行一次" 注释 = "2 运行完毕自动销毁" 注释 = "4 没有事件时自动退出" @默认值 = 0>
    {
        @  SetData( hloop_new(@<标志>));
    }

    方法 销毁 <公开 @嵌入式方法 = "">
    {
        @ hloop_free(@sn<this>.GetPointerPointer())
    }

    方法 运行 <公开 @嵌入式方法 = "">
    {
        @ hloop_run(@sn<this>.GetData())
    }

    方法 停止 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ hloop_stop(@sn<this>.GetData())
    }

    方法 暂停 <公开 类型 = 整数 注释 = "可以调用 继续() 继续工作" @嵌入式方法 = "">
    {
        @ hloop_pause(@sn<this>.GetData())
    }

    方法 继续 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ hloop_resume(@sn<this>.GetData())
    }

    方法 唤醒 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ hloop_wakeup(@sn<this>.GetData())
    }

    方法 取状态 <公开 类型 = 整数 返回值注释 = "typedef enum {" 返回值注释 = "    HLOOP_STATUS_STOP," 返回值注释 = "    HLOOP_STATUS_RUNNING,"
            返回值注释 = "    HLOOP_STATUS_PAUSE" 返回值注释 = "} hloop_status_e;" 返回值注释 = "0 停止" 返回值注释 = "1 运行中" 返回值注释 = "1 暂停中" 折叠
            @嵌入式方法 = "">
    {
        @ (int)hloop_status(@sn<this>.GetData())
    }

    方法 更新时间 <公开 @嵌入式方法 = "">
    {
        @ hloop_update_time(@sn<this>.GetData())
    }

    方法 取当前时间秒 <公开 类型 = 长整数 @嵌入式方法 = "">
    {
        @ hloop_now(@sn<this>.GetData())
    }

    方法 取当前时间毫秒 <公开 类型 = 长整数 @嵌入式方法 = "">
    {
        @ hloop_now_ms(@sn<this>.GetData())
    }

    方法 取当前时间微秒 <公开 类型 = 长整数 @嵌入式方法 = "">
    {
        @ hloop_now_hrtime(@sn<this>.GetData())
    }

    方法 取进程标识 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ hloop_pid(@sn<this>.GetData())
    }

    方法 取线程标识 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ hloop_tid(@sn<this>.GetData())
    }

    #
}

类 变整数到变整数哈希表 <公开 基础类 = 通用哈希表模板类 @模板实现类 = "变整数, 变整数">

类 HV事件回调模板 <基础类 = HV循环事件 折叠 @模板基础类 = 真>
{

    # @begin
    # @def_macro  Create_Loop_CallBack(data_type) \
    # <> <include> \ 
    # static void Loop_CalBack(data_type hHandle); \ 
    # inline data_type ToHandle(INT_P data) {    return (data_type)data; } \
    # <> </include> \
    # void @sn<current_class>::Loop_CalBack(data_type hHandle) \
    # { \
    #     @sn<current_class>::LOOP_USER_DATA* pExtra = (@sn<current_class>::LOOP_USER_DATA*)hevent_userdata(hHandle); \
    #     if(pExtra && pExtra->pThis) \
    #     { \
    #         pExtra->pThis->@<任务回调>((INT_P)hHandle,(INT_P)pExtra->userData); \
    #     } \
    # } 
    #
    # @end

    方法 任务回调 <公开 定义事件 类型 = 整数>
    参数 任务句柄 <类型 = 变整数>
    参数 用户参数 <类型 = 变整数>

    方法 置附加数据 <公开>
    参数 任务句柄 <类型 = 变整数>
    参数 用户数据 <类型 = 变整数>
    {
        @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
        @ if(pExtra)
        @ {
        @ pExtra->userData = @<用户数据>;
        @ hevent_set_userdata( ToHandle(@<任务句柄>), (void*)pExtra);
        @  }
    }

    方法 取附加数据 <公开 类型 = 变整数 @禁止流程检查 = 真>
    参数 任务句柄 <类型 = 变整数>
    {
        @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
        @ if(pExtra)
        @ {
        @     return pExtra->userData;
        @  }
        @ return 0;

    }

    #
}

类 HV计划任务 <公开 基础类 = HV事件回调模板 折叠 @模板实现类 = "">
{
    变量 成员_任务句柄数组 <类型 = 变整数数组类>
    变量 成员_锁 <类型 = 临界区类f>

    # @ @m<Create_Loop_CallBack>(htimer_t*)
    #

    方法 添加任务 <公开 类型 = 变整数 注释 = "/*" 注释 = " * minute   hour    day     week    month       cb"
            注释 = " * 0~59     0~23    1~31    0~6     1~12" 注释 = " *  30      -1      -1      -1      -1          cron.hourly"
            注释 = " *  30      1       -1      -1      -1          cron.daily"
            注释 = " *  30      1       15      -1      -1          cron.monthly"
            注释 = " *  30      1       -1       5      -1          cron.weekly"
            注释 = " *  30      1        1      -1      10          cron.yearly" 注释 = " */" 返回值注释 = "返回任务句柄" 折叠2>
    参数 分钟 <类型 = 字节 @默认值 = 0>
    参数 小时 <类型 = 字节 注释 = "-1 表示不使用" @默认值 = -1>
    参数 天 <类型 = 字节 注释 = "-1 表示不使用" @默认值 = -1>
    参数 周 <类型 = 字节 注释 = "-1 表示不使用" @默认值 = -1>
    参数 月 <类型 = 字节 注释 = "-1 表示不使用" @默认值 = -1>
    参数 重复次数 <类型 = 整数 注释 = "-1 表示一直重复" @默认值 = -1>
    {
        变量 任务句柄 <类型 = 变整数>
        @ LOOP_USER_DATA* pExtra = new LOOP_USER_DATA; 
        @ memset(pExtra,0,sizeof(*pExtra));
        @ pExtra->pThis = this;
        @ @<任务句柄> = (INT_P)htimer_add_period(GetData(), @sn<current_class>::Loop_CalBack, @<分钟>, @<小时>, @<天>, @<周>,@<月>,@<重复次数>);
        @ hevent_set_userdata(ToHandle(@<任务句柄>),pExtra);
        成员_锁.进入许可区 ()
        成员_任务句柄数组.加入成员 (任务句柄)
        成员_锁.离开许可区 ()
        返回 (任务句柄)
    }

    方法 删除任务 <公开 折叠>
    参数 任务句柄 <类型 = 变整数>
    {
        如果 (成员_任务句柄数组.所指定值是否存在 (任务句柄))
        {
            成员_锁.进入许可区 ()
            成员_任务句柄数组.查找删除成员 (任务句柄)
            成员_锁.离开许可区 ()
            @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
            @ if(pExtra) delete pExtra;
            @ htimer_del(@<任务句柄>);
        }

    }

    方法 是否存在 <公开 类型 = 逻辑型 折叠>
    参数 任务句柄 <类型 = 变整数>
    {
        变量 是否存在 <类型 = 逻辑型>
        成员_锁.进入许可区 ()
        是否存在 = 成员_任务句柄数组.所指定值是否存在 (任务句柄)
        成员_锁.离开许可区 ()
        返回 (是否存在)
    }

    方法 删除所有 <公开 折叠>
    {
        变量 i <类型 = 整数>
        成员_锁.进入许可区 ()
        循环 (0, 成员_任务句柄数组.取成员数 (), i)
        {
            变量 任务句柄 <类型 = 变整数>
            任务句柄 = 成员_任务句柄数组.取成员 (i)
            @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
            @ if(pExtra) delete pExtra;
            @ htimer_del(@<任务句柄>);
        }
        成员_任务句柄数组.删除所有成员 ()
        成员_锁.离开许可区 ()

    }

    方法 重置 <公开 折叠 @嵌入式方法 = "">
    参数 任务句柄 <类型 = 变整数>
    {
        @ htimer_reset((htimer_t*)@<任务句柄>)
    }

    #
}

类 HV任务优先级常量 <公开 注释 = "#define HEVENT_LOWEST_PRIORITY    (-5)" 注释 = "#define HEVENT_LOW_PRIORITY       (-3)"
        注释 = "#define HEVENT_NORMAL_PRIORITY      0" 注释 = "#define HEVENT_HIGH_PRIORITY        3"
        注释 = "#define HEVENT_HIGHEST_PRIORITY     5" 折叠 折叠2>
{
    常量 超低 <公开 类型 = 整数 值 = @HEVENT_LOWEST_PRIORITY>
    常量 低 <公开 类型 = 整数 值 = @HEVENT_LOW_PRIORITY>
    常量 正常 <公开 类型 = 整数 值 = @HEVENT_NORMAL_PRIORITY>
    常量 高 <公开 类型 = 整数 值 = @HEVENT_HIGH_PRIORITY>
    常量 超高 <公开 类型 = 整数 值 = @HEVENT_HIGHEST_PRIORITY>

    #
}

类 HV重复任务 <公开 基础类 = HV事件回调模板 折叠 @模板实现类 = "">
{
    变量 成员_任务句柄数组 <类型 = 变整数数组类>
    变量 成员_锁 <类型 = 临界区类f>

    # @  @m<Create_Loop_CallBack>(hidle_t*)

    方法 添加任务 <公开 类型 = 变整数 返回值注释 = "返回任务句柄">
    参数 重复次数 <类型 = 整数 注释 = "-1 表示一直重复" @默认值 = -1>
    {
        变量 任务句柄 <类型 = 变整数>
        @ LOOP_USER_DATA* pExtra = new LOOP_USER_DATA; 
        @ memset(pExtra,0,sizeof(*pExtra));
        @ pExtra->pThis = this;
        @ @<任务句柄> = (INT_P)hidle_add(GetData(), @sn<current_class>::Loop_CalBack,(uint32_t)@<重复次数>);
        @ hevent_set_userdata(ToHandle(@<任务句柄>),pExtra);
        成员_锁.进入许可区 ()
        成员_任务句柄数组.加入成员 (任务句柄)
        成员_锁.离开许可区 ()
        返回 (任务句柄)

    }

    方法 删除任务 <公开 折叠>
    参数 任务句柄 <类型 = 变整数>
    {
        如果 (成员_任务句柄数组.所指定值是否存在 (任务句柄))
        {
            成员_锁.进入许可区 ()
            成员_任务句柄数组.查找删除成员 (任务句柄)
            成员_锁.离开许可区 ()
            @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
            @ if(pExtra) delete pExtra;
            @ hidle_del(@<任务句柄>);
        }

    }

    方法 是否存在 <公开 类型 = 逻辑型 折叠>
    参数 任务句柄 <类型 = 变整数>
    {
        变量 是否存在 <类型 = 逻辑型>
        成员_锁.进入许可区 ()
        是否存在 = 成员_任务句柄数组.所指定值是否存在 (任务句柄)
        成员_锁.离开许可区 ()
        返回 (是否存在)
    }

    方法 删除所有 <公开 注释 = "注意，在不用之后，必须全部删除，否则会造成内存泄漏" 折叠>
    {
        变量 i <类型 = 整数>
        成员_锁.进入许可区 ()
        循环 (0, 成员_任务句柄数组.取成员数 (), i)
        {
            变量 任务句柄 <类型 = 变整数>
            任务句柄 = 成员_任务句柄数组.取成员 (i)
            @ LOOP_USER_DATA* pExtra = hevent_userdata( ToHandle(@<任务句柄>) );
            @ if(pExtra) delete pExtra;
            @ hidle_del(@<任务句柄>);
        }
        成员_任务句柄数组.删除所有成员 ()
        成员_锁.离开许可区 ()
    }

    方法 置优先级 <公开 折叠 @嵌入式方法 = "">
    参数 任务句柄 <类型 = 变整数>
    参数 优先级 <类型 = 整数 注释 = "HV任务优先级常量 可以用 HV任务优先级常量.超低+1" @默认值 = HV任务优先级常量.超低>
    {
        @ hevent_set_priority((hidle_t*)@<任务句柄>,@<优先级>)
    }

    #
}

