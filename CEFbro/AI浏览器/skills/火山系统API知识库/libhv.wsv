类 HVHttpServer <公开 基础类 = 空模板 折叠 @模板实现类 = "">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (HttpService)
    # <> <include>
    # http_server_t server;
    # <> </include>
    # @end

    变量 成员_证书路径 <类型 = 文本型>
    变量 成员_密钥路径 <类型 = 文本型>

    方法 定义GET请求 <公开
            @嵌入式方法 = "name = \"volhvget\"\r\nbody_header = \"@none\"\r\nbody_tail = \"return nRespons;  });\"\r\nhas_body = true\r\n">
    参数 输入_路径 <类型 = 文本型 注释 = "比如 /index.html">
    {
        @     @sn<this>.data().GET(CU8String(@<输入_路径>.GetText ()).GetText (), [&](HttpRequest* req, HttpResponse* resp) {
        @       @dt<HVHttp请求> request(req);
        @       @dt<HVHttp响应> response(resp);
        @       int nRespons = 200;


    }

    方法 定义POST请求 <公开
            @嵌入式方法 = "name = \"volhvpost\"\r\nbody_header = \"@none\"\r\nbody_tail = \"return nRespons; });\"\r\nhas_body = true">
    参数 输入_路径 <类型 = 文本型 注释 = "比如 /index.html">
    {
        @     @sn<this>.data().POST(CU8String(@<输入_路径>.GetText ()).GetText (), [&](const HttpContextPtr& ctx) {
        @       @dt<HV请求响应> TmpCtx(ctx);
        @       int nRespons = 200;
    }

    方法 取请求响应 <公开 类型 = HV请求响应 注释 = "只能用在 定义POST请求 流程线包围的范围内" @嵌入式方法 = "parent = \"volhvpost\"">
    {
        @ TmpCtx

    }

    方法 置响应状态码 <公开 @嵌入式方法 = "parent = \"volhvpost,volhvget\"">
    参数 状态码 <类型 = 整数>
    {
        @ nRespons = @<状态码>
    }

    方法 取请求 <公开 类型 = HVHttp请求 注释 = "只能用在  定义GET请求 流程线包围的范围内" @嵌入式方法 = "parent = \"volhvget\"">
    {
        @ request
    }

    方法 取响应 <公开 类型 = HVHttp响应 注释 = "只能用在  定义GET请求 流程线包围的范围内" @嵌入式方法 = "parent = \"volhvget\"">
    {
        @ response
    }

    #

    方法 置证书与密钥 <公开 注释 = "如果设置了证书和密钥,那么 启动() 方法的参数 是否HTTPS 必须设置为真哦">
    参数 证书 <类型 = 文本型>
    参数 密钥 <类型 = 文本型>
    {
        成员_证书路径 = 证书
        成员_密钥路径 = 密钥
    }

    #

    方法 启动 <公开 注释 = "暂时不支持wss">
    参数 端口 <类型 = 整数>
    参数 是否HTTPS <类型 = 逻辑型 @默认值 = 假>
    参数 是否阻塞 <类型 = 逻辑型 注释 = "默认不阻塞，不阻塞模式，可以丢到窗口，阻塞模式一般用在没界面的情况下" @默认值 = 假>
    {
        @   if(@<是否HTTPS> = FALSE)
        @   {
        @      server.port = @<端口>;
        @   }else
        @   {
        @     server.https_port = @<端口>;
        @     hssl_ctx_init_param_t param;
        @     memset(&param, 0, sizeof(param));
        如果 (成员_密钥路径 != "" && 成员_证书路径 != "")
        @    {
        @      param.crt_file = GetMbsText(@<成员_证书路径>, CVolMem(), NULL);
        @      param.key_file = GetMbsText(@<成员_密钥路径>, CVolMem(), NULL);
        @    }
        @     param.endpoint = HSSL_SERVER;
        @     if (hssl_ctx_init(&param) == NULL) 
        @    {
        @     }
        @   }
        @     server.service = pdata();
        @     http_server_run(&server,@<是否阻塞>);


    }

    方法 停止 <公开 @嵌入式方法 = "">
    {
        @ http_server_stop(&@sn<this>.server)



    }
}

