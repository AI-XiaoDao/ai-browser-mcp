    }

    方法 连接断开 <公开 定义事件 类型 = 整数>
    参数 通道 <类型 = HVChannel>
    参数 附加数据 <类型 = 模板类型1>
    {

    }

    方法 收到数据 <公开 定义事件 类型 = 整数>
    参数 通道 <类型 = HVChannel>
    参数 数据 <类型 = 字节集类>
    参数 附加数据 <类型 = 模板类型1>
    {


    }

    #

    方法 启动 <公开 注释 = "暂时不支持wss">
    参数 端口 <类型 = 整数>
    参数 是否阻塞 <类型 = 逻辑型 注释 = "默认不阻塞，不阻塞模式，可以丢到窗口，阻塞模式一般用在没界面的情况下" @默认值 = 假>
    {
        @     server.port = @<端口>;
        @ #if TEST_WSS
        @     server.https_port = port + 1;
        @     hssl_ctx_init_param_t param;
        @     memset(&param, 0, sizeof(param));
        @     param.crt_file = "cert/server.crt";
        @     param.key_file = "cert/server.key";
        @     param.endpoint = HSSL_SERVER;
        @     if (hssl_ctx_init(&param) == NULL) {

        @     }
        @ #endif
        @     server.ws = pdata();
        @     websocket_server_run(&server,@<是否阻塞>);

    }

    方法 停止 <公开 @嵌入式方法 = "">
    {
        @ http_server_stop(@sn<this>.server)
    }
