<火山程序 类型 = "通常" 版本 = 1 />

包 火山.WTL界面插件

类 启动类 <公开 基础类 = 动态库程序类>
{
    方法 启动方法 <公开 类型 = 整数>
    {
        返回 (1)
    }

    # 由系统自动填写其中内容的接口方法(用户无需处理) ===

    方法 取插件版本号 <公开 静态 类型 = 整数 注释 = "返回当前插件中由系统自动填写的相关数据的版本号" @输出名 = "@VolGetPluginVersion" @视窗.输出 = 真>

    方法 新建组件对象 <公开 静态 类型 = 变整数 注释 = "新建所指定类名的窗口组件对象,成功返回其对象指针,失败返回0." 注释 = "注意:" 注释 = "  1. 本方法仅用作新建对象,并不新建对应的窗口;"
            注释 = "  2. 所返回组件对象指针在不使用后必须调用\"删除组件对象\"将其删除." 注释 = "注意方法参数的名称不可被修改." @输出名 = "@VolNewCtrlObject" @视窗.输出 = 真>
    参数 组件对象类名 <类型 = 文本型 注释 = "提供对应组件类的全名称,该类必定为\"窗口组件\"类或其继承类.">

    方法 取组件信息 <公开 静态 类型 = 变整数 注释 = "  返回用作描述所指定组件类中相关属性信息的文本指针,如所指定" 注释 = "组件类不存在则返回0." 注释 = "  注意方法参数的名称不可被修改."
            @输出名 = "@VolGetCtrlInfo" @视窗.输出 = 真>
    参数 组件对象类名 <类型 = 文本型 注释 = "  该组件的对象类全名,注意该类不见得为\"窗口组件\"类或其继承类," 注释 = "也可能为\"窗口组件\"类的基础类.">

    方法 取组件属性值 <公开 静态 类型 = 变整数 注释 = "获取组件所指定属性的值文本." 注释 = "注意方法参数的名称不可被修改." 返回值注释 = "返回所获取属性值对应的值文本指针,如果该属性不存在则返回0."
            返回值注释 = "注意: 所返回的值文本指针在下次调用本方法时将被覆盖." @输出名 = "@VolGetCtrlAttr" @视窗.输出 = 真>
    参数 组件对象类名 <类型 = 文本型 注释 = "  该组件的对象类全名,注意该类不见得为\"窗口组件\"类或其继承类,也可能" 注释 = "为\"窗口组件\"类的基础类.">
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"新建组件对象\"方法所创建的对象指针,其必定已经创建好了界面窗口.">
    参数 属性名 <类型 = 文本型 注释 = "所欲获取其值的属性名称">

    方法 置组件属性值 <公开 静态 类型 = 逻辑型 注释 = "设置组件所指定属性的值,返回该属性是否存在." 注释 = "注意方法参数的名称不可被修改." @输出名 = "@VolSetCtrlAttr" @视窗.输出 = 真>
    参数 组件对象类名 <类型 = 文本型 注释 = "  该组件的对象类全名,注意该类不见得为\"窗口组件\"类或其继承类,也可能" 注释 = "为\"窗口组件\"类的基础类.">
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"方法所创建的对象指针,如果所欲设置属性不支持创建" 注释 = "前设置(其\"设置时机\"属性值为\"组件创建后\")其必定已经创建好了界面窗口.">
    参数 属性名 <类型 = 文本型 注释 = "所欲设置属性的名称">
    参数 属性值 <类型 = 文本型 注释 = "所欲设置属性值的文本形式">

    # 需要由用户提供其中内容的接口方法 ===

    方法 删除组件对象 <公开 静态 注释 = "  删除所指定类名的窗口组件对象,该组件对象由\"新建组件对象\"/\"创建代指组件\"/" 注释 = "\"创建工作区组件\"创建." @输出名 = "@VolDelCtrlObject"
            @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"/\"创建工作区组件\"方法所创建的对象指针," 注释 = "必定不为NULL.">
    {
        @ ((@an<CVolObject>*)@<组件对象指针>)->Destroy ();
    }

    方法 创建工作区组件 <公开 静态 类型 = 变整数 注释 = "  创建进行设计时使用的顶层工作区组件,返回所创建组件对象指针." 注释 = "  在布局设计器中,仅会创建一个这样的最顶层组件,用作与系统布局设计器交"
            注释 = "互,所有被设计的组件均为此组件的直接/间接子组件." 返回值注释 = "成功返回所创建组件对象指针(必定为\"窗口组件\"类或其继承类),失败返回0."
            返回值注释 = "所返回组件对象指针在不使用后必须调用\"删除组件对象\"将其删除." @输出名 = "@VolCreateDesignAreaCtrl" @禁止流程检查 = 真 @视窗.输出 = 真>
    参数 设计区父窗口句柄 <类型 = 变整数 注释 = "  提供系统布局设计器的设计区Windows系统窗口句柄(HWND),必定不为0且" 注释 = "有效,所创建组件必须同时创建其界面窗口及对应的Windows系统窗口,且该"
            注释 = "Windows系统窗口必须以此窗口为父窗口.">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建组件在设计区Windows系统父窗口中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建组件在设计区Windows系统父窗口中的顶边纵向坐标位置">
    参数 宽度 <类型 = 整数 注释 = "提供所创建组件的宽度值">
    参数 高度 <类型 = 整数 注释 = "提供所创建组件的高度值">
    参数 背景颜色 <类型 = 整数 注释 = "提供所创建工作区组件背景颜色">
    {
        @ CVolNativeWndCreateParam param ((HWND)@<设计区父窗口句柄>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, -1);
        @ param.m_dwStyle = (WS_VISIBLE | WS_CHILD);
        @ @dt<组件布局器>* pControl = new @dt<组件布局器> ();
        @ CVWnd_Container* pWnd = (CVWnd_Container*)pControl->GetWtlControlPtr ();
        @ pWnd->m_clrBack = (COLORREF)@<背景颜色>;
        @ if (pWnd->CreateControl (&param) == FALSE)
        @ {
        @     pControl->Destroy ();
        @     return 0;
        @ }
        @ return (INT_P)pControl;
    }

    方法 创建代指组件 <公开 静态 类型 = 变整数 注释 = "  创建对应代指组件对象及其所对应的界面窗口,成功返回其对象指针,失败返回0." 注释 = "  代指组件将在系统使用\"新建组件对象\"方法无法创建所指定\"组件对象类名\"对应"
            注释 = "的窗口组件对象(可能是因为界面插件过时/创建失败)时使用." 注释 = "  注意: 所谓\"界面窗口\"是指由所使用界面库自行定义的用作展示组件内容的界面" 注释 = "部分,并不需要一定是Windows系统窗口."
            返回值注释 = "成功返回所创建组件对象指针(必定为\"窗口组件\"类或其继承类),失败返回0." 返回值注释 = "所返回组件对象指针在不使用后必须调用\"删除组件对象\"将其删除."
            @输出名 = "@VolCreateDummyCtrl" @禁止流程检查 = 真 @视窗.输出 = 真>
    参数 父组件对象指针 <类型 = 变整数 注释 = "  提供父组件对象指针,必定不为NULL,由\"新建组件对象\"/\"创建代指组件\"/" 注释 = "\"创建工作区组件\"方法创建返回,且其必定已经创建好了有效的界面窗口.">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建代指组件的界面窗口在所处父组件客户区中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建代指组件的界面窗口在所处父组件客户区中的顶边纵向坐标位置">
    参数 宽度 <类型 = 整数 注释 = "提供所创建代指组件的界面窗口宽度值">
    参数 高度 <类型 = 整数 注释 = "提供所创建代指组件的界面窗口高度值">
    参数 ID值 <类型 = 整数 注释 = "指定所创建代指组件在其父组件中的ID值">
    参数 标题文本 <类型 = 文本型 注释 = "提供显示在代指组件内的标题文本">
    {
        @ @dt<标签>* pControl = new @dt<标签> ();
        @ pControl->@n<窗口组件.标题> (@<标题文本>);
        @ pControl->GetWtlWndObject ()->m_dwAttrInitialStyle |= WS_BORDER;
        @ CVWnd_Label* pWnd = (CVWnd_Label*)pControl->GetWtlControlPtr ();
        @ pWnd->m_clrBack = RGB (255, 255, 255);
        @ pWnd->m_enHorzAlignMode = VHAM_HCENTER;
        @ pWnd->m_enVertAlignMode = VVAM_VCENTER;
        @ if (pControl->@an<CreateVolControl> ((@dt<窗口组件>*)@<父组件对象指针>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<ID值>))
        @     return (INT_P)pControl;
        @ delete pControl;
        @ return 0;
    }

    方法 置代指组件标题 <公开 静态 注释 = "设置由\"创建代指组件\"方法所创建的代指组件的标题文本" @输出名 = "@VolSetDummyCtrlCaption" @视窗.输出 = 真>
    参数 代指组件对象指针 <类型 = 变整数 注释 = "提供代指组件对象指针,为\"创建代指组件\"方法所创建返回.">
    参数 标题文本 <类型 = 文本型 注释 = "提供显示在代指组件内的新标题文本">
    {
        @ ((@dt<标签>*)@<代指组件对象指针>)->@n<窗口组件.标题> (@<标题文本>);
    }

    方法 创建组件界面窗口 <公开 静态 类型 = 逻辑型 注释 = "  创建对应组件对象所对应的界面窗口,返回是否成功." 注释 = "  注意: 所谓\"界面窗口\"是指由所使用界面库自行定义的用作展示组件"
            注释 = "内容的界面部分,并不需要一定是Windows系统窗口." @输出名 = "@VolCreateCtrlWnd" @禁止流程检查 = 真 @视窗.输出 = 真>
    参数 组件对象类名 <类型 = 文本型 注释 = "提供对应组件类的全名称,该类必定为\"窗口组件\"类或其继承类.">
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"新建组件对象\"方法所创建的对象指针">
    参数 父组件对象指针 <类型 = 变整数 注释 = "  提供父组件对象指针,必定不为NULL,由\"新建组件对象\"/\"创建代指组件\"/" 注释 = "\"创建工作区组件\"方法创建返回,且其必定已经创建好了有效的界面窗口.">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建组件的界面窗口在所处父组件客户区中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建组件的界面窗口在所处父组件客户区中的顶边纵向坐标位置">
    参数 宽度 <类型 = 整数 注释 = "  提供所创建组件的界面窗口宽度值,注意如果所提供组件对象为顶层布局组件" 注释 = "(工作区组件的直接子组件),则为其界面窗口客户区宽度.">
    参数 高度 <类型 = 整数 注释 = "  提供所创建组件的界面窗口高度值,注意如果所提供组件对象为顶层布局组件" 注释 = "(工作区组件的直接子组件),则为其界面窗口客户区高度.">
    参数 ID值 <类型 = 整数 注释 = "指定所创建组件在其父组件中的ID值">
    {
        @ return ((@dt<窗口组件>*)@<组件对象指针>)->@an<CreateVolControl> ((@dt<窗口组件>*)@<父组件对象指针>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<ID值>);
    }

    方法 移动组件 <公开 静态 注释 = "移动已有组件在其所处父组件客户区中的界面窗口位置" @输出名 = "@VolMoveCtrl" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好了界面窗口.">
    参数 左边位置 <类型 = 整数 注释 = "提供该组件的界面窗口在所处父组件客户区中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供该组件的界面窗口在所处父组件客户区中的顶边纵向坐标位置">
    参数 宽度 <类型 = 整数 注释 = "提供该组件的界面窗口宽度值">
    参数 高度 <类型 = 整数 注释 = "提供该组件的界面窗口高度值">
    {
        @ CWindow wnd = ((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle ();
        @ wnd.MoveWindow (@<左边位置>, @<顶边位置>, @<宽度>, @<高度>);
    }

    方法 计算组件矩形 <公开 静态 注释 = "  根据所指定的客户区尺寸,计算返回对应的组件矩形范围." 注释 = "  对于容器类组件来说,里面可能会存在标题栏/菜单栏/边框等额外的非客户区内"
            注释 = "容,本方法需要根据所提供的客户区尺寸,计算并加上这些非客户区内容尺寸,返回" 注释 = "最终组件矩形范围." @输出名 = "@VolAdjustCtrlRect" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好" 注释 = "了界面窗口.该组件必定为窗口布局组件(工作区组件的唯一一个子组件且为容器类"
            注释 = "型,所有其它组件的最顶层父组件).">
    参数 矩形数据指针 <类型 = 变整数 注释 = "为一个数据类型为RECT的指针,用作接收所输入的客户区尺寸并输出返回结果矩形.">
    {
        @ CWindow wnd = ((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle ();
        @ ::AdjustWindowRectEx ((RECT*)@<矩形数据指针>, wnd.GetStyle (), FALSE, wnd.GetExStyle ());
    }

    方法 取客户区位置 <公开 静态 注释 = "  返回所指定组件的客户区域相对其组件左上角的位置矩形." 注释 = "  有些组件的客户区尺寸可能与其组件尺寸并不一致,譬如该组件设置了尺寸大"
            注释 = "于0的边框等,由于所有子组件的位置均为基于其所处父组件的客户区左上角,所" 注释 = "以此时系统需要使用本接口方法来定位子组件." @输出名 = "@VolGetClientRect" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创" 注释 = "建好了界面窗口.">
    参数 矩形数据指针 <类型 = 变整数 注释 = "为一个数据类型为RECT的指针,用作接收所获得的客户区矩形位置.">
    {
        @ CWindow wnd = ((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle ();

        @ RECT rtWindow;
        @ wnd.GetWindowRect (&rtWindow);

        @ RECT* prtClient = (RECT*)@<矩形数据指针>;
        @ wnd.GetClientRect (prtClient);
        @ wnd.ClientToScreen (prtClient);
        @ prtClient->left -= rtWindow.left;
        @ prtClient->top -= rtWindow.top;
        @ prtClient->right -= rtWindow.left;
        @ prtClient->bottom -= rtWindow.top;
    }

    方法 置父组件 <公开 静态 注释 = "设置已有组件所处的父组件" @输出名 = "@VolSetParentCtrl" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经" 注释 = "创建好了界面窗口.">
    参数 父组件对象指针 <类型 = 变整数 注释 = "  提供父组件对象指针,必定不为NULL,由\"新建组件对象\"/\"创建代指组件\"/" 注释 = "\"创建工作区组件\"方法创建返回,且其必定已经创建好了有效的界面窗口.">
    {
        @ ::SetParent (((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle (), ((@dt<窗口组件>*)@<父组件对象指针>)->SafeGetWtlWndHandle ());
    }

    方法 置组件叠放层次 <公开 静态 注释 = "  将所指定组件的界面窗口设置到另一个指定组件的界面窗口下面," 注释 = "用作指定其在所有具有相同父组件的子组件内的Z叠放层次." @输出名 = "@VolSetCtrlZOrder"
            @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必" 注释 = "定已经创建好了界面窗口.">
    参数 其上方的组件对象指针 <类型 = 变整数 注释 = "  指定所指定组件的上方窗口组件对象指针,为0表示放在所有其它具" 注释 = "有相同父组件的子组件的最顶层."
            注释 = "  参数值如果不为0,为通过\"新建组件对象\"/\"创建代指组件\"方法所" 注释 = "创建的对象指针,其必定已经创建好了界面窗口.">
    {
        @ const HWND hWndInsertAfter = (@<其上方的组件对象指针> == 0 ? HWND_TOP : ((@dt<窗口组件>*)@<其上方的组件对象指针>)->SafeGetWtlWndHandle ());
        @ ::SetWindowPos (((@dt<窗口组件>*)@<组件对象指针>)->SafeGetWtlWndHandle (), hWndInsertAfter, 0, 0, 0, 0, (SWP_NOACTIVATE | SWP_NOMOVE | SWP_NOSIZE));
    }

    方法 重绘组件 <公开 静态 注释 = "通知重绘组件内容" @输出名 = "@VolRedrawCtrlClient" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"创建工作区组件\"/\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好了界面窗口.">
    参数 欲重绘区域矩形 <类型 = 变整数 注释 = "为一个数据类型为RECT的指针,用作提供所欲重绘客户区域的矩形位置,如果为NULL,则重绘整个组件.">
    {
        @ ::RedrawWindow (((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle (), (RECT*)@<欲重绘区域矩形>, NULL, (RDW_ERASE | RDW_FRAME | RDW_INVALIDATE | RDW_ERASENOW | RDW_UPDATENOW));
    }

    方法 显示组件 <公开 静态 类型 = 逻辑型 注释 = "显示/隐藏组件内容,返回组件内容的当前显示状态是否被实际更改." @输出名 = "@VolShowCtrl" @视窗.输出 = 真 @禁止流程检查 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"创建工作区组件\"/\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好了界面窗口.">
    参数 是否可视 <类型 = 逻辑型 注释 = "为真表示显示,为假表示隐藏.">
    {
        @ const HWND hWnd = ((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle ();
        @ const BOOL blVisibleStateChanged = (::IsWindowVisible (hWnd) != @<是否可视>);
        @ ::ShowWindow (hWnd, (@<是否可视> ? SW_SHOWNA : SW_HIDE));
        @ return blVisibleStateChanged;
    }

    # 需要由用户提供其中内容的可选接口方法(如不需要该方法,将其删除即可) ===

    方法 显示对齐网格 <公开 静态 注释 = "指定在所指定容器类组件的界面窗口上显示/隐藏对齐网格." 注释 = "本接口方法为可选,插件可以不提供本方法,此时布局设计器将不支持显示对齐网格."
            @输出名 = "@VolShowAlignGrid" @视窗.输出 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "  通过\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好了" 注释 = "界面窗口.该组件必定为窗口布局组件(工作区组件的唯一一个子组件且为容器类型,"
            注释 = "所有其它组件的最顶层父组件).">
    参数 网格单元宽度 <类型 = 整数 注释 = "提供对齐网格的单个单元格宽度,单位像素,为0表示隐藏对齐网格.">
    参数 网格单元高度 <类型 = 整数 注释 = "提供对齐网格的单个单元格高度,单位像素,为0表示隐藏对齐网格.">
    {
        @ @dt<窗口组件>* pVolWnd = (@dt<窗口组件>*)@<组件对象指针>;
        @ if (P_IS_VOL_INSTANCE_OF (pVolWnd, @dt<组件布局器>))  // 在本WTL界面库中,最底层的设计时可用窗口容器类组件为"组件布局器".
        @     ((CVWnd_Container*)pVolWnd->GetWtlControlPtr ())->ShowAlignGrid (@<网格单元宽度>, @<网格单元高度>);
    }

    方法 取组件窗口句柄 <公开 静态 类型 = 变整数 注释 = "如果所指定组件对应了一个Windows窗口句柄,则将其返回,否则返回0."
            注释 = "本接口方法为可选,插件可以不提供本方法,此时设计器认为该组件未对应有Windows窗口句柄." @输出名 = "@VolGetControlHWnd" @视窗.输出 = 真 @禁止流程检查 = 真>
    参数 组件对象指针 <类型 = 变整数 注释 = "通过\"创建工作区组件\"/\"新建组件对象\"/\"创建代指组件\"方法所创建的对象指针,其必定已经创建好了界面窗口.">
    {
        @ return (INT_P)((@dt<窗口组件>*)@<组件对象指针>)->GetWtlWndHandle ();
    }

    #
}
