类 EC_K线图 <公开 基础类 = 直角坐标系图表基础类 注释 = "EchartsK线图组件" @文档 = "category = \"图表控件\""
        @视窗.窗口组件 = "icon=\"icon\\K线图.bmp\"\r\ndefault_size = \"240, 200\"\r\npreview_unsupported">
{
    方法 初始设置
    {
        坐标轴.横轴.创建坐标轴 (坐标轴类型.类目轴)
        坐标轴.纵轴.创建坐标轴 (坐标轴类型.数值轴)
        提示框.触发类型 = 提示框触发类型.数据项图形触发

    }

    # @begin
    # <> <include>
    # virtual void OnCreate () override {  @<初始设置>();}
    # <> </include>
    # @end

    方法 阳线颜色 <公开 属性写 注释 = "K线图阳线图形颜色,即涨,在系列创建前设置有效." "">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\' 设置为\"null\"表示空." @默认值 = "#c23531">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"color\":null}");
        }
        否则
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"color\":'")+@<颜色值文本>+_T("'}");
        }
    }

    方法 阴线颜色 <公开 属性写 注释 = "K线图阴线图形颜色,即跌.在系列创建前设置有效.">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\' 设置为\"null\"表示空." @默认值 = "#314656">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"color0\":null}");
        }
        否则
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"color0\":'")+@<颜色值文本>+_T("'}");
        }
    }

    方法 阳线边框颜色 <公开 属性写 注释 = "K线图阳线图形描边颜色,在系列创建前设置有效." "">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'" @默认值 = "#c23531">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"borderColor\":null}");
        }
        否则
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"borderColor\":'")+@<颜色值文本>+_T("'}");
        }
    }

    方法 阴线边框颜色 <公开 属性写 注释 = "K线图阴线图形描边颜色,在系列创建前设置有效.">
    参数 颜色值文本 <类型 = 文本型
            注释 = "颜色可以使用 RGB 表示,比如\"rgb(128, 128, 128)\" ,如果想要加上 alpha 通道,可以使用 RGBA,比如 \"rgba(128, 128, 128, 0.5)\"."
            注释 = "也可以使用十六进制格式,比如 \'#ccc\'" @默认值 = "#314656">
    {
        如果 (到小写 (颜色值文本) == 到小写 ("null"))
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"borderColor0\":null}");
        }
        否则
        {
            @ @<系列集>.data().m_mapData[_T("itemStyle")]=  _T("{\"borderColor0\":'")+@<颜色值文本>+_T("'}");
        }
    }
}
