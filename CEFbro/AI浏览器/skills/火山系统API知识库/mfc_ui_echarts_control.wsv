类 直角坐标系图表基础类 <公开 基础类 = EC基础图表 注释 = "折线图,柱状图,K线图等默认使用直角坐标系">
{
    方法 横坐标轴 <公开 属性读 类型 = 图表坐标轴类 注释 = "取首个横轴" @视窗.返回参考 = 真>
    {
        如果 (坐标轴.横轴.取坐标轴数 () == 0)
        {
            坐标轴.横轴.创建坐标轴 (坐标轴类型.类目轴, , )
        }
        返回 (坐标轴.横轴.取坐标轴 (0))
    }

    方法 横坐标轴 <公开 属性写 注释 = "设置横轴">
    参数 坐标轴配置 <类型 = 图表坐标轴类 注释 = "提供一个坐标轴对象">
    {
        坐标轴.横轴.清空 ()
        坐标轴.横轴.添加坐标轴 (坐标轴配置)
    }

    方法 纵坐标轴 <公开 属性读 类型 = 图表坐标轴类 注释 = "取首个纵轴" @视窗.返回参考 = 真>
    {
        如果 (坐标轴.纵轴.取坐标轴数 () == 0)
        {
            坐标轴.纵轴.创建数值轴 ()
        }
        返回 (坐标轴.纵轴.取坐标轴 (0))
    }

    方法 纵坐标轴 <公开 属性写 注释 = "设置纵轴">
    参数 坐标轴配置 <类型 = 图表坐标轴类 注释 = "提供一个坐标轴对象">
    {
        坐标轴.纵轴.清空 ()
        坐标轴.纵轴.添加坐标轴 (坐标轴配置)
    }

    方法 提示框指示器 <公开 属性写 注释 = "设置提示框组件的坐标轴指示器类型">
    参数 指示器类型 <类型 = 坐标轴指示器类型 注释 = "提供坐标轴指示器类型常量" @默认值 = 坐标轴指示器类型.十字准星指示器>
    {
        提示框.坐标轴指示器.类型 = 指示器类型
    }

    方法 提示框触发类型 <公开 属性写 注释 = "鼠标动到数据图形上时,触发显示提示框的类型.">
    参数 触发类型 <类型 = 提示框触发类型 注释 = "提供提示框触发类型常量" @默认值 = 提示框触发类型.坐标轴触发>
    {
        提示框.触发类型 = 触发类型
    }
}

类 EC折线图 <公开 基础类 = 直角坐标系图表基础类 注释 = "Echarts折线图组件" @文档 = "category = \"图表控件\""
        @视窗.窗口组件 = "icon=\"icon\\折线图.bmp\"\r\ndefault_size = \"240, 200\"\r\npreview_unsupported">
{

    # @begin
    # <> <include>
    # virtual void OnCreate () override {  @<初始设置>();}
    # <> </include>
    # @end

    方法 初始设置
    {
        坐标轴.横轴.创建坐标轴 (坐标轴类型.类目轴).类目轴边界留白 = 假
        坐标轴.纵轴.创建坐标轴 (坐标轴类型.数值轴)
        提示框.触发类型 = 提示框触发类型.坐标轴触发
        提示框.坐标轴指示器.类型 = 坐标轴指示器类型.十字准星指示器
    }

    方法 平滑曲线 <公开 属性写 注释 = "折线图是否平滑曲线显示.在系列创建前设置有效.">
    参数 是否启用 <类型 = 逻辑型 注释 = "默认关闭" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("smooth")]=@<是否启用> ? _T("true"): _T("");   
    }

    方法 显示标签 <公开 属性写 注释 = "是否显示数据的文字标签,在系列创建前有效.">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("label")]=@<是否显示> ? _T("{\"show\":true}"): _T("{\"show\":false}");
    }

    方法 显示标记图形 <公开 属性写 注释 = "是否显示标记图形,">
    参数 是否显示 <类型 = 逻辑型 注释 = "如果为假则只有在提示框点亮的时候显示" "">
    {
        @ @<系列集>.data().m_mapData[_T("showSymbol")]=@<是否显示> ? _T("true") : _T("false");   
    }

    方法 创建折线图系列 <公开 类型 = 图表系列类 注释 = "创建一个类型为折线图的系列数据加入系列集,并返回该系列,折线图的一个系列代表一条数据线." @视窗.返回参考 = 真>
    参数 系列名称 <类型 = 文本型 注释 = "系列名称,在折线图中表示此数据线的名称或类目" @默认值 = "">
    参数 文本系列数据 <类型 = 文本型 注释 = "  提供一个数组文本如:\"[1,2,3,4,5,6,7]\"每个成员表示一个数据节点值." 注释 = "此参数与本方法第三个参数至少提供一个,如果同时提供了第三个参数,"
            注释 = "那么此参数将被舍弃." @默认值 = "">
    参数 数组系列数据 <类型 = 整数数组类 注释 = "数组型系列数据,如果提供了此参数,那么本方法第二参数提供的内容将被舍弃." @默认值 = 空对象>
    参数 平滑曲线 <类型 = 逻辑型 注释 = "是否平滑曲线显示" @默认值 = 假>
    参数 区域填充 <类型 = 逻辑型 注释 = "是否显示成面积图" @默认值 = 假>
    参数 数据堆叠 <类型 = 逻辑型 注释 = "是否数据堆叠" @默认值 = 假>
    {
        变量 系列参数对象 <类型 = 图表系列类>
        系列参数对象.图表类型 = 图表类型.折线图
        系列参数对象.系列名称 = 系列名称
        如果真 (数组系列数据 != 空对象)
        {
            如果真 (数组系列数据.取成员数 () > 0)
            {
                文本系列数据 = "["
                数组系列数据.枚举循环 ()
                {
                    如果 (文本系列数据 == "[")
                    {
                        文本系列数据 = 文本系列数据 + 到文本 (数组系列数据.取枚举值 ())
                    }
                    否则
                    {
                        文本系列数据 = 文本系列数据 + "," + 到文本 (数组系列数据.取枚举值 ())
                    }
                }
                文本系列数据 = 文本系列数据 + "]"
            }
        }
        如果真 (文本系列数据 != "")
        {
            系列参数对象.数据_文本 = 文本系列数据
        }

        系列参数对象.平滑曲线 = 平滑曲线
        如果真 (区域填充)
        {
            系列参数对象.区域填充.是否显示 = 区域填充
        }
        如果真 (数据堆叠)
        {
            系列参数对象.数据堆叠 = "总量"
        }
        返回 (系列集.添加系列 (系列参数对象))
    }
}

类 EC柱状图 <公开 基础类 = 直角坐标系图表基础类 注释 = "Echarts柱状图组件" @文档 = "category = \"图表控件\""
        @视窗.窗口组件 = "icon=\"icon\\柱状图.bmp\"\r\ndefault_size = \"240, 200\"\r\npreview_unsupported">
{

    # @begin
    # <> <include>
    # virtual void OnCreate () override {  @<初始设置>();}
    # <> </include>
    # @end

    方法 初始设置
    {
        坐标轴.横轴.创建坐标轴 (坐标轴类型.类目轴)
        坐标轴.纵轴.创建坐标轴 (坐标轴类型.数值轴)
        显示图例 = 真
        提示框.触发类型 = 提示框触发类型.坐标轴触发
        提示框.坐标轴指示器.类型 = 坐标轴指示器类型.阴影指示器
    }

    方法 显示背景 <公开 属性写 注释 = "是否显示柱状图柱条的背景色,在系列创建前有效.">
    参数 是否显示背景颜色 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("showBackground")]=@<是否显示背景颜色> ? _T("true") : _T("false");   
    }

    方法 显示标签 <公开 属性写 注释 = "是否在柱条显示数据的文字标签,在系列创建前有效.">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("label")]=@<是否显示> ? _T("{\"show\":true}") : _T("{\"show\":false}");
    }

    方法 柱条宽度 <公开 属性写 注释 = "柱条的宽度,不设时自适应.在系列创建前有效.">
    参数 宽度值文本 <类型 = 文本型 注释 = "可以是绝对值例如\"40\"或者百分数例如\"60%\"百分数基于自动计算出的每一类目的宽度">
    {
        如果 (取文本右边 (宽度值文本, 1) == "%")
        {
            @ @<系列集>.data().m_mapData[_T("barWidth")]=_T("\"")+@<宽度值文本>+_T("\"");   
        }
        否则
        {
            @ @<系列集>.data().m_mapData[_T("barWidth")]=@<宽度值文本>;
        }
    }

    方法 创建柱状图系列 <公开 类型 = 图表系列类 注释 = "创建一个类型为柱状图的系列数据加入系列集,并返回该系列,柱状图的一个系列代表一个柱条." @视窗.返回参考 = 真>
    参数 系列名称 <类型 = 文本型 注释 = "系列名称,在折线图中表示此数据线的名称或类目" @默认值 = "">
    参数 文本系列数据 <类型 = 文本型 注释 = "  提供一个数组文本如:\"[1,2,3,4,5,6,7]\"每个成员表示一个数据节点值." 注释 = "此参数与本方法第三个参数至少提供一个,如果同时提供了第三个参数,"
            注释 = "那么此参数将被舍弃." @默认值 = "">
    参数 数组系列数据 <类型 = 整数数组类 注释 = "数组型系列数据,如果提供了此参数,那么本方法第二参数提供的内容将被舍弃." @默认值 = 空对象>
    参数 数据堆叠 <类型 = 逻辑型 注释 = "是否数据堆叠" @默认值 = 假>
    {
        变量 系列参数对象 <类型 = 图表系列类>
        系列参数对象.图表类型 = 图表类型.柱状图
        系列参数对象.系列名称 = 系列名称
        如果真 (数组系列数据 != 空对象)
        {
            如果真 (数组系列数据.取成员数 () > 0)
            {
                文本系列数据 = "["
                数组系列数据.枚举循环 ()
                {
                    如果 (文本系列数据 == "[")
                    {
                        文本系列数据 = 文本系列数据 + 到文本 (数组系列数据.取枚举值 ())
                    }
                    否则
                    {
                        文本系列数据 = 文本系列数据 + "," + 到文本 (数组系列数据.取枚举值 ())
                    }
                }
                文本系列数据 = 文本系列数据 + "]"
            }
        }
        如果真 (文本系列数据 != "")
        {
            系列参数对象.数据_文本 = 文本系列数据
        }

        如果真 (数据堆叠)
        {
            系列参数对象.数据堆叠 = "总量"
        }
        返回 (系列集.添加系列 (系列参数对象))
    }
}

类 EC饼图 <公开 基础类 = EC基础图表 注释 = "Echarts饼图组件" @文档 = "category = \"图表控件\""
        @视窗.窗口组件 = "icon=\"icon\\饼图.bmp\"\r\ndefault_size = \"240, 200\"\r\npreview_unsupported">
{

    # @begin
    # <> <include>
    # virtual void OnCreate () override {  @<初始设置>();}
    # <> </include>
    # @end

    方法 初始设置
    {
        显示图例 = 真
        提示框.触发类型 = 提示框触发类型.数据项图形触发
    }

    方法 提示框触发类型 <公开 属性写 注释 = "鼠标动到数据图形上时,触发显示提示框的类型.">
    参数 触发类型 <类型 = 提示框触发类型 注释 = "提供提示框触发类型常量" @默认值 = 提示框触发类型.数据项图形触发>
    {
        提示框.触发类型 = 触发类型
    }

    方法 显示标签 <公开 属性写 注释 = "是否显示数据的文字标签,在系列创建前有效.">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("label")]=@<是否显示> ? _T("{\"show\":true}"): _T("{\"show\":false}");
    }

    方法 玫瑰图 <公开 属性写 注释 = "饼图是否展示成南丁格尔玫瑰图,通过半径区分数据大小.在系列创建前设置有效">
    参数 是否为玫瑰图 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 假>
    {
        @ @<系列集>.data().m_mapData[_T("roseType")]=@<是否为玫瑰图> ? _T("true"): _T("");   
    }
}

