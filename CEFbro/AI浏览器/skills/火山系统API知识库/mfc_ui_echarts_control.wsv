<火山程序 类型 = "通常" 版本 = 1 />

包 火山.ECharts <注释 = "火山MFC·Echarts图表控件">

类 EC基础图表 <公开 基础类 = 窗口组件 注释 = "火山MFC·Echarts图表基础组件,基于此组件可创建各类丰富的图表." 注释 = "Apache ECharts 基于 JavaScript 的开源可视化图表库."
        注释 = "本封装尽可能的还原了Echarts官方配置项(Option)的结构,概念及命名." 注释 = "用户可参考官方及示例迅速掌握各类图表的构建过程."
        注释 = "新手教程:https://echarts.apache.org/zh/tutorial.html" 注释 = "官方文档及示例:https://echarts.apache.org/examples/zh/index.html"
        注释 = "" @视窗.后缀文本 = "public IEChartsEventListener"
        @视窗.窗口组件 = "icon=\"icon\\ECharts.bmp\"\r\ndefault_size = \"240, 200\"\r\npreview_unsupported"
        @视窗.外部头文件 = "include\\mfc_ui_mb_echarts_wnd.h" @视窗.外部源文件 = "include\\mfc_ui_mb_echarts_wnd.cpp"
        @文档 = "category = \"图表控件\"" "//@视窗.附属文件" = "data\\echarts > echarts" ""
        "@视窗.外部源文件.d:!_VOL_ECHARTS_CTL_BASE_EDGE" = "..\\vMiniblink\\lib\\mfc_ui_mb_wnd.cpp"
        "@视窗.附属文件.x64 - d:!_VOL_ECHARTS_CTL_BASE_EDGE" = "..\\vMiniblink\\lib\\x64\\node.dll"
        "@视窗.附属文件.win32 - d:!_VOL_ECHARTS_CTL_BASE_EDGE" = "..\\vMiniblink\\lib\\win32\\node.dll" ""
        "@视窗.外部库.win32 - d:_VOL_ECHARTS_CTL_BASE_EDGE" = "..\\ui_webview2\\lib\\x86\\WebView2LoaderStatic.lib"
        "@视窗.外部库.x64 - d:_VOL_ECHARTS_CTL_BASE_EDGE" = "..\\ui_webview2\\lib\\x64\\WebView2LoaderStatic.lib"
        "@视窗.需求VS版本.d:_VOL_ECHARTS_CTL_BASE_EDGE" = "16-">
{
    方法 使用Edge浏览框 <公开 静态 注释 = "调用本方法指示编译器基于Edge浏览框来编译ECharts图表组件,如果不调用本方法,将使用MiniBlink浏览框进行编译."
            注释 = "注意: 本方法为编译时处理方法,系统在编译时只要检测到用户程序实际执行流程中任意位置调用了此方法,就启用对应的编译特性,和方法本身是否被执行到没有任何关系."
            @视窗.预定义宏 = "_VOL_ECHARTS_CTL_BASE_EDGE\r\n_WIN32_WINNT=0x0600" @视窗.编译信息 = "基于Edge浏览框来编译ECharts图表组件">
    {

    }

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_EChartsWnd, IEChartsEventListener, 0, 0, 0, 0)

    变量 标题栏 <公开 类型 = 图表标题栏类 注释 = "标题组件,包含主标题和副标题. (对应option.title配置项)" 编辑时信息 = "12D2C, 0, 0, 0">
    变量 图例 <公开 类型 = 图表图例类 注释 = "图例组件(对应option.legend 配置项)展现了不同系列的标记,颜色和名字.可以通过点击图例控制哪些系列不显示." 编辑时信息 = "12D2C, 0, 0, 0">
    变量 提示框 <公开 类型 = 图表提示框类 注释 = "提示框组件,(对应option.tooltip配置项)">
    变量 工具栏 <公开 类型 = 图表工具栏类 注释 = "工具栏组件,(对应option.toolbox配置项)内置有,数据视图,动态类型切换,数据区域缩放,数据重置等工具组件.">
    变量 数据区域缩放 <公开 类型 = 图表数据区域缩放类 注释 = "区域数据缩放组件,(对应option.dataZoom配置项) 用于区域缩放,从而能自由关注细节的数据信息,或者概览数据整体,或者去除离群点的影响.">
    变量 区域选择 <公开 类型 = 图表区域选择组件类 注释 = "区域选择组件,(对应option.brush配置项) 用户可以选择图中一部分数据,从而便于向用户展示被选中数据,或者他们的一些统计计算结果.">
    变量 视觉映射 <公开 类型 = 图表视觉映射类 注释 = "视觉映射组件,(对应option.visualMap配置项)用于进行视觉编码,也就是将数据映射到视觉元素（视觉通道）">
    变量 坐标系 <公开 类型 = 图表坐标系组件类 注释 = "图表坐标系组件,用于配置各类图表的底板网格.例如:直角坐标系上可以绘制折线图,柱状图.雷达图坐标系上可以绘制雷达图.地图坐标系上可以绘制地图.">
    变量 坐标轴 <公开 类型 = 图表坐标轴组件类 注释 = "图表坐标轴组件,用来配置各个坐标系下的坐标轴.">
    变量 坐标轴指示器 <公开 类型 = 坐标轴指示器类 注释 = "坐标轴指示器,(对应option.axisPointer配置项) 全局坐标轴指示器公用设置">
    变量 系列集 <公开 类型 = 图表系列集类 注释 = "  系列集,(对应option.series配置项)此配置项实际是个数组,每个成员即一个系列,系列是指:一组数值以及他们映射成的图."
            注释 = "其不仅表示数据,也表示数据映射成为的图.所以一个系列包含的要素至少有:一组数值,图表类型,以及其他的关于这些数据如何映射成图的参数.">
    变量 动画设置 <公开 类型 = 图表动画设置类 注释 = "作用于全局的动画设置">

    方法 取文本 <公开 类型 = 文本型 注释 = "将当前图表配置参数转换成JSON文本" 返回值注释 = "成功返回本配置项JSON文本">
    {
        变量 jsonStr <类型 = 文本型>
        变量 str <类型 = 文本型>
        str = 标题栏.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"title\":" + str, "\"title\":" + str)
        }
        str = 图例.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"legend\":" + str, "\"legend\":" + str)
        }
        str = 提示框.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"tooltip\":" + str, "\"tooltip\":" + str)
        }
        str = 工具栏.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"toolbox\":" + str, "\"toolbox\":" + str)
        }
        str = 坐标轴指示器.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"axisPointer\":" + str, "\"axisPointer\":" + str)
        }
        str = 系列集.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"series\":" + str, "\"series\":" + str)
        }
        @ @<str> =  getWndPtr ()->m_color;  //调色盘
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + "," + "\"color\":" + str, "\"color\":" + str)
        }
        @ @<str> = getWndPtr ()->m_backgroundColor;  //背景色
        如果 (str != "")
        {
            如果 (取文本左边 (str, 1) == "{")  // 渐变或纹理填充时为js对象
            {
                jsonStr = 选择 (jsonStr != "", jsonStr + "," + "\"backgroundColor\":" + str, "\"backgroundColor\":" + str)
            }
            否则
            {
                jsonStr = 选择 (jsonStr != "", jsonStr + "," + "\"backgroundColor\":\"" + str + "\"", "\"backgroundColor\":\"" + str + "\"")
            }
        }
        @ @<str> = getWndPtr ()->m_darkMode; //暗黑模式
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + "," + "\"darkMode\":" + str, "\"darkMode\":" + str)
        }
        str = 坐标系.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + "," + str, str)
        }
        str = 坐标轴.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + "," + str, str)
        }
        str = 视觉映射.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"visualMap\":" + str, "\"visualMap\":" + str)
        }
        str = 数据区域缩放.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"dataZoom\":" + str, "\"dataZoom\":" + str)
        }
        str = 区域选择.取文本 ()
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + ",\"brush\":" + str, "\"brush\":" + str)
        }
        @ @<str>=@<动画设置>.getKeyValueStr(); //动画设置的成员是option的子成员 这里直接拼接到根
        如果 (str != "")
        {
            jsonStr = 选择 (jsonStr != "", jsonStr + "," + str, str)
        }
        jsonStr = "{" + jsonStr + "}"
        返回 (jsonStr)
    }

    方法 清空参数 <公开 注释 = "清空本图表对象的所有配置参数,同时柱图,折线图,K线图等基础图表组件的初始设置也会被一并清空.">
    参数 保留主题风格 <类型 = 逻辑型 注释 = "真为保留风格主题配置" @默认值 = 假>
    参数 保留调色盘 <类型 = 逻辑型 注释 = "真为保留调色盘配置" @默认值 = 假>
    参数 保留背景颜色 <类型 = 逻辑型 注释 = "真为保留背景颜色" @默认值 = 假>
    {
        标题栏.重置对象内容 ()
        图例.重置对象内容 ()
        提示框.重置对象内容 ()
        工具栏.重置对象内容 ()
        视觉映射.重置对象内容 ()
        数据区域缩放.重置对象内容 ()
        区域选择.重置对象内容 ()
        坐标系.重置对象内容 ()
        坐标轴.重置对象内容 ()
        坐标轴指示器.重置对象内容 ()
        系列集.清空 ()
        动画设置.清空参数 ()
        如果 (保留主题风格 == 假)
        {
            @ getWndPtr ()->m_theme =_T("");
            @ getWndPtr ()->m_userTheme =_T("");
            @ getWndPtr ()->m_userThemeJson =_T("");
        }
        如果 (保留调色盘 == 假)
        {
            @ getWndPtr ()->m_color =_T("");
        }
        如果 (保留背景颜色 == 假)
        {
            @ getWndPtr ()->m_backgroundColor =_T("");
        }
    }

    方法 画图 <公开 注释 = "生成图表配置,创建图表实例并执行画图.">
    {
        变量 jsStr <类型 = 文本型>
        变量 主题插件 <类型 = 文本型>
        变量 主题名称 <类型 = 文本型>
        jsStr = "window.option=" + 取文本 ()  // 全部配置项
        @ getWndPtr ()->ExecuteScript (@<jsStr>.GetText (), NULL);
        // 设置主题
        @ if (getWndPtr ()->m_userTheme != _T("") && getWndPtr ()->m_userThemeJson != _T(""))
        @ {
        @ @<主题名称>= getWndPtr ()->m_userTheme;
        @ @<主题插件> = getWndPtr ()->m_userThemeJson;
        jsStr = "ThemeObj=" + 主题插件 + ";echarts.registerTheme('" + 主题名称 + "', ThemeObj);"
        @ getWndPtr ()->ExecuteScript (@<jsStr>.GetText (), NULL);
        @ } else {
        @ @<主题名称>=getWndPtr ()->m_theme;
        如果真 (主题名称 != "")
        {
            如果 (主题名称 == "dark")
            {
                主题插件 = dark
            }
            否则 (主题名称 == "vintage")
            {
                主题插件 = vintage
            }
            否则 (主题名称 == "macarons")
            {
                主题插件 = macarons
            }
            否则 (主题名称 == "infographic")
            {
                主题插件 = infographic
            }
            否则 (主题名称 == "roma")
            {
                主题插件 = roma
            }
            否则 (主题名称 == "shine")
            {
                主题插件 = shine
            }
            否则 (主题名称 == "westeros")
            {
                主题插件 = westeros
            }
            否则 (主题名称 == "essos")
            {
                主题插件 = essos
            }
            否则 (主题名称 == "walden")
            {
                主题插件 = walden
            }
            否则 (主题名称 == "wonderland")
            {
                主题插件 = wonderland
            }
            否则 (主题名称 == "chalk")
            {
                主题插件 = chalk
            }
            否则 (主题名称 == "purple-passion")
            {
                主题插件 = purplepassion
            }
            @ getWndPtr ()->ExecuteScript (@<主题插件>.GetText (), NULL);
        }
        @ }
        // 添加点击事件脚本
        @ if (getWndPtr ()->m_enableClickEvent) {
        @ #ifndef _VOL_ECHARTS_CTL_BASE_EDGE
        常量 添加点击事件1 <类型 = 文本型
                值 = "if (sendOnClickEventData != undefined)\r\n{\r\n  myChart.on(\"click\", function (e) {\r\n    const data = {\r\n      name: e.name,\r\n      value: e.value,\r\n      seriesName: e.seriesName,\r\n      seriesIndex: e.seriesIndex,\r\n      seriesType: e.seriesType,\r\n      data: e.data,\r\n      dataIndex: e.dataIndex,\r\n      dataType: e.dataType,\r\n      color: e.color,\r\n      componentType: e.componentType,\r\n      componentSubType: e.componentSubType,\r\n      componentIndex: e.componentIndex,\r\n      percent: e.percent,\r\n      info: e.info\r\n    }\r\n    sendOnClickEventData(JSON.stringify(data));\r\n  })\r\n}">
        jsStr = "setTimeout(()=>{if(myChart != undefined)myChart.dispose(); myChart = echarts.init (dom,'" + 主题名称 + "'); myChart.setOption(option);" + 添加点击事件1 + "},0)"
        @ #else
        常量 添加点击事件2 <类型 = 文本型
                值 = "myChart.on(\"click\", function (e) {\r\nconst params = {\r\nevent: \"OnEChartItemClick\",\r\nname: e.name,\r\nvalue: e.value,\r\nseriesName: e.seriesName,\r\nseriesIndex: e.seriesIndex,\r\nseriesType: e.seriesType,\r\ndata: e.data,\r\ndataIndex: e.dataIndex,\r\ndataType: e.dataType,\r\ncolor: e.color,\r\ncomponentType: e.componentType,\r\ncomponentSubType: e.componentSubType,\r\ncomponentIndex: e.componentIndex,\r\npercent: e.percent,\r\ninfo: e.info\r\n};\r\nwindow.chrome.webview.postMessage(JSON.stringify(params));\r\n});">
        jsStr = "setTimeout(()=>{if(myChart != undefined)myChart.dispose(); myChart = echarts.init (dom,'" + 主题名称 + "'); myChart.setOption(option);" + 添加点击事件2 + "},0)"
        @ #endif
        @ } else {
        jsStr = "setTimeout(()=>{if(myChart != undefined)myChart.dispose(); myChart = echarts.init (dom,'" + 主题名称 + "'); myChart.setOption(option);},0)"
        @ }

        @ getWndPtr ()->ExecuteScript (@<jsStr>.GetText (), NULL);
        @ getWndPtr ()->m_echartsInit=true;
    }

    方法 更新重画 <公开 注释 = "生成图表配置,不创建新的图表实例,将配置数据以覆盖的方式写入实例配置,并更新图表.">
    {
        变量 jsStr <类型 = 文本型>
        jsStr = "window.option=" + 取文本 ()
        @ getWndPtr ()->ExecuteScript (@<jsStr>.GetText (), NULL);
        jsStr = "setTimeout(()=>{if(myChart != undefined)myChart.setOption(option);},0)"
        @ getWndPtr ()->ExecuteScript (@<jsStr>.GetText (), NULL);
    }

    常量 vintage <类型 = 文本型
            值 = "echarts.registerTheme(\'vintage\',{\"color\":[\"#d87c7c\",\"#919e8b\",\"#d7ab82\",\"#6e7074\",\"#61a0a8\",\"#efa18d\",\"#787464\",\"#cc7e63\",\"#724e58\",\"#4b565b\"],\"backgroundColor\":\"rgba(254,248,239,1)\",\"textStyle\":{},\"title\":{\"textStyle\":{\"color\":\"#333333\"},\"subtextStyle\":{\"color\":\"#aaaaaa\"}},\"line\":{\"itemStyle\":{\"borderWidth\":1},\"lineStyle\":{\"width\":2},\"symbolSize\":4,\"symbol\":\"emptyCircle\",\"smooth\":false},\"radar\":{\"itemStyle\":{\"borderWidth\":1},\"lineStyle\":{\"width\":2},\"symbolSize\":4,\"symbol\":\"emptyCircle\",\"smooth\":false},\"bar\":{\"itemStyle\":{\"barBorderWidth\":0,\"barBorderColor\":\"#ccc\"}},\"pie\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"scatter\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"boxplot\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"parallel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"sankey\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"funnel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"gauge\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"candlestick\":{\"itemStyle\":{\"color\":\"#c23531\",\"color0\":\"#314656\",\"borderColor\":\"#c23531\",\"borderColor0\":\"#314656\",\"borderWidth\":1}},\"graph\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"},\"lineStyle\":{\"width\":1,\"color\":\"#aaa\"},\"symbolSize\":4,\"symbol\":\"emptyCircle\",\"smooth\":false,\"color\":[\"#d87c7c\",\"#919e8b\",\"#d7ab82\",\"#6e7074\",\"#61a0a8\",\"#efa18d\",\"#787464\",\"#cc7e63\",\"#724e58\",\"#4b565b\"],\"label\":{\"color\":\"#eeeeee\"}},\"map\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eeeeee\",\"borderColor\":\"#444444\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(255,215,0,0.8)\",\"borderColor\":\"#444444\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#000000\"}},\"emphasis\":{\"textStyle\":{\"color\":\"rgb(100,0,0)\"}}}},\"geo\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eeeeee\",\"borderColor\":\"#444444\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(255,215,0,0.8)\",\"borderColor\":\"#444444\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#000000\"}},\"emphasis\":{\"textStyle\":{\"color\":\"rgb(100,0,0)\"}}}},\"categoryAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisTick\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#333\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#ccc\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.3)\",\"rgba(200,200,200,0.3)\"]}}},\"valueAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisTick\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#333\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#ccc\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.3)\",\"rgba(200,200,200,0.3)\"]}}},\"logAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisTick\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#333\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#ccc\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.3)\",\"rgba(200,200,200,0.3)\"]}}},\"timeAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisTick\":{\"show\":true,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#333\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#ccc\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.3)\",\"rgba(200,200,200,0.3)\"]}}},\"toolbox\":{\"iconStyle\":{\"normal\":{\"borderColor\":\"#999999\"},\"emphasis\":{\"borderColor\":\"#666666\"}}},\"legend\":{\"textStyle\":{\"color\":\"#333333\"}},\"tooltip\":{\"axisPointer\":{\"lineStyle\":{\"color\":\"#cccccc\",\"width\":1},\"crossStyle\":{\"color\":\"#cccccc\",\"width\":1}}},\"timeline\":{\"lineStyle\":{\"color\":\"#293c55\",\"width\":1},\"itemStyle\":{\"normal\":{\"color\":\"#293c55\",\"borderWidth\":1},\"emphasis\":{\"color\":\"#a9334c\"}},\"controlStyle\":{\"normal\":{\"color\":\"#293c55\",\"borderColor\":\"#293c55\",\"borderWidth\":0.5},\"emphasis\":{\"color\":\"#293c55\",\"borderColor\":\"#293c55\",\"borderWidth\":0.5}},\"checkpointStyle\":{\"color\":\"#e43c59\",\"borderColor\":\"#c23531\"},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#293c55\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#293c55\"}}}},\"visualMap\":{\"color\":[\"#bf444c\",\"#d88273\",\"#f6efa6\"]},\"dataZoom\":{\"backgroundColor\":\"rgba(47,69,84,0)\",\"dataBackgroundColor\":\"rgba(47,69,84,0.3)\",\"fillerColor\":\"rgba(167,183,204,0.4)\",\"handleColor\":\"#a7b7cc\",\"handleSize\":\"100%\",\"textStyle\":{\"color\":\"#333333\"}},\"markPoint\":{\"label\":{\"color\":\"#eeeeee\"},\"emphasis\":{\"label\":{\"color\":\"#eeeeee\"}}}})"
            注释 = "主题风格 vintage 复古">
    常量 dark <类型 = 文本型
