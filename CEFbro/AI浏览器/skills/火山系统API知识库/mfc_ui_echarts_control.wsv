            值 = "echarts.registerTheme(\'wonderland\',{\"color\":[\"#4ea397\",\"#22c3aa\",\"#7bd9a5\",\"#d0648a\",\"#f58db2\",\"#f2b3c9\"],\"backgroundColor\":\"rgba(255,255,255,0)\",\"textStyle\":{},\"title\":{\"textStyle\":{\"color\":\"#666666\"},\"subtextStyle\":{\"color\":\"#999999\"}},\"line\":{\"itemStyle\":{\"borderWidth\":\"2\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"8\",\"symbol\":\"emptyCircle\",\"smooth\":false},\"radar\":{\"itemStyle\":{\"borderWidth\":\"2\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"8\",\"symbol\":\"emptyCircle\",\"smooth\":false},\"bar\":{\"itemStyle\":{\"barBorderWidth\":0,\"barBorderColor\":\"#ccc\"}},\"pie\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"scatter\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"boxplot\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"parallel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"sankey\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"funnel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"gauge\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"candlestick\":{\"itemStyle\":{\"color\":\"#d0648a\",\"color0\":\"transparent\",\"borderColor\":\"#d0648a\",\"borderColor0\":\"#22c3aa\",\"borderWidth\":\"1\"}},\"graph\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"},\"lineStyle\":{\"width\":\"1\",\"color\":\"#cccccc\"},\"symbolSize\":\"8\",\"symbol\":\"emptyCircle\",\"smooth\":false,\"color\":[\"#4ea397\",\"#22c3aa\",\"#7bd9a5\",\"#d0648a\",\"#f58db2\",\"#f2b3c9\"],\"label\":{\"color\":\"#ffffff\"}},\"map\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eeeeee\",\"borderColor\":\"#999999\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(34,195,170,0.25)\",\"borderColor\":\"#22c3aa\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#28544e\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#349e8e\"}}}},\"geo\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eeeeee\",\"borderColor\":\"#999999\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(34,195,170,0.25)\",\"borderColor\":\"#22c3aa\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#28544e\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#349e8e\"}}}},\"categoryAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#999999\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#eeeeee\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"valueAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#999999\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#eeeeee\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"logAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#999999\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#eeeeee\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"timeAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#999999\"}},\"splitLine\":{\"show\":true,\"lineStyle\":{\"color\":[\"#eeeeee\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"toolbox\":{\"iconStyle\":{\"normal\":{\"borderColor\":\"#999999\"},\"emphasis\":{\"borderColor\":\"#666666\"}}},\"legend\":{\"textStyle\":{\"color\":\"#999999\"}},\"tooltip\":{\"axisPointer\":{\"lineStyle\":{\"color\":\"#cccccc\",\"width\":1},\"crossStyle\":{\"color\":\"#cccccc\",\"width\":1}}},\"timeline\":{\"lineStyle\":{\"color\":\"#4ea397\",\"width\":1},\"itemStyle\":{\"normal\":{\"color\":\"#4ea397\",\"borderWidth\":1},\"emphasis\":{\"color\":\"#4ea397\"}},\"controlStyle\":{\"normal\":{\"color\":\"#4ea397\",\"borderColor\":\"#4ea397\",\"borderWidth\":0.5},\"emphasis\":{\"color\":\"#4ea397\",\"borderColor\":\"#4ea397\",\"borderWidth\":0.5}},\"checkpointStyle\":{\"color\":\"#4ea397\",\"borderColor\":\"#3cebd2\"},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#4ea397\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#4ea397\"}}}},\"visualMap\":{\"color\":[\"#d0648a\",\"#22c3aa\",\"#adfff1\"]},\"dataZoom\":{\"backgroundColor\":\"rgba(255,255,255,0)\",\"dataBackgroundColor\":\"rgba(222,222,222,1)\",\"fillerColor\":\"rgba(114,230,212,0.25)\",\"handleColor\":\"#cccccc\",\"handleSize\":\"100%\",\"textStyle\":{\"color\":\"#999999\"}},\"markPoint\":{\"label\":{\"color\":\"#ffffff\"},\"emphasis\":{\"label\":{\"color\":\"#ffffff\"}}}})"
            注释 = "主题风格 wonderland 梦游仙境">
    常量 chalk <类型 = 文本型
            值 = "echarts.registerTheme(\'chalk\',{\"color\":[\"#fc97af\",\"#87f7cf\",\"#f7f494\",\"#72ccff\",\"#f7c5a0\",\"#d4a4eb\",\"#d2f5a6\",\"#76f2f2\"],\"backgroundColor\":\"rgba(41,52,65,1)\",\"textStyle\":{},\"title\":{\"textStyle\":{\"color\":\"#ffffff\"},\"subtextStyle\":{\"color\":\"#dddddd\"}},\"line\":{\"itemStyle\":{\"borderWidth\":\"4\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"0\",\"symbol\":\"circle\",\"smooth\":true},\"radar\":{\"itemStyle\":{\"borderWidth\":\"4\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"0\",\"symbol\":\"circle\",\"smooth\":true},\"bar\":{\"itemStyle\":{\"barBorderWidth\":0,\"barBorderColor\":\"#ccc\"}},\"pie\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"scatter\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"boxplot\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"parallel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"sankey\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"funnel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"gauge\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"candlestick\":{\"itemStyle\":{\"color\":\"#fc97af\",\"color0\":\"transparent\",\"borderColor\":\"#fc97af\",\"borderColor0\":\"#87f7cf\",\"borderWidth\":\"2\"}},\"graph\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"},\"lineStyle\":{\"width\":\"1\",\"color\":\"#ffffff\"},\"symbolSize\":\"0\",\"symbol\":\"circle\",\"smooth\":true,\"color\":[\"#fc97af\",\"#87f7cf\",\"#f7f494\",\"#72ccff\",\"#f7c5a0\",\"#d4a4eb\",\"#d2f5a6\",\"#76f2f2\"],\"label\":{\"color\":\"#293441\"}},\"map\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#f3f3f3\",\"borderColor\":\"#999999\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(255,178,72,1)\",\"borderColor\":\"#eb8146\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#893448\"}},\"emphasis\":{\"textStyle\":{\"color\":\"rgb(137,52,72)\"}}}},\"geo\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#f3f3f3\",\"borderColor\":\"#999999\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"rgba(255,178,72,1)\",\"borderColor\":\"#eb8146\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#893448\"}},\"emphasis\":{\"textStyle\":{\"color\":\"rgb(137,52,72)\"}}}},\"categoryAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#666666\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#aaaaaa\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#e6e6e6\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"valueAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#666666\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#aaaaaa\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#e6e6e6\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"logAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#666666\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#aaaaaa\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#e6e6e6\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"timeAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#666666\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#aaaaaa\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#e6e6e6\"]}},\"splitArea\":{\"show\":false,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"toolbox\":{\"iconStyle\":{\"normal\":{\"borderColor\":\"#999999\"},\"emphasis\":{\"borderColor\":\"#666666\"}}},\"legend\":{\"textStyle\":{\"color\":\"#999999\"}},\"tooltip\":{\"axisPointer\":{\"lineStyle\":{\"color\":\"#cccccc\",\"width\":1},\"crossStyle\":{\"color\":\"#cccccc\",\"width\":1}}},\"timeline\":{\"lineStyle\":{\"color\":\"#87f7cf\",\"width\":1},\"itemStyle\":{\"normal\":{\"color\":\"#87f7cf\",\"borderWidth\":1},\"emphasis\":{\"color\":\"#f7f494\"}},\"controlStyle\":{\"normal\":{\"color\":\"#87f7cf\",\"borderColor\":\"#87f7cf\",\"borderWidth\":0.5},\"emphasis\":{\"color\":\"#87f7cf\",\"borderColor\":\"#87f7cf\",\"borderWidth\":0.5}},\"checkpointStyle\":{\"color\":\"#fc97af\",\"borderColor\":\"#fc97af\"},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#87f7cf\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#87f7cf\"}}}},\"visualMap\":{\"color\":[\"#fc97af\",\"#87f7cf\"]},\"dataZoom\":{\"backgroundColor\":\"rgba(255,255,255,0)\",\"dataBackgroundColor\":\"rgba(114,204,255,1)\",\"fillerColor\":\"rgba(114,204,255,0.2)\",\"handleColor\":\"#72ccff\",\"handleSize\":\"100%\",\"textStyle\":{\"color\":\"#333333\"}},\"markPoint\":{\"label\":{\"color\":\"#293441\"},\"emphasis\":{\"label\":{\"color\":\"#293441\"}}}})"
            注释 = "主题风格 chalk 黑粉 板书">
    常量 purplepassion <类型 = 文本型
            值 = "echarts.registerTheme(\'purple-passion\',{\"color\":[\"#9b8bba\",\"#e098c7\",\"#8fd3e8\",\"#71669e\",\"#cc70af\",\"#7cb4cc\"],\"backgroundColor\":\"rgba(91,92,110,1)\",\"textStyle\":{},\"title\":{\"textStyle\":{\"color\":\"#ffffff\"},\"subtextStyle\":{\"color\":\"#cccccc\"}},\"line\":{\"itemStyle\":{\"borderWidth\":\"2\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"7\",\"symbol\":\"circle\",\"smooth\":true},\"radar\":{\"itemStyle\":{\"borderWidth\":\"2\"},\"lineStyle\":{\"width\":\"3\"},\"symbolSize\":\"7\",\"symbol\":\"circle\",\"smooth\":true},\"bar\":{\"itemStyle\":{\"barBorderWidth\":0,\"barBorderColor\":\"#ccc\"}},\"pie\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"scatter\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"boxplot\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"parallel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"sankey\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"funnel\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"gauge\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"}},\"candlestick\":{\"itemStyle\":{\"color\":\"#e098c7\",\"color0\":\"transparent\",\"borderColor\":\"#e098c7\",\"borderColor0\":\"#8fd3e8\",\"borderWidth\":\"2\"}},\"graph\":{\"itemStyle\":{\"borderWidth\":0,\"borderColor\":\"#ccc\"},\"lineStyle\":{\"width\":1,\"color\":\"#aaaaaa\"},\"symbolSize\":\"7\",\"symbol\":\"circle\",\"smooth\":true,\"color\":[\"#9b8bba\",\"#e098c7\",\"#8fd3e8\",\"#71669e\",\"#cc70af\",\"#7cb4cc\"],\"label\":{\"color\":\"#eeeeee\"}},\"map\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eee\",\"borderColor\":\"#444\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"#e098c7\",\"borderColor\":\"#444\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#000\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#ffffff\"}}}},\"geo\":{\"itemStyle\":{\"normal\":{\"areaColor\":\"#eee\",\"borderColor\":\"#444\",\"borderWidth\":0.5},\"emphasis\":{\"areaColor\":\"#e098c7\",\"borderColor\":\"#444\",\"borderWidth\":1}},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#000\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#ffffff\"}}}},\"categoryAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#cccccc\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#eeeeee\",\"#333333\"]}},\"splitArea\":{\"show\":true,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"valueAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#cccccc\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#eeeeee\",\"#333333\"]}},\"splitArea\":{\"show\":true,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"logAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#cccccc\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#eeeeee\",\"#333333\"]}},\"splitArea\":{\"show\":true,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"timeAxis\":{\"axisLine\":{\"show\":true,\"lineStyle\":{\"color\":\"#cccccc\"}},\"axisTick\":{\"show\":false,\"lineStyle\":{\"color\":\"#333\"}},\"axisLabel\":{\"show\":true,\"textStyle\":{\"color\":\"#cccccc\"}},\"splitLine\":{\"show\":false,\"lineStyle\":{\"color\":[\"#eeeeee\",\"#333333\"]}},\"splitArea\":{\"show\":true,\"areaStyle\":{\"color\":[\"rgba(250,250,250,0.05)\",\"rgba(200,200,200,0.02)\"]}}},\"toolbox\":{\"iconStyle\":{\"normal\":{\"borderColor\":\"#999999\"},\"emphasis\":{\"borderColor\":\"#666666\"}}},\"legend\":{\"textStyle\":{\"color\":\"#cccccc\"}},\"tooltip\":{\"axisPointer\":{\"lineStyle\":{\"color\":\"#cccccc\",\"width\":1},\"crossStyle\":{\"color\":\"#cccccc\",\"width\":1}}},\"timeline\":{\"lineStyle\":{\"color\":\"#8fd3e8\",\"width\":1},\"itemStyle\":{\"normal\":{\"color\":\"#8fd3e8\",\"borderWidth\":1},\"emphasis\":{\"color\":\"#8fd3e8\"}},\"controlStyle\":{\"normal\":{\"color\":\"#8fd3e8\",\"borderColor\":\"#8fd3e8\",\"borderWidth\":0.5},\"emphasis\":{\"color\":\"#8fd3e8\",\"borderColor\":\"#8fd3e8\",\"borderWidth\":0.5}},\"checkpointStyle\":{\"color\":\"#8fd3e8\",\"borderColor\":\"#8a7ca8\"},\"label\":{\"normal\":{\"textStyle\":{\"color\":\"#8fd3e8\"}},\"emphasis\":{\"textStyle\":{\"color\":\"#8fd3e8\"}}}},\"visualMap\":{\"color\":[\"#8a7ca8\",\"#e098c7\",\"#cceffa\"]},\"dataZoom\":{\"backgroundColor\":\"rgba(0,0,0,0)\",\"dataBackgroundColor\":\"rgba(255,255,255,0.3)\",\"fillerColor\":\"rgba(167,183,204,0.4)\",\"handleColor\":\"#a7b7cc\",\"handleSize\":\"100%\",\"textStyle\":{\"color\":\"#333\"}},\"markPoint\":{\"label\":{\"color\":\"#eeeeee\"},\"emphasis\":{\"label\":{\"color\":\"#eeeeee\"}}}})"
            注释 = "主题风格 purple-passion 紫色激情">
    常量 m_echartJsFile <类型 = 视窗文件资源 值 = "data\\echarts\\echarts.min.js" 注释 = "ECharts js">

    方法 执行JS脚本 <公开 类型 = 文本型 注释 = "执行一段js脚本" @嵌入式方法 = "">
    参数 JS文本 <类型 = 文本型 注释 = "提供一段js文本">
    {
        @ @sn<this>.runJs(@<JS文本>)
    }

    方法 执行JS脚本2 <公开 类型 = 文本型 注释 = "执行一段js脚本,返回执行结果文本." @嵌入式方法 = "">
    参数 JS文本 <类型 = 文本型 注释 = "提供一段js文本,如果要返回结果请在欲返回的内容之前添加\"return\"">
    {
        @ @sn<this>.runJsGetStr(@<JS文本>)
    }

    方法 启用高分辨率支持 <公开 注释 = "本质是通过设置缩放级别并且关闭系统默认缩放来实现的." @嵌入式方法 = "">
    {
        @ wkeEnableHighDPISupport()
    }

    方法 缩放级别 <公开 属性写 注释 = "浏览器容器的缩放系数">
    参数 缩放级别 <类型 = 小数 注释 = "缩放系数,正常为1.">
    {
        @ getWndPtr ()->SetZoomFactor (@<缩放级别>);
    }

    方法 缩放级别 <公开 属性读 类型 = 小数 注释 = "浏览器容器缩放系数" 返回值注释 = "返回缩放系数" @禁止流程检查 = 真>
    {
        @ return getWndPtr ()->GetZoomFactor ();
    }

    方法 启用复制图片菜单 <公开 属性写 注释 = "启用或屏蔽\'复制图片\'右键菜单." 注释 = "注意: 本方法在使用\"Edge浏览框\"来编译本组件时无效.">
    参数 是否启用 <类型 = 逻辑型 注释 = "假为屏蔽" @默认值 = 真>
    {
        @ #ifndef _VOL_ECHARTS_CTL_BASE_EDGE
        @     wkeSetContextMenuItemShow(getWndPtr ()->m_webView, wkeMenuItemId::kWkeMenuCopyImageId,@<是否启用>);
        @ #endif
    }

    方法 启用图片另存菜单 <公开 属性写 注释 = "启用或屏蔽\'启用图片另存\'右键菜单." 注释 = "注意: 本方法在使用\"Edge浏览框\"来编译本组件时无效.">
    参数 是否启用 <类型 = 逻辑型 注释 = "假为屏蔽" @默认值 = 真>
    {
        @ #ifndef _VOL_ECHARTS_CTL_BASE_EDGE
        @     wkeSetContextMenuItemShow(getWndPtr ()->m_webView, wkeMenuItemId::kWkeMenuSaveImageId,@<是否启用>);
        @ #endif
    }

    方法 截图 <公开 类型 = 字节集类 注释 = "将图表页面打印到位图,如果使用\"MiniBlink浏览框\"编译,返回位图(bmp)字节集数据,如果使用\"Edge浏览框\"编译,返回的是PNG图片字节集数据."
            返回值注释 = "成功返回截图数据,失败返回空字节集." @禁止流程检查 = 真>
    {
        @ return getWndPtr ()->CapturePreview ();
    }

    方法 自定义风格主题 <公开 注释 = "用户可自行构建风格主题" "">
    参数 主题名称 <类型 = 文本型 注释 = "提供自定义主题名称" "">
    参数 主题配置文本 <类型 = 文本型 注释 = "主题配置,提供一个ECharts主题JSON文本,具体格式参考官方主题构建工具">
    {
        @ getWndPtr ()->m_userTheme= @<主题名称>;
        @ getWndPtr ()->m_userThemeJson= @<主题配置文本>;
    }

    方法 风格主题 <公开 属性写 注释 = "设置图表的颜色风格,本模块中内置了官方提供的12种主题风格." "">
    参数 主题名称 <类型 = 图表风格主题 注释 = "提供图表风格主题常量" "">
    {
        @ getWndPtr ()->m_theme=  @<主题名称>;
        @ getWndPtr ()->m_userTheme=_T("");
    }

    方法 暗黑模式 <公开 属性写 注释 = "是否是暗黑模式,默认会根据背景色的亮度自动设置, 如果是设置了容器的背景色而无法判断到,就可以使用该配置手动指定,echarts会根据是否是暗黑模式调整文本等的颜色。" "">
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用">
    {
        @ getWndPtr ()->m_darkMode= @<是否启用> ? _T("true") : _T("false");
    }

    方法 调色盘颜色列表 <公开 属性写 注释 = "调色盘颜色列表,如果系列没有设置颜色,则会依次循环从默认列表中取颜色作为系列颜色">
    参数 颜色列表 <类型 = 文本型
            注释 = "  提供一个数组文本如:\"[\'#5470c6\', \'#91cc75\', \'#fac858\', \'#ee6666\', \'#73c0de\', \'#3ba272\', \'#fc8452\', \'#9a60b4\', \'#ea7ccc\']\"."
            注释 = "每个成员为一个颜色值依次代表一个系列的颜色.">
    {
        @ getWndPtr ()->m_color= @<颜色列表>;
    }

    方法 背景颜色 <公开 属性写 注释 = "设置图表容器的背景颜色">
    参数 颜色值 <类型 = 文本型 注释 = "颜色可以使用RGB表示，比如 \'rgb(128, 128, 128)\' 或 \'rgba(128, 128, 128, 0.5)\',也可以使用十六进制格式,比如 \'#ccc\'">
    {
        @ getWndPtr ()->m_backgroundColor= @<颜色值>;
    }

    方法 启用图表项点击事件 <公开 属性写 注释 = "启用图表项点击事件" @视窗.设置时机 = 组件创建前>
    参数 是否启用 <类型 = 逻辑型>
    {
        @ getWndPtr ()->m_enableClickEvent = (@<是否启用> ? true : false);
    }

    方法 置背景填充 <公开 注释 = "设置图表容器的背景纹理填充">
    参数 纹理图形 <类型 = 文本型 注释 = "提供一个图片链接地址,支持本地路相对径如:\"img/img.png\".也可以是dataURL格式 如:\"data:image/png;...\"">
    参数 平铺重复 <类型 = 图表背景重复模式 注释 = "提供图表背景重复模式常量" @默认值 = 图表背景重复模式.重复>
    {
        @ CVolString jsStr=_T("window.bgImg = new Image();window.bgImg.src='")+@<纹理图形>+=_T("'");
        @ runJs (jsStr);
        变量 重复 <静态 类型 = 文本型>
        重复 = "{\"image\":window.bgImg, \"repeat\":\"" + (文本型)平铺重复 + "\"}"
        @ getWndPtr ()->m_backgroundColor= @<重复>; 
    }

    方法 置背景颜色径向渐变 <公开 注释 = "设置图表容器的背景径向渐变颜色">
    参数 中心点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 中心点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 渐变半径 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 结束颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 是否绝对值 <类型 = 逻辑型 注释 = "默认位置采用百分比值,如果设置为真则采用绝对像素值" @默认值 = 假>
    {
        变量 color <静态 类型 = 文本型>
        color = "{\"type\":\"radial\",\"x\":" + 到文本 (中心点横坐标) + ",\"y\":" + 到文本 (中心点纵坐标) + ", \"r\":" + 到文本 (渐变半径) + ",\"colorStops\":[{\"offset\": 0, \"color\":\"" + 起始颜色 + "\"}, {\"offset\":1, \"color\":\"" + 结束颜色 + "\"}], \"global\":" + 选择 (是否绝对值, "1", "0") + "}"
        @ getWndPtr ()->m_backgroundColor= @<color>; 
    }

    方法 置背景颜色线性渐变 <公开 注释 = "设置图表容器的背景线性渐变颜色">
    参数 起始点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 结束点横坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 结束点纵坐标 <类型 = 小数 注释 = "取值范围0-1.">
    参数 起始颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 结束颜色 <类型 = 文本型 注释 = "可以使用rgb或十六进制格式颜色值">
    参数 是否绝对值 <类型 = 逻辑型 注释 = "默认位置采用百分比值,如果设置为真则采用绝对像素值" @默认值 = 假>
    {
        变量 color <静态 类型 = 文本型>
        color = "{\"type\":\"linear\",\"x\":" + 到文本 (起始点横坐标) + ",\"y\":" + 到文本 (起始点纵坐标) + ", \"x2\":" + 到文本 (结束点横坐标) + ", \"y2\":" + 到文本 (结束点纵坐标) + ",\"colorStops\":[{\"offset\": 0, \"color\":\"" + 起始颜色 + "\"}, {\"offset\":1, \"color\":\"" + 结束颜色 + "\"}], \"global\":" + 选择 (是否绝对值, "1", "0") + "}"
        @ getWndPtr ()->m_backgroundColor= @<color>; 
    }

    方法 置图片元素 <公开 注释 = "在图表环境中创建一个图片元素(Image),用于后续图表元素的纹理填充.">
    参数 图片地址 <类型 = 文本型 注释 = "提供一个图片链接地址,支持本地路相对径如:\"img/img.png\".也可以是dataURL格式 如:\"data:image/png;...\"">
    参数 图片名称 <类型 = 文本型 注释 = "图片在图表环境中的唯一名称">
    {
        @ CVolString jsStr=_T("window.")+@<图片名称>+_T(" = new Image();window.")+@<图片名称>+_T(".src='")+@<图片地址>+=_T("'");
        @ runJs (jsStr);
    }

    方法 注册地图 <公开 注释 = "用于为地理坐标或地图系列的地图类型系注册地图">
    参数 地图名称 <类型 = 文本型 注释 = "提供一个地图名称,用于在地理坐标系或地图系列中指定所注册的地图.">
    参数 地图数据 <类型 = 文本型 注释 = "提供一个地图数据对象文本,可以是geoJSON,也可以是SGV文件数据: \"{ svg: svg }\"具体使用格式请参考官方文档.">
    参数 特定区域设置 <类型 = 文本型 注释 = "如果地图数据为geoJSON,这里可以提供一个对象文本用与配置特定区域的位置缩放及样式.具体使用格式请参考官方文档." @默认值 = "">
    {
        @ CVolString jsStr;
        如果 (特定区域设置 == "")
        {
            @ jsStr=_T("echarts.registerMap('")+@<地图名称>+_T("', ")+@<地图数据>+_T(");");
        }
        否则
        {
            @ jsStr=_T("echarts.registerMap('")+@<地图名称>+_T("', ")+@<地图数据>+_T(", ")+@<特定区域设置>+_T(");");
        }
        @ runJs (jsStr);
    }

    方法 显示标题栏 <公开 属性写 注释 = "是否显示图表标题栏">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        标题栏.是否显示 = 是否显示
    }

    方法 显示图例 <公开 属性写 注释 = "是否显示图例">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        图例.是否显示 = 是否显示
    }

    方法 显示提示框 <公开 属性写 注释 = "是否显示提示框组件">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        提示框.是否显示 = 是否显示
    }

    方法 显示工具栏 <公开 属性写 注释 = "是否显示工具栏组件">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 假>
    {
        工具栏.是否显示 = 是否显示
    }

    方法 主标题 <公开 属性写 注释 = "设置图表的主标题内容,设置该项将自动显示标题栏.">
    参数 标题 <类型 = 文本型 注释 = "主标题文本" @默认值 = "主标题">
    {
        @ @<标题栏.主标题> (@<标题>);
    }

    方法 副标题 <公开 属性写 注释 = "设置图表的副标题内容.设置该项将自动显示标题栏">
    参数 标题 <类型 = 文本型 注释 = "副标题文本" @默认值 = "副标题">
    {
        @ @<标题栏.副标题> (@<标题>);
    }

    方法 准备就绪 <公开 定义事件 类型 = 整数 注释 = "  当页面文档及ECharts图表环境准备就绪时触发此事件.">
    参数 系列集对象 <类型 = 图表系列集类 注释 = "  系列集,(对应option.series配置项)此配置项实际是个数组,每个成员即一个系列,系列是指:一组数值以及他们映射成的图."
            注释 = "其不仅表示数据,也表示数据映射成为的图.所以一个系列包含的要素至少有:一组数值,图表类型,以及其他的关于这些数据如何映射成图的参数.">

    方法 图表项被单击 <公开 定义事件 类型 = 整数 注释 = "  当图表项被单击时触发此事件.">
    参数 图表项信息 <类型 = 文本型 注释 = "图表项信息JSON文本">

    # --
    # @begin
    # <> <include>
    # static void @an<_sOnBeforeAppInit> ()  {
    # #ifndef _VOL_ECHARTS_CTL_BASE_EDGE
