<火山程序 类型 = "通常" 版本 = 1 />

包 火山.ECharts <注释 = "火山MFC·Echarts图表控件.图表组件参数设置">

类 图表参数基础类 <注释 = "图表参数基类,用于存储图表配置参数." @视窗.外部头文件 = "include\\vol_echarts_ref_data.h">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (EChartsOptionData)

    方法 取参数 <公开 类型 = 文本型 注释 = "取当前图表组件或配置项的配置参数" @嵌入式方法 = "">
    参数 参数名 <类型 = 文本型 注释 = "提供本图表组件的配置参数名">
    {
        @ @sn<this>.GetData(@<参数名>)
    }

    方法 移除参数 <公开 类型 = 文本型 注释 = "移除当前图表组件或配置项的配置参数" @嵌入式方法 = "">
    参数 参数名 <类型 = 文本型 注释 = "提供本图表组件的配置参数名">
    {
        @ @sn<this>.EraseData(@<参数名>)
    }

    方法 置参数 <公开 注释 = "置当前图表组件或配置项的配置参数" @嵌入式方法 = "">
    参数 参数名 <类型 = 文本型 注释 = "欲置参数名">
    参数 参数值 <类型 = 文本型 注释 = "欲置参数值,注意JSON文本型值需要用引号包裹.">
    {
        @  @sn<this>.SetData(@<参数名>, @<参数值>)
    }

    方法 清空参数 <公开 注释 = "清空本图表组件中的参数设置" @嵌入式方法 = "">
    {
        @ @sn<this>.data().m_mapData.clear()
    }

    方法 是否显示 <公开 属性写 注释 = "是否显示当前图表组件">
    参数 是否显示本组件 <类型 = 逻辑型 注释 = "真为显示" @默认值 = 真>
    {
        @ SetData(_T("show"), (@<是否显示本组件> ? _T("true") : _T("false"))); 
    }

    # --
    # @begin
    # <> <include>
    # inline_ @sn<current_class>(std::map<CVolString, CVolString> mapData):@sn<current_class>(){ data().m_mapData = mapData;}
