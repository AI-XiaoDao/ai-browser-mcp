    # { 
    #     if (!value.IsEmpty())
    #         data().m_mapData[key]=_T("\"")+value+_T("\""); 
    # }
    # inline_ CVolString GetData (CVolString key ) 
    # {
    #     if (data().m_mapData.count(key) == 0)
    #         return  CVolString(_T(""));
    #     return  data().m_mapData[key];  
    # }
    # inline_ void EraseData (CVolString key ) {  data().m_mapData.erase( key); }
    #
    # CVolString getJSON()
    # {
    #     if (data().m_mapData.empty()) 
    #         return CVolString( _T(""));
    #     CVolString str(_T("{")) ;
    #     std::map<CVolString, CVolString>::iterator iter;
    #     for(iter = data().m_mapData.begin(); iter != data().m_mapData.end(); iter++)
    #     {
    #         str = (str==_T("{")) ? str + _T("\"") + iter->first + _T("\":") + iter->second : str + _T(",\"") + iter->first + _T("\":") + iter->second;
    #     }
    #     str += _T("}");
    #     return  str;
