    # 属性方法===

    方法 链接地址 <公开 属性写 注释 = "将当前网页主框架跳转载入到所指定的链接地址" @视窗.设置时机 = 组件创建后>
    参数 欲载入的链接地址 <类型 = 文本型 注释 = "欲载入的链接地址">
    {
        载入URL (欲载入的链接地址)
    }

    方法 链接地址 <公开 属性读 类型 = 文本型 注释 = "返回主框架所浏览页面的链接地址">
    {
        返回 (取Url ())
    }

    方法 背景颜色 <公开 属性写 注释 = "设置当前浏览器的背景颜色值." @视窗.设置时机 = 组件创建后 @值细节类型 = 颜色>
    参数 颜色值 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ wkeViewSettings vs;
        @ vs.size = sizeof(wkeViewSettings);
        @ vs.bgColor=@<颜色值>;
        @ wkeSetViewSettings(getWndPtr ()->m_webView, &vs);
    }

    方法 媒体音量 <公开 属性写 注释 = "设置浏览器的媒体音量">
    参数 音量 <类型 = 小数 注释 = "媒体音量值默认为1">
    {
        @ wkeSetMediaVolume(getWndPtr ()->m_webView,(float)@<音量>);
    }

    方法 媒体音量 <公开 属性读 类型 = 小数 注释 = "取浏览器的媒体音量" 返回值注释 = "媒体音量值" @嵌入式方法 = "">
    {
        @ wkeGetMediaVolume(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 启用Cookie <公开 属性写 注释 = "设置Cookie是否可用" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用" @默认值 = 真>
    {
        @ wkeSetCookieEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用Cookie <公开 属性读 类型 = 逻辑型 注释 = "判断是否启用Cookie" 返回值注释 = "真为启用" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsCookieEnabled(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 缩放级别 <公开 属性写 注释 = "浏览器的缩放系数" @视窗.设置时机 = 组件创建后>
    参数 缩放级别 <类型 = 小数 注释 = "缩放系数,正常为1.">
    {
        @ wkeSetZoomFactor(getWndPtr ()->m_webView ,  (float)@<缩放级别>);
    }

    方法 缩放级别 <公开 属性读 类型 = 小数 注释 = "浏览器缩放系数" 返回值注释 = "返回缩放系数" @嵌入式方法 = "">
    {
        @ wkeGetZoomFactor(@sn<this>.getWndPtr ()->m_webView )
    }

    方法 透明模式 <公开 属性读 类型 = 逻辑型 注释 = "判断窗口是否是透明模式" 返回值注释 = "返回真代表当前浏览器为透明模式" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsTransparent(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 透明模式 <公开 属性写 注释 = "设置是否开启透明模式" @视窗.设置时机 = 组件创建后>
    参数 是否透明 <类型 = 逻辑型 注释 = "真为开启透明模式" @默认值 = 真>
    {
        @ wkeSetTransparent(getWndPtr ()->m_webView,@<是否透明>);
    }

    方法 启用鼠标 <公开 属性写 注释 = "开启或关闭鼠标消息,可以在开启触屏后,关闭鼠标消息" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetMouseEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用触摸 <公开 属性写 注释 = "开启或关闭触屏" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetTouchEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用系统触摸 <公开 属性写 注释 = "开启或关闭系统触屏" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetSystemTouchEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用拖入文件 <公开 属性写 注释 = "可启用或关闭拖拽文件加载网页" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetDragEnable(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用拖拽元素 <公开 属性写 注释 = "可启用或关闭元素拖拽或拖拽到其他进程" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 假>
    {
        @ wkeSetDragDropEnable(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用内存缓存 <公开 属性写 注释 = "可启用或关闭内存缓存" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetMemoryCacheEnable(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 保存内存缓存 <公开 注释 = "保存当前浏览器内存缓存" @嵌入式方法 = "">
    {
        @ wkeSaveMemoryCache(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 启用Npapi插件 <公开 属性写 注释 = "可启用或关闭Npapi插件" @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetNpapiPluginsEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用无头模式 <公开 属性写 注释 = "开启或关闭无头模式,开启后页面不会被渲染上屏,直接内存运行,大幅提升性能." @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetHeadlessEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用默认菜单 <公开 属性写 注释 = "设置是否允许右键弹出MB浏览器默认菜单,默认状态下为开启." @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为开启" @默认值 = 真>
    {
        @ wkeSetContextMenuEnabled(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 置默认菜单项显示 <公开 注释 = "设置MB浏览器某菜单项是否显示">
    参数 菜单项 <类型 = MB默认菜单项 注释 = "MB默认菜单项常量">
    参数 是否显示 <类型 = 逻辑型 注释 = "真为显示,假为隐藏">
    {
        @ wkeSetContextMenuItemShow(getWndPtr ()->m_webView,(wkeMenuItemId)@<菜单项>,@<是否显示>);
    }

    方法 启用导航到新窗口 <公开 属性写 注释 = "当有新页面需要打开时,是否在新窗口打开,默认是当前窗口,如开启,则会触发\"即将创建新窗口\"事件." @视窗.设置时机 = 组件创建后>
    参数 是否启用 <类型 = 逻辑型 注释 = "真为启用,假为关闭." @默认值 = 真>
    {
        @ wkeSetNavigationToNewWindowEnable(getWndPtr ()->m_webView,@<是否启用>);
    }

    方法 启用跨域检查 <公开 属性写 注释 = "设置是否开启csp跨域检查,默认状态下为开启,如需进行跨域操作,如跨域ajax,跨域设置iframe等,则需要先关闭此开关." @视窗.设置时机 = 组件创建后>
    参数 是否检查 <类型 = 逻辑型 注释 = "真为开启跨域检查" @默认值 = 真>
    {
        @ wkeSetCspCheckEnable(getWndPtr ()->m_webView,@<是否检查>);
    }

    方法 事件注册 <公开 属性写 注释 = "浏览器组件创建后是否自动注册事件" @视窗.设置时机 = 组件创建后>
    参数 是否注册 <类型 = 逻辑型 注释 = "是否自动注册事件" @默认值 = 真>
    {
        @ if(@<是否注册> && wkeGetUserKeyValue(getWndPtr ()->m_webView,"pThis")!=this)
        @ {
        @ wkeOnTitleChanged(getWndPtr ()->m_webView, handleTitleChanged, this);
        @ wkeOnDocumentReady(getWndPtr ()->m_webView,handleDocumentReady, this);
        @ wkeOnDocumentReady2(getWndPtr ()->m_webView, handleDocumentReady2, this);
        @ wkeOnLoadUrlBegin(getWndPtr ()->m_webView, handleLoadUrlBegin, this);
        @ wkeOnLoadUrlEnd(getWndPtr ()->m_webView,  handleLoadUrlEnd, this);
        @ wkeOnURLChanged(getWndPtr ()->m_webView,  handleURLChanged, this);
        @ wkeOnURLChanged2(getWndPtr ()->m_webView,  handleURLChanged2, this);
        @ wkeOnLoadingFinish(getWndPtr ()->m_webView,  handleLoadingFinish, this);
        @ wkeOnAlertBox(getWndPtr ()->m_webView, handleAlertBoxCallback, this);
        @ wkeOnConfirmBox(getWndPtr ()->m_webView, handleConfirmBoxCallback, this);
        @ wkeOnPromptBox(getWndPtr ()->m_webView, handlePromptBoxCallback, this);
        @ wkeOnNavigation(getWndPtr ()->m_webView, handleNavigationCallback, this);
        @ wkeOnConsole(getWndPtr ()->m_webView, handleConsoleCallback, this);
        @ wkeOnDidCreateScriptContext(getWndPtr ()->m_webView,  handleDidCreateScriptContextCallback, this);
        @ wkeOnWillReleaseScriptContext(getWndPtr ()->m_webView,  handleWillReleaseScriptContextCallback, this);
        @ wkeNetOnResponse(getWndPtr ()->m_webView,  handleNetResponseCallback, this);
        @ wkeOnMouseOverUrlChanged(getWndPtr ()->m_webView,  handleMouseOverUrlChangedCallback, this);
        @ wkeOnWillMediaLoad(getWndPtr ()->m_webView,  handleWillMediaLoadCallback, this);
        @ wkeOnCreateView(getWndPtr ()->m_webView, handleCreateViewCallback, this);
        @ wkeSetUserKeyValue(getWndPtr ()->m_webView,"pThis", this);
        @ } 
    }

    # 方法===

    方法 取浏览器句柄 <公开 类型 = 变整数 注释 = "取当前控件MB浏览器句柄" 返回值注释 = "返回MB浏览器句柄" @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.getWndPtr ()->m_webView
    }

    方法 置浏览器句柄 <公开 注释 = "设置本类对象的MB浏览器句柄用于操作不同的浏览器" "">
    参数 浏览器句柄 <类型 = 变整数 注释 = "提供一个浏览器句柄(WebView),并确保此句柄的有效性." "">
    {
        @ if (getWndPtr ()->m_webView == NULL) getWndPtr ()->m_webView = (wkeWebView)@<浏览器句柄>;
    }

    方法 置绘制位置偏移 <公开 注释 = "设置浏览器的绘制位置,在某些情况下绘制的地方不在真窗口坐标的(0，0)处就需要调用此接口." @嵌入式方法 = "">
    参数 横坐标 <类型 = 整数 注释 = "横坐标,相对窗口组件的左上角起始的横向位置.">
    参数 纵坐标 <类型 = 整数 注释 = "纵坐标,相对窗口组件的左上角起始的纵向位置.">
    {
        @ wkeSetHandleOffset(@sn<this>.getWndPtr ()->m_webView , @<横坐标>, @<纵坐标>)
    }

    方法 载入URL <公开 注释 = "使浏览器载入一个URL地址" @嵌入式方法 = "">
    参数 URL <类型 = 文本型 注释 = "提供URL网址">
    {
        @ wkeLoadURLW(@sn<this>.getWndPtr ()->m_webView,@<URL>)
    }

    方法 载入HTML <公开 注释 = "使浏览器载入一段HTML文档" @嵌入式方法 = "">
    参数 html文本 <类型 = 文本型 注释 = "HTML文档">
    {
        @ wkeLoadHTMLW(@sn<this>.getWndPtr ()->m_webView,@<html文本>)
    }

    方法 载入HTML_UTF8 <公开 注释 = "使浏览器载入一段HTML文件" @嵌入式方法 = "">
    参数 html文本 <类型 = 字节集类 注释 = "提供为utf8编码格式的HTML文本字节集">
    {
        @ wkeLoadHTML(@sn<this>.getWndPtr ()->m_webView, (const utf8*)@<html文本>.GetPtr())
    }

    方法 载入HTML基于URL <公开 注释 = "使浏览器载基于一个URL地址载入一段HTML" @嵌入式方法 = "">
    参数 html文本 <类型 = 文本型 注释 = "HTML文本">
    参数 基于url <类型 = 文本型 注释 = "所基于URL地址">
    {
        @ wkeLoadHtmlWithBaseUrl(@sn<this>.getWndPtr ()->m_webView,CU8String (@<html文本>).GetText (), CU8String (@<基于url>).GetText ())
    }

    方法 载入文件 <公开 注释 = "使浏览器载入一个文件" @嵌入式方法 = "">
    参数 文件名 <类型 = 文本型 注释 = "提供一个文件名">
    {
        @ wkeLoadFileW(@sn<this>.getWndPtr ()->m_webView,@<文件名>)
    }

    方法 Post访问 <公开 注释 = "以Post方式访问所指定的URL">
    参数 链接地址 <类型 = 文本型 注释 = "提供所欲访问的链接地址">
    参数 所欲传递数据 <类型 = 字节集类 注释 = "提供所有欲传递过去的数据">
    {
        @ wkePostURLW(getWndPtr ()->m_webView, @<链接地址>.GetText(), (const char *)@<所欲传递数据>.GetPtr(), (int)@<所欲传递数据>.GetSize ());
    }

    方法 取Url <公开 类型 = 文本型 注释 = "取浏览器当前载入的url地址" 返回值注释 = "url地址" @嵌入式方法 = "">
    {
        @ CVolString( wkeGetURL(@sn<this>.getWndPtr ()->m_webView))
    }

    方法 取框架Url <公开 类型 = 文本型 注释 = "取浏览器页面某框架载入的url地址" 返回值注释 = "对应框架url地址" @嵌入式方法 = "">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    {
        @ CVolString(wkeGetFrameUrl(@sn<this>.getWndPtr ()->m_webView,(wkeWebFrameHandle)@<框架ID>))
    }

    方法 是否载入中 <公开 属性读 类型 = 逻辑型 注释 = "判断浏览器当前是否正在载入中" 返回值注释 = "浏览器载入状态" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsLoading(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 是否载入成功 <公开 属性读 类型 = 逻辑型 注释 = "判断浏览器当前是否已经载入成功" 返回值注释 = "是否载入成功" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsLoadingSucceeded(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 是否载入失败 <公开 属性读 类型 = 逻辑型 注释 = "判断浏览器当前是否已经载入失败" 返回值注释 = "是否载入失败" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsLoadingFailed(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 是否载入完成 <公开 属性读 类型 = 逻辑型 注释 = "  判断浏览器页面当前是否已经载入完成,由于现代网页大多采用动态加载 多框架等原因,"
            注释 = "本接口返回的加载完成并不等于\"网页已全部加载完成\",只表示MB已接收了服务器本次传回的全部数据." 返回值注释 = "是否载入完成" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsLoadingCompleted(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 是否文档已就绪 <公开 属性读 类型 = 逻辑型 注释 = "  判断浏览器页面当前文档是否已就绪,由于现代网页大多采用动态加载,多框架等原因,"
            注释 = "本接口返回的加载完成并不等于\"网页已全部已就绪\",只表示MB已接收了服务器本次传回的全部数据." 返回值注释 = "文档是否已就绪" @嵌入式方法 = "">
    {
        @ (BOOL)wkeIsDocumentReady(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 停止载入 <公开 注释 = "强制停止加载当前页面" @嵌入式方法 = "">
    {
        @ wkeStopLoading(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 重新载入 <公开 注释 = "刷新页面,重新加载当前页面,从服务器重新拉取内容而不仅仅是重新渲染,相当于按ctrl+F5强刷." @嵌入式方法 = "">
    {
        @ wkeReload(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 取标题 <公开 类型 = 文本型 注释 = "取浏览器当前页面标题宽字符版" 返回值注释 = "页面标题" @嵌入式方法 = "">
    {
        @ CVolString(wkeGetTitleW(@sn<this>.getWndPtr ()->m_webView))
    }

    方法 取源码 <公开 类型 = 文本型 注释 = "取浏览器当前页面源码" 返回值注释 = "页面源码" @嵌入式方法 = "">
    {
        @ CVolString(wkeGetSource(@sn<this>.getWndPtr ()->m_webView))
    }

    方法 置UserAgent <公开 注释 = "设置浏览器UserAgent" @嵌入式方法 = "req_str_param_text_pointer=true">
    参数 UA文本 <类型 = 文本型
            注释 = "提供一个UserAgent文本,如:\"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/89.0.4389.90 Safari/537.36 Edg/89.0.774.57\".">
    {
        @ wkeSetUserAgentW(@sn<this>.getWndPtr ()->m_webView,@<UA文本>)
    }

    方法 取UserAgent <公开 类型 = 文本型 注释 = "取浏览器UserAgent" 返回值注释 = "返回浏览器UserAgent" @嵌入式方法 = "">
    {
        @ CVolString(wkeGetUserAgent(@sn<this>.getWndPtr ()->m_webView))
    }

    方法 置语言 <公开 注释 = "设置其他语言,默认跟随系统设定." @嵌入式方法 = "">
    参数 语言类型 <类型 = 文本型 注释 = "语言类型">
    {
        @ wkeSetLanguage(@sn<this>.getWndPtr ()->m_webView, CU8String (@<语言类型>).GetText ())
    }

    方法 置设备参数 <公开 注释 = "设置webView模拟硬件设备环境" @嵌入式方法 = "">
    参数 设备参数名 <类型 = 文本型 注释 = "为\"navigator.maxTouchPoints\"时，需设置\"整数参数\"，表示touch的点数。"
            注释 = "为\"navigator.platform\"时，需设置\"文本参数\"，表示js里获取的navigator.platform字符串。"
            注释 = "为\"navigator.hardwareConcurrency\"时，需设置\"整数参数\"，表示js里获取的navigator.hardwareConcurrency整数值。"
            注释 = "为\"screen.width\"时，需设置\"整数参数\"，表示js里获取的screen.width整数值。"
            注释 = "为\"screen.height\"时，需设置\"整数参数\"，表示js里获取的screen.height整数值。"
            注释 = "为\"screen.availWidth\"时，需设置\"整数参数\"，表示js里获取的screen.availWidth整数值。"
            注释 = "为\"screen.availHeight\"时，需设置\"整数参数\"，表示js里获取的screen.availHeight整数值。"
            注释 = "为\"screen.pixelDepth\"时，需设置\"整数参数\"，表示js里获取的screen.pixelDepth整数值。">
    参数 文本参数 <类型 = 文本型 @默认值 = "">
    参数 整数参数 <类型 = 整数 @默认值 = 0>
    参数 浮点参数 <类型 = 小数 @默认值 = 0>
    {
        @ wkeSetDeviceParameter (@sn<this>.getWndPtr ()->m_webView, CU8String  (@<设备参数名>).GetText (), CU8String (@<文本参数>).GetText (), @<整数参数>, (float)@<浮点参数>)
    }

    方法 置代理 <公开 注释 = "置当前浏览器代理设置">
    参数 代理类型 <类型 = MB代理类型 注释 = "提供MB代理类型" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = MB代理类型.HTTP>
    参数 服务器 <类型 = 文本型 注释 = "代理服务器地址" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 端口 <类型 = 短整数 注释 = "代理服务器端口" 编辑时信息 = "7AAA3, 0, 0, 0">
    参数 用户名 <类型 = 文本型 注释 = "代理服务器用户" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "代理服务器密码" 编辑时信息 = "7AAA3, 0, 0, 0" @默认值 = "">
    {
        @ wkeProxy  Proxy;
        @ Proxy.type=(wkeProxyType)@<代理类型>;
        @ strncpy_z(Proxy.hostname, CU8String (@<服务器>).GetText(), NUM_ELEMENTS_OF (Proxy.hostname) - 1);
        @ strncpy_z(Proxy.username, CU8String (@<用户名>).GetText(), NUM_ELEMENTS_OF (Proxy.username) - 1);
        @ strncpy_z(Proxy.password, CU8String (@<密码>).GetText(), NUM_ELEMENTS_OF (Proxy.password) - 1);
        @ Proxy.port=@<端口>;
        @ wkeSetViewProxy (getWndPtr ()->m_webView, &Proxy);
    }

    方法 置调试配置 <公开 注释 = "设置一些实验性选项,配置项目前支持:"
            注释 = "\"showDevTools\":开启开发者工具,此时参数值要填写开发者工具的资源路径,如file:///c:/miniblink-release/front_end/inspector.html 必须是全路径,并且不能有中文."
            注释 = "\"wakeMinInterval\":设置帧率,默认值是10值越大帧率越低;" 注释 = "\"drawMinInterval\":设置帧率,默认值是3,值越大帧率越低;"
            注释 = "\"antiAlias\":设置抗锯齿渲染,参数值必须设置为\"1\";" 注释 = "\"minimumFontSize\":最小字体;" 注释 = "\"minimumLogicalFontSize\":最小逻辑字体;"
            注释 = "\"defaultFontSize\":默认字号;" 注释 = "\"defaultFixedFontSize\":默认Fixed字号;"
            注释 = "\"imageEnable\":是否打开无图模式,参数值为\"0\"表示开启无图模式;" 注释 = "\"jsEnable\":是否禁用js,参数值为\"0\"表示禁用;"
            注释 = "enableNodejs:是否开启nodejs 支持,参数值为\"1\"表示开启.(目前仅支持32位)" @嵌入式方法 = "">
    参数 配置项 <类型 = 文本型 注释 = "配置项名">
    参数 参数值 <类型 = 文本型 注释 = "配置项参数值">
    {
        @ wkeSetDebugConfig(@sn<this>.getWndPtr ()->m_webView,CU8String (@<配置项>).GetText(),CU8String (@<参数值>).GetText())
    }

    方法 可否后退 <公开 属性读 类型 = 逻辑型 注释 = "判断浏览器当前页面加载状态是否可以后退" 返回值注释 = "返回真代表当前页面可以后退" @嵌入式方法 = "">
    {
        @ (BOOL)wkeCanGoBack(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 后退 <公开 类型 = 逻辑型 注释 = "后退到前一页" @嵌入式方法 = "">
    {
        @ wkeGoBack(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 可否前进 <公开 属性读 类型 = 逻辑型 注释 = "判断浏览器当前页面加载状态是否可以前进" 返回值注释 = "返回真代表当前页面可以前进" @嵌入式方法 = "">
    {
        @  (BOOL)wkeCanGoForward(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 前进 <公开 类型 = 逻辑型 注释 = "前进一页" @嵌入式方法 = "">
    {
        @ wkeGoForward(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_全选 <公开 注释 = "页面编辑内容全选" @嵌入式方法 = "">
    {
        @ wkeEditorSelectAll(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_取消选择 <公开 注释 = "页面编辑内容全选取消" @嵌入式方法 = "">
    {
        @ wkeEditorUnSelect(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_复制 <公开 注释 = "页面编辑内容复制" @嵌入式方法 = "">
