    参数 网络工作指针 <类型 = 变整数 注释 = "网络工作指针">
    参数 网络工作 <类型 = MB网络工作 注释 = "MB浏览器网络相关操作">

    方法 结束加载Url <公开 定义事件 类型 = 整数 注释 = "在 \"开始加载Url\" 事件中调用 \"网络工作.Hook请求()\"方法 在本事件中触发 并获得此次请求响应的数据">
    参数 链接地址 <类型 = 文本型 注释 = "请求的url地址">
    参数 网络工作指针 <类型 = 变整数 注释 = "MB网络工作指针">
    参数 网络工作 <类型 = MB网络工作 注释 = "MB浏览器网络相关操作">
    参数 响应数据 <类型 = 字节集类 注释 = "拦截到的响应数据">
    参数 数据长度 <类型 = 整数 注释 = "数据长度">

    方法 Url被改变 <公开 定义事件 类型 = 整数 注释 = "当浏览器Url被改变时触发此事件" 折叠>
    参数 链接地址 <类型 = 文本型 注释 = "当前浏览器的url地址">

