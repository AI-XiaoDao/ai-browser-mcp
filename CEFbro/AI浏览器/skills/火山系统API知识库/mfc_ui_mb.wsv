    方法 发送鼠标事件 <公开 注释 = "发送所指定的鼠标事件到浏览器" @嵌入式方法 = "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"MB鼠标键类型\"类中各常量值." "">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    {
        @ wkeFireMouseEvent(@sn<this>.getWndPtr ()->m_webView, @<鼠标键状态>, @<横向位置>, @<纵向位置>, @<辅助键状态>);
    }

    方法 发送鼠标单击事件 <公开 注释 = "发送一个鼠标点击事件到浏览器">
    参数 横坐标 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵坐标 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    {
        @ wkeFireMouseEvent(getWndPtr ()->m_webView,WKE_MSG_LBUTTONDOWN,@<横坐标>, @<纵坐标>,WKE_LBUTTON);
        @ wkeFireMouseEvent(getWndPtr ()->m_webView,WKE_MSG_LBUTTONUP,@<横坐标>, @<纵坐标>,WKE_LBUTTON);
    }

    方法 发送鼠标移动事件 <公开 注释 = "发送所指定的鼠标移动事件到浏览器" "">
    参数 横向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的横向坐标">
    参数 纵向位置 <类型 = 整数 注释 = "提供当前鼠标位置在浏览器窗口中的纵向坐标">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 鼠标键状态 <类型 = 整数 注释 = "提供鼠标按键的按下状态,为\"MB鼠标键类型\"类中各常量值." @默认值 = 0>
    {
        @ wkeFireMouseEvent(getWndPtr ()->m_webView, WKE_MSG_MOUSEMOVE, @<横向位置>, @<纵向位置>, @<辅助键状态>);
        如果 (鼠标键状态 != 0)
        {
            @ wkeFireMouseEvent(getWndPtr ()->m_webView, @<鼠标键状态>, @<横向位置>, @<纵向位置>, @<辅助键状态>);
        }
    }

    方法 发送按键事件 <公开 注释 = "发送所指定的按键事件到MB浏览器">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "提供辅助键组合状态,为\"辅助键状态\"类中各常量值的组合." @默认值 = 0>
    参数 为按键放开事件 <类型 = 逻辑型 注释 = "  为真表示发送按键放开事件(WM_SYSKEYUP/WM_KEYUP),否则将发送" 注释 = "按键按下事件(WM_SYSKEYDOWN/WM_KEYDOWN)." @默认值 = 假>
    参数 为系统按键事件 <类型 = 逻辑型 注释 = "  为真表示发送系统按键事件(WM_SYSKEYDOWN/WM_SYSKEYUP),否则将" 注释 = "发送非系统按键事件(WM_KEYDOWN/WM_KEYUP)" @默认值 = 假>
    {
        如果 (为按键放开事件)
        {
            @ wkeFireKeyUpEvent( getWndPtr ()->m_webView, @<键代码>,@<辅助键状态>,@<为系统按键事件>);
        }
        否则
        {
            @ wkeFireKeyDownEvent( getWndPtr ()->m_webView,@<键代码>, @<辅助键状态>,@<为系统按键事件>);
        }
    }

    方法 发送字符事件 <公开 注释 = "向MB浏览器发送一个字符消息">
    参数 字符编码 <类型 = 字符 注释 = "提供所欲发送的字符">
    {
        变量 窗口句柄 <类型 = 变整数>
        窗口句柄 = 取窗口句柄 ()
        @ SendMessageW((HWND)@<窗口句柄>,WM_IME_CHAR,(WPARAM)(@<字符编码>),0); 
    }

    方法 发送字符串事件 <公开 注释 = "向MB浏览器发送一个字符串消息">
    参数 字符串文本 <类型 = 文本型 注释 = "提供所欲发送的字符串文本">
    {
        计次循环 (取文本长度 (字符串文本))
        {
            发送字符事件 (取字符 (字符串文本, 取循环索引 ()))
        }
    }

    方法 发送窗口移动事件 <公开 注释 = "鼠标捕获移动MB窗口,一般用于通过js控制窗口移动." 折叠>
    {
        变量 窗口句柄 <类型 = 变整数>
        窗口句柄 = 取窗口句柄 ()
        @ ReleaseCapture ();//鼠标释放
        @ SendMessage ((HWND)@<窗口句柄>, 161, 2, 0);
    }

    方法 发送消息 <公开 类型 = 长整数 注释 = "向浏览器窗口发送一个window消息" 折叠 @禁止流程检查 = 真>
    参数 message <类型 = 整数 注释 = "消息值" "">
    参数 wParam <类型 = 整数 注释 = "消息附加参数wParam">
    参数 IParam <类型 = 整数 注释 = "消息附加参数IParam">
    {
        变量 窗口句柄 <类型 = 变整数>
        窗口句柄 = 取窗口句柄 ()
        @ LRESULT result;
        @ wkeFireWindowsMessage(getWndPtr ()->m_webView,(HWND)@<窗口句柄>,@<message>,@<wParam>,@<IParam>,&result); 
        @ return result;
    }

    方法 网页_点击 <公开 注释 = "执行JS查找并执行元素点击事件">
