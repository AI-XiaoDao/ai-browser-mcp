    {
        如果 (框架ID == 0)
        {
            框架ID = 取主框架 ()
        }
        返回 (执行JS脚本自框架 (框架ID, "return document.querySelectorAll('" + css选择器 + "')[" + 到文本 (元素索引) + "].innerText", 真).取文本值 ())
    }

