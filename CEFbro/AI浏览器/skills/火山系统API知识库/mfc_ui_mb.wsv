<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MiniBlink浏览器组件 <注释 = "火山MFC组件MiniBlink浏览器">

类 MB浏览器组件 <公开 基础类 = 窗口组件 注释 = "" 注释 = "火山MFC组件MiniBlink浏览器" @视窗.后缀文本 = "public IBaseEventListener"
        @视窗.窗口组件 = "icon=\"@64\"\r\ndefault_size = \"120, 100\"\r\npreview_unsupported" @视窗.外部头文件 = "lib\\mfc_ui_mb_wnd.h"
        @视窗.外部源文件 = "lib\\mfc_ui_mb_wnd.cpp">
{

