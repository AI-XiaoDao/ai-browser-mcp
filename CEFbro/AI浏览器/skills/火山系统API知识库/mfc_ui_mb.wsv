        @ wkeEditorCopy(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_剪切 <公开 注释 = "页面编辑内容剪切" @嵌入式方法 = "">
    {
        @ wkeEditorCut(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_粘贴 <公开 注释 = "页面编辑内容粘贴" @嵌入式方法 = "">
    {
        @ wkeEditorPaste(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_删除 <公开 注释 = "页面编辑内容删除" @嵌入式方法 = "">
    {
        @ wkeEditorDelete(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_撤销 <公开 注释 = "页面编辑内容撤销" @嵌入式方法 = "">
    {
        @ wkeEditorUndo(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 编辑_重做 <公开 注释 = "页面编辑内容重做" @嵌入式方法 = "">
    {
        @ wkeEditorRedo(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 取Cookie <公开 类型 = 文本型 注释 = "取浏览器Cookie" 返回值注释 = "成功返回Cookie文本" @嵌入式方法 = "">
    {
        @ CVolString(wkeGetCookieW(@sn<this>.getWndPtr ()->m_webView))
    }

    方法 枚举Cookie <公开 注释 = "枚举所有现有Cookie,调用此方法触发\"获得Cookie\"事件中获得所有Cookie.">
    {
        @ wkeVisitAllCookie(getWndPtr ()->m_webView, this, (wkeCookieVisitor)onCookieVisitor);
    }

    方法 取Cookie_UTF8 <公开 类型 = 字节集类 注释 = "取浏览器Cookie" 返回值注释 = "成功返回Cookie UTF8类型" @禁止流程检查 = 真>
    {
        @ return wkeGetCookie(getWndPtr ()->m_webView);
    }

    方法 置Cookie <公开 注释 = "向浏览器写入一段Cookie" @嵌入式方法 = "">
    参数 链接地址 <类型 = 文本型 注释 = "写入Cookie对应的url">
    参数 cookie文本 <类型 = 文本型 注释 = "  cookie格式必须是类似:"
            注释 = "cna=4UvTFE12fEECAXFKf4SFW5eo; expires=Tue, 23-Jan-2029 13:17:21 GMT; path=/; domain=.youku.com">
    {
        @ wkeSetCookie(@sn<this>.getWndPtr ()->m_webView,CU8String (@<链接地址>).GetText (),CU8String (@<cookie文本>).GetText ())
    }

    方法 清除Cookie <公开 注释 = "清除Cookie,由于缓存等因素,直接删cookie.dat可能更有效.另外有的网站可能有服务端缓存,所以会存在清理无效的情况." @嵌入式方法 = "">
    {
        @ wkeClearCookie(@sn<this>.getWndPtr ()->m_webView)
    }

    方法 执行Cookie命令 <公开 注释 = "执行一个COOKIE操作命令" @嵌入式方法 = "">
    参数 COOKIE命令 <类型 = MBCookie命令 注释 = "提供MBCookie命令类型" @默认值 = MBCookie命令.全部清除>
    {
        @ wkePerformCookieCommand(@sn<this>.getWndPtr ()->m_webView,(wkeCookieCommand)@<COOKIE命令>)
    }

    方法 置Cookie文件路径 <公开 注释 = "设置Cookie文件的目录,默认情况下文件名是 cookies.dat" @嵌入式方法 = "req_str_param_text_pointer=true">
    参数 文件目录 <类型 = 文本型 注释 = "文件目录路径,不包括文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarPath(@sn<this>.getWndPtr ()->m_webView,@<文件目录>)
    }

    方法 置Cookie文件全路径 <公开 注释 = "设置Cookie文件的全路径包括文件名,默认是程序运行的当前目录,默认文件名为cookie.dat。" @嵌入式方法 = "req_str_param_text_pointer=true">
    参数 文件目录 <类型 = 文本型 注释 = "全路径,包括cookie文件名,不能自动新建不存在的目录.">
    {
        @ wkeSetCookieJarFullPath(@sn<this>.getWndPtr ()->m_webView,@<文件目录>)
    }

    方法 置LocalStorage路径 <公开 注释 = "设置LocalStorage本地存储文件的路径" @嵌入式方法 = "req_str_param_text_pointer=true">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\LocalStorage,必须且只能是目录,默认是当前目录.">
    {
        @ wkeSetLocalStorageFullPath(@sn<this>.getWndPtr ()->m_webView,@<文件目录>)
    }

    方法 添加插件目录 <公开 注释 = "设置插件目录,默认情况下为plugins目录" @嵌入式方法 = "req_str_param_text_pointer=true">
    参数 文件目录 <类型 = 文本型 注释 = "如c:\\mb\\plugins,必须且只能是目录,默认是当前目录">
    {
        @ wkeAddPluginDirectory(@sn<this>.getWndPtr ()->m_webView, @<文件目录>)
    }

    方法 执行JS脚本 <公开 类型 = js值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()" "" = 真>
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJSW(getWndPtr ()->m_webView, @<JS文本>);
        @ @<es>=(INT_P)wkeGlobalExec(getWndPtr ()->m_webView);
        返回 (js.绑定 (es, jv))
    }

    方法 执行JS脚本UTF8 <公开 类型 = js值
            注释 = "执行一段js代码，由于js是弱类型语言 返回值 jsValue其实是一个指向封装了v8内部各种类型的类指针,这里封装成了一个基于\"jsValue类\"的\"js值\"对象,方便获得返回值."
            返回值注释 = "返回js值对象,使用方法 如: js值对象.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()">
    参数 JS文本UTF8 <类型 = 字节集类 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 jsValue <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJS(getWndPtr ()->m_webView, (const utf8*)@<JS文本UTF8>.GetPtr());
        @ @<es>=(INT_P)wkeGlobalExec(getWndPtr ()->m_webView);
        返回 (jsValue.绑定 (es, jv))
    }

    方法 执行JS脚本自框架 <公开 类型 = js值
            注释 = "在指定框架中执行一段js代码,返回js执行返回值类实例 使用方法 如: 变量.取文本值() 或 mb实例.执行JS脚本(\"return document.title\").取文本值()"
            返回值注释 = "返回js值对象,用于js执行结果取值操作.">
    参数 框架ID <类型 = 变整数 注释 = "提供一个框架ID">
    参数 JS文本 <类型 = 文本型 注释 = "若要获得js运行结果返回值 脚本中加\"return\"关键字 如: \"return document.title\"">
    参数 是否闭包 <类型 = 逻辑型 注释 = "如为真,则MB会将这段js代码放到一个function(){ script }中执行,以避免变量名和页面中的js变量重名导致的错误.">
    {
        变量 jv <类型 = 变整数>
        变量 es <类型 = 变整数>
        变量 js <类型 = js值>
        @ @<jv>=(INT_P)wkeRunJsByFrame(getWndPtr ()->m_webView,(wkeWebFrameHandle)@<框架ID>,CU8String (@<JS文本>).GetText(),@<是否闭包>);
        @ @<es>=(INT_P)wkeGetGlobalExecByFrame(getWndPtr ()->m_webView,(wkeWebFrameHandle)@<框架ID>);
        返回 (js.绑定 (es, jv))
    }

    方法 取主框架 <公开 类型 = 变整数 注释 = "取页面主框架ID" 返回值注释 = "返回页面主框架ID" @嵌入式方法 = "">
