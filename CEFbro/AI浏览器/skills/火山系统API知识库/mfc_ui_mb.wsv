    方法 JS绑定函数 <公开 静态 注释 = "绑定全局JS函数,须在浏览器组件创建前调用." "">
    参数 函数名称 <类型 = 文本型 注释 = "提供该js方法的函数名称,全局生效,请注意方法名的唯一性.">
    参数 参数个数 <类型 = 整数 注释 = "提供该js方法的参数个数">
    参数 回调方法指针 <类型 = 变整数 注释 = "指定一个静态方法指针值" 注释 = "属性:@视窗.前缀文本 值为:@CDECL;" 注释 = "返回值类型:变整数;" 注释 = "参数1 类型:js执行状态;"
            注释 = "如不指定此方法默认会在本组件各实例对象的\"JS绑定方法被执行\"事件中触发" @默认值 = 0>
    {
        如果 (回调方法指针 == 0)
        {
            @ wkeJsBindFunction(CU8String (@<函数名称>).GetText (),(wkeJsNativeFunction)handlewkeJsNativeFunction,(void *)@<函数名称>.GetText (),(unsigned int)@<参数个数>);
        }
        否则
        {
            @ wkeJsBindFunction(CU8String (@<函数名称>).GetText (),(wkeJsNativeFunction)@<回调方法指针>,(void *)@<函数名称>.GetText (),(unsigned int)@<参数个数>);
        }
    }

    # 事件---

    方法 文档就绪 <公开 定义事件 类型 = 整数 注释 = "当前页面文档就绪时触发此事件" "">

    方法 文档就绪2 <公开 定义事件 类型 = 整数 注释 = "当前页面文档就绪时触发此事件" 折叠 "">
