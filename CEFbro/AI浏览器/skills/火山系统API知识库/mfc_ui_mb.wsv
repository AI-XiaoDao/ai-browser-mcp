    参数 路径 <类型 = 文本型 注释 = "如非空,只有路径上或路径下的URL才会获取cookie值.">
    参数 是否安全保护 <类型 = 逻辑型 注释 = "是否使用HTTPS安全协议发送Cookie">
    参数 限HTTP <类型 = 逻辑型 注释 = "如为真则仅为HTTP请求发送cookie,防止客户端脚本通过document.cookie属性访问Cookie.">
    参数 是否设置生存期 <类型 = 逻辑型 注释 = "cookie过期日期仅在为真时有效">

    方法 即将开始下载 <公开 定义事件 类型 = 整数 注释 = "  需要调用\"启用下载事件\",浏览器在下载浏览器有下载文件时触发此事件,此接口尚未完善,"
            注释 = "回调中暂时只返回了下载UR,未带有身份认证信息,所以只适用于不需要身份认证的下载请求." 折叠>
    参数 链接地址 <类型 = 文本型 注释 = "目标url">

    方法 即将开始下载2 <公开 定义事件 类型 = 整数 注释 = "需要调用\"启用下载事件2\",浏览器有下载文件时触发此事件,此接口尚未完善,回调中暂时"
            注释 = "只返回了下载UR,未带有身份认证信息,所以只适用于不需要身份认证的下载请求." 返回值注释 = "返回0取消 返回1缓存数据" 折叠>
    参数 预计长度 <类型 = 变整数 注释 = "目标预计长度">
    参数 链接地址 <类型 = 文本型 注释 = "目标url">
    参数 MIME类型 <类型 = 文本型 注释 = "目标MIME类型">
    参数 disposition <类型 = 文本型>
    参数 网络工作 <类型 = MB网络工作 注释 = "MB网络工作">

    方法 获得网站图标 <公开 定义事件 类型 = 整数 注释 = "需在\"载入完成\"事件里调用 \"取网站图标\"方法触发此事件.">
    参数 链接地址 <类型 = 文本型 注释 = "网站图标文件的url地址">
    参数 图标文件 <类型 = 字节集类 注释 = "网站图标文件">

    方法 JS绑定方法被执行 <公开 定义事件 类型 = 整数 注释 = "通过\"JS绑定函数\"绑定的js方法被执行时会触发此事件" 返回值注释 = "如要向js返回一个值,调用 jsValue类相关方法生成js值返回.">
    参数 js执行状态 <类型 = 变整数 注释 = "js执行状态句柄,用于js值的操作">
    参数 方法名称 <类型 = 文本型 注释 = "js函数名称">
    参数 js参数对象 <类型 = js参数 注释 = "js参数对象用于获得js参数值">
    参数 参数个数 <类型 = 整数 注释 = "参数个数">

    # ==
