类 进程通讯_单向广播_接收器 <公开 基础类 = ______进程通讯_模板类 注释 = "可以有多个接收器" 注释 = "例子 https://nanomsg.org/gettingstarted/pubsub.html" 折叠
        @模板实现类 = "">
{

    #

    方法 开始 <公开 类型 = 逻辑型 注释 = "   NN_PULL  81">
    参数 url <类型 = 文本型>
    参数 过滤器 <类型 = 文本型 注释 = "默认为空，表示接收所有的消息，否则只接收特定的消息" @默认值 = "">
    参数 协议类型 <类型 = 整数 注释 = "可选值" 注释 = "1 表示自带协议" 注释 = "2 表示原始协议" @默认值 = 1>
    {
        变量 szurl <类型 = 字节集类>
        szurl = 文本到UTF8 (url)
        如果 (Nanomsg_Socket (_取句柄 (), 协议类型, 进程通讯模型常量.NN_SUB) == 假)  // NN_SUB=33
        {
            返回 (假)
        }

        变量 subscribe <类型 = 字节集类>
        subscribe = 文本到多字节 (过滤器)
        // NN_SUB_SUBSCRIBE=1,NN_SUB_UNSUBSCRIBE=2
        如果 (Nanomsg_Setsockopt (_取句柄 (), 33, 1, 取字节集指针 (subscribe), 取字节集长度 (subscribe) - 1) == 假)
        {
            返回 (假)
        }


        如果 (Nanomsg_Connect (_取句柄 (), 取字节集指针 (szurl)) == 假)
        {
            返回 (假)
        }
        返回 (真)

    }

    方法 接收 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 用来存放接收的数据 <类型 = 字节集类>
    参数 标记 <类型 = 整数 @默认值 = 0>
    {
        @ char* pBuf = NULL;
        @ int nReadByte = 0;
        @ bool bOK = Nanomsg_Recv(GetData(),&pBuf,&nReadByte,@<标记>);
        @ @<用来存放接收的数据> = CVolMem(pBuf,nReadByte);
        @ Nanomsg_FreeMsg(pBuf);
        @ return bOK;


    }

    方法 停止 <公开 类型 = 逻辑型>
    参数 停止方式 <类型 = 整数 @默认值 = 0>
    {
        返回 (Nanomsg_Shutdown (_取句柄 (), 停止方式))


    }

    #
    #
    #
}

