<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <@文档 = "category = \"开源库.进程通讯\"">

类 进程通讯配置常量 <公开 折叠 "">
{
    常量 NN_LINGER <公开 类型 = 整数 值 = 1>
    常量 NN_SNDBUF <公开 类型 = 整数 值 = 2 注释 = "发送缓冲区大小，字节。为了防止阻止超过缓冲区的消息，除了发送缓冲区中的数据之外，还可以缓冲一条消息。此选项的类型为 int。默认值为128kB。">
    常量 NN_RCVBUF <公开 类型 = 整数 值 = 3 注释 = "接收缓冲区大小，字节。为了防止阻止超过缓冲区的消息，除了接收缓冲区中的数据之外，还可以缓冲一条消息。此选项的类型为 int。默认值为128kB。">
    常量 NN_SNDTIMEO <公开 类型 = 整数 值 = 4 注释 = "插座上发送操作的超时，在毫秒内。如果消息不能在指定的超时内发送，则会返回 ETIMEDOUT 错误。负值意味着无限超时。该选项的类型为 int。默认值为-1。">
    常量 NN_RCVTIMEO <公开 类型 = 整数 值 = 5 注释 = "插座上 recv 操作的超时，在毫秒内。如果无法在指定超时内收到消息，则会返回 ETIMEDOUT 错误。负值意味着无限超时。该选项的类型为 int。默认值为-1。">
    常量 NN_RECONNECT_IVL <公开 类型 = 整数 值 = 6 注释 = "对于基于连接的传输（如 TCP），此选项指定在尝试重新建立连接之前，" 注释 = "在毫秒内连接中断时需要等待多长时间。请注意，"
            注释 = "实际重新连接间隔可能在一定程度上是随机的，以防止严重的重新连接风暴。" 注释 = "该选项的类型为 int。默认值为 100 （0.1 秒）。">
    常量 NN_RECONNECT_IVL_MAX <公开 类型 = 整数 值 = 7 注释 = "此选项仅在NN_RECONNECT_IVL选项之外使用。它指定了最大的重新连接间隔。"
            注释 = "在每次重新连接尝试时，以前的间隔将加倍，直到达到NN_RECONNECT_IVL_MAX。" 注释 = "零值意味着不执行指数反向，重新连接间隔仅基于NN_RECONNECT_IVL。"
            注释 = "如果NN_RECONNECT_IVL_MAX小于NN_RECONNECT_IVL，则忽略它。该选项的类型为 int。默认值为 0。">
    常量 NN_SNDPRIO <公开 类型 = 整数 值 = 8 注释 = "为随后添加到插座的端点设置出站优先级。此选项对向所有同行发送消息的插座类型没有影响。"
            注释 = "但是，如果插座类型将每个消息发送给单个对等（或有限的对等器组），则具有高优先级的同级比低优先级的同侪优先。" 注释 = "该选项的类型为 int。最高优先级为 1，最低优先级为 16。默认值为 8。">
    常量 NN_RCVPRIO <公开 类型 = 整数 值 = 9 注释 = "随后添加到插座的端点设置入站优先级。此选项对无法接收消息的插座类型没有影响。收到邮件时"
            注释 = "，在收到来自优先级较低的同行的消息之前，将接收来自优先级较高的同行的消息。该选项的类型为 int。最高优先级为 1，最低优先级为 16。默认值为 8。">
    常量 NN_SNDFD <公开 类型 = 整数 值 = 10>
    常量 NN_RCVFD <公开 类型 = 整数 值 = 11>
    常量 NN_DOMAIN <公开 类型 = 整数 值 = 12>
    常量 NN_PROTOCOL <公开 类型 = 整数 值 = 13>
    常量 NN_IPV4ONLY <公开 类型 = 整数 值 = 14 注释 = "如果设置为 1，则仅使用 IPv4 地址。如果设置为 0，则使用 IPv4 和 IPv6 地址。该选项的类型为 int。默认值为 1。">
    常量 NN_SOCKET_NAME <公开 类型 = 整数 值 = 15 注释 = "错误报告和统计的插座名称。选项的类型是字符串。默认值为\"插座\"。N\"其中N是插座整数。此选项是实验性的，详情请参阅nn_env（7）">
    常量 NN_RCVMAXSIZE <公开 类型 = 整数 值 = 16 注释 = "可以字节接收的最大消息大小。负值意味着接收的大小仅受可用可地址存储器的限制。此选项的类型为 int。默认值为1024kB。">
    常量 NN_MAXTTL <公开 类型 = 整数 值 = 17 注释 = "设置消息在删除之前可以经过的最大\"跳\"数。每次收到消息（例如通过nn_device（3）函数）都算作单跳。这提供了一种防止无意循环的保护形式。">

    #
}

