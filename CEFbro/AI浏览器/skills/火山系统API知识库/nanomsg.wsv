类 进程通讯通讯状态常量 <公开 注释 = "/*  Transport statistics  */" 折叠 @常量类 = 整数>
{
    常量 NN_STAT_ESTABLISHED_CONNECTIONS <公开 值 = 101>
    常量 NN_STAT_ACCEPTED_CONNECTIONS <公开 值 = 102>
    常量 NN_STAT_DROPPED_CONNECTIONS <公开 值 = 103>
    常量 NN_STAT_BROKEN_CONNECTIONS <公开 值 = 104>
    常量 NN_STAT_CONNECT_ERRORS <公开 值 = 105>
    常量 NN_STAT_BIND_ERRORS <公开 值 = 106>
    常量 NN_STAT_ACCEPT_ERRORS <公开 值 = 107>
    常量 NN_STAT_CURRENT_CONNECTIONS <公开 值 = 201>
    常量 NN_STAT_INPROGRESS_CONNECTIONS <公开 值 = 202>
    常量 NN_STAT_CURRENT_EP_ERRORS <公开 值 = 203>
    常量 "" <注释 = "/*  The socket-internal statistics  */">
    常量 NN_STAT_MESSAGES_SENT <公开 值 = 301>
    常量 NN_STAT_MESSAGES_RECEIVED <公开 值 = 302>
    常量 NN_STAT_BYTES_SENT <公开 值 = 303>
    常量 NN_STAT_BYTES_RECEIVED <公开 值 = 304>
    常量 "" <注释 = "/*  Protocol statistics  */">
    常量 NN_STAT_CURRENT_SND_PRIORITY <公开 值 = 401>

    #
}

类 ______进程通讯_全局函数 <公开 注释 = "主页 https://nanomsg.org/gettingstarted/index.html" 折叠 @全局类 = 真
        @视窗.外部头文件 = "nanomsg\\nanomsgTool.h" @视窗.外部库.win32 = "nanomsg\\nanomsgToolx86.lib"
        @视窗.附属文件.win32 = "nanomsg\\nanomsgToolx86.dll" @视窗.外部库.x64 = "nanomsg\\nanomsgToolx64.lib"
        @视窗.附属文件.x64 = "nanomsg\\nanomsgToolx64.dll">
{
    方法 Nanomsg_GetState <公开 静态 类型 = 整数哈希集 返回值注释 = "错误返回-1" @嵌入式方法 = "">
    参数 socket <类型 = 整数>
    参数 要查询的值 <类型 = 进程通讯通讯状态常量>
    {
        @ Nanomsg_GetState(@<socket>,@<要查询的值>)
    }

    方法 Nanomsg_new <公开 静态 类型 = 变整数 返回值注释 = "void *" @嵌入式方法 = "">
    {
        @ Nanomsg_new()
    }

    方法 Nanomsg_CopyConstruct <公开 静态 返回值注释 = "void" @嵌入式方法 = "">
    参数 hDes <类型 = 变整数 注释 = "void *">
    参数 hSrc <类型 = 变整数 注释 = "void *">
    {
        @ Nanomsg_CopyConstruct((void *)@<hDes>,(void *)@<hSrc>)
    }

    方法 Nanomsg_delete <公开 静态 返回值注释 = "void" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    {
        @ Nanomsg_delete((void *)@<hNano>)
    }

    方法 Nanomsg_Socket <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 domain <类型 = 整数 注释 = "#define AF_SP 1" 注释 = "#define AF_SP_RAW 2">
    参数 protocol <类型 = 整数 注释 = "int">
    {
        @ Nanomsg_Socket((void *)@<hNano>,@<domain>,@<protocol>)
    }

    方法 Nanomsg_GetErrorText <公开 静态 类型 = 文本型 @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    {
        @ CVolString( Nanomsg_Socket((void *)@<hNano>))
    }

    方法 Nanomsg_GetErrorCode <公开 静态 类型 = 整数 @嵌入式方法 = "">
    {
        @  Nanomsg_GetErrorCode()
    }

    方法 Nanomsg_Setsockopt <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 level <类型 = 整数>
    参数 option <类型 = 整数 注释 = "如果 level == 0 ，那么可以调用 进程通讯配置常量的值">
    参数 optval <类型 = 变整数 注释 = "const void *">
    参数 optvallen <类型 = 长整数 注释 = "long long">
    {
        @ Nanomsg_Setsockopt((void *)@<hNano>,@<level>,@<option>,(const void *)@<optval>,(long long)@<optvallen>)
    }

    方法 Nanomsg_Getsockopt <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 level <类型 = 整数 注释 = "int">
    参数 option <类型 = 整数 注释 = "int">
    参数 optval <类型 = 变整数 注释 = "void *">
    参数 optvallen <类型 = 长整数 注释 = "long long *">
    {
        @ Nanomsg_Getsockopt((void *)@<hNano>,@<level>,@<option>,(void *)@<optval>,(long long *)&@<optvallen>)
    }

    方法 Nanomsg_close <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    {
        @ Nanomsg_close((void *)@<hNano>)
    }

    方法 Nanomsg_Bind <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 addr <类型 = 变整数 注释 = "const char *">
    {
        @ Nanomsg_Bind((void *)@<hNano>,(const char *)@<addr>)
    }

    方法 Nanomsg_Recv <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 buf <类型 = 变整数 注释 = "void *">
    参数 pbyteRead <类型 = 整数 注释 = "int *">
    参数 flags <类型 = 整数 注释 = "int">
    {
        @ Nanomsg_Recv((void *)@<hNano>,(void *)@<buf>,&@<pbyteRead>,@<flags>)
    }

    方法 Nanomsg_FreeMsg <公开 静态 返回值注释 = "void" @嵌入式方法 = "">
    参数 pMsg <类型 = 变整数 注释 = "void *">
    {
        @ Nanomsg_FreeMsg((void *)@<pMsg>)
    }

    方法 Nanomsg_Connect <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 lpszUrl <类型 = 变整数 注释 = "const char *">
    {
        @ Nanomsg_Connect((void *)@<hNano>,(const char *)@<lpszUrl>)
    }

    方法 Nanomsg_Send <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 buf <类型 = 变整数 注释 = "const void *">
    参数 len <类型 = 整数 注释 = "int">
    参数 flags <类型 = 整数 注释 = "int">
    {
        @ Nanomsg_Send((void *)@<hNano>,(const void *)@<buf>,@<len>,@<flags>)
    }

    方法 Nanomsg_Shutdown <公开 静态 类型 = 逻辑型 返回值注释 = "bool" @嵌入式方法 = "">
    参数 hNano <类型 = 变整数 注释 = "void *">
    参数 nhow <类型 = 整数 注释 = "int">
    {
        @ Nanomsg_Shutdown((void *)@<hNano>,@<nhow>)
    }

    #
    #
    #
    #
}

类 ______进程通讯_模板类 <@模板基础类 = 真>
{

    # @begin
    # <> <include>
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     if(m_data == objCompare.m_data)
    #         return TRUE;
    #     return FALSE;
    # }
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     Nanomsg_CopyConstruct(this->m_data,objCopyFrom.m_data);
    # }
    # void SetData(void* pData)
    # {
    #     m_data = pData;
    # }
    # void* GetData()
    # {
    #     return m_data;
    # }
    # void* m_data;
    # <> </include>
    # @end

    方法 _取句柄 <类型 = 变整数 @嵌入式方法 = "">
    {
        @ (INT_P) @sn<this>.GetData()
    }

    方法 类_初始化
    {
        @ SetData(Nanomsg_new ());
    }

    方法 类_清理
    {
        @ Nanomsg_delete(GetData());
    }

    方法 取错误信息 <公开 类型 = 文本型 @嵌入式方法 = "">
    {
        @ CVolString( Nanomsg_GetErrorText( @sn<this>.GetData()))
    }

    方法 取错误代码 <公开 类型 = 整数 @嵌入式方法 = "">
    {
        @ Nanomsg_GetErrorCode()
    }

    方法 取状态 <公开 类型 = 整数哈希集 返回值注释 = "错误返回-1" @嵌入式方法 = "">
    参数 socket <类型 = 整数>
    参数 要查询的值 <类型 = 进程通讯通讯状态常量>
    {
        @ Nanomsg_GetState( @sn<this>.GetData(),@<要查询的值>)
    }

    #
}

类 进程通讯_单向_发送器 <公开 基础类 = ______进程通讯_模板类 注释 = "原文连接https://nanomsg.org/gettingstarted/pipeline.html" 折叠 @模板实现类 = "">
{

    #

    方法 开始 <公开 类型 = 逻辑型 注释 = "   NN_PULL  81">
    参数 url <类型 = 文本型>
    参数 协议类型 <类型 = 整数 注释 = "可选值" 注释 = "1 表示自带协议" 注释 = "2 表示原始协议" @默认值 = 1>
    {
        变量 szurl <类型 = 字节集类>
        szurl = 文本到UTF8 (url)
        如果 (Nanomsg_Socket (_取句柄 (), 协议类型, 进程通讯模型常量.NN_PUSH) == 假)  // NN_PUSH, 80
        {
            返回 (假)
        }
        如果 (Nanomsg_Connect (_取句柄 (), 取字节集指针 (szurl)) == 假)
        {
            返回 (假)
        }
        返回 (真)
    }

    方法 发送 <公开 类型 = 逻辑型>
    参数 要发送的数据 <类型 = 字节集类>
    参数 选项 <类型 = 整数 @默认值 = 0>
    {
        返回 (Nanomsg_Send (_取句柄 (), 取字节集指针 (要发送的数据), 取字节集长度 (要发送的数据), 0))
    }

    方法 停止 <公开 类型 = 逻辑型>
    参数 停止方式 <类型 = 整数 @默认值 = 0>
    {
        返回 (Nanomsg_Shutdown (_取句柄 (), 停止方式))


    }

    #
    #
    #
}

类 进程通讯_单向_接收器 <公开 基础类 = ______进程通讯_模板类 注释 = "原文连接 https://nanomsg.org/gettingstarted/pipeline.html" 折叠 @模板实现类 = "">
{
    方法 开始 <公开 类型 = 逻辑型 注释 = "">
    参数 url <类型 = 文本型>
    参数 协议类型 <类型 = 整数 注释 = "可选值" 注释 = "1 表示自带协议" 注释 = "2 表示原始协议" @默认值 = 1>
    {
        变量 szurl <类型 = 字节集类>
        szurl = 文本到UTF8 (url)
        如果 (Nanomsg_Socket (_取句柄 (), 协议类型, 进程通讯模型常量.NN_PULL) == 假)  // NN_PULL 81
        {
            返回 (假)
        }
        如果 (Nanomsg_Bind (_取句柄 (), 取字节集指针 (szurl)) == 假)
        {
            返回 (假)
        }
        返回 (真)
    }

    方法 接收 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 用来存放接收的数据 <类型 = 字节集类>
    参数 标记 <类型 = 整数 @默认值 = 0>
    {
        @ char* pBuf = NULL;
        @ int nReadByte = 0;
        @ bool bOK = Nanomsg_Recv(GetData(),&pBuf,&nReadByte,@<标记>);
        @ @<用来存放接收的数据> = CVolMem(pBuf,nReadByte);
        @ Nanomsg_FreeMsg(pBuf);
        @ return bOK;


    }

    方法 停止 <公开 类型 = 逻辑型 折叠>
    参数 停止方式 <类型 = 整数 @默认值 = 0>
    {
        返回 (Nanomsg_Shutdown (_取句柄 (), 停止方式))


    }

    #
}

