    #     {                                                                 \
    #         SetData(m_data);                                              \
    #     }                                                                 \
    #     std_type& GetData()                                               \
    #     {                                                                 \
    #         return m_data;                                                \
    #     }                                                                 \
    #     const std_type& GetData() const                                   \
    #     {                                                                 \
    #         return m_data;                                                \
    #     }                                                                 \
    #     void SetData(const std_type& m_data)                              \
    #     {                                                                 \
    #       this->m_data = m_data;                                          \
    #     }                                                                 \
    #     std_type m_data;                                           
