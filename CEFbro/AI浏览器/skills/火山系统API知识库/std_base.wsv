<火山程序 类型 = "通常" 版本 = 1 />

包 火山.原创软件 <注释 = "本模块来源于网络" 注释 = "切勿用作非法用途" @文档 = "category = \"STL.基础共用模板\"" "">

#

类 _标准模板基础类 <公开 @模板基础类 = 真 @视窗.外部头文件 = "<algorithm>">
{

    # @begin
    # <> <include>
    # @def_macro DECLARE_VOL_STD_DEFAULT_FUCTION(std_type )                 \
