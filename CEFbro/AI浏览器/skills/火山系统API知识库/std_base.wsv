    # #define CFVol_FOR_FORWARD_ITERATOR(type, data)  for(type::iterator it = data.begin(); it !=data.end(); it++)
    # #define CFVol_FOR_REVERSE_ITERATOR(type,data)   for(type::reverse_iterator it = data.rbegin(); it != data.rend(); it++)
    #
    #
