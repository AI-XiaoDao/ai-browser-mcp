    }
}

类 矩形_结构类 <公开 基础类 = 结构基础类 折叠>
{

    # @begin
    # @m<DECLARE_STRUCT_CLASS>(RECT)
    # @end

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" 折叠 折叠2 @虚拟方法 = 可覆盖 @输出名 = "GetDumpString"
            @视窗.后缀文本 = "override">
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "左边:" + 到文本 (左边) + " 顶边:" + 到文本 (顶边) + " 右边:" + 到文本 (右边) + " 底边:" + 到文本 (底边)
    }

    方法 左边 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->left
    }

    方法 顶边 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->top
    }

    方法 右边 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->right
    }

    方法 底边 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->bottom
    }

    # //==
    # //属性写

    方法 左边 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @  pdata()->left = @<值>;
    }

    方法 顶边 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @ pdata()->top = @<值>;
    }

    方法 右边 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @  pdata()->right = @<值>;
    }

    方法 底边 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @  pdata()->bottom = @<值>;
    }

    #
}

类 矩形数组容器类 <公开 基础类 = 结构数组容器模板类 折叠 @模板实现类 = "矩形_结构类">
{

    # @begin
    # <> <include>
    # @m<DECLARE_VOL_STD_DEFAULT_FUCTION>( std::vector<RECT> )
    # <> </include>
    # @end
    #

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" 折叠 @虚拟方法 = 可覆盖 @输出名 = "GetDumpString"
            @视窗.后缀文本 = "override">
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        变量 i <类型 = 整数>
        循环 (0, 取成员数 (), i)
        {
            变量 临时内容 <类型 = 文本型>
            取成员 (i).取展示内容 (临时内容, 0)
            展示内容 = 展示内容 + 临时内容 + "\r\n"

        }

    }

    #
    #
}

类 坐标_结构类 <公开 基础类 = 结构基础类>
{

    # @begin
    # @m<DECLARE_STRUCT_CLASS>(POINT)
    # @end

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" 折叠2 @虚拟方法 = 可覆盖 @输出名 = "GetDumpString"
            @视窗.后缀文本 = "override">
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "横坐标:" + 到文本 (横坐标) + " 纵坐标:" + 到文本 (纵坐标)
    }

    方法 横坐标 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->x;
    }

    方法 纵坐标 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @  @sn<this>.pdata()->y
    }

    # //属性写方法

    方法 横坐标 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @  pdata()->x = @<值>;
    }

    方法 纵坐标 <公开 属性写>
    参数 值 <类型 = 整数>
    {
        @  pdata()->y = @<值>;
    }

    #
}

类 坐标数组容器类 <公开 基础类 = 结构数组容器模板类 @模板实现类 = "矩形_结构类">
{

    # @begin
    # <> <include>
    # @m<DECLARE_VOL_STD_DEFAULT_FUCTION>( std::vector<POINT> )
    # <> </include>
    # @end
    #

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" 折叠 @虚拟方法 = 可覆盖 @输出名 = "GetDumpString"
            @视窗.后缀文本 = "override">
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        变量 i <类型 = 整数>
        循环 (0, 取成员数 (), i)
        {
            变量 临时内容 <类型 = 文本型>
            取成员 (i).取展示内容 (临时内容, 0)
            展示内容 = 展示内容 + 临时内容 + "\r\n"

        }

    }

    #
    #
}

类 整数数组容器测试 <公开 折叠>
{
    变量 整数容器 <类型 = 整数数组容器类>
    变量 拷贝测试 <类型 = 整数数组容器类>

    方法 开始测试 <公开>
    {

        整数容器.置容量 (100)
        调试输出 ("容器容量为: " + 到文本 (整数容器.取容量 ()))

        调试输出 (整数容器.取成员数 ())
        调试输出 ("----整数容器测试开始")
        整数容器.加入成员 (1)
        整数容器.加入成员 (11)
        整数容器.加入成员 (5)
        整数容器.加入成员 (20)
        整数容器.加入成员 (21)
        整数容器.加入成员 (20)
        整数容器.删除尾成员 ()
        整数容器.加入成员 (8)
        整数容器.加入成员 (23)
        整数容器.加入成员 (63)
        整数容器.排序 (真)

        打印容器数组 (整数容器, "从小到大排序后的数组")

        整数容器.排序 (假)
        打印容器数组 (整数容器, "从大到小排序后的数组")

        整数容器.删除成员 (1, 2)
        打印容器数组 (整数容器, "删除成员 开始位置=1 数量=1 后的数组")

        整数容器.删除成员 (0, 1)
        打印容器数组 (整数容器, "删除成员 开始位置=0 数量=1 后的数组")

        整数容器.删除成员 (2, -1)
        打印容器数组 (整数容器, "删除成员 开始位置=2 数量=-1 后的数组")

        返回

        拷贝测试 = 整数容器
        打印容器数组 (拷贝测试, "----整数容器测试拷贝")

        调试输出 ("----整数容器相等测试")
        如果 (整数容器 == 拷贝测试)
        {
            调试输出 ("两个容器相等   测试通过")
        }
        否则
        {
            调试输出 ("两个容器不相等 测试不通过")
        }

        调试输出 ("----整数容器测试结束")


        变量 临时字节集 <类型 = 字节集类>
        变量 新的整数容器 <类型 = 容器整数类>
        调试输出 (">>>>>>  开始测试  容器到字节集，字节集到容器测试")
        临时字节集 = 整数容器.到字节集 ()
        新的整数容器.从字节集载入 (临时字节集)

        如果 (新的整数容器 == 整数容器)
        {
            调试输出 ("容器到字节集 ，字节集到容器 测试通过")
        }
        否则
        {
            调试输出 ("容器到字节集 ，字节集到容器 测试失败")

        }
        调试输出 (">>>>>>  结束测试  容器到字节集，字节集到容器测试")
        打印容器数组 (新的整数容器, "  容器到字节集，字节集到容器 观察数据")


        调试输出 ("/////////// 开始测试 容器整数 查找替换测试")
        如果 (新的整数容器.是否存在 (20) == 真)
        {
            调试输出 ("查找测试通过")
        }
        否则
        {
            调试输出 ("查找测试不通过")

        }

        新的整数容器.压入 (20)
        新的整数容器.压入 (20)
        新的整数容器.压入 (20)

        新的整数容器.替换 (20, 99, 1, 真)


        如果 (新的整数容器.是否存在 (99) == 真)
        {
            调试输出 ("替换 测试通过")
        }
        否则
        {
            调试输出 ("替换 测试未通过")

        }

        打印容器数组 (新的整数容器, " ")

        调试输出 ("/////////// 结束测试 容器整数 查找替换测试\r\n")

        调试输出 (">>>>>>>>>>>>>>>> 开始测试 容器整数 交换")
        变量 用作交换的容器整数 <类型 = 容器整数类>
        用作交换的容器整数.压入 (88)
        用作交换的容器整数.压入 (77)
        整数容器.交换 (用作交换的容器整数)

        打印容器数组 (用作交换的容器整数, "交换后的内容")

        调试输出 (">>>>>>>>>>>>>>>> 结束测试 容器整数 交换")


        打印反向容器数组 (整数容器, "反向打印容器数组")


        调试输出 ("<<<<<<<<<<<<<<< 开始测试  容器整数 反转")

        整数容器.压入 (11)
        整数容器.压入 (22)
        打印容器数组 (整数容器, "反转前")

        整数容器.反转 ()
        打印容器数组 (整数容器, "开始位置-1 反转数量-1 反转测试")
        整数容器.反转 (0, 2)
        打印容器数组 (整数容器, "开始位置0 反转数量2  反转测试")
        整数容器.反转 (1, 2)
        打印容器数组 (整数容器, "开始位置1 反转数量2  反转测试")
        整数容器.反转 (2, 2)
        打印容器数组 (整数容器, "开始位置2 反转数量2  反转测试")
        整数容器.反转 (1)
        打印容器数组 (整数容器, "开始位置1 反转数量-1  反转测试")


        调试输出 ("<<<<<<<<<<<<<<< 结束测试  容器整数 反转")


        变量 组合 <类型 = 容器整数类>
        变量 组合结果 <类型 = 文本型>
        调试输出 ("--------------------------- 组合测试")
        组合.压入 (1)
        组合.压入 (2)
        组合.压入 (3)
        组合.压入 (4)
        组合.压入 (5)

        组合.排列 ()
        {
            组合结果 = ""
            组合.迭代正向 ()
            {
                组合结果 = 组合结果 + 到文本 (组合.迭代值 ()) + " "

            }
            调试输出 (组合结果)
        }







        变量 i <类型 = 整数>
        // 组合.开始组合 (3)
        {
            // 组合结果 = ""
            // 循环 (0, 3, i)
            {
                // 组合结果 = 组合结果 + 到文本 (组合.取组合值 (i)) + " "

            }
            // 调试输出 (组合结果)

        }
        // 组合.结束组合 ()

        调试输出 ("-------新修改的组合--------")

        组合.组合 (3)
        {
            组合结果 = ""
            循环 (0, 3, i)
            {
                组合结果 = 组合结果 + 到文本 (组合.取组合值 (i)) + " "

            }
            调试输出 (组合结果)

        }

        调试输出 ("-------新修改组合结束--------")
        打印容器数组 (组合, "调用了组合函数后，原容器内容")


        变量 文本组合 <类型 = 容器文本类>
        变量 k <类型 = 整数>
        文本组合.压入 ("aa")
        文本组合.压入 ("bb")
        文本组合.压入 ("cc")
        文本组合.压入 ("dd")
        文本组合.压入 ("ee")

        文本组合.排列 ()
        {
            组合结果 = ""
            文本组合.迭代正向 ()
            {
                组合结果 = 组合结果 + 文本组合.迭代值 ()

            }
            调试输出 (组合结果)
        }


        文本组合.组合 (3)
        {

            组合结果 = ""
            循环 (0, 3, k)
            {
                组合结果 = 组合结果 + 到文本 (文本组合.取组合值 (k)) + " "

            }
            调试输出 (组合结果)

        }





        // 简易枚举测试===
        变量 vt <类型 = 容器文本类>
        vt.压入 ("name1")
        vt.压入 ("name2")
        变量 计数器 <类型 = 整数 值 = 0>
        vt.迭代正向 ()
        {
            调试输出 (vt.迭代值 ())
            计数器 = 计数器 + 1
            如果 (计数器 == 100)
            {
                返回
            }
        }


    }

    方法 打印容器数组 <折叠>
    参数 容器 <类型 = 整数数组容器类>
    参数 要输出的内容 <类型 = 文本型>
    {
        调试输出 (要输出的内容)

        容器.迭代正向 ()
        {
            调试输出 (容器.迭代值 ())
        }

    }

    方法 打印反向容器数组 <折叠>
    参数 容器 <类型 = 容器整数类>
    参数 要输出的内容 <类型 = 文本型>
    {
        调试输出 (要输出的内容)
        容器.迭代反向 ()
        {
            调试输出 (容器.迭代值 ())
        }

    }

    #
}

类 矩形数组容器测试类 <公开 折叠>
{
    方法 开始测试 <公开>
    {
        变量 arr <类型 = 矩形数组容器类>
        变量 arr2 <类型 = 矩形数组容器类>
        变量 rt <类型 = 矩形_结构类>
        变量 "" <类型 = 对象类>
        rt.左边 = 10
        rt.顶边 = 11
        rt.右边 = 12
        rt.底边 = 13

        arr.加入成员 (rt)
        arr.加入成员 (rt)

        arr2.加入成员 (rt)
        如果 (arr.对象内容是否相同 (arr2))
        {
            调试输出 ("相等")
        }
        否则
        {
            调试输出 ("不等")
        }

        arr2.加入成员 (rt)
        如果 (arr.对象内容是否相同 (arr2))
        {
            调试输出 ("相等")
        }
        否则
        {
            调试输出 ("不等")
        }

        // 调试输出 (rt)

        调试输出 (arr)






    }

    #
}

