        {
            返回 (0)
        }
        @ return sizeof( GetData()[0] )*GetData().size();
    }

    方法 加入尾成员 <公开 注释 = "[!!!]这个的封装只能用于基础类型元素，不适合结构体相关的" 注释 = "加入一个数据到容器的尾部" 折叠2 @嵌入式方法 = "">
    参数 要加入的成员 <类型 = 模板类型1>
    {
        @   @sn<this>.GetData().push_back(*@<要加入的成员>.pdata())
    }

    方法 加入成员 <公开 注释 = "[!!!]这个的封装只能用于基础类型元素，不适合结构体相关的" 注释 = "//在a的第1个元素（从第0个算起）的位置插入数值5，如a为1,2,3,4，插入元素后为1,5,2,3,4" 折叠2>
    参数 要加入的成员 <类型 = 模板类型1>
    参数 加入的位置 <类型 = 整数 注释 = "如果为 ，表示加入到末尾" @默认值 = -1>
    {
        @ if (@<加入的位置> == -1)
