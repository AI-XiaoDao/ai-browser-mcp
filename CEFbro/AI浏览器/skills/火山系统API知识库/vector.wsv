类 容器测试 <公开>
{
    变量 整数容器 <类型 = 容器整数类>
    变量 拷贝测试 <类型 = 容器整数类>
    变量 ""
    变量 ""

    方法 开始测试 <公开>
    {

        整数容器.置容量 (100)
        调试输出 ("容器容量为: " + 到文本 (整数容器.取容量 ()))

        调试输出 (整数容器.取数量 ())
        调试输出 ("----整数容器测试开始")
        整数容器.压入 (1)
        整数容器.压入 (11)
        整数容器.压入 (5)
        整数容器.压入 (20)
        整数容器.压入 (21)
        整数容器.压入 (20)
        整数容器.弹出 ()
        整数容器.压入 (8)
        整数容器.压入 (23)
        整数容器.压入 (63)

        整数容器.排序 (真)

        打印容器数组 (整数容器, "从小到大排序后的数组")

        整数容器.排序 (假)
        打印容器数组 (整数容器, "从大到小排序后的数组")

        整数容器.删除成员 (1, 2)
        打印容器数组 (整数容器, "删除成员 开始位置=1 数量=1 后的数组")

        整数容器.删除成员 (0, 1)
        打印容器数组 (整数容器, "删除成员 开始位置=0 数量=1 后的数组")

        整数容器.删除成员 (2, -1)
        打印容器数组 (整数容器, "删除成员 开始位置=2 数量=-1 后的数组")

        返回

        拷贝测试 = 整数容器
        打印容器数组 (拷贝测试, "----整数容器测试拷贝")

        调试输出 ("----整数容器相等测试")
        如果 (整数容器 == 拷贝测试)
        {
            调试输出 ("两个容器相等   测试通过")
        }
        否则
        {
            调试输出 ("两个容器不相等 测试不通过")
        }

        调试输出 ("----整数容器测试结束")


        变量 临时字节集 <类型 = 字节集类>
        变量 新的整数容器 <类型 = 容器整数类>
        调试输出 (">>>>>>  开始测试  容器到字节集，字节集到容器测试")
        临时字节集 = 整数容器.到字节集 ()
        新的整数容器.从字节集载入 (临时字节集)

        如果 (新的整数容器 == 整数容器)
        {
            调试输出 ("容器到字节集 ，字节集到容器 测试通过")
        }
        否则
        {
            调试输出 ("容器到字节集 ，字节集到容器 测试失败")

        }
        调试输出 (">>>>>>  结束测试  容器到字节集，字节集到容器测试")
        打印容器数组 (新的整数容器, "  容器到字节集，字节集到容器 观察数据")


        调试输出 ("/////////// 开始测试 容器整数 查找替换测试")
        如果 (新的整数容器.是否存在 (20) == 真)
        {
            调试输出 ("查找测试通过")
        }
        否则
        {
            调试输出 ("查找测试不通过")

        }

        新的整数容器.压入 (20)
        新的整数容器.压入 (20)
        新的整数容器.压入 (20)

        新的整数容器.替换 (20, 99, 1, 真)


        如果 (新的整数容器.是否存在 (99) == 真)
        {
            调试输出 ("替换 测试通过")
        }
        否则
        {
            调试输出 ("替换 测试未通过")

        }

        打印容器数组 (新的整数容器, " ")

        调试输出 ("/////////// 结束测试 容器整数 查找替换测试\r\n")

        调试输出 (">>>>>>>>>>>>>>>> 开始测试 容器整数 交换")
        变量 用作交换的容器整数 <类型 = 容器整数类>
        用作交换的容器整数.压入 (88)
        用作交换的容器整数.压入 (77)
        整数容器.交换 (用作交换的容器整数)

        打印容器数组 (用作交换的容器整数, "交换后的内容")

        调试输出 (">>>>>>>>>>>>>>>> 结束测试 容器整数 交换")


        打印反向容器数组 (整数容器, "反向打印容器数组")


        调试输出 ("<<<<<<<<<<<<<<< 开始测试  容器整数 反转")

        整数容器.压入 (11)
        整数容器.压入 (22)
        打印容器数组 (整数容器, "反转前")

        整数容器.反转 ()
        打印容器数组 (整数容器, "开始位置-1 反转数量-1 反转测试")
        整数容器.反转 (0, 2)
        打印容器数组 (整数容器, "开始位置0 反转数量2  反转测试")
        整数容器.反转 (1, 2)
        打印容器数组 (整数容器, "开始位置1 反转数量2  反转测试")
        整数容器.反转 (2, 2)
        打印容器数组 (整数容器, "开始位置2 反转数量2  反转测试")
        整数容器.反转 (1)
        打印容器数组 (整数容器, "开始位置1 反转数量-1  反转测试")


        调试输出 ("<<<<<<<<<<<<<<< 结束测试  容器整数 反转")


        变量 组合 <类型 = 容器整数类>
        变量 组合结果 <类型 = 文本型>
        调试输出 ("--------------------------- 组合测试")
        组合.压入 (1)
        组合.压入 (2)
        组合.压入 (3)
        组合.压入 (4)
        组合.压入 (5)

        组合.排列 ()
        {
            组合结果 = ""
            组合.迭代正向 ()
            {
                组合结果 = 组合结果 + 到文本 (组合.迭代值 ()) + " "

            }
            调试输出 (组合结果)
        }







        变量 i <类型 = 整数>
        // 组合.开始组合 (3)
        {
            // 组合结果 = ""
            // 循环 (0, 3, i)
            {
                // 组合结果 = 组合结果 + 到文本 (组合.取组合值 (i)) + " "

            }
            // 调试输出 (组合结果)

        }
        // 组合.结束组合 ()

        调试输出 ("-------新修改的组合--------")

        组合.组合 (3)
        {
            组合结果 = ""
            循环 (0, 3, i)
            {
                组合结果 = 组合结果 + 到文本 (组合.取组合值 (i)) + " "

            }
            调试输出 (组合结果)

        }

        调试输出 ("-------新修改组合结束--------")
        打印容器数组 (组合, "调用了组合函数后，原容器内容")


        变量 文本组合 <类型 = 容器文本类>
        变量 k <类型 = 整数>
        文本组合.压入 ("aa")
        文本组合.压入 ("bb")
        文本组合.压入 ("cc")
        文本组合.压入 ("dd")
        文本组合.压入 ("ee")

        文本组合.排列 ()
        {
            组合结果 = ""
            文本组合.迭代正向 ()
            {
                组合结果 = 组合结果 + 文本组合.迭代值 ()

            }
            调试输出 (组合结果)
        }


        文本组合.组合 (3)
        {

            组合结果 = ""
            循环 (0, 3, k)
            {
                组合结果 = 组合结果 + 到文本 (文本组合.取组合值 (k)) + " "

            }
            调试输出 (组合结果)

        }





        // 简易枚举测试===
        变量 vt <类型 = 容器文本类>
        vt.压入 ("name1")
        vt.压入 ("name2")
        变量 计数器 <类型 = 整数 值 = 0>
        vt.迭代正向 ()
        {
            调试输出 (vt.迭代值 ())
            计数器 = 计数器 + 1
            如果 (计数器 == 100)
            {
                返回
            }
        }


    }

    方法 打印容器数组
    参数 容器 <类型 = 容器整数类>
    参数 要输出的内容 <类型 = 文本型>
    {
        调试输出 (要输出的内容)

        容器.迭代正向 ()
        {
            调试输出 (容器.迭代值 ())
        }

    }

    方法 打印反向容器数组
    参数 容器 <类型 = 容器整数类>
    参数 要输出的内容 <类型 = 文本型>
    {
        调试输出 (要输出的内容)
        容器.迭代反向 ()
        {
            调试输出 (容器.迭代值 ())
        }

