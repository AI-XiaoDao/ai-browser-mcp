类 组合模板 <注释 = "CCombination 这个是我自己写的组合文件" @模板基础类 = 真 @视窗.外部头文件 = "Combination\\CCombination.h">
{
    方法 排列 <公开 @嵌入式方法 = "name = pailie_do_next_permutation\r\nhas_body = true">
    {
        @ CFVol_Vector_For_permutation(@sn<this>.data())
    }

    方法 组合 <公开 @嵌入式方法 = "name =  vector_Combination\r\nhas_body = true">
    参数 抽取几个组合 <类型 = 整数>
    {
        @ fvol_vector_Combination(@<抽取几个组合>,@sn<this>.data())
    }

    方法 取组合值 <公开 类型 = 模板类型1 @嵌入式方法 = "">
    参数 组合里面的索引值 <类型 = 整数 注释 = "抽取几个组合 你填的3 那么这里的索引 就只能是 0 1 2">
    {
        @ @sn<this>.data()[cbn.GetValue(@<组合里面的索引值>)]
    }
}

类 vector <公开 基础类 = 组合模板 @模板基础类 = 真>
{

    # @begin
    #
    # <> <include>
    #
    # #define CFVol_Vector_FOR_ITERATOR(vector_data_type, class_member_vecotr_data) \
    #                     for(std::vector<vector_data_type>::iterator it = class_member_vecotr_data.begin(); it !=class_member_vecotr_data.end(); it++)
    # #define CFVol_Vector_FOR_REVERSE_ITERATOR(vector_data_type,class_member_vecotr_data) \
    #                     for(std::vector<vector_data_type>::reverse_iterator it = class_member_vecotr_data.rbegin(); it != class_member_vecotr_data.rend(); it++)
    # #define CFVol_Vector_For_permutation(vector_data) \
    #               for(bool ok = true; ok ; ok =  std::next_permutation(vector_data.begin(),vector_data.end()) )
    # #define fvol_vector_Combination(Combination_Count,vector_data_ref)          \
    #                 for( CCombination cbn(Combination_Count,vector_data_ref.size()); cbn.CanNext(); cbn.Next())
    #
    #
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_data = objCopyFrom.m_data;
    # }
    #
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return m_data == objCompare.m_data;
    # }
    # inline_ std::vector<@dt<模板类型1>>& data()
    # {
    #     return m_data;
    # }
    # std::vector<@dt<模板类型1>> m_data;
    #
    # <> </include>
    # @end

    方法 取首元素指针 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (@dt<变整数>)data().begin();

    }

    方法 取尾元素指针 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return (@dt<变整数>)data().end();

    }

    方法 取首成员 <公开 类型 = 模板类型1 @禁止流程检查 = 真>
    {
        @ return data().front();
    }

    方法 取尾成员 <公开 类型 = 模板类型1 @禁止流程检查 = 真>
    {
        @ return data().back();
    }

    方法 置容量 <公开 注释 = "设置这个的好处就是可以避免重复分配内存">
    参数 最大数量 <类型 = 整数>
    {
        @ m_data.reserve(@<最大数量>);
    }

    方法 取容量 <公开 类型 = 整数 注释 = "返回a在内存中总共可以容纳的元素个数" @禁止流程检查 = 真>
    {
        @ return m_data.capacity();
    }

    方法 压入 <公开 注释 = "压入成员到末尾" "">
    参数 数据 <类型 = 模板类型1>
    {
        @ m_data.push_back(@<数据>);
    }

    方法 弹出 <公开 注释 = "弹出最后一个" @嵌入式方法 = "">
    {
        @ @sn<this>.m_data.pop_back()
    }

    方法 删除尾成员 <公开 注释 = "弹出最后一个" @嵌入式方法 = "">
    {
        @ @sn<this>.m_data.pop_back()

    }

    方法 取数量 <公开 类型 = 整数 注释 = "取数组成员数量" @禁止流程检查 = 真>
    {
        @ return (INT)m_data.size();

    }

    方法 清空 <公开 注释 = "清空容器里面的所有成员，清空后 调用取数量得到的结果是0" "">
    {
        @ m_data.clear();

    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "测试容器里面是否有成员" @禁止流程检查 = 真>
    {
        @ return m_data.empty();


    }

    方法 删除成员 <公开 注释 = "删除指定位置 和指定数量的成员">
    参数 开始位置 <类型 = 整数 注释 = "0表示从 首元素开始删除" @默认值 = 0>
    参数 删除数量 <类型 = 整数 注释 = "如果为-1 表示从指定位置删除到尾部" @默认值 = 1>
    {
        @ if(@<删除数量> == -1)
        @ {
        @      m_data.erase (m_data.begin () + @<开始位置>,m_data.end());
        @ }else if(@<删除数量> == 0 || @<删除数量> == 1)
        @ {
        @      m_data.erase (m_data.begin () + @<开始位置>, m_data.begin () + @<开始位置>+1);
        @ }else
        @ {
        @      m_data.erase (m_data.begin () + @<开始位置>, m_data.begin () + @<开始位置>+@<删除数量>);
        @ }

    }

    方法 加入成员 <公开 注释 = "//在a的第1个元素（从第0个算起）的位置插入数值5，如a为1,2,3,4，插入元素后为1,5,2,3,4">
    参数 要加入的成员 <类型 = 模板类型1>
    参数 加入的位置 <类型 = 整数 注释 = "如果为-1，表示加入到末尾" @默认值 = -1>
    {
        @ if(@<加入的位置> == -1)
        @ {
        @   m_data.push_back(@<要加入的成员>);
        @ }else
        @ {
        @  m_data.insert(m_data.begin()+@<加入的位置>,@<要加入的成员>);
        @ }
        @ 

    }

    方法 加入容器 <公开>
    参数 vt <类型 = vector>
    参数 加入到指定位置 <类型 = 整数 注释 = "-1表示加入到末尾，否则加入到指定位置 从0开始" @默认值 = -1>
    {
        @ if(@<加入到指定位置> == -1)
        @ {
        @     m_data.insert(m_data.end(),@<vt>.m_data.begin(),@<vt>.m_data.end());
        @ }else
        @ {
        @    m_data.insert(m_data.begin()+@<加入到指定位置>,@<vt>.m_data.begin(),@<vt>.m_data.end());
        @ }
    }

    方法 加入容器部分元素 <公开 折叠>
    参数 vt <类型 = vector>
    参数 截取开始位置 <类型 = 整数 注释 = "表示 vt元素要从 哪个位置开始截取">
    参数 截取数量 <类型 = 整数 注释 = "-1表示 从指定的截取开始位置 到 vt 容器的结尾位置" @默认值 = -1>
    参数 加入到指定位置 <类型 = 整数 注释 = "-1表示加入到末尾，否则加入到指定位置 从0开始" @默认值 = -1>
    {
        @ if(@<加入到指定位置> == -1)
        @ {
        @     if(@<截取数量> == -1)
        @     {
        @         m_data.insert(m_data.end(),@<vt>.m_data.begin()+@<截取开始位置>,@<vt>.m_data.end());
        @     }else
        @     {
        @         m_data.insert(m_data.end(),@<vt>.m_data.begin()+@<截取开始位置>,@<vt>.m_data.begin()+@<截取数量>);
        @     }
        @ }else
        @ {
        @     if(@<截取数量> == -1)
        @     {
        @         m_data.insert(m_data.begin()+@<加入到指定位置>,@<vt>.m_data.begin()+@<截取开始位置>,@<vt>.m_data.end());
        @     }else
        @     {
        @         m_data.insert(m_data.begin()+@<加入到指定位置>,@<vt>.m_data.begin()+@<截取开始位置>,@<vt>.m_data.begin()+@<截取数量>);
        @     }
        @
        @ }
    }

    方法 取值 <公开 类型 = 模板类型1 注释 = "根据索引取值" @禁止流程检查 = 真>
    参数 索引 <类型 = 长整数>
    {
        @ return m_data[@<索引>];
    }

    方法 置值 <公开>
    参数 索引 <类型 = 长整数>
    参数 新值 <类型 = 模板类型1>
    {
        @ m_data[@<索引>] = @<新值>;
    }

    方法 取数据指针 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return m_data.data();
    }

    方法 取数据指针大小 <公开 类型 = 变整数 @禁止流程检查 = 真>
    {
        @ return m_data.size()*sizeof(@dt<模板类型1>);
    }

    # //正反迭代----
    #

    方法 迭代正向 <公开 @嵌入式方法 = "name = FVector_Forward_Iterator\r\nhas_body = true">
    {
        @ CFVol_Vector_FOR_ITERATOR(@dt<模板类型1>,@sn<this>.data())
    }

    方法 迭代反向 <公开 @嵌入式方法 = "name = FVector_Reverse_Iterator\r\nhas_body = true">
    {
        @ CFVol_Vector_FOR_REVERSE_ITERATOR(@dt<模板类型1>,@sn<this>.data())
    }

    方法 迭代值 <公开 类型 = 模板类型1 @嵌入式方法 = "parent = \"FVector_Forward_Iterator,FVector_Reverse_Iterator\"">
    {
        @ *it
    }

    方法 替换 <公开 类型 = 整数 返回值注释 = "返回替换次数" 折叠 @禁止流程检查 = 真>
    参数 欲查找的内容 <类型 = 模板类型1>
    参数 用作替换的内容 <类型 = 模板类型1>
    参数 查找开始位置 <类型 = 整数 注释 = "表示从首元素开始查找" @默认值 = 0>
    参数 是否全部替换 <类型 = 逻辑型 @默认值 = 假>
    {
        @ std::vector< @dt<模板类型1> >::iterator it = m_data.end(); 
        @ if(@<查找开始位置> <= 0)
        @ {
        @     it = std::find(m_data.begin(),m_data.end(),@<欲查找的内容>);
        @ }else
        @ {
        @     it = std::find(m_data.begin()+@<查找开始位置>,m_data.end(),@<欲查找的内容>);
        @ }
        @ int nReplaceCount = 0;
        @ do
        @ {
        @     if( it ==  m_data.end() )
        @     {
        @         return nReplaceCount;
        @     }
        @     *it = @<用作替换的内容>;
        @     nReplaceCount++;
        @     it++;
        @     if(@<是否全部替换>)
        @     {
        @         it = std::find(it,m_data.end(),@<欲查找的内容>);
        @     }
        @ 
        @ }while(@<是否全部替换>);
        @ return nReplaceCount;

    }

    方法 是否存在 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 欲查找的内容 <类型 = 模板类型1>
    {
        @ std::vector<@dt<模板类型1> >::iterator it = std::find(m_data.begin(),m_data.end(),@<欲查找的内容>);
        @ if (it  != m_data.end())
        @ {
        @   return true;
        @ }
        @ else
        @ {
        @  return false;
        @ }

    }

    方法 交换 <公开 折叠>
    参数 vt <类型 = vector>
    {
        @ m_data.swap(@<vt>.m_data);
    }

    方法 反转 <公开 注释 = "例如当然容器值为 1 3 2  反转后为 2 3 1" 折叠>
    参数 开始位置 <类型 = 整数 注释 = "-1 或者 0 都表示从 首元素开始反转" @默认值 = -1>
    参数 反转数量 <类型 = 整数 注释 = "-1 表示从 开始位置，直接反转到 容器尾元素" @默认值 = -1>
    {

        @ if(@<反转数量> <= 0 || @<反转数量> >= m_data.size())
        @ {
        @     if(@<开始位置> <= 0)
        @     {
        @         std::reverse(m_data.begin(),m_data.end());
        @     }else
        @     {
        @         std::reverse(m_data.begin()+@<开始位置>,m_data.end());
        @     }
        @ }else
        @ {
        @     if(@<开始位置> <= 0)
        @     {
        @         std::reverse(m_data.begin(),m_data.begin()+@<反转数量>);
        @     }else
        @     {
        @         std::reverse(m_data.begin()+@<开始位置>,m_data.begin()+@<开始位置>+@<反转数量>);
        @     }
        @ }

    }

    #
}

类 容器基础数值类模板 <公开 基础类 = vector 折叠 @模板基础类 = 真>
{

    # @begin
    # <> <include>
    #     struct compare_big_to_small
    #     {
    #         bool operator() (int &left, int &right)
    #         {
    #             return left > right;
    #         }
    #     };
    #     struct compare_small_to_big
    #     {
    #         bool operator() (int &left, int &right)
    #         {
    #             return left < right;
    #         }
    #     };
    # <> </include>
    # @end

    方法 排序 <公开>
    参数 是否从小到大 <类型 = 逻辑型>
    {
        @ if (@<是否从小到大>)
        @ {
        @  std::sort(m_data.begin(),m_data.end(),compare_small_to_big());
        @ }else
        @ {
        @ std::sort(m_data.begin(),m_data.end(),compare_big_to_small());
        @ }

    }

    方法 去重复 <公开>
    参数 按照从小到大 <类型 = 逻辑型 @默认值 = 真>
    {
        排序 (按照从小到大)
        @ data().erase(std::unique(data().begin(), data().end()), data().end());
    }

    方法 到字节集 <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    {
        @ size_t nBytesOfBuffer = m_data.size()*sizeof(@dt<模板类型1>);
        @ @an<CVolMem> bin(&m_data[0],nBytesOfBuffer);
        @ return bin;

    }

    方法 从字节集载入 <公开 折叠>
    参数 数据 <类型 = 字节集类>
    {
        @ m_data.clear();
        @ INT* pBufferBegin = (@dt<模板类型1>*)@<数据>.GetPtr();
        @ INT* pBufferEnd   = pBufferBegin+ @<数据>.GetSize() / sizeof(@dt<模板类型1>);
        @ m_data.insert(m_data.end(),pBufferBegin,pBufferEnd);

    }

    #
}

