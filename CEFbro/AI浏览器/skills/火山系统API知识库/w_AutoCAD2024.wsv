    {
        返回 (对象型方法 ("CheckInterference", CAD三维实体, 操作对象, 创造干涉实体, 实体干涉))
    }

    方法 创建面域 <公开 类型 = CAD面域 注释 = "以给定三点创建三维实体对象的截面,将该截面返回为面域对象" 折叠 @输出名 = "SectionSolid">
    参数 点1 <类型 = CAD三维坐标 @输出名 = "Point1">
    参数 点2 <类型 = CAD三维坐标 @输出名 = "Point2">
    参数 点3 <类型 = CAD三维坐标 @输出名 = "point3">
    {
        返回 (对象型方法 ("SectionSolid", CAD面域, 点1, 点2, 点3))
    }

    方法 创建剖切面 <公开 类型 = CAD三维实体 注释 = "以给定的定义平面的三点创建三维实体的剖切面,返回结果三维实体对象阵列." 折叠 @输出名 = "SliceSolid">
