    }

    方法 取字符串 <公开 类型 = 文本型 注释 = "从用户获取字符串" 折叠 @输出名 = "GetString">
    参数 可包含空格 <类型 = 整数 注释 = "0:返回字符串不能包含空格.它由回车符或空格终止." 注释 = "1:返回字符串可以包含空格.它仅由回车符终止." 折叠2 @输出名 = "HasSpaces">
    参数 提示文本 <类型 = 文本型 注释 = "用于提示用户输入的文本." 折叠2 @默认值 = 空对象 @输出名 = "Prompt">
    {
        返回 (方法 ("GetString", 文本型, 可包含空格, 提示文本))
    }

    方法 取角度 <公开 类型 = 小数 注释 = "获取指定的角度.考虑 ANGBASE 系统变量的设置" 折叠 @输出名 = "GetAngle">
    参数 基点 <类型 = CAD三维坐标 折叠2 @默认值 = 空对象 @输出名 = "Point">
    参数 提示文本 <类型 = 文本型 折叠2 @默认值 = 空对象 @输出名 = "Prompt">
