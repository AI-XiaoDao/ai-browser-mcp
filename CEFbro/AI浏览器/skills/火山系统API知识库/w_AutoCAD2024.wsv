类 CAD布局集合 <公开 基础类 = CAD对象 注释 = "图形中所有布局的集合" 折叠 折叠2 @文档 = "category = \"文档集合.文档.集合类.布局集合\"" @输出名 = "IAcadLayouts">
{
    方法 成员数 <公开 属性读 类型 = 整数 注释 = "获取集合/词典/组或选择集中项目的数目" 折叠 @输出名 = "Count">
    {
        返回 (读无参数属性 ("Count", 整数))
    }

    方法 取成员 <公开 类型 = CAD布局 注释 = "图形中所有布局的集合" 折叠 @输出名 = "Item">
    参数 索引 <类型 = COM变体型 注释 = "  要查询的成员项在集合中的索引位置.索引必须是整数或字符串.如果是整数," 注释 = "则索引必须介于 0 和 N-1 之间,其中 N 是集合或选择集中的对象数." 折叠2
            @输出名 = "Index">
    {
        返回 (对象型方法 ("Item", CAD布局, 索引))
    }

    方法 添加 <公开 类型 = CAD布局 注释 = "创建成员对象并将其添加到适当的集合中" 折叠 @输出名 = "Add">
    参数 名称 <类型 = 文本型 @输出名 = "Name">
    {
        返回 (对象型方法 ("Add", CAD布局, 名称))
    }
}

