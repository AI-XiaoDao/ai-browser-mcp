类 CAD应用程序 <公开 基础类 = CAD应用程序基类 注释 = "AutoCAD 应用程序" 折叠 折叠2 @文档 = "category = \"接口类\"" @输出名 = "AcadApplication">
{
    变量 事件管理对象 <类型 = COM对象事件类>

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = COM对象事件类>
    参数 标记值 <类型 = 整数>
    参数 来源COM对象 <类型 = COM对象类>
    参数 事件方法ID <类型 = 整数>
    参数 事件参数 <类型 = COM变体型数组类>
    参数 事件返回值 <类型 = COM变体型>
    {
        如果 (事件方法ID == 1 && 事件参数.取成员数 () >= 2)
        {
            事件_系统变量被改变 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1))
        }
        否则 (事件方法ID == 2)
        {
            事件_新建图形 ()
        }
        否则 (事件方法ID == 3)
        {
            事件_程序将被激活 ()
        }
        否则 (事件方法ID == 4)
        {
            事件_程序将被取消激活 ()
        }
        否则 (事件方法ID == 5 && 事件参数.取成员数 () >= 2)
        {
            事件_窗口被移动或改变大小 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 6)
        {
            事件_将显示模式对话框 ()
        }
        否则 (事件方法ID == 7)
        {
            事件_销毁模式对话框 ()
        }
        否则 (事件方法ID == 8 && 事件参数.取成员数 () >= 1)
        {
            事件_即将被关闭 (事件参数.取成员 (0).取值 (逻辑型))
        }
        否则 (事件方法ID == 10 && 事件参数.取成员数 () >= 2)
        {
            事件_开始文件拖放 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 11 && 事件参数.取成员数 () >= 1)
        {
            事件_加载ARX应用程序 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 12 && 事件参数.取成员数 () >= 1)
        {
            事件_卸载ARX应用程序 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 13 && 事件参数.取成员数 () >= 1)
        {
            事件_开始打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 14 && 事件参数.取成员数 () >= 1)
        {
            事件_结束打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 19 && 事件参数.取成员数 () >= 1)
        {
            事件_请求保存 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 20 && 事件参数.取成员数 () >= 1)
        {
            事件_结束保存 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 21 && 事件参数.取成员数 () >= 1)
        {
            事件_开始打开 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 22 && 事件参数.取成员数 () >= 1)
        {
            事件_结束打开 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 17 && 事件参数.取成员数 () >= 1)
        {
            事件_开始执行命令 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 18 && 事件参数.取成员数 () >= 1)
        {
            事件_结束执行命令 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 15 && 事件参数.取成员数 () >= 1)
        {
            事件_开始执行LISP (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 16)
        {
            事件_结束执行LISP ()
        }
        否则 (事件方法ID == 24)
        {
            事件_取消执行LISP ()
        }
        否则 (事件方法ID == 25 && 事件参数.取成员数 () >= 1)
        {
            事件_窗口被改变 ((AC窗口状态枚举)事件参数.取成员 (0).取值 (整数))
        }
        返回 (0)
    }

    方法 事件_系统变量被改变 <公开 定义事件 类型 = 整数 注释 = "更改系统变量的值时触发" 折叠 @输出名 = "event_SysVarChanged">
    参数 系统变量名称 <类型 = 文本型 注释 = "其值已更改的系统变量的名称" @输出名 = "SysvarName">
    参数 系统变量新值 <类型 = COM变体型 注释 = "系统变量的新值" @输出名 = "newVal">

    方法 事件_新建图形 <公开 定义事件 类型 = 整数 注释 = "新图形创建前触发" @输出名 = "event_NewDrawing">

    方法 事件_程序将被激活 <公开 定义事件 类型 = 整数 注释 = "主应用程序窗口激活前触发" @输出名 = "event_AppActivate">

    方法 事件_程序将被取消激活 <公开 定义事件 类型 = 整数 注释 = "主应用程序窗口取消激活前触发" @输出名 = "event_AppDeactivate">

    方法 事件_窗口被移动或改变大小 <公开 定义事件 类型 = 整数 注释 = "在移动应用程序或绘图窗口移动或调整大小后触发" 折叠 @输出名 = "event_WindowMovedOrResized">
    参数 窗口框架句柄 <类型 = 整数 注释 = "应用程序或文档窗口框架" @输出名 = "HWNDFrame">
    参数 是否被操作 <类型 = 逻辑型 注释 = "真:窗口已移动;假:窗口大小已调整." @输出名 = "bMoved">

    方法 事件_将显示模式对话框 <公开 定义事件 类型 = 整数 注释 = "在显示模式对话框之前触发" @输出名 = "event_BeginModal">

    方法 事件_销毁模式对话框 <公开 定义事件 类型 = 整数 注释 = "在模式对话框关闭后触发" @输出名 = "event_EndModal">

    方法 事件_即将被关闭 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 会话结束或文档关闭之前触发" 折叠 @输出名 = "event_BeginQuit">
    参数 是否取消 <类型 = 逻辑型 注释 = "真:中止 AutoCAD 的关闭;假:允许继续关闭 AutoCAD." @输出名 = "Cancel">

    方法 事件_开始文件拖放 <公开 定义事件 类型 = 整数 注释 = "将文件放在主应用程序窗口上时触发" 折叠 @输出名 = "event_BeginFileDrop">
    参数 文件名称 <类型 = 文本型 @输出名 = "FileName">
    参数 是否取消 <类型 = 逻辑型 注释 = "真:中止图形的加载;假:允许继续加载图形." @输出名 = "Cancel">

    方法 事件_加载ARX应用程序 <公开 定义事件 类型 = 整数 注释 = "加载 ObjectARX 应用程序时触发" 折叠 @输出名 = "event_ARXLoaded">
    参数 应用程序名称 <类型 = 文本型 注释 = "已加载的 ObjectARX 应用程序的完整路径和文件名" @输出名 = "AppName">

    方法 事件_卸载ARX应用程序 <公开 定义事件 类型 = 整数 注释 = "在卸载 ObjectARX 应用程序时触发" 折叠 @输出名 = "event_ARXUnloaded">
    参数 应用程序名称 <类型 = 文本型 注释 = "已卸载的 ObjectARX 应用程序的完整路径和文件名" @输出名 = "AppName">

    方法 事件_开始打印 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 收到打印图形的请求后立即触发" 折叠 @输出名 = "event_BeginPlot">
    参数 图形名称 <类型 = 文本型 注释 = "要发送到打印机的图形的名称" @输出名 = "DrawingName">

    方法 事件_结束打印 <公开 定义事件 类型 = 整数 注释 = "将文档发送到打印机后触发" 折叠 @输出名 = "event_EndPlot">
    参数 图形名称 <类型 = 文本型 注释 = "已打印的图形的名称" @输出名 = "DrawingName">

    方法 事件_请求保存 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 收到保存图形的请求后立即触发" 折叠 @输出名 = "event_BeginSave">
    参数 文件名称 <类型 = 文本型 注释 = "要保存的文件的名称" @输出名 = "FileName">

    方法 事件_结束保存 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 保存完图形时触发" 折叠 @输出名 = "event_EndSave">
    参数 文件名称 <类型 = 文本型 注释 = "已保存文件的名称" @输出名 = "FileName">

    方法 事件_开始打开 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 收到打开现有图形的请求后立即触发" 折叠 @输出名 = "event_BeginOpen">
    参数 文件名称 <类型 = 文本型 注释 = "正在打开的文件的名称" @输出名 = "FileName">

    方法 事件_结束打开 <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 完成打开现有图形后立即触发" 折叠 @输出名 = "event_EndOpen">
    参数 文件名称 <类型 = 文本型 注释 = "正在打开的文件的名称" @输出名 = "FileName">

    方法 事件_开始执行命令 <公开 定义事件 类型 = 整数 注释 = "在发出命令后立即触发,但在命令完成之前触发." 折叠 @输出名 = "event_BeginCommand">
    参数 命令名称 <类型 = 文本型 注释 = "正在发出的命令的名称" @输出名 = "CommandName">

    方法 事件_结束执行命令 <公开 定义事件 类型 = 整数 注释 = "命令完成后立即触发" 折叠 @输出名 = "event_EndCommand">
    参数 命令名称 <类型 = 文本型 注释 = "发出的命令的名称" @输出名 = "CommandName">

    方法 事件_开始执行LISP <公开 定义事件 类型 = 整数 注释 = "在 AutoCAD 收到计算 AutoLISP 表达式的请求后立即触发" 折叠 @输出名 = "event_BeginLisp">
    参数 第一行 <类型 = 文本型 注释 = "即将由 AutoLISP 解释器执行的 AutoLISP 表达式的名称" @输出名 = "FirstLine">

    方法 事件_结束执行LISP <公开 定义事件 类型 = 整数 注释 = "在完成 AutoLISP 表达式计算时触发" @输出名 = "event_EndLisp">

    方法 事件_取消执行LISP <公开 定义事件 类型 = 整数 注释 = "取消 AutoLISP 表达式的计算时触发" @输出名 = "event_LispCancelled">

    方法 事件_窗口被改变 <公开 定义事件 类型 = 整数 注释 = "当应用程序或文档窗口发生更改时触发" 折叠 @输出名 = "event_WindowChanged">
    参数 窗口状态 <类型 = AC窗口状态枚举 @输出名 = "WindowState">

    方法 初始化 <公开 类型 = 逻辑型 注释 = "调用本方法以初始化本类对象的内容并挂接事件(如存在),成功返回真,失败返回假." 折叠>
    参数 版本类型 <类型 = 文本型 @默认值 = AC应用程序类型.ACAD>
    {
        获取 (版本类型)
        如果 (是否为空 ())
        {
            返回 (创建 (版本类型, ) && 事件管理对象.挂接 (本对象, ))
        }
        否则
        {
            返回 (事件管理对象.挂接 (本对象, ))
        }
    }

    方法 注册事件 <公开 类型 = 逻辑型 折叠>
    {
        返回 (事件管理对象.挂接 (本对象, ))
    }
}

类 CAD文档基类 <基础类 = CAD数据库基类 注释 = "AutoCAD 图形" 折叠 折叠2 @文档 = "category = \"基类\"" @输出名 = "IAcadDocument" @禁止创建对象 = 真>
