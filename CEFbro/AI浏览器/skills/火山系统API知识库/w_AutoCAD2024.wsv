类 CAD功能类 <公开 折叠 折叠2 @文档 = "category = \"辅助类.功能类\"" @输出名 = "Accessibility" @全局类 = 真 @禁止创建对象 = 真>
{
    方法 整数到变体型 <公开 静态 类型 = COM变体型 注释 = "整数型数据赋值给变体型,比如:\"取成员 (序号)\"时,写为\"取成员 (整数到变体型 (序号))\"." 折叠>
    参数 所欲转换的数据 <类型 = 整数>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.赋值 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 文本到变体型 <公开 静态 类型 = COM变体型 注释 = "文本型数据赋值给变体型,比如:\"取成员 (\"名称\")\"时,写为\"取成员 (文本型到变体型 (文本))\"." 折叠>
    参数 所欲转换的数据 <类型 = 文本型>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.赋值 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 小数到变体型 <公开 静态 类型 = COM变体型 注释 = "数值型数据赋值给变体型." 折叠>
    参数 所欲转换的数据 <类型 = 小数>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.赋值 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 逻辑型到变体型 <公开 静态 类型 = COM变体型 注释 = "逻辑型数据赋值给变体型." 折叠>
    参数 所欲转换的数据 <类型 = 逻辑型>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.赋值 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 字节集到变体型 <公开 静态 类型 = COM变体型 注释 = "字节集数据赋值给变体型,用于将字节集数据 (图片) 赋值给字段时,比如:..设置值（字节集到变体型 (图片数据)）." 折叠>
    参数 所欲转换的数据 <类型 = 字节集类>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.置字节集 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 日期时间到变体型 <公开 静态 类型 = COM变体型 注释 = "日期时间型数据赋值给变体型." 折叠>
    参数 所欲转换的数据 <类型 = 小数>
    {
        变量 变体型1 <类型 = COM变体型>
        变体型1.赋值 (所欲转换的数据)
        返回 (变体型1)
    }

    方法 变体型到二维坐标数组 <公开 静态 类型 = CAD二维坐标数组 折叠>
    参数 所欲转换的数据 <类型 = COM变体型>
    {
        变量 计次 <类型 = 整数 值 = 0>
        变量 二维坐标数组 <类型 = CAD二维坐标数组>
        变量 二维坐标 <类型 = CAD二维坐标>
        变量 小数数组 <类型 = "小数 [2]">
        如果真 (所欲转换的数据.取数组成员数 () % 2 != 0)
        {
            返回 (二维坐标数组)
        }

        二维坐标.创建数组 (COM数组成员类型.小数值, 2)
        计次循环 (所欲转换的数据.取数组成员数 () / 2)
        {
            所欲转换的数据.取数组 (小数数组, 计次 * 2, 2)
            二维坐标.X = 小数数组 [0]
            二维坐标.Y = 小数数组 [1]
            二维坐标数组.加入成员 (二维坐标)
            计次 = 计次 + 1
        }
        返回 (二维坐标数组)
    }

    方法 变体型到三维坐标数组 <公开 静态 类型 = CAD三维坐标数组 折叠>
    参数 所欲转换的数据 <类型 = COM变体型>
    {
        变量 计次 <类型 = 整数 值 = 0>
        变量 三维坐标数组 <类型 = CAD三维坐标数组>
        变量 三维坐标 <类型 = CAD三维坐标>
        变量 小数数组 <类型 = "小数 [3]">
        如果真 (所欲转换的数据.取数组成员数 () % 3 != 0)
        {
            返回 (三维坐标数组)
        }

        三维坐标.创建数组 (COM数组成员类型.小数值, 3)
        计次循环 (所欲转换的数据.取数组成员数 () / 3)
        {
            所欲转换的数据.取数组 (小数数组, 计次 * 3, 3)
            三维坐标.X = 小数数组 [0]
            三维坐标.Y = 小数数组 [1]
            三维坐标.Z = 小数数组 [2]
            三维坐标数组.加入成员 (三维坐标)
            计次 = 计次 + 1
        }
        返回 (三维坐标数组)
    }
}
