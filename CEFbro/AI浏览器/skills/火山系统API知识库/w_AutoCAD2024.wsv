类 CAD排序实体表基类 <基础类 = CAD对象 注释 = "AutoCAD 排序对象表基类接口" 注释 = "包含和操作绘制顺序信息" 折叠 折叠2 @文档 = "category = \"基类\""
        @输出名 = "IAcadSortentsTable" @禁止创建对象 = 真>
{
    方法 移至底部 <公开 注释 = "将对象移到绘图次序的最下面." 折叠 @输出名 = "MoveToBottom">
    参数 操作对象 <类型 = COM变体型 注释 = "要移动的对象" @输出名 = "Objects">
    {
        无返回值方法 ("MoveToBottom", 操作对象)
    }

    方法 移至顶部 <公开 注释 = "将对象移到绘图次序的最上面." 折叠 @输出名 = "MoveToTop">
    参数 操作对象 <类型 = COM变体型 注释 = "要移动的对象" @输出名 = "Objects">
    {
        无返回值方法 ("MoveToTop", 操作对象)
    }

    方法 向下移动 <公开 注释 = "将对象移到绘图次序中目标对象的下面." 折叠 @输出名 = "MoveBelow">
    参数 操作对象 <类型 = COM变体型 注释 = "要移动的对象" @输出名 = "Objects">
    参数 目标 <类型 = CAD图元 注释 = "绘制顺序的目标" @输出名 = "Target">
    {
        无返回值方法 ("MoveBelow", 操作对象, 目标)
    }

    方法 向上移动 <公开 注释 = "将对象移到绘图次序中目标对象的上面." 折叠 @输出名 = "MoveAbove">
    参数 操作对象 <类型 = COM变体型 注释 = "要移动的对象" @输出名 = "Objects">
    参数 目标 <类型 = CAD图元 注释 = "绘制顺序的目标" @输出名 = "Target">
    {
        无返回值方法 ("MoveAbove", 操作对象, 目标)
    }

    方法 交换排序 <公开 注释 = "交换两个对象的绘图次序位置." 折叠 @输出名 = "SwapOrder">
    参数 操作对象1 <类型 = CAD图元 注释 = "第一个对象" @输出名 = "Object1">
    参数 操作对象2 <类型 = CAD图元 注释 = "第二个对象" @输出名 = "Object2">
    {
        无返回值方法 ("SwapOrder", 操作对象1, 操作对象2)
    }

    方法 块 <公开 类型 = CAD块 注释 = "返回此排序实体表格所属的块." 折叠 @输出名 = "Block">
    {
        返回 (无参数对象型方法 ("Block", CAD块))
    }

    方法 取全部图形排序 <公开 注释 = "返回块中的所有对象,按绘图次序排序,最下面的排在第一位." 折叠 @输出名 = "GetFullDrawOrder">
    参数 操作对象 <类型 = COM变体型 注释 = "块中的对象." @输出名 = "Objects">
    参数 控制实体排序 <类型 = 逻辑型 注释 = "  当控制实体排序的取值为假时,表示 AutoCAD 不会按照实体对象在绘图中的顺序进行排序," 注释 = "而是按照用户选择实体的顺序进行排序."
            注释 = "  当控制实体排序的取值为真时,表示 AutoCAD 会按照实体对象在绘图中的顺序进行排序," 注释 = "即会优先选择靠近用户选择点的实体对象." 折叠2 @输出名 = "honorSortentsSysvar">
    {
        无返回值方法 ("GetFullDrawOrder", 操作对象, 控制实体排序)
    }

    方法 取绘图次序排序 <公开 注释 = "返回指定的对象,按绘图次序排序,最下面的排在第一位." 折叠 @输出名 = "GetRelativeDrawOrder">
    参数 操作对象 <类型 = COM变体型 注释 = "按绘制顺序排序的对象数组." @输出名 = "Objects">
    参数 控制实体排序 <类型 = 逻辑型 注释 = " 当控制实体排序的取值为假时,表示 AutoCAD 不会按照实体对象在绘图中的顺序进行排序," 注释 = "而是按照用户选择实体的顺序进行排序."
            注释 = "  当控制实体排序的取值为真时,表示 AutoCAD 会按照实体对象在绘图中的顺序进行排序," 注释 = "即会优先选择靠近用户选择点的实体对象." 折叠2 @输出名 = "honorSortentsSysvar">
    {
        无返回值方法 ("GetRelativeDrawOrder", 操作对象, 控制实体排序)
    }

    方法 置绘图次序排序 <公开 注释 = "将对象的相对绘图次序设置为指定的次序,最下面的排在第一位." 折叠 @输出名 = "SetRelativeDrawOrder">
    参数 操作对象 <类型 = COM变体型 注释 = "要为其设置绘制顺序的对象." @输出名 = "Objects">
    {
        无返回值方法 ("SetRelativeDrawOrder", 操作对象)
    }
}

