    参数 点2 <类型 = CAD三维坐标 @输出名 = "Point2">
    参数 点3 <类型 = CAD三维坐标 @输出名 = "point3">
    参数 是否反向 <类型 = 逻辑型 @输出名 = "Negative">
    {
        返回 (对象型方法 ("SliceSolid", CAD三维实体, 点1, 点2, 点3, 是否反向))
    }
}

