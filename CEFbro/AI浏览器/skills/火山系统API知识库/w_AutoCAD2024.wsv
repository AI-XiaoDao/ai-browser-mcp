类 CAD文档集合 <公开 基础类 = COM对象类 注释 = "当前任务中打开的所有 AutoCAD 图形的集合" 折叠 折叠2 @文档 = "category = \"文档集合.文档.集合类.文档集合\""
        @输出名 = "IAcadDocuments">
{
    方法 成员数 <公开 属性读 类型 = 整数 注释 = "获取集合/词典/组或选择集中项目的数目" 折叠 @输出名 = "Count">
    {
        返回 (读无参数属性 ("Count", 整数))
    }

    方法 应用程序 <公开 属性读 类型 = CAD应用程序 注释 = "获取应用程序对象" 折叠 @输出名 = "Application">
    {
        返回 (读无参数对象型属性 ("Application", CAD应用程序))
    }

    方法 取成员 <公开 类型 = CAD文档 注释 = "当前任务中打开的所有 AutoCAD 图形的集合" 折叠 @输出名 = "Item">
    参数 索引 <类型 = COM变体型 注释 = "  要查询的成员项在集合中的索引位置.索引必须是整数或字符串.如果是整数," 注释 = "则索引必须介于 0 和 N-1 之间,其中 N 是集合或选择集中的对象数." 折叠2
            @输出名 = "Index">
    {
        返回 (对象型方法 ("Item", CAD文档, 索引))
    }

    方法 添加 <公开 类型 = CAD文档 注释 = "创建成员对象并将其添加到适当的集合中" 折叠 @输出名 = "Add">
    参数 样板名称 <类型 = 文本型 折叠2 @默认值 = 空对象 @输出名 = "TemplateName">
    {
        返回 (对象型方法 ("Add", CAD文档, 样板名称))
    }

    方法 打开 <公开 类型 = CAD文档 注释 = "打开现有的图形文件 (DWG) 并使其成为活动文档" 折叠 @输出名 = "Open">
    参数 名称 <类型 = 文本型 注释 = "要打开的图形文件的完整路径和文件名或有效的 URL 地址.如果图形位于支持文件目录属性指定的文件夹中,则不需要路径,并且文件名就足够了." @输出名 = "Name">
    参数 只读 <类型 = 逻辑型 注释 = "真:以只读图形打开图形.假:以读写图形形式打开图形." 折叠2 @默认值 = 假 @输出名 = "ReadOnly">
    参数 密码 <类型 = 文本型 注释 = "打开加密图形的密码" 折叠2 @默认值 = 空对象 @输出名 = "Password">
    {
        返回 (对象型方法 ("Open", CAD文档, 名称, 只读, 密码))
    }

    方法 关闭 <公开 注释 = "关闭指定的图形或所有打开的图形" 折叠 @输出名 = "Close">
    {
        无参数及返回值方法 ("Close")
    }
}

类 CAD文档 <公开 基础类 = CAD文档基类 注释 = "AutoCAD 文档" 折叠 折叠2 @文档 = "category = \"文档集合.文档.集合类.文档集合.文档\"" @输出名 = "AcadDocument">
{
    变量 事件管理对象 <类型 = COM对象事件类>

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = COM对象事件类>
    参数 标记值 <类型 = 整数>
    参数 来源COM对象 <类型 = COM对象类>
    参数 事件方法ID <类型 = 整数>
    参数 事件参数 <类型 = COM变体型数组类>
    参数 事件返回值 <类型 = COM变体型>
    {
        如果 (事件方法ID == 1 && 事件参数.取成员数 () >= 1)
        {
            事件_请求保存 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 2 && 事件参数.取成员数 () >= 1)
        {
            事件_保存完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 6 && 事件参数.取成员数 () >= 1)
        {
            事件_命令被执行 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 7 && 事件参数.取成员数 () >= 1)
        {
            事件_命令完成 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 8 && 事件参数.取成员数 () >= 1)
        {
            事件_请求LISP (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 9)
        {
            事件_LIST计算完毕 ()
        }
        否则 (事件方法ID == 10)
        {
            事件_LISP被取消 ()
        }
        否则 (事件方法ID == 11)
        {
            事件_选择被改变 ()
        }
        否则 (事件方法ID == 12)
        {
            事件_被激活 ()
        }
        否则 (事件方法ID == 13)
        {
            事件_取消激活 ()
        }
        否则 (事件方法ID == 14 && 事件参数.取成员数 () >= 1)
        {
            事件_开始右击 ((CAD三维坐标)事件参数.取成员 (0))
        }
        否则 (事件方法ID == 15 && 事件参数.取成员数 () >= 1)
        {
            事件_开始快捷菜单默认 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单))
        }
        否则 (事件方法ID == 16 && 事件参数.取成员数 () >= 2)
        {
            事件_开始编辑快捷菜单 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单), 事件参数.取成员 (1).取COM对象2 (CAD选择集))
        }
        否则 (事件方法ID == 17 && 事件参数.取成员数 () >= 2)
        {
            事件_开始快捷菜单命令 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单), 事件参数.取成员 (1).取值 (文本型))
        }
        否则 (事件方法ID == 18 && 事件参数.取成员数 () >= 1)
        {
            事件_开始快捷菜单夹点 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单))
        }
        否则 (事件方法ID == 19 && 事件参数.取成员数 () >= 1)
        {
            事件_开始快捷菜单对象捕捉 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单))
        }
        否则 (事件方法ID == 30 && 事件参数.取成员数 () >= 1)
        {
            事件_结束快捷菜单 (事件参数.取成员 (0).取COM对象2 (CAD弹出菜单))
        }
        否则 (事件方法ID == 20 && 事件参数.取成员数 () >= 1)
        {
            事件_开始双击 ((CAD三维坐标)事件参数.取成员 (0))
        }
        否则 (事件方法ID == 21 && 事件参数.取成员数 () >= 1)
        {
            事件_对象已添加 (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        否则 (事件方法ID == 22 && 事件参数.取成员数 () >= 1)
        {
            事件_对象已删除 (事件参数.取成员 (0).取值 (长整数))
        }
        否则 (事件方法ID == 23 && 事件参数.取成员数 () >= 1)
        {
            事件_对象已修改 (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        否则 (事件方法ID == 24 && 事件参数.取成员数 () >= 1)
        {
            事件_开始打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 25 && 事件参数.取成员数 () >= 1)
        {
            事件_结束打印 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 29 && 事件参数.取成员数 () >= 2)
        {
            事件_窗口移动或调整大小 (事件参数.取成员 (0).取值 (长整数), 事件参数.取成员 (1).取值 (逻辑型))
        }
        否则 (事件方法ID == 31 && 事件参数.取成员数 () >= 1)
        {
            事件_布局被切换 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 32 && 事件参数.取成员数 () >= 1)
        {
            事件_窗口已修改 ((AC窗口状态枚举)事件参数.取成员 (0).取值 (整数))
        }
        否则 (事件方法ID == 33)
        {
            事件_开始关闭 ()
        }
        否则 (事件方法ID == 34 && 事件参数.取成员数 () >= 1)
        {
            事件_文档开始关闭 (事件参数.取成员 (0).取值 (逻辑型))
        }
        返回 (0)
    }

    方法 事件_请求保存 <公开 定义事件 类型 = 整数 注释 = "AutoCAD 收到保存图形的请求后触发" 折叠 @输出名 = "event_BeginSave">
