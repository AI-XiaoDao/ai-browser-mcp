类 CAD实用工具 <公开 基础类 = COM对象类 注释 = "一系列用作工具的方法" 折叠 折叠2 @文档 = "category = \"文档集合.文档.操作类\"" @输出名 = "IAcadUtility">
{
    方法 角度到小数 <公开 类型 = 小数 注释 = "将角度从字符串转换为双精度实数值" 折叠 @输出名 = "AngleToReal">
    参数 角度 <类型 = 文本型 @输出名 = "Angle">
    参数 角度单位 <类型 = AC角度单位枚举 @输出名 = "Unit">
    {
        返回 (方法 ("AngleToReal", 小数, 角度, (整数)角度单位))
    }

    方法 角度到字符串 <公开 类型 = 文本型 注释 = "将角度从双精度实数值转换为字符串" 折叠 @输出名 = "AngleToString">
    参数 角度 <类型 = 小数 @输出名 = "Angle">
    参数 角度单位 <类型 = AC角度单位枚举 @输出名 = "Unit">
    参数 精度 <类型 = 整数 @输出名 = "precision">
    {
        返回 (方法 ("AngleToString", 文本型, 角度, (整数)角度单位, 精度))
    }

    方法 距离到小数 <公开 类型 = 小数 注释 = "将距离从字符串转换为双精度实数值" 折叠 @输出名 = "DistanceToReal">
    参数 距离 <类型 = 文本型 @输出名 = "Distance">
    参数 单位 <类型 = AC单位枚举 @输出名 = "Unit">
    {
        返回 (方法 ("DistanceToReal", 小数, 距离, (整数)单位))
    }

    方法 小数到字符串 <公开 类型 = 文本型 注释 = "将双精度实数值转换为字符串" 折叠 @输出名 = "RealToString">
    参数 值 <类型 = 小数 @输出名 = "Value">
    参数 单位 <类型 = AC单位枚举 @输出名 = "Unit">
    参数 精度 <类型 = 整数 @输出名 = "precision">
    {
        返回 (方法 ("RealToString", 文本型, 值, (整数)单位, 精度))
    }

    方法 转换坐标系 <公开 类型 = COM变体型 注释 = "将点从一个坐标系转换到另一个坐标系" 折叠 @输出名 = "TranslateCoordinates">
    参数 基点 <类型 = CAD三维坐标 注释 = "指定要平移的原始坐标的 3D WCS 坐标.此参数可以被视为点或位移向量,具体取决于位移的值." @输出名 = "Point">
    参数 源坐标系 <类型 = AC坐标系枚举 注释 = "点的起点坐标系." @输出名 = "FromCoordSystem">
    参数 目标坐标系 <类型 = AC坐标系枚举 注释 = "点将转换为的坐标系." @输出名 = "ToCoordSystem">
    参数 位移矢量标记 <类型 = 逻辑型 注释 = "位移矢量标志.真:将点视为位移向量;假:点被视为点." @输出名 = "Displacement">
    参数 法线 <类型 = COM变体型 注释 = "OCS 的正常值." 折叠2 @默认值 = 空对象 @输出名 = "OCSNormal">
    {
        返回 (方法 ("TranslateCoordinates", COM变体型, 基点, (整数)源坐标系, (整数)目标坐标系, 位移矢量标记, 法线))
    }

    方法 初始化关键字 <公开 注释 = "初始化关键字方法" 折叠 @输出名 = "InitializeUserInput">
    参数 输入条件 <类型 = 整数 注释 = "  若要一次设置多个条件,请以任意组合方式将值相加.如果不包括此值或设置为 0,则任何控制条件" 注释 = "均不适用."
            注释 = "  1: 不允许空输入.这样可以防止用户仅通过输入返回或空格来响应请求." 注释 = "  2: 不允许输入零 (0).这将防止用户通过输入 0 来响应请求."
            注释 = "  4: 不允许负值.这可以防止用户通过输入负值来响应请求." 注释 = "  8: 不检查绘图限制,即使 LIMCHECK 系统变量处于打开状态.这使用户能够输入当前绘图限制之外的"
            注释 = "点.此条件适用于下一个用户输入函数,即使当前设置了 AutoCAD LIMCHECK 系统变量也是如此." 注释 = " 16: 当前未使用."
            注释 = " 32: 绘制橡皮筋线或方框时使用虚线.这会导致 AutoCAD 显示的橡皮筋线或框采用虚线而不是实线,因" 注释 = "为这些方法允许用户通过在图形屏幕上选择位置来指定点.(某些显示驱动程序使用独特的颜色而不是虚线."
            注释 = "如果 AutoCAD POPUPS 系统变量为 0,AutoCAD 将忽略此位." 注释 = " 64: 忽略 3D 点的 Z 坐标（仅限取距离方法）.此选项将忽略取距离方法返回的 3D 点的 Z 坐标,因此"
            注释 = "应用程序可以确保此函数返回 2D 距离." 注释 = "128: 允许任意输入 - 无论用户键入什么." 折叠2 @输出名 = "Bits">
    参数 关键字序列 <类型 = COM变体型 注释 = "以下用户输入法将识别的关键字." 折叠2 @默认值 = 空对象 @输出名 = "KeyWordList">
    {
        无返回值方法 ("InitializeUserInput", 输入条件, 关键字序列)
    }

    方法 取整数 <公开 类型 = 整数 注释 = "从用户获取整数值" 折叠 @输出名 = "GetInteger">
    参数 提示文本 <类型 = 文本型 折叠2 @默认值 = 空对象 @输出名 = "Prompt">
    {
        返回 (方法 ("GetInteger", 整数, 提示文本))
    }

    方法 取小数 <公开 类型 = 小数 注释 = "从用户获取双精度实数值" 折叠 @输出名 = "GetReal">
    参数 提示文本 <类型 = 文本型 折叠2 @默认值 = 空对象 @输出名 = "Prompt">
