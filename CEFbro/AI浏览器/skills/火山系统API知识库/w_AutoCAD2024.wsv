    }

    方法 拾取点 <公开 类型 = CAD三维坐标 注释 = "获取 AutoCAD 中选定的点" 返回值注释 = "AutoCAD 用户所选点的三维 WCS 坐标." 折叠 @输出名 = "GetPoint">
    参数 基点 <类型 = CAD三维坐标 注释 = "指定相对基点的 3D WCS 坐标." 折叠2 @默认值 = 空对象 @输出名 = "Point">
    参数 提示文本 <类型 = 文本型 注释 = "用于提示用户输入的文本." 折叠2 @默认值 = 空对象 @输出名 = "Prompt">
