<火山程序 类型 = "通常" 版本 = 1 />

包 火山.COM封装对象.AutoCAD <注释 = "2025.04.20：优化类排序顺序方便浏览" @文档 = "category = \"AutoCAD\"" @输出名 = "Volcano_AutoCAD">

