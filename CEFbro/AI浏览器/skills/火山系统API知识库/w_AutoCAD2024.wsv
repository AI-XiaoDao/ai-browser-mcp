    参数 旋转轴起点 <类型 = CAD三维坐标 注释 = "指定旋转轴起点的 3D WCS 坐标." @输出名 = "AxisPoint">
    参数 旋转轴方向 <类型 = COM变体型 注释 = "指定旋转轴方向的 3D 矢量." @输出名 = "AxisDir">
    参数 角度 <类型 = 小数 注释 = "弧度的旋转角度.输入 6.28 进行一整圈旋转." @输出名 = "Angle">
    {
        返回 (对象型方法 ("AddRevolvedSolid", CAD三维实体, 面域, 旋转轴起点, 旋转轴方向, 角度))
    }

