    方法 附着外部参照 <公开 类型 = CAD外部参照 注释 = "将外部参照附着到图形" 折叠 @输出名 = "AttachExternalReference">
    参数 路径名称 <类型 = 文本型 注释 = "要参照的图形的完整路径和文件名." @输出名 = "PathName">
    参数 名称 <类型 = 文本型 注释 = "要创建的外部参照的名称." @输出名 = "Name">
    参数 插入点 <类型 = CAD三维坐标 注释 = "3D WCS 坐标指定将外部参照实例插入到图形中的点.当前图形中的插入点与参照文件中 AutoCAD BASE 系统变量定义的点对齐." @输出名 = "InsertionPoint">
    参数 X向比例 <类型 = 小数 注释 = "外部参照实例的 X 比例因子." @输出名 = "Xscale">
    参数 Y向比例 <类型 = 小数 注释 = "外部参照实例的 Y 比例因子" @输出名 = "Yscale">
    参数 Z向比例 <类型 = 小数 注释 = "外部参照实例的 Z 比例因子" @输出名 = "Zscale">
    参数 旋转角度 <类型 = 小数 注释 = "外部参照实例的旋转角度.此角度以弧度指定." @输出名 = "Rotation">
    参数 覆盖 <类型 = 逻辑型 注释 = "真:外部参照实例是叠加.假:外部参照实例是附件." @输出名 = "bOverlay">
    参数 密码 <类型 = 文本型 折叠2 @默认值 = 空对象 @输出名 = "Password">
    {
        返回 (对象型方法 ("AttachExternalReference", CAD外部参照, 路径名称, 名称, 插入点, X向比例, Y向比例, Z向比例, 旋转角度, 覆盖, 密码))
    }

