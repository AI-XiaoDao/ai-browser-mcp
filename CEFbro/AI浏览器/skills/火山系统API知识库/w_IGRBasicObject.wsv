        返回 (读无参数对象型属性 ("AsLine", 线段框))
    }

    方法 获取为条码框 <公开 属性读 类型 = 条码框 注释 = "AsBarcode，将本部件框转换为条码框的接口引用。只有当本部件框确实是条码框(Barcode)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsBarcode", 条码框))
    }

    方法 获取为自由表格 <公开 属性读 类型 = 自由表格 注释 = "AsFreeGrid，将本部件框转换为自由表格的接口引用。只有当本部件框确实是自由表格(FreeGrid)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsFreeGrid", 自由表格))
    }

    方法 获取边框 <公开 属性读 类型 = 边框 注释 = "Border，部件框的边框定义对象。">
    {
        返回 (读无参数对象型属性 ("Border", 边框))
    }

    方法 获取字体 <公开 属性读 类型 = 报表字体 注释 = "Font，输出文字时使用的字体。1.当本属性值为空时，代表本部件使用父容器的字体。将本属性设置为NULL，使其使用缺省字体。">
    {
        返回 (读无参数对象型属性 ("Font", 报表字体))
    }

    方法 部件框类型 <公开 属性读 类型 = 部件框类型枚举 注释 = "ControlType，获取本部件框的具体类型。"
            注释 = "1、静态文字框； 2、图形框； 3、系统变量框； 4、字段框； 5、统计框； 6、RTF文字框； 7、图像框； 8、综合文字框； 9、子报表框； 10、线段框； 11、图表框； 12、条码框； 13、自由表格框">
    {
        返回 (读无参数属性 ("ControlType", 部件框类型枚举))
    }

    方法 光标 <公开 属性读 类型 = 光标类型枚举 注释 = "Cursor，指定在查询显示报表时，当鼠标光标位于该部件框上时要显示的鼠标光标类型。"
            注释 = "0、默认光标； 1、箭头光标； 2、放大光标； 3、手指光标； 4、确定光标； 5、否定光标">
    {
        返回 (读无参数属性 ("Cursor", 光标类型枚举))
    }

    方法 光标 <公开 属性写 注释 = "Cursor，指定在查询显示报表时，当鼠标光标位于该部件框上时要显示的鼠标光标类型。" 注释 = "0、默认光标； 1、箭头光标； 2、放大光标； 3、手指光标； 4、确定光标； 5、否定光标">
    参数 光标类型枚举值 <类型 = 光标类型枚举>
    {
        写属性 ("Cursor", (整数)光标类型枚举值)
    }

    方法 背景色 <公开 属性读 类型 = 整数 注释 = "BackColor，部件框的背景色。如果 BackStyle 属性为 grbsTranparent 时，部件框生成时不填充背景，本属性此时被忽略掉。">
    {
        返回 (读无参数属性 ("BackColor", 整数))
    }

    方法 背景色 <公开 属性写 注释 = "BackColor，部件框的背景色。如果 BackStyle 属性为 grbsTranparent 时，部件框生成时不填充背景，本属性此时被忽略掉。">
    参数 颜色值 <类型 = 整数>
    {
        写属性 ("BackColor", 颜色值)
    }

    方法 背景模式 <公开 属性读 类型 = 背景模式枚举 注释 = "BackStyle，部件框显示时背景的填充方式。">
    {
        返回 (读无参数属性 ("BackStyle", 背景模式枚举))
    }

    方法 背景模式 <公开 属性写 注释 = "BackStyle，部件框显示时背景的填充方式。">
    参数 背景模式枚举值 <类型 = 背景模式枚举>
    {
        写属性 ("BackStyle", (整数)背景模式枚举值)
    }

    方法 居中方式 <公开 属性读 类型 = 居中方式枚举 注释 = "Center，指定水平与垂直方向的居中对齐方式。" 注释 = "指定部件框在容器中水平与垂直方向上的居中对齐方式。"
            注释 = "指定部件框在水平与垂直方向上居中位于父容器的方式。通过部件框的 Center 属性指定部件框的居中方式(GRCenterStyle)。"
            注释 = "默认值是在两个方向都不居中(grcsNone)。如果在某个方向上居中，当父容器的大小发生改变时，部件框自动调整位置使自己一直居于父容器的中间。"
            注释 = "例如，如果将该属性设置为 grcsHorizontal，部件框始终在水平方向上居于父容器的正中间。" 返回值注释 = "0、无； 1、水平； 2、垂直； 3、水平垂直">
    {
        返回 (读无参数属性 ("Center", 居中方式枚举))
    }

    方法 居中方式 <公开 属性写 注释 = "Center，指定水平与垂直方向的居中对齐方式。" 注释 = "指定部件框在容器中水平与垂直方向上的居中对齐方式。"
            注释 = "指定部件框在水平与垂直方向上居中位于父容器的方式。通过部件框的 Center 属性指定部件框的居中方式(GRCenterStyle)。"
            注释 = "默认值是在两个方向都不居中(grcsNone)。如果在某个方向上居中，当父容器的大小发生改变时，部件框自动调整位置使自己一直居于父容器的中间。"
            注释 = "例如，如果将该属性设置为 grcsHorizontal，部件框始终在水平方向上居于父容器的正中间。">
    参数 居中方式枚举值 <类型 = 居中方式枚举 注释 = "0、无； 1、水平； 2、垂直； 3、水平垂直">
    {
        写属性 ("Center", (整数)居中方式枚举值)
    }

    方法 自定义绘制 <公开 属性读 类型 = 逻辑型 注释 = "CustomDraw，指定部件框是否为自绘部件框。"
            注释 = "指定部件框是否为自绘部件框，自绘部件框不会自动输出显示内容，而是会触发 ControlCustomDraw 报表事件；"
            注释 = "如本部件框果存在自绘脚本(CustomDrawScript)，则会执行该脚本。由报表开发者在事件中或事件脚本中实现部件框显示输出。">
    {
        返回 (读无参数属性 ("CustomDraw", 逻辑型))
    }

    方法 自定义绘制 <公开 属性写 注释 = "CustomDraw，指定部件框是否为自绘部件框。" 注释 = "指定部件框是否为自绘部件框，自绘部件框不会自动输出显示内容，而是会触发 ControlCustomDraw 报表事件；"
            注释 = "如本部件框果存在自绘脚本(CustomDrawScript)，则会执行该脚本。由报表开发者在事件中或事件脚本中实现部件框显示输出。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("CustomDraw", 逻辑值)
    }

    方法 自定义绘制脚本 <公开 属性读 类型 = 文本型 注释 = "CustomDrawScript，指定部件框的自绘脚本代码，只有当部件框为自绘部件框时，此属性定义的脚本代码才会执行到。">
    {
        返回 (读无参数属性 ("CustomDrawScript", 文本型))
    }

    方法 自定义绘制脚本 <公开 属性写 注释 = "CustomDrawScript，指定部件框的自绘脚本代码，只有当部件框为自绘部件框时，此属性定义的脚本代码才会执行到。">
    参数 脚本文本 <类型 = 文本型>
