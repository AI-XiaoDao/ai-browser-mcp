    方法 文字自动绕行 <公开 属性写 注释 = "WordWrap，是否自动换行显示文本。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("WordWrap", 逻辑值)
    }

    方法 字间距 <公开 属性读 类型 = 小数 注释 = "CharacterSpacing，输出文字的字间距，以屏幕像素点为计量单位。" 注释 = "当文字按任意角度显示时，字间距与行间距设置不会起作用。"
            注释 = "在显示长篇文字(文字内容超过一页，如合同与公文等)时，为了防止文字换页时出现从中间截断的情况，应该将“行间距”或“字间距”属性的值设为大于0，如“0.5”或“1.0”。">
    {
        返回 (读无参数属性 ("CharacterSpacing", 小数))
    }

    方法 字间距 <公开 属性写 注释 = "CharacterSpacing，输出文字的字间距，以屏幕像素点为计量单位。" 注释 = "当文字按任意角度显示时，字间距与行间距设置不会起作用。"
            注释 = "在显示长篇文字(文字内容超过一页，如合同与公文等)时，为了防止文字换页时出现从中间截断的情况，应该将“行间距”或“字间距”属性的值设为大于0，如“0.5”或“1.0”。">
    参数 数值 <类型 = 小数>
