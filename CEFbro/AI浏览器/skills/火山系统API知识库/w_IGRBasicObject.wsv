类 报表字体 <公开 基础类 = COM对象类 注释 = "Font，表示报表对象显示文字所使用字体的对象。"
        注释 = "表示报表对象显示文字所使用字体的对象。字体对象提供属性用来获取与设置字体定义，需要显示文本或需要为子对象提供缺省字体的报表对象拥有字体对象。"
        注释 = "当报表对象不使用其缺省字体时，它的字体对象拥有一个OLE字体对象，其字体定义由OLE字体对象表示，可以通过 OleFont 属性取得OLE字体对象的接口引用。"
        注释 = "当报表对象使用缺省字体时，其字体对象不拥有一个OLE字体对象，其字体定义来自其上级对象的字体定义，OleFont 属性为NULL。"
        注释 = "报表开发者可以在 SectionFormat 事件响应函数中改变触发事件报表节本身或其拥有的单元格或部件框的字体定义，从而改变对应文本的显示。"
        注释 = "通过设定字体对象的属性来改变字体定义，如果将 OleFont 属性设为NULL，将导致使用缺省字体。" 注释 = "Grid++Report中拥有字体对象的报表对象有："
        注释 = "  (1).报表主对象IGridppReport)。其字体对象定义整个报表的缺省字体。OleFont 属性永远不为NULL。"
        注释 = "  (3).明细网格(IGRDetailGrid),其字体对象定义其拥有的字节（标题行、内容行、分组头、分组尾）的缺省字体。其缺省字体来自报表主对象。"
        注释 = "  (2).报表节(IGRSection)。其字体对象定义其拥有全部部件框或单元格的缺省字体。如果报表节的类型为页眉、页脚、报表头、报表尾，其缺省字体来自报表主对象。"
        注释 = "      如果报表节的类型为标题行、内容行、分组头、分组尾，其缺省字体来自明细网格。"
        注释 = "  (4).单元格(IGRColumnCell)。如果为非自由格，其字体对象定义单元格文本的显示字体；如果为非自由格，其字体对象定义单元格拥有全部部件框的缺省字体。标题格的缺省字体来自标题行，内容格的缺省字体来自内容行。"
        注释 = "  (5).部件框(IGRControl)。其字体对象定义部件框文本的显示字体。其缺省字体来自父容器。">
{
    方法 类_清理
    {
        清除 ()
    }

