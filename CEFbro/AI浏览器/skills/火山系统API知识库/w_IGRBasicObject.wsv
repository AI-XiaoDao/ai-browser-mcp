            注释 = "当改变格的名称也同时改变列的名称，反之改变列的名称也同时改变格的名称。">
    {
        返回 (读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "Name，指定单元格的名称标识。" 注释 = "注意：当为内容格或当为标题格而不是组标题格时，即格存在对应列，格的名称与列的名称保持一致。"
            注释 = "当改变格的名称也同时改变列的名称，反之改变列的名称也同时改变格的名称。">
    参数 名称 <类型 = 文本型>
    {
        写属性 ("Name", 名称)
    }
}

