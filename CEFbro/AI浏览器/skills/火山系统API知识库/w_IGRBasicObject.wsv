    方法 渲染 <公开 注释 = "Render">
    参数 对象句柄 <类型 = 整数 注释 = "hdc">
    参数 左 <类型 = 整数 注释 = "Left">
    参数 上 <类型 = 整数 注释 = "Top">
    参数 宽度 <类型 = 整数 注释 = "Width">
    参数 高度 <类型 = 整数 注释 = "Height">
    参数 图像对齐方式枚举值 <类型 = 图像对齐方式枚举 注释 = "PictureAlignment 1、左上； 2、右上； 3、居中； 4、左下； 5、右下">
    参数 图像缩放方式枚举值 <类型 = 图像缩放方式枚举 注释 = "PictureSizeMode  1、剪裁； 2、铺满； 3、缩放； 4、完整显示； 5、平铺">
    参数 背景颜色 <类型 = 整数 注释 = "BackColor">
    参数 背景填充 <类型 = 逻辑型 注释 = "FillBack">
    参数 图像透明模式枚举值 <类型 = 图像透明模式枚举 注释 = "Transparent 0、不透明； 1、叠加透明； 2、背景透明">
    参数 图像旋转模式枚举值 <类型 = 图像旋转模式枚举 注释 = "RotateMode  0、无； 1、左旋； 2、右旋； 3、颠倒； 4、镜像">
    {
        无返回值方法 ("Render", 对象句柄, 左, 上, 宽度, 高度, (整数)图像对齐方式枚举值, (整数)图像缩放方式枚举值, 背景颜色, 背景填充, (整数)图像透明模式枚举值, (整数)图像旋转模式枚举值)
    }
}

类 文本格式 <公开 基础类 = COM对象类 注释 = "TextFormat，基础对象，在报表中显示文字时，表示文字格式信息的对象。" 注释 = "◆要实现长篇幅文字跨页显示，必须满足以下几点要求："
        注释 = "1、必须将部件框的“可伸展”属性设为“是”。" 注释 = "2、部件框框所在的报表节的“可伸展”属性也要设为“是”。" 注释 = "3、“文字格式”属性类别下的“文字对齐”属性的垂直对齐必须为上端，通常设置为“左上”。">
{
    方法 类_清理
    {
        清除 ()
    }

    方法 对象值复制 <公开 注释 = "Assign，将同类型的参数对象赋值到本对象。">
    参数 对象类 <类型 = COM对象类>
    {
        无返回值方法 ("Assign", 对象类)
    }

    方法 超长文字省略号 <公开 属性读 类型 = 逻辑型 注释 = "EndEllipsis，是否用省略号(...)表示超出显示区域的文本。只有当文本不是多行显示时此属性才有意义。">
    {
        返回 (读无参数属性 ("EndEllipsis", 逻辑型))
    }

    方法 超长文字省略号 <公开 属性写 注释 = "EndEllipsis，是否用省略号(...)表示超出显示区域的文本。只有当文本不是多行显示时此属性才有意义。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("EndEllipsis", 逻辑值)
    }

    方法 支持HTML标签 <公开 属性读 类型 = 逻辑型 注释 = "HtmlTags，是否支持解析显示文字中的HTML标签。" 注释 = "1、只支持部分HTML标签，支持的标签类型请参考帮助文档中“开发指南->...”的说明"
            注释 = "2、当本属性为是时，文字部件框的缩小字体功能不会生效。"
            注释 = "设置文字格式的“支持HTML标签”属性为“是”开启HTML标签解析功能。在文字中加上标签文字，在显示时就会把标签文字解析出来，标签文字本身不显示，其标注的文字将按对应效果显示。" 注释 = "◆目前支持的标签有："
            注释 = "1、<b>...</b> 文字粗体" 注释 = "2、<i>...</i> 文字斜体" 注释 = "3、<u>...</u> 文字下划线，下划线仅绘制在文字下"
            注释 = "4、<U>...</U> 文字下划线，下划线延伸到行尾，即使没有文字，行也画满下划线" 注释 = "5、<strike>...</strike> 文字删除线" 注释 = "6、<p>...</p> 文字段落换行"
            注释 = "7、<br> 或<br/> 文字段落换行" 注释 = "8、<sub>...</sub> 下标" 注释 = "9、<sup>...</sup> 上标"
            注释 = "10、<font color=...>...</font> 文字颜色，颜色值支持两种表示方式：rgb与16进制，如:<font color=#FFAA88>，<font color=#RGB(255,128,64)>"
            注释 = "11、<font size=n>..........</font> 文字大小，参数n为字体的点数，可以带小数点"
            注释 = "12、<font face=\"字体名称\">..........</font> 字体名称，参数为有效的字体名称" 注释 = "13、<icon>n</icon> 在文字中插入图标,n为从0开始的数字，分别表示不同的图标。"
            注释 = "14、<img>n(w,h)</img> 在文字中插入显示报表图像集合中的一个图像，并要指定图像显示的宽度与高度；n、w、h都是纯数字，n为从1开始的数字，对应报表图像集合中的图像序号，w与h分别指定图像的显示宽度与高度，以屏幕像素为单位。"
            注释 = "◆特别提示：Grid++Report 只支持部分HTML标签，一个HTML文档的内容一般没法在报表中正确展现出来。">
    {
        返回 (读无参数属性 ("HtmlTags", 逻辑型))
    }

    方法 支持HTML标签 <公开 属性写 注释 = "HtmlTags，是否支持解析显示文字中的HTML标签。" 注释 = "1、只支持部分HTML标签，支持的标签类型请参考帮助文档中“开发指南->...”的说明"
            注释 = "2、当本属性为是时，文字部件框的缩小字体功能不会生效。"
            注释 = "设置文字格式的“支持HTML标签”属性为“是”开启HTML标签解析功能。在文字中加上标签文字，在显示时就会把标签文字解析出来，标签文字本身不显示，其标注的文字将按对应效果显示。" 注释 = "◆目前支持的标签有："
            注释 = "1、<b>...</b> 文字粗体" 注释 = "2、<i>...</i> 文字斜体" 注释 = "3、<u>...</u> 文字下划线，下划线仅绘制在文字下"
            注释 = "4、<U>...</U> 文字下划线，下划线延伸到行尾，即使没有文字，行也画满下划线" 注释 = "5、<strike>...</strike> 文字删除线" 注释 = "6、<p>...</p> 文字段落换行"
            注释 = "7、<br> 或<br/> 文字段落换行" 注释 = "8、<sub>...</sub> 下标" 注释 = "9、<sup>...</sup> 上标"
            注释 = "10、<font color=...>...</font> 文字颜色，颜色值支持两种表示方式：rgb与16进制，如:<font color=#FFAA88>，<font color=#RGB(255,128,64)>"
            注释 = "11、<font size=n>..........</font> 文字大小，参数n为字体的点数，可以带小数点"
            注释 = "12、<font face=\"字体名称\">..........</font> 字体名称，参数为有效的字体名称" 注释 = "13、<icon>n</icon> 在文字中插入图标,n为从0开始的数字，分别表示不同的图标。"
            注释 = "14、<img>n(w,h)</img> 在文字中插入显示报表图像集合中的一个图像，并要指定图像显示的宽度与高度；n、w、h都是纯数字，n为从1开始的数字，对应报表图像集合中的图像序号，w与h分别指定图像的显示宽度与高度，以屏幕像素为单位。"
            注释 = "◆特别提示：Grid++Report 只支持部分HTML标签，一个HTML文档的内容一般没法在报表中正确展现出来。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("HtmlTags", 逻辑值)
    }

    方法 文字对齐方式 <公开 属性读 类型 = 文字对齐方式枚举 注释 = "TextAlign，文字的输出对齐方式。" 注释 = "◆要实现长篇幅文字跨页显示，必须满足以下几点要求：" 注释 = "1、必须将部件框的“可伸展”属性设为“是”。"
            注释 = "2、部件框框所在的报表节的“可伸展”属性也要设为“是”。" 注释 = "3、“文字格式”属性类别下的“文字对齐”属性的垂直对齐必须为上端，通常设置为“左上”。">
    {
        返回 (读无参数属性 ("TextAlign", 文字对齐方式枚举))
    }

    方法 文字对齐方式 <公开 属性写 注释 = "TextAlign，文字的输出对齐方式。" 注释 = "◆要实现长篇幅文字跨页显示，必须满足以下几点要求：" 注释 = "1、必须将部件框的“可伸展”属性设为“是”。"
            注释 = "2、部件框框所在的报表节的“可伸展”属性也要设为“是”。" 注释 = "3、“文字格式”属性类别下的“文字对齐”属性的垂直对齐必须为上端，通常设置为“左上”。">
