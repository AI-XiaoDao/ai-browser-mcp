    }

    方法 粗细度 <公开 属性读 类型 = 整数 注释 = "Weight，该值用数字指示此字体对象的字体粗细，比 Bold 属性更具灵活性。">
    {
        返回 (读无参数属性 ("Weight", 整数))
    }

    方法 粗细度 <公开 属性写 注释 = "Weight，该值用数字指示此字体对象的字体粗细，比 Bold 属性更具灵活性。">
    参数 粗细度值 <类型 = 整数
            注释 = "550个是常规与粗体的临界值：由粗到细的字符。400等同于normal，而700等同于bold；如果权重低于550(FW_NORMAL 400和FW_BOLD 700的平均值)，则Bold属性也初始化为false。如果权重大于550，则Bold属性设置为true。"
            注释 = "可用值   值的说明" 注释 = "normal  缺省值。字体正常显示。" 注释 = "bold    粗体" 注释 = "bolder  比粗体更加粗" 注释 = "lighter 比正常字体淡"
            注释 = "100 至少和200一样淡" 注释 = "200 至少和100一样粗，至少和300一样淡" 注释 = "300 至少和200一样粗，至少和400一样淡" 注释 = "400 字体正常显示，相当于normal。"
            注释 = "500 至少和400一样粗，至少和600一样淡" 注释 = "600 至少和500一样粗，至少和700一样淡" 注释 = "700 粗体，相当于bold。" 注释 = "800 至少和700一样粗，至少和800一样淡"
            注释 = "900 至少和800一样粗">
    {
        写属性 ("Weight", 粗细度值)
    }

    方法 字符集 <公开 属性读 类型 = 整数 注释 = "Charset，该值指定此字体对象使用的 GDI 字符集。" 编辑时信息 = "43FFB, 0, 0, 0">
