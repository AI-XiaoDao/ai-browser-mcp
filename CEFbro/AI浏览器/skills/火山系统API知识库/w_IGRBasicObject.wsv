<火山程序 类型 = "通常" 版本 = 1 />

包 火山.锐浪 <注释 = "本文件放置包含基类对象和基础对象：" 注释 = "1、基类对象：IGR对象、部件框、单元格、列格、节、报表节、分组节、文字框。" 注释 = "2、基础对象：边框、报表字体、画笔、报表图片、文本格式。"
        @文档 = "category = \"基础对象\"">

类 IGR对象 <公开 基础类 = COM对象类 注释 = "Object，基类，基础对象，全部对象由此展开。">
{
    方法 类_清理
    {
        清除 ()
    }

    方法 取对象 <公开 类型 = COM对象类>
    {
        返回 (本对象)
    }

    方法 置对象 <公开 类型 = 逻辑型>
    参数 对象 <类型 = COM对象类>
    {
        返回 (取接口 ("", 对象))
    }

    方法 标识 <公开 属性读 类型 = 文本型>
    {
        返回 (读无参数属性 ("Tag", 文本型))
    }

    方法 标识 <公开 属性写>
    参数 标识文本 <类型 = 文本型>
    {
        写属性 ("Tag", 标识文本)
    }

    方法 对象值复制 <公开 注释 = "Assign，将同类型的参数对象赋值到本对象。">
    参数 对象类 <类型 = COM对象类>
    {
        无返回值方法 ("Assign", 对象类)
    }
}

类 部件框 <公开 基础类 = COM对象类 注释 = "Control，基类，各种部件框的基接口，定义各种类型的部件框所具有的共同属性与方法。"
        注释 = "部件框是对报表中最基本可显示单元的统称，部件框在其父容器中占据一个矩形区域，部件框的内容输出在此矩形区域中。" 注释 = "部件框包括背景填充方式与背景色、边框输出模式、以及具体类型的部件框的输出前景色。" 注释 = ""
        注释 = "部件框几种布局方式之间的关系：" 注释 = "按照优先级从高到底的顺序排列：对齐列-〉停靠-〉锚定-〉居中。" 注释 = "就是说在几种布局方式之间如果存在逻辑条件冲突时，优先按照高级别的布局方式调整部件框的大小与位置。"
        注释 = "例如，将部件框的停靠方式设定为停靠左边缘（grdsLeft），而居中方式为水平居中（grcsHorizontal），则部件框将采用停靠左边缘的停靠方式，而忽略水平居中的居中方式。" 折叠2>
{
    方法 类_清理
    {
        清除 ()
    }

    方法 对象值复制 <公开 注释 = "Assign，将同类型的参数对象赋值到本对象。">
    参数 对象类 <类型 = COM对象类>
    {
        无返回值方法 ("Assign", 对象类)
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "Name，部件框的名称，采用26个英文字母(不区分大小写)和0-9这十个自然数,加上下划线\'_\'组成,共63个字符.不能出现其他字符。">
    {
        返回 (读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "Name，部件框的名称，采用26个英文字母(不区分大小写)和0-9这十个自然数,加上下划线\'_\'组成,共63个字符.不能出现其他字符。">
    参数 名称 <类型 = 文本型>
    {
        写属性 ("Name", 名称)
    }

    方法 获取父对象 <公开 属性读 类型 = COM对象类 注释 = "Parent，父容器对象的 IUnknown 接口引用。">
    {
        返回 (读无参数对象型属性 ("Parent", COM对象类))
    }

    方法 获取为文字框 <公开 属性读 类型 = 文字框 注释 = "AsTextBox，转换本部件框为文字框基类的接口引用。"
            注释 = "只有当本部件框确实是文字基类框(TextBox)派生类的对象时，才能成功读取本属性值。文字基类派生的类包括：静态文本框、综合文本框、字段框、统计框、系统变量框。">
    {
        返回 (读无参数对象型属性 ("AsTextBox", 文字框))
    }

    方法 获取为图表框 <公开 属性读 类型 = 图表框 注释 = "AsChart，只有当本部件框确实是图表(Chart)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsChart", 图表框))
    }

    方法 获取为静态文字框 <公开 属性读 类型 = 静态文字框 注释 = "AsStaticBox，将本部件框转换为静态框的接口引用。只有当本部件框确实是静态框(StaticBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsStaticBox", 静态文字框))
    }

    方法 获取为图形框 <公开 属性读 类型 = 图形框 注释 = "AsShapeBox，将本部件框转换为图形框的接口引用。只有当本部件框确实是图形框(ShapeBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsShapeBox", 图形框))
    }

    方法 获取为系统变量框 <公开 属性读 类型 = 系统变量框 注释 = "AsSystemVarBox，将本部件框转换为系统变量框的接口引用。只有当本部件框确实是系统变量框(SystemVarBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsSystemVarBox", 系统变量框))
    }

    方法 获取为字段框 <公开 属性读 类型 = 字段框 注释 = "AsFieldBox，将本部件框转换为字段框的接口引用。只有当本部件框确实是字段框(FieldBox)时，才能成功读取本属性值。" 注释 = "">
    {
        返回 (读无参数对象型属性 ("AsFieldBox", 字段框))
    }

    方法 获取为统计框 <公开 属性读 类型 = 统计框 注释 = "AsSummaryBox，将本部件框转换为统计框的接口引用。只有当本部件框确实是统计框(SummaryBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsSummaryBox", 统计框))
    }

    方法 获取为图像框 <公开 属性读 类型 = 图像框 注释 = "AsPictureBox，将本部件框转换为图像框的接口引用。只有当本部件框确实是图像框(PictureBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsPictureBox", 图像框))
    }

    方法 获取为RTF文字框 <公开 属性读 类型 = RTF文字框 注释 = "AsRichTextBox，将本部件框转换为RTF文本框的接口引用。只有当本部件框确实是RTF文本框(RichTextBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsRichTextBox", RTF文字框))
    }

    方法 获取为综合文字框 <公开 属性读 类型 = 综合文字框 注释 = "AsMemoBox，转换本部件框为综合文本框的接口引用。只有当本部件框确实是综合文本框(MemoBox)时，才能成功读取本属性值。">
    {
        返回 (读无参数对象型属性 ("AsMemoBox", 综合文字框))
