    方法 条分辨率 <公开 属性写 注释 = "BarDPI，窄条的分辨率，通常设置为与打印机DPI值一致。">
    参数 分辨率 <类型 = 整数 注释 = "如果本属性值为0，条码尺寸将自动适应条码部件框的尺寸。" 注释 = "如果本属性值大于0，每个条码图形将显示为本属性对应DPI像素的整数倍。"
            注释 = "最小条码宽度由BarWidth(条宽度)属性值确定，此时BarWidth属性的值只取整数部分。"
            注释 = "如果BarWidth(条宽度)属性值为0，条码宽度将根据条码部件框的尺寸自动计算出一个整数值，从而保证条码按指定DPI进行生成。"
            注释 = "设置本属性的作用在于按打印机的DPI值精确打印条码，让条码在输出过程中不会产生缩放变形，从而提高条码的识别效率。"
            注释 = "特别是对于小尺寸的条码，设置本属性可以明显提高条码识别率。打印机的DPI值可以在打印机的首选项对话框与属性对话框中查看到。" 注释 = "设置本属性对于用标签条码打印机打印条码特别有效。">
    {
        写属性 ("BarDPI", 分辨率)
    }

