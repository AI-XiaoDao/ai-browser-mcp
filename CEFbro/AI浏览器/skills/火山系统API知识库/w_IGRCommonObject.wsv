<火山程序 类型 = "通常" 版本 = 1 />

包 火山.锐浪 <注释 = "本文件放置包含设计器内可见常用对象：页眉、页脚、报表头、报表尾、明细网格等报表节以及各类部件框。" @文档 = "category = \"常见对象\"">

类 页眉 <公开 基础类 = 节 注释 = "PageHeader，表示报表的页眉。页眉只在打印生成时显示，紧靠每页上边距的上面显示。"
        注释 = "页眉在打印生成时，输出在每页的上边距之上；在屏幕查询显示时，页眉被忽略掉，即屏幕查询显示不使用页眉。"
        注释 = "一个报表只能定义一个页眉。在页眉中一般定义页号，总页数，文档名称，打印时间及其它需要显示在输出纸张页眉区域的信息。">

类 页脚 <公开 基础类 = 节 注释 = "PageFooter，表示报表的页脚。页脚只在打印生成时显示，紧靠每页下边距的下面显示。"
        注释 = "页脚在打印生成时，输出在每页的上边距之上；在屏幕查询显示时，页脚被忽略掉，即屏幕查询显示不使用页脚。一个报表只能定义一个页脚。"
        注释 = "在页脚中一般定义页号，总页数，文档名称，打印时间及其它需要显示在输出纸张页脚区域的信息。">

类 报表头 <公开 基础类 = 报表节 注释 = "ReportHeader，报表头在打印生成时，如果不选择每页重复输出，则只在报表的开始生成时输出一次；在屏幕查询显示时，显示在明细网格之上。"
        注释 = "一个报表可以定义多个报表头，在一般情况下我们只需定义一个报表头就可以了。" 注释 = "在报表头中一般定义报表的标题，报表标识信息，徽标图像及其它只需在报表开始时显示一次的信息。">

类 报表尾 <公开 基础类 = 报表节 注释 = "ReportFooter，表示报表的报表尾，报表尾一般显示在报表的最后面。"
        注释 = "报表尾在打印生成时，如果不选择每页重复输出，则只在报表的最后输出一次；在屏幕查询显示时，显示在明细网格之下。" 注释 = "一个报表可以定义多个报表尾，在一般情况下我们只需定义一个报表尾就可以了。"
        注释 = "在报表尾中一般定义报表的统计信息及其它只需在报表结束时显示一次的信息。">
{
    方法 追加空白行排除 <公开 属性读 类型 = 逻辑型 注释 = "AppendBlankRowExclude，是否将报表尾行从明细网格的空白行计数中排除。"
            注释 = "当明细网格设定追加空白行且指定了每页行数，本属性指定是否将本报表尾行作为本页中的一行对待。" 注释 = "假设每页指定输出10行，数据行已输出6行，如果本属性为FALSE，则补充3行空白行，反之补充4行空白行。">
    {
        返回 (读无参数属性 ("AppendBlankRowExclude", 逻辑型))
    }

    方法 追加空白行排除 <公开 属性写 注释 = "AppendBlankRowExclude，是否将报表尾行从明细网格的空白行计数中排除。" 注释 = "当明细网格设定追加空白行且指定了每页行数，本属性指定是否将本报表尾行作为本页中的一行对待。"
            注释 = "假设每页指定输出10行，数据行已输出6行，如果本属性为FALSE，则补充3行空白行，反之补充4行空白行。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("AppendBlankRowExclude", 逻辑值)
    }

    方法 打印在页底 <公开 属性读 类型 = 逻辑型 注释 = "PrintAtBottom，是否将本节输出在页面底部标志。">
    {
        返回 (读无参数属性 ("PrintAtBottom", 逻辑型))
    }

    方法 打印在页底 <公开 属性写 注释 = "PrintAtBottom，是否将本节输出在页面底部标志。">
    参数 逻辑值 <类型 = 逻辑型>
    {
        写属性 ("PrintAtBottom", 逻辑值)
    }
}

类 明细网格 <公开 基础类 = IGR对象 注释 = "DetailGrid，表示明细网格对象。绝大多数报表都拥有明细网格，并且明细网格是多数报表的主体。"
        注释 = "明细网格就是处理报表明细数据生成的实现定义，一般的报表都需要一个明细网格，明细网格一般生成在报表头之后及报表尾之前。"
        注释 = "一般明细网格构成了一个报表的主体，报表的主要信息输出在明细网格中，明细网格由实现明细数据生成需要的多种子对象组成。">
{
    方法 锁定 <公开 属性读 类型 = 锁定类别枚举 注释 = "Lock，锁定类别枚举：0、不锁定； 1、锁定继承； 2、锁定对象； 3、锁定数据； 4、锁定数据行为； 5、完全锁定"
            注释 = "说明：除1，2两项外，其它项按从弱到强的顺序锁定控制对象，后一项包括前一项的锁定权限。报表主对象设置为“锁定继承”等同于“不锁定”。">
    {
        返回 (读无参数属性 ("Lock", 锁定类别枚举))
    }

    方法 锁定 <公开 属性写 注释 = "Lock，锁定类别枚举：0、不锁定； 1、锁定继承； 2、锁定对象； 3、锁定数据； 4、锁定数据行为； 5、完全锁定"
            注释 = "说明：除1，2两项外，其它项按从弱到强的顺序锁定控制对象，后一项包括前一项的锁定权限。报表主对象设置为“锁定继承”等同于“不锁定”。">
    参数 锁定类别枚举值 <类型 = 锁定类别枚举>
