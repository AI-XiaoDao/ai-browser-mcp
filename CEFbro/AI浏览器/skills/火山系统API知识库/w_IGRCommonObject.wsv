    }

    方法 获取项目 <公开 类型 = 报表图片 注释 = "Item，通过图像序号获取共享图像的引用。">
    参数 序号 <类型 = 整数 注释 = "图像序号从1开始。">
    {
        返回 (读对象型属性 ("Item", 报表图片, 序号))
    }

    方法 增加 <公开 类型 = 整数 注释 = "Add，根据图像对象引用增加该图像到图像集合中。" 返回值注释 = "指定新增图像的序号。">
    参数 报表图片对象 <类型 = 报表图片 注释 = "准备添加的图像对象引用。">
    {
        返回 (方法 ("Add", 整数, 报表图片对象))
    }

    方法 删除项目 <公开 注释 = "Remove，从图像集合中去除一个图像。">
    参数 序号 <类型 = 整数 注释 = "图像序号，从1开始。">
