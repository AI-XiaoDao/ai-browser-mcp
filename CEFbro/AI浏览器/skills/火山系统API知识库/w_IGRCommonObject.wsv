类 交叉表 <公开 基础类 = IGR对象 注释 = "CrossTab，表示交叉表的定义接口。" 注释 = "◆对于一个交叉表来说，纵向交叉列与横向交叉列是必须要定义的，而横向小计列与横向合计列不是必须的。"
        注释 = "1、纵向交叉列：在报表生成时保持纵向伸展，列数目不变，用来显示纵向交叉的项目。纵向交叉列是明细网格中最前面的一列或几列。"
        注释 = "2、横向交叉列：在报表生成时向横向方向延展，每个横向交叉数据项都会根据横向交叉列的定义创建对应的显示列。横向交叉列定义紧随纵向交叉列之后。"
        注释 = "3、横向合计列：如果需要在横向方向上对数据进行合计统计，就需要定义横向合计列。横向合计列定义在横向交叉列之后，当不用进行横向求合统计的报表就不需定义横向合计列。"
        注释 = "4、横向小计列：如果需要在横向方向上对交叉项目按类别进行统计，即在横向上进行过类分组多次统计，就需要定义横向小计列。横向小计列定义在横向交叉列之后，在横向合计列之前。 横向小计比较较少需要，当不需用时就不用定义横向小计列。"
        注释 = "◆综合分析来看，定义一个交叉表需要考虑以下因素：" 注释 = "1、首先要确定交叉表的数据，定义报表记录集字段项。如果是采用拉模式向报表提供数据，首先定义好查询SQL语句。"
        注释 = "2、确定纵向交叉数据项，并在明细网格上定义对应的显示列，即纵向交叉列。" 注释 = "3、确定横向交叉数据项，确定数据横向交叉的显示列(即横向交叉列)，其在运行时会根据横向交叉列的定义生成对应的显示列。"
        注释 = "4、交叉表是否需要进行横向求和统计。" 注释 = "5、交叉表是否需要进行纵向求和统计。" 注释 = "6、交叉表是否需要进行横向求比重百分比计算。" 注释 = "7、交叉表是否需要进行纵向求比重百分比计算。"
        注释 = "8、交叉表是否按照日期间进行统计分析。" 注释 = "◆关于交叉表的横向交叉项与纵向交叉项的显示顺序："
        注释 = " 交叉表会自动按照横向交叉字段与纵向交叉字段自动进行排序，所以交叉项是按照内部自动排序后的顺序显示。如果希望交叉项按数据的原始顺序显示，首先必须保证原始数据将具有相同交叉字段值的记录排列在一起，并取消交叉表上对应的交叉项排序。"
        注释 = " 例如要让横向交叉项按数据的原始顺序显示，原始数据必须将具有相同横向交叉字段值的记录排列在一起，记录的顺序也是希望显示的顺序，并将交叉表的“交叉项排序::横向重排序”属性设置为“否”。"
        注释 = "◆特别提示：不能同时做到横向与纵向都按原始数据顺序显示，即“交叉项排序::横向重排序”或“交叉项排序::纵向重排序”属性不能同时设置为“否”，不然数据没法排序归类好。">
{
