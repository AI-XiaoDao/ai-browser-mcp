    方法 复制记录 <公开 注释 = "Duplicate，复制当前正在添加的新记录。" 注释 = "特别提示：此函数只能用在添加记录时触发的“提交记录前脚本(BeforePostRecord)”事件或对应的脚本代码(提交记录前脚本)中。"
            注释 = "此函数调用之后，可以重新设置各个字段的值，最后必须调用 Post 函数提交复制的记录。复制的记录在当前追加记录之前。此函数主要用于明细记录的重复打印。" 注释 = "  编程说明"
            注释 = "  在记录集的“提交记录前脚本”属性上写如下脚本，实现复制 count 变量值指定的条路的记录，最后将获得 count+1 条相同的记录。" 注释 = "  var i = 0," 注释 = "  count = 3;"
            注释 = "  //在当前正在追加的记录前面复制 count 条相同的记录" 注释 = "  while (i++<count) {" 注释 = "  Sender.Duplicate();//复制记录(Duplicate)"
            注释 = "  //... 这里可以对某些字段重新设置值" 注释 = "  Sender.Post(); //复制记录(Duplicate) 之后必须调用 提交(Post)" 注释 = "  }">
    {
        无参数及返回值方法 ("Duplicate")
    }

