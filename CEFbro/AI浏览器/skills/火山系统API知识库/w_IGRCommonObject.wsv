    方法 筛选开始 <公开 注释 = "FilterBegin，开始筛选明细记录，在筛选记录前必须调用本方法。"
            注释 = "筛选开始(FilterBegin)、筛选选中(FilterSelect) 与 筛选结束(FilterEnd) 必须在一起按顺序调用。"
            注释 = "筛选开始(FilterBegin) 与 筛选结束(FilterEnd) 在开始与结束时调用一次。"
            注释 = "筛选选中(FilterSelect) 通常会多次调用，在遍历记录的过程中，将满足条件的记录用 筛选选中(FilterSelect) 方法选中。"
            注释 = "这三个方法一般在“开始处理脚本(ProcessBeginScript)”属性的报表脚本，或“IGridppReport.ProcessBegin 事件”的响应函数中调用。" 注释 = "  编程说明"
            注释 = "  //以下代码为“开始处理脚本(ProcessBeginScript)”属性的报表脚本：" 注释 = "  var rs = Report.DetailGrid.Recordset;"
            注释 = "  rs.FilterBegin(); //开始筛选，必须调用" 注释 = "  rs.First();" 注释 = "  while(!rs.Eof()){"
            注释 = "     //将符合条件的记录数据用FilterSelect筛选中"
            注释 = "    if (Report.FieldByName(\"ID\").AsInteger % 50 == 0 || Report.FieldByName(\"ID\").AsInteger > 330){"
            注释 = "      rs.FilterSelect();" 注释 = "     }" 注释 = "   rs.Next();" 注释 = "  }" 注释 = "  rs.FilterEnd(); //结束筛选，将筛选的记录应用上">
    {
        无参数及返回值方法 ("FilterBegin")
    }

