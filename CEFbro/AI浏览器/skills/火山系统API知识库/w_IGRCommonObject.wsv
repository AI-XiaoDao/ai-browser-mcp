    }

    方法 全部删除 <公开 注释 = "RemoveAll，将图像集合中的图像全部清除掉。">
    {
        无参数及返回值方法 ("RemoveAll")
    }

    方法 从文件增加图片 <公开 类型 = 整数 注释 = "AddFromFile，根据图像文件路径名将该图像添加到图像集合中。" 返回值注释 = "指定新增图像的序号。">
    参数 文件名 <类型 = 文本型 注释 = "图像文件路径名或图像数据URL。">
    {
        返回 (方法 ("AddFromFile", 整数, 文件名))
    }

    方法 从二进制增加图片 <公开 类型 = 整数 注释 = "AddFromBinary，从二进制数据对象中载入图像到图像集合中。" 返回值注释 = "指定新增图像的序号。">
    参数 二进制数据对象 <类型 = 二进制数据 注释 = "拥有图像数据的二进制对象。">
    {
