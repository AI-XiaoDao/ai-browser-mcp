            注释 = "1、分隔；2、打印设置；3、页面设置；4、打印机设置；5、导出；6、邮件；7、保存报表文档；8、连续；9、单页；10、多页；11、放大；12、缩小；13、缩放百分比；"
            注释 = "14、上一页；15、下一页；16、首页；17、尾页；18、当前页号；19、关闭；20、剪切；21、刷新；22、书签；" 注释 = "30、查找文本框；31、查找按钮；32、继续查找按钮；33、显示查找对话框钮；"
            注释 = "50、导出XLS文件；51、导出TXT文件；52、导出HTM文件；53、导出RTF文件；54、导出PDF文件；55、导出CSV文件；56、导出IMG文件；"
            注释 = "60、导出XLS文件按钮；61、导出PDF文件按钮；65、邮件发送XLS文件；66、邮件发送TXT文件；67、邮件发送HTM文件；68、邮件发送RTF文件；69、邮件发送PDF文件；70、邮件发送CSV文件；71、邮件发送IMG文件；72、邮件发送报表文档"
            折叠2>
}

类 报表设计器 <公开 基础类 = OCX组件 注释 = "Designer，报表设计器是一个ActiveX控件。"
        注释 = "一个 ActiveX Control。在使用时关联一个报表主对象。报表设计器提供设计报表模板的操作界面，并提供属性与方法与设计器进行交互处理。" 注释 = "设计器界面主要有布局窗口，属性编辑窗口，对象浏览窗口三部分组成："
        注释 = "1、布局窗口：主要可以在其中设置报表显示元素的大小、位置、显示顺序等。" 注释 = "2、属性编辑窗口：可以查看与修改当前选中的报表元素对象的属性数据。"
        注释 = "3、对象浏览窗口：在对象浏览窗口中以树形结构的方式将所有的报表元素对象列出，不可显示的报表元素对象可以在此窗口中选中。"
        注释 = "报表开发者可以利用报表设计器构件定义自己的报表设计器，通过提供外围操作界面与设计器构件进行交互，从而为报表用户提供自定义的报表设计器，使用户在运行时可以对报表进行修改。"
        注释 = "构件接口提供执行各种设计任务的动作方法，报表开发人员通过提供外部操作界面执行动作方法，为最终用户提供运行时的可视化自定义报表设计器。"
        @视窗.窗口组件 = "icon = \".\\icon\\Designer.bmp\"\r\ndefault_size = \"256, 168\"\r\nocx_win32 = \"dll\\grdes6.dll\"\r\nocx_x64 = \"dll\\grdes6x64.dll\""
        组件类型 = "{6EDD80CB-9F08-4C71-B406-479E5CB80FCE}" @视窗.外部清单文件.win32 = "manifest\\Designer6.manifest"
        @视窗.外部清单文件.x64 = "manifest\\Designer6x64.manifest" @视窗.附属文件.win32 = "DLL\\grdes6.dll" @视窗.附属文件.x64 = "DLL\\grdes6x64.dll">
