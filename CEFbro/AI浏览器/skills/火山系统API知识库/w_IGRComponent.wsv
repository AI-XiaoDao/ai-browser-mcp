    方法 取模板WEB注册状态 <公开 类型 = 整数 注释 = "WebRegisterStatus，返回值：0、未注册；1、插件注册；2、服务器&客户端注册；3、插件注册&服务器&客户端注册。" 返回值注释 = "说明"
            返回值注释 = "获取当前报表模板的WEB开发注册状态值。WEB报表开发的注册信息包含在报表模板中，通过此方法可以侦测到报表模板是否已经注册。返回值用不同的整数表示当前模板的注册状态，整数值表义如下："
            返回值注释 = " 0 - 表示报表模板没有包含注册信息。" 返回值注释 = " 1 - 表示报表模板只包含了WEB报表插件的注册信息，应用在WEB报表插件的开发中可以去掉试用标志。"
            返回值注释 = " 2 - 表示报表模板只包含了WEB报表服务器&客户端的注册信息，应用在WEB报表服务器与WEB报表客户端的开发中可以去掉试用标志。"
            返回值注释 = " 3 - 表示报表模板既包含了WEB报表插件的注册信息，也包含了WEB报表服务器&客户端的注册信息。应用在各种WEB报表开发中都可以去掉试用标志。" 返回值注释 = "" 返回值注释 = "编程说明"
            返回值注释 = " var staus = Report.WebRegisterStatus();" 返回值注释 = " if (staus == 0) {" 返回值注释 = " alert(\"报表模板没有注册！\");"
            返回值注释 = " }" 返回值注释 = " else if (staus == 1) {" 返回值注释 = " alert(\"报表模板包含了报表插件的注册信息！\");" 返回值注释 = " }"
            返回值注释 = " else if (staus == 2) {" 返回值注释 = " alert(\"报表模板包含了报表服务器&客户端的注册信息！\");" 返回值注释 = " }"
            返回值注释 = " else if (staus == 3) {" 返回值注释 = " alert(\"报表模板包含了报表插件、报表服务器与报表客户端的注册信息，WEB报表开发购买了双注册！\");" 返回值注释 = " }"
            返回值注释 = " else {" 返回值注释 = " alert(\"报表模板的注册信息异常！\");" 返回值注释 = " }">
    {
        返回 (无参数方法 ("WebRegisterStatus", 整数))
    }

    方法 查找第一个部件框 <公开 类型 = 部件框 注释 = "FindFirstControl，找出报表中的第一个部件框，如果报表中不存在部件框，则返回值为空值引用。">
    {
        返回 (无参数对象型方法 ("FindFirstControl", 部件框))
    }

    方法 查找下一个部件框 <公开 类型 = 部件框
            注释 = "FindNextControl，找出报表中的下一个部件框的引用，如果报表中不存在后续的部件框，则返回值为空值引用。在调用 FindNextControl 之前必须调用 FindFirstControl。">
