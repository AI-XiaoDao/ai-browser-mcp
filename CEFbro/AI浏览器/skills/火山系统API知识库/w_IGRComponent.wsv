    方法 OCX组件_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到OCX组件的COM事件时,本事件被触发。" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理。">
    参数 来源对象 <类型 = OCX组件 注释 = "提供事件产生的具体来源对象。">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0。">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值。">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据。">
    {
        如果 (事件方法ID == 事件_报表设计器.设计区右键菜单)  // 事件_报表设计器_设计区右键菜单, "1", , LayoutPanelContextMenu
        {
            设计区右键菜单 ()
        }
        否则 (事件方法ID == 事件_报表设计器.属性区右键菜单)  // 事件_报表设计器_属性区右键菜单, "2", , InspectorContextMenu
        {
            属性区右键菜单 ()
        }
        否则 (事件方法ID == 事件_报表设计器.对象区右键菜单)  // 事件_报表设计器_对象区右键菜单, "3", , ExplorerContextMenu
        {
            对象区右键菜单 ()
        }
        否则 (事件方法ID == 事件_报表设计器.侦测属性改变)  // 事件_报表设计器_侦测属性改变, "4", , InspectorChange
        {
            侦测属性改变 ()
        }
        否则 (事件方法ID == 事件_报表设计器.数据改变)  // 事件_报表设计器_数据改变, "5", , DataChange
        {
            数据改变 ()
        }
        否则 (事件方法ID == 事件_报表设计器.打开报表)  // 事件_报表设计器_打开报表, "6", , OpenReport
        {
            打开报表 ()
        }
        否则 (事件方法ID == 事件_报表设计器.保存报表)  // 事件_报表设计器_保存报表, "7", , SaveReport
        {
            保存报表 ()
        }
        否则 (事件方法ID == 事件_报表设计器.将执行动作 && 事件参数.取成员数 () >= 1)  // 事件_报表设计器_将发生设计器动作, "8", , BeforeDoAction
        {
            将执行动作 ((设计器动作枚举)事件参数.取成员 (0).取值 (整数))
        }
        否则 (事件方法ID == 事件_报表设计器.请求数据 && 事件参数.取成员数 () >= 1)  // 事件_报表设计器_请求数据, "9", , RequestData
        {
            变量 报表对象 <类型 = COM对象类>
            ((COM变体型)事件参数.取成员 (0)).取COM对象 (报表对象)
            请求数据 ((报表)报表对象)
            // event_RequestData (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        返回 (0)
    }

    方法 设计区右键菜单 <公开 定义事件 类型 = 整数 注释 = "LayoutPanelContextMenu 编号：1 当在报表布局窗口中执行打开关联弹出式菜单时触发本事件。">

