    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象。">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0。">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象。">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值。">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据。">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中。">
    {
        如果 (事件方法ID == 事件_报表.初始化事件)  // 事件_报表_初始化事件, "1",
        {
            初始化事件 ()
        }
        否则 (事件方法ID == 事件_报表.请求记录数据)  // 事件_报表_请求记录数据, "2",
        {
            请求记录数据 ()
        }
        否则 (事件方法ID == 事件_报表.提交记录前)  // 事件_报表_提交记录前, "3",
        {
            提交记录前 ()
        }
        否则 (事件方法ID == 事件_报表.排序前 && 事件参数.取成员数 () >= 1)  // 事件_报表_排序前, "4",
        {
            排序前 (事件参数.取成员 (0).取值 (文本型))
        }
        否则 (事件方法ID == 事件_报表.运行时错误 && 事件参数.取成员数 () >= 2)  // 事件_报表_运行时错误, "5",
        {
            运行时错误 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (文本型))
        }
        否则 (事件方法ID == 事件_报表.请求字段显示文字 && 事件参数.取成员数 () >= 1)  // 事件_报表_请求字段显示文字, "20",
        {
            请求字段显示文字 (事件参数.取成员 (0).取COM对象2 (字段))
        }
        否则 (事件方法ID == 事件_报表.请求文字框显示文字 && 事件参数.取成员数 () >= 1)  // 事件_报表_请求文字框显示文字, "22",
        {
            请求文字框显示文字 (事件参数.取成员 (0).取COM对象2 (文字框))
        }
        否则 (事件方法ID == 事件_报表.格式化报表节 && 事件参数.取成员数 () >= 1)  // 事件_报表_格式化报表节, "23",SectionFormat
        {
            格式化报表节 (事件参数.取成员 (0).取COM对象2 (节))
        }
        否则 (事件方法ID == 事件_报表.部件框自定义绘制 && 事件参数.取成员数 () >= 2)  // 事件_报表_部件框自定义绘制, "24", ControlCustomDraw
        {
            部件框自定义绘制 (事件参数.取成员 (0).取COM对象2 (部件框), 事件参数.取成员 (1).取COM对象2 (绘图接口))
        }
        否则 (事件方法ID == 事件_报表.图表请求数据 && 事件参数.取成员数 () >= 1)  // 事件_报表_图表请求数据, "25", ChartRequestData
        {
            图表请求数据 (事件参数.取成员 (0).取COM对象2 (图表框))
        }
        否则 (事件方法ID == 事件_报表.开始处理记录)  // 事件_报表_开始处理记录, "30", ProcessBegin
        {
            开始处理记录 ()
        }
        否则 (事件方法ID == 事件_报表.结束处理记录)  // 事件_报表_结束处理记录, "31", ProcessEnd
        {
            结束处理记录 ()
        }
        否则 (事件方法ID == 事件_报表.分组开始 && 事件参数.取成员数 () >= 1)  // 事件_报表_分组开始, "32", GroupBegin
        {
            分组开始 (事件参数.取成员 (0).取COM对象2 (分组))
        }
        否则 (事件方法ID == 事件_报表.分组结束 && 事件参数.取成员数 () >= 1)  // 事件_报表_分组结束, "33", GroupEnd
        {
            分组结束 (事件参数.取成员 (0).取COM对象2 (分组))
        }
        否则 (事件方法ID == 事件_报表.处理记录)  // 事件_报表_处理记录, "34", ProcessRecord
        {
            处理记录 ()
        }
        否则 (事件方法ID == 事件_报表.页处理记录)  // 事件_报表_页处理记录, "35", PageProcessRecord
        {
            页处理记录 ()
        }
        否则 (事件方法ID == 事件_报表.页开始)  // 事件_报表_页开始, "36", PageStart
        {
            页开始 ()
        }
        否则 (事件方法ID == 事件_报表.页结束)  // 事件_报表_页结束, "37", PageEnd
        {
            页结束 ()
        }
        否则 (事件方法ID == 事件_报表.页面生成前)  // 事件_报表_页面生成前, "38", GeneratePagesBegin
        {
            页面生成前 ()
        }
        否则 (事件方法ID == 事件_报表.页面生成后)  // 事件_报表_页面生成后, "39", GeneratePagesEnd
        {
            页面生成后 ()
        }
        否则 (事件方法ID == 事件_报表.打印前)  // 事件_报表_打印前, "40", PrintBegin
        {
            打印前 ()
        }
        否则 (事件方法ID == 事件_报表.打印后)  // 事件_报表_打印后, "41", PrintEnd
        {
            打印后 ()
        }
        否则 (事件方法ID == 事件_报表.打印页 && 事件参数.取成员数 () >= 1)  // 事件_报表_打印页, "42", PrintPage
        {
            打印页 (事件参数.取成员 (0).取值 (整数))
        }
        否则 (事件方法ID == 事件_报表.打印中止)  // 事件_报表_打印中止, "43", PrintAborted
        {
            打印中止 ()
        }
        否则 (事件方法ID == 事件_报表.导出报表前 && 事件参数.取成员数 () >= 1)  // 事件_报表_导出报表前, "50", ExportBegin
        {
            导出报表前 (事件参数.取成员 (0).取COM对象2 (导出选项))
        }
        否则 (事件方法ID == 事件_报表.导出报表后 && 事件参数.取成员数 () >= 1)  // 事件_报表_导出报表后, "51", ExportEnd
        {
            导出报表后 (事件参数.取成员 (0).取COM对象2 (导出选项))
        }
        否则 (事件方法ID == 事件_报表.显示预览界面 && 事件参数.取成员数 () >= 1)  // 事件_报表_显示预览界面, "60", ShowPreviewWnd
        {
            变量 参数对象 <类型 = COM变体型>
            变量 接口对象 <类型 = COM对象类>
            变量 打印显示器类 <类型 = 打印显示器>
            打印显示器类.初始化 ()
            参数对象 = 事件参数.取成员 (0)
            参数对象.取COM对象 (接口对象)
            打印显示器类.置对象 (接口对象)
            显示预览界面 (打印显示器类)
            // 显示预览界面 (事件参数.取成员 (0).取COM对象2 (打印显示器))
            // event_ShowPreviewWnd (事件参数.取成员 (0).取COM对象2 (IGRPrintViewer))
        }
        否则 (事件方法ID == 事件_报表.显示设计界面 && 事件参数.取成员数 () >= 1)  // 事件_报表_显示设计界面, "61", ShowDesignerWnd  // 这个事件好像没实现,预留
        {
            变量 报表设计器类 <类型 = 报表设计器>
            变量 COM对象 <类型 = COM对象类>
            事件参数.取成员 (0).取COM对象 (COM对象)
            报表设计器类.取对象 ().置COM对象 (COM对象)
            显示设计界面 (报表设计器类)
            // 显示设计界面 (事件参数.取成员 (0).取COM对象2 (COM对象类))
            // event_ShowDesignerWnd (事件参数.取成员 (0).取COM对象2 (COM对象类))
        }
        否则 (事件方法ID == 事件_报表.超链接文本被点击 && 事件参数.取成员数 () >= 3)  // 事件_报表_超链接文本被点击, "65", HyperlinkClick  // 这个事件好像没实现,预留
        {
            // event_HyperlinkClick (事件参数.取成员 (0).取COM对象2 (IGRControl), 事件参数.取成员 (1).取值 (文本型), 事件参数.取成员 (2).取值 (逻辑型))
        }
        返回 (0)
    }

    方法 初始化事件 <公开 定义事件 类型 = 整数 注释 = "Initialize 编号：1"
            注释 = "在报表准备生成时触发，报表每生成一次触发一次本事件，此事件也是报表生成过程中最先触发的事件。在此事件中，报表开发者可以对报表模板定义进行修改调整。"
            注释 = "例如用户在报表生成之从所有可选的列中选择一部分列显示，就可以在此事件中以编程方式动态定义列。" 注释 = "可以在此事件中对报表进行定义，即可以改变报表模板数据，如重新载入报表模板数据，以编程的方式定义报表。"
            注释 = "在此事件中，可以将在其它事件中使用的对象接口指针或对象属性等数据用变量缓存下来，以供后面直接使用，提高程序运行效率。"
            注释 = "在除此事件之外的其它事件中，除了 SectionFormat 事件可以对事件触发节对象及其拥有的子对象的显示外观属性进行修改外，禁止对报表进行重新定义，即不允许增减报表对象与改变报表对象的属性。">

    方法 请求记录数据 <公开 定义事件 类型 = 整数 注释 = "FetchRecord 编号：2"
            注释 = "采用推模式填充数据时，当报表的记录集上没有定义数据源连接串与查询SQL，或其“忽略数据查询”属性设为“是”，则在报表生成时，报表主对象请求数据时触发本事件。报表开发者必须在此事件中向记录集填入数据。"
            注释 = "如果没有定义数据库连接串与查询SQL，或指定在运行时不从数据库连接串与查询SQL设置中取得明细记录数据，则FetchRecord 事件在报表请求数据时触发，报表每生成一次触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "报表开发者必须响应此事件，且只能在此事件中向记录集填充记录。报表开发者使用记录集接口与字段接口的属性与方法向记录集填充记录。"
            注释 = "注意：Delphi 与 C++Builder 的包装类定义了一个 DataSet 属性，并对 FetchRecord 事件在包装类中进行了响应，如果设置了 DataSet 属性值，则会把 DataSet 属性关联记录集对象中的数据填入到 Grid++Report 中。"
            注释 = "因此在Delphi 与 C++Builder 中一般通过设置 DataSet 属性来提供明细记录数据。">

    方法 提交记录前 <公开 定义事件 类型 = 整数 注释 = "BeforePostRecord 编号：3"
            注释 = "在向报表中填入记录数据的过程中，每当提交一条记录时，触发一次本事件。在此事件中，我们可以对当前记录的各个字段值进行重新设置，记录提交之后就不能修改其字段值。"
            注释 = "譬如可以在此事件中设置需要由其它字段通过计算得来的字段值。" 注释 = "报表开发者可以在此事件中设定各个字段的值，这样就可以对记录数据进行最后的调整。"
            注释 = "如某些字段的值不能直接从数据源中的得来，而是根据一定的运算求得，则可以在此事件中处理。" 注释 = "不管是根据查询SQL取得的数据，还是通过 FetchRecord 事件提供的数据，在每提交一条记录之前都会触发本事件。">

    方法 排序前 <公开 定义事件 类型 = 整数 注释 = "BeforeSort 编号：4"
            注释 = "当要对记录集中的记录进行重新排序之前触发本事件。在此事件中可以重新设置明细记录集的 SortFields 属性，随后排序将按新设定的字段进行。"
            注释 = "如果报表的记录集指定了排序字段，在 ProcessBegin 之前会触发 BeforeSort 事件。"
            注释 = "如果设置了记录集的排序字段(SortFields)属性，在每次生成报表时，在BeginPeocessRecord事件之前会触发BeforeSort事件。"
            注释 = "另当查询显示器设定为可排序时，点击明细网格的列标题会按点击的列对记录进行重新排序，此时也会触发BeforeSort事件。"
            注释 = "在此事件中可以重新设置明细记录集的 SortFields 属性，随后排序将按新设定的字段进行。如下代码：Report.DetailGrid.Recordset.SortFields = \"Field1 DESC;Field2\";">
    参数 排序字段 <类型 = 文本型 注释 = "事件参数 Name，字段名。">

    方法 运行时错误 <公开 定义事件 类型 = 整数 注释 = "RuntimeError 编号：5">
    参数 错误ID <类型 = 整数>
    参数 错误信息 <类型 = 文本型>

    方法 请求字段显示文字 <公开 定义事件 类型 = 整数 注释 = "FieldGetDisplayText 编号：20" 注释 = "当字段对象准备生成其显示文本时触发。"
            注释 = "如果一个字段的显示文本不是字段对象内部生成的文本，就需要在此事件中为字段设定显示文本，通过给字段的 DisplayText 属性赋值改变字段的显示文本。"
            注释 = "报表在输出显示时，当部件框需要取关联字段的显示文本时触发本事件。在此事件中可以对触发事件的字段对象的显示文本(DisplayText)属性赋值，使字段的显示文本是报表开发者自定义的。"
            注释 = "例如在财务报表中，需要将负数用红字显示，就可以在此事件处理函数中将负号从显示文本中去掉，在 SectionFormat 事件处理函数中将对应显示部件框的前景色(ForeColor)设为红色。"
            注释 = "注意：FieldGetDisplayForamt 事件会频繁触发，在此事件中不应该执行运行开销大的任务，在此事件响应函数中使用的对象接口指针最好在 Initialize 事件处理函数中缓存到变量中。">
    参数 字段对象 <类型 = 字段 注释 = "事件参数 pSender，字段。">

    方法 请求文字框显示文字 <公开 定义事件 类型 = 整数 注释 = "TextBoxGetDisplayText 编号：22" 注释 = "当文字类型的部件框准备生成其显示文本时触发。此事件类同 FieldGetDisplayText。"
            注释 = "如果其显示文本不是内部生成的文本，就需要在此事件中为其设定显示文本，通过给其 DisplayText 属性赋值改变字段的显示文本。"
            注释 = "报表在输出显示时，当文字部件输出文字时触发本事件。在此事件中可以对触发事件的文字部件框对象的显示文本(DisplayText)属性赋值，使显示文本是报表开发者自定义的。">
    参数 文字框对象 <类型 = 文字框 注释 = "事件参数 pSender，文字框， 各种显示文本的部件框的统称，包括：静态框、字段框、统计框、系统变量框、综合文字框。">

    方法 格式化报表节 <公开 定义事件 类型 = 整数 注释 = "SectionFormat 编号：23" 注释 = "当报表节在输出之前触发。包括查询显示与打印生成显示。"
            注释 = "当报表节在输出显示之前触发。一般在 SectionFormat 事件中改变节及节中的部件框或单元格的显示外观属性，达到某些突出显示的效果。"
            注释 = "当报表输出在查询显示器中，当前可见的节在显示时会触发本事件，节如果是重复显示的，同一节还会多次触发。"
            注释 = "当节在查询显示器中显示时，每当查询显示器窗口需要刷新显示时（要进行自画时），都会触发节的 SectionFormat 事件，所以节的 SectionFormat 事件会频繁触发。"
            注释 = "当报表节打印生成时，当每个节在输出之前会触发 SectionFormat 事件。一个节每显示一次，就会触发一次 SectionFormat 事件，一个节如果多次显示，就会多次触发 SectionFormat 事件。"
            注释 = "当报表在打印或打印预览时，首先要生成打印页面数据，在页面中显示每个节之前触发本事件。可以通过取报表的当前显示状态（DispalyMode）属性确定事件是由查询显示器自画时触发，还是由生成打印页面时触发。"
            注释 = "注意：SectionForamt 事件会频繁触发，在此事件中不应该执行运行开销大的任务，在此事件响应函数中使用的对象接口指针最好在 Initialize 事件处理函数中缓存到变量中。">
    参数 节对象 <类型 = 节
            注释 = "事件参数 pSender，节Section，包括：页眉、页脚、报表节ReportSection(报表头与报表尾)、列节ColumnSection(标题行与内容行)、分组节GroupSection(分组头与分组尾)。">

    方法 部件框自定义绘制 <公开 定义事件 类型 = 整数 注释 = "ControlCustomDraw 编号：24" 注释 = "报表部件框自绘事件。"
            注释 = "当部件框为自绘部件框时(部件框的自绘属性设置为是)，部件框在输出显示时会触发本事件,报表开发者应该在本事件中实现部件框的显示输出。">
    参数 部件框对象 <类型 = 部件框 注释 = "事件参数 pSender，指定了触发本事件的部件框引用；">
    参数 绘图接口对象 <类型 = 绘图接口 注释 = "事件参数 Graphics， 提供了在部件框中实现显示输出功能的接口引用，调用其方法在部件框中实现输出；"
            注释 = "事件本参数可以继续获取 x, y, width, height 指定部件框的属性以得到输出区域。">

    方法 图表请求数据 <公开 定义事件 类型 = 整数 注释 = "ChartRequestData 编号：25" 注释 = "当报表中的图表运行时，会触发本事件来请求加载图表数据。"
            注释 = "在此事件响应函数中，开发者可以将数据加载触发此事件的到图表中。如果此图表定义了数据记录集，则向其记录集中追加一条条记录数据。"
            注释 = "如果此图表没有定义数据记录集，则直接向图表载入数据，既可以载入XML形式的数据包，也可以通过调用图表接口的属性或方法写入一个个数据。">
    参数 图表框对象 <类型 = 图表框 注释 = "事件参数 pSender，图表框。">

    方法 开始处理记录 <公开 定义事件 类型 = 整数 注释 = "ProcessBegin 编号：30" 注释 = "当报表准备对填入的数据进行分析处理之前触发本事件。"
            注释 = "报表在获得记录集的明细数据之后，会对明细数据进行运算处理。在开始处理之前触发 ProcessBegin 事件，在完成处理之时触发 ProcessEnd 事件。"
            注释 = "在 ProcessBegin 与 ProcessEnd 之间在处理每条明细数据时都会触发一次 ProcessRecord。">

    方法 结束处理记录 <公开 定义事件 类型 = 整数 注释 = "ProcessEnd 编号：31" 注释 = "当报表对填入的数据进行分析处理完成之后触发本事件。">

    方法 分组开始 <公开 定义事件 类型 = 整数 注释 = "GroupBegin 编号：32" 注释 = "在生成报表数据时，开始一个分组触发。当定义了页分组，在开始生成明细网格关联的每一页时，每个页分组将触发一次本事件。"
            注释 = "报表在生成的过程中，会按顺序逐条处理每个记录，如果报表定义有分组，每当一个分组项开始时，触发 GroupBegin 事件，每当一个分组项结束时，触发 GroupEnd 事件。"
            注释 = "如果要对分组进行自定义的复杂统计，可以在 GroupBegin 事件函数中设定运算的初值，在 ProcessRecord 事件中对每条记录进行累积运算，在 GroupEnd 事件中对运算的结果进行最后的运算。">
    参数 分组对象 <类型 = 分组 注释 = "事件参数 pSender，分组。">

    方法 分组结束 <公开 定义事件 类型 = 整数 注释 = "GroupEnd 编号：33" 注释 = "在生成报表数据时，结束一个分组触发。当定义了页分组，在结束生成明细网格关联的每一页时，每个页分组将触发一次本事件。">
    参数 分组对象 <类型 = 分组 注释 = "事件参数 pSender，分组。">

    方法 处理记录 <公开 定义事件 类型 = 整数 注释 = "ProcessRecord 编号：34" 注释 = "当报表生成时，会按顺序遍历每一条记录，每当遍历一条记录时触发本事件。在此事件中，可以取记录的各个字段的值。"
            注释 = "报表开发者可以在此事件中对数据进行一些自定义的分析统计。" 注释 = "报表在生成的过程中，会按顺序逐条处理每个记录，在每处理一条记录之前，都会触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "如果要对报表数据进行自定义的统计运算，就应该在此事件中取记录数据进行运算，将计算结果保存到参数对象或程序中的变量中。"
            注释 = "在此事件中可以调用 IGRDetailGrid 接口的 StartNewGroup 方法指定前一个分组项的结束与后一个分组项的开始，从而实现自定义的分组。">

    方法 页处理记录 <公开 定义事件 类型 = 整数 注释 = "PageProcessRecord 编号：35"
            注释 = "当报表在生成打印数据时，会再次按顺序遍历每一条记录，每当遍历一条记录时触发本事件，只有具有明细网格的报表才会触发此事件。" 注释 = "此事件只有当报表将输出到打印机或打印预览时才会触发。"
            注释 = "在页分组中，如果要对报表数据进行自定义的统计运算，就应该在此事件中取记录数据进行运算，将计算结果保存到参数对象或程序中的变量中。">

    方法 页开始 <公开 定义事件 类型 = 整数 注释 = "PageStart 编号：36" 注释 = "此事件只有当报表将输出到打印机或打印预览时才会触发。在开始生成一个打印页面时触发本事件。在开始生成每一页时，将触发一次本事件。"
            注释 = "报表在生成打印页面的过程中，会再次按顺序逐条处理每个记录，在每处理一条记录之前，都会触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "在页分组中，如果要对报表数据进行自定义的统计运算，就应该在此事件中取记录数据进行运算，将计算结果保存到参数对象或程序中的变量中。">

    方法 页结束 <公开 定义事件 类型 = 整数 注释 = "PageEnd 编号：37" 注释 = "在完成一个打印页面生成时触发本事件。在结束生成每一页时，将触发一次本事件。">

    方法 页面生成前 <公开 定义事件 类型 = 整数 注释 = "GeneratePagesBegin 编号：38" 注释 = "在产生打印页面数据之前触发本事件。">

    方法 页面生成后 <公开 定义事件 类型 = 整数 注释 = "GeneratePagesEnd 编号：39" 注释 = "在产生打印页面数据完成后触发本事件。">

    方法 打印前 <公开 定义事件 类型 = 整数 注释 = "PrintBegin 编号：40" 注释 = "在开始打印报表之前，触发本事件。另也可以在此事件中设置打印设置参数。"
            注释 = "在此事件中可以调用 AbortPrint 方法取消打印过程，这样就可以根据一定的条件控制是否可以打印输出。"
            注释 = "一次打印任务成功完成过程，开始时会触发 PrintBegin 事件，在打印数据全部传输给打印机之后触发 PrintEnd 事件；"
            注释 = "如果中途取消打印或发生了各种异常导致打印任务没有完成，PrintAborted 事件会触发，而PrintEnd 事件就不会执行到。">

    方法 打印后 <公开 定义事件 类型 = 整数 注释 = "PrintEnd 编号：41" 注释 = "在结束打印报表之后，触发本事件。"
            注释 = "一次打印任务成功完成过程，开始时会触发 PrintBegin 事件，在打印数据全部传输给打印机之后触发 PrintEnd 事件；"
            注释 = "如果中途取消打印或发生了各种异常导致打印任务没有完成，PrintAborted 事件会触发，而PrintEnd 事件就不会执行到。">

    方法 打印页 <公开 定义事件 类型 = 整数 注释 = "PrintPage 编号：42" 注释 = "在打印每一页报表页面时触发本事件。">
    参数 页号 <类型 = 整数 注释 = "当前触发打印的页码。">

    方法 打印中止 <公开 定义事件 类型 = 整数 注释 = "PrintAborted 编号：43" 注释 = "当打印任务中途取消时触发本事件。"
            注释 = "一次打印任务成功完成过程，开始时会触发 PrintBegin 事件，在打印数据全部传输给打印机之后触发 PrintEnd 事件；"
            注释 = "如果中途取消打印或发生了各种异常导致打印任务没有完成，PrintAborted 事件会触发，而PrintEnd 事件就不会执行到。">

    方法 导出报表前 <公开 定义事件 类型 = 整数 注释 = "ExportBegin 编号：50" 注释 = "在报表导出任务执行之前触发本事件。">
