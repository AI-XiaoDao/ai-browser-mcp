    方法 OCX组件_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到OCX组件的COM事件时,本事件被触发。" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理。">
    参数 来源对象 <类型 = OCX组件 注释 = "提供事件产生的具体来源对象。">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0。">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值。">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据。">
    {
        如果 (事件方法ID == 事件_查询显示器.被单击事件)  // 事件_查询显示器_被单击, "-600", Click
        {
            被单击事件 ()
        }
        否则 (事件方法ID == 事件_查询显示器.被双击事件)  // 事件_查询显示器_被双击, "-601", DblClick
        {
            被双击事件 ()
        }
        否则 (事件方法ID == 事件_查询显示器.按下某键事件 && 事件参数.取成员数 () >= 2)  // 事件_查询显示器_按下某键, "-602", KeyDown
        {
            按下某键事件 ((功能键枚举)事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.字符输入事件 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_字符输入, "-603", KeyPress
        {
            字符输入事件 (事件参数.取成员 (0).取值 (字节))
        }
        否则 (事件方法ID == 事件_查询显示器.放开某键事件 && 事件参数.取成员数 () >= 2)  // 事件_查询显示器_放开某键, "-604", KeyUp
        {
            放开某键事件 ((功能键枚举)事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.鼠标键按下 && 事件参数.取成员数 () >= 4)  // 事件_查询显示器_鼠标键按下, "-605", MouseDown
        {
            鼠标键按下 ((鼠标键枚举)事件参数.取成员 (0).取值 (整数), (功能键枚举)事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数), 事件参数.取成员 (3).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.鼠标位置移动 && 事件参数.取成员数 () >= 3)  // 事件_查询显示器_鼠标位置移动, "-606", MouseMove
        {
            鼠标位置移动 ((功能键枚举)事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.鼠标键放开 && 事件参数.取成员数 () >= 4)  // 事件_查询显示器_鼠标键放开, "-607", MouseUp
        {
            鼠标键放开 ((鼠标键枚举)事件参数.取成员 (0).取值 (整数), (功能键枚举)事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数), 事件参数.取成员 (3).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.部件框被单击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_部件框被单击, "1", ControlClick
        {
            部件框被单击 (事件参数.取成员 (0).取COM对象2 (部件框))
        }
        否则 (事件方法ID == 事件_查询显示器.部件框被双击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_部件框被双击, "2", ControlDblClick
        {
            部件框被双击 (事件参数.取成员 (0).取COM对象2 (部件框))
        }
        否则 (事件方法ID == 事件_查询显示器.报表节被单击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_报表节被单击, "3", SectionClick
        {
            报表节被单击 (事件参数.取成员 (0).取COM对象2 (节))
        }
        否则 (事件方法ID == 事件_查询显示器.报表节被双击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_报表节被双击, "4", SectionDblClick
        {
            报表节被双击 (事件参数.取成员 (0).取COM对象2 (节))
        }
        否则 (事件方法ID == 事件_查询显示器.内容格被单击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_内容格被单击, "5", ContentCellClick
        {
            内容格被单击 (事件参数.取成员 (0).取COM对象2 (内容格))
        }
        否则 (事件方法ID == 事件_查询显示器.内容格被双击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_内容格被双击, "6", ContentCellDblClick
        {
            内容格被双击 (事件参数.取成员 (0).取COM对象2 (内容格))
        }
        否则 (事件方法ID == 事件_查询显示器.标题格被单击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_标题格被单击, "7", TitleCellClick
        {
            标题格被单击 (事件参数.取成员 (0).取COM对象2 (标题格))
        }
        否则 (事件方法ID == 事件_查询显示器.标题格被双击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_标题格被双击, "8", TitleCellDblClick
        {
            标题格被双击 (事件参数.取成员 (0).取COM对象2 (标题格))
        }
        否则 (事件方法ID == 事件_查询显示器.列布局发生改变)  // 事件_查询显示器_列布局发生改变, "9", ColumnLayoutChange
        {
            列布局发生改变 ()
        }
        否则 (事件方法ID == 事件_查询显示器.选中格改变 && 事件参数.取成员数 () >= 2)  // 事件_查询显示器_选中格改变, "10", SelectionCellChange
        {
            选中格改变 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.图表图形被单击 && 事件参数.取成员数 () >= 3)  // 事件_查询显示器_图表图形被单击, "11", ChartClickSeries
        {
            图表图形被单击 (事件参数.取成员 (0).取COM对象2 (图表框), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.图表图形被双击 && 事件参数.取成员数 () >= 3)  // 事件_查询显示器_图表图形被双击, "12", ChartDblClickSeries
        {
            图表图形被双击 (事件参数.取成员 (0).取COM对象2 (图表框), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.图表图例被单击 && 事件参数.取成员数 () >= 3)  // 事件_查询显示器_图表图例被单击, "13", ChartClickLegend
        {
            图表图例被单击 (事件参数.取成员 (0).取COM对象2 (图表框), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.图表图例被双击 && 事件参数.取成员数 () >= 3)  // 事件_查询显示器_图表图例被双击, "14", ChartDblClickLegend
        {
            图表图例被双击 (事件参数.取成员 (0).取COM对象2 (图表框), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.分批次填充数据)  // 事件_查询显示器_分批次填充数据, "15", BatchFetchRecord
        {
            分批次填充数据 ()
        }
        否则 (事件方法ID == 事件_查询显示器.状态被改变)  // 事件_查询显示器_状态被改变, "22", StatusChange
        {
            状态被改变 ()
        }
        否则 (事件方法ID == 事件_查询显示器.关闭按钮被点击)  // 事件_查询显示器_关闭按钮被点击, "29", CloseButtonClick
        {
            关闭按钮被点击 ()
        }
        否则 (事件方法ID == 事件_查询显示器.自定义按钮被点击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_自定义按钮被点击, "30", CustomButtonClick
        {
            自定义按钮被点击 (事件参数.取成员 (0).取值 (整数))
        }
        否则 (事件方法ID == 事件_查询显示器.工具栏按钮被点击 && 事件参数.取成员数 () >= 1)  // 事件_查询显示器_工具栏按钮被点击, "31", ToolbarCommandClick,5和6不会产生反馈事件
        {
            工具栏按钮被点击 ((查询显示器按钮枚举)事件参数.取成员 (0).取值 (整数))
        }
        返回 (0)
    }

