<火山程序 类型 = "通常" 版本 = 1 />

包 火山.锐浪 <注释 = "本文件放置包含报表主对象、查询显示器、打印显示器、报表设计器这些主要窗口显示组件。"
        注释 = "Grid++Report 为报表开发者提供四个外层构件，报表开发人员通过对这四个构件的使用为最终用户提供完善的报表系统。" 注释 = "报表主对象是不可视的，其它三个构件都是可视的。" 注释 = "以下是对四个构件对象的简要叙述"
        注释 = "1、报表对象是整个系统中最基础的组件，其负责报表的定义与生成等基本功能，相当于整个报表系统的引擎部分。其它几个组件都要依赖关联一个报表对象。"
        注释 = "2、查询显示器以连续不分页的方式展现报表数据，报表的明细数据以网格形式在屏幕上展现查看。" 注释 = "3、打印显示器按打印页面方式展现报表数据，是对报表数据打印输出在屏幕上的模拟显示。"
        注释 = "4、报表设计器以可视化设计的方式定义报表。" 折叠2 @文档 = "category = \"对象组件\"">

类 报表 <公开 基础类 = COM对象类 注释 = "Report，表示报表的主对象。" 注释 = "一个不可视的组件对象，定义报表的模板数据，在生成报表时存贮报表记录数据，对数据进行加工处理，生成打印页面，输出打印页面到打印机。"
        注释 = "报表主对象是整个产品中最基础的构成部分，通过报表主对象可以访问报表中的各个子对象。" 注释 = "其他报表元素对象都是其子孙对象，对其它对象的访问与使用都是以此对象作为进入起点。"
        注释 = "报表主对象Report是一个COM自动化（COM Automation）对象的接口定义，是Grid++Report组件对象模型的最外层对象。"
        注释 = "报表主对象是所有其它报元素对象的直接或间接拥有者，直接拥有的报表元素对象有：明细网格，报表节集合、参数集合、打印机对象。" 注释 = "另也包括报表有关的公共信息，如设计行为属性、计量单位、整个报表的缺省字体等。"
        @视窗.附属文件.win32 = "DLL\\gregn6.dll" @视窗.附属文件.x64 = "DLL\\gregn6x64.dll" @视窗.附属文件.win32 = "DLL\\grmysql6.dll"
        @视窗.附属文件.x64 = "DLL\\grmysql6x64.dll" @视窗.外部清单文件.win32 = "manifest\\Report6.manifest"
        @视窗.外部清单文件.x64 = "manifest\\Report6x64.manifest">
{
    变量 事件接口 <类型 = COM对象事件类 "">

    方法 类_清理
    {
        清除 ()
        事件接口.取消挂接 ()
    }

    方法 初始化 <公开 类型 = 逻辑型 注释 = "创建报表对象的开端。" 注释 = "报表对象增加“初始化”接口的目的：为了避免程序里有多少报表变量，在启动程序时就初始化多少次的问题，减轻不必要的负担。">
    {
        返回 (创建 (GR标识类.CLSID_报表, ) && 事件接口.挂接 (本对象, GR标识类.IID_报表事件))
    }

    方法 释放 <公开>
    {
        清除 ()
    }

    方法 对象值复制 <公开 注释 = "Assign，将同类型的参数对象赋值到本对象。">
    参数 对象类 <类型 = COM对象类>
    {
        无返回值方法 ("Assign", 对象类)
    }

    方法 标识 <公开 属性写 注释 = "Tag，报表对象的标识值。" 注释 = "可以按自己意愿任意使用本属性，如可以将此属性作为对象的身份标识。">
    参数 标识文本 <类型 = 文本型>
    {
        写属性 ("Tag", 标识文本)
    }

    方法 标识 <公开 属性读 类型 = 文本型 注释 = "Tag，报表对象的标识值。" 注释 = "可以按自己意愿任意使用本属性，如可以将此属性作为对象的身份标识。">
    {
        返回 (读无参数属性 ("Tag", 文本型))
    }

    方法 版本号 <公开 属性读 类型 = 文本型 注释 = "Version，指示Grid++Report的当前运行版本。">
    {
        返回 (读无参数属性 ("Version", 文本型))
    }

    方法 文档标题 <公开 属性读 类型 = 文本型 注释 = "Title，报表文档的标题文字，当打印输出报表时，打印文档的标题是此属性的值。报表数据导出时，此属性将作为导出文件的默认文件名称。">
    {
        返回 (读无参数属性 ("Title", 文本型))
    }

    方法 文档标题 <公开 属性写 注释 = "Title，报表文档的标题文字，当打印输出报表时，打印文档的标题是此属性的值。报表数据导出时，此属性将作为导出文件的默认文件名称。">
    参数 标题文本 <类型 = 文本型>
    {
