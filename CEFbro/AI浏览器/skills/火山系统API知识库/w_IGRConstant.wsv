类 系统图像枚举 <公开 注释 = "GRSystemImage 指定报表引擎中的系统内建图像。"
        注释 = "Grid++Report 在报表引擎中定义了一些系统内建图像。图片框可以将其图像序号指定为某个枚举项的值来关联某个系统图像,从而在图像框中显示系统图像。"
        注释 = "另也可以调用 IGRPictureBox 接口的 AttachSystemImage 方法来关联系统图像。" @常量类 = 整数>
{
    常量 未选中3D单选框 <公开 值 = -10 注释 = "-10 grsiRadio3DUnchecked 值为-10,3D形式的无线按钮(Radio)非选中标志。">
    常量 选中3D单选框 <公开 值 = -9 注释 = "-9 grsiRadio3DChecked 值为-9,3D形式的无线按钮(Radio)选中标志。">
    常量 向上箭头 <公开 值 = -8 注释 = "-8 grsiArrowUp 值为-8,朝上箭头标志。">
    常量 向下箭头 <公开 值 = -7 注释 = "-7 grsiArrowDown 值为-7,朝下箭头标志。">
    常量 否定标志 <公开 值 = -6 注释 = "-6 grsiNegative 值为-6,否定标志。">
    常量 肯定标志 <公开 值 = -5 注释 = "-5 grsiAffirm 值为-5,肯定标志。">
    常量 未选中3D <公开 值 = -4 注释 = "-4 grsi3DUnchecked 值为-4,3D形式的非选中标志。">
    常量 选中3D <公开 值 = -3 注释 = "-3 grsi3DChecked 值为-3,3D形式的选中标志。">
    常量 未选中 <公开 值 = -2 注释 = "-2 grsiUnchecked 值为-2,非选中标志。">
    常量 选中 <公开 值 = -1 注释 = "-1 grsiChecked 值为-1,选中标志。">
}

