类 文档类型枚举 <公开 注释 = "GRDocType 指定报表模板的文档类型。以文本格式打开报表模板文件,可以看到不同文档类型保存的报表模板数据的差异。" @常量类 = 整数>
{
    常量 对象格式 <公开 值 = 1 注释 = "1 grdtObject 按对象方式保存模板数据,此种格式为 Grid++Report 自有格式,内容非常直观易理解。" 编辑时信息 = "0, 3AAA7, 0, 0">
    常量 JSON格式 <公开 值 = 2 注释 = "2 grdtJSON 按 JSON 格式保存报表模板数据,完全符合 JSON 规范要求。" 编辑时信息 = "0, 3AAA7, 0, 0">
    常量 注册格式 <公开 值 = 3 注释 = "3 grdtRegister 6.6.5.0 改变报表模板存储方式,让WEB无限分发版的各种注册方式共享相同的报表模板">
}

