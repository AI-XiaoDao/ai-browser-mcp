{
    常量 左端 <公开 值 = 1 注释 = "1 gracsLeft 对齐到列的左端。" "">
    常量 右端 <公开 值 = 2 注释 = "2 gracsRight 对齐到列的右端。">
    常量 左右两端 <公开 值 = 3 注释 = "3 gracsBoth 对齐到列的左右两端,部件框宽度与列保持一致。">
