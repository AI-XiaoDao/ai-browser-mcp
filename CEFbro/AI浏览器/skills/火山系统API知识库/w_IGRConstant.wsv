类 换新页栏方式枚举 <公开 注释 = "GRNewPageColumnStyle 在打印生成明细网格的分组头时,指定是否强制产生新页列的方式。" @常量类 = 整数>
{
    常量 不应用 <公开 值 = 1 注释 = "1 grncsNone 分组头在任何时候都不另起新页栏。">
    常量 页栏前 <公开 值 = 2 注释 = "2 grncsBefore 分组头在打印输出之前另起新页栏进行输出。">
    常量 页栏后 <公开 值 = 3 注释 = "3 grncsAfter 分组头在打印输出之后另起新页栏。后续内容输出在新页栏中。">
    常量 页栏前与页栏后 <公开 值 = 4 注释 = "4 grncsBeforeAfter 分组头在打印输出之前与之后都另起新页栏。">
}

类 换新页方式枚举 <公开 注释 = "GRNewPageStyle 在打印生成报表节时,指定是否强制产生新页的方式。" @常量类 = 整数>
{
    常量 不应用 <公开 值 = 1 注释 = "1 grnpsNone 报表节不强制产生新页。">
    常量 节前 <公开 值 = 2 注释 = "2 grnpsBefore 报表节在打印输出之前要求产生新页,保证本节在新页中输出。">
    常量 节后 <公开 值 = 3 注释 = "3 grnpsAfter 报表节在打印输出之后要求产生新页,保证本节之后的后续节在新页中输出。">
    常量 节前与节后 <公开 值 = 4 注释 = "4 grnpsBeforeAfter 报表节在打印输出之前与之后要求产生新页。">
}

类 页栏输出方向枚举 <公开 注释 = "GRPageColumnDirection 在明细网格打印生成时,如果生成多栏报表,指定明细网格的各种行的在各页栏中的输出次序。" @常量类 = 整数>
{
    常量 先从上到下再左到右 <公开 值 = 1 注释 = "1 grpcdDownAcross 按从上到下,再从左到右的顺序在页栏中打印输出。">
    常量 先从左到右再上到下 <公开 值 = 2 注释 = "2 grpcdAcrossDown 按从左到右,再从上到下的顺序在页栏中打印输出。">
    常量 先从上到下且等分 <公开 值 = 3 注释 = "3 grpcdDownAcrossEqual 按从上到下,再从左到右的顺序在页栏中打印输出,保持每栏输出基本一样多的数据。">
}

类 重复方式枚举 <公开 注释 = "GRRepeatStyle 指定明细网格标题的重复输出方式。"
        注释 = "如果为不重复输出方式（None），则只在明细网格打印生成的开始时输出一次标题。如果为每页重复方式（OnPage)或每页列重复方式（OnPageColumn）,则在明细网格打印生成的开始时与产生新页或新页列时输出标题。"
        注释 = "如果为在分组头上重复方式（OnGroupHeader），则在明细网格打印生成的开始时不输出报表头，而是在每个分组头输出后输出标题。" @常量类 = 整数>
{
    常量 不应用 <公开 值 = 1 注释 = "1 grrsNone 明细网格标题不重复输出。">
    常量 新页 <公开 值 = 2 注释 = "2 grrsOnPage 明细网格标题在每页重复输出。">
    常量 新页栏 <公开 值 = 4 注释 = "4 grrsOnPageColumn 明细网格标题在每个页栏重复输出。">
    常量 新分组头 <公开 值 = 8 注释 = "8 grrsOnGroupHeader 明细网格标题在最内层的分组头之后重复输出。">
    常量 新分组头新页 <公开 值 = 10 注释 = "10 grrsOnGroupHeaderPage 明细网格标题在每页与最内层的分组头之后重复输出。">
}

