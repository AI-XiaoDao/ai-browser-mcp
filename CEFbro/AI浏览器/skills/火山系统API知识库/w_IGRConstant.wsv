    常量 英语 <公开 值 = 1033 注释 = "1033，0x0409">
    常量 俄语 <公开 值 = 1049 注释 = "1049，0x0419">
    常量 日语 <公开 值 = 1041 注释 = "1041，0x0411">
    常量 朝鲜语 <公开 值 = 1042 注释 = "1042，0x0412">
    常量 德语 <公开 值 = 1031 注释 = "1031，0x00407">
    常量 法语 <公开 值 = 1036 注释 = "1036，0x040c">
    常量 意大利语 <公开 值 = 1040 注释 = "1040，0x0410">
    常量 西班牙语 <公开 值 = 1034 注释 = "1034，0x040a">
    常量 葡萄牙语 <公开 值 = 2070 注释 = "2070，0x0816">
}

