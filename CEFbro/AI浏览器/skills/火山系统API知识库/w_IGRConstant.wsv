    常量 UTF8WithHead码 <公开 值 = 5 注释 = "5 grtemUTF8WithHead 此项同grtemUTF8,特别注意:枚举值也应为 2">
}

类 内码表枚举 <公开 注释 = "CodePage 指定报表内部进行文字编码转换的内码表"
        注释 = "当此属性为0时，将采用 Windows 系统默认的内码表进行文字砖换。具体的有效值可以在MSDN文档中按关键字“Code Page Identifiers”或“WideCharToMultiByte”进行查询。"
        @常量类 = 整数>
{
    常量 ANSI <公开 值 = 0 注释 = "default to ANSI code page">
    常量 OEM <公开 值 = 1 注释 = "default to OEM  code page">
    常量 MAC <公开 值 = 2 注释 = "default to MAC  code page">
    常量 current_ANSI <公开 值 = 3 注释 = "current thread\'s ANSI code page">
    常量 Japanese <公开 值 = 932 注释 = "ANSI/OEM - Japanese, Shift-JIS">
    常量 Simplified <公开 值 = 936 注释 = "ANSI/OEM - Simplified Chinese (PRC, Singapore)">
    常量 Korean <公开 值 = 949 注释 = "ANSI/OEM - Korean (Unified Hangeul Code)">
    常量 Traditional <公开 值 = 950 注释 = "ANSI/OEM - Traditional Chinese (Taiwan; Hong Kong SAR, PRC)">
    常量 utf_7 <公开 值 = 65000 注释 = "utf-7 Unicode (UTF-7)">
    常量 utf_8 <公开 值 = 65001 注释 = "utf-8 Unicode (UTF-8)【默认设置】">
}

