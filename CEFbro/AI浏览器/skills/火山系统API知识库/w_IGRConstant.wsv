    常量 非空总体方差 <公开 值 = 21 注释 = "21 grsfVarPA">
    常量 非空标准偏差 <公开 值 = 22 注释 = "22 grsfStdDevA">
    常量 非空总体标准偏差 <公开 值 = 23 注释 = "23 grsfStdDevPA">
