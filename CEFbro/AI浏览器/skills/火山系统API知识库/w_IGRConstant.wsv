    常量 非空值个数 <公开 值 = 13 注释 = "13 grsfCountA">
    常量 非重复值个数 <公开 值 = 14 注释 = "14 grsfDistinct">
    常量 非空值平均 <公开 值 = 15 注释 = "15 grsfAvgA">
