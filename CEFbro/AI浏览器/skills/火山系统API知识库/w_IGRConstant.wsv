类 打印策略枚举 <公开 注释 = "GRColumnPrintAdaptMethod 打印生成时，明细网格列对输出页面的适应方法。"
        注释 = "在打印输出到纸张页面中，输出列的总宽度与页面的输出宽度（除掉左右页边距的宽度）很可能不一样，系统可以采用几种方法来处理列的输出。"
        注释 = "如采用调整列的宽度以适应输出区域的宽度，则系统根据每个列的设计宽度按比列调整其打印输出宽度，使所有打印输出列的打印输出总宽度与打印输出区域宽度保持一样；"
        注释 = "如果列的设计总宽度小于输出区域宽度，所有列的打印宽度将放大，反之则缩小。" @常量类 = 整数>
{
    常量 丢弃 <公开 值 = 1 注释 = "1 grcpamDiscard 在打印输出时,超出页面输出范围的列内容将被忽略掉,即不输出显示。" 编辑时信息 = "42AA6, 0, 0, 0">
    常量 绕行 <公开 值 = 2 注释 = "2 grcpamWrap 在打印输出时,超出页面输出范围的列内容将另起新行输出显示。" 编辑时信息 = "42AA6, 0, 0, 0">
    常量 缩放适应 <公开 值 = 3 注释 = "3 grcpamResizeToFit 在打印输出时,根据列的宽度按比列将所有要输出的列的总宽度调整到页面输出区域的宽度。" 编辑时信息 = "42AA6, 0, 0, 0">
    常量 按需缩小适应 <公开 值 = 4 注释 = "4 grcpamShrinkToFit 在打印输出时,如果列的总宽度超出页面输出范围,与grcpamResizeToFit相同,反之按设计时宽度输出。"
            编辑时信息 = "42AA6, 0, 0, 0">
    常量 横向分页先纵向 <公开 值 = 5 注释 = "5 grcpamToNewPage 在打印输出时,超出页面输出范围的列内容将另起新页输出显示,按先从上到下的顺序输出。" 编辑时信息 = "42AA6, 0, 0, 0">
    常量 横向分页先横向 <公开 值 = 6 注释 = "6 grcpamToNewPageEx 在打印输出时,超出页面输出范围的列内容将另起新页输出显示,按先从左到右的顺序输出。" 编辑时信息 = "42AA6, 0, 0, 0">
    常量 横向分页并重复锁定列先纵向 <公开 值 = 7 注释 = "7 grcpamToNewPageRFC 在打印输出时,超出页面输出范围的列内容将另起新页输出显示,且左边的固定列在每页中重复输出,按先从上到下的顺序输出。"
            编辑时信息 = "42AA6, 0, 0, 0">
    常量 横向分页并重复锁定列先横向 <公开 值 = 8 注释 = "8 grcpamToNewPageRFCEx 在打印输出时,超出页面输出范围的列内容将另起新页输出显示,且左边的固定列在每页中重复输出,按先从左到右的顺序输出。"
            编辑时信息 = "42AA6, 0, 0, 0">
    常量 排除分组绕行 <公开 值 = 9 注释 = "9 grcpamWrapExcludeGroup 类同 grcpamWrap,但分组头尾不另起新行。" 编辑时信息 = "42AA6, 0, 0, 0">
}

类 打印生成方式枚举 <公开 注释 = "GRPrintGenerateStyle 指示打印页面的生成方式。"
        注释 = "打印生成时，如果指定打印生成方式为只输出报表内容数据（OnlyContent）,则只输出打印类别为报表内容数据的报表元素，其它打印类别为报表表单数据的报表元素将不会输出。"
        注释 = "在只输出报表内容数据时，报表节的背景色不会填充，明细网格的边框线与行列线也不会输出。在只输出报表内容数据的打印生成方式特别适用于进行票据套打与现存格式报表的套打。"
        注释 = "打印生成时，如果指定印生成方式为输出报表表单数据（OnlyForm）,生成方式与只输出报表内容数据（OnlyContent）反之对应。"
        注释 = "在此种方式下，明细网格的记录数据不会被应用，明细行的生成与明细记录不对应，不填充明细记录页也可以输出报表表单数据。报表表单数据一般只生成一页。此种模式一般用来制作票据与固定格式报表的印刷模版。"
        注释 = "打印生成时，如果指定印生成方式（PrintGenerateStyle）为输出全部数据（All）,则所有数据都会输出，这也是我们平时最多用到的方式。"
        注释 = "使用打印页面的生成方式的地方有： 在IGridppReport接口中执行PrintEx与PrintViewEx方法中可以指定打印页面的生成方式，另可以设定打印预览查看器的打印页面的生成方式（GenerateStyle）属性。"
        @常量类 = 整数>
{
    常量 仅表单 <公开 值 = 1 注释 = "1 grpgsOnlyForm 只生成报表表单数据。">
    常量 仅内容 <公开 值 = 2 注释 = "2 grpgsOnlyContent 只生成报表内容数据。">
    常量 全部 <公开 值 = 3 注释 = "3 grpgsAll 生成报表所有数据。">
    常量 预览全部 <公开 值 = 4 注释 = "4 grpgsPreviewAll 预览报表全部内容,但只打印出内容数据。">
}

