    常量 自由表格子格 <公开 值 = 53 注释 = "53  grdssFreeGridCell 选中对象为自由表格子格。">
}

类 设计器动作枚举 <公开 注释 = "GRDesignerAction 指定执行报表设计器动作的类型。" 注释 = "在报表设计器IGRDesigner接口DoAction与IsActionEnabled方法中，指定动作的类型。"
        @常量类 = 整数>
{
    常量 撤销 <公开 值 = 101 注释 = " 101  grdaEditUndo  恢复操作。">
    常量 重做 <公开 值 = 102 注释 = " 102  grdaEditRedo  重复操作。">
