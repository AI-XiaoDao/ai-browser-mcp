类 报表类名枚举 <公开 注释 = "Class类名文本，便于设计器属性栏操作枚举的接口。" @常量类 = 文本型>
{
    常量 报表 <公开 值 = "Report" 注释 = "IGridppReport">
    常量 明细网格 <公开 值 = "DetailGrid" 注释 = "DetailGrid">
    常量 交叉表 <公开 值 = "CrossTab" 注释 = "CrossTab">
    常量 列 <公开 值 = "Column" 注释 = "Column">
    常量 记录集 <公开 值 = "Recordset" 注释 = "Recordset">
    常量 字段 <公开 值 = "Field" 注释 = "Field">
    常量 参数 <公开 值 = "Parameter" 注释 = "Parameter">
    常量 节 <公开 值 = "Section" 注释 = "<基类> 节：页眉、页脚、报表节(报表头与报表尾)、列节(标题行与内容行)、分组节(分组头与分组尾)">
    常量 页眉 <公开 值 = "PageHeader" 注释 = "PageHeader">
    常量 页脚 <公开 值 = "PageFooter" 注释 = "PageFooter">
    常量 报表节 <公开 值 = "ReportSection" 注释 = "<基类> 报表节：报表头、报表尾">
    常量 报表头 <公开 值 = "ReportHeader" 注释 = "报表头 ReportHeader">
    常量 报表尾 <公开 值 = "ReportFooter" 注释 = "报表尾 ReportFooter">
    常量 列节 <公开 值 = "ColumnSection" 注释 = "<基类> 列节 ColumnSection：标题行、内容行">
    常量 标题行 <公开 值 = "ColumnTitle" 注释 = "标题行 ColumnTitle">
    常量 内容行 <公开 值 = "ColumnContent" 注释 = "内容行 ColumnContent">
    常量 分组节 <公开 值 = "GroupSection" 注释 = "<基类> 分组节 GroupSection：分组(分组头、分组尾)">
    常量 分组 <公开 值 = "Group" 注释 = "分组 Group">
    常量 分组头 <公开 值 = "GroupHeader" 注释 = "分组头 GroupHeader">
    常量 分组尾 <公开 值 = "GroupFooter" 注释 = "分组尾 GroupFooter">
    常量 单元格 <公开 值 = "CellBase" 注释 = "<基类> 单元格CellBase，包含各种单元格：单元格（标题格、内容格）、自由表格子格">
    常量 列格 <公开 值 = "ColumnCell" 注释 = "<基类> 列格ColumnCell，包含：标题格、内容格">
    常量 标题格 <公开 值 = "ColumnTitleCell" 注释 = "标题格 ColumnTitleCell">
    常量 内容格 <公开 值 = "ColumnContentCell" 注释 = "内容格 ColumnContentCell">
    常量 部件框 <公开 值 = "Control" 注释 = "<基类> 部件框 所有部件框">
    常量 文字框 <公开 值 = "TextBox" 注释 = "<基类> 部件框_文字框：静态文字框StaticBox、系统变量框SystemVarBox、字段框FieldBox、统计框SummaryBox、综合文字框MemoBox">
    常量 静态文字框 <公开 值 = "StaticBox" 注释 = "静态文字框 StaticBox">
    常量 系统变量框 <公开 值 = "SystemVarBox" 注释 = "系统变量框 SystemVarBox">
    常量 字段框 <公开 值 = "FieldBox" 注释 = "字段框 FieldBox">
    常量 统计框 <公开 值 = "SummaryBox" 注释 = "统计框 SummaryBox">
    常量 综合文字框 <公开 值 = "MemoBox" 注释 = "综合文字框 MemoBox">
    常量 图形框 <公开 值 = "ShapeBox" 注释 = "图形框 ShapeBox">
    常量 RTF文字框 <公开 值 = "RichTextBox" 注释 = "RTF文字框 RichTextBox">
    常量 图像框 <公开 值 = "PictureBox" 注释 = "图像框 PictureBox">
    常量 子报表框 <公开 值 = "SubReport" 注释 = "子报表框 SubReport">
    常量 线段框 <公开 值 = "Line" 注释 = "线段框 Line">
    常量 条码框 <公开 值 = "Barcode" 注释 = "条码框 Barcode">
    常量 图表框 <公开 值 = "Chart" 注释 = "图表框 Chart">
    常量 图表轴 <公开 值 = "ChartAxis" 注释 = "图表轴 ChartAxis">
    常量 图表序列 <公开 值 = "ChartSeries" 注释 = "图表序列 ChartSeries">
    常量 自由表格框 <公开 值 = "FreeGrid" 注释 = "自由表格框 FreeGrid">
    常量 自由表格行 <公开 值 = "FreeGridRow" 注释 = "自由表格行 FreeGridRow">
    常量 自由表格列 <公开 值 = "FreeGridColumn" 注释 = "自由表格列 FreeGridColumn">
    常量 自由表格子格 <公开 值 = "FreeGridCell" 注释 = "自由表格子格 FreeGridCell">
}

类 报表类属性组枚举 <公开 注释 = "Class类对象属性项里某一属性组文本(帮助文件里面查不到的信息)，便于设计器属性栏操作枚举的部分接口。" @常量类 = 文本型>
{
    常量 边框 <公开 值 = "Border">
    常量 位置 <公开 值 = "Location">
    常量 大小 <公开 值 = "Size">
    常量 边距 <公开 值 = "Padding">
    常量 对齐明细列 <公开 值 = "AlignDetailColumn">
    常量 文字格式 <公开 值 = "TextFormatGroup">
    常量 财务金额线 <公开 值 = "MoneyLine">
    常量 文档格式 <公开 值 = "DocFormat" 注释 = "报表">
    常量 设计栅格点 <公开 值 = "DesignGrid" 注释 = "报表">
    常量 共享打印设置 <公开 值 = "SharePrintSetupOption" 注释 = "报表">
}
