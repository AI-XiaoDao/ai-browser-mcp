类 锁定类别枚举 <公开 注释 = "GRLockType 说明：除1，2两项外，其它项按从弱到强的顺序锁定控制对象，后一项包括前一项的锁定权限。报表主对象设置为“锁定继承”等同于“不锁定”。" @常量类 = 整数>
{
    常量 不锁定 <公开 值 = 0 注释 = "0 grltNone，指定对象没有锁定，可以全部权限进行设计。">
    常量 锁定继承 <公开 值 = 1 注释 = "1 grltInherited，指定对象的锁定控制来自父级对象，与父级对象保持一样的锁定控制。">
    常量 锁定对象 <公开 值 = 2 注释 = "2 grltObject，指定对象自身不能删除，其子对象不能删除与增加。如记录集锁定对象后，现有的字段不能删除，也不能增加新的字段。">
    常量 锁定数据 <公开 值 = 3 注释 = "3 grltData，在锁定对象的基础上，再增加对象的数据相关的属性锁定控制，如明细网格不能改变数据连接串与查询SQL，字段框不能修改关联的“数据字段”。">
    常量 锁定数据行为 <公开 值 = 4 注释 = "4 grltDataAction，在锁定数据的基础上，再增加对报表生成行为相关的锁定控制，主要体现为不能编辑“行为”与“脚本”类别的属性设置。">
    常量 完全锁定 <公开 值 = 5 注释 = "5 grltAll，对象完全不能编辑修改。">
}

类 边框模式枚举 <公开 注释 = "GRBorderStyles (组合值)，指定是否画部件框的上下左右边框线的组合方式。" "">
{
    常量 画左 <公开 类型 = 整数 值 = 1 注释 = "1 grbsDrawLeft 部件框或明细网格显示左边边框线。">
    常量 画上 <公开 类型 = 整数 值 = 2 注释 = "2 grbsDrawTop 部件框或明细网格显示上边边框线。">
    常量 画右 <公开 类型 = 整数 值 = 4 注释 = "4 grbsDrawRight 部件框或明细网格显示右边边框线。">
    常量 画下 <公开 类型 = 整数 值 = 8 注释 = "8 grbsDrawBottom 部件框或明细网格显示下边边框线。">
}

类 锚定方式枚举 <公开 注释 = "GRAnchorStyles (组合值)，指定部件框如何锚定到其容器的边缘。" 注释 = "如果将部件框锚定到其容器的边缘，当调整该容器的大小时，该部件框与指定边缘间的距离保持不变。"
        注释 = "例如，如果将控件锚定到其容器的右边缘，则当调整该容器的大小时，该控件的右边缘与容器的右边缘之间的距离保持不变。"
        注释 = "可以将控件锚定到任何控件边缘的组合上。如果将控件锚定到其容器的相对边缘上（例如，锚定到顶部和底部），当调整容器的大小时，控件大小就会随之改变。" "">
{
    常量 左边 <公开 类型 = 整数 值 = 1 注释 = "1 grasLeft 该部件框锚定到其容器的左边缘。">
    常量 上边 <公开 类型 = 整数 值 = 2 注释 = "2 grasTop 该部件框锚定到其容器的上边缘。">
    常量 右边 <公开 类型 = 整数 值 = 4 注释 = "4 grasRight 该部件框锚定到其容器的右边缘。">
    常量 下边 <公开 类型 = 整数 值 = 8 注释 = "8 grasBottom 该部件框锚定到其容器的下边缘。">
}

类 停靠方式枚举 <公开 注释 = "GRDockStyle 指定部件框停靠的位置和方式。" 注释 = "当部件框停靠到其容器的一条边缘时，调整容器的大小时，始终使部件框与那条边缘对齐。"
        注释 = "如果多个部件框停靠到一条边缘，那么这些部件框将按照它们的 Z 顺序并排出现，部件框在 Z 顺序中的位置越高，距离容器边缘就越远。"
        注释 = "如果选择了 Left、Right、Top 或 Bottom，则调整部件框的指定边缘和相对边缘的尺寸至包含部件框的相应边缘的尺寸。" 注释 = "如果选择了 Fill，则调整部件框的所有四条边以匹配包含部件框的边缘。"
        @常量类 = 整数>
{
    常量 无 <公开 值 = 0 注释 = "0 grdsNone 该部件框未停靠">
    常量 左边 <公开 值 = 1 注释 = "1 grdsLeft 该部件框的左边缘停靠在父容器的左边缘。">
    常量 上边 <公开 值 = 2 注释 = "2 grdsTop 该部件框的上边缘停靠在父容器的顶端。">
    常量 右边 <公开 值 = 3 注释 = "3 grdsRight 该部件框的右边缘停靠在父容器的右边缘。">
    常量 下边 <公开 值 = 4 注释 = "4 grdsBottom 该部件框的下边缘停靠在父容器的底部。">
    常量 充满 <公开 值 = 5 注释 = "5 grdsFill 部件框的各个边缘分别停靠在父容器的各个边缘,并且适当调整大小。">
}

类 伸展位移枚举 <公开 注释 = "GRShiftMode 指定部件框在其上部的部件框自动伸展高度时在垂直方向进行平移的方式。" @常量类 = 整数>
{
    常量 不进行位移 <公开 值 = 1 注释 = "1 grsmNever 不进行位移。">
    常量 总是进行位移 <公开 值 = 2 注释 = "2 grsmAlways 总是进行位移。">
    常量 重叠时位移 <公开 值 = 3 注释 = "3 grsmWhenOverLapped 只有与上部部件框在垂直方向有重叠时才进行位移。">
}

类 居中方式枚举 <公开 注释 = "GRCenterStyle 指定用来在容器中居中对齐部件框的方式。" @常量类 = 整数>
{
    常量 不应用 <公开 值 = 0 注释 = "0 grcsNone 部件框在父容器中不居中对齐。">
    常量 水平 <公开 值 = 1 注释 = "1 grcsHorizontal 部件框始终位于父容器水平方向的正中间。">
    常量 垂直 <公开 值 = 2 注释 = "2 grcsVertical 部件框始终位于父容器垂直方向的正中间。">
    常量 水平垂直 <公开 值 = 3 注释 = "3 grcsBoth 部件框始终位于父容器水平与垂直方向的正中间。">
}

