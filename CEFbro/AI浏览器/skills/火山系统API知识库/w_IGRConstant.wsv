类 系统变量枚举 <公开 注释 = "GRSystemVarType 指定系统变量部件框应用的系统变量类型。"
        注释 = "grsvPageCount(页数)，grsvPageNumber(页号)，grsvGroupPageCount(分组页数)，grsvGroupPageNo(分组页号)等打印页面相关的系统变量只在产生打印页面数据时有效，在查询显示报表时，应避免对这些系统变量的使用。"
        注释 = "关于分组相关的系统变量必须通过序号指定对应的分组。" 注释 = "如果是在表达式的系统变量函数中，或接口调用 SystemVarValue2 方法中，通过参数提供分组序号。如果是系统变量框，通过“分组序号”属性指定分组。"
        注释 = "分组相关的系统变量如下：" 注释 = "grsvGroupNo(分组序号)" 注释 = "grsvGroupCount(分组数)" 注释 = "grsvGroupRowNo(分组项行号)"
        注释 = "grsvGroupRowCount(分组项行数)" 注释 = "grsvGroupPageNo(分组项页号)" 注释 = "grsvGroupPageCount(分组项页数)" 注释 = "关于分组页号与页数的更进一步说明："
        注释 = "1、为了产生分组页号与页数信息，必须设置对应分组头与分组尾的“可见性”属性为“是”，且其“高度”属性值大于0。"
        注释 = "2、如果实际不需要显示分组头与分组尾，可以在其“格式化脚本”上写脚本代码“Sender.Visible = false;”，这样可以在运行时将分组头与分组尾隐藏不显示。"
        注释 = "3、分组页号页数在查询显示报表时不会得到正确的值，所以不应在查询显示报表时显示分组页号页数。" @常量类 = 整数>
{
    常量 当前日期时间 <公开 值 = 1 注释 = "1 grsvCurrentDateTime 计算机的当前日期时间。">
    常量 总页数 <公开 值 = 2 注释 = "2 grsvPageCount 总页数。">
    常量 当前页号 <公开 值 = 3 注释 = "3 grsvPageNumber 当前页号。">
    常量 记录号 <公开 值 = 4 注释 = "4 grsvRecordNo 明细记录的当前记录号,从1开始计数。">
    常量 行号 <公开 值 = 8 注释 = "8 grsvRowNo 明细网格的当前行号,从1开始计数。">
    常量 分组项序号 <公开 值 = 9 注释 = "9 roupOrderNo 分组项序号,最内层分组的项序号 6.0转移至SystemVarValue2，这里也可用。">
    常量 记录数 <公开 值 = 19 注释 = "19 grsvRecordCount 明细记录的记录数。">
}

类 分组变量枚举 <公开 注释 = "SystemVarValue2 获取的分组变量"
        注释 = "如果是在表达式的系统变量函数中，或接口调用 SystemVarValue2 方法中，通过参数提供分组序号。如果是系统变量框，通过“分组序号”属性指定分组。" 注释 = "分组相关的系统变量如下："
        注释 = "grsvGroupNo(分组序号)" 注释 = "grsvGroupCount(分组数)" 注释 = "grsvGroupRowNo(分组项行号)" 注释 = "grsvGroupRowCount(分组项行数)"
        注释 = "grsvGroupPageNo(分组项页号)" 注释 = "grsvGroupPageCount(分组项页数)" 注释 = "关于分组页号与页数的更进一步说明："
        注释 = "1、为了产生分组页号与页数信息，必须设置对应分组头与分组尾的“可见性”属性为“是”，且其“高度”属性值大于0。"
        注释 = "2、如果实际不需要显示分组头与分组尾，可以在其“格式化脚本”上写脚本代码“Sender.Visible = false;”，这样可以在运行时将分组头与分组尾隐藏不显示。"
        注释 = "3、分组页号页数在查询显示报表时不会得到正确的值，所以不应在查询显示报表时显示分组页号页数。" @常量类 = 整数>
{
    常量 分组序号 <公开 值 = 20 注释 = "20 grsvGroupNo，分组序号，某个分组内的序号，与分组项个数关联，序号从1开始">
    常量 分组项数 <公开 值 = 21 注释 = "21 grsvGroupCount，分组数，某个分组产生的分组项个数（全程变量，全程统一值）">
    常量 分组项行号 <公开 值 = 22 注释 = "22 grsvGroupRowNo，分组项行号，在一个分组内重启序号，序号从1开始">
    常量 分组项行数 <公开 值 = 23 注释 = "23 grsvGroupRowCount，分组项行数，某个分组项包含的明细记录(行)数">
    常量 分组项页号 <公开 值 = 24 注释 = "24 grsvGroupPageNo，分组项页号">
    常量 分组项页数 <公开 值 = 25 注释 = "25 grsvGroupPageCount，分组项页数">
}

类 分组保持同页方式枚举 <公开 注释 = "GRGrpKpTogetherStyle 指定分组头行与本分组项其他行在打印输出时聚集在相同页的方式。" @常量类 = 整数>
{
    常量 不应用 <公开 值 = 1 注释 = "1 grgktsNone 不要求分组头行与本分组项其他行打印输出聚集在相同页。">
