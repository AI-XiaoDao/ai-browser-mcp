类 对齐列枚举 <公开 注释 = "对齐到明细网格的左右专用，可以和列名称一样使用。" @常量类 = 文本型>
{
    常量 表格左端 <公开 值 = "(GridLeft)" 注释 = "用于部件框“对齐列”属性，可以指定对齐到明细网格的左端">
    常量 表格右端 <公开 值 = "(GridRight)" 注释 = "用于部件框“对齐列”属性，可以指定对齐到明细网格的右端">
}

类 背景模式枚举 <公开 注释 = "GRBackStyle 指定部件再显示时用来填充其所占区域背景的方式。" @常量类 = 整数>
{
    常量 填充 <公开 值 = 1 注释 = "1 grbkNormal 部件框使用背景色填充他占据的矩形区域。">
    常量 透明 <公开 值 = 2 注释 = "2 grbkTransparent 部件框背景透明,允许任何背景图像或其他部件框透过自身显示。">
}

类 打印类别枚举 <公开 注释 = "GRPrintType" 注释 = "包括两种打印类别：报表表单数据（Form），报表内容数据（Content）。"
        注释 = "打印生成时，如果指定打印生成方式（PrintGenerateStyle）为只输出报表内容数据（OnlyContent）,则只输出打印类别为报表内容数据的报表元素，其它打印类别为报表表单数据的报表元素将不会输出。"
        注释 = "在只输出报表内容数据时，报表节的背景色不会填充，明细网格的边框线与行列线也不会输出。在只输出报表内容数据的打印生成方式特别适用于进行票据套打与现存格式报表的套打。"
        注释 = "打印生成时，如果指定印生成方式（PrintGenerateStyle）为输出报表表单数据（OnlyForm）,生成方式与只输出报表内容数据（OnlyContent）反之对应。在此种方式下，明细网格的记录数据不会应用到，明细行的生成与明细记录不对应，不填充明细记录页可以输出报表表单数据。"
        注释 = "报表表单数据一般只生成一页，用来制作票据与固定格式报表的印刷模版。" 注释 = "打印生成时，如果指定印生成方式（PrintGenerateStyle）为输出全部数据（All）,则所有数据都会输出，这也是我们平时最多用到的方式。"
        注释 = "可以指定打印类别的报表元素包括部件框，明细网格标题格，明细网格内容格。" @常量类 = 整数>
{
    常量 表单 <公开 值 = 1 注释 = "1 grptForm 表单固定数据,在套打输出内容时不输出。">
    常量 内容 <公开 值 = 2 注释 = "2 grptContent 表单内容数据,在套打输出内容时输出。">
}

类 光标类型枚举 <公开 注释 = "GRDisplayCursor 指定查询显示报表时,可供使用的鼠标光标类型。" @常量类 = 整数>
{
    常量 默认光标 <公开 值 = 0 注释 = "0 grdcDefault">
    常量 普通箭头光标 <公开 值 = 1 注释 = "1 grdcArrow">
    常量 放大镜光标 <公开 值 = 2 注释 = "2 grdcMagnify">
    常量 手指光标 <公开 值 = 3 注释 = "3 grdcFinger">
    常量 肯定光标 <公开 值 = 4 注释 = "4 grdcAffirm">
    常量 否定光标 <公开 值 = 5 注释 = "5 grdcNegative">
}

类 文字方向枚举 <公开 注释 = "GRTextOrientation 指定综合文字框的各种文字行向。" @常量类 = 整数>
{
    常量 默认 <公开 值 = 0 注释 = "0 grtoDefault 默认方式,按从左到右,从上到下方式显示文字。">
    常量 从上至下从左至右0 <公开 值 = 5 注释 = "5 grtoU2DL2R0 按从上到下,从左到右方式显示文字,文字不旋转。">
    常量 从上至下从右至左0 <公开 值 = 9 注释 = "9 grtoU2DR2L0 按从上到下,从右到左方式显示文字,文字不旋转。">
    常量 从下至上从左至右1 <公开 值 = 22 注释 = "22 grtoD2UL2R1 按从下到上,从左到右方式显示文字,文字旋转。">
    常量 从上至下从右至左1 <公开 值 = 25 注释 = "25 grtoU2DR2L1 按从上到下,从右到左方式显示文字,文字旋转。">
    常量 从左到右从下到上脊背模式 <公开 值 = 38 注释 = "38 grtoL2RD2U0 按从左到右,从下到上方式显示文字,适合用来进行脊背打印,字体应该选择旋转的,即字体名称前带\'@\'符号。">
    常量 从左到右从下到上且旋转 <公开 值 = 54 注释 = "54 grtoL2RD2U1 按从左到右,从下到上方式显示文字,文字旋转,适合用来进行脊背打印。">
    常量 镜像翻转 <公开 值 = 58 注释 = "58 grtoInvert倒影方式。">
}

