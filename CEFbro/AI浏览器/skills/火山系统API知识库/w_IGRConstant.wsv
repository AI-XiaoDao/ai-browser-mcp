类 事件_报表 <公开 注释 = "event 报表事件ID枚举，事件就是 Grid++Report 在运行时各种报表对象在执行特定的任务时所发出的消息，通知操作的发生。"
        注释 = "报表开发者通过对事件的响应处理，可以控制报表的行为，让 Grid++Report 完成特定的任务。">
{
    常量 初始化事件 <公开 类型 = 整数 值 = 1 注释 = "Initialize，在报表生成开始时触发。" 注释 = "在报表准备生成时触发，报表每生成一次触发一次本事件，此事件也是报表生成过程中最先触发的事件。"
            注释 = "可以在此事件中对报表进行定义，即可以改变报表模板数据，如重新载入报表模板数据，以编程的方式定义报表。"
            注释 = "在此事件中，可以将在其它事件中使用的对象接口指针或对象属性等数据用变量缓存下来，以供后面直接使用，提高程序运行效率。"
            注释 = "在除此事件之外的其它事件中，除了 SectionFormat 事件可以对事件触发节对象及其拥有的子对象的显示外观属性进行修改外，禁止对报表进行重新定义，即不允许增减报表对象与改变报表对象的属性。">
    常量 请求记录数据 <公开 类型 = 整数 值 = 2 注释 = "FetchRecord，在报表生成时且以推模式向报表提供数据，报表主对象请求数据时触发。"
            注释 = "如果没有定义数据库连接串与查询SQL，或指定在运行时不从数据库连接串与查询SQL设置中取得明细记录数据，则FetchRecord 事件在报表请求数据时触发，报表每生成一次触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "报表开发者必须响应此事件，且只能在此事件中向记录集填充记录。报表开发者使用记录集接口与字段接口的属性与方法向记录集填充记录。"
            注释 = "注意：Delphi 与 C++Builder 的包装类定义了一个 DataSet 属性，并对 FetchRecord 事件在包装类中进行了响应，如果设置了 DataSet 属性值，则会把 DataSet 属性关联记录集对象中的数据填入到 Grid++Report 中。"
            注释 = "因此在Delphi 与 C++Builder 中一般通过设置 DataSet 属性来提供明细记录数据。">
    常量 提交记录前 <公开 类型 = 整数 值 = 3 注释 = "BeforePostRecord，在向报表中填入记录数据的过程中，每当提交一条记录之前触发本事件。"
            注释 = "在每提交一条记录时，触发一次本事件。报表开发者可以在此事件中设定各个字段的值，这样就可以对记录数据进行最后的调整。" 注释 = "如某些字段的值不能直接从数据源中的得来，而是根据一定的运算求得，则可以在此事件中处理。"
            注释 = "不管是根据查询SQL取得的数据，还是通过 FetchRecord 事件提供的数据，在每提交一条记录之前都会触发本事件。">
    常量 排序前 <公开 类型 = 整数 值 = 4 注释 = "BeforeSort，当要对记录集中的记录进行重新排序之前触发本事件。在此事件中可以重新设置明细记录集的 SortFields 属性，随后排序将按新设定的字段进行。"
            注释 = "如果报表的记录集指定了排序字段，在 ProcessBegin 之前会触发 BeforeSort 事件。">
    常量 运行时错误 <公开 类型 = 整数 值 = 5 注释 = "RuntimeError，">
    常量 "//单元格显示文字" <类型 = 整数 注释 = "CellGetDisplayText，当单元格对象准备生成显示文本时触发。本事件在设计器里存在，但没有事件接口，可能是为了保持代码兼容性吧。标题格、内容格、自由表格子格">
    常量 请求字段显示文字 <公开 类型 = 整数 值 = 20 注释 = "FieldGetDisplayText，当字段对象准备生成其显示文本时触发。"
            注释 = "报表在输出显示时，当部件框需要取关联字段的显示文本时触发本事件。在此事件中可以对触发事件的字段对象的显示文本(DisplayText)属性赋值，使字段的显示文本是报表开发者自定义的。"
            注释 = "例如在财务报表中，需要将负数用红字显示，就可以在此事件处理函数中将负号从显示文本中去掉，在 SectionFormat 事件处理函数中将对应显示部件框的前景色(ForeColor)设为红色。"
            注释 = "注意：FieldGetDisplayForamt 事件会频繁触发，在此事件中不应该执行运行开销大的任务，在此事件响应函数中使用的对象接口指针最好在 Initialize 事件处理函数中缓存到变量中。">
    常量 请求文字框显示文字 <公开 类型 = 整数 值 = 22 注释 = "TextBoxGetDisplayText，当文字类型的部件框准备生成其显示文本时触发。（20190910发现也包含：标题格、内容格、自由表格子格）"
            注释 = "报表在输出显示时，当文字部件输出文字时触发本事件。在此事件中可以对触发事件的文字部件框对象的显示文本(DisplayText)属性赋值，使显示文本是报表开发者自定义的。"
            注释 = "此事件类同 FieldGetDisplayText。">
    常量 格式化报表节 <公开 类型 = 整数 值 = 23 注释 = "SectionFormat，当报表节在输出之前触发。包括查询显示与打印生成显示。"
            注释 = "在每个报表节即将显示之前触发。当报表输出在查询显示器中，每当窗口要进行自画时，当前可见的节在显示时会触发本事件，节如果是重复显示的，同一节还会多次触发。"
            注释 = "当报表在打印或打印预览时，首先要生成打印页面数据，在页面中显示每个节之前触发本事件。可以通过取报表的当前显示状态（DispalyMode）属性确定事件是由查询显示器自画时触发，还是由生成打印页面时触发。"
            注释 = "注意：SectionForamt 事件会频繁触发，在此事件中不应该执行运行开销大的任务，在此事件响应函数中使用的对象接口指针最好在 Initialize 事件处理函数中缓存到变量中。">
    常量 部件框自定义绘制 <公开 类型 = 整数 值 = 24 注释 = "ControlCustomDraw，报表部件框自绘事件。">
    常量 图表请求数据 <公开 类型 = 整数 值 = 25 注释 = "ChartRequestData，当报表中的图表运行时，会触发本事件来请求加载图表数据。">
    常量 开始处理记录 <公开 类型 = 整数 值 = 30 注释 = "ProcessBegin，当报表准备对填入的数据进行分析处理之前触发本事件。"
            注释 = "报表在获得记录集的明细数据之后，会对明细数据进行运算处理。在开始处理之前触发 ProcessBegin 事件，在完成处理之时触发 ProcessEnd 事件。"
            注释 = "在 ProcessBegin 与 ProcessEnd 之间在处理每条明细数据时都会触发一次 ProcessRecord。">
    常量 结束处理记录 <公开 类型 = 整数 值 = 31 注释 = "ProcessEnd，当报表对填入的数据进行分析处理完成之后触发本事件。">
    常量 分组开始 <公开 类型 = 整数 值 = 32 注释 = "GroupBegin，在生成报表数据时，当定义了页分组，在开始生成明细网格关联的每一页时，每个页分组将触发一次本事件。"
            注释 = "报表在生成的过程中，会按顺序逐条处理每个记录，如果报表定义有分组，每当一个分组项开始时，触发 GroupBegin 事件，每当一个分组项结束时，触发 GroupEnd 事件。"
            注释 = "如果要对分组进行自定义的复杂统计，可以在 GroupBegin 事件函数中设定运算的初值，在 ProcessRecord 事件中对每条记录进行累积运算，在 GroupEnd 事件中对运算的结果进行最后的运算。">
    常量 分组结束 <公开 类型 = 整数 值 = 33 注释 = "GroupEnd，在生成报表数据时，当定义了页分组，在结束生成明细网格关联的每一页时，每个页分组将触发一次本事件。">
    常量 处理记录 <公开 类型 = 整数 值 = 34 注释 = "ProcessRecord，当报表生成时，会按顺序遍历每一条记录，每当遍历一条记录时触发本事件。"
            注释 = "报表在生成的过程中，会按顺序逐条处理每个记录，在每处理一条记录之前，都会触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "如果要对报表数据进行自定义的统计运算，就应该在此事件中取记录数据进行运算，将计算结果保存到参数对象或程序中的变量中。"
            注释 = "在此事件中可以调用 IGRDetailGrid 接口的 StartNewGroup 方法指定前一个分组项的结束与后一个分组项的开始，从而实现自定义的分组。">
    常量 页处理记录 <公开 类型 = 整数 值 = 35 注释 = "PageProcessRecord，当报表在生成打印数据时，会再次按顺序遍历每一条记录，每当遍历一条记录时触发本事件。此事件只有当报表将输出到打印机或打印预览时才会触发。"
            注释 = "报表在生成打印页面的过程中，会再次按顺序逐条处理每个记录，在每处理一条记录之前，都会触发一次本事件，只有具有明细网格的报表才会触发此事件。"
            注释 = "在页分组中，如果要对报表数据进行自定义的统计运算，就应该在此事件中取记录数据进行运算，将计算结果保存到参数对象或程序中的变量中。">
    常量 页开始 <公开 类型 = 整数 值 = 36 注释 = "PageStart，在开始生成每一页时，将触发一次本事件。"
            注释 = "如果进行打印页面数据生成，在每页开始时触发 PageStart 事件， 在每页结束时触发 PageEnd 事件。">
    常量 页结束 <公开 类型 = 整数 值 = 37 注释 = "PageEnd，在结束生成每一页时，将触发一次本事件。">
    常量 页面生成前 <公开 类型 = 整数 值 = 38 注释 = "GeneratePagesBegin，在产生打印页面数据之前触发本事件。">
    常量 页面生成后 <公开 类型 = 整数 值 = 39 注释 = "GeneratePagesEnd，在产生打印页面数据完成后触发本事件。">
    常量 打印前 <公开 类型 = 整数 值 = 40 注释 = "PrintBegin，在开始打印报表之前，触发本事件。">
    常量 打印后 <公开 类型 = 整数 值 = 41 注释 = "PrintEnd，在结束打印报表之后，触发本事件。">
    常量 打印页 <公开 类型 = 整数 值 = 42 注释 = "PrintPage，在打印每一页报表页面时触发本事件。">
    常量 打印中止 <公开 类型 = 整数 值 = 43 注释 = "PrintAborted，当打印任务中途取消时触发本事件。">
    常量 导出报表前 <公开 类型 = 整数 值 = 50 注释 = "ExportBegin，在报表导出任务执行之前触发本事件。"
            注释 = "在报表导出任务执行之前触发 ExportBegin 事件，在报表导出任务执行之后触发 ExportEnd 事件。在 ExportBegin 事件中可以改变导出选项，重新控制导出行为。">
    常量 导出报表后 <公开 类型 = 整数 值 = 51 注释 = "ExportEnd，在报表导出任务完成时触发本事件。">
    常量 显示预览界面 <公开 类型 = 整数 值 = 60 注释 = "ShowPreviewWnd，在显示默认打印预览窗口时触发本事件。可以在本事件响应中通过 IGRPrintViewer 控件接口对默认预览窗口进行自定义。">
    常量 显示设计界面 <公开 类型 = 整数 值 = 61 注释 = "ShowDesignerWnd，预留事件接口">
    常量 超链接文本被点击 <公开 类型 = 整数 值 = 65 注释 = "HyperlinkClick，预留事件接口">
}

