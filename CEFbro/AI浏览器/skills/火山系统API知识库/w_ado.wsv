类 数据库字段属性类型 <公开 注释 = "指定字段对象的一个或多个属性." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
    常量 缓存读取 <公开 类型 = 长整数 值 = 0x1000 注释 = "程序将会缓存字段值,后续的读取是从缓存中完成的.">
    常量 定长数据 <公开 类型 = 长整数 值 = 0x10 注释 = "字段包含固定长度数据.">
    常量 包含子集 <公开 类型 = 长整数 值 = 0x2000 注释 = "字段包含子集值.">
    常量 集合类型 <公开 类型 = 长整数 值 = 0x40000 注释 = "字段是由记录表示其他资源的集合.">
    常量 主键列 <公开 类型 = 长整数 值 = 0x8000 注释 = "字段是主键列的全部或部分.">
    常量 默认流 <公开 类型 = 长整数 值 = 0x20000 注释 = "字段包含由记录表示的资源的默认流.">
    常量 可接受空 <公开 类型 = 长整数 值 = 0x20 注释 = "字段接受NULL值.">
    常量 URL资源 <公开 类型 = 长整数 值 = 0x10000 注释 = "字段包含从记录表示的数据存储区中对资源进行命名的URL.">
    常量 大二进制 <公开 类型 = 长整数 值 = 0x80 注释 = "该字段是长二进制字段.">
    常量 可能为空 <公开 类型 = 长整数 值 = 0x40 注释 = "可能会从该字段中读到NULL值.">
    常量 已延迟 <公开 类型 = 长整数 值 = 0x2 注释 = "字段值不是从数据源中检索整个记录,而只是在显式访问字段值时进行检索.">
    常量 反比例 <公开 类型 = 长整数 值 = 0x4000 注释 = "字段值支持反比例列的数值.">
    常量 标识行 <公开 类型 = 长整数 值 = 0x100 注释 = "字段包含不能写入的持久性行标识符,并且除标识行(如记录号,唯一标识符)等之外没有有意义的值.">
    常量 版本行 <公开 类型 = 长整数 值 = 0x200 注释 = "字段包含用于标识更新的时间戳或日期值.">
    常量 未知状态 <公开 类型 = 长整数 值 = 0x8 注释 = "提供程序无法确定是否可以写入字段.">
    常量 可写入 <公开 类型 = 长整数 值 = 0x4 注释 = "表示该字段支持写入.">
    常量 无 <公开 类型 = 长整数 值 = -1 注释 = "未指定字段属性.">
}

