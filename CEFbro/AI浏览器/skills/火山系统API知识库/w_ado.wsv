    }

    方法 批更新 <公开 类型 = 逻辑型 注释 = "将记录集对象中所做的所有更改传输到数据库." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 范围选项 <类型 = 整数 注释 = "指定该更新操作会影响到的记录,请参考\"数据库影响记录选项\"." @默认值 = 数据库影响记录选项.所有>
    {
        返回 (无返回值方法 ("UpdateBatch", 范围选项))
    }

    方法 类_初始化
    {
        创建 ("ADODB.recordset")
        事件对象.挂接 (本对象, "{00000266-0000-0010-8000-00AA006D2EA4}")
    }

    方法 初始化事件挂接 <注释 = "该方法用于挂接外部传入对象构造时挂接事件">
    参数 构造参数 <类型 = COM对象类>
    {
        事件对象.挂接 (本对象, "{00000266-0000-0010-8000-00AA006D2EA4}")  // 这里不能用类_初始化去挂接
    }

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        如果 (事件对象 == 来源对象)
        {
            如果 (事件方法ID == 0x00000011)  // EndOfRecordset
            {
                事件返回值.赋值 (已超出数据范围 (事件参数.取成员 (0).取值 (逻辑型), 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000013)  // FetchComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (数据检索已完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000012)  // FetchProgress
            {
                事件返回值.赋值 (数据检索进度改变 (事件参数.取成员 (0).取值 (长整数), 事件参数.取成员 (1).取值 (长整数), 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000009)  // WillChangeField
            {
                变量 参数变体 <类型 = COM变体型>
                事件参数.取成员 (1).取变体型 (参数变体)
                事件返回值.赋值 (字段即将被更改 (事件参数.取成员 (0).取值 (长整数), 参数变体, 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000a)  // FieldChangeComplete
            {

                变量 参数变体 <类型 = COM变体型>
                事件参数.取成员 (1).取变体型 (参数变体)
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (2).取COM对象 (错误返回)
                事件返回值.赋值 (字段已更改完毕 (事件参数.取成员 (0).取值 (长整数), 参数变体, 错误返回, 事件参数.取成员 (3).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000b)  // WillChangeRecord
            {
                事件返回值.赋值 (记录即将被更改 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (长整数), 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000c)  // RecordChangeComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (2).取COM对象 (错误返回)
                事件返回值.赋值 (记录已更改完毕 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (长整数), 错误返回, 事件参数.取成员 (3).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000d)  // WillChangeRecordset
            {
                事件返回值.赋值 (记录集即将被更改 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000e)  // RecordsetChangeComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (1).取COM对象 (错误返回)
                事件返回值.赋值 (记录集已更改完毕 (事件参数.取成员 (0).取值 (整数), 错误返回, 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x0000000f)  // WillMove
            {
                事件返回值.赋值 (位置即将被移动 (事件参数.取成员 (0).取值 (整数), 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000010)  // MoveComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (1).取COM对象 (错误返回)
                事件返回值.赋值 (位置已移动完毕 (事件参数.取成员 (0).取值 (整数), 错误返回, 事件参数.取成员 (2).取值 (整数)))
            }
        }
        返回 (0)
    }

