类 数据库字段状态类型 <公开 注释 = "表示一个字段的状态." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
    常量 已存在 <公开 类型 = 长整数 值 = 26 注释 = "表示指定字段已存在.">
    常量 状态无效 <公开 类型 = 长整数 值 = 12 注释 = "表示从ADO发送到OLEDB提供程序的状态值无效.">
    常量 无法完成 <公开 类型 = 长整数 值 = 20 注释 = "由源指定的URL服务器无法完成操作.">
    常量 源无法删除 <公开 类型 = 长整数 值 = 23 注释 = "在移动操作过程中,树或子树已移动到新位置,但无法删除该源.">
    常量 无法检索字段 <公开 类型 = 长整数 值 = 2 注释 = "无法检索或存储字段,不会丢失数据.">
    常量 无法创建 <公开 类型 = 长整数 值 = 7 注释 = "未能添加字段,因为提供程序超出了允许的字段数.">
    常量 数据溢出 <公开 类型 = 长整数 值 = 6 注释 = "从提供程序返回的数据溢出了字段的数据类型.">
    常量 默认值 <公开 类型 = 长整数 值 = 13 注释 = "在设置数据时使用了字段的默认值.">
    常量 不存在 <公开 类型 = 长整数 值 = 16 注释 = "表示指定字段不存在.">
    常量 忽略置值 <公开 类型 = 长整数 值 = 15 注释 = "在设置数据时跳过了该字段.">
    常量 派生实体 <公开 类型 = 长整数 值 = 10 注释 = "无法修改字段,因为它是计算实体或派生实体.">
    常量 无效字符 <公开 类型 = 长整数 值 = 17 注释 = "数据源URL包含无效字符.">
    常量 空值 <公开 类型 = 长整数 值 = 3 注释 = "提供程序返回VT_NULL类型的变量值.">
    常量 成功 <公开 类型 = 长整数 值 = 0 注释 = "已成功添加或删除字段.">
    常量 内存不足 <公开 类型 = 长整数 值 = 22 注释 = "提供程序无法获得足够的存储空间来完成移动或复制操作.">
    常量 即将修改 <公开 类型 = 长整数 值 = 0x40000 注释 = "字段的值或者数据类型在调用更新后会被修改.">
    常量 即将删除 <公开 类型 = 长整数 值 = 0x20000 注释 = "字段在调用更新后会被删除.">
    常量 即将插入 <公开 类型 = 长整数 值 = 0x10000 注释 = "在字段集合中新增的字段,调用更新后会被加入.">
    常量 未知预操作 <公开 类型 = 长整数 值 = 0x80000 注释 = "无法确定字段即将会有何状态.">
    常量 未知操作删除 <公开 类型 = 长整数 值 = 0x100000 注释 = "无法确定何种操作导致字段即将被删除,更新后字段会被删除.">
    常量 权限不足 <公开 类型 = 长整数 值 = 9 注释 = "权限不足无法修改字段,可能当前字段权限为只读.">
    常量 只读 <公开 类型 = 长整数 值 = 24 注释 = "表示字段被定义为只读状态.">
    常量 资源已存在 <公开 类型 = 长整数 值 = 19 注释 = "提供程序无法执行该操作,因为目标URL中已存在一个对象,且该对象不能被覆盖.">
    常量 资源已锁定 <公开 类型 = 长整数 值 = 18 注释 = "提供程序无法执行该操作,因为数据源被一个或多个其他应用程序或进程锁定.">
    常量 超出记录范围 <公开 类型 = 长整数 值 = 25 注释 = "指示源或目标URL超出了当前记录的范围.">
    常量 违反架构约束 <公开 类型 = 长整数 值 = 11 注释 = "提供的值违反了字段的数据源架构约束.">
    常量 签名不匹配 <公开 类型 = 长整数 值 = 5 注释 = "提供程序返回的数据值已签名,但ADO字段值的数据类型未签名.">
    常量 数据被截断 <公开 类型 = 长整数 值 = 4 注释 = "在从数据源读取时,长度可变的数据被截断.">
    常量 值不可用 <公开 类型 = 长整数 值 = 8 注释 = "在从数据源读取时,提供程序无法确定该值.">
    常量 找不到储存卷 <公开 类型 = 长整数 值 = 21 注释 = "提供程序找不到URL所指示的存储卷.">
}

类 记录操作状态类型 <公开 注释 = "指定有关批更新和其他批量操作的记录的状态." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
    常量 已取消 <公开 类型 = 整数 值 = 0x100 注释 = "指示未修改记录,因为该操作已取消.">
    常量 无法释放 <公开 类型 = 整数 值 = 0x400 注释 = "指示未修改新记录,因为现有记录已锁定.">
    常量 并发冲突 <公开 类型 = 整数 值 = 0x800 注释 = "指示由于使用乐观并发而未修改记录.">
    常量 数据源已删除 <公开 类型 = 整数 值 = 0x40000 注释 = "指示已从数据源中删除记录.">
    常量 已删除 <公开 类型 = 整数 值 = 0x4 注释 = "指示记录已被删除.">
    常量 非完整数据 <公开 类型 = 整数 值 = 0x1000 注释 = "指示由于违法了数据完整约束而未修改记录.">
    常量 书签无效 <公开 类型 = 整数 值 = 0x10 注释 = "指示未修改记录,因为其书签无效.">
    常量 挂起太多 <公开 类型 = 整数 值 = 0x2000 注释 = "指示未修改记录,因为挂起的更改操作太多.">
    常量 已修改 <公开 类型 = 整数 值 = 0x2 注释 = "已修改记录.">
    常量 影响多个 <公开 类型 = 整数 值 = 0x40 注释 = "指示未修改记录,因为它会影响多个记录.">
    常量 新记录 <公开 类型 = 整数 值 = 0x1 注释 = "指示记录是新记录.">
    常量 储存对象冲突 <公开 类型 = 整数 值 = 0x4000 注释 = "指示由于与打开的存储对象冲突而未修改记录.">
    常量 成功 <公开 类型 = 整数 值 = 0 注释 = "指示已成功更新记录.">
    常量 内存不足 <公开 类型 = 整数 值 = 0x8000 注释 = "由于计算机内存不足而未修改记录.">
    常量 引用挂起 <公开 类型 = 整数 值 = 0x80 注释 = "指示未修改记录,因为它引用了挂起的插入.">
    常量 权限不足 <公开 类型 = 整数 值 = 0x10000 注释 = "指示未保存记录,因为用户没有足够的权限.">
    常量 违反基础结构 <公开 类型 = 整数 值 = 0x20000 注释 = "指示未保存记录,因为它违反了基础数据库的结构.">
    常量 未修改 <公开 类型 = 整数 值 = 0x8 注释 = "指示未修改记录.">
}

