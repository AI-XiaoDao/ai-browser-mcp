<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.数据库

类 数据库类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "基于ADO实现对各种不同数据库的访问,使用前确保系统中已安装ADO.">
{

    # //用作已有IUnknown*创建火山包装对象.
    # //vol_class_name:COM对象类名称
    # @begin
    # @ @def_macro DECLARE_ADO_COMOBJ(vol_class_name)    \
    # <>         <include>    \
    #         inline_ @dt<vol_class_name> (@dt<COM对象类>& obj) : @dt<vol_class_name> () { SetUnknownObject (obj.m_pUnknownObject); }    \
    #         inline_ void @an<_OnCleanupExtra> () { ReleaseUnknownObject(); }    \
    # <>         </include>
    #
    # //同上,提供一个额外的初始化方法,用于事件挂接
    # @ @def_macro DECLARE_ADO_COMOBJ_EXTRA_INIT(vol_class_name, init_method_name)    \
    # <>         <include>    \
    #         inline_ @dt<vol_class_name> (@dt<COM对象类>& obj) : @dt<vol_class_name> ()   \
    #         {    \
    #             SetUnknownObject (obj.m_pUnknownObject);    \
    #             @n<init_method_name>(obj);    \
    #         }    \
    #         inline_ void @an<_OnCleanupExtra> () { ReleaseUnknownObject(); }    \
    # <>         </include>
    #
    # @end

    变量 连接对象 <公开 类型 = COM对象类>
    变量 连接事件对象 <类型 = COM对象事件类>
    变量 连接文本内容 <类型 = 文本型>

    方法 执行超时 <公开 属性写 注释 = "设置该数据库对象等待命令执行所欲等待的时间.">
    参数 超时 <类型 = 整数 注释 = "单位:秒,提供0表示无超时一直等待.">
    {
        连接对象.写属性 ("CommandTimeout", 超时)
    }

    方法 执行超时 <公开 属性读 类型 = 整数 注释 = "获取该数据库对象等待命令执行所欲等待的时间.">
    {
        返回 (连接对象.读无参数属性 ("CommandTimeout", 整数))
    }

    方法 连接文本 <公开 属性写 注释 = "设置\"连接\"方法所欲使用的连接文本." 编辑时信息 = "7954D, 0, 0, 0" @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nGetODBCConnectStr\r\n0">
    参数 值 <类型 = 文本型 编辑时信息 = "7954D, 0, 0, 0">
    {
        连接文本内容 = 值
    }

    方法 连接文本 <公开 属性读 类型 = 文本型 注释 = "获取已设置的连接文本属性内容.">
    {
        返回 (连接文本内容)
    }

    方法 连接超时 <公开 属性写 注释 = "设置该数据库执行连接所欲等待的时间.">
    参数 超时 <类型 = 整数 注释 = "单位:秒,提供0表示无超时一直等待.">
    {
        连接对象.写属性 ("ConnectionTimeout", 超时)
    }

    方法 连接超时 <公开 属性读 类型 = 整数 注释 = "获取该数据库执行连接所欲等待的时间.">
    {
        返回 (连接对象.读无参数属性 ("ConnectionTimeout", 整数))
    }

    方法 当前状态 <公开 属性读 类型 = 整数 注释 = "获取当前数据库对象的工作状态." 返回值注释 = "请参考\"数据库状态类型\"所提供的常量.">
    {
        返回 (连接对象.读无参数属性 ("State", 整数))
    }

    方法 提供者名称 <公开 属性写 注释 = "设置数据库连接所欲使用的提供者,默认使用\"MSDASQL\".">
    参数 名称 <类型 = 文本型>
    {
        连接对象.写属性 ("Provider", 名称)
    }

    方法 提供者名称 <公开 属性读 类型 = 文本型 注释 = "获取数据库连接所欲使用的提供者.">
    {
        返回 (连接对象.读无参数属性 ("Provider", 文本型))
    }

    方法 版本信息 <公开 属性读 类型 = 文本型 注释 = "获取当前系统所使用的ADO版本号.">
    {
        返回 (连接对象.读无参数属性 ("Version", 文本型))
    }

    方法 游标服务位置 <公开 属性写 注释 = "指定游标服务位置,请参考\"数据库游标服务位置\"所提供的常量.">
    参数 游标位置 <类型 = 整数>
    {
        连接对象.写属性 ("CursorLocation", 游标位置)
    }

    方法 游标服务位置 <公开 属性读 类型 = 整数 注释 = "获取游标服务位置." 返回值注释 = "请参考\"数据库游标服务位置\"所提供的常量.">
    {
        返回 (连接对象.读无参数属性 ("CursorLocation", 整数))
    }

    方法 默认数据库 <公开 属性写 注释 = "设置当前对象的默认数据库,可以使用非限定语法的SQL命令来访问该默认数据库中的对象.">
    参数 库名 <类型 = 文本型>
    {
        连接对象.写属性 ("DefaultDatabase", 库名)
    }

    方法 默认数据库 <公开 属性读 类型 = 文本型 注释 = "获取当前对象的默认数据库.">
    {
        返回 (连接对象.读无参数属性 ("DefaultDatabase", 文本型))
    }

    方法 事务隔离级别 <公开 属性写 注释 = "设置所欲使用的事务隔离级别.">
    参数 级别 <类型 = 整数>
    {
        连接对象.写属性 ("IsolationLevel", 级别)
    }

    方法 事务隔离级别 <公开 属性读 类型 = 整数 注释 = "获取所使用的事务隔离级别." 返回值注释 = "请参考\"数据库事务隔离级别\"所提供的常量.">
    {
        返回 (连接对象.读无参数属性 ("IsolationLevel", 整数))
    }

    方法 权限模式 <公开 属性写 注释 = "设置数据库中数据的可用权限.">
    参数 模式 <类型 = 整数>
    {
        连接对象.写属性 ("Mode", 模式)
    }

    方法 权限模式 <公开 属性读 类型 = 整数 注释 = "获取数据库中数据的可用权限." 返回值注释 = "请参考\"数据库权限模式\"所提供的常量.">
    {
        返回 (连接对象.读无参数属性 ("Mode", 整数))
    }

    方法 取错误信息 <公开 类型 = 数据库错误集合类 注释 = "获取当前的错误集合." @禁止流程检查 = 真>
    {
        @ return @dt<数据库错误集合类>(@<连接对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Errors"), 0, _T ("")));
    }

    方法 取属性信息 <公开 类型 = 数据库属性集合类 注释 = "获取当前的属性集合." @禁止流程检查 = 真>
    {
        @ return @dt<数据库属性集合类>(@<连接对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Properties"), 0, _T ("")));
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "关闭当前已连接的数据库,并释放所关联的任何系统资源." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (连接对象.无参数及返回值方法 ("Close"))
    }

    方法 取消执行 <公开 类型 = 逻辑型 注释 = "取消执行挂起的异步方法调用." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (连接对象.无参数及返回值方法 ("Cancel"))
    }

    方法 开始事务 <公开 类型 = 整数 注释 = "开始一个新的事务." 返回值注释 = "返回事务的嵌套级别.">
    {
        返回 (连接对象.无参数方法 ("BeginTrans", 整数))
    }

    方法 保存事务 <公开 类型 = 逻辑型 注释 = "保存所有更改并结束当前事务." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (连接对象.无参数及返回值方法 ("CommitTrans"))
    }

    方法 回滚事务 <公开 类型 = 逻辑型 注释 = "取消在当前事务中所做的任何更改并结束事务." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (连接对象.无参数及返回值方法 ("RollbackTrans"))
    }

    方法 执行SQL <公开 类型 = 记录集类 注释 = "基于当前的数据库连接执行指定的查询或SQL语句." 返回值注释 = "注意:所返回的记录集对象为只读,只进,如果需要对数据集进行写入等操作请单独使用\"记录集类\"."
            @禁止流程检查 = 真>
    参数 语句内容 <类型 = 文本型 注释 = "提供所欲执行的SQL语句,例如:SELECT * FROM VOLDP">
    参数 选项 <类型 = 整数 注释 = "提供本次执行的可选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 影响行数 <类型 = 长整数类 注释 = "提供一个长整数变量以获取本次命令执行后,影响到表中的记录数量." @默认值 = 空对象>
    {
        变量 临时记录 <类型 = COM对象类>
        临时记录 = 连接对象.方法 ("Execute", COM对象类, 语句内容, 影响行数, 选项)
        @ return @dt<记录集类> (@<临时记录>);
    }

    方法 连接Mysql <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程Mysql数据库." 注释 = "注意:使用前确保系统中已安装对应的数据库驱动程序." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称.">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码.">
    参数 端口号 <类型 = 整数 注释 = "通过该数据库的连接端口." @默认值 = 3306>
    参数 驱动程序 <类型 = 文本型 注释 = "提供连接Mysql所需的驱动程序名称,例如\"MySQL ODBC 8.0 Unicode Driver\",使用前请确保系统中已安装该驱动,否则无法进行连接."
            注释 = "如果你安装了9.2版本的驱动,驱动名称为\"MySQL ODBC 9.2 Unicode Driver\",不同的驱动版本驱动名称可能不一致." 注释 = "如果无法确定可通过\"连接文本\"属性建立连接文本后获取驱动名称."
            注释 = "驱动下载地址:https://dev.mysql.com/downloads/connector/odbc/" @默认值 = "MySQL ODBC 8.0 Unicode Driver">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    {
        返回 (连接 ("Provider=MSDASQL; DRIVER=" + 驱动程序 + "; SERVER=" + 地址 + "; PORT=" + 到文本 (端口号) + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接))
    }

    方法 连接Oracle <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程Oracle数据库." 注释 = "注意:使用前确保系统中已安装对应的数据库驱动程序." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码.">
    参数 驱动程序 <类型 = 文本型 注释 = "提供连接Oracle所需的驱动程序名称,例如\"Oracle in OraClient11g_home1\",使用前请确保系统中已安装该驱动,否则无法进行连接."
            @默认值 = "Oracle in OraClient11g_home1">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    {
        返回 (连接 ("Provider=OraOLEDB.Oracle.1; DRIVER=" + 驱动程序 + "; SERVER=" + 地址, 用户名, 密码, , 异步连接))
    }

    方法 连接Access <公开 类型 = 逻辑型 注释 = "连接到指定Access数据库." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 文件路径 <类型 = 文本型 注释 = "提供数据库文件完整路径.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的用户密码." @默认值 = "">
    参数 是否新版 <类型 = 逻辑型 注释 = "本参数指定Access版本,为假则使用2003以下连接方式,为真则使用2007版本连接方式." @默认值 = 假>
    {
        如果 (是否新版)
        {
            返回 (连接 ("Provider=Microsoft.ACE.OLEDB.12.0; Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码))
        }
        否则
        {
            返回 (连接 ("Provider=Microsoft.Jet.OLEDB.4.0; Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码))
        }
    }

    方法 连接Mssql <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程Mssql数据库." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称.">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码.">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    参数 加密连接 <类型 = 逻辑型 注释 = "使用加密连接必须确保本地驱动为\"ODBC Driver 17 for SQL Server\"或以上版本" @默认值 = 假>
    {
        // 返回 (连接 ("Provider=SqlOleDB; SERVER=" + 地址 + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接))
        如果 (加密连接)
        {
            返回 (连接 ("DRIVER=ODBC Driver 17 for SQL Server; SERVER=" + 地址 + "; DATABASE=" + 数据库名 + "; Encrypt=yes; TrustServerCertificate=yes", 用户名, 密码, , 异步连接))
        }
        否则
        {
            返回 (连接 ("DRIVER=SQL Server; SERVER=" + 地址 + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接))
        }
    }

    方法 连接Postgresql <公开 类型 = 逻辑型 注释 = "开始连接到指定的远程PostgreSQL数据库." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址.">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称.">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码.">
    参数 端口号 <类型 = 整数 注释 = "通过该数据库的连接端口." @默认值 = 5432>
    参数 驱动程序 <类型 = 文本型 注释 = "指定是否使用ODBC驱动方式连接(例如:PostgreSQL UNICODE),提供空文本将会使用OLEDB方式连接,如果使用驱动方式连接,务必保证系统中已安装该驱动." @默认值 = "">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    {
        如果 (文本是否为空 (驱动程序))
        {
            返回 (连接 ("Provider=PostgreSQL OLE DB; Data Source=" + 地址 + "; location=" + 数据库名 + ";", 用户名, 密码, , 异步连接))
        }
        否则
        {
            返回 (连接 ("Provider=MSDASQL; DRIVER=" + 驱动程序 + "; SERVER=" + 地址 + "; PORT=" + 到文本 (端口号) + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接))
        }
    }

    方法 连接 <公开 类型 = 逻辑型 注释 = "开始连接到指定的数据库." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 连接文本 <类型 = 文本型
            注释 = "提供包含连接信息的一个文本,具体信息可参阅文档\"https://docs.microsoft.com/zh-cn/sql/ado/reference/ado-api/connectionstring-property-ado?view=sql-server-ver15\"."
            注释 = "如果本参数为空,将使用\"连接文本\"属性作为该参数的值,如果本参数提供非空内容,将会优先于\"连接文本\"属性." @默认值 = "">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名(如果连接文本中包含,此参数将会覆盖连接文本中的对应用户名信息)." @默认值 = "">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码(如果连接文本中包含,此参数将会覆盖连接文本中的对应密码信息)." @默认值 = "">
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    {
        如果 (是否客户端)
        {
            游标服务位置 = 数据库游标服务位置.客户端游标
        }
        变量 方式 <类型 = 整数>
        如果 (异步连接)
        {
            方式 = 16
        }
        否则
        {
            方式 = -1
        }
        如果 (文本是否为空 (连接文本))
        {
            连接文本 = 连接文本内容
        }
        返回 (连接对象.无返回值方法 ("Open", 连接文本, 用户名, 密码, 方式))
    }

    方法 取结构信息 <公开 类型 = 记录集类 注释 = "获取当前所连接数据库的结构信息." 返回值注释 = "返回包含该数据库的结构信息记录集." @禁止流程检查 = 真>
    参数 查询类型 <类型 = 整数 注释 = "提供所欲查询的类型,请参考\"数据库结构信息类型\"所提供的常量值.">
    {
        变量 返回记录 <类型 = COM对象类>
        返回记录 = 连接对象.方法 ("OpenSchema", COM对象类, 查询类型)
        @ return @dt<记录集类>(@<返回记录>);
    }

    方法 类_初始化
    {
        如果 (连接对象.创建 ("ADODB.Connection"))
        {
            连接事件对象.挂接 (连接对象, "{00000400-0000-0010-8000-00AA006D2EA4}")
        }
    }

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        如果 (来源对象 == 连接事件对象)  // 分发连接对象的事件
        {
            如果 (事件方法ID == 0x00000006)  // WillConnect
            {
                事件返回值.赋值 (即将开始连接 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (文本型), 事件参数.取成员 (2).取值 (文本型), 事件参数.取成员 (4).取值 (整数)))
            }
            否则 (事件方法ID == 0)  // InfoMessage
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (警告信息反馈 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000001)  // BeginTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (1).取COM对象 (错误返回)
                事件返回值.赋值 (开始事务完成 (事件参数.取成员 (0).取值 (整数), 错误返回, 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000003)  // CommitTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (提交事务完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000002)  // RollbackTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (回滚事务完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000004)  // WillExecute
            {
                事件返回值.赋值 (即将开始执行 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数), 事件参数.取成员 (3).取值 (整数), 事件参数.取成员 (4).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000005)  // ExecuteComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (1).取COM对象 (错误返回)
                变量 返回记录 <类型 = 记录集类>
                事件参数.取成员 (4).取COM对象 (返回记录)
                事件返回值.赋值 (命令执行完成 (事件参数.取成员 (0).取值 (整数), 返回记录, 错误返回, 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000007)  // ConnectComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (连接完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000008)  // Disconnect
            {
                事件返回值.赋值 (断开连接 (事件参数.取成员 (0).取值 (整数)))
            }
        }
        返回 (0)
    }

    方法 即将开始连接 <公开 定义事件 类型 = 整数 注释 = "即将发起数据库连接时,本事件将被调用.">
    参数 连接文本 <类型 = 文本型 注释 = "本次发起连接所使用的连接文本内容.">
    参数 用户名 <类型 = 文本型 注释 = "本次发起连接所使用的用户名.">
    参数 密码 <类型 = 文本型 注释 = "本次发起连接所使用的密码.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 即将开始执行 <公开 定义事件 类型 = 整数 注释 = "即将执行SQL命令时,本事件将被调用.">
    参数 命令内容 <类型 = 文本型 注释 = "即将执行的命令内容文本.">
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型\"所提供的常量值.">
    参数 编辑锁类型 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型\"所提供的常量值.">
    参数 选项值 <类型 = 整数 注释 = "执行命令或打开记录集所使用的选项值.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 警告信息反馈 <公开 定义事件 类型 = 整数 注释 = "在操作过程中如果出现警告信息,本事件将被调用.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 开始事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用.">
    参数 事务等级 <类型 = 整数 注释 = "本次事务的等级.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 提交事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 回滚事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 命令执行完成 <公开 定义事件 类型 = 整数 注释 = "在执行SQL命令后,执行完毕本事件将被调用.">
    参数 影响行数 <类型 = 整数 注释 = "执行该命令后被影响的记录数量.">
    参数 记录集 <类型 = 记录集类 注释 = "执行该命令后所获取到的记录集对象.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 连接完成 <公开 定义事件 类型 = 整数 注释 = "当执行连接数据库后,连接过程结束本事件将被调用.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 断开连接 <公开 定义事件 类型 = 整数 注释 = "与数据库断开连接后,本事件将被调用.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">
}

类 记录集类 <公开 基础类 = COM对象类 注释 = "表示数据表中的整个记录集或执行的命令的结果,可使用本类实例获取具体数据.">
{

    # @ @m<数据库类.DECLARE_ADO_COMOBJ_EXTRA_INIT>(记录集类, 初始化事件挂接)

    变量 事件对象 <类型 = COM对象事件类>

    方法 当前页 <公开 属性读 类型 = 变整数 注释 = "获取当前所处的页索引.">
    {
        返回 (读无参数属性 ("AbsolutePage", 变整数))
    }

    方法 当前页 <公开 属性写 注释 = "设置当前所处的页索引.">
    参数 索引 <类型 = 变整数>
    {
        写属性 ("AbsolutePage", 索引)
    }

    方法 当前位置 <公开 属性读 类型 = 变整数 注释 = "获取当前记录集所处的序号位置.">
    {
        返回 (读无参数属性 ("AbsolutePosition", 变整数))
    }

    方法 当前位置 <公开 属性写 注释 = "设置当前记录集所处的序号位置.">
    参数 位置 <类型 = 变整数>
    {
        写属性 ("AbsolutePosition", 位置)
    }

    方法 首记录前 <公开 属性读 类型 = 逻辑型 注释 = "判断当前记录位置是否处于首记录之前,通常用于判断该记录集是否存在数据.">
    {
        返回 (读无参数属性 ("BOF", 逻辑型))
    }

    方法 尾记录后 <公开 属性读 类型 = 逻辑型 注释 = "判断当前记录位置是否处于尾记录之后,通常用于判断当前位置后是否还存在更多记录.">
    {
        返回 (读无参数属性 ("EOF", 逻辑型))
    }

    方法 缓存数量 <公开 属性读 类型 = 整数 注释 = "获取当前记录集对象缓存到内存中的记录数量.">
    {
        返回 (读无参数属性 ("CacheSize", 整数))
    }

    方法 缓存数量 <公开 属性写 注释 = "设置当前记录集对象缓存到内存中的记录数量.">
    参数 数量 <类型 = 整数 注释 = "必须大于等于1.">
    {
        写属性 ("CacheSize", 数量)
    }

    方法 游标服务位置 <公开 属性写 注释 = "指定游标服务位置,请参考\"数据库游标服务位置\"所提供的常量.">
    参数 位置 <类型 = 整数>
    {
        写属性 ("CursorLocation", 位置)
    }

    方法 游标服务位置 <公开 属性读 类型 = 整数 注释 = "获取游标服务位置." 返回值注释 = "请参考\"数据库游标服务位置\"所提供的常量.">
    {
        返回 (读无参数属性 ("CursorLocation", 整数))
    }

    方法 游标类型 <公开 属性写 注释 = "指定所欲使用游标的类型,请参考\"记录集游标类型\"所提供的常量.">
    参数 类型 <类型 = 整数>
    {
        写属性 ("CursorType", 类型)
    }

    方法 游标类型 <公开 属性读 类型 = 整数 注释 = "获取所使用游标的类型." 返回值注释 = "请参考\"记录集游标类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("CursorType", 整数))
    }

    方法 编辑状态 <公开 属性读 类型 = 整数 注释 = "获取当前记录集的编辑状态." 返回值注释 = "请参考\"记录集编辑状态\"所提供的常量.">
    {
        返回 (读无参数属性 ("EditMode", 整数))
    }

    方法 书签 <公开 属性写 注释 = "在记录集的当前位置设置一个书签,即一个自定义标识符,后续移动不同的位置后,可通过该书签快速返回到标记书签的位置.">
    参数 值 <类型 = COM变体型 注释 = "提供一个自定义标记.">
    {
        写属性 ("Bookmark", 值)
    }

    方法 书签 <公开 属性读 类型 = COM变体型 注释 = "获取当前位置所设置的书签.">
    {
        返回 (读无参数属性 ("Bookmark", COM变体型))
    }

    方法 筛选器 <公开 属性写 注释 = "为当前记录集设置一个数据筛选器.">
    参数 筛选条件 <类型 = COM变体型 注释 = "本参数可包含以下项之一:" 注释 = "  条件语句内容:由一个或单独子语句组成,例如由AND或or运算符相连接." 注释 = "  书签数组:获取所有打上书签位置的数据."
            注释 = "  筛选组:请参考\"记录集筛选组类型\"所提供的常量.">
    {
        写属性 ("Filter", 筛选条件)
    }

    方法 筛选器 <公开 属性读 类型 = COM变体型 注释 = "获取当前记录集的筛选器.">
    {
        返回 (读无参数属性 ("Filter", COM变体型))
    }

    方法 索引名称 <公开 属性读 类型 = 文本型 注释 = "获取当前记录集对象索引名称.">
    {
        返回 (读无参数属性 ("Index", 文本型))
    }

    方法 索引名称 <公开 属性写 注释 = "设置当前记录集对象索引名称.">
    参数 名称 <类型 = 文本型>
    {
        写属性 ("Index", 名称)
    }

    方法 编辑锁类型 <公开 属性读 类型 = 整数 注释 = "获取当前记录集对象的编辑锁类型." 返回值注释 = "请参考\"记录集编辑锁类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("LockType", 整数))
    }

    方法 编辑锁类型 <公开 属性写 注释 = "设置当前记录集对象的编辑锁类型.">
    参数 类型 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型\"所提供的常量.">
    {
        写属性 ("LockType", 类型)
    }

    方法 数据封送选项 <公开 属性读 类型 = 整数 注释 = "获取当前记录集所设置的数据封送选项." 返回值注释 = "请参考\"记录集数据封送选项\"所提供的常量.">
    {
        返回 (读无参数属性 ("MarshalOptions", 整数))
    }

    方法 数据封送选项 <公开 属性写 注释 = "设置当前记录集所设置的数据封送(跨线程或进程边界打包和发送接口方法参数的过程)选项.">
    参数 选项 <类型 = 整数 注释 = "请参考\"记录集数据封送选项\"所提供的常量.">
    {
        写属性 ("MarshalOptions", 选项)
    }

    方法 最大记录数 <公开 属性读 类型 = 长整数 注释 = "获取该记录集所设置的最大记录数量限制.">
    {
        返回 (读无参数属性 ("MaxRecords", 长整数))
    }

    方法 最大记录数 <公开 属性写 注释 = "限定一个获取数据量的最大值,从数据源获取数据时将会受该属性限制.">
    参数 最大数量 <类型 = 长整数 注释 = "默认为0,表示无限制,将会返回所有记录.">
    {
        写属性 ("MaxRecords", 最大数量)
    }

    方法 页数 <公开 属性读 类型 = 长整数 注释 = "获取当前记录集所包含的页数.">
    {
        返回 (读无参数属性 ("PageCount", 长整数))
    }

    方法 单页记录数 <公开 属性读 类型 = 长整数 注释 = "获取当前记录集一个页所包含的记录数量,即页数据尺寸.">
    {
        返回 (读无参数属性 ("PageSize", 长整数))
    }

    方法 单页记录数 <公开 属性写 注释 = "设置当前记录集一个页所包含的记录数量.">
    参数 尺寸 <类型 = 长整数 注释 = "默认为10.">
    {
        写属性 ("PageSize", 尺寸)
    }

    方法 记录数量 <公开 属性读 类型 = 长整数 注释 = "获取该记录集所包含的记录数量(即数据行).">
    {
        返回 (读无参数属性 ("RecordCount", 长整数))
    }

    方法 排序规则 <公开 属性读 类型 = 文本型 注释 = "获取当前记录集对象所设置的排序规则.">
    {
        返回 (读无参数属性 ("Sort", 文本型))
    }

    方法 排序规则 <公开 属性写 注释 = "设置当前记录集对象的排序规则." 注释 = "注意:该属性将会优先于SQL语句的order by.">
    参数 规则 <类型 = 文本型 注释 = "例如记录集中包含有三个字段:\"firstName\",\"middle\",\"lastName\","
            注释 = "该参数内容为\"lastName DESC, firstName ASC\",此时该记录集将会按照lastName降序,firstName升序来排列,中间的middle被忽略.">
    {
        写属性 ("Sort", 规则)
    }

    方法 数据源 <公开 属性读 类型 = COM变体型 注释 = "获取当前记录集的数据源,通过\"打开\"方法指定.">
    {
        返回 (读无参数属性 ("Source", COM变体型))
    }

    方法 状态 <公开 属性读 类型 = 整数 注释 = "获取该记录集对象当前状态." 返回值注释 = "请参考\"数据库状态类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("State", 整数))
    }

    方法 记录状态 <公开 属性读 类型 = 整数 注释 = "获取该记录集批更新或执行了其他大容量操作记录的状态." 返回值注释 = "请参考\"记录操作状态类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("Status", 整数))
    }

    方法 保持同步 <公开 属性读 类型 = 逻辑型 注释 = "在多层记录集的情况下,是否与引用的其他层次保持数据更改同步.">
    {
        返回 (读无参数属性 ("StayInSync", 逻辑型))
    }

    方法 保持同步 <公开 属性写 注释 = "在多层记录集的情况下,是否与引用的其他层次保持数据更改同步.">
    参数 启用 <类型 = 逻辑型>
    {
        写属性 ("StayInSync", 启用)
    }

    方法 取字段列表 <公开 类型 = 数据库字段集合类 注释 = "获取该记录集当前位置所包含的所有字段(列)列表." @禁止流程检查 = 真>
    {
        @ return @dt<数据库字段集合类>(Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Fields"), 0, _T ("")));
    }

    方法 取属性信息 <公开 类型 = 数据库属性集合类 注释 = "获取当前记录集的属性集合." @禁止流程检查 = 真>
    {
        @ return @dt<数据库属性集合类>(Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Properties"), 0, _T ("")));
    }

    方法 添加空记录 <公开 类型 = 逻辑型 注释 = "如果当前记录集可写,该方法将添加一个新的空记录至当前记录集." 返回值注释 = "添加成功返回真,否则返回假.">
    {
        返回 (无参数及返回值方法 ("AddNew"))
    }

    方法 添加新记录 <公开 类型 = 逻辑型 注释 = "如果当前记录集可写,该方法将添加新的记录至当前记录集." 返回值注释 = "添加成功返回真,否则返回假.">
    参数 字段列表 <类型 = COM变体型数组类 注释 = "提供本次置入新记录的字段名称列表(或者可提供字段的整数索引列表),请置入字段名称的文本型数组或字段索引的整数数组."
            注释 = "注意:如果该参数提供空对象,将会按所提供的值列表成员依次对应字段索引置入其记录值." @默认值 = 空对象>
    参数 值列表 <类型 = COM变体型数组类 注释 = "提供本次置入新记录的值列表,对应\"字段列表\"参数.">
    {
        如果 (是否为空对象 (字段列表) && 是否为空对象 (值列表))
        {
            返回 (无参数及返回值方法 ("AddNew"))
        }
        否则 (是否为空对象 (值列表))  // 值列表为空,无意义.
        {
            返回 (假)
        }
        否则
        {
            变量 局_字段列表 <类型 = COM变体型>
            变量 局_值列表 <类型 = COM变体型>
            变量 字段数量 <类型 = 整数>
            如果 (是否为空对象 (字段列表))
            {
                字段数量 = 值列表.取成员数 ()
                @ INT* fieldList = new INT[@<字段数量>];
                @ for (INT i = 0; i < @<字段数量>; i++)
                @     fieldList[i] = i;
                @ @<局_字段列表>.CreateArray_INT(fieldList, @<字段数量>, 0, -1);
                @ delete[] fieldList;
            }
            否则
            {
                字段数量 = 字段列表.取成员数 ()
                @ CVolComVariant* fieldList = new CVolComVariant[@<字段数量>];
                @ for (INT i = 0; i < @<字段数量>; i++)
                @     fieldList[i] = (CVolComVariant&)@<字段列表>.GetAt (i);
                @ @<局_字段列表>.CreateArray_Variant(fieldList, @<字段数量>, 0, -1);
                @ delete[] fieldList;
            }
            变量 值数量 <类型 = 整数>
            值数量 = 值列表.取成员数 ()
            @ CVolComVariant* valueList = new CVolComVariant[@<值数量>];
            @ for (INT i = 0; i < @<值数量>; i++)
            @     valueList[i] = (CVolComVariant&)@<值列表>.GetAt (i);
            @ @<局_值列表>.CreateArray_Variant(valueList, @<值数量>, 0, -1);
            @ delete[] valueList;
            返回 (无返回值方法 ("AddNew", 局_字段列表, 局_值列表))
        }
    }

    方法 取消执行 <公开 类型 = 逻辑型 注释 = "取消执行挂起的异步方法调用." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (无参数及返回值方法 ("Cancel"))
    }

