    参数 值 <类型 = 小数 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.赋值 (值)
        返回 (写数据 (字段名, 写入值))
    }

    方法 写索引小数数据 <公开 类型 = 逻辑型 注释 = "根据指定字段的索引将指定小数数据写入该记录集当前所处位置." 返回值注释 = "返回是否执行成功.">
    参数 字段索引 <类型 = 整数 注释 = "提供所欲写入数据对应的字段索引位置.">
    参数 值 <类型 = 小数 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.赋值 (值)
        返回 (写索引数据 (字段索引, 写入值))
    }

    方法 读字节集数据 <公开 类型 = 字节集类 注释 = "根据指定字段名读取该记录集当前所处位置的字节集数据.">
    参数 字段名 <类型 = 文本型 注释 = "提供所欲获取数据对应的字段名称,例如:field1.">
    {
        变量 缓冲区 <类型 = 字节集类>
        读数据 (字段名).取字节集 (缓冲区)
        返回 (缓冲区)
    }

    方法 读索引字节集数据 <公开 类型 = 字节集类 注释 = "根据指定字段的索引读取该记录集当前所处位置的字节集数据.">
    参数 字段索引 <类型 = 整数 注释 = "提供所欲获取数据对应的字段索引位置.">
    {
        变量 缓冲区 <类型 = 字节集类>
        读索引数据 (字段索引).取字节集 (缓冲区)
        返回 (缓冲区)
    }

    方法 写字节集数据 <公开 类型 = 逻辑型 注释 = "根据指定字段名将指定字节集数据写入该记录集当前所处位置." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 字段名 <类型 = 文本型 注释 = "提供所欲写入数据对应的字段名称,例如:field1.">
    参数 值 <类型 = 字节集类 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.置字节集 (值)
        返回 (写数据 (字段名, 写入值))
    }

    方法 写索引字节集数据 <公开 类型 = 逻辑型 注释 = "根据指定字段的索引将指定字节集数据写入该记录集当前所处位置." 返回值注释 = "返回是否执行成功.">
    参数 字段索引 <类型 = 整数 注释 = "提供所欲写入数据对应的字段索引位置.">
    参数 值 <类型 = 字节集类 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.置字节集 (值)
        返回 (写索引数据 (字段索引, 写入值))
    }

    方法 添加字节集数据 <公开 类型 = 逻辑型 注释 = "将所指定字节集数据加入到记录集中当前位置处指定名称字段的数据尾部." 注释 = "注意:本方法适用与添加较大的二进制数据,且仅在数据库字段支持\"大二进制\"属性时可用."
            返回值注释 = "执行成功返回真,否则返回假.">
    参数 字段名 <类型 = 文本型 注释 = "提供所欲写入数据对应的字段名称,例如:field1.">
    参数 值 <类型 = 字节集类 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.置字节集 (值)
        返回 (取字段列表 ().取成员2 (字段名).无返回值方法 ("AppendChunk", 写入值))
    }

    方法 添加索引字节集数据 <公开 类型 = 逻辑型 注释 = "将所指定字节集数据加入到记录集中当前位置处指定索引位置字段的数据尾部." 注释 = "注意:本方法适用与添加较大的二进制数据,且仅在数据库字段支持\"大二进制\"属性时可用."
            返回值注释 = "返回是否执行成功.">
    参数 字段索引 <类型 = 整数 注释 = "提供所欲写入数据对应的字段索引位置.">
    参数 值 <类型 = 字节集类 注释 = "提供所欲写入的值.">
    {
        变量 写入值 <类型 = COM变体型>
        写入值.置字节集 (值)
        返回 (取字段列表 ().取成员 (字段索引).无返回值方法 ("AppendChunk", 写入值))
    }

    方法 已超出数据范围 <公开 定义事件 类型 = 整数 注释 = "在移到超过记录集末尾的行时,本事件将被调用.">
    参数 更多数据 <类型 = 逻辑型 注释 = "是否存在更多数据.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 数据检索已完成 <公开 定义事件 类型 = 整数 注释 = "当异步操作中的所有记录都已检索到记录集中后,本事件将被调用.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 数据检索进度改变 <公开 定义事件 类型 = 整数 注释 = "当异步操作中的记录检索到记录集中时,将会定期触发本事件以反馈当前的检索进度.">
    参数 当前进度 <类型 = 长整数 注释 = "当前已检索到的记录数.">
    参数 最大进度 <类型 = 长整数 注释 = "预期所需要检索的总记录数量.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 字段即将被更改 <公开 定义事件 类型 = 整数 注释 = "字段即将被更改之前本事件被调用.">
    参数 字段数量 <类型 = 长整数>
    参数 字段对象 <类型 = COM变体型 注释 = "即将被更改的字段数组.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 字段已更改完毕 <公开 定义事件 类型 = 整数 注释 = "字段在更改完成后本事件将被调用.">
    参数 字段数量 <类型 = 长整数>
    参数 字段对象 <类型 = COM变体型 注释 = "即将被更改的字段数组.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 记录即将被更改 <公开 定义事件 类型 = 整数 注释 = "记录集中的一个或多个记录即将被修改之前本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致记录即将被更改的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 记录数量 <类型 = 长整数 注释 = "即将发生更改的记录数量.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 记录已更改完毕 <公开 定义事件 类型 = 整数 注释 = "记录集中的一个或多个记录已修改完毕后本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致记录被更改的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 记录数量 <类型 = 长整数 注释 = "即将发生更改的记录数量.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 记录集即将被更改 <公开 定义事件 类型 = 整数 注释 = "记录集(状态)即将发生改变之前本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致记录集即将被更改的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 记录集已更改完毕 <公开 定义事件 类型 = 整数 注释 = "记录集(状态)已发生改变后本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致记录集被更改的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 位置即将被移动 <公开 定义事件 类型 = 整数 注释 = "记录集的当前位置即将发生移动之前本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致位置即将被移动的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">

    方法 位置已移动完毕 <公开 定义事件 类型 = 整数 注释 = "记录集的当前位置已移动完毕后本事件被调用.">
    参数 原因 <类型 = 整数 注释 = "导致位置被移动的原因,请参考\"记录集数据更改类型\"所提供的常量.">
    参数 错误对象 <类型 = 数据库错误信息类 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态\"所提供的常量值.">
}

# 集合对象 ---

类 数据库集合类 <公开 基础类 = COM对象类 注释 = "模板类型1为集合中的成员类型." 注释 = "模板类型2为实现类自身" @文档 = "category = \"辅助类\"" @模板基础类 = 真>
{

    # @ @m<数据库类.DECLARE_ADO_COMOBJ>(模板类型2)

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "获取该集合中所包含的成员数量.">
    {
        返回 (读无参数属性 ("Count", 整数))
    }

    方法 刷新 <公开 类型 = 逻辑型 注释 = "刷新该集合." 返回值注释 = "返回调用结果.">
    {
        返回 (无参数及返回值方法 ("Refresh"))
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "获取该集合中所包含的指定成员.">
    参数 索引 <类型 = 整数>
    {
        返回 ((模板类型1)读属性 ("Item", COM对象类, 索引))
    }

    方法 取成员2 <公开 类型 = 模板类型1 注释 = "以指定的成员名称获取该成员对象.">
    参数 成员名 <类型 = 文本型>
    {
        返回 ((模板类型1)读属性 ("Item", COM对象类, 成员名))
    }
}

类 数据库属性集合类 <公开 基础类 = 数据库集合类 注释 = "表示包含多个属性对象的集合." @文档 = "category = \"辅助类\"" @模板实现类 = "数据库属性类,数据库属性集合类">

类 数据库错误集合类 <公开 基础类 = 数据库集合类 注释 = "表示包含多个错误对象的集合." @文档 = "category = \"辅助类\"" @模板实现类 = "数据库错误信息类,数据库错误集合类">
{
    方法 清空 <公开 注释 = "清空当前错误集合.">
    {
        无参数及返回值方法 ("Clear")
    }
}

类 数据库属性类 <公开 基础类 = COM对象类 注释 = "表示对象的一个属性." @文档 = "category = \"辅助类\"">
{
    方法 值 <公开 属性读 类型 = COM变体型 注释 = "读取该属性的值.">
    {
        返回 (读无参数属性 ("Value", COM变体型))
    }

    方法 值 <公开 属性写 注释 = "置入该属性新的值.">
    参数 欲设置值 <类型 = COM变体型>
    {
        写属性 ("Value", 欲设置值)
    }

    方法 文本值 <公开 属性读 类型 = 文本型 注释 = "读取该属性的文本值.">
    {
        返回 (读无参数属性 ("Value", 文本型))
    }

    方法 文本值 <公开 属性写 注释 = "置入该属性新的文本值.">
    参数 欲设置值 <类型 = 文本型>
    {
        写属性 ("Value", 欲设置值)
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "取该属性的名称.">
    {
        返回 (读无参数属性 ("Name", 文本型))
    }

    方法 类型 <公开 属性读 类型 = 整数 注释 = "取该属性的类型.">
    {
        返回 (读无参数属性 ("Type", 整数))
    }

    方法 属性值 <公开 属性读 类型 = 整数 注释 = "取该对象的属性值.">
    {
        返回 (读无参数属性 ("Attributes", 整数))
    }

    方法 属性值 <公开 属性写 注释 = "置入该对象新的属性值.">
    参数 欲设置值 <类型 = 整数>
    {
        写属性 ("Attributes", 欲设置值)
    }
}

类 数据库错误信息类 <公开 基础类 = COM对象类 注释 = "表示运行过程中的一个错误." @文档 = "category = \"辅助类\"">
{
    方法 错误描述 <公开 属性读 类型 = 文本型 注释 = "获取错误的简要描述内容.">
    {
        返回 (读无参数属性 ("Description", 文本型))
    }

    方法 错误代码 <公开 属性读 类型 = 整数 注释 = "获取错误代码.">
    {
        返回 (读无参数属性 ("NativeError", 整数))
    }
}

类 数据库字段类 <公开 基础类 = COM对象类 注释 = "表示表中的一个字段(列)." @文档 = "category = \"辅助类\"">
{
    方法 取属性信息 <公开 类型 = 数据库属性集合类 注释 = "获取当前字段的属性集合." @禁止流程检查 = 真>
    {
        @ return @dt<数据库属性集合类>(Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Properties"), 0, _T ("")));
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "获取该字段的名称.">
    {
        返回 (读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "设置该字段的名称.">
    参数 值 <类型 = 文本型>
    {
        写属性 ("Name", 值)
    }

    方法 实际尺寸 <公开 属性读 类型 = 长整数 注释 = "获取字段值的实际所占用的长度(字节单位).">
    {
        返回 (读无参数属性 ("ActualSize", 长整数))
    }

    方法 定义尺寸 <公开 属性读 类型 = 长整数 注释 = "获取字段值定义的尺寸(字节单位).">
    {
        返回 (读无参数属性 ("DefinedSize", 长整数))
    }

    方法 小数位数 <公开 属性读 类型 = 整数 注释 = "获取字段中数值的小数位数.">
    {
        返回 (读无参数属性 ("NumericScale", 整数))
    }

    方法 小数位数 <公开 属性写 注释 = "数值字段中数值的小数位数.">
    参数 值 <类型 = 整数>
    {
        写属性 ("NumericScale", 值)
    }

    方法 原始值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段在有任何更改之前的原始值.">
    {
        返回 (读无参数属性 ("OriginalValue", COM变体型))
    }

    方法 最大位数 <公开 属性读 类型 = 整数 注释 = "获取字段中值的最大位数(精度).">
    {
        返回 (读无参数属性 ("Precision", 整数))
    }

    方法 最大位数 <公开 属性写 注释 = "数值字段中值的最大位数(精度).">
    参数 值 <类型 = 整数>
    {
        写属性 ("Precision", 值)
    }

    方法 状态 <公开 属性读 类型 = 长整数 注释 = "获取该字段当前状态." 返回值注释 = "返回值请参考\"数据库字段状态类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("Status", 长整数))
    }

    方法 类型 <公开 属性读 类型 = 整数 注释 = "获取该字段定义的数据类型." 返回值注释 = "返回值请参考\"数据库字段数据类型\"所提供的常量.">
    {
        返回 (读无参数属性 ("Type", 整数))
    }

    方法 当前值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段当前的值.">
    {
        返回 (读无参数属性 ("UnderlyingValue", COM变体型))
    }

    方法 值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段的值.">
    {
        返回 (读无参数属性 ("Value", COM变体型))
    }

    方法 值 <公开 属性写 注释 = "设置该字段的值." 返回值注释 = "返回值请参考\"数据库字段数据类型\"所提供的常量.">
    参数 欲置入值 <类型 = COM变体型>
    {
        写属性 ("Value", 欲置入值)
    }
}

类 数据库字段集合类 <公开 基础类 = 数据库集合类 注释 = "本类表示一个数据集中所有的字段数据." @文档 = "category = \"辅助类\"" @模板实现类 = "数据库字段类,数据库字段集合类">
{
    方法 加入 <公开 类型 = 逻辑型 注释 = "将指定字段追加至该集合的尾部." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 名称 <类型 = 文本型 注释 = "所欲加入新字段的名称,不能与集合中的任何其他字段同名.">
    参数 字段对象 <类型 = 数据库字段类 注释 = "提供所欲加入该集合的字段对象.">
    参数 数据类型 <类型 = 整数 注释 = "所欲加入新字段的数据类型,请参考\"数据库字段数据类型\"所提供的常量." @默认值 = 数据库字段数据类型.空值>
    参数 定义尺寸 <类型 = 长整数 注释 = "表示所加入新字段定义的大小(字节)." @默认值 = 0>
    参数 字段属性 <类型 = 长整数 注释 = "提供该字段的属性选项,请参考\"数据库字段属性类型\"所提供的常量,支持其单个或多个组合值." @默认值 = 数据库字段属性类型.无>
    {
        返回 (无返回值方法 ("Append", 名称, 数据类型, 定义尺寸, 字段属性, 字段对象))
    }

    方法 删除索引 <公开 类型 = 逻辑型 注释 = "删除指定索引处的字段对象." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 索引 <类型 = 整数 注释 = "所欲删除字段在本集合内所处的索引位置.">
    {
        返回 (无返回值方法 ("Delete", 索引))
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "以字段名称删除指定字段对象." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 名称 <类型 = 文本型 注释 = "所欲删除字段的名称.">
    {
        返回 (无返回值方法 ("Delete", 名称))
    }

    方法 取消更新 <公开 类型 = 逻辑型 注释 = "在调用\"更新\"方法之前,取消对当前字段对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假.">
    {
        返回 (无参数及返回值方法 ("CancelUpdate"))
    }

    方法 重新同步 <公开 类型 = 逻辑型 注释 = "通过重新执行对象所基于的查询来更新字段集合对象中的字段数据." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 是否覆盖 <类型 = 逻辑型 注释 = "是否覆盖原有数据,挂起的更新动作将被直接取消,提供假将不会覆盖数据,也不会取消挂起的更新动作." @默认值 = 真>
    {
        如果 (是否覆盖)
        {
            返回 (无返回值方法 ("Resync", 3, 2))
        }
        否则
        {
            返回 (无返回值方法 ("Resync", 3, 1))
        }
    }

    方法 更新 <公开 类型 = 逻辑型 注释 = "保存对字段集合对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假.">
    参数 字段 <类型 = COM变体型 注释 = "指定所欲修改的一个或多个字段名称,如果有多个字段请置入字段数组,可以为名称也可以是字段索引." @默认值 = 空对象>
    参数 值 <类型 = COM变体型 注释 = "指定字段所对应的值,如果有多个字段,必须提供对等数量的值,否则将无法正常执行更新." @默认值 = 空对象>
    {
        返回 (无返回值方法 ("Update", 字段, 值))
    }
}

