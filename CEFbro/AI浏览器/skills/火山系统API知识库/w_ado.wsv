    常量 默认 <公开 类型 = 整数 值 = 8 注释 = "未知命令类型,ADO将会多次尝试解释命令类型.">
    常量 记录集文件 <公开 类型 = 整数 值 = 256 注释 = "指定语句为持久储存的记录集文件名,适用于记录集类.">
    常量 获取所有数据 <公开 类型 = 整数 值 = 512 注释 = "指定记录集需要获取所有数据,如果记录集需要使用\"跳转\"方法,必须使用该类型打开记录集.">
}

类 记录集游标类型 <公开 注释 = "指定记录集对象中使用的游标类型." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
    常量 动态游标 <公开 类型 = 整数 值 = 2 注释 = "使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动.">
    常量 默认 <公开 类型 = 整数 值 = 0 注释 = "只进游标,只能向前滚动记录.">
    常量 键集游标 <公开 类型 = 整数 值 = 1 注释 = "使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用.">
    常量 静态游标 <公开 类型 = 整数 值 = 3 注释 = "使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用.">
    常量 无 <公开 类型 = 整数 值 = -1 注释 = "不指定游标的类型">
}

