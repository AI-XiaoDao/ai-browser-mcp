    常量 查找记录 <公开 类型 = 长整数 值 = 0x80000 注释 = "支持\"查找指定记录\"方法.">
    常量 检索更多数据 <公开 类型 = 长整数 值 = 0x100 注释 = "检索更多记录或更改下一个位置,而不提交所有挂起的更改.">
    常量 索引命名 <公开 类型 = 长整数 值 = 0x100000 注释 = "支持\"索引名称\"属性.">
    常量 向前移动 <公开 类型 = 长整数 值 = 0x200 注释 = "支持\"到首记录\",\"到上一行\"方法.">
    常量 事件通知 <公开 类型 = 长整数 值 = 0x40000 注释 = "判断当前记录集是否支持事件.">
    常量 重新同步 <公开 类型 = 长整数 值 = 0x20000 注释 = "支持\"重新同步\"方法.">
    常量 更新 <公开 类型 = 长整数 值 = 0x1008000 注释 = "支持\"更新\"方法.">
    常量 批更新 <公开 类型 = 长整数 值 = 0x10000 注释 = "支持\"批更新\"以及\"取消批更新\"方法.">
}

类 记录集数据更改类型 <公开 注释 = "指定记录集中记录发生改变的原因." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
    常量 添加新记录 <公开 类型 = 整数 值 = 1 注释 = "添加新记录的操作导致的更改.">
    常量 关闭 <公开 类型 = 整数 值 = 9 注释 = "关闭记录集导致的更改.">
    常量 删除 <公开 类型 = 整数 值 = 2 注释 = "删除记录导致的更改.">
    常量 首次更改 <公开 类型 = 整数 值 = 11 注释 = "对记录进行第一次更改.">
    常量 移动 <公开 类型 = 整数 值 = 10 注释 = "记录集中移动位置的更改.">
    常量 移动到首部 <公开 类型 = 整数 值 = 12 注释 = "移动到记录集首条记录导致的更改.">
    常量 移动到尾部 <公开 类型 = 整数 值 = 15 注释 = "移动到记录集尾条记录导致的更改.">
    常量 移动到下条 <公开 类型 = 整数 值 = 13 注释 = "移动到下一条记录导致的更改.">
    常量 移动到上条 <公开 类型 = 整数 值 = 14 注释 = "移动到上一条记录导致的更改.">
    常量 重新查询 <公开 类型 = 整数 值 = 7 注释 = "刷新记录集导致的更改.">
    常量 重新同步 <公开 类型 = 整数 值 = 8 注释 = "重新同步该记录集导致的更改.">
    常量 取消添加新记录 <公开 类型 = 整数 值 = 5 注释 = "取消添加新纪录导致的更改.">
    常量 取消删除 <公开 类型 = 整数 值 = 6 注释 = "取消删除记录导致的更改.">
    常量 取消更新 <公开 类型 = 整数 值 = 4 注释 = "取消更新记录导致的更改.">
    常量 更新 <公开 类型 = 整数 值 = 3 注释 = "更新记录导致的更改.">
}
