    常量 已提交可读 <公开 类型 = 整数 值 = 4096 注释 = "只允许读其他事务已提交的改变." 编辑时信息 = "0, 4D550, 0, 0">
    常量 禁止读其他 <公开 类型 = 整数 值 = 65536 注释 = "禁止读其他事务的改变." 编辑时信息 = "0, 4D550, 0, 0">
    常量 隔离时执行 <公开 类型 = 整数 值 = 1048576 注释 = "仅在隔离其他事务时执行事务." 编辑时信息 = "0, 4D550, 0, 0">
}

