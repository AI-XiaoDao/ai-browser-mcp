    常量 子记录继承 <公开 类型 = 整数 值 = 0x400000 注释 = "该值与\"允许所有\",\"阻止读\",\"阻止写\",\"阻止所有\"组合使用,表示子记录集继承该权限模式.">
    常量 默认 <公开 类型 = 整数 值 = 0 注释 = "默认,权限尚未设置或无法确定.">
}

类 数据库命令类型 <公开 注释 = "指定如何计算SQL语句参数." @禁止创建对象 = 真 @文档 = "category = \"辅助类\"">
{
