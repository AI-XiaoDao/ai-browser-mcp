<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.增强位图处理

类 增强位图类 <公开 注释 = "处理位图操作" @视窗.外部头文件 = "lib\\bitmap24.h" @视窗.后缀文本 = "public CFBitMap">
{

    # @begin
    # <> <include>
    # void @an<_CopySelfFromExtra> (const @sn<current_class>& o)
    # {
    #     CreateFromMem(o.m_pBitmap,o.m_nBitmapSize);
    # }
    # <> <include>
    # @end

    方法 从文件创建 <公开 静态 类型 = 逻辑型 注释 = "从文件创建当前位图对象">
    参数 所操作的本对象 <类型 = 增强位图类>
    参数 本地文件路径 <类型 = 文本型 注释 = "提供bmp位图文件路径">
    {
        返回 (从字节集创建 (所操作的本对象, 读入文件 (本地文件路径)))
    }

    方法 从指针创建 <公开 静态 类型 = 逻辑型 注释 = "从指针创建位图对象" 返回值注释 = "创建成功返回真" @禁止流程检查 = 真>
    参数 所操作的本对象 <类型 = 增强位图类>
    参数 位图文件指针 <类型 = 变整数 注释 = "提供位图文件数据指针">
    参数 位图文件大小 <类型 = 整数 注释 = "提供位图大小">
    {
        @ if (@<所操作的本对象>.CreateFromMem ((void*)@<位图文件指针>,@<位图文件大小>))
        @     return TRUE;
        @ const HBITMAP hBitmap = g_objVolApp.LoadBitmapFromMemory ((BYTE*)@<位图文件指针>, @<位图文件大小>);
        @ if (hBitmap == NULL)  return FALSE;
        @ CVolMem memBitmap;
        @ const BOOL blSucceeded = (BOOL)WriteBitmap (hBitmap, memBitmap, 0, 0);
        @ ::DeleteObject (hBitmap);
        @ return (blSucceeded && @<所操作的本对象>.CreateFromMem (memBitmap.GetPtr (), memBitmap.GetSize ()));
    }

    方法 从字节集创建 <公开 静态 类型 = 逻辑型 注释 = "从字节集创建位图对象" 返回值注释 = "创建成功返回真">
    参数 所操作的本对象 <类型 = 增强位图类>
    参数 位图字节集 <类型 = 字节集类 注释 = "提供位图字节集数据">
    {
        返回 (从指针创建 (所操作的本对象, 位图字节集.取字节集指针 (), 位图字节集.取字节集长度 ()))
    }

    方法 从资源创建 <公开 静态 类型 = 逻辑型 注释 = "从资源创建位图对象" 返回值注释 = "创建成功返回真">
    参数 所操作的本对象 <类型 = 增强位图类>
    参数 资源 <类型 = 位图资源 注释 = "提供位图资源">
    {
        变量 位图数据 <类型 = 字节集类>
        载入位图资源 (资源).取图片数据 (位图数据)
        返回 (从字节集创建 (所操作的本对象, 位图数据))
    }

    方法 取位图指针 <公开 静态 类型 = 变整数 注释 = "取当前位图对象指针" 返回值注释 = "返回位图指针数据" @嵌入式方法 = "">
    参数 所操作的本对象 <类型 = 增强位图类>
    {
