    }

    方法 取红色通道数组 <公开 注释 = "取出所有的红色通道保存在数组中">
    参数 结果数组 <类型 = 整数数组类 注释 = "结果保存在此参数中">
    {
        结果数组.重置数组 (256)
        变量 数组指针 <类型 = 变整数>
        数组指针 = 结果数组.取数组指针 ()
        @ GetRedChannel((int*)@<数组指针>);
    }

    方法 取绿色通道数组 <公开 注释 = "取出所有的绿色通道保存在数组中">
    参数 结果数组 <类型 = 整数数组类 注释 = "结果保存在此参数中">
    {
        结果数组.重置数组 (256)
        变量 数组指针 <类型 = 变整数>
        数组指针 = 结果数组.取数组指针 ()
        @ GetGreenChannel((int*)@<数组指针>);
    }

