类 基本类型值数组模板类 <公开 基础类 = 基本类型数组模板类 注释 = "  使用本模板基础类的数组类将使用值内容复制的方式传递数组数据." 注释 = "  即: 执行类似赋值操作\"变量数组1 = 变量数组2\"后,变量数组1中将"
        注释 = "获得变量数组2中的所有数组数据的一个完全独立拷贝,修改变量数组1" 注释 = "的内容不会对变量数组2造成影响." 注释 = "  模板类型2: 对应的参考类型数组数据类型"
        @文档 = "category = \"数组操作.模板类\"" @模板基础类 = 真>
{
    方法 取参考数组 <公开 注释 = "将本数组的内容复制到一个对应的参考类型组中" @嵌入式方法 = "">
    参数 数据接收数组 <类型 = 模板类型2 注释 = "提供用作接收被复制数据的参考类型数组">
    {
        @ @<数据接收数组>.data ().Copy (@sn<this>.data ());
    }

    # --
    #
    # @begin
    # <> <include>
    #
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     m_aryData.Copy (objCopyFrom.m_aryData);
    # }
    #
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const
    # {
    #     return (BOOL)m_aryData.IsEqual (objCompare.m_aryData);
    # }
    #
    # inline_ CMArray<@dt<模板类型1>>& data ()
    # {
    #     return m_aryData;
    # }
    #
    # CMArray<@dt<模板类型1>> m_aryData;
    #
    # <> </include>
    # @end
}

类 字节数组类 <公开 基础类 = 基本类型值数组模板类 @模板实现类 = "字节, 字节参考数组类">

