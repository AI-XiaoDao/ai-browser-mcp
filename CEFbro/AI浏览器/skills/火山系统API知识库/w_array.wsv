<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <@文档 = "category = \"数组操作\"">

类 基本数组操作类 <公开 注释 = "  本类提供维定义数组的相关操作支持,建议数组数据不要使用维定义数组," 注释 = "使用类库中提供的相关数组类对象更加方便灵活." @全局类 = 真>
{
    方法 数组清零 <公开 静态 注释 = "将所指定数值型数组变量中的内容全部清零" @嵌入式方法 = "">
    参数 数组变量数据 <@需求类型 = 可写入变量 @匹配类型 = 通用数值型数组>
    {
        @ ZERO_ARRAY_VAR (@<数组变量数据>)
    }

    方法 重置逻辑值数组 <公开 静态 注释 = "将所指定逻辑型数组变量中的内容全部设置为假" @嵌入式方法 = "">
    参数 数组变量数据 <类型 = "逻辑型 []" @需求类型 = 可写入变量>
    {
        @ ZERO_ARRAY_VAR (@<数组变量数据>)
    }

    方法 取数组成员数 <公开 静态 类型 = 整数 注释 = "返回指定数组变量首维的定义维数,对于单维数组来说,就是其成员数目." @嵌入式方法 = "">
    参数 数组变量数据 <@匹配类型 = 通用型数组>
    {
        @ NUM_ELEMENTS_OF (@<数组变量数据>)
    }

    方法 整数数组排序 <公开 静态 注释 = "将所指定整数数组中的所有成员进行排序" @嵌入式方法 = "">
    参数 所欲排序的数组 <类型 = "整数 []" @需求类型 = 可写入变量>
    参数 从小到大排序 <类型 = 逻辑型 @默认值 = 真>
    {
        @ SORT_INT_ARRAY (@<所欲排序的数组>, @<从小到大排序>)
    }

    方法 小数数组排序 <公开 静态 注释 = "将所指定小数数组中的所有成员进行排序" @嵌入式方法 = "">
    参数 所欲排序的数组 <类型 = "小数 []" @需求类型 = 可写入变量>
    参数 从小到大排序 <类型 = 逻辑型 @默认值 = 真>
    {
        @ SORT_DOUBLE_ARRAY (@<所欲排序的数组>, @<从小到大排序>)
    }
}

# ===

类 基本类型数组模板类 <公开 基础类 = 扩展对象类 注释 = "所有基本数据类型(不包括文本型)数组的模版类." 注释 = "模板类型1: 数组成员的数据类型" @文档 = "category = \"数组操作.模板类\""
        @模板基础类 = 真>
{

    # 属性 --

    方法 预分配尺寸 <公开 属性读 类型 = 整数 注释 = "  返回本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetAlignElementCount ()
    }

    方法 预分配尺寸 <公开 属性写 注释 = "  设置本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    参数 所欲设置的预分配尺寸 <类型 = 整数>
    {
        @ data ().SetAlignElementCount (@<所欲设置的预分配尺寸>);
    }

    # 方法 --

    方法 枚举循环 <公开 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_bary = 0; __vol_itr_index_bary < @sn<this>.data ().GetCount (); __vol_itr_index_bary++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个逆向循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_bary = @sn<this>.data ().GetCount () - 1; __vol_itr_index_bary >= 0; __vol_itr_index_bary--)
    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
            注释 = "本类或本类继承类的循环嵌套,本方法将返回所处最近层循环的枚举成员值." @嵌入式方法 = "parent = counter">
    {
        @ @sn<this>.data ().GetElementAt (__vol_itr_index_bary)
    }

    方法 取枚举索引 <公开 类型 = 整数 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到" 注释 = "成员的索引位置,如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环"
            注释 = "枚举到成员的索引位置." @嵌入式方法 = "parent = counter">
    {
        @ (INT)__vol_itr_index_bary
    }

    方法 取数组指针 <公开 类型 = 变整数 注释 = "返回当前数组内容的数据指针值." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.data ().GetData ()
    }

    方法 添加数组指针内容 <公开 注释 = "将所指定指针处的数组数据添加到本数组的尾部." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 数组数据指针 <类型 = 变整数 注释 = "提供指向为本数组成员数据类型的数组数据指针">
    参数 所欲添加成员数目 <类型 = 整数 注释 = "  提供所欲添加的指针所指向地址处的数组成员数目,其数据类型必须" 注释 = "为本数组的成员数据类型.因此必须确保指针所指向地址处的尺寸为"
            注释 = "\"本数组成员数据类型尺寸 * 本参数值\"的数据内容有效.">
    {
        @ @sn<this>.data ().Append ((@dt<模板类型1>*)@<数组数据指针>, @<所欲添加成员数目>)
    }

    方法 索引是否有效 <公开 类型 = 逻辑型 注释 = "返回所指定的索引值是否大于等于0且小于本数组的成员数" @嵌入式方法 = "">
    参数 所欲检查的索引值 <类型 = 整数>
    {
        @ (BOOL)@sn<this>.data ().IsIndexValid (@<所欲检查的索引值>)
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetCount ()
    }

    方法 取最大索引 <公开 类型 = 整数 注释 = "返回数组中尾成员的索引位置" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetUpperBound ()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本数组是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().IsEmpty ()
    }

    方法 删除所有成员 <公开 注释 = "删除数组中的当前所有成员" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().RemoveAll ()
    }

    方法 重置数组 <公开 注释 = "重置数组中的成员数为所指定的数目" @嵌入式方法 = "">
    参数 欲重置的成员数目 <类型 = 整数>
    参数 是否清零 <类型 = 逻辑型 注释 = "如果为真则清零所有成员值." 注释 = "注意: 如果本参数设置为假且扩充了数组成员数,则新增数组成员值为随机值." @默认值 = 真>
    {
        @ @sn<this>.data ().InitCount (@<欲重置的成员数目>, @<是否清零>)
    }

    方法 清零 <公开 注释 = "将数组中的所有成员值清除为零值(如果是逻辑型数组,则清除为假)" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Zero ()
    }

    方法 取字节集 <公开 类型 = 字节集类 注释 = "将本数组中的内容以字节集对象的形式返回" @嵌入式方法 = "" @视窗.返回参考 = 真>
    {
        @ @sn<this>.data ().GetMem ()
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "返回所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ @sn<this>.data ().GetAt (@<索引位置>)
    }

    方法 取成员尺寸 <公开 类型 = 整数 注释 = "返回数组中单个成员的数据尺寸,单位字节." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetOneElementSize ()
    }

    方法 置成员值 <公开 注释 = "设置数组中所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    参数 所欲设置的值 <类型 = 模板类型1 注释 = "提供所欲设置的成员值,先前的值将被覆盖.">
    {
        @ @sn<this>.data ().SetAt (@<索引位置>, @<所欲设置的值>)
    }

    方法 复制到基本数组 <公开 注释 = "将本数组对象的内容复制到对应数据类型的基本数组中" @嵌入式方法 = "">
    参数 起始复制首成员索引 <类型 = 整数 注释 = "  提供所欲复制的在本数组对象内的首成员索引位置,参数值必须大于等" 注释 = "于0且小于等于本数组对象的成员数." @默认值 = 0>
    参数 所欲复制的成员数 <类型 = 整数 注释 = "  提供所欲复制的本数组对象内成员数目,参数值务必大于等于0且加上" 注释 = "\"所欲复制的成员数\"后小于等于本数组对象的成员数.">
    参数 所欲复制到的基本数组 <类型 = "模板类型1 []" 注释 = "提供所欲复制到的对应基本数据类型数组">
    参数 复制到的首成员索引 <类型 = 整数 注释 = "  提供所欲复制到的在目标数组内的首成员索引位置,参数值务必大于等" 注释 = "于0且加上\"所欲复制的成员数\"后小于等于\"所欲复制到的数组\"所定义的" 注释 = "成员数."
            @默认值 = 0>
    {
        @ COPY_MEM (&@<所欲复制到的基本数组> [@<复制到的首成员索引>], @sn<this>.data ().GetData () + @<起始复制首成员索引>, @<所欲复制的成员数> * sizeof (@dt<模板类型1>))
    }

    方法 添加基本数组 <公开 注释 = "将对应的基本数据类型数组中的指定内容添加到本数组的尾部" @嵌入式方法 = "">
    参数 所欲添加的基本数组 <类型 = "模板类型1 []" 注释 = "提供所欲添加其数据的对应基本数据类型数组">
    参数 首成员索引 <类型 = 整数 注释 = "  提供所欲添加的首成员在基本数据类型数组中的索引位置,参数值务必大于等于0" 注释 = "且加上\"所欲添加的成员数\"后小于等于\"所欲添加的基本数组\"的定义成员数." @默认值 = 0>
    参数 所欲添加的成员数 <类型 = 整数 注释 = "  提供所欲添加的基本数据类型数组内的成员数目,参数值务必大于等于0且加上" 注释 = "\"首成员索引\"后小于等于该数组的定义成员数.">
    {
        @ @sn<this>.data ().Append (&@<所欲添加的基本数组> [@<首成员索引>], @<所欲添加的成员数>)
    }

    方法 从字节集复制 <公开 注释 = "清空本数组的内容后,将所指定字节集中的指定部分内容作为数组成员数据添加到本数组中." @嵌入式方法 = "">
    参数 所欲复制的字节集 <类型 = 字节集类 注释 = "用作提供成员数据的字节集数据">
    参数 起始复制偏移位置 <类型 = 整数 注释 = "提供首成员数据在所指定字节集中的偏移位置(单位字节),必须大于等于0.">
    参数 所欲复制的成员数目 <类型 = 整数 注释 = "  提供所欲添加的成员数,必须大于等于0,\"起始复制偏移位置 + 所欲复制的成员数目 * 单个成员数据尺寸\"" 注释 = "必须小于等于所指定字节集的尺寸.">
    {
        @ @sn<this>.data ().Copy ((const @dt<模板类型1>*)(@<所欲复制的字节集>.GetPtr () + @<起始复制偏移位置>), @<所欲复制的成员数目>)
    }

    方法 添加字节集 <公开 注释 = "将所指定字节集中的指定部分内容作为数组成员数据添加到本数组尾部" @嵌入式方法 = "">
    参数 所欲添加的字节集 <类型 = 字节集类 注释 = "用作提供成员数据的字节集数据">
    参数 起始添加偏移位置 <类型 = 整数 注释 = "提供首成员数据在所指定字节集中的偏移位置(单位字节),必须大于等于0.">
    参数 所欲添加的成员数目 <类型 = 整数 注释 = "  提供所欲添加的成员数,必须大于等于0,\"起始添加偏移位置 + 所欲添加的成员数目 * 单个成员数据尺寸\"" 注释 = "必须小于等于所指定字节集的尺寸.">
    {
        @ @sn<this>.data ().Append ((const @dt<模板类型1>*)(@<所欲添加的字节集>.GetPtr () + @<起始添加偏移位置>), @<所欲添加的成员数目>)
    }

    方法 添加数组 <公开 注释 = "将另一个同类型数组的内容添加到本数组尾部" @嵌入式方法 = "">
    参数 所欲添加的数组 <类型 = 基本类型数组模板类>
    {
        @ @sn<this>.data ().Append (@<所欲添加的数组>.data ())
    }

    方法 添加部分数组 <公开 注释 = "将另一个同类型数组内容中的一部分添加到本数组尾部" @嵌入式方法 = "">
    参数 所欲添加的数组 <类型 = 基本类型数组模板类>
    参数 起始索引位置 <类型 = 整数 注释 = "必须大于等于0且加上\"所欲添加的成员数\"后小于等于\"所欲添加的数组\"的成员数目">
    参数 所欲添加的成员数 <类型 = 整数 注释 = "必须大于等于0且加上\"起始索引位置\"后小于等于\"所欲添加的数组\"的成员数目">
    {
        @ @sn<this>.data ().Append (@<所欲添加的数组>.data (), @<起始索引位置>, @<所欲添加的成员数>)
    }

    方法 从数组复制 <公开 注释 = "清空本数组的原有内容,将另一个同类型数组的内容添加到本数组中." @嵌入式方法 = "">
    参数 所欲复制的数组 <类型 = 基本类型数组模板类>
    {
        @ @sn<this>.data ().Copy (@<所欲复制的数组>.data ())
    }

    方法 加入空成员 <公开 注释 = "加入所指定数目的值为零(如果是逻辑型数组,则值为假)的成员" @嵌入式方法 = "">
    参数 所欲加入的零成员数 <类型 = 整数>
    {
        @ @sn<this>.data ().AddEmptyElements (@<所欲加入的零成员数>, TRUE)
    }

    方法 加入成员 <公开 类型 = 整数 注释 = "将一个或多个所指定类型的成员值加入到本数组的尾部" 返回值注释 = "返回所加入的第一个成员在数组中的记录索引位置" @嵌入式方法 = "">
    参数 所欲添加成员值 <类型 = 模板类型1 @可扩展 = "">
    {
        @ (INT)@sn<this>.data ().Add3 (_T (@sn<pm_types>), @<所欲添加成员值>)
    }

    方法 插入成员 <公开 注释 = "将所指定的成员值插入到所指定的索引位置" @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的成员值 <类型 = 模板类型1>
    {
        @ @sn<this>.data ().InsertAt (@<插入索引位置>, @<所欲插入的成员值>)
    }

    方法 插入字节集 <公开 注释 = "将所指定字节集中的成员值内容插入到所指定的索引位置" @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的字节集 <类型 = 字节集类 注释 = "用作提供成员数据的字节集数据">
    参数 起始数据偏移位置 <类型 = 整数 注释 = "提供首成员数据在所指定字节集中的偏移位置(单位字节),必须大于等于0.">
    参数 所欲插入的成员数目 <类型 = 整数 注释 = "  提供所欲插入的成员数,必须大于等于0,\"起始数据偏移位置 + 所欲插入的成员数目 * 单个成员数据尺寸\"" 注释 = "必须小于等于所指定字节集的尺寸.">
    {
        @ @sn<this>.data ().InsertAt (@<插入索引位置>, (const @dt<模板类型1>*)(@<所欲插入的字节集>.GetPtr () + @<起始数据偏移位置>), @<所欲插入的成员数目>)
    }

    方法 插入数组 <公开 注释 = "将另一个同类型数组的内容插入到本数组的所指定索引位置" @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的数组 <类型 = 基本类型数组模板类 注释 = "提供所欲插入的数组数据">
    {
        @ @sn<this>.data ().InsertAt (@<插入索引位置>, @<所欲插入的数组>.data ())
    }

    方法 插入部分数组 <公开 注释 = "将另一个同类型数组的部分内容插入到本数组的所指定索引位置" @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的数组 <类型 = 基本类型数组模板类 注释 = "提供所欲插入的数组数据">
    参数 起始索引位置 <类型 = 整数 注释 = "必须大于等于0且加上\"所欲插入的成员数\"后小于等于\"所欲插入的数组\"的成员数目">
    参数 所欲插入的成员数 <类型 = 整数 注释 = "必须大于等于0且加上\"起始索引位置\"后小于等于\"所欲插入的数组\"的成员数目">
    {
        @ @sn<this>.data ().InsertAt (@<插入索引位置>, @<所欲插入的数组>.data (), @<起始索引位置>, @<所欲插入的成员数>)
    }

    方法 删除成员 <公开 注释 = "删除数组中所指定索引位置处的成员" @嵌入式方法 = "">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲删除成员数目 <类型 = 整数 注释 = "提供所欲删除成员的数目,必须大于等于0且加上\"删除索引位置\"参数值后小于等于数组成员数目." @默认值 = 1>
    {
        @ @sn<this>.data ().RemoveAt (@<删除索引位置>, @<所欲删除成员数目>)
    }

    方法 删除到尾部 <公开 注释 = "删除数组中所指定索引位置后(包括该位置)的所有成员" @嵌入式方法 = "">
    参数 起始索引位置 <类型 = 整数 注释 = "提供所欲删除起始成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    {
        @ @sn<this>.data ().RemoveToEnd (@<起始索引位置>)
    }

    方法 查找删除成员 <公开 类型 = 逻辑型 注释 = "查找第一个等于所指定值的成员,如果找到则将其删除并返回真,否则返回假." @嵌入式方法 = "">
    参数 所欲查找成员值 <类型 = 模板类型1 注释 = "提供所欲查找并删除的成员值">
    {
        @ (BOOL)@sn<this>.data ().RemoveElement (@<所欲查找成员值>)
    }

    方法 交换成员 <公开 注释 = "将两个索引位置处的成员值相互交换" @嵌入式方法 = "">
    参数 索引位置1 <类型 = 整数 注释 = "提供成员1的索引位置,必须大于等于0且小于数组成员数目.">
    参数 索引位置2 <类型 = 整数 注释 = "提供成员2的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ @sn<this>.data ().XchgElement (@<索引位置1>, @<索引位置2>)
    }

    方法 压入成员 <公开 注释 = "将所指定的成员值添加到本数组的尾部." 注释 = "本方法的效果等同于\"加入成员\"." @嵌入式方法 = "">
    参数 所欲压入的成员值 <类型 = 模板类型1>
    {
        @ @sn<this>.data ().Push (@<所欲压入的成员值>)
    }

    方法 弹出成员 <公开 类型 = 模板类型1 注释 = "返回并删除数组尾部的单个成员." 注释 = "注意: 执行本方法前必须确保数组不为空" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Pop ()
    }

    方法 抛弃尾成员 <公开 注释 = "删除数组尾部的单个成员" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().CheckPopDiscard ()
    }

    方法 取尾成员 <公开 类型 = 模板类型1 注释 = "返回数组尾部的单个成员值." 注释 = "注意: 执行本方法前必须确保数组不为空" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetLastElement ()
    }

    方法 查找首成员 <公开 类型 = 整数 注释 = "正向查找等于所指定值的第一个成员,找到返回其索引位置,未找到返回-1." @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 模板类型1>
    {
        @ (INT)@sn<this>.data ().FindElement (@<所欲查找的成员值>)
    }

    方法 所指定值是否存在 <公开 类型 = 逻辑型 注释 = "返回数组中是否存在为所指定值的成员" @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 模板类型1>
    {
        @ (BOOL)@sn<this>.data ().IsElementExist (@<所欲查找的成员值>)
    }

    方法 查找尾成员 <公开 类型 = 整数 注释 = "逆向查找等于所指定值的最后一个成员,找到返回其索引位置,未找到返回-1." @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 模板类型1>
    {
        @ (INT)@sn<this>.data ().ReverseFindElement (@<所欲查找的成员值>)
    }

    方法 替换成员值 <公开 类型 = 逻辑型 注释 = "将所有等于指定值的成员替换为另一个值,返回是否至少进行了一次替换操作." @嵌入式方法 = "">
    参数 所欲替换的成员值 <类型 = 模板类型1>
    参数 所替换到的成员值 <类型 = 模板类型1>
    {
        @ (BOOL)@sn<this>.data ().ReplaceAllElements (@<所欲替换的成员值>, @<所替换到的成员值>)
    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "返回所指定数组的内容是否与本数组相同" @嵌入式方法 = "">
    参数 所欲比较的数组 <类型 = 基本类型数组模板类>
    {
        @ (BOOL)@sn<this>.data ().IsEqual (@<所欲比较的数组>.data ())
    }

    方法 排序 <公开 注释 = "对数组中的所有成员进行排序" @嵌入式方法 = "">
    参数 从小到大排序 <类型 = 逻辑型 注释 = "为真表示从小到大进行排序,为假表示从大到小进行排序." @默认值 = 真>
    {
        @ @sn<this>.data ().Sort (@<从小到大排序>)
    }

    方法 取展示内容 <公开 注释 = "将本数组中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本数组中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        @ CMArray<@dt<模板类型1>>& ary = data ();
        @ if (@<最大展示数据尺寸> == 0)  // 使用默认尺寸?
        @     @<最大展示数据尺寸> = 64;
        @ const INT_P npCount = ary.GetCount ();
        @ const INT_P npDumpedCount = (@<最大展示数据尺寸> < 0 ? npCount : MIN (npCount, @<最大展示数据尺寸>));
        @ if (npCount == npDumpedCount)
        @     @<展示内容>.AddFormatText (_T_ARY_ELEMENTS_DUMPED1_D, (INT)npCount);
        @ else
        @     @<展示内容>.AddFormatText (_T_ARY_ELEMENTS_DUMPED2_DDD, (INT)npCount, npDumpedCount, (INT)(npCount - npDumpedCount));
        @ for (INT_P npIndex = 0; npIndex < npDumpedCount; npIndex++)
        @     @<展示内容>.AddFormatText (_T ("\r\n%d. %s"), (INT)(npIndex + 1), CVolString (ary.GetAt (npIndex)).GetText ());
    }

    方法 流读入 <公开 注释 = "从所指定的流对象中读入本对象的数据" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输入流类 注释 = "提供欲从其中读入本对象数据内容的输入流">
    {
        @ data ().LoadFromStream (@<流对象>);
    }

    方法 流写出 <公开 注释 = "将本对象的数据写入所指定的流对象中" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输出流类 注释 = "提供欲将本对象数据内容写出到其中的输出流">
    {
        @ data ().SaveIntoStream (@<流对象>);
    }
}

