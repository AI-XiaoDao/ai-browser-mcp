类 文本数组模板类 <基础类 = 扩展对象类 注释 = "用作动态管理文本型数组数据的模板基础类" @文档 = "category = \"数组操作.模板类\"" @模板基础类 = 真>
{

    # 属性 --

    方法 预分配尺寸 <公开 属性读 类型 = 整数 注释 = "  返回本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetAlignElementCount ()
    }

    方法 预分配尺寸 <公开 属性写 注释 = "  设置本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    参数 所欲设置的预分配尺寸 <类型 = 整数>
    {
        @ data ().SetAlignElementCount (@<所欲设置的预分配尺寸>);
    }

    # 方法 --

    方法 枚举循环 <公开 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_sary = 0; __vol_itr_index_sary < @sn<this>.data ().GetCount (); __vol_itr_index_sary++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个逆向循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_sary = @sn<this>.data ().GetCount () - 1; __vol_itr_index_sary >= 0; __vol_itr_index_sary--)
    }

    方法 取枚举值 <公开 类型 = 文本型 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
            注释 = "本类或本类继承类的循环嵌套,本方法将返回所处最近层循环的枚举成员值." @嵌入式方法 = "parent = counter">
    {
        @ CVolString (@sn<this>.data ().GetAt (__vol_itr_index_sary))
    }

    方法 取枚举索引 <公开 类型 = 整数 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到成员的索引位置,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环枚举到成员的索引位置." @嵌入式方法 = "parent = counter">
    {
        @ (INT)__vol_itr_index_sary
    }

    方法 索引是否有效 <公开 类型 = 逻辑型 注释 = "返回所指定的索引值是否大于等于0且小于本数组的成员数" @嵌入式方法 = "">
    参数 所欲检查的索引值 <类型 = 整数>
    {
        @ (BOOL)@sn<this>.data ().IsIndexValid (@<所欲检查的索引值>)
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetCount ()
    }

    方法 取最大索引 <公开 类型 = 整数 注释 = "返回数组中尾成员的索引位置" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetUpperBound ()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本数组是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().IsEmpty ()
    }

    方法 删除所有成员 <公开 注释 = "删除数组中的当前所有成员" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().RemoveAll ()
    }

    方法 取成员 <公开 类型 = 文本型 注释 = "返回所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ CVolString (@sn<this>.data ().GetAt (@<索引位置>))
    }

    方法 交换成员 <公开 注释 = "将两个索引位置处的成员值相互交换" @嵌入式方法 = "">
    参数 索引位置1 <类型 = 整数 注释 = "提供成员1的索引位置,必须大于等于0且小于数组成员数目.">
    参数 索引位置2 <类型 = 整数 注释 = "提供成员2的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ @sn<this>.data ().XchgElement (@<索引位置1>, @<索引位置2>)
    }

    方法 添加数组 <公开 注释 = "将另一个文本数组的内容添加到本数组尾部" @嵌入式方法 = "">
    参数 所欲添加的数组 <类型 = 文本数组模板类>
    {
        @ @sn<this>.data ().Append (@<所欲添加的数组>.data ())
    }

    方法 添加数组独有成员 <公开 注释 = "将另一个文本数组中在本数组内不存在的成员添加到本数组尾部">
    参数 所欲添加的数组 <类型 = 文本数组模板类>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     data ().UniqueAppend (@<所欲添加的数组>.data ());
        @ else
        @     data ().IUniqueAppend (@<所欲添加的数组>.data ());
    }

    方法 对比删除重复成员 <公开 注释 = "将本数组中在\"所欲检查的数组\"内已经存在的成员删除掉">
    参数 所欲检查的数组 <类型 = 文本数组模板类 注释 = "提供用作检查重复成员的文本数组">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     data ().RemoveDuplicated (@<所欲检查的数组>.data ());
        @ else
        @     data ().IRemoveDuplicated (@<所欲检查的数组>.data ());
    }

    方法 从数组复制 <公开 注释 = "清空本数组的原有内容,将另一个文本数组的内容添加到本数组中." @嵌入式方法 = "">
    参数 所欲复制的数组 <类型 = 文本数组模板类>
    {
        @ @sn<this>.data ().Copy (@<所欲复制的数组>.data ())
    }

    方法 删除成员 <公开 注释 = "删除数组中所指定索引位置处的成员" @嵌入式方法 = "">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲删除成员数目 <类型 = 整数 注释 = "提供所欲删除成员的数目,必须大于等于0且加上\"删除索引位置\"参数值后小于等于数组成员数目." @默认值 = 1>
    {
        @ @sn<this>.data ().RemoveAt (@<删除索引位置>, @<所欲删除成员数目>)
    }

    方法 查找删除成员 <公开 类型 = 逻辑型 注释 = "查找第一个等于所指定值的成员,如果找到则将其删除并返回真,否则返回假." @嵌入式方法 = "">
    参数 所欲查找文本 <类型 = 文本型 注释 = "提供所欲查找并删除的成员值">
    {
        @ (BOOL)@sn<this>.data ().RemoveElement (@<所欲查找文本>.GetText ())
    }

    方法 置成员值 <公开 注释 = "设置数组中所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    参数 所欲设置的值 <类型 = 文本型 注释 = "提供所欲设置的成员值,先前的值将被覆盖.">
    {
        @ @sn<this>.data ().SetAt (@<索引位置>, @<所欲设置的值>.GetText ())
    }

    方法 加入成员 <公开 类型 = 整数 注释 = "将一个或多个文本值加入到本数组的尾部" 返回值注释 = "返回所加入的第一个文本值在数组中的记录索引位置"
            @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 所欲添加成员值 <类型 = 文本型 @可扩展 = "">
    {
        @ (INT)@sn<this>.data ().Add4 (@sn<pm_count>, @<所欲添加成员值>)
    }

    方法 插入成员 <公开 注释 = "将所指定的成员值插入到所指定的索引位置" @嵌入式方法 = "">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的成员值 <类型 = 文本型>
    {
        @ @sn<this>.data ().InsertAt (@<插入索引位置>, @<所欲插入的成员值>.GetText ())
    }

    方法 查找首成员 <公开 类型 = 整数 注释 = "正向查找等于所指定值的第一个成员,找到返回其索引位置,未找到返回-1." @禁止流程检查 = 真>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     return (INT)data ().FindFirstElement (@<所欲查找的成员值>.GetText ());
        @ else
        @     return (INT)data ().IFindFirstElement (@<所欲查找的成员值>.GetText ());
    }

    方法 所指定值是否存在 <公开 类型 = 逻辑型 注释 = "返回数组中是否存在为所指定值的成员" @禁止流程检查 = 真>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     return (BOOL)data ().IsElementExist (@<所欲查找的成员值>.GetText ());
        @ else
        @     return (BOOL)data ().IIsElementExist (@<所欲查找的成员值>.GetText ());
    }

    方法 查找尾成员 <公开 类型 = 整数 注释 = "逆向查找等于所指定值的最后一个成员,找到返回其索引位置,未找到返回-1." @禁止流程检查 = 真>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     return (INT)data ().FindLastElement (@<所欲查找的成员值>.GetText ());
        @ else
        @     return (INT)data ().IFindLastElement (@<所欲查找的成员值>.GetText ());
    }

    方法 替换成员值 <公开 类型 = 逻辑型 注释 = "将所有等于指定值的成员替换为另一个值,返回是否至少进行了一次替换操作." @禁止流程检查 = 真>
    参数 所欲替换的成员值 <类型 = 文本型>
    参数 所替换到的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ if (@<是否区分大小写>)
        @     return (BOOL)data ().ReplaceAllElements (@<所欲替换的成员值>.GetText (), @<所替换到的成员值>.GetText ());
        @ else
        @     return (BOOL)data ().IReplaceAllElements (@<所欲替换的成员值>.GetText (), @<所替换到的成员值>.GetText ());
    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "返回所指定数组的内容是否与本数组相同" @嵌入式方法 = "">
    参数 所欲比较的数组 <类型 = 文本数组模板类>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ (BOOL)@sn<this>.data ().IsEqual (@<所欲比较的数组>.data (), !@<是否区分大小写>)
    }

    方法 取展示内容 <公开 注释 = "将本数组中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本数组中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        @ data ().GetDumpString (@<展示内容>, @<最大展示数据尺寸>);
    }

    方法 流读入 <公开 注释 = "从所指定的流对象中读入本对象的数据" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输入流类 注释 = "提供欲从其中读入本对象数据内容的输入流">
    {
        @ data ().LoadFromStream (@<流对象>);
    }

    方法 流写出 <公开 注释 = "将本对象的数据写入所指定的流对象中" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输出流类 注释 = "提供欲将本对象数据内容写出到其中的输出流">
    {
        @ data ().SaveIntoStream (@<流对象>);
    }
}

