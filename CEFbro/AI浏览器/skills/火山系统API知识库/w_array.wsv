类 文本数组类 <公开 基础类 = 文本数组模板类 注释 = "  本文本数组类将使用值内容复制的方式传递数组数据." 注释 = "  即: 执行类似赋值操作\"变量数组1 = 变量数组2\"后,变量数组1中将"
        注释 = "获得变量数组2中的所有数组数据的一个完全独立拷贝,修改变量数组1" 注释 = "的内容不会对变量数组2造成影响." @模板实现类 = "">
{
    方法 取参考数组 <公开 注释 = "将本数组的内容复制到一个对应的参考类型组中" @嵌入式方法 = "">
    参数 数据接收数组 <类型 = 文本参考数组类 注释 = "提供用作接收被复制数据的参考类型数组">
    {
        @ @<数据接收数组>.data ().Copy (@sn<this>.data ());
    }

