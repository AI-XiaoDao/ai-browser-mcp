            注释 = "方法返回真)." @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)@<所欲操作的数组>.GetAt (@<索引位置>, VOL_RUNTIME_CLASS (@<所欲获取对象的类型>), @<所欲获取对象的类型> ())
    }
}

类 对象数组类 <公开 基础类 = 对象数组模板类 注释 = "最基本的对象类数组" @模板实现类 = "对象类">

类 字节集数组类 <公开 基础类 = 对象数组模板类 @模板实现类 = "字节集类">

# ===

类 结构数组模板类 <公开 基础类 = 扩展对象类 注释 = "  用作提供对C++结构类对象的数组封装." 注释 = "  模板类型1: 对应的结构类,其必须定义了有效的\"@视窗.结构类\"属性,"
        注释 = "且其中不能存在/包含数据类型为文本型的成员." @文档 = "category = \"数组操作.模板类\"" @模板基础类 = 真>
{
    变量 数组内容 <公开 类型 = 字节集类 注释 = "用作保存具体的数组数据,数据内容为所有C++结构数据成员的顺序排列.">

    方法 类_初始化
    {
        预分配尺寸 = 32  // 设置默认预分配尺寸
    }

    # 属性 --

    方法 预分配尺寸 <公开 属性读 类型 = 整数 注释 = "  返回本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    {
        返回 (数组内容.取字节集预分配尺寸 () / 取成员尺寸 ())
    }

    方法 预分配尺寸 <公开 属性写 注释 = "  设置本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    参数 所欲设置的预分配尺寸 <类型 = 整数>
    {
        数组内容.置字节集预分配尺寸 (所欲设置的预分配尺寸 * 取成员尺寸 ())
    }

    # 方法 --

    方法 枚举循环 <公开 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = struct_counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_stary = 0; __vol_itr_index_stary < @sn<this>.@<取成员数> (); __vol_itr_index_stary++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个逆向循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = struct_counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_stary = @sn<this>.@<取成员数> () - 1; __vol_itr_index_stary >= 0; __vol_itr_index_stary--)
    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环的枚举成员值." @嵌入式方法 = "parent = struct_counter">
    {
        @ @sn<this>.@<取成员> (__vol_itr_index_stary)
    }

    方法 取枚举索引 <公开 类型 = 整数 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到成员的索引位置,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环枚举到成员的索引位置." @嵌入式方法 = "parent = struct_counter">
    {
        @ (INT)__vol_itr_index_stary
    }

    方法 取数组指针 <公开 类型 = 变整数 注释 = "返回当前数组内容的数据指针值." 注释 = "数组数据内容为所有C++结构数据成员的顺序排列.">
    {
        返回 (数组内容.取字节集指针 ())
    }

    方法 取数组数据尺寸 <公开 类型 = 整数 注释 = "返回当前数组内容数据的尺寸,单位字节." 注释 = "数组数据内容为所有C++结构数据成员的顺序排列.">
    {
        返回 (数组内容.取字节集长度 ())
    }

    方法 索引是否有效 <公开 类型 = 逻辑型 注释 = "返回所指定的索引值是否大于等于0且小于本数组的成员数">
    参数 所欲检查的索引值 <类型 = 整数>
    {
        返回 (所欲检查的索引值 >= 0 && 所欲检查的索引值 < 取成员数 ())
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目">
    {
        返回 (数组内容.取字节集长度 () / 取成员尺寸 ())
    }

    方法 取最大索引 <公开 类型 = 整数 注释 = "返回数组中尾成员的索引位置">
    {
        返回 (取成员数 () - 1)
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本数组是否为空">
    {
        返回 (数组内容.字节集是否为空 ())
    }

    方法 删除所有成员 <公开 注释 = "删除数组中的当前所有成员">
    {
        数组内容.释放字节集 ()
    }

    方法 重置数组 <公开 注释 = "重置数组中的成员数为所指定的数目并将其清零">
    参数 欲重置的成员数目 <类型 = 整数 注释 = "必须大于等于0">
    {
        数组内容.分配字节集 (欲重置的成员数目 * 取成员尺寸 (), 真)
    }

    方法 清零 <公开 注释 = "将数组中的所有成员值清除为零值">
    {
        数组内容.清零字节集 ()
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "返回所指定索引位置处的成员值">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        变量 变量1 <类型 = 模板类型1>
        取成员2 (索引位置, 变量1)
        返回 (变量1)
    }

    方法 取成员2 <公开 注释 = "返回所指定索引位置处的成员值">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    参数 结果对象 <类型 = 模板类型1 注释 = "用作保存所获得的成员值数据内容">
    {
        调试检查 (索引是否有效 (索引位置))
        置结构数据 (结果对象, 数组内容, 索引位置 * 取成员尺寸 ())
    }

    方法 取成员尺寸 <公开 静态 类型 = 整数 注释 = "返回数组中单个成员的数据尺寸,单位字节.">
    {
        返回 (取结构数据尺寸 (模板类型1))
    }

    方法 置成员值 <公开 注释 = "设置数组中所指定索引位置处的成员值">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    参数 所欲设置的值 <类型 = 模板类型1 注释 = "提供所欲设置的成员值,先前的值将被覆盖.">
    {
        调试检查 (索引是否有效 (索引位置))
        取结构数据到地址 (所欲设置的值, 数组内容.取字节集指针 () + 索引位置 * 取成员尺寸 ())
    }

    方法 添加数组 <公开 注释 = "将另一个同类型数组的内容添加到本数组尾部">
    参数 所欲添加的数组 <类型 = 结构数组模板类>
    {
        数组内容.添加字节集 (所欲添加的数组.数组内容)
    }

    方法 添加部分数组 <公开 注释 = "将另一个同类型数组内容中的一部分添加到本数组尾部">
    参数 所欲添加的数组 <类型 = 结构数组模板类>
    参数 起始索引位置 <类型 = 整数 注释 = "必须大于等于0且加上\"所欲添加的成员数\"后小于等于\"所欲添加的数组\"的成员数目">
    参数 所欲添加的成员数 <类型 = 整数 注释 = "必须大于等于0且加上\"起始索引位置\"后小于等于\"所欲添加的数组\"的成员数目">
    {
        调试检查 (起始索引位置 >= 0 && 所欲添加的成员数 >= 0 && 起始索引位置 + 所欲添加的成员数 <= 所欲添加的数组.取成员数 ())
        数组内容.指针添加字节集 (所欲添加的数组.数组内容.取字节集指针 () + 起始索引位置 * 取成员尺寸 (), 所欲添加的成员数 * 取成员尺寸 ())
    }

    方法 从数组复制 <公开 注释 = "清空本数组的原有内容,将另一个同类型数组的内容复制到本数组中.">
    参数 所欲复制的数组 <类型 = 结构数组模板类>
    {
        数组内容 = 所欲复制的数组.数组内容
    }

    方法 加入空成员 <公开 注释 = "加入所指定数目的值为零的成员">
    参数 所欲加入的零成员数 <类型 = 整数>
    {
        数组内容.添加字节集空间 (所欲加入的零成员数 * 取成员尺寸 (), 真)
    }

    方法 加入成员 <公开 类型 = 整数 注释 = "将成员值加入到本数组的尾部" 返回值注释 = "返回所加入的成员在数组中的记录索引位置">
    参数 所欲添加成员值 <类型 = 模板类型1>
    {
        加入结构数据 (所欲添加成员值, 数组内容)
        返回 (取最大索引 ())
    }

    方法 插入成员 <公开 注释 = "将所指定的成员值插入到所指定的索引位置">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的成员值 <类型 = 模板类型1>
    {
        调试检查 (索引是否有效 (插入索引位置))
        插入结构数据 (所欲插入的成员值, 数组内容, 插入索引位置 * 取成员尺寸 ())
    }

    方法 插入数组 <公开 注释 = "将另一个同类型数组的内容插入到本数组的所指定索引位置">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的数组 <类型 = 结构数组模板类 注释 = "提供所欲插入的数组数据">
    {
        调试检查 (索引是否有效 (插入索引位置))
        数组内容.插入字节集 (插入索引位置 * 取成员尺寸 (), 所欲插入的数组.数组内容)
    }

    方法 插入部分数组 <公开 注释 = "将另一个同类型数组的部分内容插入到本数组的所指定索引位置">
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲插入的数组 <类型 = 结构数组模板类 注释 = "提供所欲插入的数组数据">
    参数 起始索引位置 <类型 = 整数 注释 = "必须大于等于0且加上\"所欲插入的成员数\"后小于等于\"所欲插入的数组\"的成员数目">
    参数 所欲插入的成员数 <类型 = 整数 注释 = "必须大于等于0且加上\"起始索引位置\"后小于等于\"所欲插入的数组\"的成员数目">
    {
        调试检查 (索引是否有效 (插入索引位置) && 起始索引位置 >= 0 && 所欲插入的成员数 >= 0 && 起始索引位置 + 所欲插入的成员数 <= 所欲插入的数组.取成员数 ())
        数组内容.指针插入字节集 (插入索引位置 * 取成员尺寸 (), 所欲插入的数组.数组内容.取字节集指针 () + 起始索引位置 * 取成员尺寸 (), 所欲插入的成员数 * 取成员尺寸 ())
    }

    方法 删除成员 <公开 注释 = "删除数组中所指定索引位置处的成员">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲删除成员数目 <类型 = 整数 注释 = "提供所欲删除成员的数目,必须大于等于0且加上\"删除索引位置\"参数值后小于等于数组成员数目." @默认值 = 1>
    {
        调试检查 (删除索引位置 >= 0 && 所欲删除成员数目 >= 0 && 删除索引位置 + 所欲删除成员数目 <= 取成员数 ())
        数组内容.字节集删除 (删除索引位置 * 取成员尺寸 (), 所欲删除成员数目 * 取成员尺寸 ())
    }

    方法 删除到尾部 <公开 注释 = "删除数组中所指定索引位置后(包括该位置)的所有成员">
    参数 起始索引位置 <类型 = 整数 注释 = "提供所欲删除起始成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    {
        调试检查 (索引是否有效 (起始索引位置))
        数组内容.删除字节集尾部数据 (起始索引位置 * 取成员尺寸 ())
    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "返回所指定数组的内容是否与本数组相同">
    参数 所欲比较的数组 <类型 = 结构数组模板类>
    {
        返回 (数组内容 == 所欲比较的数组.数组内容)
    }

    方法 流读入 <公开 注释 = "从所指定的流对象中读入本对象的数据" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输入流类 注释 = "提供欲从其中读入本对象数据内容的输入流">
    {
        @ @<数组内容>.LoadFromStream (@<流对象>);
    }

    方法 流写出 <公开 注释 = "将本对象的数据写入所指定的流对象中" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输出流类 注释 = "提供欲将本对象数据内容写出到其中的输出流">
    {
        @ @<数组内容>.SaveIntoStream (@<流对象>);
    }
}
