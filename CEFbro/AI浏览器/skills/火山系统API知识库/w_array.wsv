类 对象数组模板类 <公开 注释 = "用作动态管理数据类型为\"对象类\"或其继承类的数组数据" 注释 = "模板类型1: 具体的对象类数据类型" @文档 = "category = \"数组操作.模板类\""
        @别名 = "CVolObjectArray" @模板基础类 = 真>
{

    # 属性 --

    方法 预分配尺寸 <公开 静态 属性读 类型 = 整数 注释 = "  返回本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ (INT)@<所欲操作的数组>.GetAlignElementCount ()
    }

    方法 预分配尺寸 <公开 静态 属性写 注释 = "  设置本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲设置的预分配尺寸 <类型 = 整数>
    {
        @ @<所欲操作的数组>.SetAlignElementCount (@<所欲设置的预分配尺寸>);
    }

    # 方法 --

    方法 枚举循环 <公开 静态 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ for (INT_P __vol_itr_index_oary = 0; __vol_itr_index_oary < @<所欲操作的数组>.GetCount (); __vol_itr_index_oary++)
    }

    方法 逆向枚举循环 <公开 静态 注释 = "  启动一个逆向循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\""
            注释 = "方法来获取当前所枚举到成员的索引位置." @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ for (INT_P __vol_itr_index_oary = @<所欲操作的数组>.GetCount () - 1; __vol_itr_index_oary >= 0; __vol_itr_index_oary--)
    }

    方法 取枚举值 <公开 静态 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环的枚举成员值." @嵌入式方法 = "parent = counter" @视窗.返回参考 = 真>
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ (@dt<模板类型1>&)@<所欲操作的数组>.GetAt (__vol_itr_index_oary)
    }

    方法 取枚举索引 <公开 静态 类型 = 整数 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到成员的索引位置,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环枚举到成员的索引位置." @嵌入式方法 = "parent = counter">
    {
        @ (INT)__vol_itr_index_oary
    }

    方法 索引是否有效 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的索引值是否大于等于0且小于本数组的成员数" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲检查的索引值 <类型 = 整数>
    {
        @ (BOOL)@<所欲操作的数组>.IsIndexValid (@<所欲检查的索引值>)
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回数组中的当前已有成员数目" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ (INT)@<所欲操作的数组>.GetCount ()
    }

    方法 取最大索引 <公开 静态 类型 = 整数 注释 = "返回数组中尾成员的索引位置" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ (INT)@<所欲操作的数组>.GetUpperBound ()
    }

    方法 是否为空 <公开 静态 类型 = 逻辑型 注释 = "返回本数组是否为空" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ (BOOL)@<所欲操作的数组>.IsEmpty ()
    }

    方法 删除所有成员 <公开 静态 注释 = "删除数组中的当前所有成员" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    {
        @ @<所欲操作的数组>.RemoveAll ()
    }

    方法 取成员 <公开 静态 类型 = 模板类型1 注释 = "返回所指定索引位置处成员对象的参考." 注释 = "注意: 如果所获取对象成员需要动态挂接事件,请按类似以下格式挂接:"
            注释 = "  挂接事件 ((对象实际数据类型)数组1.取成员 (索引位置))" 注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一"
            注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ (@dt<模板类型1>&)@<所欲操作的数组>.GetAt (@<索引位置>)
    }

    方法 交换成员 <公开 静态 注释 = "将两个索引位置处的成员值相互交换" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 索引位置1 <类型 = 整数 注释 = "提供成员1的索引位置,必须大于等于0且小于数组成员数目.">
    参数 索引位置2 <类型 = 整数 注释 = "提供成员2的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ @<所欲操作的数组>.XchgElement (@<索引位置1>, @<索引位置2>)
    }

    方法 添加数组 <公开 静态 注释 = "将另一个对象数组的内容添加到本数组尾部" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲添加的数组 <类型 = 对象数组模板类 注释 = "提供所欲加入的对象数组">
    {
        @ @<所欲操作的数组>.Append (@<所欲添加的数组>)
    }

    方法 从数组复制 <公开 静态 注释 = "清空本数组的原有内容,将另一个数组数组的内容添加到本数组中." 注释 = "注: 直接使用赋值操作也可以达到同样的效果." @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲复制的数组 <类型 = 对象数组模板类 注释 = "提供所欲复制到本数组的对象数组">
    {
        @ @<所欲操作的数组>.CopyFrom (@<所欲复制的数组>)
    }

    方法 删除成员 <公开 静态 注释 = "删除数组中所指定索引位置处的成员" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲删除成员数目 <类型 = 整数 注释 = "提供所欲删除成员的数目,必须大于等于0且加上\"删除索引位置\"参数值后小于等于数组成员数目." @默认值 = 1>
    {
        @ @<所欲操作的数组>.RemoveAt (@<删除索引位置>, @<所欲删除成员数目>)
    }

    方法 置成员值 <公开 静态 注释 = "设置数组中所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    参数 所欲设置的值 <类型 = 模板类型1 注释 = "提供所欲设置的成员值,该对象将被复制一份后覆盖到所指定的索引位置.">
    {
        @ @<所欲操作的数组>.SetAt (@<索引位置>, @<所欲设置的值>)
    }

    方法 加入成员 <公开 静态 类型 = 整数 注释 = "将所指定的对象复制一份后加入到本数组中,返回所加入成员的索引位置." @嵌入式方法 = "">
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲添加成员值 <类型 = 模板类型1 注释 = "提供所欲加入的对象值,该对象将被复制一份后加入到本数组中.">
    {
        @ (INT)@<所欲操作的数组>.Add (@<所欲添加成员值>, NULL)
    }

    方法 加入并返回成员 <公开 静态 类型 = 模板类型1 注释 = "将所指定的对象复制一份后加入到本数组中,返回所加入复制对象的参考." 注释 = "注意: 如果所返回对象成员需要动态挂接事件,请按类似以下格式挂接:"
            注释 = "  挂接事件 ((对象实际数据类型)数组1.加入并返回成员 (...))" 注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一"
            注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @禁止流程检查 = 真 @视窗.返回参考 = 真>
    参数 所欲操作的数组 <类型 = 对象数组模板类 注释 = "提供所欲操作的对象数组">
    参数 所欲添加成员值 <类型 = 模板类型1 注释 = "提供所欲加入的对象值,该对象将被复制一份后加入到本数组中.">
    {
        @ CVolObject* pNewVolObject;
        @ @<所欲操作的数组>.Add (@<所欲添加成员值>, &pNewVolObject);
        @ return (@dt<模板类型1>&)*pNewVolObject;
    }

    方法 加入并返回成员2 <公开 静态 类型 = 模板类型1 注释 = "将所指定的对象复制一份后加入到本数组中,返回所加入复制对象的参考." 注释 = "注意: 如果所返回对象成员需要动态挂接事件,请按类似以下格式挂接:"
            注释 = "  挂接事件 ((对象实际数据类型)数组1.加入并返回成员2 (...))" 注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一"
