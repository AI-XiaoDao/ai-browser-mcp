}

类 文本参考数组类 <公开 基础类 = 文本数组模板类 注释 = "  本文本数组类将使用参考的方式传递数组数据." 注释 = "  即: 执行类似赋值操作\"变量数组1 = 变量数组2\"后,变量数组1将与变量数组2指向"
        注释 = "同一份数组数据,对两个变量进行数组操作将基于同一份实际数组数据." 注释 = "  数组以参考方式赋值要比完全的值内容复制快得多,但是需要了解两种方式的不同性."
        注释 = "  需要注意的是: 无论哪种类型的数组,在传递到方法参数上时,均采用参考方式传递." @模板实现类 = "">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CMStringArray)

    方法 取值数组 <公开 注释 = "将本数组的内容复制到一个对应的值传递类型组中" @嵌入式方法 = "">
    参数 数据接收数组 <类型 = 文本数组类 注释 = "提供用作接收被复制数据的值传递类型数组">
    {
        @ @<数据接收数组>.data ().Copy (@sn<this>.data ());
    }
}

# ===

类 文本排序数组类 <公开 基础类 = 扩展对象类 注释 = "  用作动态管理文本型数组数据并对其自动排序." 注释 = "  本文本数组类将使用值内容复制的方式传递数组数据."
        注释 = "  即: 执行类似赋值操作\"变量数组1 = 变量数组2\"后,变量数组1中将" 注释 = "获得变量数组2中的所有数组数据的一个完全独立拷贝,修改变量数组1" 注释 = "的内容不会对变量数组2造成影响."
        注释 = "  本数组类中对文本进行比较时区分大小写.">
{

    # 属性 --

    方法 预分配尺寸 <公开 属性读 类型 = 整数 注释 = "  返回本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetAlignElementCount ()
    }

    方法 预分配尺寸 <公开 属性写 注释 = "  设置本数组为了快速进行数组成员的添加/删除处理使用的空间分配尺寸," 注释 = "每次数组需要调整其空间大小时,都使用本属性值乘于单个数组成员尺寸作为"
            注释 = "空间调整基准尺寸.值越大,批量加入/删除数组成员时所实际需要重分配空间" 注释 = "的次数就越少,操作速度越快,但是多余内存占用就越大." 注释 = "  一般情况下无需更改本属性值.">
    参数 所欲设置的预分配尺寸 <类型 = 整数>
    {
        @ data ().SetAlignElementCount (@<所欲设置的预分配尺寸>);
    }

    # 方法 --

    方法 枚举循环 <公开 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_ssary = 0; __vol_itr_index_ssary < @sn<this>.data ().GetCount (); __vol_itr_index_ssary++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个逆向循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    {
        @ for (INT_P __vol_itr_index_ssary = @sn<this>.data ().GetCount () - 1; __vol_itr_index_ssary >= 0; __vol_itr_index_ssary--)
    }

    方法 取枚举值 <公开 类型 = 文本型 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
            注释 = "本类或本类继承类的循环嵌套,本方法将返回所处最近层循环的枚举成员值." @嵌入式方法 = "parent = counter">
    {
        @ CVolString (@sn<this>.data ().GetAt (__vol_itr_index_ssary))
    }

    方法 取枚举索引 <公开 类型 = 整数 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到成员的索引位置,"
            注释 = "如果有多层本类或本类继承类的循环嵌套,本方法将返回所处最近层循环枚举到成员的索引位置." @嵌入式方法 = "parent = counter">
    {
        @ (INT)__vol_itr_index_ssary
    }

    方法 索引是否有效 <公开 类型 = 逻辑型 注释 = "返回所指定的索引值是否大于等于0且小于本数组的成员数" @嵌入式方法 = "">
    参数 所欲检查的索引值 <类型 = 整数>
    {
        @ (BOOL)@sn<this>.data ().IsIndexValid (@<所欲检查的索引值>)
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回数组中的当前已有成员数目" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetCount ()
    }

    方法 取最大索引 <公开 类型 = 整数 注释 = "返回数组中尾成员的索引位置" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data ().GetUpperBound ()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本数组是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().IsEmpty ()
    }

    方法 删除所有成员 <公开 注释 = "删除数组中的当前所有成员" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().RemoveAll ()
    }

    方法 删除成员 <公开 注释 = "删除数组中所指定索引位置处的成员" @嵌入式方法 = "">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    参数 所欲删除成员数目 <类型 = 整数 注释 = "提供所欲删除成员的数目,必须大于等于0且加上\"删除索引位置\"参数值后小于等于数组成员数目." @默认值 = 1>
    {
        @ @sn<this>.data ().RemoveAt (@<删除索引位置>, @<所欲删除成员数目>)
    }

    方法 取成员 <公开 类型 = 文本型 注释 = "返回所指定索引位置处的成员值" @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ CVolString (@sn<this>.data ().GetAt (@<索引位置>))
    }

    方法 从数组复制 <公开 注释 = "清空本数组的原有内容,将另一个文本数组的内容添加到本数组中." @嵌入式方法 = "">
    参数 所欲复制的数组 <类型 = 文本排序数组类>
    {
        @ @sn<this>.data ().Copy (@<所欲复制的数组>.data ())
    }

    方法 从无序数组复制 <公开 注释 = "从一个非排序文本数组复制内容,然后将其进行排序.">
    参数 所欲复制的数组 <类型 = 文本数组类 注释 = "提供所欲复制的数组数据内容">
    {
        @ data ().StringArray ().Copy (@<所欲复制的数组>.data ());
        @ data ().Sort ();
    }

    方法 从无序参考数组复制 <公开 注释 = "从一个非排序文本数组复制内容,然后将其进行排序.">
    参数 所欲复制的数组 <类型 = 文本参考数组类 注释 = "提供所欲复制的数组数据内容">
    {
        @ data ().StringArray ().Copy (@<所欲复制的数组>.data ());
        @ data ().Sort ();
    }

    方法 从无序数组独有复制 <公开 注释 = "从一个非排序文本数组复制内容,然后将其进行排序并删除重复的数组成员.">
    参数 所欲复制的数组 <类型 = 文本数组类 注释 = "提供所欲复制的数组数据内容">
    {
        @ data ().StringArray ().Copy (@<所欲复制的数组>.data ());
        @ data ().SortAndEnsureUnique ();
    }

    方法 从无序参考数组独有复制 <公开 注释 = "从一个非排序文本数组复制内容,然后将其进行排序并删除重复的数组成员.">
    参数 所欲复制的数组 <类型 = 文本参考数组类 注释 = "提供所欲复制的数组数据内容">
    {
        @ data ().StringArray ().Copy (@<所欲复制的数组>.data ());
        @ data ().SortAndEnsureUnique ();
    }

    方法 输出无序数组 <公开 注释 = "将本对象的数组内容复制到所指定的无序数组中" @嵌入式方法 = "">
    参数 所输出到的数组 <类型 = 文本数组类>
    {
        @ @<所输出到的数组>.data ().Copy (@sn<this>.data ().StringArray ())
    }

    方法 输出参考无序数组 <公开 注释 = "将本对象的数组内容复制到所指定的无序参考数组中" @嵌入式方法 = "">
    参数 所输出到的数组 <类型 = 文本参考数组类>
    {
        @ @<所输出到的数组>.data ().Copy (@sn<this>.data ().StringArray ())
    }

    方法 是否相等 <公开 类型 = 逻辑型 注释 = "返回所指定数组的内容是否与本数组相同." 注释 = "是否区分英文字母大小写由本文本数组类的继承类具体特性决定." @嵌入式方法 = "">
    参数 所欲比较的数组 <类型 = 文本排序数组类>
    {
        @ (BOOL)@sn<this>.data ().IsEqual (@<所欲比较的数组>.data ())
    }

    方法 加入成员 <公开 类型 = 整数 注释 = "将一个或多个文本值加入到本数组中" 返回值注释 = "  返回所加入的文本值在数组中的记录索引位置,具体位置由排序算法决定."
            返回值注释 = "  注意: 1.如果本对象实例为\"文本独有数组类\"或\"大小写无关文本独有数组类\"," 返回值注释 = "则当所欲添加的第一个文本值在数组中已经存在时,将返回-1; 2.如果添加进了新的成员,"
            返回值注释 = "本方法返回的所加入成员对应的索引位置可能发生改变; 3.如果同时添加了多个文本值," 返回值注释 = "则本方法的返回值没有意义(因为首文本值记录位置可能会被后面加入的文本值改变)."
            @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 所欲添加成员值 <类型 = 文本型 @可扩展 = "">
    {
        @ (INT)@sn<this>.data ().Add2 (@sn<pm_count>, @<所欲添加成员值>)
    }

    方法 查找成员 <公开 类型 = 整数 注释 = "查找等于所指定值的成员,找到返回其索引位置,未找到返回-1." 注释 = "注意: 1.所找到的可能并非第一个等于该值的成员; 2.如果添加进了新的成员,"
            注释 = "本方法所返回的成员对应索引位置可能发生改变." @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 文本型>
    {
        @ (INT)@sn<this>.data ().FindElement (@<所欲查找的成员值>)
    }

    方法 查找首成员 <公开 类型 = 整数 注释 = "正向查找等于所指定值的第一个成员,找到返回其索引位置,未找到返回-1." 注释 = "注意: 如果添加进了新的成员,本方法所返回的成员对应索引位置可能发生改变." @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 文本型>
    {
        @ (INT)@sn<this>.data ().FindFirstElement (@<所欲查找的成员值>)
    }

    方法 查找尾成员 <公开 类型 = 整数 注释 = "逆向查找等于所指定值的最后一个成员,找到返回其索引位置,未找到返回-1." 注释 = "注意: 如果添加进了新的成员,本方法所返回的成员对应索引位置可能发生改变." @嵌入式方法 = "">
    参数 所欲查找的成员值 <类型 = 文本型>
    {
        @ (INT)@sn<this>.data ().FindLastElement (@<所欲查找的成员值>)
    }

    方法 取展示内容 <公开 注释 = "将本数组中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本数组中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        @ data ().GetDumpString (@<展示内容>, @<最大展示数据尺寸>);
    }

    方法 流读入 <公开 注释 = "从所指定的流对象中读入本对象的数据" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输入流类 注释 = "提供欲从其中读入本对象数据内容的输入流">
    {
        @ data ().LoadFromStream (@<流对象>);
    }

    方法 流写出 <公开 注释 = "将本对象的数据写入所指定的流对象中" @虚拟方法 = 可覆盖>
    参数 流对象 <类型 = 输出流类 注释 = "提供欲将本对象数据内容写出到其中的输出流">
    {
        @ data ().SaveIntoStream (@<流对象>);
    }

