类 事件接收器 <公开 注释 = "  用作挂接到一个\"事件发送器\"对象以接收其所发送的事件,本类对象" 注释 = "被销毁时将自动断开与所挂接到\"事件发送器\"对象之间的连接.">
{
    方法 接收到事件 <公开 定义事件 类型 = 整数 注释 = "当本对象接收到来自所挂接\"事件发送器\"对象的事件时,本事件被发送." 返回值注释 = "事件处理方法返回值将返回到所挂接\"事件发送器\"对象的\"发送事件\"方法">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    参数 事件附加对象 <类型 = 对象类 注释 = "为调用\"事件发送器\"对象的\"发送事件\"方法时所提供的\"事件附加对象\"参数值">
    参数 事件附加值 <类型 = 变整数 注释 = "为调用\"事件发送器\"对象的\"发送事件\"方法时所提供的\"事件附加值\"参数值">

    # @begin
    #
    # <> <include>
    #     inline_ void @an<_OnInitExtra> ()  { m_pEventBridge = new CVolObjectPointer (this); }
    #     inline_ void @an<_OnCleanupExtra> ()  { m_pEventBridge->ReleasePointer (); }
    #     inline_ CVolObjectPointer* GetEventBridge ()  { return m_pEventBridge; }
    # private:
    #     CVolObjectPointer* m_pEventBridge;
    # <> </include>
    #
    # @end
}

类 事件发送器 <公开 注释 = "  用作向已经挂接到本对象的\"事件接收器\"对象发送事件,发送事件时不用" 注释 = "考虑该接收器对象是否还存在,所挂接的\"事件接收器\"对象被销毁时将自动" 注释 = "断开与本对象之间的连接.">
{
    方法 挂接 <公开 注释 = "将所指定的\"事件接收器\"对象挂接到本对象,先前的挂接将被覆盖." @嵌入式方法 = "">
    参数 所欲挂接的接收器 <类型 = 事件接收器 注释 = "提供所欲挂接到本对象的\"事件接收器\"对象">
    {
        @ @sn<this>.AttachReceiver (@<所欲挂接的接收器>.GetEventBridge ())
    }

    方法 取消挂接 <公开 注释 = "取消当前已经挂接进来的\"事件接收器\"对象." 注释 = "除非必要不用显式调用本方法取消挂接,所挂接的\"事件接收器\"对象被销毁时将自动取消挂接." @嵌入式方法 = "">
    {
        @ @sn<this>.AttachReceiver (NULL)
    }

    方法 是否已挂接 <公开 类型 = 逻辑型 注释 = "返回当前是否已经挂接了\"事件接收器\"对象" @禁止流程检查 = 真>
    {
        @ return (m_pEventBridge->SafeGetVolObject () != NULL);
    }

    方法 发送事件 <公开 类型 = 整数 注释 = "向所挂接的\"事件接收器\"对象发送事件" 返回值注释 = "  如果本对象上挂接有\"事件接收器\"对象,本方法将返回该对象的"
            返回值注释 = "\"接收到事件\"事件方法的返回值,否则返回0." @嵌入式方法 = "">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据" @默认值 = 空对象>
    参数 事件返回值 <类型 = COM变体型 注释 = "用作接收用户处理事件后的返回数据" @默认值 = 空对象>
    参数 事件附加对象 <类型 = 对象类 注释 = "用作提供事件的\"事件附加对象\"参数值" @默认值 = 空对象>
    参数 事件附加值 <类型 = 变整数 注释 = "用作提供事件的\"事件附加值\"参数值" @默认值 = 0>
    {
        @ @sn<this>.SendEvent (@<事件参数>, @<事件返回值>, @<事件附加对象>, @<事件附加值>)
    }

    # @begin
    #
    # <> <include>
    #     inline_ void @an<_OnInitExtra> ()  { m_pEventBridge = NULL; }
    #     inline_ void @an<_OnCleanupExtra> ()  { m_pEventBridge->SafeRelease (); }
    #     void AttachReceiver (CVolObjectPointer* pNewEventBridge);
    #     INT SendEvent (@dt<COM变体型数组类>& aryParams, CVolComVariant& varResult, CVolObject& objExtra, INT_P npExtra);
    # private:
    #     CVolObjectPointer* m_pEventBridge;
    # <> </include>
    #
    # void @sn<current_class>::AttachReceiver (CVolObjectPointer* pNewEventBridge)
    # {
    #     if (pNewEventBridge != m_pEventBridge)
    #     {
    #         m_pEventBridge->SafeRelease ();
    #         m_pEventBridge = pNewEventBridge;
    #         if (pNewEventBridge != NULL)
    #             pNewEventBridge->AddRef ();
    #     }
    # }
    #
    # INT @sn<current_class>::SendEvent (@dt<COM变体型数组类>& aryParams, CVolComVariant& varResult, CVolObject& objExtra, INT_P npExtra)
    # {
    #     @dt<事件接收器>* pobjEventReceiver = (@dt<事件接收器>*)m_pEventBridge->SafeGetVolObject ();
