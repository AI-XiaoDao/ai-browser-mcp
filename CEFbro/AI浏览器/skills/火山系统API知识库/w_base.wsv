类 本地结构指针模板 <公开 注释 = "用作支持C++结构指针的基础模板类" @模板基础类 = 真 @别名类型 = 本地参考类型>
{
    方法 创建 <公开 静态 类型 = 本地结构指针模板 注释 = "  创建并返回一个本类指针,注意不使用后必须调用销毁命令将其销毁."
            注释 = "  注意: 使用本模板类方法时,所对应的C++结构指针别名必须以\'*\'字符结束,或者以\"P\"/\"P_\"/\"LP\"/\"LP_\"这几类文本开头,"
            注释 = "譬如别名为 xxx 结构的指针, 可以使用\"Pxxx\" / \"LPxxx\" / \"P_xxx\" / \"LP_xxx\" / \"xxx*\"别名,否则将无法正确取得结构" 注释 = "指针所对应的结构数据类型."
            @嵌入式方法 = "">
    {
        @ new @dt<本地结构指针模板, n>
    }

    方法 销毁 <公开 静态 注释 = "销毁先前调用\"创建\"方法所创建的本类指针" @嵌入式方法 = "">
    参数 指针值 <类型 = 本地结构指针模板>
    {
        @ delete @<指针值>
    }

    方法 取数据尺寸 <公开 静态 类型 = 整数 注释 = "  返回本类指针所指向结构数据的尺寸."
            注释 = "  注意: 使用本模板类方法时,所对应的C++结构指针别名必须以\'*\'字符结束,或者以\"P\"/\"P_\"/\"LP\"/\"LP_\"这几类文本开头,"
            注释 = "譬如别名为 xxx 结构的指针, 可以使用\"Pxxx\" / \"LPxxx\" / \"P_xxx\" / \"LP_xxx\" / \"xxx*\"别名,否则将无法正确取得结构" 注释 = "指针所对应的结构数据类型."
            @嵌入式方法 = "">
    {
        @ (INT)sizeof (@dt<本地结构指针模板, n>)
    }

    方法 取指针 <公开 静态 类型 = 通用指针 注释 = "取回本类指针对应的通用指针" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = 本地结构指针模板>
    {
        @ (void*)@<欲操作本对象>
    }

    方法 取变整数指针 <公开 静态 类型 = 变整数 注释 = "将本数据类型值转换到变整数后返回" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = 本地结构指针模板>
    {
        @ (INT_P)@<欲操作本对象>
    }

    方法 来自变整数 <公开 静态 类型 = 本地结构指针模板 注释 = "将指定整数值转换为本数据类型值后返回" @嵌入式方法 = "">
    参数 欲转换整数值 <@匹配类型 = 通用整数型>
    {
        @ (@dt<本地结构指针模板>)@<欲转换整数值>
    }

    方法 空指针 <公开 静态 类型 = 本地结构指针模板 注释 = "将NULL指针值转换为本数据类型值后返回" @嵌入式方法 = "">
    {
        @ NULL
    }
}

