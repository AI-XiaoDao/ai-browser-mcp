<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "本文件提供视窗项目的相关基本功能" 编辑时信息 = "19331A, 0, 0, 0" @文档 = "category = \"基础类\""
        "@视窗.外部头文件.全局-110" = "libs\\win_base\\vol_base.h"
        @视窗.外部源文件 = "libs\\win_base\\cpp\\vol_assert.cpp\r\nlibs\\win_base\\cpp\\vol_classes.cpp\r\nlibs\\win_base\\cpp\\vol_functions.cpp\r\nlibs\\win_base\\cpp\\vol_time.cpp\r\nlibs\\win_base\\cpp\\vol_key.cpp\r\nlibs\\win_base\\cpp\\vol_math.cpp\r\nlibs\\win_base\\cpp\\vol_mem.cpp\r\nlibs\\win_base\\cpp\\vol_mem_pool.cpp\r\nlibs\\win_base\\cpp\\vol_muti_thread.cpp\r\nlibs\\win_base\\cpp\\vol_stream.cpp\r\nlibs\\win_base\\cpp\\vol_string.cpp\r\nlibs\\win_base\\cpp\\vol_array.cpp\r\nlibs\\win_base\\cpp\\vol_bitmap.cpp\r\nlibs\\win_base\\cpp\\vol_com.cpp"
        @视窗.外部库.x64 = "libs\\win_base\\projects\\x64\\asm_64\\spin_lock_64.lib">

类 对象类 <公开 注释 = "所有火山类的默认基础类,如果某类没有明确指定其基础类,则其基础类为本类." @别名 = "@an<CVolObject>" @默认基础类 = 真 @全局类 = 真>
{
    方法 标记值 <公开 静态 属性读 类型 = 变整数 注释 = "返回本对象中所设置的用户标记数值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.m_npUserValue
    }

    方法 标记值 <公开 静态 属性写 注释 = "设置本对象中的用户标记数值,如果未设置过,其初始值为0.">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所欲设置的标记值 <类型 = 变整数>
    {
        @ @<所欲操作的本对象>.m_npUserValue = @<所欲设置的标记值>;
    }

    # --

    方法 为指定对象类 <公开 静态 类型 = 逻辑型 注释 = "返回本对象的实际数据类型是否为所指定的类" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所检查的类型 <类型 = 对象类 注释 = "提供所欲检查是否匹配的类数据类型" @需求类型 = 数据类型>
    {
        @ @<所欲操作的本对象>.IsVolClass (VOL_RUNTIME_CLASS (@<所检查的类型>))
    }

    方法 匹配指定对象类 <公开 静态 类型 = 逻辑型 注释 = "返回本对象的实际数据类型是否匹配所指定的类(为其或其继承类)." 注释 = "注: 调用本方法的效果等同于使用\"属于\"操作符" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所检查的类型 <类型 = 对象类 注释 = "提供所欲检查是否匹配的类数据类型" @需求类型 = 数据类型>
    {
        @ @<所欲操作的本对象>.IsVolInstanceOf (VOL_RUNTIME_CLASS (@<所检查的类型>))
    }

    方法 对象类型是否相同 <公开 静态 类型 = 逻辑型 注释 = "返回本对象的实际数据类型是否与所指定对象的实际数据类型相同" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所欲检查的对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.IsVolClass (@<所欲检查的对象>.GetRuntimeClass ())
    }

    方法 对象内容是否相同 <公开 静态 类型 = 逻辑型 注释 = "  返回本对象的当前运行时实际数据类型及其中的数据内容是否与所指定对象相同." 注释 = "  注: 使用比较操作符对两个对象进行比较时将仅对比这两个对象的地址是否相同,"
            注释 = "如欲比较两个对象的数据内容是否相同,必须使用本方法." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所欲检查的对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.IsVolObjectEqual (@<所欲检查的对象>)
    }

    方法 "// 新建对象" <公开 静态 类型 = 对象类 注释 = "创建并返回一个所指定类的新对象" 返回值注释 = "所返回对象的实际数据类型等于所指定类型的对象类" @嵌入式方法 = "">
    参数 所欲创建对象的类型 <类型 = 对象类 注释 = "提供所欲创建对象的数据类型" @需求类型 = 数据类型>
    {
        @ @<所欲创建对象的类型> ()
    }

    方法 新建对象 <公开 静态 注释 = "新建一个指定类数据类型的对象" 返回值注释 = "返回所新建的对象,其类型由所提供的数据类型决定." @嵌入式方法 = "">
    参数 所欲创建对象的类型 <注释 = "提供欲新建对象的类数据类型" @匹配类型 = 通用类 @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ @<所欲创建对象的类型> ()
    }

    方法 检查复制对象 <公开 静态 类型 = 逻辑型 注释 = "  如果所提供欲复制对象的实际数据类型匹配本对象的实际数据类型(为本对象" 注释 = "的实际数据类型或其继承类),则将所指定对象的内容复制到本对象中后返回真,"
            注释 = "否则失败返回假." 返回值注释 = "如数据类型匹配则返回真,否则返回假." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所欲复制的对象 <类型 = 对象类 注释 = "  提供所欲复制到本对象的对象,其实际数据类型需要与本对象的实际数据类型" 注释 = "匹配(为本对象的实际数据类型或其继承类),否则本方法将失败返回假.">
    {
        @ @<所欲操作的本对象>.CheckCopyFrom (@<所欲复制的对象>)
    }

    方法 重置对象内容 <公开 静态 注释 = "将本对象的内容重置到初始状态(根据当前实际数据类型)" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.ResetObject ()
    }

    方法 重置为空对象 <公开 静态 注释 = "将本对象的内容重置到初始状态(根据当前实际数据类型),并设置其\"空白对象\"标志." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.ResetToNullObject ()
    }

    方法 去除空对象标志 <公开 静态 注释 = "去除掉本对象中的\"空白对象\"标志." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ @<所欲操作的本对象>.RemoveNullObjectFlag ()
    }

    方法 是否为空对象 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否设置了\"空白对象\"标志" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ (BOOL)@<所欲操作的本对象>.IsNullObject ()
    }

    方法 取空对象 <公开 静态 注释 = "返回一个设置了\"空白对象\"标志的指定类型对象" @嵌入式方法 = "">
    参数 对象类型 <类型 = 对象类 注释 = "提供所欲建立的对象类型" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ _NULL_VOL_OBJECT (@<对象类型>)
    }

    方法 取空基本对象 <公开 静态 类型 = 对象类 注释 = "返回一个设置了\"空白对象\"标志的\"对象类\"对象" @嵌入式方法 = "">
    {
        @ _NULL_VOL_OBJECT (CVolObject)
    }

    方法 取对象类输出名 <公开 静态 类型 = 文本型 注释 = "返回本对象的类输出名" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ CVolString (@<所欲操作的本对象>.GetRuntimeClass ()->GetClassFullName ())
    }

    方法 取对象类信息 <公开 静态 类型 = 对象类信息 注释 = "返回本对象的类信息" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ @dt<对象类信息> (@<所欲操作的本对象>.GetRuntimeClass ())
    }

    方法 取对象自身指针 <公开 静态 类型 = 变整数 注释 = "返回本对象的自身地址指针值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        @ (INT_P)&@<所欲操作的本对象>
    }

    方法 取对象数据 <公开 静态 类型 = 字节集类 注释 = "基于流操作获取本对象中的所有内容数据">
    参数 所欲操作的本对象 <类型 = 对象类>
    {
        变量 输出流1 <类型 = 内存输出流>
        输出流1.写对象 (所欲操作的本对象)
        返回 (输出流1.取数据 ())
    }

    方法 置对象数据 <公开 静态 注释 = "基于流操作设置本对象中的所有内容数据">
    参数 所欲操作的本对象 <类型 = 对象类>
    参数 所欲设置的内容数据 <类型 = 字节集类 注释 = "  本参数用作提供对象内容数据,该数据必须为\"取对象数据\"" 注释 = "方法所返回,否则将导致不可预知的后果.">
    {
        变量 输入流1 <类型 = 内存输入流>
        输入流1.打开 (所欲设置的内容数据)
        输入流1.读对象 (所欲操作的本对象)
    }
}

# ---

类 扩展对象类 <公开 基础类 = 对象类 注释 = "所有以此类为直接或间接基础类的对象将可以使用一些高级特性">
{
    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖 @输出名 = "GetDumpString"
            @视窗.后缀文本 = "override">
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        @ BaseClass::GetDumpString (@<展示内容>, @<最大展示数据尺寸>);
    }

    方法 流读入 <公开 注释 = "从所指定的流对象中读入本对象的数据. 请注意以下事项:" 注释 = "  1. 一旦定义了\"流读入\"方法,必须定义对应的\"流写出\"方法,所读入内容格式与"
            注释 = "\"流写出\"方法写出的内容格式必须完全一致;" 注释 = "  2. 任何类如果既没有定义\"流读入\"方法,也没有定义\"流写出\"方法,编译器会自动"
            注释 = "建立默认的\"流读入\"和\"流写出\"方法,默认方法就是首先调用基础类中的对应方法," 注释 = "然后将本对象中的所有非静态变量成员顺序从流中读入/写出;"
            注释 = "  3. 继承类中如果覆盖了本方法且基础类中也存在数据需要从流中读入,则必须负" 注释 = "责调用基础类中的\"流读入\"方法,调用格式如: \"父对象.流读入 (流对象)\";"
            注释 = "  4. 如果本方法中的读入操作比较复杂或耗时,在之前最好检查一下流对象当前是" 注释 = "否处于出错状态(\"流对象.是否出错\"方法返回真),如果出错则放弃后续的读入操作," 注释 = "以提高运行效率;"
            注释 = "  5. 在读入过程中一旦发现出错,则需要将对应的错误码写入\"流对象.错误码\"属性" 注释 = "中(流读入出错不需要,会自动写入),以禁止后续的流读入操作. 错误码可以是"
            注释 = "\"流错误码\"类中的常量值,也可以是自行定义的错误码值(必须大于0);" 注释 = "  6. 流对象一旦处于出错状态(流对象的\"错误码\"属性值不为\"流错误码.无错误\"),"
            注释 = "则后续所有流读入操作都会失败,如果欲再次使用此流对象,需要首先调用其" 注释 = "\"清除错误\"方法清除掉流的出错状态或者将流关闭后再打开." @虚拟方法 = 可覆盖 @输出名 = "@LoadFromStream"
            @视窗.后缀文本 = "override">
    参数 流对象 <类型 = 输入流类 注释 = "提供欲从其中读入本对象数据内容的输入流">

    方法 流写出 <公开 注释 = "将本对象的数据写入所指定的流对象中. 注意:" 注释 = "  1. 一旦定义了\"流写出\"方法,必须定义对应的\"流读入\"方法,所写出内容格式与"
            注释 = "\"流读入\"方法读取的内容格式必须完全一致;" 注释 = "  2. 任何类如果既没有定义\"流读入\"方法,也没有定义\"流写出\"方法,编译器会自动"
            注释 = "建立默认的\"流读入\"和\"流写出\"方法,默认方法就是首先调用基础类中的对应方法," 注释 = "然后将本对象中的所有非静态变量成员顺序从流中读入/写出;"
            注释 = "  3. 继承类中如果覆盖了本方法且基础类中也存在数据需要写出到流中,则必须负" 注释 = "责调用基础类中的\"流写出\"方法,调用格式如: \"父对象.流写出 (流对象)\";"
            注释 = "  4. 如果本方法中的写出操作比较复杂或耗时,在之前最好检查一下流对象当前是" 注释 = "否处于出错状态(\"流对象.是否出错\"方法返回真),如果出错则放弃后续的写出操作," 注释 = "以提高运行效率;"
            注释 = "  5. 在写出过程中一旦发现出错,则需要将对应的错误码写入\"流对象.错误码\"属性" 注释 = "中(流写出出错不需要,会自动写入),以禁止后续的流写出操作. 错误码可以是"
            注释 = "\"流错误码\"类中的常量值,也可以是自行定义的错误码值(必须大于0);" 注释 = "  6. 流对象一旦处于出错状态(流对象的\"错误码\"属性值不为\"流错误码.无错误\"),"
            注释 = "则后续所有流写出操作都会失败,如果欲再次使用此流对象,需要首先调用其" 注释 = "\"清除错误\"方法清除掉流的出错状态或者将流关闭后再打开." @虚拟方法 = 可覆盖 @输出名 = "@SaveIntoStream"
            @视窗.后缀文本 = "override">
    参数 流对象 <类型 = 输出流类 注释 = "提供欲将本对象数据内容写出到其中的输出流">
}

# ---

类 对象包装类 <公开 注释 = "  用作在其中包装一个任意实际数据类型的火山类对象.本类对象之间赋值时,采用" 注释 = "参考赋值方式,原对象和被赋值到对象将指向同一个被包装的火山对象实例."
        @别名 = "CVolWrapperObject">
{
    方法 是否为空 <公开 静态 类型 = 逻辑型 注释 = "返回本对象的内容是否为空" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    {
        @ @<所欲操作本对象>.IsEmpty ()
    }

    方法 清空 <公开 静态 注释 = "清空本对象的内容" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    {
        @ @<所欲操作本对象>.Empty ()
    }

    方法 置对象 <公开 静态 类型 = 对象类 注释 = "置入一个火山对象实例到本对象中" 返回值注释 = "返回被置入到本对象中的复制对象实例" @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所欲置入的对象 <类型 = 对象类 注释 = "  提供所欲置入的对象实例,类库将会创建一个新的同实际数据类型" 注释 = "对象然后将其内容复制进去后置入本对象.">
    {
        @ @<所欲操作本对象>.SetVolObject (@<所欲置入的对象>)
    }

    方法 创建新对象 <公开 静态 注释 = "创建一个所指定类型的新火山对象实例并置入本对象中" 返回值注释 = "返回被置入到本对象中的新对象实例" @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所欲创建对象的类型 <类型 = 对象类 注释 = "提供所欲新建对象的数据类型" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲创建对象的类型>&)@<所欲操作本对象>.CreateNewVolObject (VOL_RUNTIME_CLASS (@<所欲创建对象的类型>))
    }

    方法 创建新对象2 <公开 静态 类型 = 对象类 注释 = "创建一个所指定类型的新火山对象实例并置入本对象中" 返回值注释 = "返回被置入到本对象中的新对象实例" @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所欲创建对象的类型 <类型 = 对象类信息 注释 = "提供所欲新建对象的数据类型,注意此信息的内容不能为空.">
    {
        @ @<所欲操作本对象>.CreateNewVolObject (@<所欲创建对象的类型>.m_pRuntimeClass)
    }

    方法 取对象 <公开 静态 类型 = 对象类 注释 = "  返回包装在本对象中火山对象实例的参考,如果本对象的内容为空,则将返回" 注释 = "一个数据类型为\"对象类\"的空对象(其\"是否为空对象\"方法返回真)."
            注释 = "  注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "    挂接事件 ((对象实际数据类型)变量1.取对象 ())"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    {
        @ @<所欲操作本对象>.GetVolObject (CVolObject ())
    }

    方法 匹配指定类 <公开 静态 类型 = 逻辑型 注释 = "返回包装在本对象中的火山对象实例的实际数据类型是否匹配所指定的类(为其或其继承类)" @嵌入式方法 = "">
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所检查的类型 <类型 = 对象类 注释 = "提供所欲检查是否匹配的类数据类型" @需求类型 = 数据类型>
    {
        @ @<所欲操作本对象>.IsVolObjectClass (VOL_RUNTIME_CLASS (@<所检查的类型>))
    }

    方法 取指定类型对象 <公开 静态 注释 = "返回包装在本对象中火山对象实例的参考." 注释 = "注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "  挂接事件 (变量1.取指定类型对象 (对象实际数据类型))"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所欲获取对象的类型 <类型 = 对象类 注释 = "  提供所欲获取对象的数据类型,如果包装在本对象中的火山对象实例不匹配该数据" 注释 = "类型(为其或其继承类对象),将返回一个为该数据类型的空对象(其\"是否为空对象\""
            注释 = "方法返回真)." @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)@<所欲操作本对象>.GetVolObject (VOL_RUNTIME_CLASS (@<所欲获取对象的类型>), @<所欲获取对象的类型> ())
    }

    方法 对象 <公开 静态 注释 = "  返回包装在本对象中火山对象实例的参考." 注释 = "  注意: 本方法为\"取指定类型对象\"的快捷操作版,不会进行各种安全性检查.因此"
            注释 = "执行本方法前,必须确保本对象内容不为空且其中所包装对象符合所指定的数据类型" 注释 = "(即\"匹配指定类\"方法必须返回真),否则在运行时程序将崩溃(调试运行时会报错)."
            注释 = "  注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "    挂接事件 (变量1.取指定类型对象 (对象实际数据类型))"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    参数 所欲操作本对象 <类型 = 对象包装类 注释 = "提供所欲操作的本对象">
    参数 所欲获取对象的类型 <类型 = 对象类 注释 = "  提供所欲获取对象的数据类型,必须确保本对象内容不为空且其中所包装对象匹配" 注释 = "该数据类型(即\"匹配指定类 (所欲获取对象的类型)\"方法调用必须返回真),否则在运"
            注释 = "行时程序将崩溃(调试运行时会报错)." @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)@<所欲操作本对象>._VWRP_OBJ (VOL_RUNTIME_CLASS (@<所欲获取对象的类型>))
    }
}

类 对象包装数组类 <公开 基础类 = 对象数组模板类 注释 = "成员数据类型为\"对象包装类\"的数组" @模板实现类 = "对象包装类">

# ---

类 对象类信息 <公开 基础类 = 扩展对象类 注释 = "用作记录对象的运行时类信息">
{
    方法 获取 <公开 静态 类型 = 对象类信息 注释 = "获取并返回所指定类的运行时信息" @嵌入式方法 = "">
    参数 所欲置入的对象类 <类型 = 对象类 注释 = "该对象类的运行时信息将被置入本对象中" @需求类型 = 数据类型>
    {
        @ @dt<对象类信息> (VOL_RUNTIME_CLASS (@<所欲置入的对象类>))
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象的内容是否为空" @嵌入式方法 = "">
    {
        @ @sn<this>.m_pRuntimeClass == NULL
    }

    方法 置对象类 <公开 注释 = "将所指定类的运行时信息置入本对象中" @嵌入式方法 = "">
    参数 所欲置入的对象类 <类型 = 对象类 注释 = "该对象类的运行时信息将被置入本对象中" @需求类型 = 数据类型>
    {
        @ @sn<this>.m_pRuntimeClass = VOL_RUNTIME_CLASS (@<所欲置入的对象类>)
    }

    方法 为指定类 <公开 类型 = 逻辑型 注释 = "返回本对象中当前所保存的运行时类信息是否为所指定的类" @嵌入式方法 = "">
    参数 所检查的类型 <类型 = 对象类 注释 = "提供所欲检查的类数据类型" @需求类型 = 数据类型>
    {
        @ @sn<this>.m_pRuntimeClass->SafeIsEqual (VOL_RUNTIME_CLASS (@<所检查的类型>))
    }

    方法 置对象实例类 <公开 注释 = "将所指定对象的运行时类信息置入本对象中" @嵌入式方法 = "">
    参数 所欲置入的对象 <类型 = 对象类 注释 = "该对象的运行时类信息将被置入本对象中">
    {
        @ @sn<this>.m_pRuntimeClass = @<所欲置入的对象>.GetRuntimeClass ()
    }

    方法 为指定实例类 <公开 类型 = 逻辑型 注释 = "返回本对象中当前所保存的运行时类信息是否为所指定对象实例的类" @嵌入式方法 = "">
    参数 所检查的对象 <类型 = 对象类 注释 = "提供所欲检查的对象实例,将依据此对象的实际数据类型进行检查.">
    {
        @ @sn<this>.m_pRuntimeClass->SafeIsEqual (@<所检查的对象>.GetRuntimeClass ())
    }

    方法 创建对象 <公开 类型 = 逻辑型 注释 = "根据本对象中当前所保存的运行时类信息创建对应的对象实例,返回是否成功." 返回值注释 = "本对象中当前内容为空返回假,否则返回真." @禁止流程检查 = 真>
    参数 所创建的对象 <类型 = 对象包装类 注释 = "如果本方法返回真,则所创建的对象实例将保存到此参数中,其中的已有内容将被覆盖.">
    {
        @ if (m_pRuntimeClass == NULL)  return FALSE;
        @ @<所创建的对象>.CreateNewVolObject (m_pRuntimeClass);
        @ return TRUE;
    }

    方法 创建指定类型对象 <公开 类型 = 逻辑型 注释 = "根据本对象中当前所保存的运行时类信息创建所指定类型的对象实例,返回是否成功." 注释 = ""
            返回值注释 = "如果本对象中当前所保存的运行时类信息为所指定数据类型,返回真,否则返回假." @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 所欲创建对象的类型 <类型 = 对象类 注释 = "提供所欲创建对象的数据类型" @需求类型 = 数据类型>
    参数 所创建的对象 <类型 = 对象包装类 注释 = "如果本方法返回真,则所创建的对象实例将保存到此参数中,其中的已有内容将被覆盖.">
    {
        @ (@<所欲创建对象的类型>&)@sn<this>.CreateVolObject (VOL_RUNTIME_CLASS (@<所欲创建对象的类型>), @<所创建的对象>)
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        @ if (m_pRuntimeClass == NULL)  @<展示内容>.SetText (_T ("[空]")); else @<展示内容>.SetText (m_pRuntimeClass->GetClassFullName ());
    }

    # --
    # @ <include>
    # @ inline_ @sn<current_class> (CVolRuntimeClass* pRuntimeClass) : @sn<current_class> ()  { m_pRuntimeClass = pRuntimeClass; }
    # @ inline_ void @an<_OnInitExtra> ()  { m_pRuntimeClass = NULL; }
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_pRuntimeClass = objCopyFrom.m_pRuntimeClass; }
    # @ inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return m_pRuntimeClass->SafeIsEqual (objCompare.m_pRuntimeClass); }
    # @ inline_ BOOL CreateVolObject (const CVolRuntimeClass* pRuntimeClass, CVolWrapperObject& objWrapper)
    # @ {
    # @     if (m_pRuntimeClass->SafeIsEqual (pRuntimeClass) == FALSE)  return FALSE;
    # @     objWrapper.CreateNewVolObject (pRuntimeClass);
    # @     return TRUE;
    # @ }
    # @ CVolRuntimeClass* m_pRuntimeClass;
    # @ </include>
}

