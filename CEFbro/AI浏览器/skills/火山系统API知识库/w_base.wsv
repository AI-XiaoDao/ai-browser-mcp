类 指针类 <公开 注释 = "  由于火山视窗程序没有支持参考型变量,特提供本类用作支持通过指针对其它基本" 注释 = "数据类型或对象实例数据进行访问,以间接达到参考型变量的效果."
        注释 = "  由于是指针操作,使用本类务必仔细小心,避免程序出错.">
{
    方法 置指针 <公开 注释 = "设置本对象中指针所指向的数据内容" @嵌入式方法 = "">
    参数 所指向的数据 <注释 = "该数据的地址指针将被置入本对象中,以后可以通过\"读\"/\"写\"方法访问." @匹配类型 = 所有类型>
    {
        @ @sn<this>.@n<指针> = (INT_P)&@<所指向的数据>
    }

    方法 读 <公开 注释 = "返回先前通过\"置指针\"方法所提供的数据指针内容,对该内容进行操作等同于对指针内容进行操作." 注释 = "调用本方法前必须满足以下前提:"
            注释 = "  1. 必须已经通过调用\"置指针\"方法置入了有效且为指定数据类型(由\"欲获取数据类型\"参数指定)的数据指针;" 注释 = "  2. \"置指针\"方法所置入指针指向的数据必须确保有效存在."
            注释 = "如果不能保证以上事项,调用本方法程序将崩溃." @嵌入式方法 = "">
    参数 指针数据类型 <注释 = "提供所欲读出数据的数据类型,必须与调用\"置指针\"方法所提供数据的数据类型匹配." 注释 = "匹配的意思是:"
            注释 = "   1. 如果调用\"置指针\"方法所提供数据的数据类型为基本数据类型,则必须相同;" 注释 = "   2. 如果调用\"置指针\"方法所提供数据的数据类型为类,则可以为该类或该类的基础类." @返回值类型 = 0
            @需求类型 = 数据类型 @匹配类型 = 所有类型>
    {
        @ (*(@<指针数据类型>*)@sn<this>.@n<指针>)
    }

    方法 写 <公开 注释 = "将指定数据写入先前通过\"置指针\"方法所提供的数据指针中." 注释 = "调用本方法前必须满足以下前提:"
            注释 = "  1. 必须已经通过调用\"置指针\"方法置入了有效且为指定数据类型(由\"欲写入数据\"参数提供)的数据指针;" 注释 = "  2. \"置指针\"方法所置入指针指向的数据必须确保有效存在."
            注释 = "如果不能保证以上事项,调用本方法程序将崩溃." @嵌入式方法 = "">
    参数 指针数据类型 <注释 = "必须与调用\"置指针\"方法所提供数据的数据类型相同" @需求类型 = 数据类型 @匹配类型 = 所有类型>
    参数 欲写入数据 <注释 = "提供所欲写入的数据,必须与调用\"置指针\"方法所提供数据的数据类型相同或匹配." @匹配类型 = 所有类型>
    {
        @ *(@<指针数据类型>*)@sn<this>.@n<指针> = @<欲写入数据>
    }

    方法 清除 <公开 注释 = "清除本对象中所指向的数据指针">
    {
        指针 = 0
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象中是否不存在\"置指针\"方法所置入的指针">
    {
        返回 (指针 == 0)
    }

    变量 指针 <公开 类型 = 变整数>
}

# --

类 指针模板类 <公开 注释 = "  由于火山视窗程序没有支持参考型变量,特提供本类用作支持通过指针对其它基本" 注释 = "数据类型或对象实例数据进行访问,以间接达到参考型变量的效果."
        注释 = "  由于是指针操作,使用本类务必仔细小心,避免程序出错." 注释 = "  模板类型1: 所欲操作数据的类型" @模板基础类 = 真>
{
    方法 置指针 <公开 注释 = "设置本对象中指针所指向的数据内容" @嵌入式方法 = "">
    参数 所指向的数据 <类型 = 模板类型1 注释 = "该数据的地址指针将被置入本对象中,以后可以通过\"读\"/\"写\"方法访问.">
    {
        @ @sn<this>.@n<指针> = (INT_P)&@<所指向的数据>
    }

    方法 读 <公开 类型 = 模板类型1 注释 = "返回先前通过\"置指针\"方法所提供的数据指针内容,对该内容进行操作等同于对指针内容进行操作." 注释 = "调用本方法前必须满足以下前提:"
            注释 = "  1. 必须已经通过调用\"置指针\"方法置入了有效的数据指针;" 注释 = "  2. \"置指针\"方法所置入指针指向的数据必须确保有效存在." 注释 = "如果不能保证以上事项,调用本方法程序将崩溃."
            @嵌入式方法 = "">
    {
        @ (*(@dt<模板类型1>*)@sn<this>.@n<指针>)
    }

    方法 写 <公开 注释 = "将指定数据写入先前通过\"置指针\"方法所提供的数据指针中." 注释 = "调用本方法前必须满足以下前提:" 注释 = "  1. 必须已经通过调用\"置指针\"方法置入了有效的数据指针;"
            注释 = "  2. \"置指针\"方法所置入指针指向的数据必须确保有效存在." 注释 = "如果不能保证以上事项,调用本方法程序将崩溃." @嵌入式方法 = "">
    参数 欲写入数据 <类型 = 模板类型1 注释 = "提供所欲写入的数据">
    {
        @ *(@dt<模板类型1>*)@sn<this>.@n<指针> = @<欲写入数据>
    }

    方法 清除 <公开 注释 = "清除本对象中所指向的数据指针">
    {
        指针 = 0
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本对象中是否不存在\"置指针\"方法所置入的指针">
    {
        返回 (指针 == 0)
    }

    变量 指针 <公开 类型 = 变整数>
}

# --
#
# @begin
#
# // 本宏用作定义参考型数据对象类.
# // 注意: 建立参考型数据时务必小心,一定要确认数据之间不会形成循环引用.
# // 注意: 如果要释放m_pRefObject,不能直接调用m_pRefObject->Release,而要调用ReleaseRefObject,因为继承类中可能覆盖了此方法进行了额外处理.
# @def_macro DECLARE_REF_OBJECT_CLASS(ref_data_type, initial_value)  \
# <>     <include>  \
#     protected:  \
#         inline_ void @an<_OnInitExtra> ()  {  m_pRefObject = initial_value; }  \
#         inline_ void @an<_OnCleanupExtra> ()  { if (m_pRefObject != NULL)  m_pRefObject->Release (); }  \
#         inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { SetRefObject (objCopyFrom.m_pRefObject); }  \
#         inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return (m_pRefObject == objCompare.m_pRefObject); }  \
#         ref_data_type* m_pRefObject;  \
#     public:  \
#         void SetRefObject (ref_data_type* pRefObject);  \  // 设置参考对象
#         void TakeOverNewRefObject (ref_data_type* pNewRefObject);  \  // 接管一个新建的参考对象,pNewRefObject本身所具有的参考将被转移到本对象中接管.
#         inline_ ref_data_type* GetRefObject ()  {  return m_pRefObject;  }  \
# <>     </include>  \
#     void @sn<current_class>::SetRefObject (ref_data_type* pRefObject)  \
#     {  \
#         ASSERT_R_DATA_OR_NULL (pRefObject);  \
#         if (pRefObject != NULL)  pRefObject->AddRef ();  \
#         if (m_pRefObject != NULL)  m_pRefObject->Release ();  \
#         m_pRefObject = pRefObject;  \
#     }  \
#     void @sn<current_class>::TakeOverNewRefObject (ref_data_type* pNewRefObject)  \  // 接管pNewRefObject对象的释放工作,其不再由调用方负责.
#     {  \
#         ASSERT (pNewRefObject != m_pRefObject);  \  // pNewRefObject应该是一个新建的对象
#         ASSERT_R_DATA_OR_NULL (pNewRefObject);  \
#         if (m_pRefObject != NULL)  m_pRefObject->Release ();  \
#         m_pRefObject = pNewRefObject;  \
#     }
#
# //--
#
# // 用作定义携带有新建实例对象的参考对象类的继承类.
# // 使用本宏的类必须是"参考对象类"的继承类.
# @def_macro DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_NEW_OBJECT(ref_data_type)  \
# <>     <include>  \
#     inline_ void @an<_OnInitExtra> ()  { ASSERT (m_pRefObject == NULL); m_pRefObject = new ref_data_type; }  \
#     inline_ ref_data_type* pdata ()  { return (ref_data_type*)m_pRefObject; }  \
# <>     </include>
#
# // 用作定义携带有新建实例对象的参考对象类的继承类.
# // 使用本宏的类不要求必须是"参考对象类"的继承类.
# @def_macro DECLARE_REF_OBJECT_CLASS_WITH_NEW_OBJECT(ref_data_type)  \
#     @m<DECLARE_REF_OBJECT_CLASS> (ref_data_type, new ref_data_type) 
#
# //--
#
# // 用作获取所参考到的值数据
# @def_macro DECLARE_VOL_REF_DATA_GETTER(value_data_type)  \
# <>     <include>  \
#     public:  \
#         inline_ value_data_type& data ()  { return ((CRefObjectWithData<value_data_type>*)m_pRefObject)->m_data; }  \
#         inline_ value_data_type* pdata ()  { return &((CRefObjectWithData<value_data_type>*)m_pRefObject)->m_data; }  \
# <>     </include>
#
# // 用作定义携带有另一指定数据类型实例数据的参考对象类的继承类.
# // 使用本宏的类必须是"参考对象类"的继承类.
# @def_macro DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA(value_data_type)  \
#     @m<DECLARE_VOL_REF_DATA_GETTER> (value_data_type)  \
# <>     <include>  \
#     inline_ void @an<_OnInitExtra> ()  { ASSERT (m_pRefObject == NULL); m_pRefObject = new CRefObjectWithData<value_data_type>; }  \
# <>     </include>
#
# // 同上,不过支持一个额外的构造参数.
# @def_macro DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA2(value_data_type, construct_param)  \
#     @m<DECLARE_VOL_REF_DATA_GETTER> (value_data_type)  \
# <>     <include>  \
#     inline_ void @an<_OnInitExtra> ()  { ASSERT (m_pRefObject == NULL); m_pRefObject = new CRefObjectWithData<value_data_type (construct_param)>; }  \
# <>     </include>
#
# // 用作定义携带有另一指定数据类型实例数据的参考对象类
# // 使用本宏的类不要求必须是"参考对象类"的继承类.
# @def_macro DECLARE_REF_OBJECT_CLASS_WITH_DATA(value_data_type)  \
#     @m<DECLARE_REF_OBJECT_CLASS> (CRefObject, new CRefObjectWithData<value_data_type>)  \
#     @m<DECLARE_VOL_REF_DATA_GETTER> (value_data_type)
#
# //--
#
# // 用作快捷封装C++结构
# //   struct_data_type: 所封装C++结构的数据类型
# @def_macro DECLARE_STRUCT_CLASS(struct_data_type)  \
# <>     <include>  \
#     typedef struct_data_type DATA_TYPE;  \
#     @sn<current_class> (DATA_TYPE& data) : @sn<current_class> ()  { m_pData = &data; COPY_MEM (&m_data, &data, sizeof (DATA_TYPE)); }  \
#     inline_ void @an<_OnInitExtra> ()  { m_pData = NULL; ZERO_MEM (&m_data, sizeof (DATA_TYPE)); }  \
#     inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_pData = NULL; COPY_MEM (&m_data, objCopyFrom.pdata (), sizeof (DATA_TYPE)); }  \
#     inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return (memcmp (pdata (), objCompare.pdata (), sizeof (DATA_TYPE)) == 0); }  \
#     inline_ @sn<current_class>& Copy (DATA_TYPE& data)  { m_pData = NULL; COPY_MEM (&m_data, &data, sizeof (DATA_TYPE)); return *this; }  \
#     inline_ DATA_TYPE* pdata ()  { return (m_pData != NULL ? m_pData : &m_data); }  \
#     inline_ const DATA_TYPE* pdata () const  { return (m_pData != NULL ? m_pData : &m_data); }  \
#     inline_ INT get_size () const  { return sizeof (DATA_TYPE); }  \
#     inline_ CVolMem& get_bin (CVolMem& memBuf)  { memBuf.CopyFrom (pdata (), sizeof (DATA_TYPE)); return memBuf; }  \
#     private:  DATA_TYPE* m_pData; DATA_TYPE m_data;  \
# <>     </include>
#
# // 下列宏用作读写结构或C++类中的子结构成员. 注意: 使用下列宏的方法不能为嵌入式方法.
# // 本宏用作读取结构或C++类中的子结构成员,此类成员必须使用本宏读取,以支持对所返回对象的内容进行修改时能够直接修改到本对象.
# //   child_class_data_type: 所欲访问子结构成员使用 DECLARE_STRUCT_CLASS / DECLARE_CPPCLS_CLASS 宏封装的对应火山类名;
# //   child_member_name: 所欲访问子结构成员(或子结构对应首成员)的名称
# @def_macro GET_STRUCT_MEMBER(child_class_data_type, child_member_name)  *(@dt<child_class_data_type>::DATA_TYPE*)&pdata ()->child_member_name
# // 本宏用作设置结构或C++类中的子结构成员.
# //   objSetFrom: 所欲将其结构内容设置进来的火山类对象
# @def_macro SET_STRUCT_MEMBER(child_member_name, objSetFrom)  COPY_MEM (&pdata ()->child_member_name, objSetFrom.pdata (), sizeof (*objSetFrom.pdata ()))

类 结构基础类 <公开 注释 = "本类可以在封装C++结构时作为其基础类,用作提供一些基本的操作功能." 注释 = "注意: 本类唯一可以使用的位置为作为使用 DECLARE_STRUCT_CLASS 宏进行结构封装的类的基础类."
        @禁止创建对象 = 真>
{
    方法 取结构指针 <公开 类型 = 变整数 注释 = "返回继承类中所封装C++结构的指针地址" @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.pdata ()
    }

    方法 取结构尺寸 <公开 类型 = 整数 注释 = "返回继承类中所封装C++结构的尺寸" @嵌入式方法 = "">
    {
        @ @sn<this>.get_size ()
    }

    方法 取结构字节集 <公开 类型 = 字节集类 注释 = "返回继承类中所封装C++结构所对应的字节集数据" @嵌入式方法 = "">
    {
        @ @sn<this>.get_bin (CVolMem ())
    }
}

# //--
#
# // 用作快捷封装C++类
# //   cppcls_data_type: 所封装C++类的数据类型,该类必须覆盖支持了赋值操作符.
# @def_macro DECLARE_CPPCLS_CLASS(cppcls_data_type)  \
# <>     <include>  \
#     typedef cppcls_data_type DATA_TYPE;  \
#     @sn<current_class> (DATA_TYPE& obj) : @sn<current_class> ()  { m_pObject = &obj; m_obj = obj; }  \
#     inline_ void @an<_OnInitExtra> ()  { m_pObject = NULL; }  \
#     inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_pObject = NULL; m_obj = *objCopyFrom.pdata (); }  \
#     inline_ @sn<current_class>& Copy (DATA_TYPE& obj)  { m_pObject = NULL; m_obj = obj; return *this; }  \
#     inline_ DATA_TYPE* pdata ()  { return (m_pObject != NULL ? m_pObject : &m_obj); }  \
#     inline_ const DATA_TYPE* pdata () const  { return (m_pObject != NULL ? m_pObject : &m_obj); }  \
#     private:  DATA_TYPE* m_pObject; DATA_TYPE m_obj;  \
# <>     </include>
#
# // 下列宏用作读写结构或C++类中数据类型为C++类的子成员. 注意: 使用下列宏的方法不能为嵌入式方法.
# // 本宏用作读取结构或C++类中数据类型为C++类的子成员,此类成员必须使用本宏读取,以支持对所返回对象的内容进行修改时能够直接修改到本对象.
# //   child_member_name: 所欲访问数据类型为C++类的子成员名称
# @def_macro GET_CPPCLS_MEMBER(child_member_name)  pdata ()->child_member_name
# // 本宏用作设置结构或C++类中数据类型为C++类的子成员.
# //   objSetFrom: 所欲将其C++类内容设置进来的火山类对象
# @def_macro SET_CPPCLS_MEMBER(child_member_name, objSetFrom)  pdata ()->child_member_name = *objSetFrom.pdata ()
#
# @end
#
