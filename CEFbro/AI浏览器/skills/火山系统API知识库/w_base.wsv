类 参考对象模板类 <公开 基础类 = 参考对象类 注释 = "支持保存一个具有指定类型参考型数据的模板基础类." 注释 = "模板类型1: 所欲保存的参考型数据的数据类型(可以是任意除数组外的数据类型,包括对象类)."
        注释 = "提示: 可以使用为对象类的模板类型1,以支持在该类销毁时自动调用\"类_清理\"方法进行相关清理工作." @模板基础类 = 真>
{
    方法 类_初始化
    {
        @ ASSERT (m_pRefObject == NULL);
        @ m_pRefObject = new CRefObjectWithData<@dt<模板类型1>>;
    }

    方法 参考数据 <公开 属性读 类型 = 模板类型1 注释 = "  返回当前所参考到的数据,可以直接对本属性所返回数据中的" 注释 = "成员值进行修改,注意将会影响所有参考到该数据的对象实例." @视窗.返回参考 = 真
            @禁止流程检查 = 真>
    {
        @ return GetData ();
    }

    方法 参考数据 <公开 属性写 注释 = "设置当前所参考到的数据,注意将会影响所有参考到该数据的对象实例.">
    参数 所欲设置的数据 <类型 = 模板类型1>
    {
        @ SetData (@<所欲设置的数据>);
    }

    # --
    #
    # @begin
    # <> <include>
    # @dt<模板类型1>& GetData ();
    # void SetData (const @dt<模板类型1>& data);
    # <> </include>
    #
    # @dt<模板类型1>& @sn<current_class>::GetData ()  { return ((CRefObjectWithData<@dt<模板类型1>>*)m_pRefObject)->m_data; }
    # void @sn<current_class>::SetData (const @dt<模板类型1>& data)  { ((CRefObjectWithData<@dt<模板类型1>>*)m_pRefObject)->m_data = data; }
    # @end
}

