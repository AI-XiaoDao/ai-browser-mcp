类 基本数据封装类 <公开 @别名 = "CVolBaseDataType" @禁止创建对象 = 真>
{

    # @begin
    # @def_macro DECLARE_BASE_ENVELOPE_CLASS  \
    # <>     <include>  \
    #     virtual void* GetDataPtr () override  { return &@<值>; }  \
    #     virtual void GetDumpString (CVolString& strDump, INT nMaxDumpSize) override  { strDump.SetValueText (@<值>); }  \
    # <>     </include>
    # @end
}

类 字节类 <公开 基础类 = 基本数据封装类 注释 = "  提供对字节基本数据类型的封装,一般用作支持通过方法参数来传递回对应的基本数据类型数据."
        注释 = "  由于除开\"文本型\"以外的基本数据类型参数数据传递均采用值传递方式,因此在被调用方法内部" 注释 = "对这些参数值进行修改并不能返回到方法调用方,如果有此类需求,可以通过改用对应的基本数据类"
        注释 = "型封装类的方式,将值传递转换为参考传递,从而达到将方法内部的修改传递到调用方的要求." 注释 = "  譬如: 假设一个方法需要返回两个整数,但是方法返回值只能返回一个,可以通过定义一个数据类"
        注释 = "型为\"整数类\"的参数来返回,因为在方法内部对该参数对象的\"值\"成员进行更改可以被返回到调用方." 注释 = "  文本型数据本身就是以参考方式进行方法参数数据传递的,因此不需要进行封装."
        @文档 = "category = \"基础类.基本数据类型封装类\"">
{
    变量 值 <公开 类型 = 字节 注释 = "提供所封装的字节基本数据类型值" @属性变量 = 真>

    # @ @m<基本数据封装类.DECLARE_BASE_ENVELOPE_CLASS>
}

