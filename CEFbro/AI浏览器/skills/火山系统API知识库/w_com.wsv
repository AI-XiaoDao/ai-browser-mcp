        @ (BOOL)@<所操作本对象>.Invoke (CVolComObject::IMT_RUN_METHOD, @<方法名称>.GetText (), 2, _T (@sn<pm_types>), @<参数数据>)
    }

    方法 无参数方法 <公开 静态 注释 = "  执行本对象中所指定名称的方法,返回该方法执行后的结果值. 本方法用作执行无参数的COM方法."
            注释 = "  执行本方法如果失败,\"所欲获取数据类型\"为数值型时返回0,为逻辑型时返回假,为文本型时返回空文本,为COM对象类或"
            注释 = "COM变体型时返回内容为空的该类对象(COM对象类/COM变体型的\"是否为空\"方法返回真)."
            注释 = "  紧跟本方法后调用\"是否成功\"方法将返回本方法是否执行成功,调用\"取错误\"方法将返回具体的错误码值(成功将返回" 注释 = "\"COM方法调用结果.成功\")." @嵌入式方法 = "">
    参数 所操作本对象 <类型 = COM对象类>
    参数 方法名称 <类型 = 文本型 注释 = "提供所欲执行方法的名称">
    参数 所欲获取数据类型 <注释 = "提供所欲获得的返回值数据类型." 注释 = "注意: 只能为基本数据类型/常量类/COM对象类/COM变体型,否则本地编译器将编译出错.如果欲读取数据类型为"
            注释 = "\"COM对象类\"的继承类,请使用\"无参数对象型方法\"." @匹配类型 = 通用型 @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ @<所操作本对象>.Invoke_@<所欲获取数据类型> (CVolComObject::IMT_RUN_METHOD, @<方法名称>.GetText (), 0, _T (""))
    }

    方法 无参数对象型方法 <公开 静态 注释 = "  执行本对象中所指定名称的方法,返回该方法执行后的结果值. 本方法用作执行无参数的COM方法."
            注释 = "  执行本方法如果失败,返回内容为空的该类对象(COM对象类的\"是否为空\"方法返回真)." 注释 = "  紧跟本方法后调用\"是否成功\"方法将返回本方法是否执行成功,调用\"取错误\"方法将返回具体的错误码值(成功将返回"
            注释 = "\"COM方法调用结果.成功\")." @嵌入式方法 = "">
    参数 所操作本对象 <类型 = COM对象类>
    参数 方法名称 <类型 = 文本型 注释 = "提供所欲执行方法的名称">
    参数 所欲获取数据类型 <类型 = COM对象类 注释 = "提供所欲获得的返回值数据类型" @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取数据类型>&)@<所操作本对象>.Invoke_ComObject (CVolComObject::IMT_RUN_METHOD, @<方法名称>.GetText (), @<所欲获取数据类型> (), 0, _T (""))
    }

    方法 无参数及返回值方法 <公开 静态 类型 = 逻辑型 注释 = "  执行本对象中所指定名称的方法. 本方法用作执行无参数且无返回值" 注释 = "COM方法或者执行无参数COM方法但不需要返回数据."
            返回值注释 = "  返回执行本方法是否成功.如果失败,紧跟本方法后调用\"取错误\"方法" 返回值注释 = "将返回具体的错误码值." @嵌入式方法 = "">
    参数 所操作本对象 <类型 = COM对象类>
    参数 方法名称 <类型 = 文本型 注释 = "提供所欲执行方法的名称">
    {
        @ (BOOL)@<所操作本对象>.Invoke (CVolComObject::IMT_RUN_METHOD, @<方法名称>.GetText (), 0, _T (""))
    }

    方法 查看接口 <公开 静态 注释 = "启动一个对话框来显示本对象的COM接口信息." 注释 = "注意: 本方法只能在主界面线程中执行."
            @视窗.外部头文件 = "libs\\win_base\\include\\vol_com_inf.h" @视窗.外部源文件 = "libs\\win_base\\cpp\\tr_vol_com_inf.cpp"
            @视窗.外部资源文件 = "libs\\win_base\\cpp\\res\\vol_com_inf.rc">
    参数 所操作本对象 <类型 = COM对象类>
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供对话框的父窗口句柄,为0表示使用默认父窗口." @默认值 = 0>
    {
        @ CVolComViewDialog dlg;
        @ dlg.ShowDialog ((HWND)@<父窗口句柄>, @<所操作本对象>.GetUnknownObject ());
    }
}

类 COM对象事件类 <公开 注释 = "用作提供对COM对象事件的挂接操作">
{
    方法 接收到事件 <公开 定义事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">

    方法 挂接 <公开 类型 = 逻辑型 注释 = "挂接指定COM对象的指定事件接口,返回是否成功." @嵌入式方法 = "">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供欲挂接其中事件的具体COM对象." 注释 = "该对象在\"接收到事件\"事件方法中将反馈过去.">
    参数 事件接口名称 <类型 = 文本型 注释 = "  提供所欲挂接的事件接口IID文本,如\"{bdfff072-497b-407b-a8f2-450d6e7b6827}\","
            注释 = "如果为空文本,则自动去查找使用\"来源COM对象\"所实现的默认事件来源接口." @默认值 = "">
    {
        @ (BOOL)@sn<this>.m_objHandler.SetupConnectionPoint (@<来源COM对象>.GetUnknownObject (), @<事件接口名称>.GetText ())
    }

    方法 取消挂接 <公开 注释 = "取消先前所挂接的COM事件" @嵌入式方法 = "">
    {
        @ @sn<this>.m_objHandler.ShutdownConnectionPoint ()
    }

    # --
    #
    # @begin
    #
    # <> <include>
    # void @an<_OnInitExtra> ();
    # CComEventHandler m_objHandler;
    # <> </include>
    #
    # static void sOnComEvent (CVolComObject& objEventSource, const INT dispIdMember, CVolObjectArray& aryParamVariants, CVolComVariant& vResult, UINT_P upUserData)
    # {
    #     ASSERT (upUserData != NULL);
    #     ((@sn<current_class>*)upUserData)->@<接收到事件> (objEventSource, dispIdMember, aryParamVariants, vResult);
    # }
    #
    # void @sn<current_class>::@an<_OnInitExtra> ()
    # {
    #     m_objHandler.init (sOnComEvent, (UINT_P)this);
    # }
    #
    # @end
}

类 COM字体类 <公开 基础类 = COM对象类 注释 = "用作记录一个COM字体对象(IFontDisp)">
{
    方法 从描述文本创建字体 <公开 静态 类型 = COM字体类 注释 = "从一个指定格式的字体描述文本创建字体对象" 返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)."
            @禁止流程检查 = 真>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅,旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\".">
    {
        @ LOGFONT infFont;
        @ GetFontDescTextInfo (@<字体描述文本>, &infFont);
        @ @sn<current_class> obj;
        @ obj.CreateFontDispObjectFromInfo (&infFont);
        @ return obj;
    }

    方法 创建默认GUI字体 <公开 静态 类型 = COM字体类 注释 = "创建操作系统所使用的默认GUI字体对象" 返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)."
            @禁止流程检查 = 真>
    {
        @ LOGFONT infFont;
        @ GetDefaultFontInfo (&infFont);
        @ @sn<current_class> obj;
        @ obj.CreateFontDispObjectFromInfo (&infFont);
        @ return obj;
    }

    方法 创建字体 <公开 静态 类型 = COM字体类 注释 = "从指定参数创建并返回一个字体对象" 返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 字体名称 <类型 = 文本型 注释 = "提供所欲创建字体的名称">
    参数 字体尺寸 <类型 = 整数 注释 = "提供所欲创建字体的尺寸,单位为磅.">
    参数 是否粗体 <类型 = 逻辑型 @默认值 = 假>
    参数 是否斜体 <类型 = 逻辑型 @默认值 = 假>
    参数 是否有下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 是否有删除线 <类型 = 逻辑型 @默认值 = 假>
    参数 旋转角度 <类型 = 整数 注释 = "提供字体的旋转角度,单位为十分之一度." @默认值 = 0>
    {
        @ // 使用默认字体的信息进行初始化
        @ LOGFONT infFont;
        @ GetDefaultFontInfo (&infFont);
        @ if (@<字体名称>.IsEmpty () == FALSE)
        @     _tcsncpy_z (infFont.lfFaceName, @<字体名称>.GetText (), NUM_ELEMENTS_OF (infFont.lfFaceName) - 1);
        @ const INT_P npFontSize = FontPtSize2Dp (@<字体尺寸>);
        @ if (npFontSize > 0)
        @     infFont.lfHeight = (LONG)npFontSize;
        @ INT_P npAngle = (@<旋转角度> % 3600);
        @ if (npAngle < 0)  npAngle += 3600;
        @ infFont.lfOrientation = infFont.lfEscapement = (LONG)npAngle;
        @ infFont.lfWeight = (@<是否粗体> ? FW_BOLD : FW_NORMAL);
        @ infFont.lfItalic = (BYTE)@<是否斜体>;
        @ infFont.lfUnderline = (BYTE)@<是否有下划线>;
        @ infFont.lfStrikeOut = (BYTE)@<是否有删除线>;
        @ @sn<current_class> obj;
        @ obj.CreateFontDispObjectFromInfo (&infFont);
        @ return obj;
    }
}

类 COM图片类 <公开 基础类 = COM对象类 注释 = "用作记录一个COM图片对象(IPictureDisp)">
{
    方法 从资源创建图片 <公开 静态 类型 = COM图片类 注释 = "载入所指定的位图资源(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico),返回所载入的图片对象."
            返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 所欲载入的位图 <类型 = 位图资源>
    {
        @ const HBITMAP hBitmap = (HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲载入的位图>);
        @ @sn<current_class> obj;
        @ obj.CreatePicDispObject (hBitmap);
        @ if (hBitmap != NULL)  ::DeleteObject (hBitmap);
        @ return obj;
    }

    方法 从文件创建图片 <公开 静态 类型 = COM图片类 注释 = "载入所指定的位图文件(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico),返回所载入的图片对象."
            返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 所欲载入的位图文件 <类型 = 文本型>
    {
        @ const HBITMAP hBitmap = (HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲载入的位图文件>.GetText ());
        @ @sn<current_class> obj;
        @ obj.CreatePicDispObject (hBitmap);
        @ if (hBitmap != NULL)  ::DeleteObject (hBitmap);
        @ return obj;
    }

    方法 从数据创建图片 <公开 静态 类型 = COM图片类 注释 = "载入所指定的位图数据(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico),返回所载入的图片对象."
            返回值注释 = "成功所返回的COM对象不为空(\"是否为空\"方法返回假),失败为空(\"是否为空\"方法返回真)." @禁止流程检查 = 真>
    参数 所欲载入的位图数据 <类型 = 字节集类>
    {
        @ const HBITMAP hBitmap = (HBITMAP)g_objVolApp.LoadBitmapFromMemory (@<所欲载入的位图数据>);
        @ @sn<current_class> obj;
        @ obj.CreatePicDispObject (hBitmap);
        @ if (hBitmap != NULL)  ::DeleteObject (hBitmap);
        @ return obj;
    }

    #
}
