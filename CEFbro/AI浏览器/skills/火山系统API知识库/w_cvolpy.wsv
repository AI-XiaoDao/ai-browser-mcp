            注释 = "  2.此方法不会对当前方法对象进行有效检查,您应该确保,当前的方法对象是有效的, 可通过属性\"是否有效\"获得有效状态."
            返回值注释 = "如果所调用的Py方法具有返回值,则此方法将返回其返回值,否则,将返回一个空的的火山Py对象." @嵌入式方法 = "">
    参数 本类对象 <类型 = Py方法类 注释 = "当前类型实例对象.">
    {
        @ @dt<Py对象类>(PyObject_CallNoArgs(@<本类对象>.GetPyObj()), PYREF_FALSE)
    }

    方法 调用格式化参数 <公开 静态 类型 = Py对象类 注释 = "将指定的火山基本类型数据格式化为Py参数,并且调用当前方法." 注释 = "请注意:"
            注释 = "  1.本方法不会对当前的方法对象,以及传入的参数进行检查,如果您当前使用的方法对象无效,或者传入的参数不正确,都会应发崩溃."
            注释 = "  2.本方法仅支持火山基本类型数据,不可传入任意的火山类对象,且,格式替换符与实际参数类型必须一致,本方法使用与\"创建格式化" 注释 = "对象\"类似,只是不可使用对象替换符." 注释 = ""
            注释 = "以下为常用的格式替换符,详细信息,请参阅: https://docs.python.org/3/c-api/arg.html?highlight=py_buildvalue#c.Py_BuildValue" 注释 = ""
            注释 = "  s/s#/z/z# 创建Py文本类对象,使用此替换符,替换数据参数,必须为UTF8文本(实际为字节集)."
            注释 = "  u/u#      创建Py文本类对象,使用此替换符,替换数据参数,可以直接填入文本型数据(UTF-16 或 UCS-4)."
            注释 = "  y/y#      创建Py字节序列类对象.使用此替换符,替换数据参数,应为字节集指针." 注释 = "  i         创建Py数值类对象,使用此替换符,替换数据参数,应为整数型."
            注释 = "  b         创建Py字符对象,使用此替换符,替换数据参数,应为字符型数据." 注释 = "  h         创建Py数值类对象,使用此替换符,替换数据参数,应为短整数型."
            注释 = "  l         创建Py数值类对象,使用此替换符,替换数据参数,应为变整数." 注释 = "  L         创建Py数值类对象,使用此替换符,替换数据参数,应为长整数."
            注释 = "  d         创建Py数值类对象,使用此替换符,替换数据参数,应为小数型." 注释 = "" 注释 = "请注意: 以下所介绍的符号,不可单独使用,需要在括号,或中括号中,包含上述几种替换符方可."
            注释 = "  (xxx)/xx     可变参数替换符." 注释 = "  [xxx]        列表参数替换符." 注释 = "  {xxx}        字典参数替换符." 注释 = ""
            注释 = "  传递字节集数据时,请您注意,一定要传递字节集变量的数据指针,不要直接传递字节集变量,例如,可以使用 字节集变量.取字节集指针()."
            注释 = "  使用时文本替换符(\"s\"-\"u\")时,请您一定要注意文本编码问题,使用\"u\"替换符,您直接传入火山文本即可,如果使用\"s/s#/z/z#\",请一定要"
            注释 = "将火山文本转为UTF8文本后,在传入.否则,会因为编码不正确,导致文本乱码或文本内容不完整." 注释 = ""
            返回值注释 = "如果所欲调用的Py方法具有返回值,且本方法执行成功,则本方法返回Py的返回值,否则返回空的Py对象." 编辑时信息 = "123FED, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 本类对象 <类型 = Py方法类 注释 = "当前方法对象." 编辑时信息 = "123FED, 0, 0, 0">
    参数 参数替换符 <类型 = 文本型 注释 = "所欲传入的替换符参数,必须为上述的替换字符,可以组合使用." 编辑时信息 = "123FED, 0, 0, 0">
    参数 替换数据 <注释 = "所欲使用的替换数据,请您一定要确保,此数据与\"参数替换符\"数量以及类型是匹配的." 编辑时信息 = "123FED, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @  @dt<Py对象类>(PyObject_CallFunction (@<本类对象>.GetPyObj(), CU8String(@<参数替换符>).GetText(), @<替换数据>), PYREF_FALSE)
    }

    方法 调用 <公开 静态 类型 = Py对象类 注释 = "调用当前方法." 注释 = "请注意:在调用前,您应该先检查该方法是否有效."
            返回值注释 = "如果所欲调用的Py方法具有返回值,且本方法执行成功,则本方法返回Py的返回值,否则返回空的Py对象." @嵌入式方法 = "req_obj_param_pointer = true">
    参数 本类对象 <类型 = Py方法类 注释 = "当前方法对象.">
    参数 方法参数 <注释 = "支持类型:" 注释 = "   1. Py对象类以及其子类对象." 注释 = "   2. 火山基本数据类型(数值{整数, 长整数, 小数}, 逻辑型, 文本型)" @匹配类型 = 通用型 @可扩展 = "">
    {
