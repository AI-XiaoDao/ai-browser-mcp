类 Py字典类 <公开 基础类 = Py对象类 注释 = "对应Python中的字典类(Dict)." 注释 = "字典类与火山的某某键值对列表类相似,允许以键名/键值的方式,管理内容."
        注释 = "请注意: 本类无法自动创建实例对象,您需要自行通过\"Py字典类.创建()\"方法进行创建实例对象." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

