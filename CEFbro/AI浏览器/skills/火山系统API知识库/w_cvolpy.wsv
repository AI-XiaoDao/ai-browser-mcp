<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.CVolPy <注释 = "  整体与火山安卓相似,由于系统平台的差异原因,所以,还是有部分与安卓不一样的." 注释 = ""
        注释 = "  请注意: 凡是直接从Py文件中加载的模块/成员,其引用计数都会大于1,您必须在使用完毕该对象之" 注释 = "后,手动将其引用计数清空,或设为1,否则,将会造成内存垃圾. 通过火山Pyxxx类.创建() 的对象,不需"
        注释 = "要您自行清空." 注释 = "" 注释 = "关于Py库体积说明:" 注释 = "  本模块所附带的Py库,为Python3.9所有自带的库,体积可能稍微大了一下,如果您对体积比较在意,可以"
        注释 = "通过删减一些用不到的库来降低尺寸,比如 网络模块,数据库模块等.这些库,动态库部分在Dlls文件夹中," 注释 = "Py库在Python3.9.zip中." 注释 = "" 注释 = "二次封装请注意:"
        注释 = "   本库集成了一个叫做“CVolPy\"的模块,用于将Python的数据通过火山调试输出.如果您想要更改模块名称," 注释 = "请替换所有\"CVolPy\"." 注释 = ""
        注释 = "  请千万千万切记,如果不熟悉指针,引用, 引用计数等概念,千万不要尝试修改所有嵌入的代码.不然可" 注释 = "能会由于错误的修改,导致出现空指针,野指针等,直接导致您的程序发生崩溃." 注释 = ""
        注释 = "  如果您想要对本模块进行升级,请千万千万要注意,一定要区分好Py返回的引用类型." 注释 = "  一种是原始引用(表示 此对象及Py内的对象 两个对象指针是指向一个地址的), 一种是新引用,即 返回的是克"
        注释 = "隆副本,在第一种情况下,如果您不熟悉指针概念, 引用概念,请千万不要对该对象进行引用计数的操作.也不要" 注释 = "尝试释放该对象,否则,一定会引起数据错误." 折叠2>

# // 所有Py对象类的子类,都需要实现此宏,来完成该类对象的建立..
# @begin
#  @def_macro PyObjectDefaultConstructor                                                          \
# <>      <include>                                                                                  \
#          PyObject * GetPyObj() {                                                                \
#              if (pdata () == NULL) return NULL;                                                 \
#              return pdata ()->GetPyObj();                                                       \
#          }                                                                                      \
#          BOOL  IsRefObj() {                                                                     \
#              if (pdata () == NULL) return FALSE;                                                \
#              return pdata ()->GetIsRef();                                                       \
#          }                                                                                      \
#          void SetPyObj (PyObject * obj, BOOL bRef) {                                            \
#              if (pdata () == NULL) return;                                                      \
#              pdata ()->SetPyObj(obj, bRef);                                                     \
#          }                                                                                      \
#          @sn<current_class> (PyObject * pObject, bool bRef) : @sn<current_class> () {           \  // 必须先调用默认构造,进行创建参考计数容器,
#              SetPyObj (pObject, bRef);                                                          \
#          }                                                                                      \ 
# <>      </include>
# // py=检查的Py对象, ret=检查失败返回的数据, method=成功则返回此可以是方法, 也可以是数据.
#  @def_macro PyObjectCheckAndReturn(py, ret, method)        \
#     if (py == NULL || py->ob_refcnt <= 0)                  \
#         return ret;                                        \
#     return method;
# // 检查执行, 比支持返回值.
#  @def_macro PyObjectCheckAndExec(py, method)               \
#     if (py != NULL && py->ob_refcnt > 0)                   \
#         method;
# @end

类 火山Python <公开 注释 = "火山Python支持." 注释 = "本类封装了Python较重要的方法,可以直接使用本类,快速完成Py代码的编译,加载以及执行等."
        @视窗.外部库 = "..\\..\\shared\\extern_lib\\common\\python\\1\\Python3_9\\$(p)\\python39.lib"
        @视窗.附属文件 = "..\\..\\shared\\extern_lib\\common\\python\\1\\Python3_9\\$(p)\\python39.dll"
        @视窗.附属文件 = "..\\..\\shared\\extern_lib\\common\\python\\1\\Py3_9Libs\\$(p)"
        @视窗.附属文件 = "..\\..\\shared\\extern_lib\\common\\python\\1\\Py3_9Libs\\Python3_9.zip"
        @视窗.头文件搜寻目录 = "..\\..\\shared\\extern_lib\\common\\python\\1\\Python3_9\\Include\\" @视窗.外部头文件 = "Python.h"
        @视窗.外部头文件 = "CVolPyWraper.h">
{

