    参数 成员索引 <类型 = 整数 注释 = "所欲取成员索引,不得超过当前元组对象的成员数.">
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), @dt<Py对象类>(), @dt<Py对象类>(PyTuple_GetItem(GetPyObj(), @<成员索引>), PYREF_TRUE) )
    }

    方法 置成员 <公开 静态 类型 = 逻辑型 注释 = "设置当前元组对象内指定索引处的数据." 注释 = "请注意:如果该索引已存在数据,则本方法将会替换该数据为您新设置的数据对象." 返回值注释 = "设置成功返回真,失败返回假."
            @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py元组类 注释 = "本类对象.">
    参数 成员索引 <类型 = 整数 注释 = "所欲设置的成员索引.">
    参数 所欲添加对象 <注释 = "所欲设置进入的对象,可以为火山基本数据类型和任意Py对象." @匹配类型 = 通用型>
    {
        @ @<本类对象>.Append (@<成员索引>, @dt<Py对象类>::AnyVolType2PyType(PYREF_TRUE, @pdt_ch<所欲添加对象>, @<所欲添加对象>))
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为元组对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyTuple_Check (GetPyObj()) )
