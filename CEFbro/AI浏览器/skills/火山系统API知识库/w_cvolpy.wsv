类 Py列表类 <公开 基础类 = Py对象类 注释 = "  对应着Python中的列表类(List)." 注释 = "  列表的使用方法,与火山的某某某列表相似,允许添加/删除成员,但是不同的是,此列表,允许插入不同类型的数据."
        注释 = "  请注意: 本类无法自动创建实例对象,您需要自行通过\"Py列表类.创建()\"方法进行创建实例对象,成员数可以为0或" 注释 = "大于0的数字." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建 <公开 静态 类型 = Py列表类 注释 = "  创建一个具有指定成员数量的列表实例对象."
            注释 = "  请注意: 通过本方法所创建的列表对象,并不是固定成员数量,您依然可以通过\"添加成员\"与\"插入成员\"进行成员数扩充,"
            注释 = "使用本方法创建列表对象后,会分配指定数量的成员,这些成员默认是NULL(空成员,没有类型,没有数据),需要您使用\"置成员\"" 注释 = "为其设置数据." @禁止流程检查 = 真>
    参数 列表成员数 <类型 = 整数 注释 = "所欲用于创建列表的成员数量.">
    {
        @ return @sn<current_class> (PyList_New (@<列表成员数>), PYREF_FALSE);
    }

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "取得此对象内的成员数量." 注释 = "请注意:如果方法执行失败,则返回-1,否则必定返回一个正整数表示成员数量." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, (INT)PyList_Size(GetPyObj()))
    }

    方法 取成员 <公开 类型 = Py对象类 注释 = "取得指定索引的成员对象." 注释 = "请注意:" 注释 = "  1.如果您所指定的\"成员索引\"超出了列表成员数量,则此方法执行失败,并且返回一个空的Py对象."
            注释 = "  2.本方法所取得成员对象,为引用列表内数据的对象,即 您取得对象,实际上就是列表内的成员对象,如果您将其释放掉." 注释 = "则会引起列表内出现野指针." @禁止流程检查 = 真>
    参数 成员索引 <类型 = 整数 注释 = "所欲取成员的索引,此索引不可大于当前列表的成员数量.">
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), @dt<Py对象类>(), @dt<Py对象类>(PyList_GetItem(GetPyObj(), @<成员索引>), PYREF_TRUE) )
    }

    方法 置成员 <公开 静态 类型 = 逻辑型 注释 = "设置指定索引位置的成员对象." 注释 = "请注意: 如果该索引处已存在数据,则本方法将会使用新数据替换旧数据."
            返回值注释 = "设置成员成功返回真,失败返回假,如果成功,可使用火山Python类方法\"检查异常\"获得信息." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py列表类 注释 = "本类对象.">
    参数 成员索引 <类型 = 整数 注释 = "所欲设置成员的索引,此索引不可大于当前列表的成员数量.">
    参数 所欲插入对象 <注释 = "所欲设置的对象,可以为任意Py对象,或火山基本类型数据." @匹配类型 = 通用型>
    {
        @ @<本类对象>.SetItem (@<成员索引>, @dt<Py对象类>::AnyVolType2PyType(PYREF_TRUE, @pdt_ch<所欲插入对象>, @<所欲插入对象>), FALSE)
    }

    方法 插入成员 <公开 静态 类型 = 逻辑型 注释 = "向当前列表对象内,插入一条数据." 返回值注释 = "成功返回真,失败返回假.如果失败,可使用火山Python类方法\"检查异常\"获得信息."
            @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py列表类 注释 = "本类对象.">
    参数 成员索引 <类型 = 整数 注释 = "所欲插入成员的索引,此索引不可大于当前列表的成员数量.">
    参数 所欲插入对象 <注释 = "所欲插入的成员对象,可以是火山基本数据类型,也可以是任意有效的Py对象." @匹配类型 = 通用型>
    {
        @ @<本类对象>.SetItem (@<成员索引>, @dt<Py对象类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<所欲插入对象>, @<所欲插入对象>), TRUE)
    }

    方法 添加成员 <公开 静态 类型 = 逻辑型 注释 = "向当前列表对象内添加成员." 返回值注释 = "添加成功返回真,失败返回假.如果失败,可使用火山Python类方法\"检查异常\"获得信息."
            @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py列表类 注释 = "本类对象.">
    参数 所欲添加对象 <注释 = "所欲添加的成员对象,可以是火山基本数据类型,也可以是任意有效的Py对象." @匹配类型 = 通用型>
    {
        @ @<本类对象>.Append(@dt<Py对象类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<所欲添加对象>, @<所欲添加对象>))
    }

    方法 排序 <公开 类型 = 逻辑型 注释 = "将当前列表内的数据进行排序." 注释 = "排序成功返回真,失败返回假." 注释 = "请注意: 排序只支持统一数据类型,例如,全部为文本型,或全部为整数型." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), FALSE, PyList_Sort(GetPyObj()) == 0 )
    }

    方法 反转 <公开 类型 = 逻辑型 注释 = "反转列表内的成员(将底部成员移至上面, 上面成员移至下面),成功返回真,失败返回假." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), FALSE, PyList_Reverse(GetPyObj()) == 0 )
    }

    方法 取范围成员 <公开 类型 = Py列表类 注释 = "取得指定范围内的成员列表." 注释 = "取得\"开始位置\"至\"结束位置\"之间的所有成员." @禁止流程检查 = 真>
    参数 开始位置 <类型 = 整数 注释 = "所欲设置开始位置,此参数不可超过当前列表对象的成员数量.">
    参数 结束位置 <类型 = 整数 注释 = "所欲设置结束位置,此参数不可超过当前列表对象的成员数量,且应大于\"开始位置\".">
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), @dt<Py列表类>(), @dt<Py列表类>(PyList_GetSlice(GetPyObj(), @<开始位置>, @<结束位置>), PYREF_FALSE) )
    }

    方法 到元组 <公开 类型 = Py元组类 注释 = "将当前列表对象,转为元组对象." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), @dt<Py元组类>(), @dt<Py元组类>(PyList_AsTuple(GetPyObj()), PYREF_FALSE) )
    }

