类 Py文本类 <公开 基础类 = Py对象类 注释 = "Python中的文本类型(3.x中,被称之为UnIcode对象)." 注释 = "请注意:"
        注释 = "  1.py的一些文本操作,并没有封装进来,因为火山已经具备了这些方法,比如,编解码等.此类工作." 注释 = "请使用火山文本类提供的方法进行完成." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建 <公开 静态 类型 = Py文本类 注释 = "根据指定的文本内容参数,创建Py文本类对象." @禁止流程检查 = 真>
    参数 文本参数 <类型 = 文本型 注释 = "基于此文本创建Py文本对象.">
    {
        @ return @sn<current_class>( PyUnicode_FromWideChar (   (const wchar_t *) @<文本参数>.GetText(), @<文本参数>.GetLength()  ), PYREF_FALSE);
    }

    方法 创建自UTF8文本 <公开 静态 类型 = Py文本类 注释 = "根据指定的文本内容参数,创建Py文本类对象."
            注释 = "请注意: 本方法会自动将火山文本内容转为UTF8后,使用此方法创建的文本对象,需要使用\"UTF8内容\"属性获取文本内容." @禁止流程检查 = 真>
    参数 文本参数 <类型 = 文本型 注释 = "基于此文本创建Py文本对象.">
    参数 加入文本长度 <类型 = 整数 注释 = "所欲加入文本长度,如果小于等于0,则将\"文本参数\"全部加入,大于零,则截取此长度加入." @默认值 = -1>
    {
        @ if(@<加入文本长度> <= 0)
        @     return @sn<current_class>(PyUnicode_FromString ( (const char *) CU8String(@<文本参数>).GetText()   ), PYREF_FALSE);
        @ else
        @     return @sn<current_class>(PyUnicode_FromStringAndSize ( (const char *) CU8String(@<文本参数>).GetText(), @<加入文本长度>   ), PYREF_FALSE);
    }

    方法 UTF8内容 <公开 属性读 类型 = 文本型 注释 = "  取得UTF8文本内容" 注释 = "  请注意: 如果您使用\"创建\"创建的此对象,那么,您应该使用\"内容\"属性获得文本内容,如果使用此属性取,"
            注释 = "那么会造成内容乱码." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @an<CVolString> (), @an<CVolString> ( (const CHAR*)PyUnicode_AsUTF8 (GetPyObj()) ) )
    }

    方法 内容 <公开 属性读 类型 = 文本型 注释 = "  取得本对象内的文本内容." 注释 = "  请注意: 如果您使用\"创建自UTF8文本\"创建的此对象,那么,您应该使用\"UTF8文本\"属性取得文本内容,如果使用此属性取,"
            注释 = "那么会造成其中的中文乱码." @禁止流程检查 = 真>
    {
        @ if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0)
        @     return _CT("");
        @ Py_ssize_t iLen = 0;
        @ wchar_t * pBuff = PyUnicode_AsWideCharString (GetPyObj(), &iLen);
        @ @an<CVolString> sRet = @an<CVolString> ( (const wchar_t *) pBuff, iLen);
        @ PyMem_Del (pBuff);
        @ return sRet;
    }

    方法 文本长度 <公开 属性读 类型 = 变整数 注释 = "取得当前Py文本对象内的文本长度." 注释 = "成功返回文本长度,失败则返回-1,如果失败,您可以检查当前文本对象是否为有效对象." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, PyUnicode_GetLength(GetPyObj()))
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为文本对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyUnicode_Check (GetPyObj()))
    }
}

