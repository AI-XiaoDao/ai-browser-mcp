    方法 添加定义成员 <公开 静态 类型 = 逻辑型 注释 = "向\"CVolPy\"模块内添加一个任意类型的成员变量."
            注释 = "您可在Py中通过该成员名称进行访问该成员数据,例如\"CVolPy.Var1\",如果所指定成员名已存在,则更新值,如果不存在,则添加."
            返回值注释 = "添加成功返回真, 失败返回假,如果返回假,可使用\"检查异常\"进行异常检查." @禁止流程检查 = 真>
    参数 成员名称 <类型 = 文本型 注释 = "所欲设置此成员名称.">
    参数 成员对象 <类型 = 变整数 注释 = "所欲设置成员数据,可以为任意对象/数据或静态方法的指针." "">
    {
        @ return CVolPyWraper::AddMacroObject ( (const char *) CU8String(@<成员名称>).GetText(), PyLong_FromSize_t(@<成员对象>) );
    }

    方法 Py到文本 <公开 静态 类型 = 文本型 注释 = "将任意火山Py对象,转化为文本并返回." 注释 = "请注意: 如果所提供的Py对象无效,或其引用计数已被归零(其实就是无效),本方法将返回空文本." @禁止流程检查 = 真>
    参数 欲转换对象 <类型 = Py对象类 注释 = "所欲转换为文本的Py对象">
    {
        @ if (@<欲转换对象>.GetPyObj() == NULL || @<欲转换对象>.GetPyObj()->ob_refcnt <= 0)
        @     return _CT("");
        @ PyObject * pStr = PyObject_Str( @<欲转换对象>.GetPyObj() );
        @ if (pStr == NULL) return _CT("");
        @ if (!PyUnicode_Check (pStr)) {
        @     Py_CLEAR(pStr);
        @     return _CT("");
        @ }
        @ const CHAR* pws =  PyUnicode_AsUTF8 ( pStr );
        @ @an<CVolString> pRet( (const CHAR*) pws );
        @ Py_CLEAR (pStr);
        @ return pRet;
    }

    方法 初始化 <公开 静态 类型 = 逻辑型 注释 = "  初始化Py解释器引擎,初始化成功返回真,失败返回假." 注释 = "  请注意: 在您的应用生命周期内(从开始到结束),只需要初始化一次即可.无需多次初始化,除非"
            注释 = "您自行通过\"释放\"将其释放掉,才需要再次初始化.初始化结果,可使用属性\"是否已初始化\"获得." @禁止流程检查 = 真>
    {
        @ if (Py_IsInitialized()) return TRUE;
        @ PyImport_AppendInittab("CVolPy", PyInit_VolPCLog);
        @ Py_Initialize ();
        如果 (火山Python.检查异常 ())
        {
            @ ::MessageBoxA (0, "", "", 0);
        }
        @ CVolPyWraper::SetVolPyEvent ();
        @ return Py_IsInitialized();
    }

    方法 卸载 <公开 静态 注释 = "释放当前Python解释器引擎." 注释 = "请注意:" 注释 = "  1.释放过后,您将不得再次使用,如欲再次使用,请先进行初始化."
            注释 = "  2.本方法为全局方法,即,只要您执行了此方法进行卸载Py解释器引擎,则您程序内的所有\"火山Python\"" 注释 = "变量对象,都将被清理,无法再次使用." @嵌入式方法 = "">
    {
        @ Py_Finalize()
    }

    方法 是否已初始化 <公开 静态 类型 = 逻辑型 注释 = "取得Python引擎是否已经初始化." 返回值注释 = "已初始化返回真,未初始化返回假." @禁止流程检查 = 真>
    {
        @ return Py_IsInitialized();
    }

    方法 置库路径 <公开 静态 注释 = "  设置Python库路径, 此方法可在初始化之前使用." 注释 = "  请注意: 此路径下必须包含Python的库文件,也可以是一个包含py库的压缩包文件."
            注释 = "且该路径下,必须有\"Dlls\"目录,该目录下为Py的动态库,可以包含多个路径,Windows" 注释 = "平台下,路径使用\";\"进行分隔,其他系统,如 Linux下,使用\":\"进行分隔.设置成功之"
            注释 = "后,Py引擎默认从设置的路径中搜索需求的Py库文件.">
    参数 所欲设置路径 <类型 = 文本型>
    {
        @ Py_SetPath (@<所欲设置路径>.GetText());
    }

    方法 运行代码行 <公开 静态 类型 = 逻辑型 注释 = "载入一段Py代码运行,运行成功返回真,失败返回假." 注释 = "请注意: 请一定要注意Py代码中的缩进格式,如果格式不正确,会导致执行失败." @嵌入式方法 = "">
    参数 所欲运行Py代码 <类型 = 文本型 注释 = "请注意,是运行Py代码,而不是直接载入Py文件.">
    {
        @ PyRun_SimpleString((const char *)CU8String(@<所欲运行Py代码>).GetText()) == 0
    }

    方法 加载Py文件 <公开 静态 类型 = Py模块类 注释 = "载入并编译一个Py代码文件," 注释 = "请注意:"
            注释 = "  1.请不要让文件名称,与Py核心库的文件名重名,否则,将会加载核心库中的py.比如,test就存在于核心库中."
            注释 = "  2.请一定要确保,所加载的Py代码中的引入库,在您所设置的路径中可以找到,如果您引入了无法找到的库,则无法执行."
            注释 = "  3.所欲加载的Py代码文件,千万不要使用 \"路径\\\\VolCpTest.py.py\"这种方式,只能给出Py代码文件名(不包括扩展名 .Py)," 注释 = "路径,只能在所设置的环境路径目录下."
            @禁止流程检查 = 真>
    参数 py代码文件 <类型 = 文本型 注释 = "所欲加载的Py代码文件.">
    {
        @ PyObject* pModule = PyImport_ImportModule ((const char *)CU8String(@<py代码文件>).GetText());
        @ if (pModule == NULL) return @dt<Py模块类> ();
        @ if (PyErr_Occurred() != NULL || !PyModule_Check(pModule)) {
        @     Py_CLEAR (pModule);
        @     return @dt<Py模块类> ();
        @ }
        @ return @dt<Py模块类> (pModule, PYREF_FALSE);
    }

    方法 添加模块路径 <公开 静态 类型 = 逻辑型 注释 = "将指定路径的Py文件添加到搜索路径中." "">
    参数 所欲添加路径 <类型 = 文本型 注释 = "所欲添加的文件路径.">
    {
        返回 (运行代码行 ("sys.path.append(r'" + 所欲添加路径 + "')"))
    }

    方法 加载Py代码 <公开 静态 类型 = Py模块类 注释 = "将指定的代码文本转换为Py模块对象." 注释 = "请注意:" 注释 = "  1.如果该代码文本中,依赖了其他模块(import了其他模块或类),则您需要将其模块路径"
            注释 = "加载至系统路径中(使用方法 \"添加模块路径\"),否则运行时,会报找不到模块名的错误." 注释 = "  2.请一定要确保,代码的正确性(主要是代码索引),如果代码书写有误,则会加载为模块时"
            注释 = ",报代码书写错误的信息." 注释 = "  3.代码别名参数,这个参数,是在加载为模块时,为这个模块指定一个别名,您可以通过这个" 注释 = "别名,来直接访问模块中的代码,在代码运行错误时,报错中也会提示这个别名哪一行错误."
            @禁止流程检查 = 真>
    参数 py代码文本 <类型 = 文本型 注释 = "所欲创建模块的代码文本.">
    参数 运行别名 <类型 = 文本型 注释 = "所欲指定的代码别名." @默认值 = "CVolPyTestCode">
    {
        @ PyObject * pCode = Py_CompileString  ((const char *)CU8String(@<py代码文本>).GetText(), (const char *)CU8String (@<运行别名>).GetText(), Py_file_input);
        @ if (pCode == NULL) return @dt<Py模块类> ();
        @ if (PyErr_Occurred() != NULL || !PyCode_Check(pCode)) {
        @     Py_CLEAR (pCode);
        @     return @dt<Py模块类> ();
        @ }
        @ PyObject * pModule = PyImport_ExecCodeModule((const char *)CU8String (@<运行别名>).GetText(), pCode);
        @ if (pModule == NULL) {
        @     Py_CLEAR (pCode);
        @     return @dt<Py模块类> ();
        @ }
        @ if (PyErr_Occurred() != NULL || !PyModule_Check(pModule)) {
        @     Py_CLEAR (pCode);
        @     Py_CLEAR (pModule);
        @     return @dt<Py模块类> ();
        @ }
        @ Py_CLEAR (pCode);
        @ return @dt<Py模块类> (pModule, PYREF_FALSE);
    }

    方法 检查异常 <公开 静态 类型 = 逻辑型 注释 = "  检查是否有异常代码." 注释 = "  请注意: 本方法仅可检查到运行处为止,是否捕获过异常,如果有,则可以通过\"打印异常\"或\"取异常文本\""
            注释 = "进行异常输出,如果多次捕获异常,则只记录最后一次异常信息." @禁止流程检查 = 真>
    {
        @ return PyErr_Occurred() != NULL;
    }

    方法 打印异常 <公开 静态 注释 = "将当前所捕获的异常信息,输出至火山输出窗口.">
    {
        @ PyErr_Print();
        @ PyErr_Clear();
    }

    方法 取异常文本 <公开 静态 类型 = 文本型 注释 = "检查并获得Py代码异常文本." 注释 = "当代码执行失败后,您可通过此方法,获取最后一次触发的异常信息." @禁止流程检查 = 真>
    {
        @ return CVolPyWraper::GetExceptionString();
    }

    # 本地代码======
}

类 Py对象类 <公开 注释 = "本类为所有Py类的基础类,为其提供基础方法." 注释 = "Py对象基础类" @文档 = "category = \"辅助类\"">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVolPyWraper)
    # @ @m<PyObjectDefaultConstructor>

    方法 是否有效 <公开 属性读 类型 = 逻辑型 注释 = "返回当前Py对象是否为有效对象." @禁止流程检查 = 真>
    {
        @ return (GetPyObj() != NULL && GetPyObj()->ob_refcnt > 0);
    }

    方法 创建格式化对象 <公开 静态 类型 = Py对象类 注释 = "通过指定的格式化字符串与参数,创建所指定的Py对象类或其子类实例对象." 注释 = "请注意:"
            注释 = "  1.此方法不会检查您传入的对象是否为有效对象,如果您传递的对象为无效对象,或替换符与替换数据类型不匹配,则会直接引发崩溃."
            注释 = "  2.使用此方法,请确保\"格式文本\"替换符数据量,与参数数量一致,且,替换符与实际提供参数,必须匹配.以下简介中,\"/\"代表或,\"#\"号"
            注释 = "代表, 该替换符需要同时传入长度参数, 例如, 文本长度, 字节集长度." 注释 = ""
            注释 = "以下为常用的格式替换符,详细信息,请参阅: https://docs.python.org/3/c-api/arg.html?highlight=py_buildvalue#c.Py_BuildValue" 注释 = ""
            注释 = "  s/s#/z/z# 创建Py文本类对象,使用此替换符,替换数据参数,必须为UTF8文本(实际为字节集)."
            注释 = "  u/u#      创建Py文本类对象,使用此替换符,替换数据参数,可以直接填入文本型数据(UTF-16 或 UCS-4)."
            注释 = "  y/y#      创建Py字节序列类对象.使用此替换符,替换数据参数,应为字节集指针." 注释 = "  i         创建Py数值类对象,使用此替换符,替换数据参数,应为整数型."
            注释 = "  b         创建Py字符对象,使用此替换符,替换数据参数,应为字符型数据." 注释 = "  h         创建Py数值类对象,使用此替换符,替换数据参数,应为短整数型."
            注释 = "  l         创建Py数值类对象,使用此替换符,替换数据参数,应为变整数." 注释 = "  L         创建Py数值类对象,使用此替换符,替换数据参数,应为长整数."
            注释 = "  d         创建Py数值类对象,使用此替换符,替换数据参数,应为小数型."
            注释 = "  O/S       创建Py对象类对象,使用此替换符,替换数据参数,应为Py对象类实例,或其子类实例.使用本替换符,所传入对象,将会导致该对象" 注释 = "引用计数增加1个."
            注释 = "  N         创建Py对象类对象,使用此替换符,替换数据参数,应为Py对象类实例,或其子类实例,与\"O/S\"不同的是,本替换符不会增加所传入" 注释 = "Py对象的引用计数."
            注释 = "  O&        创建Py对象类对象,使用此替换符,替换数据参数,可以为任意类型(火山任意类对象,基本数据类型,Py任意类对象).使用此替换"
            注释 = "符您需要注意,如果在火山中将该火山对象释放,则传入py的火山对象会变成无效对象,您不得再次使用该对象,否则将会引发崩溃." 注释 = "" 注释 = "请注意: 以上带有#号的替换符,表示需要传入该文本或字节集长度参数."
            注释 = "示例:" 注释 = "  Py文本对象 = 创建格式化对象(\"s#\", 文本参数, 取文本长度(文本参数))" 注释 = "" 注释 = "示例:"
            注释 = "  Py数值对象 = 创建格式化对象(\"i\", 整数值: 1)" 注释 = "  Py文本对象 = 创建格式化对象(\"s\", 整数值: 1)" 注释 = ""
            注释 = "请注意: 以下所介绍的符号,不可单独使用,需要在括号,或中括号中,包含上述几种替换符方可."
            注释 = "  ()/xx     创建Py元组类对象,使用此符号,替换数据参数,可以为任意类型,但是要与替换符相匹配,其中XX表示任意类型."
            注释 = "  []        创建Py列表类对象,使用此符号,替换数据参数,可以为任意类型,但是要与替换符相匹配."
            注释 = "  {}        创建Py字典类对象,使用此符号,替换数据参数,可以为任意类型,但是要与替换符相匹配." 注释 = "示例:"
            注释 = "  元组对象 = 创建格式化对象(\"(ibhl)\", 整数值: 1, 字符值: \'C\', 短整数值: 2, 变整数值: 123)"
            注释 = "  列表对象 = 创建格式化对象(\"[ibhl]\", 整数值: 1, 字符值: \'C\', 短整数值: 2, 变整数值: 123)"
            注释 = "  字典对象 = 创建格式化对象(\"{ibhl}\", 整数值: 1, 字符值: \'C\', 短整数值: 2, 变整数值: 123)" @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 格式文本 <类型 = 文本型 注释 = "所欲使用的替换符文本,替换符只可使用本方法注释中的替换符.不可与火山的格式化替换符混合使用.">
    参数 替换数据 <注释 = "所欲设置的替换数据,本方法会根据您传入的替换符文本,将数据替换为指定的Py对象类型." 注释 = "请注意: 本方法仅支持火山基本数据类型,不支持任何类对象." @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ @dt<Py对象类>(Py_BuildValue(CU8String(@<格式文本>).GetText(), @<替换数据>), FALSE)
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将任意火山Py对象,转化为文本并返回." 注释 = "请注意: 如果所提供的Py对象无效,或其引用计数已被归零(其实就是无效),本方法将返回空文本." @虚拟方法 = 可覆盖>
    {
        返回 (火山Python.Py到文本 (本对象))
    }

    方法 清空引用计数 <公开 注释 = "将当前Py对象清空引用计数." 注释 = "请注意: 这是相当危险的操作,如果您不熟悉引用,指针,计数的概念,请不要使用此方法.">
    {
        @ @m<PyObjectCheckAndExec> (pdata()->GetPyObj(), pdata()->SafeClearRef() );
    }

    方法 增加引用计数 <公开 注释 = "为当前对象增加一个引用计数." 注释 = "请注意: 这是相当危险的操作,如果您不熟悉引用,指针,计数的概念,请不要使用此方法.">
    {
        @ @m<PyObjectCheckAndExec> (pdata()->GetPyObj(), pdata()->SafeIncRef() );
    }

    方法 减少引用计数 <公开 注释 = "为当前对象减少一个引用计数." 注释 = "请注意: 这是相当危险的操作,如果您不熟悉引用,指针,计数的概念,请不要使用此方法.">
    {
        @ @m<PyObjectCheckAndExec> (pdata()->GetPyObj(), pdata()->SafeDecRef() );
    }

    方法 重置引用计数 <公开 静态>
    参数 本类对象 <类型 = Py对象类>
    参数 欲设新计数 <类型 = 整数>
    {
        @ if (@<本类对象>.GetPyObj() == NULL || @<本类对象>.GetPyObj()->ob_refcnt <= 0)
        @     return ;
        @ @<本类对象>.GetPyObj()->ob_refcnt = @<欲设新计数>;
    }

    方法 对象引用计数 <公开 静态 属性读 类型 = 整数 注释 = "  取得当前火山Py对象引用计数." 注释 = "  请注意: 当此对象的引用计数小于等于0的时候,则证明则对象已经被弃用,即将进行回收,"
            注释 = "此时,您不应该继续使用此对象." @禁止流程检查 = 真>
    参数 本类对象 <类型 = Py对象类>
    {
        @ if (@<本类对象>.GetPyObj() == NULL || @<本类对象>.GetPyObj()->ob_refcnt <= 0)
        @     return 0;
        @ return (INT)@<本类对象>.GetPyObj()->ob_refcnt;
    }

    方法 类型 <公开 属性读 类型 = 文本型 注释 = "取得当前对象的类型文本,成功返回其类型文本,失败返回空文本." 注释 = "请注意: 该方法取得的类型,是Py定义的类型文本,例如\"str\",\"tuple\"等."
            @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), _CT (""), @an<CVolString> ((const CHAR*) GetPyObj()->ob_type->tp_name))
    }

    # 本地代码======
