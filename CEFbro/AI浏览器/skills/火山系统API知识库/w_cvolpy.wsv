类 Py模块类 <公开 基础类 = Py对象类 注释 = "Py模块类." 注释 = "本类的主要作用,就是加载代码片段/文件/以及从压缩模块文件中加载指定的模块." 注释 = "加载模块后,就可以通过火山来调用其中的方法或类."
        @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 模块名 <公开 属性读 类型 = Py对象类 注释 = "取得当前模块对象的名称." @禁止流程检查 = 真>
    {
        @ if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0  || !PyModule_Check(GetPyObj())) {
        @     return @dt<Py字典类> ();
        @ }
        @ PyObject * pName = PyModule_GetNameObject(GetPyObj());
        @ if (PyErr_Occurred() != NULL || pName == NULL) {
        @     return @dt<Py对象类> ();
        @ }
        @ return @dt<Py对象类> (pName, PYREF_FALSE);
    }

    方法 文件名 <公开 属性读 类型 = Py对象类 注释 = "取得当前模块文件名称." @禁止流程检查 = 真>
    {
        @ if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0  || !PyModule_Check(GetPyObj())) {
        @     return @dt<Py字典类> ();
        @ }
        @ PyObject * pName = PyModule_GetFilenameObject(GetPyObj());
        @ if (PyErr_Occurred() != NULL || pName == NULL) {
        @     return @dt<Py对象类> ();
        @ }
        @ return @dt<Py对象类> (pName, PYREF_FALSE);
    }

    方法 取字典 <公开 类型 = Py字典类 注释 = "从当前模块中取得字典对象." 注释 = "请注意: 本方法所取得字典对象,其中包括了该模块中的所有方法/变量成员名称." @禁止流程检查 = 真>
    {
        @ if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0  || !PyModule_Check(GetPyObj())) {
        @     return @dt<Py字典类> ();
        @ }
        @ PyObject * dict = PyModule_GetDict(GetPyObj());
        @ if (PyErr_Occurred() != NULL || dict == NULL || !PyDict_Check(dict)) {
        @     return @dt<Py字典类> ();
        @ }
        @ return @dt<Py字典类> (dict, PYREF_TRUE);
    }

    方法 成员是否存在 <公开 类型 = 逻辑型 注释 = "查询当前模块内,是否有指定名称的成员." 注释 = "请注意: 此名称,可以为方法名称,也可以是变量名称或类名." 返回值注释 = "如果该成员存在,则返回真,否则返回假."
            @禁止流程检查 = 真>
    参数 所指定成员名称 <类型 = 文本型 注释 = "所欲查询的成员名称.">
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyObject_HasAttrString(GetPyObj(), (const char *)CU8String(@<所指定成员名称>).GetText()))
    }

    方法 取成员 <公开 类型 = Py对象类 注释 = "从当前模块中取得指定成员对象." 注释 = "请注意:" 注释 = "  1.本方法所取得对象,可以为变量成员,也可以为方法成员或类成员."
            注释 = "  2.如果您通过本方法所取得成员为类型/类,请切记,该对象不可直接操作,因为它只是一个类,而并" 注释 = "非实例对象,只有您将其创建,成为实例对象后,才可继续操作."
            注释 = "  2.如果该模块对象中,并不存在您所指定的名称成员,那么本方法将会返回一个空的Py对象类对象," 注释 = "您可使用方法\"成员是否存在\"查询当前模块中是否具有指定名称的成员." @禁止流程检查 = 真>
    参数 所指定成员名称 <类型 = 文本型 注释 = "所欲查询的成员名称.">
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @dt<Py对象类>(), @dt<Py对象类>(PyObject_GetAttrString(GetPyObj(), (const char *)CU8String(@<所指定成员名称>).GetText()), PYREF_FALSE))
    }

    方法 取方法 <公开 类型 = Py方法类 注释 = "从当前模块中取得指定名称的方法对象." @禁止流程检查 = 真>
    参数 所欲指定方法名 <类型 = 文本型 注释 = "所欲获取的方法对象名称.">
    {
        变量 返回方法 <类型 = Py方法类>
        返回方法 = (Py方法类)取成员 (所欲指定方法名)
        如果 (返回方法.检查类型 ())
        {
            返回 (返回方法)
        }
        返回 ((Py方法类)新建对象 (Py方法类))
    }

    方法 创建自系统模块 <公开 静态 类型 = Py模块类 注释 = "加载Py核心库或您指定的路径中的Py模块." 返回值注释 = "加载成功返回一个有效的模块对象,如果失败,您可通过火山Python类方法\"检查异常\"获取异常信息."
            @禁止流程检查 = 真>
    参数 模块名称 <类型 = 文本型 注释 = "所欲加载的模块名称.">
    {
        @ PyObject * moudle = PyImport_ImportModule((const char *)CU8String(@<模块名称>).GetText());
        @ if (PyErr_Occurred () != NULL || moudle == NULL) {
        @     PyErr_Print();
        @     PyErr_Clear();
        @     if (moudle != NULL)
        @         Py_CLEAR (moudle);
        @     return @sn<current_class> ();
        @ }
        @ return @sn<current_class> (moudle, PYREF_TRUE);
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为模块对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyModule_Check (GetPyObj()))
    }
}

类 Py类型类 <公开 基础类 = Py对象类 注释 = "Py类型类,对应着Python中的类/类型(type)." 注释 = "Python中,一切数据皆为对象,所以,本类可以创建/调用任何Python类型对象.">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建实例 <公开 静态 类型 = Py类型类 注释 = "  创建指定Python类型实例." 注释 = "  请注意: 通过\"Py字典对象\"或\"Py模块对象\"取得的本类对象,实际上只是一个类,而并非实例,需要通过此方法,"
            注释 = "来创建该类的实例对象." 返回值注释 = "本方法执行成功,则返回该Py类实例对象,否则将返回空的Py对象." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 类型对象 <类型 = Py类型类 注释 = "当前类对象.">
    参数 构造参数 <注释 = "所欲提供构造的参数,参数类型可以为火山基本数据类型或Py对象类对象." 注释 = "支持类型:" 注释 = "   1. Py对象类以及其子类对象."
            注释 = "   2. 火山基本数据类型(数值{整数, 长整数, 小数}, 逻辑型, 文本型)" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @dt<Py类型类>(@dt<Py对象类>::_PyObject_CallMethod(@<类型对象>.GetPyObj(), @sn<pm_types>, @<构造参数>, NULL), PYREF_FALSE)
    }

    方法 创建空参实例 <公开 静态 类型 = Py类型类 注释 = "  创建指定Python类型实例." 注释 = "  请注意: 通过方法\"Py字典对象\"或\"Py模块对象\"取得的本类对象,实际上只是一个类,而并非实例,需要通过此方法,"
            注释 = "来创建该类的实例对象." 返回值注释 = "本方法执行成功,则返回该Py类实例对象,否则将返回空的Py对象." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 类型对象 <类型 = Py类型类 注释 = "当前类对象.">
    {
        @ @dt<Py类型类>(PyObject_CallObject(@<类型对象>.GetPyObj(), NULL), PYREF_FALSE)
    }

    方法 调用无参方法 <公开 静态 类型 = Py对象类 注释 = "调用当前Py类型实例对象内的指定无参方法.." 返回值注释 = "如果所欲调用的Py方法具有返回值,且本方法执行成功,则本方法返回Py的返回值,否则返回空的Py对象."
            @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py类型类 注释 = "当前类型实例对象.">
    参数 方法名称 <类型 = 文本型 注释 = "所欲调用的Py方法名称.">
    {
        @ @dt<Py对象类>(PyObject_CallMethodNoArgs (@<本类对象>.GetPyObj(), @dt<Py文本类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<方法名称>, @<方法名称>).GetPyObj()), PYREF_FALSE)
    }

    方法 调用格式化参数方法 <公开 静态 类型 = Py对象类 注释 = "通过格式化参数,将您所提供的参数转变为Py可变参数,然后调用目标Py方法." 注释 = "请注意:"
            注释 = "  1.本方法会将元组类型参数\"替换符为 (xxxx)\"解释为可变参数,如果您所欲调用的目标py方法参数不为" 注释 = "可变参数,则调用失败."
            注释 = "  1.本方法仅支持火山基本类型参数,例如, 文本型, 整数型等,不支持类对象,本方法不会对数据进行检查," 注释 = "请您一定要确保,\"参数替换符\"与\"参数替换数据\"数量一致,且类型匹配." 注释 = ""
            注释 = "替换符:" 注释 = "  s/s#/z/z# 创建Py文本类对象,使用此替换符,替换数据参数,必须为UTF8文本(实际为字节集)."
            注释 = "  u/u#      创建Py文本类对象,使用此替换符,替换数据参数,可以直接填入文本型数据(UTF-16 或 UCS-4)."
            注释 = "  y/y#      创建Py字节序列类对象.使用此替换符,替换数据参数,应为字节集指针." 注释 = "  i         创建Py数值类对象,使用此替换符,替换数据参数,应为整数型."
            注释 = "  b         创建Py字符对象,使用此替换符,替换数据参数,应为字符型数据." 注释 = "  h         创建Py数值类对象,使用此替换符,替换数据参数,应为短整数型."
            注释 = "  l         创建Py数值类对象,使用此替换符,替换数据参数,应为变整数." 注释 = "  L         创建Py数值类对象,使用此替换符,替换数据参数,应为长整数."
            注释 = "  d         创建Py数值类对象,使用此替换符,替换数据参数,应为小数型." 注释 = "" 注释 = "请注意: 以下所介绍的符号,不可单独使用,需要在括号,或中括号中,包含上述几种替换符方可."
            注释 = "  (xxx)/xx     可变参数替换符." 注释 = "  [xxx]        列表参数替换符." 注释 = "  {xxx}        字典参数替换符."
            返回值注释 = "如果所欲调用的Py方法具有返回值,且本方法执行成功,则本方法返回Py的返回值,否则返回空的Py对象." 编辑时信息 = "BAA9F, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 本类对象 <类型 = Py类型类 注释 = "当前类型实例对象." 编辑时信息 = "BAA9F, 0, 0, 0">
    参数 方法名称 <类型 = 文本型 注释 = "所欲调用的Py方法名称." 编辑时信息 = "BAA9F, 0, 0, 0">
    参数 参数替换符 <类型 = 文本型 注释 = "所欲使用参数替换符." 编辑时信息 = "BAA9F, 0, 0, 0">
    参数 参数替换数据 <注释 = "所欲提供的参数,请注意,此参数数量,与类型,必须与\"参数替换符\"保持一致." 注释 = "支持类型: 火山基本数据类型(数值{整数, 长整数, 小数}, 逻辑型, 文本型)"
            编辑时信息 = "BAA9F, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @dt<Py对象类>( PyObject_CallMethod(@<本类对象>.GetPyObj(), CU8String(@<方法名称>).GetText(), CU8String(@<参数替换符>).GetText(), @<参数替换数据>), PYREF_FALSE)
    }

    方法 调用方法 <公开 静态 类型 = Py对象类 注释 = "  调用当前Py类型实例对象内的任意方法." 注释 = "  请注意: 本方法无法自动将火山基本数据类型转为Py类型,您只能使用Py对象类或其子类的对象来传递参数."
            注释 = "如果您需要使用火山基本数据类型作为参数,请使用方法\"调用格式化参数方法\"." 返回值注释 = "如果所欲调用的Py方法具有返回值,且本方法执行成功,则本方法返回Py的返回值,否则返回空的Py对象."
            编辑时信息 = "F2A9B, 0, 0, 0" @嵌入式方法 = "req_obj_param_pointer=true">
