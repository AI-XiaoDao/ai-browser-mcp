类 Py集合类 <公开 基础类 = Py对象类 注释 = "对应Python中的集合类(Set(,))." 注释 = "集合类,允许用户插入不同数据类型的成员,但是最后输出内容时,会将值重复的成员删除." 注释 = "请注意:"
        注释 = "  1.本类无法自动创建实例对象,您需要自行通过\"Py集合类.创建()/创建自迭代器()\"方法进行创建实例对象."
        注释 = "  2.在您取成员时,请不要以添加成员时的顺序进行取,因为集合会自动去重和排序,导致成员位置发生了变换." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建 <公开 静态 类型 = Py集合类 注释 = "创建集合对象." @禁止流程检查 = 真>
    {
        @ return @sn<current_class> (PySet_New (NULL), PYREF_FALSE);
    }

    方法 创建自迭代器 <公开 静态 类型 = Py集合类 注释 = "通过指定的Py迭代器对象创建集合实例." 注释 = "请注意:请确保您指定的迭代器对象是有效的,且迭代器对象内是有数据的,否则,本方法将无法创建集合实例."
            @禁止流程检查 = 真>
    参数 指定迭代器 <类型 = Py迭代器类 注释 = "所指定的迭代器对象,">
    {
        如果 (指定迭代器.检查类型 () == 假)
        {
            返回 ((Py集合类)新建对象 (Py集合类))
        }
        @ return @sn<current_class> (PySet_New (@<指定迭代器>.GetPyObj()), PYREF_FALSE);
    }

    方法 创建冻结集合 <公开 静态 类型 = Py集合类 注释 = "创建一个不可改变的集合." 注释 = "请注意: 通过此方法所创建的集合对象,不可在Py代码内动态更改/加入成员."
            返回值注释 = "创建成功返回集合对象,创建失败,则返回空的火山Py集合对象." @禁止流程检查 = 真>
    参数 指定迭代器 <类型 = Py迭代器类 注释 = "所指定的迭代器对象," @默认值 = 空对象>
    {
        如果 (指定迭代器.检查类型 () == 假)
        {
            返回 ((Py集合类)新建对象 (Py集合类))
        }
        @ return @sn<current_class> (PyFrozenSet_New (@<指定迭代器>.GetPyObj()), PYREF_FALSE);
    }

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "  取得此对象内的成员数量." 注释 = "  请注意:千万不要直接使用此属性,当做循环目标值,因为,当您在循环体内执行\"弹出成员\"时,会影响"
            注释 = "成员数,每弹出一个成员,成员数量都会-1,您可在循环开始前,使用整数变量,记录当前的成员数,然后使" 注释 = "用该整数变量,当做循环目标值."
            返回值注释 = "如果方法执行失败,则返回-1,否则必定返回一个正整数表示成员数量." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, (INT)PySet_Size(GetPyObj()))
    }

    方法 添加成员 <公开 静态 类型 = 逻辑型 注释 = "  添加一个成员至当前集合对象内." 注释 = "  请注意: 所以添加的成员类型包括(文本型, 整数型, 小数型, 长整数型, 逻辑型以及任意Py对象类型)."
            注释 = "请不要添加其他类型数据,以免导致添加失败." 返回值注释 = "添加成功返回真,失败返回假,如果所添加的成员类型不为上述几种类型,也会导致添加失败." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py集合类 注释 = "当前集合对象.">
    参数 所欲添加成员 <注释 = "所欲添加的成员,可以是火山基本数据类型,也可以是任意Py对象类型(Py对象类的子类实例)." @匹配类型 = 通用型>
    {
        @ @<本类对象>.Append ( @dt<Py对象类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<所欲添加成员>, @<所欲添加成员>) )
    }

    方法 清空 <公开 类型 = 逻辑型 注释 = "清空该集合内的所有成员." 注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), FALSE, PySet_Clear(GetPyObj())==0 )
    }

    方法 是否包含 <公开 静态 类型 = 整数 注释 = "在此集合内查找指定成员,查找到返回1,未找到返回0,如果出错则返回-1." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py集合类 注释 = "当前集合对象.">
    参数 所欲查找成员 <注释 = "所欲查找的成员对象" @匹配类型 = 通用型>
    {
        @ @<本类对象>.IsContains ( @dt<Py对象类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<所欲查找成员>, @<所欲查找成员>) )
    }

    方法 查找并删除 <公开 静态 类型 = 整数 注释 = "在此集合内查找指定成员,查找到则将其删除,并返回1,未找到返回0,如果出错则返回-1." @嵌入式方法 = "req_obj_param_pointer=true">
    参数 本类对象 <类型 = Py集合类 注释 = "当前集合对象.">
    参数 所欲查找成员 <注释 = "所欲查找的成员对象" @匹配类型 = 通用型>
    {
        @ @<本类对象>.Discard ( @dt<Py对象类>::AnyVolType2PyType(PYREF_FALSE, @pdt_ch<所欲查找成员>, @<所欲查找成员>) )
    }

    方法 弹出成员 <公开 类型 = Py对象类 注释 = "取得集合内的第一个成员,并将其从集合内删除." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>( GetPyObj(), @dt<Py对象类>(), @dt<Py对象类>( PySet_Pop(GetPyObj()), PYREF_FALSE) )
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为集合对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PySet_Check (GetPyObj()) || PyFrozenSet_Check(GetPyObj()) )
    }

    # 本地代码======
    # @begin
    # <> <include>
    # BOOL @sn<current_class>::Append (@dt<Py对象类>& pValue);
    # INT @sn<current_class>::IsContains (@dt<Py对象类>& pValue);
    # INT @sn<current_class>::Discard (@dt<Py对象类>& pValue);
    # <> </include>
    #     
    # BOOL @sn<current_class>::Append (@dt<Py对象类>& pValue) {
    #     if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0 || pValue.GetPyObj() == NULL || pValue.GetPyObj()->ob_refcnt <= 0)
    #         return FALSE;
    #     return PySet_Add (GetPyObj(), pValue.GetPyObj()) == 0;
    # }
    #
    # INT @sn<current_class>::IsContains (@dt<Py对象类>& pValue) {
    #     if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0 || pValue.GetPyObj() == NULL || pValue.GetPyObj()->ob_refcnt <= 0)
    #         return -1;
    #     return PySet_Contains (GetPyObj(), pValue.GetPyObj());
    # }
    #
    # INT @sn<current_class>::Discard (@dt<Py对象类>& pValue) {
    #     if (GetPyObj() == NULL || GetPyObj()->ob_refcnt <= 0 || pValue.GetPyObj() == NULL || pValue.GetPyObj()->ob_refcnt <= 0)
    #         return -1;
    #     return PySet_Discard (GetPyObj(), pValue.GetPyObj());
    # }
    # @end
}

类 Py字节数组类 <公开 基础类 = Py对象类 注释 = "Py字节数组类." 注释 = "本类可以将Python的字节数组,与火山的字节集类进行互转." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建自对象 <公开 静态 类型 = Py字节数组类 注释 = "通过指定的Py对象(可以是任意类型的Py对象)创建Py字节数组对象."
            注释 = "请注意:您需要保证\"所基于Py对象\"是有效的对象,否则,本方法将执行失败,并且返回一个无效的字节数组对象." @禁止流程检查 = 真>
    参数 所欲提供对象 <类型 = Py对象类 注释 = "所基于Py对象,本对象可以是任意Py类型对象.">
    {
        @ @m<PyObjectCheckAndReturn>(@<所欲提供对象>.GetPyObj(), @sn<current_class>(),  @sn<current_class>(PyByteArray_FromObject(@<所欲提供对象>.GetPyObj()), PYREF_FALSE) )
    }

    方法 创建自字节集 <公开 静态 类型 = Py字节数组类 注释 = "通过指定的字节集对象,创建Py字节数组对象." @禁止流程检查 = 真>
    参数 所基于字节集 <类型 = 字节集类 注释 = "所基于字节集数据.">
    {
        @ return  @sn<current_class>( PyByteArray_FromStringAndSize((const char *)@<所基于字节集>.GetPtr(), @<所基于字节集>.GetSize()), PYREF_FALSE );
    }

    方法 到字节集 <公开 属性读 类型 = 字节集类 注释 = "将Py字节序列转为火山字节集对象." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @an<CVolString>(),  @an<CVolString>( (const CHAR*) PyByteArray_AsString(GetPyObj()) ) )
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将字节数组对象转为文本内容." @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @an<CVolString>(),  @an<CVolString>( (const CHAR*) PyByteArray_AsString(GetPyObj()) ) )
    }

    方法 合并 <公开 静态 类型 = Py字节数组类 注释 = "将两个字节数组对象合并为一个,并且返回合并后的字节数组类对象."
            注释 = "请注意: 您需要保证,\"所欲合并对象1/2\"均为有效的Py字节数组类对象,否则,本方法将执行失败,并且返回一个无效的字节数组对象." @禁止流程检查 = 真>
    参数 所欲合并对象1 <类型 = Py字节数组类 注释 = "所欲合并的字节数组对象.">
    参数 所欲合并对象2 <类型 = Py字节数组类 注释 = "所欲合并的字节数组对象.">
    {
        @ @m<PyObjectCheckAndReturn>( @<所欲合并对象1>.GetPyObj(), @sn<current_class>(),  @sn<current_class> (PyByteArray_Concat(@<所欲合并对象1>.GetPyObj(), @<所欲合并对象2>.GetPyObj()), PYREF_FALSE) )
    }

    方法 成员数 <公开 属性读 类型 = 变整数 注释 = "取得字节数组对象内字节成员数." 注释 = "请注意: 如果字节数组对象无效,则此方法返回-1,否则将返回一个正整数." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, PyByteArray_Size(GetPyObj()))
    }

    方法 重定义成员数 <公开 类型 = 整数 注释 = "重新设置该字节数组的成员数." 注释 = "" @禁止流程检查 = 真>
    参数 新成员数量 <类型 = 整数>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, PyByteArray_Resize(GetPyObj(), @<新成员数量>))
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为字节数组对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyByteArray_Check (GetPyObj()))
    }
}

类 Py字节序列类 <公开 基础类 = Py对象类 注释 = "  Py字节序列类." 注释 = "  本类可以将Python的字节数组,与火山的字节集类进行互转.与\"Py字节数组类\"不同的是."
        注释 = "本类实例对象,在Py代码中,不允许修改成员." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建自对象 <公开 静态 类型 = Py字节序列类 注释 = "通过指定的Py对象(可以是任意类型的Py对象)创建Py字节序列对象."
            注释 = "请注意:您需要保证\"所基于Py对象\"是有效的对象,否则,本方法将执行失败,并且返回一个无效的字节序列对象." @禁止流程检查 = 真>
    参数 所基于Py对象 <类型 = Py对象类 注释 = "所基于Py对象,本对象可以是任意Py类型对象.">
    {
        @ @m<PyObjectCheckAndReturn>(@<所基于Py对象>.GetPyObj(), @sn<current_class> (), @sn<current_class> (PyBytes_FromObject (@<所基于Py对象>.GetPyObj()), PYREF_FALSE))
    }

    方法 创建自字节集 <公开 静态 类型 = Py字节序列类 注释 = "通过指定的字节集对象,创建Py字节序列对象." @禁止流程检查 = 真>
    参数 所基于字节集 <类型 = 字节集类 注释 = "所基于字节集数据.">
    {
        @ return @sn<current_class>( PyBytes_FromString((const char *)@<所基于字节集>.GetPtr()), PYREF_FALSE);
    }

    方法 到字节集 <公开 属性读 类型 = 字节集类 注释 = "将Py字节序列转为火山字节集对象." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @an<CVolString>(),  @an<CVolString>( (const CHAR*) PyBytes_AsString(GetPyObj()) ) )
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为字节序列对象." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @禁止流程检查 = 真 @虚拟方法 = 可覆盖>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE, PyBytes_Check (GetPyObj()))
    }

    方法 成员数 <公开 属性读 类型 = 变整数 注释 = "取得字节序列对象内字节成员数." 注释 = "请注意: 如果字节序列对象无效,则此方法返回-1,否则将返回一个正整数." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), -1, PyBytes_Size(GetPyObj()))
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将字节序列对象转为文本内容." @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @an<CVolString>(),  @an<CVolString>( (const CHAR*) PyBytes_AsString(GetPyObj()) ) )
    }

    方法 添加 <公开 注释 = "将指定字节序列对象,合并到自身中.">
    参数 所欲合并对象 <类型 = Py字节序列类>
    {
        @ PyObject * pObj = GetPyObj();
        @ if (pObj == NULL || pObj->ob_refcnt <= 0 || @<所欲合并对象>.GetPyObj() == NULL || @<所欲合并对象>.GetPyObj()->ob_refcnt <= 0)
        @     return ;
        @ PyBytes_Concat(&pObj, @<所欲合并对象>.GetPyObj());
    }
}

# ======
# // 迭代器循环宏. iter=迭代器对象, outvolpy=接受迭代数据的火山Py对象
# @ @def_macro PyIterWhile(iter,outvolpy)  while (@dt<Py对象类>::CopyPyObject(PyIter_Next(iter.GetPyObj()), outvolpy))

类 Py迭代器类 <公开 基础类 = Py对象类 注释 = "  Py迭代器类,此类可获得( Py列表类, Py元组类, Py集合类, Py字典类, Py字节数组类, Py字节序列类, Py文本类)等Py"
        注释 = "对象的成员数据,也可以通过此迭代器,创建上述几种Py对象." 注释 = "  请注意: 如果您取得迭代器对象之后,将其数据消费掉(直接或间接使用 下一项 方法,或 迭代循环),那么,该迭代器对象"
        注释 = "将会清空迭代器内的已消费的数据.也就是说,此迭代器是一次性的,使用完毕,就无法再次使用." @文档 = "category = \"辅助类\"">
{

    # @ @m<PyObjectDefaultConstructor>

    方法 创建 <公开 静态 类型 = Py迭代器类 注释 = "从指定的Py对象创建迭代器." 注释 = "可用于创建迭代器的对象有: Py列表类, Py元组类, Py集合类, Py字典类, Py字节数组类, Py字节序列类, Py文本类."
            @禁止流程检查 = 真>
    参数 Py对象 <类型 = Py对象类 注释 = "基于此对象创建迭代器.">
    {
        @ @m<PyObjectCheckAndReturn>(@<Py对象>.GetPyObj(), @sn<current_class>(),  @sn<current_class>(PyObject_GetIter(@<Py对象>.GetPyObj()), PYREF_FALSE) )
    }

    方法 下一项 <公开 类型 = Py对象类 注释 = "获取迭代器下一项数据." 注释 = "获取成功返回真,失败返回假." @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), @dt<Py对象类>(),  @dt<Py对象类>(PyIter_Next(GetPyObj()), PYREF_FALSE) )
    }

    方法 迭代循环 <公开 静态 注释 = "开始循环迭代." 注释 = "本方法的\"输出Py对象\"为循环迭代时,将数据写入到该对象中,您可在循环体中,通过该对象获得数据." @嵌入式方法 = "has_body = true">
    参数 本类对象 <类型 = Py迭代器类 注释 = "迭代器对象">
    参数 输出Py对象 <类型 = Py对象类 注释 = "输出对象">
    {
        @ @m<PyIterWhile> (@<本类对象>, @<输出Py对象>)
    }

    方法 检查类型 <公开 类型 = 逻辑型 注释 = "检查当前对象,是否为迭代器." 注释 = "成功返回真, 失败返回假,如果失败,可用\"类型\"获得实际类型文本." @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    {
        @ @m<PyObjectCheckAndReturn>(GetPyObj(), FALSE,  PyIter_Check (GetPyObj()) )
    }
}
