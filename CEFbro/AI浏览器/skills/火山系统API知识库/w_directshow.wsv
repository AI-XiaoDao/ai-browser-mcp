    方法 窗口扩展风格 <公开 属性写 注释 = "设置扩展窗口样式" 折叠 @禁止流程检查 = 真>
    参数 窗口扩展风格 <类型 = 整数 注释 = "欲设置的扩展窗口风格样式">
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_WindowStyleEx((long)@<窗口扩展风格>);
    }

    方法 背景调色板 <公开 属性读 类型 = 逻辑型 注释 = "检索一个标志,用于在后台实现调色板" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nTop = 0;
        @     m_pVideoWindow->get_BackgroundPalette(&nTop);
        @     return (@dt<逻辑型>)nTop;
        @ }
        @ return 0;
    }

    方法 背景调色板 <公开 属性写 注释 = "设置一个标志,用于在后台实现调色板" 折叠 @禁止流程检查 = 真>
    参数 背景调色板 <类型 = 逻辑型 注释 = "如果视频将在另一个应用程序或文档中播放,则应用程序可能想要使用自己的调色板.它可以通过将此标志设置为\"真\"来要求视频使用当前的前台调色板,而不是使用自己的面板."
            注释 = "如果设置为 0,窗口将安装并实现自己的首选调色板.请注意,要求窗口使用不同的调色板将导致严重的性能损失." 折叠2>
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_BackgroundPalette((long)@<背景调色板>);
    }

    方法 边框颜色 <公开 属性读 类型 = 整数 注释 = "检索当前边框颜色" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nTop = 0;
        @     m_pVideoWindow->get_BorderColor(&nTop);
        @     return (@dt<整数>)nTop;
        @ }
        @ return 0;
    }

    方法 边框颜色 <公开 属性写 注释 = "设置当前边框颜色" 折叠 @禁止流程检查 = 真>
    参数 边框颜色 <类型 = 整数 注释 = "指向当前边框的颜色">
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_BorderColor((long)@<边框颜色>);
    }

    方法 隐藏光标 <公开 属性读 类型 = 逻辑型 注释 = "检索当鼠标放置在视频窗口上时显示或隐藏光标" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nCursorHidden = 0;
        @     m_pVideoWindow->IsCursorHidden(&nCursorHidden);
        @     return (@dt<逻辑型>)nCursorHidden;
        @ }
        @ return 0;
    }

    方法 隐藏光标 <公开 属性写 注释 = "设置当鼠标放置在视频窗口上时显示或隐藏光标" 折叠 @禁止流程检查 = 真>
    参数 是否隐藏 <类型 = 逻辑型 注释 = "指定视频窗口是否是否隐藏隐藏光标" @默认值 = 真>
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->HideCursor(@<是否隐藏> ? OATRUE : OAFALSE);
    }

    方法 所有者窗口句柄 <公开 属性读 类型 = 变整数 注释 = "检索当前窗口所有者" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     OAHWND hWnd = NULL;
        @     m_pVideoWindow->get_Owner(&hWnd);
        @     return (@dt<变整数>)hWnd;
        @ }
        @ return 0;
    }

    方法 所有者窗口句柄 <公开 属性写 注释 = "设置当前窗口所有者" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "指向窗口所有者的句柄">
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_Owner((OAHWND)@<窗口句柄>);
    }

    方法 获取焦点 <公开 注释 = "将视频窗口移动到前台,并选择性地为其提供焦点" 折叠 @禁止流程检查 = 真>
    参数 是否获得焦点 <类型 = 逻辑型 注释 = "指定视频窗口是否获得焦点的值.值为真表示窗口焦点,假表示不提供" @默认值 = 真>
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->SetWindowForeground((long)@<是否获得焦点>);
    }

    方法 置父窗口 <公开 类型 = 逻辑型 注释 = "将预览视频窗口置入到某个窗口组件当中" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供所创建窗口的父窗口组件,如果该窗口组件尚未被创建,则认为无父窗口组件." @默认值 = 0>
    参数 左边 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示使用父组件的左边." @默认值 = 数值范围.最小整数值>
    参数 顶边 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示使用父组件的顶边." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用父组件的宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用父组件的高度." @默认值 = 数值范围.最小整数值>
    {
        @ if(m_pVideoWindow){
        @     OAHWND hWnd = (OAHWND)@<父窗口句柄>;
        @     if(hWnd){
        @         m_pVideoWindow->put_Owner(hWnd);
        @         m_pVideoWindow->put_WindowStyle(WS_CHILD | WS_CLIPSIBLINGS);
        @         m_pVideoWindow->put_MessageDrain(hWnd);
        @         RECT rect;
        @         ::GetClientRect((HWND)hWnd, &rect);
        @         if(@<左边> != @<火山.基本.数值范围.最小整数值>)
        @             rect.left = @<左边>;
        @         if(@<顶边> != @<火山.基本.数值范围.最小整数值>)
        @             rect.top = @<顶边>;
        @         if(@<宽度> != @<火山.基本.数值范围.最小整数值>)
        @             rect.right = rect.left + @<宽度>;
        @         if(@<高度> != @<火山.基本.数值范围.最小整数值>)
        @             rect.bottom = rect.top + @<高度>;
        @         m_pVideoWindow->SetWindowPosition(rect.left, rect.top, rect.right - rect.left, rect.bottom - rect.top);
        @     }
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 取窗口矩形 <公开 类型 = 矩形类 注释 = "获取视频预览窗口的矩形" 折叠 @禁止流程检查 = 真>
    {
        变量 矩形 <类型 = 矩形类>
        @ if(m_pVideoWindow){
        @     long pLeft = 0;
        @     long pTop = 0;
        @     long pWidth = 0;
        @     long pHeight = 0;
        @     m_pVideoWindow->GetWindowPosition(&pLeft, &pTop, &pWidth, &pHeight);
        @     @<矩形.设置>(pLeft, pTop, pWidth, pHeight);
        @ }
        返回 (矩形)
    }

    方法 置窗口尺寸 <公开 注释 = "设置视频预览窗口的尺寸;注意:\"打开预览\"命令执行后调用" 折叠 @禁止流程检查 = 真>
    参数 左边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置" @默认值 = 0>
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置" @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度" @默认值 = 500>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度" @默认值 = 500>
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->SetWindowPosition(@<左边位置>, @<顶边位置>, @<宽度>, @<高度>);
    }

    方法 取最小分辨率 <公开 类型 = 尺寸类 注释 = "获取视频图像最小尺寸" 折叠 @禁止流程检查 = 真>
    {
        变量 尺寸 <类型 = 尺寸类>
        @ if(m_pVideoWindow){
        @     long pWidth = 0;
        @     long pHeight = 0;
        @     m_pVideoWindow->GetMinIdealImageSize(&pWidth, &pHeight);
        @     @<尺寸.设置>(pWidth, pHeight);
        @ }
        返回 (尺寸)
    }

    方法 取最大分辨率 <公开 类型 = 尺寸类 注释 = "获取视频图形最大尺寸" 折叠 @禁止流程检查 = 真>
    {
        变量 尺寸 <类型 = 尺寸类>
        @ if(m_pVideoWindow){
        @     long pWidth = 0;
        @     long pHeight = 0;
        @     m_pVideoWindow->GetMaxIdealImageSize(&pWidth, &pHeight);
        @     @<尺寸.设置>(pWidth, pHeight);
        @ }
        返回 (尺寸)
    }

