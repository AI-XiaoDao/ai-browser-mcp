类 摄像头类 <公开 基础类 = 对象类 注释 = "摄像头相关操作">
{
    方法 类_清理 <折叠>
    {
        关闭设备 ()
    }

    方法 播放器 <公开 属性读 类型 = 视频播放器 注释 = "取播放器对象实例" 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<视频播放器>(m_pVideoWindow);
    }

    方法 打开设备 <公开 类型 = 逻辑型 注释 = "选择指定摄像头" 返回值注释 = "成功返回真,失败或已存在打开的设备则返回假." 折叠 @禁止流程检查 = 真>
    参数 设备索引 <类型 = 整数 注释 = "当前视频设备索引,可使用\"音视频操作.枚举摄像头\"命令定位确认设备索引.">
    {
        @ if(!m_pBaseFilter && !m_pGraphBuilder && !m_pMediaControl && !m_pVideoWindow && !m_pSampleGrabber && !m_pCaptureGraphBuilder2){
        @     IMoniker *pMoniker = nullptr;
        @     if(SUCCEEDED(SelectedDevices(CLSID_VideoInputDeviceCategory, (ULONG)@<设备索引>, &pMoniker))){
        @         if(SUCCEEDED(pMoniker->BindToObject(0, 0, IID_IBaseFilter, (void **)&m_pBaseFilter))){
        @             if(SUCCEEDED(CoCreateInstance(CLSID_FilterGraph, NULL, CLSCTX_INPROC_SERVER, IID_IGraphBuilder, (void **)&m_pGraphBuilder))){
        @                 if(FAILED(m_pGraphBuilder->AddFilter(m_pBaseFilter, L"Video Capture")))
        @                     goto __Failed;
        @             }
        @             if(SUCCEEDED(CoCreateInstance(CLSID_CaptureGraphBuilder2, NULL, CLSCTX_INPROC_SERVER, IID_ICaptureGraphBuilder2, (void **)&m_pCaptureGraphBuilder2))){
        @                 if(FAILED(m_pCaptureGraphBuilder2->SetFiltergraph(m_pGraphBuilder)))
        @                     goto __Failed;
        @             }
        @             if(FAILED(m_pGraphBuilder->QueryInterface(IID_IMediaControl, (void **)&m_pMediaControl)))
        @                 goto __Failed;
        @             pMoniker->Release(); 
        @             return TRUE;
        @         }
        @ __Failed:
        @         m_pBaseFilter->Release();
        @         m_pBaseFilter = nullptr;
        @     }
        @     pMoniker->Release();
        @ }
        @ this->@<关闭设备>();
        @ return FALSE;
    }

    方法 关闭设备 <公开 注释 = "关闭已打开的摄像头" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pCaptureGraphBuilder2){
        @     m_pCaptureGraphBuilder2->Release();
        @     m_pCaptureGraphBuilder2 = nullptr;
        @ }
        @ if(m_pSampleGrabber){
        @     m_pSampleGrabber->Release();
        @     m_pSampleGrabber = nullptr;
        @ }
        @ if(m_pVideoWindow){
        @     m_pVideoWindow->Release();
        @     m_pVideoWindow = nullptr;
        @ }
        @ if(m_pMediaControl){
        @     m_pMediaControl->Release();
        @     m_pMediaControl = nullptr;
        @ }
        @ if(m_pGraphBuilder){
        @     m_pGraphBuilder->Release();
        @     m_pGraphBuilder = nullptr;
        @ }
        @ if(m_pBaseFilter){
        @     m_pBaseFilter->Release();
        @     m_pBaseFilter = nullptr;
        @ }
    }

    方法 启用采样 <公开 类型 = 逻辑型 注释 = "启用视频采样;注意:必须在\"打开设备\"命令执行后,\"启用预览\"命令执行前调用" @禁止流程检查 = 真>
    参数 采样器对象 <类型 = 视频采样器 注释 = "用于接收采样数据的对实例化对象" "">
    参数 快照模式 <类型 = 逻辑型 注释 = "如果启用则获取到第一张图像时将自动停止" @默认值 = 假>
    {
        @ if(!m_pVideoWindow && !m_pSampleGrabber){
        @     HRESULT hr = 0;
        @     IBaseFilter *pSG_Filter = nullptr;
        @     if(SUCCEEDED(CoCreateInstance(CLSID_SampleGrabber, NULL, CLSCTX_INPROC_SERVER, IID_PPV_ARGS(&pSG_Filter)))){
        @         hr = m_pGraphBuilder->AddFilter(pSG_Filter, L"Sample Grabber");
        @         if(SUCCEEDED(pSG_Filter->QueryInterface(IID_ISampleGrabber, (void **)&m_pSampleGrabber))){
        @             hr = m_pSampleGrabber->SetOneShot(@<快照模式>);
        @             hr = m_pSampleGrabber->SetBufferSamples(TRUE); // 必须开启缓冲区,否则无法拍照
        @             hr = m_pSampleGrabber->SetCallback((ISampleGrabberCB*)&@<采样器对象>, 1L);
        @             pSG_Filter->Release();
        @             return TRUE;
        @         }
        @         pSG_Filter->Release();
        @     }
        @ }
        @ return FALSE;
    }

    方法 启用预览 <公开 类型 = 逻辑型 注释 = "启用预览视频;注意:必须在\"打开设备\"命令执行后,\"运行\"命令执行前调用" @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供所创建窗口的父窗口组件,如果该窗口组件尚未被创建,则认为无父窗口组件." @默认值 = 0>
    参数 左边 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的横向坐标位置,为\"数值范围.最小整数值\"表示使用父组件的左边." @默认值 = 数值范围.最小整数值>
    参数 顶边 <类型 = 整数 注释 = "提供所创建窗口左边在屏幕上的纵向坐标位置,为\"数值范围.最小整数值\"表示使用父组件的顶边." @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供所创建窗口的宽度,为\"数值范围.最小整数值\"表示使用父组件的宽度." @默认值 = 数值范围.最小整数值>
    参数 高度 <类型 = 整数 注释 = "提供所创建窗口的高度,为\"数值范围.最小整数值\"表示使用父组件的高度." @默认值 = 数值范围.最小整数值>
    {
        @ if(m_pBaseFilter && m_pGraphBuilder && m_pCaptureGraphBuilder2 && !m_pVideoWindow){
        @     HRESULT hr = m_pCaptureGraphBuilder2->RenderStream(&PIN_CATEGORY_PREVIEW, &MEDIATYPE_Video, m_pBaseFilter, NULL, NULL);
        @     if(SUCCEEDED(hr) || hr == VFW_S_NOPREVIEWPIN)
        @         if(SUCCEEDED(m_pGraphBuilder->QueryInterface(IID_IVideoWindow, (void **)&m_pVideoWindow))){
        @             this->@<播放器>().@n<视频播放器.置父窗口>(@<父窗口句柄>, @<左边>, @<顶边>, @<宽度>, @<高度>);
        @             return TRUE;
        @         }
        @ }
        @ return FALSE;
    }

    方法 启用录制 <公开 类型 = 逻辑型 注释 = "启用录制视频;注意:必须在\"打开设备\"命令执行后,\"运行\"命令执行前调用" 折叠 @禁止流程检查 = 真>
    参数 文件名称 <类型 = 文本型 注释 = "录制后视频储存的文件名称;如\"c:\\video.avi\"">
    {
        @ if(m_pBaseFilter && m_pCaptureGraphBuilder2){
        @     IBaseFilter *pBaseFilter;
        @     if(SUCCEEDED(m_pCaptureGraphBuilder2->SetOutputFileName(&MEDIASUBTYPE_Avi, @<文件名称>, &pBaseFilter, NULL))){ 
        @         if(SUCCEEDED(m_pCaptureGraphBuilder2->RenderStream(&PIN_CATEGORY_CAPTURE, &MEDIATYPE_Video, m_pBaseFilter, NULL, pBaseFilter))){
        @             m_pCaptureGraphBuilder2->RenderStream(&PIN_CATEGORY_CAPTURE, &MEDIATYPE_Audio, m_pBaseFilter, NULL, pBaseFilter);
        @             pBaseFilter->Release();
        @             return TRUE;
        @         }
        @         pBaseFilter->Release();
        @     }
        @ }
        @ return FALSE;
    }

    方法 采样拍照 <公开 类型 = 字节集类 注释 = "获取当前采集器中的图像;注意:必须在\"启用采样\"和\"运行\"命令执行后调用" @禁止流程检查 = 真>
    {
        @ @an<CVolMem> memBuffer;
        @ if(m_pSampleGrabber){
        @     long lBufferSize = 0;
        @     if (SUCCEEDED (m_pSampleGrabber->GetCurrentBuffer(&lBufferSize,NULL)))  {
        @         if (SUCCEEDED (m_pSampleGrabber->GetCurrentBuffer(&lBufferSize, (long *)memBuffer.Realloc ((INT_P)lBufferSize))))
        @             memBuffer.Realloc ((INT_P)lBufferSize);
        @         else
        @             memBuffer.Free ();
        @     }
        @ }
        @ return memBuffer;
    }

    方法 运行 <公开 类型 = 逻辑型 注释 = "开始视频预览或录制;注意:\"启用预览\"或\"启用录制\"或\"启用采样\"命令执行后调用" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pMediaControl){
        @     m_pMediaControl->Run();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 暂停 <公开 类型 = 逻辑型 注释 = "暂停视频预览或录制;注意:\"启用预览\"或\"启用录制\"或\"启用采样\"命令执行后调用" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pMediaControl){
        @     m_pMediaControl->Pause();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 停止 <公开 类型 = 逻辑型 注释 = "停止视频预览或录制;注意:\"启用预览\"或\"启用录制\"或\"启用采样\"命令执行后调用" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pMediaControl){
        @     m_pMediaControl->Stop();
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 取状态 <公开 类型 = 播放器状态 注释 = "取当前视频预览或录制状态;注意:\"启用预览\"或\"启用录制\"或\"启用采样\"命令执行后调用" 折叠 @禁止流程检查 = 真>
    参数 超时持续时间 <类型 = 整数 注释 = "超时持续时间(以毫秒为单位)或-1表示指定无限超时.">
    {
        @ if(m_pMediaControl){
        @     OAFilterState fs;
        @     m_pMediaControl->GetState(@<超时持续时间>, &fs);
        @     return (@dt<播放器状态>)fs;
        @ }
        返回 (播放器状态.未开启)
    }

    方法 异步停止 <公开 类型 = 逻辑型 注释 = "停止视频预览或录制;注意:\"启用预览\"或\"启用录制\"或\"启用采样\"命令执行后调用;如果要在停止图形时查找筛选器图,此方法非常有用." 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pMediaControl){
        @     return m_pMediaControl->StopWhenReady() == S_OK;
        @ }
        @ return FALSE;
    }

    方法 显示属性窗口 <公开 注释 = "显示摄像头属性设置窗口;注意:只有摄像头支持的时候才会显示" 折叠 @禁止流程检查 = 真>
    {
        @ if (m_pBaseFilter == nullptr)  return;
        @ HRESULT hr;
        @ IEnumPins  *pEnum;
        @ IPin       *pPin;
        @ if (FAILED(m_pBaseFilter->EnumPins(&pEnum)))  return;
        @ while(pEnum->Next(1, &pPin, 0) == S_OK) {
        @     PIN_DIRECTION PinDirThis; 
        @     pPin->QueryDirection(&PinDirThis);
        @     if (PINDIR_OUTPUT == PinDirThis){
        @         ISpecifyPropertyPages *pSpecify;
        @         hr = pPin->QueryInterface(IID_ISpecifyPropertyPages, (void **)&pSpecify);
        @         if (SUCCEEDED(hr)) {
        @             CAUUID caGUID;
        @             pSpecify->GetPages(&caGUID);
        @             pSpecify->Release();
        @             OleCreatePropertyFrame(NULL, 0, 0, NULL, 1, (IUnknown **)&pPin, caGUID.cElems, caGUID.pElems, 0, 0, NULL);
        @             CoTaskMemFree(caGUID.pElems);
        @         }
        @         pPin->Release();
        @         break;
        @     }
        @     pPin->Release();
        @ }
        @ pEnum->Release();
    }

    # @begin
    # <> <include>
    #     IBaseFilter           *m_pBaseFilter           = nullptr;
    #     IGraphBuilder         *m_pGraphBuilder         = nullptr;
    #     IMediaControl         *m_pMediaControl         = nullptr;
    #     IVideoWindow          *m_pVideoWindow          = nullptr;
    #     ISampleGrabber        *m_pSampleGrabber        = nullptr;
    #     ICaptureGraphBuilder2 *m_pCaptureGraphBuilder2 = nullptr;
    # <> </include>
    # @end
}
