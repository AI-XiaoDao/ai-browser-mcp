    # <> </include>
    # @end
}

类 音视频操作类 <公开 基础类 = 对象类 注释 = "摄像头及麦克风相关操作" 折叠 @禁止创建对象 = 真>
{
    方法 枚举摄像头 <公开 静态 注释 = "枚举本地已存在的摄像头设备" 折叠
            @嵌入式方法 = "name = enum_videos\r\nhas_loop_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"DSHOW_ENUM_DEVICES_END()\"">
    {
        @ DSHOW_ENUM_DEVICES_GET_INFORMATION(CLSID_VideoInputDeviceCategory)
    }

    方法 枚举麦克风 <公开 静态 注释 = "枚举本地已存在的麦克风设备" 折叠 隐藏值属性 = "0"
            @嵌入式方法 = "name = enum_audios\r\nhas_loop_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"DSHOW_ENUM_DEVICES_END()\"">
    {
        @ DSHOW_ENUM_DEVICES_GET_INFORMATION(CLSID_AudioInputDeviceCategory)
    }

    方法 取设备名称 <公开 静态 类型 = 文本型 注释 = "取已枚举到的设备名称" 折叠 隐藏值属性 = "0" @嵌入式方法 = "parent = \"enum_videos, enum_audios\"">
    {
        @ szFriendlyName
    }

    方法 取设备路径 <公开 静态 类型 = 文本型 注释 = "取已枚举到的设备路径" 折叠 隐藏值属性 = "0" @嵌入式方法 = "parent = \"enum_videos, enum_audios\"">
    {
        @ szDevicePath
    }

    方法 取波形标识 <公开 静态 类型 = 整数 注释 = "取已枚举到的麦克风波形ID" 折叠 隐藏值属性 = "0" @嵌入式方法 = "parent = \"enum_audios\"">
    {
        @ nWaveInID
    }
}

