<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "微软文档：https://learn.microsoft.com/zh-cn/windows/win32/directshow" 注释 = "" @视窗.外部库 = "strmiids.lib"
        @视窗.外部头文件 = "include\\w_directshow.h" @视窗.外部源文件 = "include\\w_directshow.cpp">

类 播放器状态 <公开 折叠 @常量类 = 整数>
{
    常量 未开启 <公开 值 = -1 注释 = "视频播放器出现了错误">
    常量 已停止 <公开 值 = @"@ FILTER_STATE::State_Stopped" 注释 = "视频播放器出于停止状态">
    常量 已暂停 <公开 值 = @"@ FILTER_STATE::State_Paused" 注释 = "视频播放器出于暂停状态">
    常量 正在播放 <公开 值 = @"@ FILTER_STATE::State_Running" 注释 = "视频播放器出于播放状态">
}

类 视频播放器 <公开 基础类 = 对象类 注释 = "视频播放窗口操作类" 折叠 @禁止创建对象 = 真>
{
    方法 宽度 <公开 属性读 类型 = 整数 注释 = "检索当前窗口宽度" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nWidth = 0;
        @     m_pVideoWindow->get_Width(&nWidth);
        @     return (@dt<整数>)nWidth;
        @ }
        @ return 0;
    }

    方法 宽度 <公开 属性写 注释 = "设置当前窗口宽度" 折叠 @禁止流程检查 = 真>
    参数 宽度 <类型 = 整数 注释 = "欲设置的窗口宽度">
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_Width((long)@<宽度>);
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "检索当前窗口高度" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nHeight = 0;
        @     m_pVideoWindow->get_Height(&nHeight);
        @     return (@dt<整数>)nHeight;
        @ }
        @ return 0;
    }

