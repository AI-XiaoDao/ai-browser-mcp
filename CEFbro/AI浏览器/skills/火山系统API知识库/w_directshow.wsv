    参数 窗口状态 <类型 = 整数 注释 = "新建窗口状态" 注释 = "此成员函数采用与\"ShowWindow\"函数相同的参数(例如:WS_SHOWNORMAL,WS_SHOWMINNOACTIVATE和WS_SHOWMAXIMIZED)"
            折叠2>
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_WindowState((long)@<窗口状态>);
    }

    方法 窗口风格 <公开 属性读 类型 = 整数 注释 = "检索标准窗口样式" 折叠 @禁止流程检查 = 真>
    {
        @ if(m_pVideoWindow){
        @     long nWindowStyle = 0;
        @     m_pVideoWindow->get_WindowStyle(&nWindowStyle);
        @     return (@dt<整数>)nWindowStyle;
        @ }
        @ return 0;
    }

    方法 窗口风格 <公开 属性写 注释 = "设置标准窗口样式" 折叠 @禁止流程检查 = 真>
    参数 窗口风格 <类型 = 整数 注释 = "欲设置的窗口风格样式">
    {
        @ if(m_pVideoWindow)
        @     m_pVideoWindow->put_WindowStyle((long)@<窗口风格>);
    }

