        @视窗.附属文件 = "lib\\$(p)\\dynamic\\icudt69.dll\r\nlib\\$(p)\\dynamic\\icuin69.dll\r\nlib\\$(p)\\dynamic\\icuio69.dll\r\nlib\\$(p)\\dynamic\\icutu69.dll\r\nlib\\$(p)\\dynamic\\icuuc69.dll\r\nlib\\$(p)\\dynamic\\v8.dll\r\nlib\\$(p)\\dynamic\\v8_libbase.dll\r\nlib\\$(p)\\dynamic\\v8_libplatform.dll\r\n..\\..\\shared\\extern_lib\\common\\zlib\\1\\$(p)\\dll\\zlib1.dll"
        @视窗.预定义宏 = "USING_V8_SHARED, V8_USE_EXTERNAL_STARTUP_DATA" @视窗.需求VS版本 = "14-" ""
        "// @视窗.外部库.non_static" = "lib\\$(p)\\dynamic\\icudt.lib\r\nlib\\$(p)\\dynamic\\icuin.lib\r\nlib\\$(p)\\dynamic\\icuio.lib\r\nlib\\$(p)\\dynamic\\icutu.lib\r\nlib\\$(p)\\dynamic\\icuuc.lib\r\nlib\\$(p)\\dynamic\\v8.dll.lib\r\nlib\\$(p)\\dynamic\\v8_libbase.dll.lib\r\nlib\\$(p)\\dynamic\\v8_libplatform.dll.lib\r\nlib\\$(p)\\dynamic\\zlib.lib"
        "// @视窗.附属文件.non_static" = "lib\\$(p)\\dynamic\\icudt69.dll\r\nlib\\$(p)\\dynamic\\icuin69.dll\r\nlib\\$(p)\\dynamic\\icuio69.dll\r\nlib\\$(p)\\dynamic\\icutu69.dll\r\nlib\\$(p)\\dynamic\\icuuc69.dll\r\nlib\\$(p)\\dynamic\\v8.dll\r\nlib\\$(p)\\dynamic\\v8_libbase.dll\r\nlib\\$(p)\\dynamic\\v8_libplatform.dll\r\nlib\\$(p)\\dynamic\\zlib1.dll"
        "// @视窗.预定义宏.non_static" = "USING_V8_SHARED, V8_USE_EXTERNAL_STARTUP_DATA" "// @视窗.需求VS版本.non_static" = "14-"
        "// @视窗.外部库.static" = "lib\\$(p)\\static\\$(d)\\icudt.lib\r\nlib\\$(p)\\static\\$(d)\\icuin.lib\r\nlib\\$(p)\\static\\$(d)\\icuio.lib\r\nlib\\$(p)\\static\\$(d)\\icutu.lib\r\nlib\\$(p)\\static\\$(d)\\icuuc.lib\r\nlib\\$(p)\\static\\$(d)\\v8_monolith.lib\r\nlib\\$(p)\\static\\$(d)\\zlib.lib\r\nDbghelp.lib"
        "// @视窗.需求VS版本.static" = "16-">

类 JS引擎类 <公开 注释 = "提供V8引擎的全局初始化以及一些全局方法">
{
    方法 初始化 <公开 静态 类型 = 逻辑型 注释 = "JS引擎全局初始化并设置默认使用的平台对象" @禁止流程检查 = 真>
    参数 平台 <类型 = JS平台类 注释 = "提供所欲使用的默认平台对象">
    {
        @ V8::InitializePlatform(@<平台>.data().GetPlatform());
        @ return V8::Initialize();
    }

    方法 取库版本信息 <公开 静态 类型 = 文本型 注释 = "取当前V8库版本号相关信息" @嵌入式方法 = "">
    {
        @ CVolString(v8::V8::GetVersion())
    }

    方法 执行脚本 <公开 静态 类型 = 文本型 注释 = "提供指定JS脚本内容,对其编译执行并返回执行后结果." 返回值注释 = "以文本形式返回脚本执行后所返回的内容,失败返回空文本.">
    参数 脚本内容 <类型 = 文本型 注释 = "提供所欲执行的脚本内容">
    {
        变量 运行空间 <类型 = JS隔离空间类>
        变量 运行环境 <类型 = JS环境类>
        运行空间.创建 ()
        运行环境.创建 (运行空间)
        变量 JS脚本 <类型 = JS脚本类>
        JS脚本 = 运行环境.编译脚本 (脚本内容)
        如果 (JS脚本.是否为空 ())
        {
            返回 ("")
        }
        返回 (JS脚本.执行 (运行环境).取文本值 (运行环境))
    }

    # @begin
    # <> <include>
    # static void @an<_sOnBeforeAppInit> ();
    # <> </include>
    # void @sn<current_class>::@an<_sOnBeforeAppInit>()
    # {
    # #if defined(USING_V8_SHARED) && defined(V8_USE_EXTERNAL_STARTUP_DATA)    //为动态编译?
    #     static CVolMem membuf;
    #     static StartupData snapshot_data;
    #     VERIFY(g_objVolApp.LoadResData (_ID_VOL_V8_BLOB, membuf));
    #     snapshot_data.data = (const char*)membuf.GetPtr();
    #     snapshot_data.raw_size = (int)membuf.GetSize();
    #     V8::SetSnapshotDataBlob(&snapshot_data);
    # #endif
    # }
    # @end
}

类 JS平台类 <公开 注释 = "表示JS的一个平台,本类实例负责管理线程池,调用栈以及事件队列等.">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8PlatformWrapper)

    方法 创建 <公开 注释 = "创建并初始化当前平台对象" @嵌入式方法 = "">
    参数 线程数 <类型 = 整数 注释 = "指定该平台中线程池的最大线程数,提供小于0表示使用单线程,提供0表示使用(CPU数量-1)个线程." @默认值 = 0>
    参数 空闲任务 <类型 = 逻辑型 注释 = "指定该平台是否启用空闲任务" @默认值 = 假>
    参数 堆栈输出到控制台 <类型 = 逻辑型 注释 = "如果当前程序为控制台应用,是否将堆栈信息转储于控制台中进行输出." @默认值 = 假>
    {
        @ @sn<this>.data().CreatePlatform(@<线程数>, @<空闲任务>, @<堆栈输出到控制台>)
    }

    方法 取工作线程数 <公开 类型 = 整数 注释 = "获取当前平台的工作线程数量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetPlatform()->NumberOfWorkerThreads()
    }
}

类 JS隔离空间类 <公开 注释 = "本类实例表示JS环境运行的隔离空间,不同的空间之间无法互相影响.">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8IsolateWrapper)
    # <> <include>
    # @sn<current_class>(Isolate::CreateParams& stParams):@sn<current_class>() { data().CreateIsolate(stParams); }
    # @sn<current_class>(Isolate* pIsolate):@sn<current_class>() { data().CreateIsolateWithoutWrapper(pIsolate); }
    # <> </include>
    # @end

    方法 创建 <公开 注释 = "初始化当前空间对象." 注释 = "注意:本方法须在引擎\"初始化\"成功后调用.">
    参数 栈限制 <类型 = 变整数 注释 = "提供所欲使用的VM堆栈的最大地址限制,提供0表示使用默认." @默认值 = 0>
    参数 代码区尺寸 <类型 = 变整数 注释 = "为生成的代码保留的虚拟内存量,提供0表示使用默认." @默认值 = 0>
    参数 老生代初始尺寸 <类型 = 变整数 注释 = "指定老生代的初始内存大小,提供0表示使用默认." @默认值 = 0>
    参数 老生代最大尺寸 <类型 = 变整数 注释 = "指定老生代可使用内存的最大尺寸,达到该限制时将会执行一系列垃圾回收动作,提供0表示使用默认." @默认值 = 0>
    参数 新生代初始尺寸 <类型 = 变整数 注释 = "指定新生代的初始内存大小,提供0表示使用默认." @默认值 = 0>
    参数 新生代最大尺寸 <类型 = 变整数 注释 = "指定新生代可使用内存的最大尺寸,该值将会影响垃圾回收的频率." @默认值 = 0>
    参数 允许原子等待 <类型 = 逻辑型 注释 = "指定是否允许执行原子等待." @默认值 = 真>
    参数 仅允许安全终止 <类型 = 逻辑型 注释 = "指定是否在没有有效的安全终止范围时,延迟终止动作." @默认值 = 假>
    {
        @ Isolate::CreateParams stParams;
        @ stParams.array_buffer_allocator = ArrayBuffer::Allocator::NewDefaultAllocator();
        @ stParams.constraints.set_stack_limit(@<栈限制> == 0 ? nullptr : (uint32_t*)@<栈限制>);
        @ stParams.constraints.set_code_range_size_in_bytes((size_t)@<代码区尺寸>);
        @ stParams.constraints.set_initial_old_generation_size_in_bytes((size_t)@<老生代初始尺寸>);
        @ stParams.constraints.set_max_old_generation_size_in_bytes((size_t)@<老生代最大尺寸>);
        @ stParams.constraints.set_initial_young_generation_size_in_bytes((size_t)@<新生代初始尺寸>);
        @ stParams.constraints.set_max_young_generation_size_in_bytes((size_t)@<新生代最大尺寸>);
        // @ stParams.code_event_handler = @sn<current_class>::OnJitEvent;
        @ stParams.allow_atomics_wait = @<允许原子等待>;
        @ stParams.only_terminate_in_safe_scope = @<仅允许安全终止>;
        @ this->data().CreateIsolate(stParams);
    }
}

类 JS环境类 <公开 注释 = "表示JS脚本的执行环境">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8ContextWrapper)
    # <> <include>
    # @sn<current_class>(const Local<Context>& context):@sn<current_class>() { data().CreateContext(context); }
    # inline_ Local<String> VolString2LocalU8 (CVolString& value)
    # {
    #     CU8String u8str(value.GetText());
    #     return String::NewFromUtf8(data().GetLocalContext()->GetIsolate(), u8str.GetText(), NewStringType::kNormal).ToLocalChecked();
    # }
    # <> </include>
    # @end

    方法 创建 <公开 注释 = "基于指定空间创建环境" @嵌入式方法 = "">
    参数 空间 <类型 = JS隔离空间类 注释 = "所提供的空间对象,必须已经执行过\"创建\".">
    {
        @ @sn<this>.data().CreateContext(@<空间>.data().GetIsolate())
    }

    方法 编译脚本 <公开 类型 = JS脚本类 注释 = "提供JS脚本内容,进行编译并执行." 注释 = "注意: 如果编译失败,所返回\"JS脚本类\"对象将为空(其\"是否为空\"方法返回真),此时不能执行该对象的其它方法."
            @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "提供所欲编译的JS脚本内容">
    {
        @ Local<Script> mScript;
        @ Script::Compile(data().GetLocalContext(), VolString2LocalU8(@<内容>)).ToLocal(&mScript);
        @ return @dt<JS脚本类>(mScript);
    }

    方法 取数据分配字段数 <公开 类型 = 整数 注释 = "返回为嵌入程序数据分配的字段数" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.data().GetLocalContext()->GetNumberOfEmbedderDataFields()
    }

    方法 取嵌入数据 <公开 类型 = JS结果类 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalContext()->GetEmbedderData(@<索引>))
    }

    方法 置嵌入数据 <公开 @嵌入式方法 = "">
    参数 索引 <类型 = 整数>
    参数 数据 <类型 = JS结果类>
    {
        @ @sn<this>.data().GetLocalContext()->SetEmbedderData(@<索引>, @<数据>.data().GetLocalValue())
    }

    方法 取保留嵌入数据 <公开 类型 = JS结果类 @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalContext()->GetContinuationPreservedEmbedderData())
    }

    方法 置保留嵌入数据 <公开 @嵌入式方法 = "">
    参数 数据 <类型 = JS结果类>
    {
        @ @sn<this>.data().GetLocalContext()->SetContinuationPreservedEmbedderData(@<数据>.data().GetLocalValue())
    }

    方法 取全局对象 <公开 类型 = JS对象类 注释 = "获取处于当前执行环境中的JS全局对象" @嵌入式方法 = "">
    {
        @ @dt<JS对象类>(@sn<this>.data().GetLocalContext()->Global())
    }

    方法 分离全局对象 <公开 类型 = JS对象类 注释 = "分离处于当前执行环境中的JS全局对象" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalContext()->DetachGlobal()
    }

    方法 取额外绑定对象 <公开 类型 = JS对象类 注释 = "获取额外绑定的JS对象" @嵌入式方法 = "">
    {
        @ @dt<JS对象类>(@sn<this>.data().GetLocalContext()->GetExtrasBindingObject())
    }
}

类 JS脚本类 <公开 注释 = "本类实例表示一个已编译完成的JS脚本." 注释 = "注意: 在执行本类中除了\"是否为空\"之外的其它方法前,请先确认本类对象不为空(\"是否为空\"方法返回假).">
{
    方法 是否为空 <公开 类型 = 逻辑型 注释 = "检查当前脚本是否有效可被执行" 返回值注释 = "有效返回真,否则返回假." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue().IsEmpty()
    }

    方法 执行 <公开 类型 = JS结果类 注释 = "开始执行当前脚本" 返回值注释 = "如果该脚本执行后有返回值,将返回的值置入该返回的对象中." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供执行当前脚本所欲使用的运行环境">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->Run(@<环境>.data().GetLocalContext()).ToLocalChecked())
    }

    方法 取ID <公开 类型 = 整数 注释 = "获取脚本ID" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->GetUnboundScript()->GetId()
    }

    方法 取脚本名称 <公开 类型 = JS结果类 注释 = "获取脚本名称" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetUnboundScript()->GetScriptName())
    }

    方法 取源地址 <公开 类型 = JS结果类 注释 = "获取脚本源地址" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetUnboundScript()->GetSourceURL())
    }

    方法 取源映射地址 <公开 类型 = JS结果类 注释 = "获取脚本源映射地址" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetUnboundScript()->GetSourceMappingURL())
    }

    方法 取代码所处行 <公开 类型 = 整数 注释 = "根据指定代码位置取出其所处行数." @嵌入式方法 = "">
    参数 代码位置 <类型 = 整数>
    {
        @ @sn<this>.data().GetLocalValue()->GetUnboundScript()->GetLineNumber()
    }

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Script>)
    # <> <include>
    # @sn<current_class>(Local<Script>& value):@sn<current_class>() { data().CreateValue(value); }
    # <> </include>
    # @end
    #
}

类 JS数据类 <公开 注释 = "本类用于表示JS中的一个数据">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Data>)
    # <> <include>
    # @sn<current_class>(Local<Data>& value):@sn<current_class>() { data().CreateValue(value); }
    # <> </include>
    # @end

    方法 是否为结果 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为结果对象(JS结果类)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsValue()
    }

    方法 是否为模块 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为结果对象(JS模块类)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsModule()
    }

    方法 是否为私有符号 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为私有符号(JS私有符号类)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsPrivate()
    }

    方法 是否为对象模板 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为对象模板." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsObjectTemplate()
    }

    方法 是否为函数模板 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为函数模板." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsFunctionTemplate()
    }

    方法 是否为环境 <公开 类型 = 逻辑型 注释 = "检查当前对象是否为环境对象(JS环境类)." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->IsContext()
    }

    方法 到环境 <公开 类型 = JS环境类 注释 = "将当前结果对象转换环境对象" @嵌入式方法 = "">
    {
        @ @dt<JS环境类>(@sn<this>.data().GetLocalValue().As<Context>())
    }

    方法 到结果 <公开 类型 = JS结果类 注释 = "将当前结果对象转换JS结果对象" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue().As<Value>())
    }

    方法 到私有符号 <公开 类型 = JS私有符号类 注释 = "将当前结果对象转换JS私有符号对象" @嵌入式方法 = "">
    {
        @ @dt<JS私有符号类>(@sn<this>.data().GetLocalValue().As<Private>())
    }
}

类 JS结果类 <公开 基础类 = JS数据类 注释 = "本类实例表示一个值对象">
{
    方法 创建空对象 <公开 静态 类型 = JS结果类 注释 = "创建一个空内容的当前本类实例." @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(Local<Value>())
    }

    方法 比较 <公开 类型 = 逻辑型 注释 = "将当前结果对象中的值与另一结果对象中的值做比较,即对应JS中的\"==\"运算符." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    参数 比较对象 <类型 = JS结果类 注释 = "提供欲与其进行对比的另一对象">
    {
        @ @sn<this>.data().GetLocalValue()->Equals(@<环境>.data().GetLocalContext(), @<比较对象>.data().GetLocalValue()).ToLocalChecked()->Value()
    }

    方法 严格比较 <公开 类型 = 逻辑型 注释 = "将当前结果对象中的值与另一结果对象中的值做严格对比" @嵌入式方法 = "">
    参数 比较对象 <类型 = JS结果类 注释 = "提供欲与其进行对比的另一对象">
    {
        @ @sn<this>.data().GetLocalValue()->StrictEquals(@<比较对象>.data().GetLocalValue())
    }

    方法 值比较 <公开 类型 = 逻辑型 注释 = "将当前结果对象中的值与另一结果对象中的值对比" @嵌入式方法 = "">
    参数 比较对象 <类型 = JS结果类 注释 = "提供欲与其进行对比的另一对象">
    {
        @ @sn<this>.data().GetLocalValue()->SameValue(@<比较对象>.data().GetLocalValue())
    }

    方法 取文本值 <公开 类型 = 文本型 注释 = "以文本形式取出值" @禁止流程检查 = 真>
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    {
        @ v8::String::Utf8Value utf8(@<环境>.data().GetLocalContext()->GetIsolate(), data().GetLocalValue());
        @ return CVolString(*utf8);
    }

    方法 取大整数值 <公开 类型 = 长整数 注释 = "以大整数形式取出值" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    {
        @ (INT64)@sn<this>.data().GetLocalValue()->ToBigInt(@<环境>.data().GetLocalContext()).ToLocalChecked()->Int64Value()
    }

    方法 取数值 <公开 类型 = 小数 注释 = "以数值形式取出值" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    {
        @ @sn<this>.data().GetLocalValue()->ToNumber(@<环境>.data().GetLocalContext()).ToLocalChecked()->Value()
    }

