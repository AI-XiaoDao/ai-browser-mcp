    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->CallAsFunction(@<环境>.data().GetLocalContext(), @<执行对象>.data().GetLocalValue(), 0, nullptr).ToLocalChecked())
    }

