类 JS文本类 <公开 基础类 = JS结果类 注释 = "本类实例表示一个文本对象" @文档 = "category = \"辅助类\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<String>)
    # <> <include>
    # @sn<current_class>(Local<String>& value):@sn<current_class>() { data().CreateValue(value); }
    # <> </include>
    # @end

    方法 创建 <公开 注释 = "根据指定文本内容创建一个JS文本对象" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    参数 内容 <类型 = 文本型 注释 = "提供所欲置入的文本内容">
    {
        @ @sn<this>.data().ReplaceValue(String::NewFromUtf8(@<环境>.data().GetLocalContext()->GetIsolate(), CU8String(@<内容>.GetText()).GetText()))
    }
}

