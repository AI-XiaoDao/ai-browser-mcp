    # <> </include>
    # @end

    方法 成员数 <公开 属性读 类型 = 变整数 注释 = "获取当前键值表中的成员数量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->Size()
    }

    方法 创建 <公开 注释 = "基于指定空间创建键值表对象" @嵌入式方法 = "">
    参数 空间 <类型 = JS隔离空间类>
    {
        @ @sn<this>.data().ReplaceValue(Map::New(@<空间>.data().GetIsolate()))
    }

    方法 清空 <公开 注释 = "清空当前键值表中所有内容" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->Clear()
    }

    方法 取值 <公开 类型 = JS结果类 注释 = "根据指定键名取出其对应的值" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 键对象 <类型 = JS结果类 注释 = "提供所欲取其对应值的键对象">
    {
        @ @sn<this>.data().GetLocalValue()->Get(@<环境>.data().GetLocalContext(), @<键对象>.data().GetLocalValue())
    }

    方法 置值 <公开 注释 = "置入一对键值" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 键对象 <类型 = JS结果类 注释 = "提供所欲置入的键对象">
    参数 值对象 <类型 = JS结果类 注释 = "提供所欲置入的值对象">
    {
        @ @sn<this>.data().GetLocalValue()->Set(@<环境>.data().GetLocalContext(), @<键对象>.data().GetLocalValue(), @<值对象>.data().GetLocalValue())
    }

    方法 是否存在值 <公开 类型 = 逻辑型 注释 = "检查指定键对象是否存在其对应的值" 返回值注释 = "存在则返回真,否则返回假." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 键对象 <类型 = JS结果类 注释 = "提供所欲检查的键对象">
    {
        @ @sn<this>.data().GetLocalValue()->Has(@<环境>.data().GetLocalContext(), @<键对象>.data().GetLocalValue()).ToChecked()
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "删除指定的一对键值" 返回值注释 = "删除成功则返回真,否则返回假." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 键对象 <类型 = JS结果类 注释 = "提供所欲删除的键对象">
    {
        @ @sn<this>.data().GetLocalValue()->Delete(@<环境>.data().GetLocalContext(), @<键对象>.data().GetLocalValue()).ToChecked()
    }

    方法 转为数组 <公开 类型 = JS数组类 注释 = "将当前键值表中的所有内容转换为一个数组装载并返回该数组" 注释 = "" 返回值注释 = "每个键以及值对象都会作为一个成员加入至该数组" @嵌入式方法 = "">
    {
        @ @dt<JS数组类>(@sn<this>.data().GetLocalValue()->AsArray())
    }
}

类 JS集合类 <公开 基础类 = JS对象类 注释 = "本类实例表示JS中的Set对象" @文档 = "category = \"辅助类\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Set>)
    # <> <include>
    # @sn<current_class>(Local<Set>& value):@sn<current_class>() { data().CreateValue(value); }
    # <> </include>
    # @end

    方法 成员数 <公开 属性读 类型 = 变整数 注释 = "获取当前集合中的成员数量" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->Size()
    }

    方法 创建 <公开 注释 = "基于指定空间创建集合对象" @嵌入式方法 = "">
    参数 空间 <类型 = JS隔离空间类>
    {
        @ @sn<this>.data().ReplaceValue(Set::New(@<空间>.data().GetIsolate()))
    }

    方法 清空 <公开 注释 = "清空当前集合中所有内容" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->Clear()
    }

    方法 加入 <公开 注释 = "加入一个新成员" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 成员 <类型 = JS结果类 注释 = "提供所欲加入的成员对象">
    {
        @ @sn<this>.data().GetLocalValue()->Add(@<环境>.data().GetLocalContext(), @<成员>.data().GetLocalValue())
    }

    方法 是否存在值 <公开 类型 = 逻辑型 注释 = "检查指定成员对象是否处于当前集合中" 返回值注释 = "存在则返回真,否则返回假." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 成员 <类型 = JS结果类 注释 = "提供所欲检查的成员对象">
    {
        @ @sn<this>.data().GetLocalValue()->Has(@<环境>.data().GetLocalContext(), @<成员>.data().GetLocalValue()).ToChecked()
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "删除指定的成员对象" 返回值注释 = "删除成功则返回真,否则返回假." @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS执行环境">
    参数 成员 <类型 = JS结果类 注释 = "提供所欲删除的成员对象">
    {
        @ @sn<this>.data().GetLocalValue()->Delete(@<环境>.data().GetLocalContext(), @<成员>.data().GetLocalValue()).ToChecked()
    }

    方法 转为数组 <公开 类型 = JS数组类 注释 = "将当前键值对中的所有内容转换为一个数组装载并返回该数组." 注释 = "" @嵌入式方法 = "">
    {
        @ @dt<JS数组类>(@sn<this>.data().GetLocalValue()->AsArray())
    }
}

类 JS函数类 <公开 基础类 = JS对象类 注释 = "本类实例表示JS中的函数(Function)." @文档 = "category = \"辅助类\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Function>)
    #
    # <> <include>
    # @sn<current_class>(Local<Function>& value):@sn<current_class>() { data().CreateValue(value); }
    # static void VolFunctionCallback(const FunctionCallbackInfo<Value>& info);
    # MaybeLocal<Value> Call(const TCHAR* szParamType, Local<Context> context, Local<Value> recv, ...);
    # MaybeLocal<Object> NewInstance(const TCHAR* szParamType, Local<Context> context, ...);
    # <> </include>
    # void @sn<current_class>::VolFunctionCallback(const FunctionCallbackInfo<Value>& info)
    # {
    #     ASSERT(!info.Data().IsEmpty());
    #     Local<External> data = info.Data().As<External>();
    #     @sn<current_class>* pThis = (@sn<current_class>*)data->Value();
    #     pThis->@n<JS函数类.函数被执行>(@dt<JS函数回调信息类>(info));
    # }
    # @end

    方法 置名称 <公开 注释 = "设置当前函数的函数名称" @嵌入式方法 = "">
    参数 函数名称 <类型 = JS文本类 注释 = "提供所欲设置的函数名称">
    {
        @ @sn<this>.data().GetLocalValue()->SetName(@<函数名称>.data().GetLocalValue())
    }

    方法 取名称 <公开 类型 = JS结果类 注释 = "获取当前函数的函数名称" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetName())
    }

    方法 取推断名称 <公开 类型 = JS结果类 注释 = "推断当前函数的函数名称" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetInferredName())
    }

    方法 取调试名称 <公开 类型 = JS结果类 注释 = "当前函数的调试函数名称" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetDebugName())
    }

    方法 函数被执行 <公开 定义事件 类型 = 整数 注释 = "当本函数被执行时将会发送本事件">
    参数 执行信息 <类型 = JS函数回调信息类>

    方法 创建 <公开 注释 = "基于指定执行环境创建当前函数对象,当函数被执行时将会响应事件\"函数被执行\"." 编辑时信息 = "5443F, 0, 0, 0">
    参数 环境 <类型 = JS环境类 注释 = "提供当前执行JS的环境" 编辑时信息 = "5443F, 0, 0, 0">
    参数 长度 <类型 = 整数 注释 = "提供所欲使用的长度" 编辑时信息 = "5443F, 0, 0, 0" @默认值 = 0>
    参数 允许构造 <类型 = 逻辑型 注释 = "指定该函数是否允许为构造函数" 编辑时信息 = "5443F, 0, 0, 0" @默认值 = 真>
    参数 副作用类型 <类型 = JS副作用类型 注释 = "指定该函数的副作用类型" 编辑时信息 = "5443F, 0, 0, 0" @默认值 = JS副作用类型.启用>
    {
        @ Local<External> pData = External::New(@<环境>.data().GetLocalContext()->GetIsolate(), this);
        @ data().ReplaceValue(Function::New(@<环境>.data().GetLocalContext(), VolFunctionCallback, pData, @<长度>, @<允许构造> ? ConstructorBehavior::kAllow : ConstructorBehavior::kThrow, @<副作用类型> == 0 ? SideEffectType::kHasSideEffect : (@<副作用类型> == 1 ? SideEffectType::kHasNoSideEffect : SideEffectType::kHasSideEffectToReceiver)));
    }

    方法 执行 <公开 类型 = JS结果类 注释 = "执行当前函数并返回执行结果" 返回值注释 = "返回函数执行后的结果" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前执行JS的环境">
    参数 执行对象 <类型 = JS结果类 注释 = "提供本方法所处的实例对象,即所欲执行本函数的指定对象.">
    参数 参数 <注释 = "提供调用该构造函数所需的参数列表" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().Call(_T (@sn<pm_types>), @<环境>.data().GetLocalContext(), @<执行对象>.data().GetLocalValue(), @<参数>).ToLocalChecked())
    }

    方法 执行无参方法 <公开 类型 = JS结果类 注释 = "执行当前函数并返回执行结果" 返回值注释 = "返回函数执行后的结果" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前执行JS的环境">
    参数 执行对象 <类型 = JS结果类 注释 = "提供本方法所处的实例对象,即所欲执行本函数的指定对象.">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->Call(@<环境>.data().GetLocalContext(), @<执行对象>.data().GetLocalValue(), 0, nullptr).ToLocalChecked())
    }

    方法 新建实例 <公开 类型 = JS对象类 注释 = "提供指定的参数以新建指定函数实例" 返回值注释 = "返回所新建的实例对象" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前执行JS的环境">
    参数 参数 <注释 = "提供新建实例函数所需的参数列表" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ @dt<JS对象类>(@sn<this>.data().NewInstance(_T (@sn<pm_types>), @<环境>.data().GetLocalContext(), @<参数>).ToLocalChecked())
    }

    方法 新建实例无参 <公开 类型 = JS对象类 注释 = "与\"新建实例\"方法一致,本方法不需要提供参数以新建指定函数实例." 返回值注释 = "返回所新建的实例对象" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前执行JS的环境">
    {
        @ @dt<JS对象类>(@sn<this>.data().GetLocalValue()->NewInstance(@<环境>.data().GetLocalContext()).ToLocalChecked())
    }

    方法 取所处代码行号 <公开 类型 = 整数 注释 = "获取该函数处于脚本中的代码行号" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->GetScriptLineNumber()
    }

    方法 取所处代码列号 <公开 类型 = 整数 注释 = "获取该函数处于脚本中的代码列号" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->GetScriptColumnNumber()
    }

    方法 取所处脚本ID <公开 类型 = 整数 注释 = "获取该函数处于脚本的ID" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetLocalValue()->ScriptId()
    }

    方法 取已绑定函数 <公开 类型 = JS结果类 注释 = "如果当前函数已绑定则返回原始函数,否则返回未定义值." @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->GetBoundFunction())
    }

    方法 到序列化文本 <公开 类型 = JS文本类 注释 = "将当前函数对象序列化到文本" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类>
    {
        @ @dt<JS文本类>(@sn<this>.data().GetLocalValue()->FunctionProtoToString(@<环境>.data().GetLocalContext()).ToLocalChecked())
    }
}

类 JS函数回调信息类 <公开 注释 = "本类实例表示JS中的函数执行回调的结果信息" @文档 = "category = \"辅助类\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WithOutLocalWrapperTemplate<FunctionCallbackInfo<Value>>)
    # <> <include>
    # @sn<current_class>(const FunctionCallbackInfo<Value>& info):@sn<current_class>() { data().CreateObject(info); }
    # <> </include>
    # @end

    方法 取参数数量 <公开 类型 = 整数 注释 = "取出在调用时所使用的参数个数" @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetObject().Length()
    }

    方法 取指定参数 <公开 类型 = JS结果类 注释 = "取出在调用时所使用的参数对象" 返回值注释 = "如果提供的索引越界,将返回一个未定义内容的值." @嵌入式方法 = "">
    参数 索引 <类型 = 整数 注释 = "提供所欲获取参数的索引位置">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetObject()[@<索引>])
    }

    方法 取当前本对象 <公开 类型 = JS对象类 注释 = "返回接收器,相当于this." @嵌入式方法 = "">
    {
        @ @dt<JS对象类>(@sn<this>.data().GetObject().This())
    }

    方法 取持有对象 <公开 类型 = JS对象类 注释 = "返回持有对象,即Holder." @嵌入式方法 = "">
    {
        @ @dt<JS对象类>(@sn<this>.data().GetObject().Holder())
    }

    方法 取新目标值 <公开 类型 = JS结果类 @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetObject().NewTarget())
    }

    方法 是否为构造调用 <公开 类型 = 逻辑型 注释 = "返回本次调用是否为构造调用" 返回值注释 = "返回真表示为构造调用,否则为常规调用." @嵌入式方法 = "">
    {
        @ @sn<this>.data().GetObject().IsConstructCall()
    }

    方法 取返回值 <公开 类型 = JS返回值类 注释 = "获取该函数的返回值" @嵌入式方法 = "">
    {
        @ @dt<JS返回值类>(@sn<this>.data().GetObject().GetReturnValue())
    }
}

类 JS私有符号类 <公开 基础类 = JS数据类 注释 = "本类实例表示JS中的私有符号(Private)." @文档 = "category = \"辅助类\"">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Private>)
    # <> <include>
    # @sn<current_class>(Local<Private>& value):@sn<current_class>() { data().CreateValue(value); }
    # <> </include>
    # @end

    方法 取名称 <公开 类型 = JS结果类 注释 = "获取该符号的名称" @嵌入式方法 = "">
    {
        @ @dt<JS结果类>(@sn<this>.data().GetLocalValue()->Name())
    }

    方法 创建 <公开 注释 = "创建一个私有符号对象" @嵌入式方法 = "">
    参数 空间 <类型 = JS隔离空间类 注释 = "提供该私有符号所处空间">
    参数 名称 <类型 = JS文本类 注释 = "提供该私有符号的名称">
    {
        @ @sn<this>.data().Create(Private::New(@<空间>.data().GetIsolate(), @<名称>.data().GetLocalValue()))
    }
}

