    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Value>)
    # <> <include>
    # @sn<current_class>(Local<Value>& value):@sn<current_class>() { data().CreateValue(value); }
    # //virtual Local<Value>& GetLocalValue() { return data().GetLocalValue(); }
    # <> </include>
    # @end
}

类 JS对象类 <公开 基础类 = JS结果类 注释 = "本类实例表示一个JS中的任意对象,通过键值对方式取/置任意值.">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CV8WrapperTemplate<Object>)
    #
    # @def_macro DECLARE_V8_GET_ACCESSOR_CALLBACK(event_name)  \
    #     ASSERT(!info.Data().IsEmpty());                       \
    #     Local<External> data = info.Data().As<External>();    \
    #     @sn<current_class>* pThis = (@sn<current_class>*)data->Value();    \
    #     pThis->@n<JS对象类.event_name>(@dt<JS文本类>(property.As<String>()), @dt<JS返回值类>(info.GetReturnValue()), info.ShouldThrowOnError());
    #
    # @def_macro DECLARE_V8_SET_ACCESSOR_CALLBACK(event_name)  \
    #     ASSERT(!info.Data().IsEmpty());                      \
    #     Local<External> data = info.Data().As<External>();   \
    #     @sn<current_class>* pThis = (@sn<current_class>*)data->Value();    \
    #     pThis->@n<JS对象类.event_name>(@dt<JS文本类>(property.As<String>()), @dt<JS结果类>(value), info.ShouldThrowOnError());
    #
    # <> <include>
    # //@ #ifdef _VOL_X64    //指针数据类型
    # //@ #define V8_INT_P BigInt
    # //@ #else
    # //@ #define V8_INT_P Integer
    # //@ #endif
    # @sn<current_class>(Local<Object>& value):@sn<current_class>() { data().CreateValue(value); }
    # static void CallbackSetAccessorNameGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info);
    # static void CallbackSetAccessorNameSetter(Local<Name> property, Local<Value> value, const PropertyCallbackInfo<void>& info);
    # static void CallbackSetNativeDataPropertyGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info);
    # static void CallbackSetNativeDataPropertySetter(Local<Name> property, Local<Value> value, const PropertyCallbackInfo<void>& info);
    # static void CallbackSetLazyDataPropertyGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info);
    # <> </include>
    #
    # void @sn<current_class>::CallbackSetAccessorNameGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info)
    # {
    #     @m<DECLARE_V8_GET_ACCESSOR_CALLBACK>(属性读方法回调)
    # }
    # void @sn<current_class>::CallbackSetAccessorNameSetter(Local<Name> property, Local<Value> value, const PropertyCallbackInfo<void>& info)
    # {
    #     @m<DECLARE_V8_SET_ACCESSOR_CALLBACK>(属性写方法回调)
    # }
    # void @sn<current_class>::CallbackSetNativeDataPropertyGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info)
    # {
    #     @m<DECLARE_V8_GET_ACCESSOR_CALLBACK>(本地数据属性读方法回调)
    # }
    # void @sn<current_class>::CallbackSetNativeDataPropertySetter(Local<Name> property, Local<Value> value, const PropertyCallbackInfo<void>& info)
    # {
    #     @m<DECLARE_V8_SET_ACCESSOR_CALLBACK>(本地数据属性写方法回调)
    # }
    # void @sn<current_class>::CallbackSetLazyDataPropertyGetter(Local<Name> property, const PropertyCallbackInfo<Value>& info)
    # {
    #     @m<DECLARE_V8_GET_ACCESSOR_CALLBACK>(懒数据属性读方法回调)
    # }
    # @end

    方法 创建新对象 <公开 注释 = "基于指定空间中创建对象" @嵌入式方法 = "">
    参数 空间 <类型 = JS隔离空间类>
    {
        @ @sn<this>.data().CreateValue(Object::New(@<空间>.data().GetIsolate()))
    }

    方法 置结果值 <公开 类型 = 逻辑型 注释 = "置入指定值." 返回值注释 = "返回执行是否成功" @嵌入式方法 = "">
    参数 环境 <类型 = JS环境类 注释 = "提供当前所使用的JS环境对象">
    参数 键对象 <类型 = JS结果类 注释 = "提供所欲置入值对应的键对象">
    参数 值对象 <类型 = JS结果类 注释 = "提供所欲置入值对应的值对象">
    {
        @ @sn<this>.data().GetLocalValue()->Set(@<环境>.data().GetLocalContext(), @<键对象>.data().GetLocalValue(), @<值对象>.data().GetLocalValue()).ToChecked()
    }

