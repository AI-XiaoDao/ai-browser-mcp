        @ @sn<this>.data().GetLocalValue()->SetAccessorProperty(@<名称>.data().GetLocalValue(), @<读属性>.data().GetLocalValue(), @<写属性>.data().GetLocalValue(), (PropertyAttribute)@<属性类型>, (AccessControl)@<访问控制>)
