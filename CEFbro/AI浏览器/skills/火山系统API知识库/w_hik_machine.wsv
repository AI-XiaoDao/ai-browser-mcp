    方法 翻转图像数据2 <公开 类型 = 整数 注释 = "同\"翻转图像数据\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 垂直翻转 <类型 = 逻辑型 注释 = "提供真表示垂直翻转,否则水平翻转.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        @ MV_CC_FLIP_IMAGE_PARAM stFlipParam;
        @ memset(&stFlipParam, 0, sizeof(MV_CC_FLIP_IMAGE_PARAM));
        @ stFlipParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stFlipParam.nWidth = (UINT)@<图像宽度>;
        @ stFlipParam.nHeight = (UINT)@<图像高度>;
        @ stFlipParam.pSrcData = (unsigned char*)@<数据指针>;
        @ stFlipParam.nSrcDataLen = (UINT)@<数据长度>;
        @ stFlipParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stFlipParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stFlipParam.enFlipType = @<垂直翻转> ? MV_IMG_FLIP_TYPE::MV_FLIP_VERTICAL : MV_IMG_FLIP_TYPE::MV_FLIP_HORIZONTAL;
        @ INT ret = MV_CC_FlipImage(this->data().GetDeviceHandle(), &stFlipParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stFlipParam.nDstBufLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 转换图像像素格式 <公开 类型 = 整数 注释 = "将指定图像数据的像素格式转换到指定格式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
