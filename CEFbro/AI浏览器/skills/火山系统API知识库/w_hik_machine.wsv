    参数 图像ROI <类型 = 矩形类 注释 = "提供图像区域数据,如果提供空对象则会进行全图噪声估计.">
    参数 噪声阀值 <类型 = 整数 注释 = "提供噪声阈值,范围:[0-4095].">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        返回 (图像噪声估计2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 图像宽度, 图像高度, 像素格式, 图像ROI, 噪声阀值, 输出数据))
    }

    方法 图像噪声估计2 <公开 类型 = 整数 注释 = "同\"图像噪声估计\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 图像ROI <类型 = 矩形类 注释 = "提供图像区域数据,如果提供空对象则会进行全图噪声估计.">
    参数 噪声阀值 <类型 = 整数 注释 = "提供噪声阈值,范围:[0-4095].">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放噪声特性的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    {
        @ MV_CC_NOISE_ESTIMATE_PARAM stNoiseEstimateParam = {0};
        @ stNoiseEstimateParam.nWidth = (UINT)@<图像宽度>;
        @ stNoiseEstimateParam.nHeight = (UINT)@<图像高度>;
        @ stNoiseEstimateParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stNoiseEstimateParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stNoiseEstimateParam.nSrcBufLen = (UINT)@<数据长度>;
        @ MV_CC_RECT_I rect;
        @ rect.nX = (UINT)@<图像ROI.左边>;
        @ rect.nY = (UINT)@<图像ROI.顶边>;
        @ rect.nWidth = (UINT)@<图像ROI.宽度>();
        @ rect.nHeight = (UINT)@<图像ROI.高度>();
        @ stNoiseEstimateParam.pNoiseProfile = (unsigned char*)@<输出数据>.GetPtr();
        @ stNoiseEstimateParam.nNoiseProfileSize = (UINT)@<输出数据>.GetSize();
        @ stNoiseEstimateParam.nNoiseThreshold = (UINT)@<噪声阀值>;
        @ stNoiseEstimateParam.pstROIRect = @<图像ROI>.IsNullObject() ? NULL : &rect;
        @ stNoiseEstimateParam.nROINum = @<图像ROI>.IsNullObject() ? 0 : 1;
        @ INT ret = MV_CC_NoiseEstimate (this->data().GetDeviceHandle(), &stNoiseEstimateParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stNoiseEstimateParam.nNoiseProfileLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

