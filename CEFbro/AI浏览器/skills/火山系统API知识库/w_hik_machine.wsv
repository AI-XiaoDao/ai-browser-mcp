        @ MV_CC_SetBayerCvtQuality(@sn<this>.data().GetDeviceHandle(), (UINT)@<插值方法>)
    }

    方法 置Bayer伽马值 <公开 类型 = 整数 注释 = "设置Bayer格式的Gamma值." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 伽马值 <类型 = 小数 注释 = "提供所欲使用的Gamma值,范围:[0.1,4.0]">
    {
        @ MV_CC_SetBayerGammaValue(@sn<this>.data().GetDeviceHandle(), (FLOAT)@<伽马值>)
    }

    方法 置Bayer伽马信息 <公开 类型 = 整数 注释 = "设置Bayer格式的Gamma信息." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 类型 <类型 = 图像Bayer伽马类型 注释 = "提供所欲指定的类型.">
    参数 伽马值 <类型 = 小数 注释 = "提供所欲使用的Gamma值,范围:[0.1,4.0]">
    参数 曲线缓存 <类型 = 字节集类 注释 = "提供所欲使用的Gamma曲线缓存数据.">
    {
        @ MV_CC_GAMMA_PARAM stGammaParam;
        @ memset(&stGammaParam, 0, sizeof(MV_CC_GAMMA_PARAM));
        @ stGammaParam.enGammaType = (MV_CC_GAMMA_TYPE)@<类型>;
        @ stGammaParam.fGammaValue = (FLOAT)@<伽马值>;
        @ stGammaParam.pGammaCurveBuf = (unsigned char*)@<曲线缓存>.GetPtr();
        @ stGammaParam.nGammaCurveBufLen = (UINT)@<曲线缓存>.GetSize();
        @ return MV_CC_SetBayerGammaParam(this->data().GetDeviceHandle(), &stGammaParam);
    }

    方法 置BayerCCM参数 <公开 类型 = 整数 注释 = "设置Bayer格式的CCM使能和矩阵,量化系数默认1024." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 启用 <类型 = 逻辑型 注释 = "是否启用CCM.">
    参数 矩阵数据 <类型 = 整数数组类 注释 = "提供CCM矩阵数据,最多可提供9个成员.">
    参数 量化系数 <类型 = 整数 注释 = "提供所欲使用的量化系数,必须是2的整数幂,最大值65536." @默认值 = 1024>
    {
        @ MV_CC_CCM_PARAM_EX stCCMParam = {0};
        @ stCCMParam.bCCMEnable = @<启用>;
        @ COPY_MEM (&stCCMParam.nCCMat[0], @<矩阵数据>.data ().GetData (), 9 * sizeof (INT));
        @ stCCMParam.nCCMScale = (UINT)@<量化系数>;
        @ return MV_CC_SetBayerCCMParamEx(this->data().GetDeviceHandle(), &stCCMParam);
    }

    方法 置BayerCLUT参数 <公开 类型 = 整数 注释 = "设置Bayer格式的CLUT使能和信息." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 启用 <类型 = 逻辑型 注释 = "是否启用CLUT.">
    参数 CLUT尺寸 <类型 = 整数 注释 = "指定CLUT尺寸,范围:[17-33].">
    参数 量化CLUT表 <类型 = 字节集类>
    参数 量化系数 <类型 = 整数 注释 = "提供所欲使用的量化系数,必须是2的整数幂,最大值65536." @默认值 = 1024>
    {
        @ MV_CC_CLUT_PARAM stCLUTParam = {0};
        @ stCLUTParam.bCLUTEnable = @<启用>;
        @ stCLUTParam.nCLUTScale = (UINT)@<量化系数>;
        @ stCLUTParam.nCLUTSize = (UINT)@<CLUT尺寸>;
        @ stCLUTParam.pCLUTBuf = (unsigned char*)@<量化CLUT表>.GetPtr();
        @ stCLUTParam.nCLUTBufLen = (UINT)@<量化CLUT表>.GetSize();
        @ return MV_CC_SetBayerCLUTParam(this->data().GetDeviceHandle(), &stCLUTParam);
    }

    方法 调整图像对比度 <公开 类型 = 整数 注释 = "将指定图像数据的对比度调整后返回,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
