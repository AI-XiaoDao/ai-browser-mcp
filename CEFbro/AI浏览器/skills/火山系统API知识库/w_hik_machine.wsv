    }

    方法 调整图像色彩校正2 <公开 类型 = 整数 注释 = "同\"调整图像色彩校正\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 有效图像位 <类型 = 整数 注释 = "提供有效图像位数(8,10,12,16).">
    参数 伽马类型 <类型 = 图像Bayer伽马类型 注释 = "提供所欲指定的类型.">
    参数 伽马值 <类型 = 小数 注释 = "提供所欲使用的Gamma值,范围:[0.1,4.0]">
    参数 伽马曲线缓存 <类型 = 字节集类 注释 = "提供所欲使用的Gamma曲线缓存数据.">
    参数 CCM启用 <类型 = 逻辑型 注释 = "是否启用CCM.">
    参数 CCM矩阵数据 <类型 = 整数数组类 注释 = "提供矩阵数据,最多可提供9个成员.">
    参数 CCM量化系数 <类型 = 整数 注释 = "提供所欲使用的CCM量化系数,必须是2的整数幂,最大值65536.">
    参数 CLUT启用 <类型 = 逻辑型 注释 = "是否启用CLUT.">
    参数 CLUT尺寸 <类型 = 整数 注释 = "指定CLUT尺寸,范围:[17-33].">
    参数 CLUT量化表 <类型 = 字节集类 注释 = "提供量化CLUT表数据.">
    参数 CLUT量化系数 <类型 = 整数 注释 = "提供所欲使用的CLUT量化系数,必须是2的整数幂,最大值65536.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        @ MV_CC_COLOR_CORRECT_PARAM stColorCorrectParam = {0};
        @ stColorCorrectParam.nWidth = (UINT)@<图像宽度>;
        @ stColorCorrectParam.nHeight = (UINT)@<图像高度>;
        @ stColorCorrectParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stColorCorrectParam.nSrcBufLen = (UINT)@<数据长度>;
        @ stColorCorrectParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stColorCorrectParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stColorCorrectParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stColorCorrectParam.nImageBit = (UINT)@<有效图像位>;

        @ stColorCorrectParam.stGammaParam.enGammaType = (MV_CC_GAMMA_TYPE)@<伽马类型>;
        @ stColorCorrectParam.stGammaParam.fGammaValue = (FLOAT)@<伽马值>;
        @ stColorCorrectParam.stGammaParam.pGammaCurveBuf = (unsigned char*)@<伽马曲线缓存>.GetPtr();
        @ stColorCorrectParam.stGammaParam.nGammaCurveBufLen = (UINT)@<伽马曲线缓存>.GetSize();

        @ stColorCorrectParam.stCCMParam.bCCMEnable = @<CCM启用>;
        @ COPY_MEM (&stColorCorrectParam.stCCMParam.nCCMat[0], @<CCM矩阵数据>.data ().GetData (), 9 * sizeof (INT));
        @ stColorCorrectParam.stCCMParam.nCCMScale = (UINT)@<CCM量化系数>;

        @ stColorCorrectParam.stCLUTParam.bCLUTEnable = @<CLUT启用>;
        @ stColorCorrectParam.stCLUTParam.nCLUTScale = (UINT)@<CLUT量化系数>;
        @ stColorCorrectParam.stCLUTParam.nCLUTSize = (UINT)@<CLUT尺寸>;
        @ stColorCorrectParam.stCLUTParam.pCLUTBuf = (unsigned char*)@<CLUT量化表>.GetPtr();
        @ stColorCorrectParam.stCLUTParam.nCLUTBufLen = (UINT)@<CLUT量化表>.GetSize();

        @ INT ret = MV_CC_ColorCorrect (this->data().GetDeviceHandle(), &stColorCorrectParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stColorCorrectParam.nDstBufLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 图像噪声估计 <公开 类型 = 整数 注释 = "对指定图像数据进行噪声估计,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
