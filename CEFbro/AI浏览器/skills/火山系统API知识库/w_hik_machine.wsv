<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.海康威视 <编辑时信息 = "215534, 0, 0, 0" @视窗.头文件搜寻目录 = "lib\\include" @视窗.外部头文件 = "src\\vol_hik_machine.h"
        @视窗.外部库 = "lib\\$(p)\\MvCameraControl.lib">

类 工业相机类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "海康工业相机SDK V3.4.0" 注释 = "使用前确保系统已安装对应环境(MVS驱动以及动态链接库环境变量)."
        注释 = "官方网站:https://www.hikrobotics.com/"
        注释 = "运行时软件环境下载(MSV):https://www.hikrobotics.com/machinevision/service/download?module=0" 编辑时信息 = "7BBB4, 0, 0, 0"
        @禁止创建对象 = 真>
{
    方法 取库版本号 <公开 静态 类型 = 整数 注释 = "获取SDK版本号." 返回值注释 = "4个字节分别对应主版本号,子版本号,修正版本号,测试." @嵌入式方法 = "">
    {
        @ MV_CC_GetSDKVersion()
    }

    方法 取支持传输协议层 <公开 静态 类型 = 整数 注释 = "获取支持的传输层,包含Gige和U3V传输层,Gige代表支持GigeVision协议的工业相机,U3V代表支持U3V协议的工业相机." 返回值注释 = "返回支持的传输层编号."
            @嵌入式方法 = "">
    {
        @ MV_CC_EnumerateTls()
    }

    方法 取所有设备信息 <公开 静态 类型 = 整数 注释 = "枚举获取指定类型的设备列表." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 传输层 <类型 = 整数 注释 = "提供所欲枚举的指定设备类型,请参考\"相机传输层协议类型\"所提供的常量,本参数支持位或多选.">
    参数 信息列表 <类型 = 相机设备信息数组类 注释 = "如果获取成功,获取的设备信息列表结果将写入至该变量.">
    {
        @ MV_CC_DEVICE_INFO_LIST m_stDevList;    //sdk内部分配, 随时可能被释放, 值复制到火山对象.
        @ memset(&m_stDevList, 0, sizeof(MV_CC_DEVICE_INFO_LIST));
        @ INT ret = MV_CC_EnumDevices(@<传输层>, &m_stDevList);
        @ if (ret == MV_OK)
        @ {
        @     TRACE0((INT)m_stDevList.nDeviceNum);
        @     @<信息列表>.RemoveAll();    //避免携带成员越界.
        @     @<信息列表>.AddNewObjects(@dt<相机设备信息类>::sGetRuntimeClass(), 0, m_stDevList.nDeviceNum);
        @     for (INT i = 0; i < (INT)@<信息列表>.GetCount(); i++)
        @         ((@dt<相机设备信息类>&)@<信息列表>.GetAt(i)).SetInfo(m_stDevList.pDeviceInfo[i]);
        @ }
        @ return ret;
    }

    方法 取接口信息列表 <公开 静态 类型 = 整数 注释 = "通过GenTL枚举接口信息列表." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 文件路径 <类型 = 文本型 注释 = "提供所欲使用的GenTL的cti文件路径.">
    参数 信息列表 <类型 = 接口信息数组类 注释 = "如果获取成功,获取的接口信息列表结果将写入至该变量.">
    {
        @ MV_GENTL_IF_INFO_LIST m_stIFList;    //sdk内部分配, 随时可能被释放, 值复制到火山对象.
        @ memset(&m_stIFList, 0, sizeof(MV_GENTL_IF_INFO_LIST));
        @ INT ret = MV_CC_EnumInterfacesByGenTL(&m_stIFList, (const char*)GetMbsText(@<文件路径>.GetText(), CVolMem(), NULL));
        @ if (ret == MV_OK)
        @ {
        @     @<信息列表>.RemoveAll();    //避免携带成员越界.
        @     @<信息列表>.AddNewObjects(@dt<接口信息类>::sGetRuntimeClass(), 0, m_stIFList.nInterfaceNum);
        @     for (INT i = 0; i < (INT)@<信息列表>.GetCount(); i++)
        @         ((@dt<接口信息类>&)@<信息列表>.GetAt(i)).SetInfo(m_stIFList.pIFInfo[i]);
        @ }
        @ return ret;
    }

    方法 取指定接口设备信息 <公开 静态 类型 = 整数 注释 = "通过指定的通过GenTL Interface枚举所有设备列表." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 接口信息 <类型 = 接口信息类 注释 = "提供指定的接口信息对象.">
    参数 信息列表 <类型 = GENTL设备信息数组类 注释 = "如果获取成功,获取的设备信息列表结果将写入至该变量.">
    {
        @ MV_GENTL_DEV_INFO_LIST m_stDevList;
        @ memset(&m_stDevList, 0, sizeof(MV_GENTL_DEV_INFO_LIST));
        @ INT ret = MV_CC_EnumDevicesByGenTL(@<接口信息>.data().GetInterfaceInfo(), &m_stDevList);
        @ if (ret == MV_OK)
        @ {
        @     @<信息列表>.RemoveAll();
        @     @<信息列表>.AddNewObjects(@dt<GENTL设备信息类>::sGetRuntimeClass(), 0, m_stDevList.nDeviceNum);
        @     for (INT i = 0; i < (INT)@<信息列表>.GetCount(); i++)
        @         ((@dt<GENTL设备信息类>&)@<信息列表>.GetAt(i)).SetInfo(m_stDevList.pDeviceInfo[i]);
        @ }
        @ return ret;
    }

    方法 取指定设备可访问权限 <公开 静态 类型 = 逻辑型 注释 = "读取设备CCP寄存器的值,判断当前状态是否具有指定类型的访问权限." 返回值注释 = "可用返回真,否则返回假." @嵌入式方法 = "">
    参数 设备 <类型 = 相机设备信息类 注释 = "提供所欲检查的设备.">
    参数 检查类型 <类型 = 相机访问权限类型 注释 = "提供所欲检查该设备的权限类型.">
    {
        @ MV_CC_IsDeviceAccessible(@<设备>.data().GetDeviceInfo(), (UINT)@<检查类型>)
    }

    方法 置日志储存路径 <公开 静态 类型 = 整数 注释 = "设置SDK输出的日志保存路径." 返回值注释 = "返回设置是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 路径 <类型 = 文本型 注释 = "提供所欲指定的日志储存路径.">
    {
        @ MV_CC_SetSDKLogPath((const char*)GetMbsText(@<路径>.GetText(), CVolMem(), NULL))
    }

    方法 创建设备 <公开 静态 类型 = 相机设备类 注释 = "根据指定的设备信息创建相机设备对象." 返回值注释 = "返回所创建的相机设备对象." @禁止流程检查 = 真>
    参数 设备信息 <类型 = 相机设备信息类 注释 = "提供所欲创建设备的信息对象.">
    参数 启用日志 <类型 = 逻辑型 注释 = "指定所打开的相机设备对象是否生成其操作日志." @默认值 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次创建设备的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ void* handle = NULL;
        @ INT ret = @<启用日志> ? MV_CC_CreateHandle(&handle, @<设备信息>.data().GetDeviceInfo()) : MV_CC_CreateHandleWithoutLog(&handle, @<设备信息>.data().GetDeviceInfo());
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机设备类>(handle);
    }

    方法 创建接口设备 <公开 静态 类型 = 相机设备类 注释 = "根据指定的接口设备信息创建相机设备对象." 返回值注释 = "返回所创建的相机设备对象." @禁止流程检查 = 真>
    参数 设备信息 <类型 = GENTL设备信息类 注释 = "提供所欲创建GENTL接口设备的信息对象.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次创建设备的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ void* handle = NULL;
        @ INT ret = MV_CC_CreateHandleByGenTL(&handle, @<设备信息>.data().GetGenTLDevInfo());
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机设备类>(handle);
    }

    方法 发送动作命令 <公开 静态 类型 = 相机动作命令结果数组类 注释 = "对当前相机设备发出动作命令,仅GIGE设备可用." 返回值注释 = "返回执行动作命令后的结果." @禁止流程检查 = 真>
    参数 设备密钥 <类型 = 整数 注释 = "设备密钥.">
    参数 组键 <类型 = 整数>
    参数 组掩码 <类型 = 整数>
    参数 广播包地址 <类型 = 文本型>
    参数 启用动作时间 <类型 = 逻辑型 注释 = "指定是否启用动作时间." @默认值 = 假>
    参数 动作时间 <类型 = 长整数 注释 = "预定的动作时间,和设备主频有关,仅在\"启用动作时间\"为真时本参数才有意义." @默认值 = 0>
    参数 ACK超时 <类型 = 整数 注释 = "等待ACK的超时时间,如果为0表示不需要ACK." @默认值 = 0>
    参数 启用指定网卡 <类型 = 逻辑型 注释 = "指定是否启用指定网卡." @默认值 = 假>
    参数 指定网卡IP <类型 = 整数 注释 = "指定的网卡IP,仅在\"启用指定网卡\"为真时本参数才有意义." @默认值 = 0>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_ACTION_CMD_INFO stActionCmdInfo = {0};
        @ MV_ACTION_CMD_RESULT_LIST stActionCmdResults = {0};
        @ CVolMem memBuf;
        @ stActionCmdInfo.nDeviceKey = (UINT)@<设备密钥>;
        @ stActionCmdInfo.nGroupKey = (UINT)@<组键>;
        @ stActionCmdInfo.nGroupMask = (UINT)@<组掩码>;
        @ stActionCmdInfo.bActionTimeEnable = (UINT)@<启用动作时间>;
        @ stActionCmdInfo.nActionTime = (int64_t)@<动作时间>;
        @ stActionCmdInfo.pBroadcastAddress = (const char*)GetMbsText(@<广播包地址>.GetText(), memBuf, NULL);
        @ stActionCmdInfo.nTimeOut = (UINT)@<启用动作时间>;
        @ stActionCmdInfo.bSpecialNetEnable = (UINT)@<启用指定网卡>;
        @ stActionCmdInfo.nSpecialNetIP = (UINT)@<指定网卡IP>;
        @ INT ret = MV_GIGE_IssueActionCommand(&stActionCmdInfo, &stActionCmdResults);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ @dt<相机动作命令结果数组类> results;
        @ if (ret == MV_OK && stActionCmdResults.nNumResults > 0)
        @ {
        @     results.AddNewObjects(@dt<相机动作命令结果类>::sGetRuntimeClass(), 0, stActionCmdResults.nNumResults);
        @     for (INT i = 0; i < (INT)results.GetCount(); i++)
        @         ((@dt<相机动作命令结果类>&)results.GetAt(i)).SetInfo(&stActionCmdResults.pResults[i]);
        @ }
        @ return results;
    }

    方法 置枚举命令回复包类型 <公开 静态 类型 = 整数 注释 = "设置枚举命令的回复包类型,该方法只对GigE相机有效." 返回值注释 = "返回设置是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 类型 <类型 = 整数 注释 = "0表示单播,1表示广播." "">
    {
        @ MV_GIGE_SetDiscoveryMode((UINT)@<类型>)
    }
}

类 相机设备类 <公开 注释 = "表示一个相机设备对象,提供设备的所有操作接口.">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CDeviceHandleWrapper)
    #
    # <> <include>
    # inline_ @sn<current_class> (void* ptr) : @sn<current_class>()  { data().SetDeviceHandle(ptr); }
    # static void WINAPI ExceptionCallBack(unsigned int nMsgType, void* pUser) { ((@sn<current_class>*)pUser)->@n<相机设备类.收到异常消息>((INT)nMsgType); }
    # static void WINAPI EventCallBack(MV_EVENT_OUT_INFO* pEventInfo, void* pUser)
    # {
    #     if (pEventInfo)
    #         ((@sn<current_class>*)pUser)->@n<相机设备类.收到设备事件>(CVolString(GetWideText((const CHAR *)pEventInfo->EventName, CVolMem(), NULL)), 
    #         (SHORT)pEventInfo->nEventID, (SHORT)pEventInfo->nStreamChannel, (INT)pEventInfo->nBlockIdHigh, (INT)pEventInfo->nBlockIdLow, 
    #         (INT)pEventInfo->nTimestampHigh, (INT)pEventInfo->nTimestampLow, CVolMem(pEventInfo->pEventData, pEventInfo->nEventDataSize));
    # }
    # static void WINAPI ImageCallBackEx(unsigned char *pData, MV_FRAME_OUT_INFO_EX* pstFrameInfo, void* pUser);
    # <> </include>
    # void @sn<current_class>::ImageCallBackEx(unsigned char *pData, MV_FRAME_OUT_INFO_EX* pstFrameInfo, void* pUser)
    # {
    #     ((@sn<current_class>*)pUser)->@n<相机设备类.收到图像采集数据>((INT_P)pData, @dt<图像数据信息>(pstFrameInfo));
    # }
    # @end

    方法 打开设备 <公开 类型 = 整数 注释 = "在对设备进行任何操作之前务必确保已成功打开设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 访问权限 <类型 = 相机访问权限类型 注释 = "提供打开该设备所欲使用的权限类型." @默认值 = 相机访问权限类型.独占权限>
    参数 权限切换密钥 <类型 = 短整数 注释 = "提供切换访问权限时的密钥." @默认值 = 0>
    {
        @ INT ret = MV_CC_OpenDevice(this->data().GetDeviceHandle(), (UINT)@<访问权限>, (USHORT)@<权限切换密钥>);
        @ if (ret == MV_OK)    //注册异常回调以及全事件回调
        @ {
        @     MV_CC_RegisterExceptionCallBack(this->data().GetDeviceHandle(), ExceptionCallBack, this);
        @     MV_CC_RegisterAllEventCallBack(this->data().GetDeviceHandle(), EventCallBack, this);
        @ }
        @ return ret;
    }

    方法 关闭设备 <公开 类型 = 整数 注释 = "通常与\"打开设备\"成对使用,关闭后如需再使用设备需再次调用\"打开设备\"方法." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    {
        @ MV_CC_CloseDevice(@sn<this>.data().GetDeviceHandle())
    }

    方法 取设备信息 <公开 类型 = 相机设备信息类 注释 = "获取该设备的信息对象." 返回值注释 = "返回该相机的设备信息对象." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_CC_DEVICE_INFO stDevInfo = {0};
        @ INT ret = MV_CC_GetDeviceInfo(this->data().GetDeviceHandle(), &stDevInfo);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机设备信息类>(&stDevInfo, FALSE);
    }

    方法 读整数值属性 <公开 类型 = 相机数值属性类 注释 = "读取该设备的数值属性." 返回值注释 = "返回读取的属性值." @禁止流程检查 = 真>
    参数 属性名 <类型 = 文本型 注释 = "提供所欲读取的属性名称,例如需获取其宽度属性即提供\"Width\",具体可以查看MVS属性描述.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MVCC_INTVALUE_EX stIntValue = {0};
        @ INT ret = MV_CC_GetIntValueEx(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), &stIntValue);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机数值属性类>(&stIntValue);
    }

    方法 写整数值属性 <公开 类型 = 整数 注释 = "写入该设备的数值属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,例如需设置其宽度属性即提供\"Width\",具体可以查看MVS属性描述.">
    参数 值 <类型 = 长整数 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetIntValueEx(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), (int64_t)@<值>)
    }

    方法 读枚举值属性 <公开 类型 = 相机枚举值属性类 注释 = "读取该设备的枚举值属性." 返回值注释 = "返回读取的属性值." @禁止流程检查 = 真>
    参数 属性名 <类型 = 文本型 注释 = "提供所欲读取的属性名称,例如需获取其像素格式属性即提供\"PixelFormat\",具体可以查看MVS属性描述.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MVCC_ENUMVALUE stEnumValue = {0};
        @ INT ret = MV_CC_GetEnumValue(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), &stEnumValue);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机枚举值属性类>(&stEnumValue);
    }

    方法 写枚举值属性 <公开 类型 = 整数 注释 = "写入该设备的枚举值属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,例如需设置其像素格式属性即提供\"PixelFormat\",具体可以查看MVS属性描述.">
    参数 值 <类型 = 整数 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetEnumValue(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), (UINT)@<值>)
    }

    方法 写文本枚举值属性 <公开 类型 = 整数 注释 = "同\"写枚举值属性\"一致,本方法以文本型内容写入该设备的枚举值属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,例如需设置其像素格式属性即提供\"PixelFormat\",具体可以查看MVS属性描述.">
    参数 值 <类型 = 文本型 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetEnumValueByString(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), (const char*)GetMbsText(@<值>.GetText(), CVolMem(), NULL))
    }

    方法 读浮点值属性 <公开 类型 = 相机浮点属性类 注释 = "读取该设备的浮点属性." 返回值注释 = "返回读取的属性值." @禁止流程检查 = 真>
    参数 属性名 <类型 = 文本型 注释 = "提供所欲读取的属性名称,具体可以查看MVS属性描述.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MVCC_FLOATVALUE stFloatValue = {0};
        @ INT ret = MV_CC_GetFloatValue(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), &stFloatValue);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机浮点属性类>(&stFloatValue);
    }

    方法 写浮点值属性 <公开 类型 = 整数 注释 = "写入该设备的浮点属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,具体可以查看MVS属性描述.">
    参数 值 <类型 = 小数 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetFloatValue(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), (FLOAT)@<值>)
    }

    方法 读逻辑值属性 <公开 类型 = 逻辑型 注释 = "读取该设备的逻辑值属性." 返回值注释 = "返回读取的属性值." @禁止流程检查 = 真>
    参数 属性名 <类型 = 文本型 注释 = "提供所欲读取的属性名称,具体可以查看MVS属性描述.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ bool bValue = false;
        @ INT ret = MV_CC_GetBoolValue(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), &bValue);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return bValue;
    }

    方法 写逻辑值属性 <公开 类型 = 整数 注释 = "写入该设备的逻辑值属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,具体可以查看MVS属性描述.">
    参数 值 <类型 = 逻辑型 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetBoolValue(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), @<值>)
    }

    方法 读文本值属性 <公开 类型 = 文本型 注释 = "读取该设备的文本值属性." 返回值注释 = "返回读取的属性值." @禁止流程检查 = 真>
    参数 属性名 <类型 = 文本型 注释 = "提供所欲读取的属性名称,具体可以查看MVS属性描述.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MVCC_STRINGVALUE stStringValue = {0};
        @ INT ret = MV_CC_GetStringValue(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), &stStringValue);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return GetWideText ((const CHAR*)stStringValue.chCurValue, CVolMem(), NULL);
    }

    方法 写文本值属性 <公开 类型 = 整数 注释 = "写入该设备的文本值属性." 返回值注释 = "返回执行是否成功，请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲写入的属性名称,具体可以查看MVS属性描述.">
    参数 值 <类型 = 文本型 注释 = "提供所欲写入的属性值.">
    {
        @ MV_CC_SetStringValue(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL), (const char*)GetMbsText(@<值>.GetText(), CVolMem(), NULL))
    }

    方法 执行指定命令 <公开 类型 = 整数 注释 = "设置该设备的命令属性,以执行指定的命令." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 命令 <类型 = 文本型 注释 = "提供所欲执行的命令,例如:\"TriggerSoftware\".">
    {
        @ MV_CC_SetCommandValue(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<命令>.GetText(), CVolMem(), NULL))
    }

    方法 读指定内存地址值 <公开 类型 = 字节集类 注释 = "通过寄存器地址获取该相机设备寄存器的数据." 返回值注释 = "返回读取到的数据." @禁止流程检查 = 真>
    参数 地址 <类型 = 长整数 注释 = "待读取的内存地址,该地址可以从设备的Camera.xml文件中获取,形如xxx_RegAddr的xml节点值.">
    参数 读取长度 <类型 = 长整数 注释 = "提供所欲读取数据的尺寸(单位字节).">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ CVolMem memBuf;
        @ INT ret = MV_CC_ReadMemory(this->data().GetDeviceHandle(), (void*)memBuf.Alloc(@<读取长度>, TRUE), (int64_t)@<地址>, (int64_t)@<读取长度>);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return memBuf;
    }

    方法 写指定内存地址值 <公开 类型 = 整数 注释 = "通过寄存器地址写入该相机设备寄存器的数据." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲写入的完整数据.">
    参数 地址 <类型 = 长整数 注释 = "待读取的内存地址,该地址可以从设备的Camera.xml文件中获取,形如xxx_RegAddr的xml节点值.">
    {
        @ return MV_CC_WriteMemory(this->data().GetDeviceHandle(), (const void*)@<数据>.GetPtr(), (int64_t)@<地址>, (int64_t)@<数据>.GetSize());
    }

    方法 取当前连接状态 <公开 类型 = 逻辑型 注释 = "获取当前该设备是否处于连接状态." 返回值注释 = "返回真表示处于连接状态,否则为失去连接." @嵌入式方法 = "">
    {
        @ (BOOL)MV_CC_IsDeviceConnected(@sn<this>.data().GetDeviceHandle())
    }

    方法 置内部图像缓存节点数量 <公开 类型 = 整数 注释 = "设置SDK内部图像缓存节点个数,通常在抓图前调用." 注释 = "注意:该方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功，请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 数量 <类型 = 整数 注释 = "提供所欲设置的缓存节点个数,必须大于等于1.">
    {
        @ MV_CC_SetImageNodeNum(@sn<this>.data().GetDeviceHandle(), (UINT)@<数量>)
    }

    方法 置取流策略 <公开 类型 = 整数 注释 = "设置该设备的取流策略." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 策略 <类型 = 相机取流策略 注释 = "提供所欲设置的策略类型.">
    {
        @ MV_CC_SetGrabStrategy(@sn<this>.data().GetDeviceHandle(), (MV_GRAB_STRATEGY)@<策略>)
    }

    方法 置输出缓存数量 <公开 类型 = 整数 注释 = "设置输出缓存个数(只有在\"列表最新\"取流策略下才有效." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 数量 <类型 = 整数 注释 = "提供所欲设置的数量,范围:大于等于1,小于图像缓存节点个数(即\"置内部图像缓存节点数量\"方法的设置值).">
    {
        @ MV_CC_SetOutputQueueSize(@sn<this>.data().GetDeviceHandle(), (UINT)@<数量>)
    }

    方法 取流量及丢包信息 <公开 类型 = 相机流量丢包信息类 注释 = "如果当前设备为GigE设备,调用本方法以获取网络流量以及丢包信息,其他类型设备无法获取." 注释 = "注意:需要在开启抓图后才可使用."
            返回值注释 = "返回流量以及丢包信息." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_ALL_MATCH_INFO stMatchInfo = {0};
        @ MV_MATCH_INFO_NET_DETECT stMatchInfoNetDetect = {0};
        @ stMatchInfo.nType = MV_MATCH_TYPE_NET_DETECT;
        @ stMatchInfo.pInfo = &stMatchInfoNetDetect;
        @ stMatchInfo.nInfoSize = sizeof (MV_MATCH_INFO_NET_DETECT);
        @ INT ret = MV_CC_GetAllMatchInfo(this->data().GetDeviceHandle(), &stMatchInfo);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机流量丢包信息类>(&stMatchInfoNetDetect);
    }

    方法 取相机数据接收信息 <公开 类型 = 相机数据接收信息类 注释 = "如果当前设备为U3V设备,调用本方法以获取host收到从设备端的总字节数,其他类型设备无法获取." 返回值注释 = "返回数据接收信息." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_ALL_MATCH_INFO stMatchInfo = {0};
        @ MV_MATCH_INFO_USB_DETECT stMatchInfoUSBDetect = {0};
        @ stMatchInfo.nType = MV_MATCH_TYPE_USB_DETECT;
        @ stMatchInfo.pInfo = &stMatchInfoUSBDetect;
        @ stMatchInfo.nInfoSize = sizeof (MV_MATCH_INFO_USB_DETECT);
        @ INT ret = MV_CC_GetAllMatchInfo(this->data().GetDeviceHandle(), &stMatchInfo);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机数据接收信息类>(&stMatchInfoUSBDetect);
    }

    方法 保存相机属性 <公开 类型 = 整数 注释 = "保存当前相机设备指定属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲保存的属性名称.">
    {
        @ MV_CC_FeatureSave(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL))
    }

    方法 导入相机属性 <公开 类型 = 整数 注释 = "导入当前相机设备指定属性." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 属性名 <类型 = 文本型 注释 = "提供所欲导入的属性名称.">
    {
        @ MV_CC_FeatureLoad(@sn<this>.data().GetDeviceHandle(), (const char*)GetMbsText(@<属性名>.GetText(), CVolMem(), NULL))
    }

    方法 读取相机文件 <公开 类型 = 整数 注释 = "从当前相机设备读取文件." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 用户文件名 <类型 = 文本型 注释 = "提供用户文件名,例如:UserSet1.bin">
    参数 设备文件名 <类型 = 文本型 注释 = "提供设备文件名,例如:UserSet1">
    {
        @ MV_CC_FILE_ACCESS stFileAccess = {0};
        @ CVolMem memBuf, memBuf2;
        @ stFileAccess.pUserFileName = (const char*)GetMbsText(@<用户文件名>.GetText(), memBuf, NULL);
        @ stFileAccess.pDevFileName = (const char*)GetMbsText(@<设备文件名>.GetText(), memBuf2, NULL);
        @ return MV_CC_FileAccessRead(this->data().GetDeviceHandle(), &stFileAccess);
    }

    方法 写入相机文件 <公开 类型 = 整数 注释 = "将文件写入当前相机设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 用户文件名 <类型 = 文本型 注释 = "提供用户文件名,例如:UserSet1.bin">
    参数 设备文件名 <类型 = 文本型 注释 = "提供设备文件名,例如:UserSet1">
    {
        @ MV_CC_FILE_ACCESS stFileAccess = {0};
        @ CVolMem memBuf, memBuf2;
        @ stFileAccess.pUserFileName = (const char*)GetMbsText(@<用户文件名>.GetText(), memBuf, NULL);
        @ stFileAccess.pDevFileName = (const char*)GetMbsText(@<设备文件名>.GetText(), memBuf2, NULL);
        @ return MV_CC_FileAccessWrite(this->data().GetDeviceHandle(), &stFileAccess);
    }

    方法 取文件存取进度 <公开 类型 = 整数 注释 = "获取文件存取的进度." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 总长度 <类型 = 长整数类 注释 = "提供变量以接收文件存取的总长度值.">
    参数 已完成长度 <类型 = 长整数类 注释 = "提供变量以接收文件存取的已完成长度值.">
    {
        @ MV_CC_FILE_ACCESS_PROGRESS stFileAccessProgress = {0};
        @ INT ret = MV_CC_GetFileAccessProgress(this->data().GetDeviceHandle(), &stFileAccessProgress);
        @ if (ret == MV_OK)
        @ {
        @     *(INT64*)@<总长度>.GetDataPtr() = (INT64)stFileAccessProgress.nTotal;
        @     *(INT64*)@<已完成长度>.GetDataPtr() = (INT64)stFileAccessProgress.nCompleted;
        @ }
        @ return ret;
    }

    # GIGE独有接口 ---

    方法 强制设置网络参数 <公开 类型 = 整数 注释 = "强制设置设备网络参数(包括IP,子网掩码,默认网关),仅GIGE设备可用."
            注释 = "  注意:本方法调用后需要重新创建设备,即重新调用\"工业相机类.创建设备()\",当前本对象将失效无法继续使用." 注释 = "如果设备为DHCP的状态,调用该接口强制设置设备网络参数之后设备将会重启."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 IP <类型 = 整数>
    参数 子网掩码 <类型 = 整数>
    参数 默认网关 <类型 = 整数>
    {
        @ MV_GIGE_ForceIpEx(@sn<this>.data().GetDeviceHandle(), (UINT)@<IP>, (UINT)@<子网掩码>, (UINT)@<默认网关>)
    }

    方法 置IP配置方式 <公开 类型 = 整数 注释 = "设置当前设备IP配置方式,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 模式 <类型 = 相机IP配置模式 注释 = "提供所欲设置的模式.">
    {
        @ MV_GIGE_SetIpConfig(@sn<this>.data().GetDeviceHandle(), (UINT)@<模式>)
    }

    方法 置网络传输模式 <公开 类型 = 整数 注释 = "设置SDK内部优先使用的网络模式,如不设置默认优先使用驱动模式,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @嵌入式方法 = "">
    参数 模式 <类型 = 相机网络传输模式 注释 = "提供所欲设置的模式.">
    {
        @ MV_GIGE_SetNetTransMode(@sn<this>.data().GetDeviceHandle(), (UINT)@<模式>)
    }

    方法 取网络传输信息 <公开 类型 = 相机网络传输信息类 注释 = "获取网络传输相关信息,包括已接收数据大小,丢帧数量等,请在开始取流开启采集之后调用,仅GIGE设备可用." 返回值注释 = "返回网络传输信息." @嵌入式方法 = "">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_NETTRANS_INFO stInfo = {0};
        @ INT ret = MV_GIGE_GetNetTransInfo(this->data().GetDeviceHandle(), &stInfo);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return @dt<相机网络传输信息类>(&stInfo);
    }

    方法 置GVSP取流超时 <公开 类型 = 整数 注释 = "在开始取流之前调用本方法以设置GVSP取流超时时间,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 超时 <类型 = 整数 注释 = "单位:毫秒,提供的值必须大于等于10毫秒.">
    {
        @ MV_GIGE_SetGvspTimeout(@sn<this>.data().GetDeviceHandle(), (UINT)@<超时>)
    }

    方法 取GVSP取流超时 <公开 类型 = 整数 注释 = "获取所设置的GVSP取流超时时间,仅GIGE设备可用." 返回值注释 = "返回所定义的取流超时时间,单位:毫秒." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT nMillisec = 0;
        @ INT ret = MV_GIGE_GetGvspTimeout(this->data().GetDeviceHandle(), &nMillisec);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)nMillisec;
    }

    方法 取最佳包尺寸 <公开 类型 = 整数 注释 = "获取当前相机设备的最佳包尺寸(packetsize),该大小即网络上传输一个包的大小,仅GIGE设备可用." 返回值注释 = "返回最佳包尺寸." @嵌入式方法 = "">
    {
        @ MV_CC_GetOptimalPacketSize(@sn<this>.data().GetDeviceHandle())
    }

    方法 置重发包配置 <公开 类型 = 整数 注释 = "设置是否打开重发包支持,及重发包设置,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            编辑时信息 = "49550, 0, 0, 0" @嵌入式方法 = "">
    参数 启用 <类型 = 逻辑型 注释 = "指定是否启用重发包." 编辑时信息 = "49550, 0, 0, 0">
    参数 最大重发比 <类型 = 整数>
    参数 重发超时 <类型 = 整数>
    {
        @ MV_GIGE_SetResend(@sn<this>.data().GetDeviceHandle(), (UINT)@<启用>, (UINT)@<最大重发比>, (UINT)@<重发超时>)
    }

    方法 置重传命令重试次数 <公开 类型 = 整数 注释 = "设置重传命令最大尝试次数,在重发包配置启用的状态下可设置,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @嵌入式方法 = "">
    参数 最大次数 <类型 = 整数 注释 = "重传命令最大尝试次数,默认为20.">
    {
        @ MV_GIGE_SetResendMaxRetryTimes(@sn<this>.data().GetDeviceHandle(), (UINT)@<最大次数>)
    }

    方法 取重传命令重试次数 <公开 类型 = 整数 注释 = "获取重传命令最大尝试次数,仅GIGE设备可用." 返回值注释 = "返回所定义的最大重传命令重试次数." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT nRetryTimes = 0;
        @ INT ret = MV_GIGE_GetResendMaxRetryTimes(this->data().GetDeviceHandle(), &nRetryTimes);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)nRetryTimes;
    }

    方法 置重传包请求间隔 <公开 类型 = 整数 注释 = "设置同一重传包多次请求之间的时间间隔,在重发包配置启用的状态下可设置,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @嵌入式方法 = "">
    参数 间隔 <类型 = 整数 注释 = "单位:毫秒.">
    {
        @ MV_GIGE_SetResendTimeInterval(@sn<this>.data().GetDeviceHandle(), (UINT)@<间隔>)
    }

    方法 取重传包请求间隔 <公开 类型 = 整数 注释 = "获取同一重传包多次请求之间的时间间隔,仅GIGE设备可用." 返回值注释 = "返回所定义的重传包请求间隔." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT nMillisec = 0;
        @ INT ret = MV_GIGE_GetResendTimeInterval(this->data().GetDeviceHandle(), &nMillisec);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)nMillisec;
    }

    方法 置数据传输模式 <公开 类型 = 整数 注释 = "设置传输模式,可以为单播模式,组播模式等,仅GIGE设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 类型 <类型 = 相机数据传输模式 注释 = "提供所欲设置的传输模式.">
    参数 目标IP <类型 = 整数 注释 = "仅在组播模式下需要提供本参数." @默认值 = 0>
    参数 目标端口 <类型 = 短整数 注释 = "仅在组播模式下需要提供本参数." @默认值 = 0>
    {
        @ MV_TRANSMISSION_TYPE stTransmissionType;
        @ memset(&stTransmissionType, 0, sizeof(MV_TRANSMISSION_TYPE));
        @ stTransmissionType.enTransmissionType = (MV_GIGE_TRANSMISSION_TYPE)@<类型>;
        @ stTransmissionType.nDestIp = (UINT)@<目标IP>;
        @ stTransmissionType.nDestPort = (USHORT)@<目标端口>;
        @ return MV_GIGE_SetTransmissionType(this->data().GetDeviceHandle(), &stTransmissionType);
    }

    # CameraLink独有接口 ---

    方法 置设备波特率 <公开 类型 = 整数 注释 = "设置设备波特率,支持在未打开前调用,仅CameraLink设备可用." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 波特率 <类型 = 相机波特率类型 注释 = "提供所欲使用的波特率.">
    {
        @ MV_CAML_SetDeviceBaudrate(@sn<this>.data().GetDeviceHandle(), (UINT)@<波特率>);
    }

    方法 取设备波特率 <公开 类型 = 相机波特率类型 注释 = "获取设备的波特率,支持在未打开前调用,仅CameraLink设备可用." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_CAML_GetDeviceBaudrate(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 "//取主机连接支持波特率" <公开 类型 = 相机波特率类型 注释 = "获取设备与主机间连接支持的波特率,支持在未打开前调用,仅CameraLink设备可用." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_CAML_GetSupportBaudrates(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 置串口操作等待超时 <公开 类型 = 整数 注释 = "设置串口操作等待时长." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 超时 <类型 = 整数 注释 = "提供串口操作的等待时长,单位:毫秒.">
    {
        @ MV_CAML_SetGenCPTimeOut(@sn<this>.data().GetDeviceHandle(), (UINT)@<超时>);
    }

    方法 注册图像数据采集回调 <公开 类型 = 整数 注释 = "本方法设置图像数据的回调函数(图像数据将通过\"收到图像采集数据\"事件返回),即被动采集图像,本方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    {
        @ return MV_CC_RegisterImageCallBackEx(this->data().GetDeviceHandle(), ImageCallBackEx, this);
    }

    方法 注册图像RGB数据采集回调 <公开 类型 = 整数 注释 = "本方法设置RGB图像数据的回调函数(图像数据将通过\"收到图像采集数据\"事件返回),即被动采集图像,本方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    {
        @ return MV_CC_RegisterImageCallBackForRGB(this->data().GetDeviceHandle(), ImageCallBackEx, this);
    }

    方法 注册图像BGR数据采集回调 <公开 类型 = 整数 注释 = "本方法设置BGR图像数据的回调函数(图像数据将通过\"收到图像采集数据\"事件返回),即被动采集图像,本方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    {
        @ return MV_CC_RegisterImageCallBackForBGR(this->data().GetDeviceHandle(), ImageCallBackEx, this);
    }

    方法 开始取流 <公开 类型 = 整数 注释 = "  开始取流,如果调用了\"注册图像数据采集回调\"等方法,采集到数据后将会触发\"收到图像采集数据\"事件."
            注释 = "如未使用上述方法注册事件,此时可调用\"取图像帧采集数据\"等方法获取采集的图像数据,本方法不支持CameraLink设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @嵌入式方法 = "">
    {
        @ MV_CC_StartGrabbing(@sn<this>.data().GetDeviceHandle())
    }

    方法 停止取流 <公开 类型 = 整数 注释 = "调用了\"开始取流\"后,可使用本方法停止,通常成对使用,本方法不支持CameraLink设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @嵌入式方法 = "">
    {
        @ MV_CC_StopGrabbing(@sn<this>.data().GetDeviceHandle())
    }

    方法 取图像帧采集数据 <公开 类型 = 整数 注释 = "  在调用\"开始取流\"后,获取一帧采集到的图像数据,应用程序需要根据帧率,控制好调用该方法的频率."
            注释 = "注意:调用本方法将阻塞直到有数据返回或指定的超时时间达到后返回错误,本方法不支持CameraLink设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 帧数据 <类型 = 字节集类 注释 = "提供存放数据的缓冲区,获取到数据后将写入至该变量." 注释 = "注意:调用本方法前务必为其分配足够的内存空间.">
    参数 数据对象 <类型 = 图像数据信息 注释 = "提供数据信息对象,获取到的信息将写入至该变量.">
    参数 超时时间 <类型 = 整数 注释 = "提供本次执行的最大超时时间,单位毫秒,在该时间内未获取到数据将返回一个错误." @默认值 = 1000>
    {
        @ @<帧数据>.Zero();    //交由用户分配,清零即可
        @ MV_FRAME_OUT_INFO_EX stFrameInfo = {0};
        @ INT ret = MV_CC_GetOneFrameTimeout(this->data().GetDeviceHandle(), (unsigned char*)@<帧数据>.GetPtr(), (UINT)@<帧数据>.GetSize(), &stFrameInfo, (UINT)@<超时时间>);
        @ @<数据对象>.SetInfo(&stFrameInfo);
        @ return ret;
    }

    方法 取内部缓存图像帧数据 <公开 类型 = 整数 注释 = "  在调用\"开始取流\"后,使用内部缓存获取一帧图片,应用程序需要根据帧率,控制好调用该方法的频率."
            注释 = "注意:调用本方法将阻塞直到有数据返回或指定的超时时间达到后返回错误,本方法不支持CameraLink设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 数据对象 <类型 = 图像帧输出数据信息 注释 = "提供数据信息对象,获取到的信息将写入至该变量.">
    参数 超时时间 <类型 = 整数 注释 = "提供本次执行的最大超时时间,单位毫秒,在该时间内未获取到数据将返回一个错误." @默认值 = 1000>
    {
        @ MV_CC_GetImageBuffer(@sn<this>.data().GetDeviceHandle(), @<数据对象>.GetSTFrame(), (UINT)@<超时时间>)
    }

    方法 取内部缓存图像帧RGB数据 <公开 类型 = 整数 注释 = "  同\"取内部缓存图像帧数据\"方法一致,但会将获取到的数据转为RGB24格式再返回,本方法不支持CameraLink设备."
            注释 = "注意:因为图像转换成RGB24格式有耗时,所以当数据帧率过高时该方法可能会导致丢帧." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 帧数据 <类型 = 字节集类 注释 = "提供存放数据的缓冲区,获取到数据后将写入至该变量." 注释 = "注意:调用本方法前务必为其分配足够的内存空间.">
    参数 数据对象 <类型 = 图像数据信息 注释 = "提供数据信息对象,获取到的信息将写入至该变量.">
    参数 超时时间 <类型 = 整数 注释 = "提供本次执行的最大超时时间,单位毫秒,在该时间内未获取到数据将返回一个错误." @默认值 = 1000>
    {
        @ MV_FRAME_OUT_INFO_EX stFrameInfo = {0};
        @ INT ret = MV_CC_GetImageForRGB(this->data().GetDeviceHandle(), (unsigned char*)@<帧数据>.GetPtr(), (UINT)@<帧数据>.GetSize(), &stFrameInfo, (UINT)@<超时时间>);
        @ @<数据对象>.SetInfo(&stFrameInfo);
        @ return ret;
    }

    方法 释放内部缓存图像帧数据 <公开 类型 = 整数 注释 = "释放图像缓存(此接口用于释放不再使用的图像缓存,与\"取内部缓存图像帧数据\"成对使用),本方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 数据对象 <类型 = 图像帧输出数据信息 注释 = "提供所欲释放的数据对象.">
    {
        @ MV_CC_FreeImageBuffer(@sn<this>.data().GetDeviceHandle(), @<数据对象>.GetSTFrame())
    }

    方法 清除取流数据缓存 <公开 类型 = 整数 注释 = "  支持在取流过程中调用,以清除缓存中不需要的图像数据." 注释 = "在连续模式切触发模式后,可以清除历史数据,本方法不支持CameraLink设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    {
        @ MV_CC_ClearImageBuffer(@sn<this>.data().GetDeviceHandle())
    }

    # 图像处理 ---

    方法 显示图像帧到组件 <公开 类型 = 整数 注释 = "将一帧图像显示到指定的窗口组件上,该方法不支持CameraLink设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 窗口句柄 <类型 = 变整数 注释 = "提供所欲图像的窗口组件句柄.">
    参数 数据 <类型 = 字节集类 注释 = "提供采集到的原始图像数据.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲显示图像的宽度.">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲显示图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供所欲显示图像的像素格式.">
    {
        返回 (显示图像帧到组件2 (窗口句柄, 数据.取字节集指针 (), 数据.取字节集长度 (), 图像宽度, 图像高度, 像素格式))
    }

    方法 显示图像帧到组件2 <公开 类型 = 整数 注释 = "同\"显示图像帧到组件\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "提供所欲图像的窗口组件句柄.">
    参数 数据指针 <类型 = 变整数 注释 = "提供所欲显示的数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲显示图像的宽度.">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲显示图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供所欲显示图像的像素格式.">
    {
        @ MV_DISPLAY_FRAME_INFO stDisplayInfo = {0};
        @ stDisplayInfo.hWnd = (void*)@<窗口句柄>;
        @ stDisplayInfo.pData = (unsigned char*)@<数据指针>;
        @ stDisplayInfo.nDataLen = (UINT)@<数据长度>;
        @ stDisplayInfo.nWidth = (USHORT)@<图像宽度>;
        @ stDisplayInfo.nHeight = (USHORT)@<图像高度>;
        @ stDisplayInfo.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ return MV_CC_DisplayOneFrame(this->data().GetDeviceHandle(), &stDisplayInfo);
    }

    方法 保存图像数据 <公开 类型 = 整数 注释 = "将所采集的图像帧数据转换保存为指定格式(JPG/BMP等)的图像数据." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供采集到的原始图像数据.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲输出图像的宽度">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲输出图像的高度.">
    参数 输出格式 <类型 = 相机图像数据保存格式 注释 = "提供所欲输出的图像格式类型.">
    参数 JPG质量 <类型 = 整数 注释 = "在指定输出格式为\"JPEG\"时本参数有意义,其他格式无效,范围:[50-99].">
    参数 插值方法 <类型 = 整数 注释 = "指定所欲使用的插值方法,0表示快速,1表示均衡,2表示最优." @默认值 = 2>
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        返回 (保存图像数据2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 像素格式, 图像宽度, 图像高度, 输出格式, JPG质量, 插值方法, 输出数据))
    }

    方法 保存图像数据2 <公开 类型 = 整数 注释 = "同\"保存图像数据\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像的数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲输出图像的宽度">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲输出图像的高度.">
    参数 输出格式 <类型 = 相机图像数据保存格式 注释 = "提供所欲输出的图像格式类型.">
    参数 JPG质量 <类型 = 整数 注释 = "在指定输出格式为\"JPEG\"时本参数有意义,其他格式无效,范围:[50-99].">
    参数 插值方法 <类型 = 整数 注释 = "指定所欲使用的插值方法,0表示快速,1表示均衡,2表示最优.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        @ MV_SAVE_IMAGE_PARAM_EX stSaveParam = {0};
        @ stSaveParam.pData = (unsigned char*)@<数据指针>;
        @ stSaveParam.nDataLen = (UINT)@<数据长度>;
        @ stSaveParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stSaveParam.nWidth = (USHORT)@<图像宽度>;
        @ stSaveParam.nHeight = (USHORT)@<图像高度>;
        @ stSaveParam.pImageBuffer = (unsigned char*)@<输出数据>.GetPtr();
        @ stSaveParam.nBufferSize = (UINT)@<输出数据>.GetSize();
        @ stSaveParam.enImageType = (MV_SAVE_IAMGE_TYPE)@<输出格式>;
        @ stSaveParam.nJpgQuality = (UINT)@<JPG质量>;
        @ stSaveParam.iMethodValue = (UINT)@<插值方法>;
        @ INT ret = MV_CC_SaveImageEx2(this->data().GetDeviceHandle(), &stSaveParam);
        @ if (ret == MV_OK) 
        @     @<输出数据>.Realloc(stSaveParam.nImageLen);
        @ else 
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 保存图像数据到文件 <公开 类型 = 整数 注释 = "将所采集的图像帧数据转换保存为指定格式(JPG/BMP等)的图像数据并写出到指定文件." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供采集到的原始图像数据.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲输出图像的宽度">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲输出图像的高度.">
    参数 保存格式 <类型 = 相机图像数据保存格式 注释 = "提供所欲保存图像的图像格式类型.">
    参数 图像质量 <类型 = 整数 注释 = "在指定保存格式为\"JPEG/PNG\"时本参数有意义,其他格式无效,JPG范围:[50-99]，PNG范围:[0-9].">
    参数 插值方法 <类型 = 整数 注释 = "指定所欲使用的插值方法,0表示快速,1表示均衡,2表示最优.">
    参数 保存路径 <类型 = 文本型 注释 = "提供图像文件的写出路径.">
    {
        返回 (保存图像数据到文件2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 像素格式, 图像宽度, 图像高度, 保存格式, 图像质量, 插值方法, 保存路径))
    }

    方法 保存图像数据到文件2 <公开 类型 = 整数 注释 = "同\"保存图像数据到文件\"基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 图像宽度 <类型 = 短整数 注释 = "提供所欲输出图像的宽度">
    参数 图像高度 <类型 = 短整数 注释 = "提供所欲输出图像的高度.">
    参数 保存格式 <类型 = 相机图像数据保存格式 注释 = "提供所欲保存图像的图像格式类型.">
    参数 图像质量 <类型 = 整数 注释 = "在指定保存格式为\"JPEG/PNG\"时本参数有意义,其他格式无效,JPG范围:[50-99]，PNG范围:[0-9].">
    参数 插值方法 <类型 = 整数 注释 = "指定所欲使用的插值方法,0表示快速,1表示均衡,2表示最优.">
    参数 保存路径 <类型 = 文本型 注释 = "提供图像文件的写出路径.">
    {
        @ MV_SAVE_IMG_TO_FILE_PARAM stSaveFileParam;
        @ memset(&stSaveFileParam, 0, sizeof(MV_SAVE_IMG_TO_FILE_PARAM));
        @ stSaveFileParam.pData = (unsigned char*)@<数据指针>;
        @ stSaveFileParam.nDataLen = (UINT)@<数据长度>;
        @ stSaveFileParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stSaveFileParam.nWidth = (USHORT)@<图像宽度>;
        @ stSaveFileParam.nHeight = (USHORT)@<图像高度>;
        @ INT_P mbsLen;
        @ CVolMem memBuf;
        @ char* mbsPath = (char*)GetMbsText(@<保存路径>.GetText(), memBuf, &mbsLen);
        @ memcpy(stSaveFileParam.pImagePath, mbsPath, mbsLen > 256 ? 256 : mbsLen);
        @ stSaveFileParam.enImageType = (MV_SAVE_IAMGE_TYPE)@<保存格式>;
        @ stSaveFileParam.nQuality = (UINT)@<图像质量>;
        @ stSaveFileParam.iMethodValue = (UINT)@<插值方法>;
        @ return MV_CC_SaveImageToFile(this->data().GetDeviceHandle(), &stSaveFileParam);
    }

    方法 保存3D点云数据 <公开 类型 = 整数 注释 = "保存3D点云数据,支持PLY,CSV和OBJ三种格式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供采集到的原始图像数据.">
    参数 行点数 <类型 = 整数 注释 = "行点数,即图像宽度.">
    参数 行数 <类型 = 整数 注释 = "行数,即图像宽高.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 输出格式 <类型 = 点云数据保存文件格式 注释 = "提供所欲输出点云文件的格式类型.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,转换后将图像数据写入至该变量.">
    {
        返回 (保存3D点云数据2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 行点数, 行数, 像素格式, 输出格式, 输出数据))
    }

    方法 保存3D点云数据2 <公开 类型 = 整数 注释 = "同\"保存3D点云数据\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 行点数 <类型 = 整数 注释 = "行点数,即图像宽度.">
    参数 行数 <类型 = 整数 注释 = "行数,即图像宽高.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 输出格式 <类型 = 点云数据保存文件格式 注释 = "提供所欲输出点云文件的格式类型.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,转换后将图像数据写入至该变量.">
    {
        @ MV_SAVE_POINT_CLOUD_PARAM stPointDataParam = {0};
        @ stPointDataParam.nLinePntNum = (UINT)@<行点数>;
        @ stPointDataParam.nLineNum = (UINT)@<行数>;
        @ stPointDataParam.enSrcPixelType = (MvGvspPixelType)@<像素格式>;
        @ stPointDataParam.pSrcData = (unsigned char*)@<数据指针>;
        @ stPointDataParam.nSrcDataLen = (UINT)@<数据长度>;
        @ stPointDataParam.pDstBuf = (unsigned char*)@<输出数据>.Alloc(@<行点数> * @<行数> * (16 * 3 + 4) + 2048, TRUE);
        @ stPointDataParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stPointDataParam.enPointCloudFileType = (MV_SAVE_POINT_CLOUD_FILE_TYPE)@<输出格式>;
        @ INT ret = MV_CC_SavePointCloudData(this->data().GetDeviceHandle(), &stPointDataParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stPointDataParam.nDstBufLen);
        @ else 
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 旋转图像数据 <公开 类型 = 整数 注释 = "将指定图像数据进行旋转变换后返回,本方法仅支持MONO8/RGB24/BGR24格式数据的90/180/270度旋转."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供采集到的原始图像数据指针.">
    参数 图像宽度 <类型 = 整数类 注释 = "需提供原始图像的宽度,旋转后新图像数据的宽度将被写入至该变量.">
    参数 图像高度 <类型 = 整数类 注释 = "需提供原始图像的高度,旋转后新图像数据的高度将被写入至该变量.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 旋转类型 <类型 = 整数 注释 = "提供所欲使用的旋转类型,1表示旋转90度,2表示旋转180度,3表示旋转270度.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        返回 (旋转图像数据2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 图像宽度, 图像高度, 像素格式, 旋转类型, 输出数据))
    }

    方法 旋转图像数据2 <公开 类型 = 整数 注释 = "同\"旋转图像数据\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数类 注释 = "需提供原始图像的宽度,旋转后新图像数据的宽度将被写入至该变量.">
    参数 图像高度 <类型 = 整数类 注释 = "需提供原始图像的高度,旋转后新图像数据的高度将被写入至该变量.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 旋转类型 <类型 = 整数 注释 = "提供所欲使用的旋转类型,1表示旋转90度,2表示旋转180度,3表示旋转270度.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        @ MV_CC_ROTATE_IMAGE_PARAM stRotateParam;
        @ memset(&stRotateParam, 0, sizeof(MV_CC_ROTATE_IMAGE_PARAM));
        @ stRotateParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stRotateParam.nWidth = (UINT)*(INT*)@<图像宽度>.GetDataPtr();
        @ stRotateParam.nHeight = (UINT)*(INT*)@<图像高度>.GetDataPtr();
        @ stRotateParam.pSrcData = (unsigned char*)@<数据指针>;
        @ stRotateParam.nSrcDataLen = (UINT)@<数据长度>;
        @ stRotateParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stRotateParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stRotateParam.enRotationAngle = (MV_IMG_ROTATION_ANGLE)@<旋转类型>;
        @ INT ret = MV_CC_RotateImage(this->data().GetDeviceHandle(), &stRotateParam);
        @ if (ret == MV_OK)
        @ {
        @     @<输出数据>.Realloc(stRotateParam.nDstBufLen);
        @     *(INT*)@<图像宽度>.GetDataPtr() = (INT)stRotateParam.nWidth;
        @     *(INT*)@<图像高度>.GetDataPtr() = (INT)stRotateParam.nHeight;
        @ }
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 翻转图像数据 <公开 类型 = 整数 注释 = "将指定图像数据进行翻转变换后返回,本方法仅支持MONO8/RGB24/BGR24格式数据的垂直和水平翻转."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
