    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 噪声特性 <类型 = 字节集类 注释 = "提供噪声特性数据.">
    参数 降噪强度 <类型 = 整数 注释 = "提供所欲使用的降噪强度,范围:[0-100].">
    参数 Bayer锐化强度 <类型 = 整数 注释 = "提供所欲使用的Bayer锐化强度,范围:[0-32].">
    参数 噪声校正系数 <类型 = 整数 注释 = "提供所欲使用的噪声校正系数,范围:[0-1280].">
    参数 亮度校正系数 <类型 = 整数 注释 = "提供所欲使用的亮度校正系数,范围:[1-2000].">
    参数 色度校正系数 <类型 = 整数 注释 = "提供所欲使用的色度校正系数,范围:[1-2000].">
    参数 亮度降噪强度 <类型 = 整数 注释 = "提供所欲使用的亮度降噪强度,范围:[0-100].">
    参数 色度降噪强度 <类型 = 整数 注释 = "提供所欲使用的色度降噪强度,范围:[0-100].">
    参数 锐化强度 <类型 = 整数 注释 = "提供所欲使用的锐化强度,范围:[1-1000].">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放处理后数据的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    {
        @ MV_CC_SPATIAL_DENOISE_PARAM stSpatialDenoiseParam = {0};
        @ stSpatialDenoiseParam.nWidth = (UINT)@<图像宽度>;
        @ stSpatialDenoiseParam.nHeight = (UINT)@<图像高度>;
        @ stSpatialDenoiseParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stSpatialDenoiseParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stSpatialDenoiseParam.nSrcBufLen = (UINT)@<数据长度>;
        @ stSpatialDenoiseParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stSpatialDenoiseParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stSpatialDenoiseParam.pNoiseProfile = (unsigned char*)@<噪声特性>.GetPtr();
        @ stSpatialDenoiseParam.nNoiseProfileLen = (UINT)@<噪声特性>.GetSize();
        @ stSpatialDenoiseParam.nBayerDenoiseStrength = (UINT)@<降噪强度>;
        @ stSpatialDenoiseParam.nBayerSharpenStrength = (UINT)@<Bayer锐化强度>;
        @ stSpatialDenoiseParam.nBayerNoiseCorrect = (UINT)@<噪声校正系数>;
        @ stSpatialDenoiseParam.nNoiseCorrectLum = (UINT)@<亮度校正系数>;
        @ stSpatialDenoiseParam.nNoiseCorrectChrom = (UINT)@<色度校正系数>;
        @ stSpatialDenoiseParam.nStrengthLum = (UINT)@<亮度降噪强度>;
        @ stSpatialDenoiseParam.nStrengthChrom = (UINT)@<色度降噪强度>;
        @ stSpatialDenoiseParam.nStrengthSharpen = (UINT)@<锐化强度>;
        @ INT ret = MV_CC_SpatialDenoise(this->data().GetDeviceHandle(), &stSpatialDenoiseParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stSpatialDenoiseParam.nDstBufLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 图像LSC标定 <公开 类型 = 整数 注释 = "对指定图像数据进行LSC标定,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供所欲处理的源图像数据.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 宽度分块数 <类型 = 整数 注释 = "提供宽度分块数.">
    参数 高度分块数 <类型 = 整数 注释 = "提供高度分块数.">
    参数 边缘填充系数 <类型 = 整数 注释 = "提供边缘填充系数,范围:[1-5].">
    参数 标定方式 <类型 = 整数 注释 = "提供标定方式,0表示以中心为基准,1表示以最亮区为基准,2表示以\"目标亮度\"参数为基准.">
    参数 目标亮度 <类型 = 整数 注释 = "提供所欲使用的目标亮度基准(标定方式为2时本参数有意义),8位时范围为[0-255],10位时范围为[0-1023],12位时范围为[0-4095],16位时范围为[0-65535].">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放处理后数据的变量,处理完成后将数据写入至该变量.">
    {
        返回 (图像LSC标定2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 图像宽度, 图像高度, 像素格式, 宽度分块数, 高度分块数, 边缘填充系数, 标定方式, 目标亮度, 输出数据))
    }

    方法 图像LSC标定2 <公开 类型 = 整数 注释 = "对指定图像数据进行LSC标定,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 宽度分块数 <类型 = 整数 注释 = "提供宽度分块数.">
    参数 高度分块数 <类型 = 整数 注释 = "提供高度分块数.">
    参数 边缘填充系数 <类型 = 整数 注释 = "提供边缘填充系数,范围:[1-5].">
    参数 标定方式 <类型 = 整数 注释 = "提供标定方式,0表示以中心为基准,1表示以最亮区为基准,2表示以\"目标亮度\"参数为基准.">
    参数 目标亮度 <类型 = 整数 注释 = "提供所欲使用的目标亮度基准(标定方式为2时本参数有意义),8位时范围为[0-255],10位时范围为[0-1023],12位时范围为[0-4095],16位时范围为[0-65535].">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放标定表缓存数据的变量,处理完成后将数据写入至该变量.">
    {
        @ MV_CC_LSC_CALIB_PARAM stLSCCalibParam = {0};
        @ stLSCCalibParam.nWidth = (UINT)@<图像宽度>;
        @ stLSCCalibParam.nHeight = (UINT)@<图像高度>;
        @ stLSCCalibParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stLSCCalibParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stLSCCalibParam.nSrcBufLen = (UINT)@<数据长度>;
        @ stLSCCalibParam.pCalibBuf = (unsigned char*)@<输出数据>.Alloc(@<图像宽度> * @<图像高度> * sizeof(USHORT));
        @ stLSCCalibParam.nCalibBufSize = (UINT)@<输出数据>.GetSize();
        @ stLSCCalibParam.nSecNumW = (UINT)@<宽度分块数>;
        @ stLSCCalibParam.nSecNumH = (UINT)@<高度分块数>;
        @ stLSCCalibParam.nPadCoef = (UINT)@<边缘填充系数>;
        @ stLSCCalibParam.nCalibMethod = (UINT)@<标定方式>;
        @ stLSCCalibParam.nTargetGray = (UINT)@<目标亮度>;
        @ INT ret = MV_CC_LSCCalib(this->data().GetDeviceHandle(), &stLSCCalibParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stLSCCalibParam.nCalibBufLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 图像LSC校正 <公开 类型 = 整数 注释 = "对指定图像数据进行LSC校正,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供所欲处理的源图像数据.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度,范围:16-65535.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度,范围:16-65535.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 标定数据 <类型 = 字节集类 注释 = "提供该图像的标定数据.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放校正后数据的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    {
        返回 (图像LSC校正2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 图像宽度, 图像高度, 像素格式, 标定数据, 输出数据))
    }

    方法 图像LSC校正2 <公开 类型 = 整数 注释 = "对指定图像数据进行LSC校正,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 整数 注释 = "需提供原始图像的宽度,范围:16-65535.">
    参数 图像高度 <类型 = 整数 注释 = "需提供原始图像的高度,范围:16-65535.">
    参数 像素格式 <类型 = 图像像素格式 注释 = "提供原始图像的像素格式.">
    参数 标定数据 <类型 = 字节集类 注释 = "提供该图像的标定数据.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放校正后数据的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    {
        @ MV_CC_LSC_CORRECT_PARAM stLSCCorrectParam = {0};
        @ stLSCCorrectParam.nWidth = (UINT)@<图像宽度>;
        @ stLSCCorrectParam.nHeight = (UINT)@<图像高度>;
        @ stLSCCorrectParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stLSCCorrectParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stLSCCorrectParam.nSrcBufLen = (UINT)@<数据长度>;
        @ stLSCCorrectParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stLSCCorrectParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ stLSCCorrectParam.pCalibBuf = (unsigned char*)@<标定数据>.GetPtr();
        @ stLSCCorrectParam.nCalibBufLen = (UINT)@<标定数据>.GetSize();
        @ INT ret = MV_CC_LSCCorrect(this->data().GetDeviceHandle(), &stLSCCorrectParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stLSCCorrectParam.nDstBufLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 图像无损解码 <公开 类型 = 整数 注释 = "对指定图像数据进行LSC校正,以相机实际支持为准." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值.">
    参数 图像数据 <类型 = 字节集类 注释 = "提供所欲处理的源图像数据.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放解码后数据的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    参数 输出信息 <类型 = 图像解码结果信息类 注释 = "提供存放解码后图像信息的变量,处理完成后解码的图像信息将写入该变量.">
    {
        返回 (图像无损解码2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 输出数据, 输出信息))
    }

    方法 图像无损解码2 <公开 类型 = 整数 注释 = "将从相机中取到的无损压缩码流解码成裸数据,同时支持解析当前相机实时图像的水印信息(如果输入的无损码流不是当前相机或者不是实时取流的，则水印解析可能异常),以相机实际支持为准."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放解码后数据的变量,务必提供足够长度的空间,处理完成后将数据写入至该变量.">
    参数 输出信息 <类型 = 图像解码结果信息类 注释 = "提供存放解码后图像信息的变量,处理完成后解码的图像信息将写入该变量.">
    {
        @ MV_CC_HB_DECODE_PARAM stDecodeParam = {0};
        @ stDecodeParam.pSrcBuf = (unsigned char*)@<数据指针>;
        @ stDecodeParam.nSrcLen = (UINT)@<数据长度>;
        @ stDecodeParam.pDstBuf = (unsigned char*)@<输出数据>.GetPtr();
        @ stDecodeParam.nDstBufSize = (UINT)@<输出数据>.GetSize();
        @ INT ret = MV_CC_HB_Decode(this->data().GetDeviceHandle(), &stDecodeParam);
        @ if (ret == MV_OK)
        @ {
        @     @<输出数据>.Realloc(stDecodeParam.nDstBufLen);
        @     @<输出信息>.SetInfo(&stDecodeParam);
        @ }
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 开始录像 <公开 类型 = 整数 注释 = "开始录像." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 像素格式 <类型 = 图像像素格式 注释 = "输入数据的像素格式.">
    参数 图像宽度 <类型 = 短整数 注释 = "图像宽(指定目标参数时需为2的倍数).">
    参数 图像高度 <类型 = 短整数 注释 = "图像高(指定目标参数时需为2的倍数).">
    参数 帧率 <类型 = 小数 注释 = "帧率fps(大于1/16).">
    参数 码率 <类型 = 整数 注释 = "码率kbps(128-16*1024).">
    参数 存放路径 <类型 = 文本型 注释 = "录像文件存放路径.">
    参数 录像格式 <类型 = 整数 注释 = "录像格式,1表示AVI格式,目前仅支持AVI." @默认值 = 1>
    {
        @ MV_CC_RECORD_PARAM stRecordParam;
        @ memset(&stRecordParam, 0, sizeof(MV_CC_RECORD_PARAM));
        @ stRecordParam.enPixelType = (MvGvspPixelType)@<像素格式>;
        @ stRecordParam.nWidth = (USHORT)@<图像宽度>;
        @ stRecordParam.nHeight = (USHORT)@<图像高度>;
        @ stRecordParam.fFrameRate = (FLOAT)@<帧率>;
        @ stRecordParam.nBitRate = (USHORT)@<码率>;
        @ stRecordParam.enRecordFmtType = (MV_RECORD_FORMAT_TYPE)@<录像格式>;
        @ CU8String u8str (@<存放路径>.GetText ());    //避免存在中文.
        @ stRecordParam.strFilePath = (char *)u8str.GetText();
        @ return MV_CC_StartRecord (this->data().GetDeviceHandle(), &stRecordParam);
    }

    方法 输入录像数据 <公开 类型 = 整数 注释 = "输入录像数据." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲输入的录像数据.">
    {
        @ MV_CC_INPUT_FRAME_INFO stInputFrameInfo = {0};
        @ stInputFrameInfo.pData = (unsigned char*)@<数据>.GetPtr();
        @ stInputFrameInfo.nDataLen = (UINT)@<数据>.GetSize();
        @ return MV_CC_InputOneFrame(this->data().GetDeviceHandle(), &stInputFrameInfo);
    }

    方法 停止录像 <公开 类型 = 整数 注释 = "停止录像." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    {
        @ MV_CC_StopRecord(@sn<this>.data().GetDeviceHandle())
    }

    方法 清除GenICam节点缓存 <公开 类型 = 整数 注释 = "在加载工业相机节点时需要读取GenICam配置文件,该方法可以起到清除GenICam缓存的功能."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    {
        @ MV_CC_InvalidateNodes(@sn<this>.data().GetDeviceHandle())
    }

    方法 置GVCP命令超时 <公开 类型 = 整数 注释 = "设置GVCP命令超时时间,仅用于GIGE设备." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 超时 <类型 = 整数 注释 = "提供所欲设置的超时时间,单位:毫秒.">
    {
        @ MV_GIGE_SetGvcpTimeout(@sn<this>.data().GetDeviceHandle(), (UINT)@<超时>)
    }

    方法 置重传GVCP命令次数 <公开 类型 = 整数 注释 = "该方法用于在GVCP包传输异常时,增加重传的次数,在一定程度上可以避免设备掉线,仅用于GIGE设备."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 次数 <类型 = 整数 注释 = "提供所欲设置的重传次数,范围:0-100">
    {
        @ MV_GIGE_SetRetryGvcpTimes(@sn<this>.data().GetDeviceHandle(), (UINT)@<次数>)
    }

    方法 取重传GVCP命令次数 <公开 类型 = 整数 注释 = "获取当前设备所设置的GVCP重传次数,仅用于GIGE设备." 返回值注释 = "返回所设置的重传次数." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_GIGE_GetRetryGvcpTimes(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 置U3V传输包尺寸 <公开 类型 = 整数 注释 = "增加传输包大小可以适当降低取流时的CPU占用率,但不同的PC和不同USB扩展卡存在不同的兼容性,如果参数设置过大可能会出现取不到图像的风险."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 尺寸 <类型 = 整数 注释 = "提供所欲设置的传输的包大小,单位:字节.">
    {
        @ MV_USB_SetTransferSize(@sn<this>.data().GetDeviceHandle(), (UINT)@<尺寸>)
    }

    方法 取U3V传输包尺寸 <公开 类型 = 整数 注释 = "获取当前设备所设置的传输包尺寸,仅用于USB3设备." 返回值注释 = "返回所设置的传输包尺寸." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_USB_GetTransferSize(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 置U3V传输通道个数 <公开 类型 = 整数 注释 = "可以根据PC的性能,设备出图帧率,图像大小和内存使用率等因素对该参数进行调节,但不同的PC和不同的USB扩展卡存在不同的兼容性."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 个数 <类型 = 整数 注释 = "提供所欲设置的传输通道个数,范围:1-10">
    {
        @ MV_USB_SetTransferWays(@sn<this>.data().GetDeviceHandle(), (UINT)@<个数>)
    }

    方法 取U3V传输通道个数 <公开 类型 = 整数 注释 = "获取当前设置的U3V异步取流节点个数,2000W设备的MONO8默认为3个,YUV为默认2个,RGB为默认1个,其它情况默认8个节点." 返回值注释 = "返回传输通道个数."
            @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_USB_GetTransferWays(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 本地升级设备 <公开 类型 = 整数 注释 = "通过本方法可以将升级固件文件发送给设备进行升级,该接口需要等待升级固件文件成功传给设备端之后再返回,响应时间可能较长."
            返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
    参数 文件名 <类型 = 文本型 注释 = "提供升级固件文件.">
    {
        @ MV_CC_LocalUpgrade(@sn<this>.data().GetDeviceHandle(), (const void*)GetMbsText(@<文件名>.GetText(), CVolMem(), NULL))
    }

    方法 取当前升级进度 <公开 类型 = 整数 注释 = "获取升级进度." 返回值注释 = "返回当前进度值." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ UINT value = 0;
        @ INT ret = MV_CC_GetUpgradeProcess(this->data().GetDeviceHandle(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 取相机属性树 <公开 类型 = 整数 注释 = "获取相机属性树XML." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @禁止流程检查 = 真>
    参数 返回数据 <类型 = 字节集类 注释 = "提供接收数据的缓冲区变量,获取的结果将写入至该变量.">
    {
        @ UINT nDataLen = 0;
        @ INT ret;
        @ ret = MV_XML_GetGenICamXML(this->data().GetDeviceHandle(), NULL, 0, &nDataLen);
        @ if (nDataLen > 0)
        @ {
        @     @<返回数据>.Alloc(nDataLen, TRUE);
        @     ret = MV_XML_GetGenICamXML(this->data().GetDeviceHandle(), (unsigned char*)@<返回数据>.GetPtr(), (UINT)@<返回数据>.GetSize(), &nDataLen);
        @ }
        @ return ret;
    }

    方法 取指定节点访问模式 <公开 类型 = 相机属性树节点访问模式 注释 = "获得指定节点的访问模式." @禁止流程检查 = 真>
    参数 节点名称 <类型 = 文本型 注释 = "提供所欲检查的节点名称.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_XML_AccessMode value = MV_XML_AccessMode::AM_Undefined;
        @ INT ret = MV_XML_GetNodeAccessMode(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<节点名称>.GetText(), CVolMem(), NULL), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    方法 取指定节点接口类型 <公开 类型 = 相机属性树节点接口类型 注释 = "获得指定节点的类型." @禁止流程检查 = 真>
    参数 节点名称 <类型 = 文本型 注释 = "提供所欲检查的节点名称.">
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ MV_XML_InterfaceType value = MV_XML_InterfaceType::IFT_IValue;
        @ INT ret = MV_XML_GetNodeInterfaceType(this->data().GetDeviceHandle(), (const char*)GetMbsText(@<节点名称>.GetText(), CVolMem(), NULL), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return (INT)value;
    }

    # 事件 ---

    方法 收到异常消息 <公开 定义事件 类型 = 整数 注释 = "运行过程中如果设备发送异常消息,本事件将被发送.">
    参数 消息类型 <类型 = 整数 注释 = "提供本次设备异常的消息类型,请参考\"相机异常消息类型\"所提供的常量值.">

    方法 收到设备事件 <公开 定义事件 类型 = 整数 注释 = "在设备被成功打开后,相机有事件回调时本事件将被发送.">
    参数 事件名称 <类型 = 文本型 注释 = "提供本次事件的事件名称.">
    参数 事件ID <类型 = 短整数 注释 = "提供本次事件的事件序号.">
    参数 流通道序号 <类型 = 短整数>
    参数 帧号高位 <类型 = 整数>
    参数 帧号低位 <类型 = 整数>
    参数 时间戳高位 <类型 = 整数>
    参数 时间戳低位 <类型 = 整数>
    参数 数据 <类型 = 字节集类>

    方法 收到图像采集数据 <公开 定义事件 类型 = 整数 注释 = "在调用了\"注册图像数据采集回调\"并且开始取流后,如果采集到图像数据将通过本事件发送.">
    参数 数据指针 <类型 = 变整数>
    参数 图像信息 <类型 = 图像数据信息>
}

