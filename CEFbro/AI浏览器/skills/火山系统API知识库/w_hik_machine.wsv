    参数 图像高度 <类型 = 短整数 注释 = "需提供原始图像的高度.">
    参数 原像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 新像素格式 <类型 = 图像像素格式 注释 = "提供所欲转换到的新像素格式.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        返回 (转换图像像素格式2 (图像数据.取字节集指针 (), 图像数据.取字节集长度 (), 图像宽度, 图像高度, 原像素格式, 新像素格式, 输出数据))
    }

    方法 转换图像像素格式2 <公开 类型 = 整数 注释 = "同\"转换图像像素格式\"方法基本一致,不同的是本方法的数据需要提供数据指针方式而非字节集方式." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值."
            @禁止流程检查 = 真>
    参数 数据指针 <类型 = 变整数 注释 = "提供采集到的原始图像数据指针.">
    参数 数据长度 <类型 = 整数 注释 = "提供数据指针指向数据的长度.">
    参数 图像宽度 <类型 = 短整数 注释 = "需提供原始图像的宽度.">
    参数 图像高度 <类型 = 短整数 注释 = "需提供原始图像的高度.">
    参数 原像素格式 <类型 = 图像像素格式 注释 = "提供采集到的原始图像的像素格式.">
    参数 新像素格式 <类型 = 图像像素格式 注释 = "提供所欲转换到的新像素格式.">
    参数 输出数据 <类型 = 字节集类 注释 = "提供存放图像数据的变量,务必提供足够长度的空间,转换后将图像数据写入至该变量.">
    {
        @ MV_CC_PIXEL_CONVERT_PARAM stCvtParam = {0};
        @ stCvtParam.enSrcPixelType = (MvGvspPixelType)@<原像素格式>;
        @ stCvtParam.enDstPixelType = (MvGvspPixelType)@<新像素格式>;
        @ stCvtParam.nWidth = (USHORT)@<图像宽度>;
        @ stCvtParam.nHeight = (USHORT)@<图像高度>;
        @ stCvtParam.pSrcData = (unsigned char*)@<数据指针>;
        @ stCvtParam.nSrcDataLen = (UINT)@<数据长度>;
        @ stCvtParam.pDstBuffer = (unsigned char*)@<输出数据>.GetPtr();
        @ stCvtParam.nDstBufferSize = (UINT)@<输出数据>.GetSize();
        @ INT ret = MV_CC_ConvertPixelType(this->data().GetDeviceHandle(), &stCvtParam);
        @ if (ret == MV_OK)
        @     @<输出数据>.Realloc(stCvtParam.nDstLen);
        @ else
        @     @<输出数据>.Free();
        @ return ret;
    }

    方法 置Bayer插值算法类型 <公开 类型 = 整数 注释 = "设置内部图像转换接口的Bayer插值算法类型." 返回值注释 = "返回执行是否成功,请参考\"工业相机状态码\"所提供的常量值." @嵌入式方法 = "">
