    # <> </include>
    # @end

    方法 取设备组播状态 <公开 类型 = 逻辑型 注释 = "获取该设备的组播状态,无需打开设备即可获取其状态." 返回值注释 = "返回真表示处于组播状态,反之则未处于组播." @禁止流程检查 = 真>
    参数 结果 <类型 = 整数类 注释 = "提供变量以接收本次执行的结果,值可参考\"工业相机状态码\"所提供的常量值." @默认值 = 空对象>
    {
        @ bool value = false;
        @ INT ret = MV_GIGE_GetMulticastStatus(this->data().GetDeviceInfo(), &value);
        @ if (!(BOOL)@<结果>.IsNullObject()) *(INT*)@<结果>.GetDataPtr() = ret;
        @ return value;
    }
}

