类 相机取流策略 <公开 注释 = "相机设备的取流策略类型." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 逐帧获取 <公开 值 = @"@MV_GRAB_STRATEGY::MV_GrabStrategy_OneByOne" 注释 = "从旧到新一帧一帧的从输出缓存列表中获取图像,打开设备后默认为该策略.">
    常量 列表最新帧 <公开 值 = @"@MV_GRAB_STRATEGY::MV_GrabStrategy_LatestImagesOnly" 注释 = "仅从输出缓存列表中获取最新的一帧图像,同时清空输出缓存列表.">
    常量 列表最新 <公开 值 = @"@MV_GRAB_STRATEGY::MV_GrabStrategy_LatestImages" 注释 = "从输出缓存列表中获取最新的指定多帧(由\"置输出缓存数量\"方法设置)的图像.">
    常量 等待下帧 <公开 值 = @"@MV_GRAB_STRATEGY::MV_GrabStrategy_UpcomingImage"
            注释 = "在调用取流接口时忽略输出缓存列表中所有图像,并等待设备即将生成的一帧图像.该策略只支持GigE设备.不支持U3V设备.">
}

