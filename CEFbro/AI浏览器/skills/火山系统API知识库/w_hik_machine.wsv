    }
}

类 工业相机状态码 <公开 注释 = "工业相机SDK状态码定义." @文档 = "category = \"辅助类\"">
{
    常量 成功 <公开 类型 = 整数 值 = @MV_OK 注释 = "成功,未出现错误">
    常量 无效句柄 <公开 类型 = 整数 值 = @MV_E_HANDLE 注释 = "错误或无效的句柄">
    常量 功能不支持 <公开 类型 = 整数 值 = @MV_E_SUPPORT 注释 = "不支持的功能">
    常量 缓存已满 <公开 类型 = 整数 值 = @MV_E_SUPPORT 注释 = "缓存已满">
    常量 函数调用顺序错误 <公开 类型 = 整数 值 = @MV_E_CALLORDER 注释 = "函数调用顺序有误">
    常量 参数错误 <公开 类型 = 整数 值 = @MV_E_PARAMETER 注释 = "错误的参数">
    常量 资源申请失败 <公开 类型 = 整数 值 = @MV_E_RESOURCE 注释 = "资源申请失败">
    常量 无数据 <公开 类型 = 整数 值 = @MV_E_NODATA 注释 = "无数据">
    常量 前置条件有误 <公开 类型 = 整数 值 = @MV_E_PRECONDITION 注释 = "前置条件有误,或运行环境已发生变化.">
    常量 版本不匹配 <公开 类型 = 整数 值 = @MV_E_VERSION 注释 = "版本不匹配">
    常量 缓冲区尺寸不足 <公开 类型 = 整数 值 = @MV_E_NOENOUGH_BUF 注释 = "传入的内存空间不足">
    常量 图像异常 <公开 类型 = 整数 值 = @MV_E_ABNORMAL_IMAGE 注释 = "异常图像,可能是丢包导致图像不完整.">
    常量 无法载入动态链接库 <公开 类型 = 整数 值 = @MV_E_LOAD_LIBRARY 注释 = "动态导入DLL失败">
    常量 无可输出缓存 <公开 类型 = 整数 值 = @MV_E_NOOUTBUF 注释 = "没有可输出的缓存">
    常量 加密错误 <公开 类型 = 整数 值 = @MV_E_ENCRYPT 注释 = "加密错误">
