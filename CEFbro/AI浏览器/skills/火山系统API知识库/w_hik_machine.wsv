类 相机数据传输模式 <公开 注释 = "定义设备的网络传输模式." @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 单播 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_UNICAST" 注释 = "表示单播(默认)">
    常量 组播 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_MULTICAST" 注释 = "表示组播">
    常量 局域网广播 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_LIMITEDBROADCAST" 注释 = "表示局域网内广播,暂不支持.">
    常量 子网内广播 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_SUBNETBROADCAST" 注释 = "表示子网内广播,暂不支持.">
    常量 从设备获取 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_CAMERADEFINED" 注释 = "表示从设备获取,暂不支持.">
    常量 自定义接收 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_UNICAST_DEFINED_PORT" 注释 = "表示用户自定义应用端接收图像数据端口号.">
    常量 单播不接收数据 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_UNICAST_WITHOUT_RECV" 注释 = "表示设置了单播,但本实例不接收图像数据.">
    常量 组播不接收数据 <公开 值 = @"@MV_GIGE_TRANSMISSION_TYPE::MV_GIGE_TRANSTYPE_MULTICAST_WITHOUT_RECV" 注释 = "表示组播模式,但本实例不接收图像数据.">
}

