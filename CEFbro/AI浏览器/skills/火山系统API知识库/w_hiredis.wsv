    方法 初始化 <公开 类型 = 整数 注释 = "初始化Redis连接池并连接至指定Redis服务器" 返回值注释 = "返回该连接池中所创建成功的连接数" @嵌入式方法 = "">
    参数 地址 <类型 = 文本型 注释 = "提供所欲连接数据库的地址/IP.">
    参数 端口 <类型 = 整数 注释 = "提供所欲连接数据库的连接端口号." @默认值 = 6379>
    参数 超时 <类型 = 整数 注释 = "提供连接服务器的超时时间,单位:秒." @默认值 = 10>
    参数 密码 <类型 = 文本型 注释 = "提供该库的授权密码,无密码请留空." @默认值 = 空对象>
    参数 库号 <类型 = 整数 注释 = "  提供连接成功后所欲使用的库号索引,默认情况下有16个库,可" 注释 = "提供0-15之间的索引号,如自己设置库数量请提供正确范围内的索引." @默认值 = 0>
    参数 最大连接数 <类型 = 整数 注释 = "连接池中所能创建的最大连接数量." @默认值 = 50>
    参数 初始连接数 <类型 = 整数 注释 = "初始化时所欲创建的可用连接数." @默认值 = 10>
    {
        @ @sn<this>.InitConnectPool(@<地址>, @<端口>, @<超时>, @<密码>, @<库号>, @<最大连接数>, @<初始连接数>)
    }

    方法 取连接 <公开 类型 = 逻辑型 注释 = "  从Redis连接池中取出一个可用的连接,成功返回真,失败返回假." 注释 = "  如果当前连接池中暂无可用连接,将会新建一个连接,如果已达到最大连接数限制时将会等待指定时长,"
            注释 = "超时后将会返回假." 注释 = "  注意:取出的连接使用完毕后务必调用\"释放连接\"方法,否则所取出的连接将一直处于占用状态." 返回值注释 = "返回本次获取的连接是否有效." @嵌入式方法 = "">
    参数 结果连接 <类型 = Redis数据库类 注释 = "如果本方法成功,则所获得连接将填入此结果变量中.">
    参数 繁忙等待时间 <类型 = 整数 注释 = "指定在所有连接都已用尽时所欲等待的时长,提供-1表示无限等待,0表示不等待.单位:毫秒." @默认值 = 10000>
    {
        @ @sn<this>.GetListActivityRedis(@<结果连接>, @<繁忙等待时间>)
    }

    方法 释放连接 <公开 注释 = "释放从连接池中所取出的连接对象,使其在连接池中恢复空闲状态等待被获取." 注释 = "注意:取出的连接使用完毕后务必调用本方法释放,否则所取出的连接将一直处于占用状态." @嵌入式方法 = "">
    参数 连接对象 <类型 = Redis数据库类 注释 = "提供所欲释放的连接对象,必须确认此连接目前不再使用.">
    {
        @ @sn<this>.ReleaseRedis(@<连接对象>)
    }

    方法 释放所有连接 <公开 注释 = "释放连接池中所有的连接对象,使其在连接池中恢复空闲状态等待被获取." 注释 = "调用本方法时必须确认所有连接目前不再使用." @嵌入式方法 = "">
    {
        @ @sn<this>.ReleaseAll()
    }

    方法 销毁连接 <公开 注释 = "销毁连接池中的指定连接,该连接将会从连接池中被移除并断开释放." @嵌入式方法 = "">
    参数 连接对象 <类型 = Redis数据库类 注释 = "提供所欲销毁的连接对象,必须确认此连接不再使用.">
    {
        @ @sn<this>.DestroyRedis(@<连接对象>)
    }

    方法 创建连接 <公开 类型 = 逻辑型 注释 = "在该连接池中新建一个连接,返回创建的结果." 返回值注释 = "如果当前连接池中连接已达最大连接数将会返回失败." @嵌入式方法 = "">
    {
        @ @sn<this>.CreateRedis(NULL)
    }

    方法 取空闲连接数 <公开 类型 = 整数 注释 = "获取当前连接池中空闲的可用连接数." @嵌入式方法 = "">
    {
        @ @sn<this>.GetActiveConnectCount()
    }

    方法 取连接数 <公开 类型 = 整数 注释 = "获取当前连接池中所有的可用连接数(包括所有空闲或正在执行任务的连接)." @嵌入式方法 = "">
    {
        @ @sn<this>.GetConnectCount()
    }
}
