    常量 未授权 <公开 类型 = 短整数 值 = 401 注释 = "UNAUTHORIZED">
    常量 需要付款 <公开 类型 = 短整数 值 = 402 注释 = "PAYMENT_REQUIRED">
    常量 拒绝访问 <公开 类型 = 短整数 值 = 403 注释 = "FORBIDDEN">
    常量 未找到资源 <公开 类型 = 短整数 值 = 404 注释 = "NOT_FOUND">
