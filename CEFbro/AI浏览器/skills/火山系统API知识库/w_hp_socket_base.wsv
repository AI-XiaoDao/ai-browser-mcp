类 HPSocket类 <公开 基础类 = HPSocket基础类 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "提供一些全局方法." @禁止创建对象 = 真>
{

    # Global---

    方法 取HP版本号 <公开 静态 类型 = 整数 注释 = "获取当前库的版本号." 返回值注释 = "4个字节分别对应主版本号,子版本号,修正版本号,构建编号." @嵌入式方法 = "">
    {
        @ (INT)HP_GetHPSocketVersion()
    }

    方法 取错误码描述 <公开 静态 类型 = 文本型 注释 = "获取指定错误代码的描述文本." @嵌入式方法 = "">
    参数 错误码 <类型 = 整数 注释 = "提供所欲获取其文本描述的错误码.">
    {
        @ @an<CVolString> (HP_GetSocketErrorDesc((EnSocketError)@<错误码>))
    }

    方法 取上次错误码 <公开 静态 类型 = 整数 注释 = "获取系统返回的错误代码." @嵌入式方法 = "">
    {
        @ (INT)SYS_GetLastError()
    }

    方法 取上次错误码_WSA <公开 静态 类型 = 整数 注释 = "获取系统返回的错误代码(调用WSAGetLastError()方法)." @嵌入式方法 = "">
    {
        @ (INT)SYS_WSAGetLastError()
    }

    # Cookie管理器 ---

    方法 从文件加载Cookie <公开 静态 类型 = 逻辑型 注释 = "从指定文件加载Cookie." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 目标文件 <类型 = 文本型 注释 = "提供所欲加载Cookie的文件.">
    参数 是否追加 <类型 = 逻辑型 注释 = "指定是否保留已存在的Cookie,提供假将清除原有Cookie." @默认值 = 真>
    {
        @ HP_HttpCookie_MGR_LoadFromFile(GetMbsText (@<目标文件>, CVolMem (), NULL), @<是否追加>)
    }

    方法 保存Cookie到文件 <公开 静态 类型 = 逻辑型 注释 = "将Cookie写出到文件保存." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 目标文件 <类型 = 文本型 注释 = "提供所欲保存Cookie的文件.">
    参数 是否追加 <类型 = 逻辑型 注释 = "指定是否保留文件中已存在的Cookie,提供假将清除原有Cookie." @默认值 = 真>
    {
        @ HP_HttpCookie_MGR_SaveToFile(GetMbsText (@<目标文件>, CVolMem (), NULL), @<是否追加>)
    }

    方法 清理Cookie <公开 静态 类型 = 逻辑型 注释 = "清理指定域名下Cookies." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 域名 <类型 = 文本型 注释 = "提供所欲清除Cookie的域名,提供空将清除所有.">
    参数 路径 <类型 = 文本型 注释 = "路径,提供空文本将清除所有路径.">
    {
        @ HP_HttpCookie_MGR_ClearCookies(GetMbsText (@<域名>,CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL))
    }

    方法 清理过期Cookie <公开 静态 类型 = 逻辑型 注释 = "清理指定域名下过期的Cookies." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 域名 <类型 = 文本型 注释 = "提供所欲清除过期Cookie的域名,提供空将清除所有.">
    参数 路径 <类型 = 文本型 注释 = "路径,提供空文本将清除所有路径.">
    {
        @ HP_HttpCookie_MGR_ClearCookies(GetMbsText (@<域名>, CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL))
    }

    方法 置Cookie <公开 静态 类型 = 逻辑型 注释 = "设置Cookie." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 名称 <类型 = 文本型 注释 = "提供Cookie名称.">
    参数 值 <类型 = 文本型 注释 = "提供Cookie值内容.">
    参数 域名 <类型 = 文本型 注释 = "提供所欲置入的域.">
    参数 路径 <类型 = 文本型 注释 = "提供所欲置入的路径.">
    参数 生命周期 <类型 = 整数 注释 = "即\"MaxAge\"属性.">
    参数 HttpOnly <类型 = 逻辑型 注释 = "即\"HttpOnly\"属性.">
    参数 Secure <类型 = 逻辑型 注释 = "即\"Secure\"属性.">
    参数 SameSite <类型 = 整数 注释 = "即\"SameSite\"属性.">
    参数 已存在更新值 <类型 = 逻辑型 注释 = "如果所欲置入Cookie已存在,是否仅更新其值内容." @默认值 = 真>
    {
        @ HP_HttpCookie_MGR_SetCookie(GetMbsText (@<名称>, CVolMem (), NULL), GetMbsText (@<值>, CVolMem (), NULL), GetMbsText (@<域名>, CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL), @<生命周期>, @<HttpOnly>, @<Secure>, @<SameSite>, @<已存在更新值>)
    }

    方法 删除Cookie <公开 静态 类型 = 逻辑型 注释 = "删除指定Cookie." 返回值注释 = "返回是否操作成功." @嵌入式方法 = "">
    参数 域名 <类型 = 文本型 注释 = "提供所欲删除Cookie所在域.">
    参数 路径 <类型 = 文本型 注释 = "提供所欲删除Cookie所处路径.">
    参数 名称 <类型 = 文本型 注释 = "提供所欲删除Cookie的名称.">
    {
        @ HP_HttpCookie_MGR_DeleteCookie(GetMbsText (@<域名>, CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL), GetMbsText (@<名称>, CVolMem (), NULL))
    }

    方法 置允许三方Cookie <公开 静态 注释 = "设置是否允许第三方Cookie." @嵌入式方法 = "">
    参数 是否允许 <类型 = 逻辑型>
    {
        @ HP_HttpCookie_MGR_SetEnableThirdPartyCookie(@<是否允许>)
    }

    方法 取允许三方Cookie <公开 静态 类型 = 逻辑型 注释 = "获取是否允许第三方Cookie." @嵌入式方法 = "">
    {
        @ HP_HttpCookie_MGR_IsEnableThirdPartyCookie()
    }

    方法 Cookie过期文本到整数 <公开 静态 类型 = 长整数 注释 = "将指定Cookie expires字符串转换为整数." 返回值注释 = "返回时间戳." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "提供所欲转换的Cookie expires内容.">
    {
        @ __time64_t time;
        @ HP_HttpCookie_HLP_ParseExpires(GetMbsText (@<内容>, CVolMem (), NULL), time);
        @ return time;
    }

    方法 Cookie过期整数到文本 <公开 静态 类型 = 逻辑型 注释 = "将指定时间戳转换为Cookie expires内容." 返回值注释 = "返回是否操作成功." 编辑时信息 = "9AAA1, 0, 0, 0" @禁止流程检查 = 真>
    参数 时间戳 <类型 = 长整数 注释 = "提供所欲转换的expires时间." 编辑时信息 = "9AAA1, 0, 0, 0">
    参数 内容 <类型 = 文本型 注释 = "转换成功将返回Cookie expires内容.">
    {
        @ int len = 0;
        @ HP_HttpCookie_HLP_MakeExpiresStr(nullptr, len, @<时间戳>);
        @ char *str2 = new char[len];
        @ BOOL isSuccess = HP_HttpCookie_HLP_MakeExpiresStr(str2, len, @<时间戳>);
        @ if (isSuccess) @<内容>.SetText(str2);
        @ delete[] str2;
        @ return isSuccess;
    }

    方法 生成Cookie内容 <公开 静态 类型 = 逻辑型 注释 = "提供指定Cookie属性生成一个Cookie字符串." 返回值注释 = "返回是否生成成功." @禁止流程检查 = 真>
    参数 名称 <类型 = 文本型 注释 = "提供Cookie名称.">
    参数 值 <类型 = 文本型 注释 = "提供Cookie值内容.">
    参数 域名 <类型 = 文本型 注释 = "提供所欲置入的域.">
    参数 路径 <类型 = 文本型 注释 = "提供所欲置入的路径.">
    参数 生命周期 <类型 = 整数 注释 = "即\"MaxAge\"属性.">
    参数 HttpOnly <类型 = 逻辑型 注释 = "即\"HttpOnly\"属性.">
    参数 Secure <类型 = 逻辑型 注释 = "即\"Secure\"属性.">
    参数 SameSite <类型 = 整数 注释 = "即\"SameSite\"属性.">
    参数 内容 <类型 = 文本型 注释 = "转换成功将返回所生成的Cookie内容.">
    {
        @ int len = 0;
        @ HP_HttpCookie_HLP_ToString(nullptr, len, GetMbsText (@<名称>, CVolMem (), NULL), GetMbsText (@<值>, CVolMem (), NULL), GetMbsText (@<域名>,CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL), @<生命周期>, @<HttpOnly>, @<Secure>, @<SameSite>);
        @ char *str = new char[len + 1];
        @ BOOL isSuccess = HP_HttpCookie_HLP_ToString(str, len, GetMbsText (@<名称>, CVolMem (), NULL), GetMbsText (@<值>, CVolMem (), NULL), GetMbsText (@<域名>, CVolMem (), NULL), GetMbsText (@<路径>, CVolMem (), NULL), @<生命周期>, @<HttpOnly>, @<Secure>, @<SameSite>);
        @ if (isSuccess) @<内容>.SetText (GetWideText (str, CVolMem (), NULL));
        @ delete[] str;
        @ return isSuccess;
    }

    方法 取当前UTC时间 <公开 静态 类型 = 长整数 注释 = "获取当前UTC时间." @嵌入式方法 = "">
    {
        @ (INT64)HP_HttpCookie_HLP_CurrentUTCTime()
    }

    方法 Cookie最大时间到过期时间 <公开 静态 类型 = 长整数 注释 = "将指定Cookie MaxAge属性转换为过期时间." @嵌入式方法 = "">
    参数 MaxAge <类型 = 整数>
    {
        @ (INT64)HP_HttpCookie_HLP_MaxAgeToExpires(@<MaxAge>)
    }

    方法 Cookie过期时间到最大时间 <公开 静态 类型 = 整数 注释 = "将指定Cookie Expires属性转换为MaxAge." @嵌入式方法 = "">
    参数 Expires <类型 = 长整数>
    {
        @ HP_HttpCookie_HLP_ExpiresToMaxAge(@<Expires>)
    }

    方法 取主机IP地址 <公开 静态 类型 = 文本数组类 注释 = "获取指定主机IPV4地址." @禁止流程检查 = 真>
    参数 主机名 <类型 = 文本型 注释 = "提供空文本则表示获取本机." @默认值 = "">
    {
        变量 返回结果 <类型 = 文本数组类>
        @ int count = 0;
        @ LPTIPAddr* adds = nullptr;
        @ if (SYS_EnumHostIPAddresses(@<主机名>, IPT_IPV4, &adds, count))
        @ {
        @     for (INT i = 0; i < count && count <= 10; i++)
        @     {
        @         @<返回结果>.data ().Add (adds[i]->address);
        @     }
        @ }
        @ SYS_FreeHostIPAddresses(adds);
        @ return @<返回结果>;
    }

    方法 取主机IPV6地址 <公开 静态 类型 = 文本数组类 注释 = "获取主机IPV6地址." @禁止流程检查 = 真>
    参数 主机名 <类型 = 文本型 注释 = "提供空文本则表示获取本机." @默认值 = "">
    {
        变量 返回结果 <类型 = 文本数组类>
        @ int count = 0;
        @ LPTIPAddr* adds = nullptr;
        @ if (SYS_EnumHostIPAddresses(@<主机名>, IPT_IPV6, &adds, count))
        @ {
        @     for (INT i = 0; i < count && count <= 10; i++)
        @     {
        @         @<返回结果>.data ().Add (adds[i]->address);
        @     }
        @ }
        @ SYS_FreeHostIPAddresses(adds);
        @ return @<返回结果>;
    }

    方法 压缩数据 <公开 静态 类型 = 字节集类 注释 = "对指定数据进行Zlib压缩." 返回值注释 = "返回被压缩后的数据." @禁止流程检查 = 真>
    参数 欲压缩数据 <类型 = 字节集类 注释 = "提供所欲压缩的数据.">
    参数 压缩级别 <类型 = 整数 注释 = "0-9之间,级别越高压缩率越大,相应的压缩时间会变长." @默认值 = -1>
    参数 压缩位数 <类型 = 整数 注释 = "8-15,表示处理raw deflate的方法." @默认值 = 15>
    参数 压缩状态 <类型 = 整数 注释 = "指定分配内存的等级,1-9之间,1会使用最低的内存,压缩时间最长." @默认值 = 8>
    参数 压缩算法 <类型 = 整数 注释 = "指定所欲使用的压缩算法." @默认值 = 0>
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_GuessCompressBound((INT)@<欲压缩数据>.GetSize(), FALSE);
        @ SYS_CompressEx(@<欲压缩数据>.GetPtr(), (INT)@<欲压缩数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen, @<压缩级别>, 8, @<压缩位数>, @<压缩状态>, @<压缩算法>);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 解压数据 <公开 静态 类型 = 整数 注释 = "对指定数据进行Zlib解压." 返回值注释 = "返回解压的结果." 返回值注释 = "0->解压成功." 返回值注释 = "-3->提供的解压数据不正确."
            返回值注释 = "-5->输出缓冲区尺寸不足,需要分配更大空间." @禁止流程检查 = 真>
    参数 欲解压数据 <类型 = 字节集类 注释 = "提供所欲解压的数据.">
    参数 输出缓冲区 <类型 = 字节集类 注释 = "提供的字节集必须先预分配足够的空间.">
    参数 压缩位数 <类型 = 整数 注释 = "8-15,表示处理raw deflate的方法." @默认值 = 15>
    {
        @ DWORD dwDestLen;
        @ return SYS_UncompressEx(@<欲解压数据>.GetPtr(), (INT)@<欲解压数据>.GetSize(), @<输出缓冲区>.GetPtr(), dwDestLen, @<压缩位数>);
    }

    方法 压缩数据_GZip <公开 静态 类型 = 字节集类 注释 = "对指定数据进行GZip压缩." 返回值注释 = "返回被压缩后的数据." @禁止流程检查 = 真>
    参数 欲压缩数据 <类型 = 字节集类 注释 = "提供所欲压缩的数据.">
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_GuessCompressBound((INT)@<欲压缩数据>.GetSize(), TRUE);
        @ SYS_GZipCompress(@<欲压缩数据>.GetPtr(), (INT)@<欲压缩数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 解压数据_GZip <公开 静态 类型 = 字节集类 注释 = "对指定数据进行GZip解压." 返回值注释 = "返回被解压后的数据." @禁止流程检查 = 真>
    参数 欲解压数据 <类型 = 字节集类 注释 = "提供所欲解压的数据.">
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_GZipGuessUncompressBound(@<欲解压数据>.GetPtr(), (INT)@<欲解压数据>.GetSize());
        @ SYS_GZipUncompress(@<欲解压数据>.GetPtr(), (INT)@<欲解压数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 Base64编码 <公开 静态 类型 = 字节集类 注释 = "将指定数据进行Base64编码." 返回值注释 = "返回编码后的数据." @禁止流程检查 = 真>
    参数 欲编码数据 <类型 = 字节集类 注释 = "提供所欲进行编码的数据.">
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_GuessBase64EncodeBound((INT)@<欲编码数据>.GetSize());
        @ SYS_Base64Encode(@<欲编码数据>.GetPtr(), (INT)@<欲编码数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 Base64解码 <公开 静态 类型 = 字节集类 注释 = "将指定数据进行Base64解码." 返回值注释 = "返回解码后的数据." @禁止流程检查 = 真>
    参数 欲解码数据 <类型 = 字节集类 注释 = "提供所欲进行解码的数据.">
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_GuessBase64DecodeBound(@<欲解码数据>.GetPtr(), (INT)@<欲解码数据>.GetSize());
        @ SYS_Base64Decode(@<欲解码数据>.GetPtr(), (INT)@<欲解码数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 URL编码 <公开 静态 类型 = 字节集类 注释 = "将指定数据进行URL编码." 返回值注释 = "返回编码后的数据." @禁止流程检查 = 真>
