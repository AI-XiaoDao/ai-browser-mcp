类 HP请求头数组类 <公开 基础类 = 对象数组模板类 注释 = "实现一个键/值数组列表类型." @文档 = "category = \"辅助类\"" @模板实现类 = "HP请求头类">
{
    方法 检查加入头成员 <公开 静态>
    参数 欲操作本对象 <类型 = HP请求头数组类>
    参数 参数1 <类型 = HP请求头类>
    {
        欲操作本对象.枚举循环 ()
        {
            如果 (欲操作本对象.取枚举值 ().名称 == 参数1.名称)
            {
                欲操作本对象.取枚举值 ().值 = 参数1.值
                返回
            }
        }
        欲操作本对象.加入成员 (参数1)
    }
}

类 HPHTTP状态码 <公开 注释 = "定义HTTP状态码." 编辑时信息 = "CFFF3, 0, 0, 0" @文档 = "category = \"辅助类\"">
{
