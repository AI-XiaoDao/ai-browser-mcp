        @ SYS_UrlDecode(@<欲解码数据>.GetPtr(), (INT)@<欲解码数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 压缩数据_Brotli <公开 静态 类型 = 字节集类 注释 = "将指定数据使用Brotli算法进行无损压缩后返回" @禁止流程检查 = 真>
    参数 欲压缩数据 <类型 = 字节集类 注释 = "提供所欲对其进行压缩的数据">
    {
        变量 目标 <类型 = 字节集类>
        @ DWORD dwDestLen = SYS_BrotliGuessCompressBound((INT)@<欲压缩数据>.GetSize());
        @ SYS_BrotliCompress(@<欲压缩数据>.GetPtr(), (INT)@<欲压缩数据>.GetSize(), @<目标>.Alloc (dwDestLen, TRUE), dwDestLen);
        @ return @<目标>.GetBinLeft (dwDestLen);
    }

    方法 解压数据_Brotli <公开 静态 类型 = 整数 注释 = "将指定使用Brotli压缩算法压缩后的数据进行解压后返回"
            返回值注释 = "返回0表示解压成功,返回-3表示所提供的压缩数据不正确,返回-5表示所提供的数据缓冲区尺寸不足,需增加尺寸后重试." @禁止流程检查 = 真>
    参数 欲解压数据 <类型 = 字节集类 注释 = "提供所欲对其进行解压的数据">
    参数 数据缓冲区 <类型 = 字节集类 注释 = "解压成功后数据将写入该参数">
    参数 数据长度 <类型 = 整数类 注释 = "解压成功后数据的真实长度将写入该参数">
    {
        @ DWORD dwDestLen = @<数据缓冲区>.GetSize();
        @ INT ret = SYS_BrotliUncompress(@<欲解压数据>.GetPtr(), (INT)@<欲解压数据>.GetSize(), @<数据缓冲区>.GetPtr (), dwDestLen);
        @ if (ret == 0)
        @     @<数据长度.值> = dwDestLen;
        @ return ret;
    }
}

类 HP线程池类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "可用于执行异步任务的线程池类." @强制依赖 = "HPSocket基础类"
        @视窗.后缀文本 = "public IHPThreadPoolListener">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CHPSocketThreadPoolWraper)
    #

    方法 创建 <公开 注释 = "主动创建线程池,可设置是否监听线程池的各种事件." 注释 = "注:如不主动创建将自动创建,不会启用监听事件,如已经使用过该对象再调用本方法将会被忽略.">
    参数 是否监听 <类型 = 逻辑型 注释 = "设置是否监听线程池中发生的各种事件,譬如:\"线程池已启动\" / \"线程即将执行\"等系列事件.">
    {
        @ data().GetData(@<是否监听> ? this : nullptr);
    }

    方法 启动状态 <公开 属性读 类型 = 逻辑型 注释 = "检查当前线程池是否已经启动." @嵌入式方法 = "">
    {
        @ @sn<this>.GetPoolPtr()->HasStarted()
    }

    方法 运行状态 <公开 属性读 类型 = HP状态 注释 = "检查当前线程池当前的运行状态." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetState()
    }

    方法 任务等待数量 <公开 属性读 类型 = 整数 注释 = "检查当前线程池中处于等待队列中的任务数量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetQueueSize()
    }

    方法 正在执行数量 <公开 属性读 类型 = 整数 注释 = "检查当前线程池中处于执行中的任务数量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetTaskCount()
    }

    方法 工作线程数量 <公开 属性读 类型 = 整数 注释 = "检查当前线程池的工作线程数量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetThreadCount()
    }

    方法 队列最大容量 <公开 属性读 类型 = 整数 注释 = "检查当前线程池的任务队列最大容量." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetMaxQueueSize()
    }

    方法 任务拒绝策略 <公开 属性读 类型 = HP线程任务拒绝策略 注释 = "检查当前线程池所使用的任务拒绝策略." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.GetPoolPtr()->GetRejectedPolicy()
    }

    # 方法 ---

    方法 启动 <公开 类型 = 逻辑型 注释 = "启动线程池组件并设定线程池运行参数." 编辑时信息 = "52AA5, 0, 0, 0" @嵌入式方法 = "">
    参数 线程数量 <类型 = 整数 注释 = "默认为0,即(CPU核数 * 2 + 2)." 编辑时信息 = "52AA5, 0, 0, 0" @默认值 = 0>
    参数 队列容量 <类型 = 整数 注释 = "任务队列最大容量,默认为0,即不限制." 编辑时信息 = "52AA5, 0, 0, 0" @默认值 = 0>
    参数 拒绝策略 <类型 = HP线程任务拒绝策略 注释 = "当任务无法处理时所欲使用的策略." 编辑时信息 = "52AA5, 0, 0, 0" @默认值 = HP线程任务拒绝策略.立即返回失败>
    参数 堆栈大小 <类型 = 整数 注释 = "线程堆栈空间大小(默认为0,即由操作系统默认)." @默认值 = 0>
    {
        @ @sn<this>.GetPoolPtr()->Start(@<线程数量>, @<队列容量>, (EnRejectedPolicy)@<拒绝策略>, @<堆栈大小>)
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "关闭线程池组件,在线程池不再使用之后可以调用本方法进行关闭." @嵌入式方法 = "">
    参数 等待时间 <类型 = 整数 注释 = "单位:毫秒,默认-1即无限等待.如果在此等待时间内未能正常关闭,此时会尝试强制关闭." @默认值 = -1>
    {
        @ @sn<this>.GetPoolPtr()->Stop(@<等待时间>)
    }

    方法 等待 <公开 类型 = 逻辑型 注释 = "等待线程池组件停止运行." @嵌入式方法 = "">
    参数 超时时间 <类型 = 整数>
    {
        @ @sn<this>.GetPoolPtr()->Wait(@<超时时间>)
    }

    方法 置线程数量 <公开 类型 = 逻辑型 注释 = "动态调整该线程池可工作线程的数量." @嵌入式方法 = "">
    参数 线程数量 <类型 = 整数 注释 = "默认为0,即(CPU核数 * 2 + 2).">
    {
        @ @sn<this>.GetPoolPtr()->AdjustThreadCount(@<线程数量>)
    }

    方法 提交任务 <公开 类型 = 逻辑型 注释 = "提交新任务至当前线程池组件中等待执行,注意使用本方法提交的线程将不会触发\"任务启动\"事件." 注释 = "" 返回值注释 = "返回任务是否提交成功." @嵌入式方法 = "">
    参数 执行函数 <注释 = "提供所欲执行的线程函数." @匹配方法 = "线程模板函数">
    参数 用户数据 <类型 = 变整数 注释 = "自定义用户数据,将会在线程执行函数中提供数据." @默认值 = 0>
    参数 等待时间 <类型 = 整数 注释 = "单位:毫秒,默认-1即无限等待." 注释 = "注意:仅在\"拒绝策略\"为立即返回失败时有效." @默认值 = -1>
    {
        @ @sn<this>.GetPoolPtr()->Submit((Fn_TaskProc)&@<执行函数>, (PVOID)@<用户数据>, @<等待时间>)
    }

    方法 线程模板函数 <静态 注释 = "提供线程执行函数的模板方法.">
    参数 用户数据 <类型 = 变整数 注释 = "在提交任务时所提供的用户数据参数.">

    # ---

    方法 线程池已启动 <公开 定义事件 类型 = 整数 注释 = "当线程池启动成功本事件将被发送">

    方法 线程池已关闭 <公开 定义事件 类型 = 整数 注释 = "当线程池关闭后本事件将被发送">

    方法 线程已就绪 <公开 定义事件 类型 = 整数 注释 = "当线程池中的任意一条工作线程准备就绪后本事件将被发送">
    参数 线程ID <类型 = 变整数>

    方法 线程已退出 <公开 定义事件 类型 = 整数 注释 = "当线程池中的任意一条工作线程已执行完毕退出后本事件将被发送">
    参数 线程ID <类型 = 变整数>

    #
    # @begin
    #
    # <> <include>
    # inline_ IHPThreadPool* GetPoolPtr() { return data().GetData(); }
    #
    # @ virtual void OnStartup(IHPThreadPool* pThreadPool) override  {  @<线程池已启动> ();  }
    # @ virtual void OnShutdown(IHPThreadPool* pThreadPool) override  {  @<线程池已关闭> ();  }
    # @ virtual void OnWorkerThreadStart(IHPThreadPool* pThreadPool, THR_ID dwThreadID) override  {  @<线程已就绪> (dwThreadID);  }
    # @ virtual void OnWorkerThreadEnd(IHPThreadPool* pThreadPool, THR_ID dwThreadID) override  {  @<线程已退出> (dwThreadID);  }
    # <> </include>
    #
    # @end
}

