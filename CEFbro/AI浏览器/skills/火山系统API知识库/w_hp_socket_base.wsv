    常量 不允许的请求 <公开 类型 = 短整数 值 = 406 注释 = "NOT_ACCEPTABLE">
    常量 需要代理服务器认证身份 <公开 类型 = 短整数 值 = 407 注释 = "PROXY_AUTHENTICATION_REQUIRED">
    常量 请求超时 <公开 类型 = 短整数 值 = 408 注释 = "REQUEST_TIMEOUT">
    常量 资源状态冲突 <公开 类型 = 短整数 值 = 409 注释 = "CONFLICT">
    常量 资源过期 <公开 类型 = 短整数 值 = 410 注释 = "GONE">
    常量 需要表明长度 <公开 类型 = 短整数 值 = 411 注释 = "LENGTH_REQUIRED">
    常量 未满足先决条件 <公开 类型 = 短整数 值 = 412 注释 = "PRECONDITION_FAILED">
    常量 请求体太大 <公开 类型 = 短整数 值 = 413 注释 = "REQUEST_ENTITY_TOO_LARGE">
    常量 请求域太长 <公开 类型 = 短整数 值 = 414 注释 = "REQUEST_URI_TOO_LONG">
    常量 不支持的媒体类型 <公开 类型 = 短整数 值 = 415 注释 = "UNSUPPORTED_MEDIA_TYPE">
    常量 不满足请求范围 <公开 类型 = 短整数 值 = 416 注释 = "REQUESTED_RANGE_NOT_SATISFIABLE">
    常量 预期结果失败 <公开 类型 = 短整数 值 = 417 注释 = "EXPECTATION_FAILED">
    常量 错误的请求 <公开 类型 = 短整数 值 = 421 注释 = "MISDIRECTED_REQUEST">
    常量 无法遵循的语义错误 <公开 类型 = 短整数 值 = 422 注释 = "UNPROCESSABLE_ENTITY">
    常量 已锁定 <公开 类型 = 短整数 值 = 423 注释 = "LOCKED">
    常量 失败的依赖项 <公开 类型 = 短整数 值 = 424 注释 = "FAILED_DEPENDENCY">
    常量 无序收集 <公开 类型 = 短整数 值 = 425 注释 = "UNORDERED_COLLECTION">
    常量 需要升级协议 <公开 类型 = 短整数 值 = 426 注释 = "UPGRADE_REQUIRED">
    常量 需要条件请求 <公开 类型 = 短整数 值 = 428 注释 = "PRECONDITION_REQUIRED">
    常量 请求过多 <公开 类型 = 短整数 值 = 429 注释 = "TOO_MANY_REQUESTS">
    常量 请求头过大 <公开 类型 = 短整数 值 = 431 注释 = "REQUEST_HEADER_FIELDS_TOO_LARGE">
    常量 因法律不可用 <公开 类型 = 短整数 值 = 451 注释 = "UNAVAILABLE_FOR_LEGAL_REASONS">
    常量 使用重试 <公开 类型 = 短整数 值 = 449 注释 = "RETRY_WITH">
    常量 服务器内部错误 <公开 类型 = 短整数 值 = 500 注释 = "INTERNAL_SERVER_ERROR">
    常量 尚未实现 <公开 类型 = 短整数 值 = 501 注释 = "NOT_IMPLEMENTED">
    常量 错误网关 <公开 类型 = 短整数 值 = 502 注释 = "BAD_GATEWAY">
    常量 服务不可用 <公开 类型 = 短整数 值 = 503 注释 = "SERVICE_UNAVAILABLE">
    常量 网关超时 <公开 类型 = 短整数 值 = 504 注释 = "GATEWAY_TIMEOUT">
    常量 HTTP版本不支持 <公开 类型 = 短整数 值 = 505 注释 = "HTTP_VERSION_NOT_SUPPORTED">
    常量 服务器存在内部配置错误 <公开 类型 = 短整数 值 = 506 注释 = "VARIANT_ALSO_NEGOTIATES">
    常量 服务器无法存储 <公开 类型 = 短整数 值 = 507 注释 = "INSUFFICIENT_STORAGE">
    常量 发现无穷循环 <公开 类型 = 短整数 值 = 508 注释 = "LOOP_DETECTED">
    常量 流量超限 <公开 类型 = 短整数 值 = 509 注释 = "BANDWIDTH_LIMIT_EXCEEDED">
    常量 未扩展 <公开 类型 = 短整数 值 = 510 注释 = "NOT_EXTENDED">
    常量 需要网络验证 <公开 类型 = 短整数 值 = 511 注释 = "NETWORK_AUTHENTICATION_REQUIRED">
    常量 无法解析响应头 <公开 类型 = 短整数 值 = 600 注释 = "UNPARSEABLE_RESPONSE_HEADERS">
}

类 HPURL字段 <公开 注释 = "本常量类定义了HP_HTTP服务器可以取得的URL域值字段名." @文档 = "category = \"辅助类\"" @常量类 = 短整数>
{
    常量 概要 <公开 值 = 0 注释 = "当前所请求概要">
    常量 主机 <公开 值 = 1 注释 = "当前所请求主机">
    常量 端口 <公开 值 = 2 注释 = "当前所请求端口">
    常量 路径 <公开 值 = 3 注释 = "当前所请求路径,即请求文件的路径">
    常量 查询 <公开 值 = 4 注释 = "当前所请求查询文本,即GET访问?后面的参数">
    常量 片段 <公开 值 = 5 注释 = "当前所请求片段">
    常量 用户信息 <公开 值 = 6 注释 = "当前所请求用户信息">
    常量 字段数量 <公开 值 = 7>
}

类 HP线程任务拒绝策略 <公开 编辑时信息 = "AAAA0, 0, 0, 0" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 立即返回失败 <公开 值 = 0 注释 = "当任务无法执行时直接返回失败.">
    常量 等待 <公开 值 = 1 注释 = "等待(直到执行成功,超时或线程池关闭等原因导致失败).">
    常量 调用者线程执行 <公开 值 = 2 注释 = "转到调用处的线程去执行.">
}
