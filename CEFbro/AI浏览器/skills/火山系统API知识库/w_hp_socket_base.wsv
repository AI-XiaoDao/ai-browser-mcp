    常量 已报告 <公开 类型 = 短整数 值 = 208 注释 = "ALREADY_REPORTED">
    常量 已响应 <公开 类型 = 短整数 值 = 226 注释 = "IM_USED">
    常量 多重选择 <公开 类型 = 短整数 值 = 300 注释 = "MULTIPLE_CHOICES">
    常量 永久重定向 <公开 类型 = 短整数 值 = 301 注释 = "MOVED_PERMANENTLY">
    常量 临时重定向 <公开 类型 = 短整数 值 = 302 注释 = "MOVED_TEMPORARILY">
    常量 重定向 <公开 类型 = 短整数 值 = 303 注释 = "SEE_OTHER">
    常量 缓存 <公开 类型 = 短整数 值 = 304 注释 = "NOT_MODIFIED">
    常量 使用代理 <公开 类型 = 短整数 值 = 305 注释 = "USE_PROXY">
    常量 选择代理 <公开 类型 = 短整数 值 = 306 注释 = "SWITCH_PROXY">
    常量 临时重定向_ <公开 类型 = 短整数 值 = 307 注释 = "TEMPORARY_REDIRECT">
    常量 永久重定向_ <公开 类型 = 短整数 值 = 308 注释 = "PERMANENT_REDIRECT">
