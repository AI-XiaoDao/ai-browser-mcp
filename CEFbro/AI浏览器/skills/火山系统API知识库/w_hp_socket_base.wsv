    常量 正在处理 <公开 类型 = 短整数 值 = 102 注释 = "PROCESSING">
    常量 成功 <公开 类型 = 短整数 值 = 200 注释 = "HTTP_OK">
    常量 已创建 <公开 类型 = 短整数 值 = 201 注释 = "CREATED">
    常量 已同意 <公开 类型 = 短整数 值 = 202 注释 = "ACCEPTED">
    常量 非权威信息 <公开 类型 = 短整数 值 = 203 注释 = "NON_AUTHORITATIVE_INFORMATION">
    常量 空内容 <公开 类型 = 短整数 值 = 204 注释 = "NO_CONTENT">
    常量 重置内容 <公开 类型 = 短整数 值 = 205 注释 = "RESET_CONTENT">
