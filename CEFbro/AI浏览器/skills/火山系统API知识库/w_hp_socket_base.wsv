    常量 端口错误 <公开 值 = 7 注释 = "创建完成端口失败">
    常量 创建线程失败 <公开 值 = 8 注释 = "创建工作线程失败">
    常量 监测线程失败 <公开 值 = 9 注释 = "创建监测线程失败">
    常量 绑定端口失败 <公开 值 = 10 注释 = "绑定完成端口失败">
    常量 连接失败 <公开 值 = 11 注释 = "连接服务器失败">
    常量 网络错误 <公开 值 = 12 注释 = "网络错误">
