    方法 开始握手 <公开 定义事件 类型 = 整数 注释 = "当收到客户端的握手请求时本事件被发送.">
    参数 客户ID <类型 = 变整数>

    方法 已关闭 <公开 定义事件 类型 = 整数 注释 = "当服务器被关闭时本事件被发送.">

    方法 收到数据 <公开 定义事件 类型 = 整数 注释 = "当收到客户端发送过来的数据时本事件被发送，如果数据大于" 注释 = "缓冲区尺寸，会分段接收，也就是一个数据会多次触发本事件"
            注释 = "如果要直接接收完整的数据，请用【收到WS完整数据包体】事件">
    参数 客户ID <类型 = 变整数>
    参数 数据 <类型 = 字节集类>

    方法 收到WS完整数据包 <公开 定义事件 类型 = 整数 注释 = "当接收完一个完整的WebSocket数据包体的时候会触发本事件." 注释 = "注意: 需要把\"接收完整数据包\"属性设置为真才会触发本事件.">
    参数 连接ID <类型 = 变整数>
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧">
    参数 保留位 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x00 - 0x0F" 注释 = "0x01：代表该数据为文本型数据" 注释 = "0x02：代表该数据为二进制，图片、音频或压缩文件等等" 注释 = "0x03-0x07：保留的非控制帧。"
            注释 = "0x08：用来指示即将断开连接" 注释 = "0x09：代表ping心跳" 注释 = "0x0A：代表pong心跳" 注释 = "0x0B-0x0F：保留的非控制帧。">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 客户IP地址 <类型 = 文本型 注释 = "客户的远程IP地址">
    参数 数据长度 <类型 = 长整数 注释 = "数据体长度.">
    参数 数据 <类型 = 字节集类 注释 = "WebSocket接收到的完整数据体">

    方法 正在解析数据头2 <公开 定义事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发." 返回值注释 = "本事件返回0则继续触发\"正在解析数据头\"事件,返回1则跳过\"正在解析数据头\"事件.">
    参数 连接ID <类型 = 变整数>
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧.">
    参数 保留 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">

    方法 正在解析数据头 <公开 定义事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发.">
    参数 客户ID <类型 = 变整数>

    方法 数据接收完成 <公开 定义事件 类型 = 整数 注释 = "WS数据接收完毕后本事件被发送">
    参数 客户ID <类型 = 变整数>

    方法 客户进入 <公开 定义事件 类型 = 整数 注释 = "当有客户端连接成功时本事件被发送.">
    参数 客户ID <类型 = 变整数>

    方法 客户离开 <公开 定义事件 类型 = 整数 注释 = "当有已连接的客户端断开连接时本事件被发送.">
    参数 客户ID <类型 = 变整数 注释 = "当前已连接的客户ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">

    方法 数据发送完毕 <公开 定义事件 类型 = 整数 注释 = "本服务器发送数据成功后本事件被发送.">
    参数 客户ID <类型 = 变整数 注释 = "欲接收本次数据的客户端ID.">
    参数 数据 <类型 = 字节集类 注释 = "本次发送的数据内容.">

    方法 请求解析完成 <公开 定义事件 类型 = 整数 注释 = "当服务器接收到客户请求后,将触发本事件,本事件将指定" 注释 = "当前请求方式,和请求路径.例如:本机地址为192.168.0.103"
            注释 = ",WebSocket客户端连接：\"ws://192.168.0.103/love\",本事件" 注释 = "将解析出请求地址后面的\"/love\".">
    参数 连接ID <类型 = 变整数>
    参数 当前请求方式 <类型 = 文本型 注释 = "当前客户请求方式,例如GET或POST.">
    参数 当前请求地址 <类型 = 文本型 注释 = "当前客户请求路径.为地址后面的参数.">

    方法 启动成功 <公开 定义事件 类型 = 整数 注释 = "服务器端启动完毕并开始监听后,将触发本事件.">
}

类 WebSocket_数据结构
{
    变量 结束帧 <公开 类型 = 逻辑型>
    变量 RSV <公开 类型 = 字节>
    变量 操作码 <公开 类型 = 字节>
    变量 掩码 <公开 类型 = 变整数>
    变量 消息长度 <公开 类型 = 长整数>
    变量 数据 <公开 类型 = 字节集类>
}
