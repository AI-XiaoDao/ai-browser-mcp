    方法 升级协议处理 <类型 = 文本型 返回值注释 = "返回Accept内容.">
    参数 Key <类型 = 文本型 注释 = "客户端发送的Sec-WebSocket-Key.">
    {
        变量 临时Key <类型 = 文本型>
        临时Key = Key + 验证
        返回 (字节集到BASE64文本 (十六进制文本到字节集 (加解密类.取数据SHA1 (文本到多字节 (临时Key, 假)))))
    }

    方法 HP_HTTP安全服务器_收到WS数据体 <接收事件 类型 = 整数 注释 = "当接收到WebSocket数据包体时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP安全服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 数据 <类型 = 字节集类>
    参数 长度 <类型 = 整数>
    {
        如果 (是否接收完整数据包)
        {
            互斥锁_哈希表_连接ID到对象.加锁 ()
            添加字节集 (((WebSocket_数据结构)哈希表_连接ID到对象.取值 (到文本 (连接ID))).数据, 数据)
            互斥锁_哈希表_连接ID到对象.解锁 ()
            返回 (0)
        }
        返回 (收到数据 (连接ID, 数据))
    }

    方法 HP_HTTP服务器_收到WS数据体 <接收事件 类型 = 整数 注释 = "当接收到WebSocket数据包体时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
