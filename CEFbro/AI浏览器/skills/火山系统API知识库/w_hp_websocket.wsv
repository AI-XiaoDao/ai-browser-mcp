    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">
    {
        如果 (正在解析数据头2 (结束帧, 保留, 操作码, 掩码, 消息长度) == 0)
        {
            正在解析数据头 ()
        }
        返回 (0)
    }

    方法 HP_HTTP客户端_WS数据接收完成 <接收事件 类型 = 整数 注释 = "当完整接收一个WebSocket数据包时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
