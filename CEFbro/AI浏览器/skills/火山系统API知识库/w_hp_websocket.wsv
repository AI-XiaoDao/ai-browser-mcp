    方法 HP_HTTP服务器_正在解析WS数据头 <接收事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧.">
    参数 保留 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">
    {
        如果 (是否接收完整数据包)
        {
            变量 WebSocket数据 <类型 = WebSocket_数据结构>
            WebSocket数据.结束帧 = 结束帧
            WebSocket数据.RSV = 保留
            WebSocket数据.操作码 = 操作码
            WebSocket数据.掩码 = 掩码
            WebSocket数据.消息长度 = 消息长度

            互斥锁_哈希表_连接ID到对象.加锁 ()
            哈希表_连接ID到对象.插入 (到文本 (连接ID), WebSocket数据)
            互斥锁_哈希表_连接ID到对象.解锁 ()
        }

        如果 (是否启动自动心跳 && 操作码 == 9)
        {
            发送心跳 (连接ID, 真)
        }

        如果 (正在解析数据头2 (连接ID, 结束帧, 保留, 操作码, 掩码, 消息长度) == 0)
        {
            正在解析数据头 (连接ID)
        }
        返回 (0)
    }

