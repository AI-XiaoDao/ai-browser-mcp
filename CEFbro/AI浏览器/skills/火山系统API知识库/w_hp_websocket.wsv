<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.网络

类 Websocket客户端类2 <公开 注释 = "封装HPsocket的WS客户端实现." 注释 = "本类相对\"Websocket客户端类\"新增了以下特性:"
        注释 = "  1. 所接收到的数据内部自动组包,当接收到全部数据后再触发数据接收事件;" 注释 = "  2. 非异步连接时等待升级协议完成;"
        注释 = "  3. \"收到数据\"事件增加消息类型,用作判断所接收到的数据是文本还是字节集.">
{
    变量 客户端 <类型 = HP_HTTP客户端>
    变量 SSL客户端 <类型 = HP_HTTP安全客户端类>
    变量 SSL <类型 = 逻辑型>
    变量 请求路径 <类型 = 文本型>
    变量 服务器地址 <类型 = 文本型>
    变量 端口号 <类型 = 整数>
    变量 附加协议头 <类型 = 文本数组类>
    变量 m_本次操作码 <类型 = 整数>
    变量 m_组包数据 <类型 = 字节集类 注释 = "内部组包,让用户组包太麻烦了">
    变量 m_ssl初始化 <类型 = 逻辑型>

    方法 连接 <公开 类型 = 逻辑型 注释 = "向指定WS服务器发起连接请求." 返回值注释 = "如果\"异步连接\"参数为假,将返回本次连接服务器的结果,否则返回本地客户端通信组件的启动结果.">
    参数 地址 <类型 = 文本型 注释 = "例如:ws://localhost:9010/ajaxchattest">
    参数 附加头 <类型 = 文本数组类 注释 = "提供连接所欲使用的附加请求头,一个成员表示一组,例如:\"Origin:http://0.0.0.0\"." @默认值 = 空对象>
    参数 异步连接 <类型 = 逻辑型 注释 = "指定是否以异步通知(通过事件获取连接结果,本方法不会阻塞)方式连接到服务端." @默认值 = 真>
    {
        如果 (是否以文本开头 (地址, "wss://"))
        {
            SSL = 真
            如果 (m_ssl初始化 == 假)
            {
                如果 (SSL客户端.初始化SSL环境 () == 假)
                {
                    返回 (假)
                }
                m_ssl初始化 = 真
            }
        }
        否则
        {
            SSL = 假  // 防止二次连接
        }
        端口号 = 解析地址 (地址, 服务器地址, 请求路径)
        如果 (端口号 < 0 || 文本是否为空 (服务器地址))
        {
            返回 (假)
        }
        附加协议头 = 附加头
        如果 (选择 (SSL, SSL客户端.启动 (服务器地址, 端口号, 异步连接), 客户端.启动 (服务器地址, 端口号, 异步连接)) == 假)
        {
            返回 (假)
        }
        如果 (异步连接 == 假)
        {
            如果 (等待升级协议 (10000) == 假)
            {
                本对象.关闭 ()  // 这么久了,升级协议还没完成吗?...
                如果 (SSL)
                {
                    m_ssl初始化 = 假
                }
                返回 (假)
            }
        }
        返回 (真)
    }

    方法 等待升级协议 <类型 = 逻辑型 注释 = "由于HP,握手=连接成功,但是还没升级协议呢,所以需要等待升级协议." 注释 = "如果不等待,连接成功后,直接发数据给服务器,是发不出去的.">
    参数 超时时间 <类型 = 整数 注释 = "毫秒">
    {
        变量 启动时间 <类型 = 长整数>
        启动时间 = 取启动时间 ()
        判断循环 (真)
        {
            如果 (SSL)
            {
                如果 (SSL客户端.是否升级协议)
                {
                    返回 (真)
                }
            }
            否则 (客户端.是否升级协议)
            {
                返回 (真)
            }
            如果 (取启动时间 () - 启动时间 > 超时时间)  // 超时?
            {
                返回 (假)
            }
            延时 (100)
        }
        返回 (真)
    }

    方法 发送文本 <公开 类型 = 逻辑型 注释 = "向服务器发送文本内容消息." 返回值注释 = "返回发送结果.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲发送的文本数据.">
    参数 文本编码 <类型 = 文本编码类型 注释 = "指定所提供的内容是否需要以Utf8编码提交." @默认值 = 文本编码类型.UTF8>
    {
        变量 掩码 <类型 = 字节集类>
        掩码.添加值到字节集 (0x1)
        掩码.添加值到字节集 (0x2)
        掩码.添加值到字节集 (0x3)
        掩码.添加值到字节集 (0x4)
        变量 数据 <类型 = 字节集类>
        如果 (文本编码 == 文本编码类型.UTF8)
        {
            数据 = 文本到UTF8 (内容, 假)
        }
        否则 (文本编码 == 文本编码类型.多字节)
        {
            数据 = 文本到多字节 (内容, 假)
        }
        否则
        {
            数据 = 文本到字节集 (内容)
        }
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (真, 0, 1, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (真, 0, 1, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "向服务器发送二进制内容消息." 返回值注释 = "返回发送结果.">
    参数 数据 <类型 = 字节集类 注释 = "提供所欲发送的数据.">
    {
        变量 掩码 <类型 = 字节集类>
        掩码.添加值到字节集 (0x1)
        掩码.添加值到字节集 (0x2)
        掩码.添加值到字节集 (0x3)
        掩码.添加值到字节集 (0x4)
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (真, 0, 2, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (真, 0, 2, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送自定义消息 <公开 类型 = 逻辑型 注释 = "向服务器发送自定义消息." 返回值注释 = "返回发送结果.">
    参数 是否结束帧 <类型 = 逻辑型 注释 = "指定当前所发送的消息帧是否为结束帧." @默认值 = 真>
    参数 RSV <类型 = 字节 注释 = "指定所欲使用的扩展位数据." @默认值 = 0>
    参数 操作码 <类型 = 字节 注释 = "指定本次消息的操作码." @默认值 = 2>
    参数 掩码 <类型 = 字节集类 注释 = "指定本次发送消息所使用的掩码." @默认值 = 空对象>
    参数 数据 <类型 = 字节集类 注释 = "指定本次所欲发送的数据内容." @默认值 = 空对象>
    参数 消息长度 <类型 = 整数 注释 = "指定本次的消息长度,为0自动计算." @默认值 = 0>
    {
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (是否结束帧, RSV, 操作码, 掩码, 数据, 数据.取字节集长度 (), 消息长度))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (是否结束帧, RSV, 操作码, 掩码, 数据, 数据.取字节集长度 (), 消息长度))
        }
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "断开当前连接并释放资源.">
    {
        如果 (SSL)
        {
            返回 (SSL客户端.停止 ())
        }
        否则
        {
            返回 (客户端.停止 ())
        }
    }

    方法 取通信对象 <公开 类型 = HP_HTTP客户端 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (客户端)
    }

    方法 取SSL通信对象 <公开 类型 = HP_HTTP安全客户端类 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (SSL客户端)
    }

    方法 解析地址 <类型 = 整数 返回值注释 = "正确返回端口号,必定>0,否则返回-1.">
    参数 地址 <类型 = 文本型>
    参数 服务器 <类型 = 文本型>
    参数 路径 <类型 = 文本型>
    {
        变量 端口 <类型 = 整数 值 = -1>
        变量 协议名 <类型 = 文本型>
        如果 (是否以文本开头 (地址, "ws://"))
        {
            协议名 = "ws://"
        }
        否则 (是否以文本开头 (地址, "wss://"))
        {
            协议名 = "wss://"
        }
        否则
        {
            返回 (端口)
        }
        变量 路径符位置 <类型 = 整数>
        变量 服务器和端口 <类型 = 文本型>
        变量 端口位置 <类型 = 整数>
        路径符位置 = 寻找文本 (地址, "/", 取文本长度 (协议名))
        如果 (路径符位置 != -1)
        {
            服务器和端口 = 取文本中间 (地址, 取文本长度 (协议名), 路径符位置 - 取文本长度 (协议名))
            路径 = 取文本右边 (地址, 取文本长度 (地址) - 路径符位置 - 1)
        }
        否则
        {
            服务器和端口 = 取文本右边 (地址, 取文本长度 (地址) - 取文本长度 (协议名))
        }
        端口位置 = 寻找文本 (服务器和端口, ":")
        如果 (端口位置 != -1)
        {
            服务器 = 取文本左边 (服务器和端口, 端口位置)
            端口 = 文本到整数 (取文本右边 (服务器和端口, 取文本长度 (服务器和端口) - 端口位置 - 1))
        }
        否则
        {
            服务器 = 服务器和端口
            端口 = 选择 (SSL, 443, 80)
        }
        返回 (端口)
    }

    方法 HP_HTTP客户端_开始握手 <接收事件 类型 = 整数 注释 = "当前客户端将与服务端握手时将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        返回 (握手处理 ())
    }

    方法 HP_HTTP安全客户端类_开始握手 <接收事件 类型 = 整数 注释 = "当前客户端将与服务端握手时将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        返回 (握手处理 ())
    }

    方法 HP_HTTP客户端_协议升级 <接收事件 类型 = 整数 注释 = "  当客户端主动升级协议后,将会触发本事件." 注释 = "  当客户端从HTTP1.0协议升级为HTTP1.1协议后,服务器将通过本事件通知" 注释 = "用户."
            注释 = "  本事件返回值拥有具体意义,请您参考如下返回值:" 注释 = "    0  - 本次操作成功,默认返回值." 注释 = "    -1 - 本次操作失败,主动与客户断开连接."
            注释 = "  请注意:如果本事件返回-1,将会触发事件\"解析错误\",您可以忽略本次\"解析" 注释 = "错误\"事件." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 协议类型 <类型 = HPHTTP协议升级类型>
    {
        如果 (协议类型 == HPHTTP协议升级类型.WebSocket)
        {
            返回 (连接完成 ())
        }
        返回 (0)
    }

    方法 HP_HTTP安全客户端类_协议升级 <接收事件 类型 = 整数 注释 = "  当客户端主动升级协议后,将会触发本事件." 注释 = "  当客户端从HTTP1.0协议升级为HTTP1.1协议后,服务器将通过本事件通知"
            注释 = "用户." 注释 = "  本事件返回值拥有具体意义,请您参考如下返回值:" 注释 = "    0  - 本次操作成功,默认返回值." 注释 = "    -1 - 本次操作失败,主动与客户断开连接."
            注释 = "  请注意:如果本事件返回-1,将会触发事件\"解析错误\",您可以忽略本次\"解析" 注释 = "错误\"事件." 返回值注释 = "返回-1则会关闭当前连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 协议类型 <类型 = HPHTTP协议升级类型>
    {
        如果 (协议类型 == HPHTTP协议升级类型.WebSocket)
        {
            返回 (连接完成 ())
        }
        返回 (0)
    }

    方法 HP_HTTP客户端_收到WS数据体 <接收事件 类型 = 整数 注释 = "当接收到WebSocket数据包体时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 数据 <类型 = 字节集类>
    参数 长度 <类型 = 整数>
    {
        m_组包数据.添加字节集 (数据)
        返回 (0)
    }

    方法 HP_HTTP安全客户端类_收到WS数据体 <接收事件 类型 = 整数 注释 = "当接收到WebSocket数据包体时本事件将被触发." 返回值注释 = "返回-1则会关闭当前连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 数据 <类型 = 字节集类>
    参数 长度 <类型 = 整数>
    {
        m_组包数据.添加字节集 (数据)
        返回 (0)
    }

    方法 HP_HTTP安全客户端类_通信发生错误 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        连接断开 (关闭原因, 错误码)
        返回 (0)
    }

    方法 HP_HTTP客户端_通信发生错误 <接收事件 类型 = 整数 注释 = "当客户端主动或被动与服务器断开后将触发本事件.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数 注释 = "触发该事件的连接ID.">
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被关闭的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">
    {
        连接断开 (关闭原因, 错误码)
        返回 (0)
    }

    方法 HP_HTTP安全客户端类_正在解析WS数据头 <接收事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发." 返回值注释 = "返回-1则会关闭当前连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧.">
    参数 保留 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">
    {
        m_本次操作码 = 操作码
        m_组包数据.清空字节集 ()
        返回 (0)
    }

    方法 HP_HTTP客户端_正在解析WS数据头 <接收事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧.">
    参数 保留 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">
    {
        m_本次操作码 = 操作码
        m_组包数据.清空字节集 ()
        返回 (0)
    }

    方法 HP_HTTP客户端_WS数据接收完成 <接收事件 类型 = 整数 注释 = "当完整接收一个WebSocket数据包时本事件将被触发." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        变量 返回值 <类型 = 整数>
        返回值 = 收到数据 (m_本次操作码, m_组包数据)
        m_组包数据.清空字节集 ()
        返回 (返回值)
    }

    方法 HP_HTTP安全客户端类_WS数据接收完成 <接收事件 类型 = 整数 注释 = "当完整接收一个WebSocket数据包时本事件将被触发." 返回值注释 = "返回-1则会关闭当前连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        变量 返回值 <类型 = 整数>
        返回值 = 收到数据 (m_本次操作码, m_组包数据)
        m_组包数据.清空字节集 ()
        返回 (返回值)
    }

    方法 握手处理 <类型 = 整数>
    {
        变量 WS升级头 <类型 = HP请求头数组类>
        变量 头 <类型 = HP请求头类>
        头.名称 = "Upgrade"
        头.值 = "websocket"
        WS升级头.加入成员 (头)
        头.名称 = "Connection"
        头.值 = "Upgrade"
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Key"
        头.值 = "MTIzNDU2Nzg5MDExMTExMQ=="
        WS升级头.加入成员 (头)
        头.名称 = "Origin"
        头.值 = "http://" + 服务器地址
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Version"
        头.值 = "13"
        WS升级头.加入成员 (头)
        如果 (是否为空对象 (附加协议头) == 假 && 附加协议头.取成员数 () > 0)
        {
            变量 i <类型 = 整数>
            循环 (, 附加协议头.取成员数 (), i)
            {
                变量 起始位置 <类型 = 整数>
                起始位置 = 寻找文本 (附加协议头.取成员 (i), ":")
                头.名称 = 取文本左边 (附加协议头.取成员 (i), 起始位置)
                头.值 = 取文本右边 (附加协议头.取成员 (i), 取文本长度 (附加协议头.取成员 (i)) - 起始位置 - 1)
                WS升级头.检查加入头成员 (头)
            }
        }
        变量 握手结果 <类型 = 逻辑型>
        如果 (SSL)
        {
            握手结果 = SSL客户端.发送请求 ("GET", 请求路径, WS升级头)
        }
        否则
        {
            握手结果 = 客户端.发送请求 ("GET", 请求路径, WS升级头)
        }
        返回 (选择 (握手结果, 0, 2))
    }

    方法 收到数据 <公开 定义事件 类型 = 整数 注释 = "当接收到数据时本事件被触发,注意数据已经被自动内部组成一个完整的数据包.">
    参数 消息类型 <类型 = 整数 注释 = "1=文本,2=字节集">
    参数 数据 <类型 = 字节集类>

    方法 连接断开 <公开 定义事件 类型 = 整数>
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被断开的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">

    方法 连接完成 <公开 定义事件 类型 = 整数>
}

类 Websocket客户端类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "封装HPsocket的WS客户端实现.">
{
    变量 客户端 <类型 = HP_HTTP客户端>
    变量 SSL客户端 <类型 = HP_HTTP安全客户端类>
    变量 SSL <类型 = 逻辑型>
    变量 请求路径 <类型 = 文本型>
    变量 服务器地址 <类型 = 文本型>
    变量 端口号 <类型 = 整数>
    变量 附加协议头 <类型 = 文本数组类>

    方法 初始化SSL <公开 类型 = 逻辑型 注释 = "如欲启用SSL,需在\"连接\"方法之前初始化." 返回值注释 = "返回SSL初始化的结果.">
    参数 验证模式 <类型 = HPSSL验证模式 注释 = "指定当前SSL验证模式." @默认值 = HPSSL验证模式.无验证>
    参数 证书文件 <类型 = 文本型 注释 = "提供所欲使用的证书文件路径(客户端可选)." @默认值 = "">
    参数 私钥文件 <类型 = 文本型 注释 = "提供所欲使用的私钥文件路径(客户端可选)." @默认值 = "">
    参数 私钥密码 <类型 = 文本型 注释 = "提供所欲使用的私钥密码,如无密码可为空." @默认值 = "">
    参数 CA证书 <类型 = 文本型 注释 = "CA证书文件或目录(单向验证或客户端可选)." @默认值 = "">
    {
        返回 (SSL客户端.初始化SSL环境 (验证模式, 证书文件, 私钥文件, 私钥密码, CA证书))
    }

    方法 连接 <公开 类型 = 逻辑型 注释 = "向指定WS服务器发起连接请求." 返回值注释 = "如果\"异步连接\"参数为假,将返回本次连接服务器的结果,否则返回本地客户端通信组件的启动结果.">
    参数 地址 <类型 = 文本型 注释 = "例如:ws://localhost:9010/ajaxchattest">
    参数 附加头 <类型 = 文本数组类 注释 = "提供连接所欲使用的附加请求头,一个成员表示一组,例如:\"Origin:http://0.0.0.0\"." @默认值 = 空对象>
    参数 异步连接 <类型 = 逻辑型 注释 = "指定是否以异步通知(通过事件获取连接结果,本方法不会阻塞)方式连接到服务端." @默认值 = 真>
    {
        如果 (是否以文本开头 (地址, "wss://"))
        {
            SSL = 真
        }
        否则
        {
            SSL = 假  // 防止二次连接
        }
        端口号 = 解析地址 (地址, 服务器地址, 请求路径)
        如果 (端口号 < 0 || 文本是否为空 (服务器地址))
        {
            返回 (假)
        }
        附加协议头 = 附加头
        返回 (选择 (SSL, SSL客户端.启动 (服务器地址, 端口号, 异步连接), 客户端.启动 (服务器地址, 端口号, 异步连接)))
    }

    方法 发送文本 <公开 类型 = 逻辑型 注释 = "向服务器发送文本内容消息." 返回值注释 = "返回发送结果.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲发送的文本数据.">
    参数 UTF8编码 <类型 = 逻辑型 注释 = "指定所提供的内容是否需要以Utf8编码提交." @默认值 = 真>
    {
        变量 掩码 <类型 = 字节集类>
        掩码.添加值到字节集 (0x1)
        掩码.添加值到字节集 (0x2)
        掩码.添加值到字节集 (0x3)
        掩码.添加值到字节集 (0x4)
        变量 数据 <类型 = 字节集类>
        如果 (UTF8编码)
        {
            数据 = 文本到UTF8 (内容, 假)
        }
        否则
        {
            数据 = 文本到字节集 (内容)
        }
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (真, 0, 1, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (真, 0, 1, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "向服务器发送二进制内容消息." 返回值注释 = "返回发送结果.">
    参数 数据 <类型 = 字节集类 注释 = "提供所欲发送的数据.">
    {
        变量 掩码 <类型 = 字节集类>
        掩码.添加值到字节集 (0x1)
        掩码.添加值到字节集 (0x2)
        掩码.添加值到字节集 (0x3)
        掩码.添加值到字节集 (0x4)
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (真, 0, 2, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (真, 0, 2, 掩码, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送自定义消息 <公开 类型 = 逻辑型 注释 = "向服务器发送自定义消息." 返回值注释 = "返回发送结果.">
    参数 是否结束帧 <类型 = 逻辑型 注释 = "指定当前所发送的消息帧是否为结束帧." @默认值 = 真>
    参数 RSV <类型 = 字节 注释 = "指定所欲使用的扩展位数据." @默认值 = 0>
    参数 操作码 <类型 = 字节 注释 = "指定本次消息的操作码." @默认值 = 2>
    参数 掩码 <类型 = 字节集类 注释 = "指定本次发送消息所使用的掩码." @默认值 = 空对象>
    参数 数据 <类型 = 字节集类 注释 = "指定本次所欲发送的数据内容." @默认值 = 空对象>
    参数 消息长度 <类型 = 整数 注释 = "指定本次的消息长度,为0自动计算." @默认值 = 0>
    {
        如果 (SSL)
        {
            返回 (SSL客户端.发WebSocket消息 (是否结束帧, RSV, 操作码, 掩码, 数据, 数据.取字节集长度 (), 消息长度))
        }
        否则
        {
            返回 (客户端.发WebSocket消息 (是否结束帧, RSV, 操作码, 掩码, 数据, 数据.取字节集长度 (), 消息长度))
        }
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "断开当前连接并释放资源.">
    {
        如果 (SSL)
        {
            返回 (SSL客户端.停止 ())
        }
        否则
        {
            返回 (客户端.停止 ())
        }
    }

    方法 取通信对象 <公开 类型 = HP_HTTP客户端 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (客户端)
    }

    方法 取SSL通信对象 <公开 类型 = HP_HTTP安全客户端类 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (SSL客户端)
    }

    方法 解析地址 <类型 = 整数 返回值注释 = "正确返回端口号,必定>0,否则返回-1.">
    参数 地址 <类型 = 文本型>
    参数 服务器 <类型 = 文本型>
    参数 路径 <类型 = 文本型>
    {
        变量 端口 <类型 = 整数 值 = -1>
        变量 协议名 <类型 = 文本型>
        如果 (是否以文本开头 (地址, "ws://"))
        {
            协议名 = "ws://"
        }
        否则 (是否以文本开头 (地址, "wss://"))
        {
            协议名 = "wss://"
        }
        否则
        {
            返回 (端口)
        }
        变量 路径符位置 <类型 = 整数>
        变量 服务器和端口 <类型 = 文本型>
        变量 端口位置 <类型 = 整数>
        路径符位置 = 寻找文本 (地址, "/", 取文本长度 (协议名))
        如果 (路径符位置 != -1)
        {
            服务器和端口 = 取文本中间 (地址, 取文本长度 (协议名), 路径符位置 - 取文本长度 (协议名))
            路径 = 取文本右边 (地址, 取文本长度 (地址) - 路径符位置 - 1)
        }
        否则
        {
            服务器和端口 = 取文本右边 (地址, 取文本长度 (地址) - 取文本长度 (协议名))
        }
        端口位置 = 寻找文本 (服务器和端口, ":")
        如果 (端口位置 != -1)
        {
            服务器 = 取文本左边 (服务器和端口, 端口位置)
            端口 = 文本到整数 (取文本右边 (服务器和端口, 取文本长度 (服务器和端口) - 端口位置 - 1))
        }
        否则
        {
            服务器 = 服务器和端口
            端口 = 选择 (SSL, 443, 80)
        }
        返回 (端口)
    }

    方法 HP_HTTP客户端_开始握手 <接收事件 类型 = 整数 注释 = "当前客户端将与服务端握手时将触发本事件." 返回值注释 = "可选返回值:" 返回值注释 = "  0 = 本次操作成功, 客户端将与服务器进行握手."
            返回值注释 = "  1 = 忽略本次操作." 返回值注释 = "  2 = 本次操作错误, 握手动作失败, 主动断开与客户的连接.">
    参数 来源对象 <类型 = HP_HTTP客户端 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        返回 (握手处理 ())
    }

