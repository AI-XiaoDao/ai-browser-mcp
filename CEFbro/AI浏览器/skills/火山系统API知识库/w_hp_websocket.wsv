            头.值 = "websocket"
            WS升级头.加入成员 (头)
            头.名称 = "Connection"
            头.值 = "Upgrade"
            WS升级头.加入成员 (头)
            头.名称 = "Sec-WebSocket-Accept"
            头.值 = Accept
            WS升级头.加入成员 (头)
            头.名称 = "Sec-WebSocket-Protocol"
            头.值 = 来源对象.取请求头值 (连接ID, "Sec-WebSocket-Protocol")
            如果 (头.值 != "")
            {
                WS升级头.加入成员 (头)
            }
            如果 (来源对象.回复请求 (连接ID, 101, "", WS升级头, 请求体))
