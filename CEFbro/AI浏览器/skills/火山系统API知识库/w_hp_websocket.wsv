    方法 HP_HTTP安全客户端类_WS数据接收完成 <接收事件 类型 = 整数 注释 = "当完整接收一个WebSocket数据包时本事件将被触发." 返回值注释 = "返回-1则会关闭当前连接.">
    参数 来源对象 <类型 = HP_HTTP安全客户端类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    {
        数据接收完成 ()
        返回 (0)
    }

    方法 握手处理 <类型 = 整数>
    {
        变量 WS升级头 <类型 = HP请求头数组类>
        变量 头 <类型 = HP请求头类>
        头.名称 = "Upgrade"
        头.值 = "websocket"
        WS升级头.加入成员 (头)
        头.名称 = "Connection"
        头.值 = "Upgrade"
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Key"
        头.值 = "MTIzNDU2Nzg5MDExMTExMQ=="
        WS升级头.加入成员 (头)
        头.名称 = "Origin"
        头.值 = "http://" + 服务器地址
        WS升级头.加入成员 (头)
        头.名称 = "Sec-WebSocket-Version"
        头.值 = "13"
        WS升级头.加入成员 (头)
        如果 (是否为空对象 (附加协议头) == 假 && 附加协议头.取成员数 () > 0)
        {
            变量 i <类型 = 整数>
            循环 (, 附加协议头.取成员数 (), i)
            {
                变量 起始位置 <类型 = 整数>
                起始位置 = 寻找文本 (附加协议头.取成员 (i), ":")
                头.名称 = 取文本左边 (附加协议头.取成员 (i), 起始位置)
                头.值 = 取文本右边 (附加协议头.取成员 (i), 取文本长度 (附加协议头.取成员 (i)) - 起始位置 - 1)
                WS升级头.检查加入头成员 (头)
            }
        }
        变量 握手结果 <类型 = 逻辑型>
        如果 (SSL)
        {
            握手结果 = SSL客户端.发送请求 ("GET", 请求路径, WS升级头)
        }
        否则
        {
            握手结果 = 客户端.发送请求 ("GET", 请求路径, WS升级头)
        }
        返回 (选择 (握手结果, 0, 2))
    }

    方法 收到数据 <公开 定义事件 类型 = 整数>
    参数 数据 <类型 = 字节集类>

    方法 连接断开 <公开 定义事件 类型 = 整数>
    参数 关闭原因 <类型 = HP操作类型 注释 = "返回导致连接被断开的操作.">
    参数 错误码 <类型 = HP错误码 注释 = "如果客户端为非正常退出,此参数为错误代码.">

    方法 连接完成 <公开 定义事件 类型 = 整数>

    方法 正在解析数据头2 <公开 定义事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发." 返回值注释 = "本事件返回0则继续触发\"正在解析数据头\"事件,返回1则跳过\"正在解析数据头\"事件.">
    参数 结束帧 <类型 = 逻辑型 注释 = "是否结束帧.">
    参数 保留 <类型 = 字节 注释 = "RSV1/RSV2/RSV3各1位.">
    参数 操作码 <类型 = 字节 注释 = "操作码:0x0 - 0xF.">
    参数 掩码 <类型 = 变整数 注释 = "4字节掩码,空指针则无掩码.">
    参数 消息长度 <类型 = 长整数 注释 = "消息体长度.">

    方法 正在解析数据头 <公开 定义事件 类型 = 整数 注释 = "当解析WebSocket数据包头时本事件将被触发.">

    方法 数据接收完成 <公开 定义事件 类型 = 整数 注释 = "WS数据接收完毕后本事件被触发">
}

类 Websocket服务端类 <公开>
{
    变量 服务端 <类型 = HP_HTTP服务器>
    变量 SSL服务端 <类型 = HP_HTTP安全服务器>
    变量 SSL <类型 = 逻辑型>
    变量 互斥锁_哈希表_连接ID到对象 <类型 = 互斥锁类>
    变量 哈希表_连接ID到对象 <类型 = 文本到对象哈希表>
    变量 是否接收完整数据包 <类型 = 逻辑型 注释 = "注意本属性值只能在初始化本对象时设置一次,中途不能更改.">
    变量 是否启动自动心跳 <类型 = 逻辑型>

    常量 验证 <类型 = 文本型 值 = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11">

    方法 启动 <公开 类型 = 逻辑型 注释 = "启动服务器并开始监听指定端口." 返回值注释 = "返回启动结果.">
    参数 绑定地址 <类型 = 文本型 注释 = "提供所欲绑定的地址." @默认值 = 空对象>
    参数 监听端口 <类型 = 整数 注释 = "提供所欲监听的端口号. 有效端口号从0到65535." @默认值 = 80>
    参数 是否SSL <类型 = 逻辑型 注释 = "指定是否以SSL服务器方式启动." @默认值 = 假>
    {
        SSL = 是否SSL
        如果 (是否SSL)
        {
            返回 (SSL服务端.启动 (绑定地址, 监听端口))
        }
        否则
        {
            返回 (服务端.启动 (绑定地址, 监听端口))
        }
    }

    方法 初始化SSL <公开 类型 = 逻辑型 注释 = "如欲启用SSL,需在\"启动\"方法之前初始化." 返回值注释 = "返回SSL初始化结果.">
    参数 验证模式 <类型 = HPSSL验证模式 注释 = "指定当前SSL验证模式." @默认值 = HPSSL验证模式.无验证>
    参数 证书文件 <类型 = 文本型 注释 = "提供所欲使用的证书文件路径(客户端可选)." @默认值 = "">
    参数 私钥文件 <类型 = 文本型 注释 = "提供所欲使用的私钥文件路径(客户端可选)." @默认值 = "">
    参数 私钥密码 <类型 = 文本型 注释 = "提供所欲使用的私钥密码,如无密码可为空." @默认值 = "">
    参数 CA证书 <类型 = 文本型 注释 = "CA证书文件或目录(单向验证或客户端可选)." @默认值 = "">
    {
        返回 (SSL服务端.初始化SSL环境 (验证模式, 证书文件, 私钥文件, 私钥密码, CA证书))
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "断开当前服务器并释放资源.">
    {
        如果 (SSL)
        {
            返回 (SSL服务端.停止 ())
        }
        否则
        {
            返回 (服务端.停止 ())
        }
    }

    方法 断开连接 <公开 注释 = "断开指定客户的连接">
    参数 连接ID <类型 = 变整数>
    参数 强制断开 <类型 = 逻辑型 注释 = "是否强制断开" @默认值 = 假>
    {
        如果 (SSL)
        {
            SSL服务端.断开连接 (连接ID, 强制断开)
        }
        否则
        {
            服务端.断开连接 (连接ID, 强制断开)
        }
    }

    方法 自动心跳 <公开 属性写 注释 = "启动自动心跳功能：当客户端发送ping心跳请求过来，则服务端自动回复pong心跳。">
    参数 是否启动 <类型 = 逻辑型 "">
    {
        是否启动自动心跳 = 是否启动
    }

    方法 发送心跳 <公开 类型 = 逻辑型 注释 = "发送WS协议层心跳：ping/pong" 返回值注释 = "返回发送结果">
    参数 连接ID <类型 = 变整数>
    参数 pong心跳 <类型 = 逻辑型 注释 = "为真则发送pong心跳，假则发送ping心跳。" @默认值 = 真>
    {
        变量 心跳类型 <类型 = 字节>
        如果 (pong心跳)
        {
            心跳类型 = 10  // 发送pong心跳。
        }
        否则
        {
            心跳类型 = 9  // 发送ping心跳。
        }

        如果 (SSL)
        {
            返回 (SSL服务端.发WebSocket消息 (连接ID, 真, 0, 心跳类型, 空对象, 0, 0))
        }
        否则
        {
            返回 (服务端.发WebSocket消息 (连接ID, 真, 0, 心跳类型, 空对象, 0, 0))
        }
    }

    方法 接收完整数据包 <公开 属性写 注释 = "如果为真，则用【收到WS完整数据包体】这个事件接收数据" 注释 = "为假则用【收到数据】这个事件接收数据，默认为假" 注释 = "区别在于，【收到数据】事件是分包接收的，要把每个数据连接"
            注释 = "起来，当【数据接收完成】事件触发后所连接的包才是完整的。" 注释 = "【收到WS完整数据包体】事件收到的数据是一个完完整整的WS数据包。">
    参数 是否接收 <类型 = 逻辑型 @默认值 = 假>
    {
        是否接收完整数据包 = 是否接收
    }

    方法 客户端连接数 <公开 属性读 类型 = 整数 注释 = "获取当前通信组件的连接数">
    {
        如果 (SSL)
        {
            返回 (SSL服务端.客户端连接数)
        }
        否则
        {
            返回 (服务端.客户端连接数)
        }
    }

    方法 取所有连接ID <公开 类型 = 变整数数组类 注释 = "获取当前已连接的所有连接ID">
    {
        如果 (SSL)
        {
            返回 (SSL服务端.取所有连接ID ())
        }
        否则
        {
            返回 (服务端.取所有连接ID ())
        }
    }

    方法 取连接时长 <公开 类型 = 整数 注释 = "获取某个客户端连接时长(毫秒).">
    参数 连接ID <类型 = 变整数>
    {
        如果 (SSL)
        {
            返回 (SSL服务端.取连接时长 (连接ID))
        }
        否则
        {
            返回 (服务端.取连接时长 (连接ID))
        }
    }

    方法 工作线程数 <公开 属性写 注释 = "设置工作线程数量(通常设置为 2 * CPU + 2).含义为: 所有连接所共用的线程数量." 注释 = "注意: 请按实际情况设置,组件会根据该值预分配内存,必须在启动服务器之前调用.">
    参数 线程数 <类型 = 整数 "">
    {
        服务端.工作线程数 = 线程数
        SSL服务端.工作线程数 = 线程数
    }

    方法 最大连接数 <公开 属性写 注释 = "  设置通信组件所设置的最大连接数.注意:请按实际情况设置," 注释 = "组件会根据该值预分配内存,必须在启动服务器之前调用.">
    参数 欲设最大连接数 <类型 = 整数>
    {
        服务端.最大连接数 = 欲设最大连接数
        SSL服务端.最大连接数 = 欲设最大连接数
    }

    方法 发送文本 <公开 类型 = 逻辑型 注释 = "向客户端发送文本内容消息." 返回值注释 = "返回发送结果.">
    参数 客户ID <类型 = 变整数 注释 = "提供所欲接收数据的客户ID.">
    参数 内容 <类型 = 文本型 注释 = "提供所欲发送的文本内容.">
    参数 UTF8编码 <类型 = 逻辑型 注释 = "指定所提供的内容是否需要以Utf8编码提交." @默认值 = 真>
    {
        变量 数据 <类型 = 字节集类>
        如果 (UTF8编码)
        {
            数据 = 文本到UTF8 (内容, 假)
        }
        否则
        {
            数据 = 文本到字节集 (内容)
        }
        如果 (SSL)
        {
            返回 (SSL服务端.发WebSocket消息 (客户ID, 真, 0, 1, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (服务端.发WebSocket消息 (客户ID, 真, 0, 1, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送数据 <公开 类型 = 逻辑型 注释 = "向客户端发送二进制内容消息." 返回值注释 = "返回发送结果.">
    参数 客户ID <类型 = 变整数 注释 = "提供所欲接收数据的客户ID.">
    参数 数据 <类型 = 字节集类 注释 = "提供所欲发送的数据.">
    {
        如果 (SSL)
        {
            返回 (SSL服务端.发WebSocket消息 (客户ID, 真, 0, 2, 数据, 数据.取字节集长度 (), 0))
        }
        否则
        {
            返回 (服务端.发WebSocket消息 (客户ID, 真, 0, 2, 数据, 数据.取字节集长度 (), 0))
        }
    }

    方法 发送自定义消息 <公开 类型 = 逻辑型 注释 = "向服务器发送自定义消息." 返回值注释 = "返回发送结果.">
    参数 客户ID <类型 = 变整数 注释 = "提供所欲接收数据的客户ID.">
    参数 是否结束帧 <类型 = 逻辑型 注释 = "指定当前所发送的消息帧是否为结束帧." @默认值 = 真>
    参数 RSV <类型 = 字节 注释 = "指定所欲使用的扩展位数据." @默认值 = 0>
    参数 操作码 <类型 = 字节 注释 = "指定本次消息的操作码." @默认值 = 2>
    参数 数据 <类型 = 字节集类 注释 = "指定本次所欲发送的数据内容." @默认值 = 空对象>
    参数 消息长度 <类型 = 整数 注释 = "指定本次的消息长度,为0自动计算." @默认值 = 0>
    {
        如果 (SSL)
        {
            返回 (SSL服务端.发WebSocket消息 (客户ID, 是否结束帧, RSV, 操作码, 数据, 数据.取字节集长度 (), 消息长度))
        }
        否则
        {
            返回 (服务端.发WebSocket消息 (客户ID, 是否结束帧, RSV, 操作码, 数据, 数据.取字节集长度 (), 消息长度))
        }
    }

    方法 取通信对象 <公开 类型 = HP_HTTP服务器 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (服务端)
    }

    方法 取SSL通信对象 <公开 类型 = HP_HTTP安全服务器 注释 = "获取当前Websocket连接所使用的HP通信组件对象.">
    {
        返回 (SSL服务端)
    }

    方法 HP_HTTP服务器_协议升级 <接收事件 类型 = 整数 注释 = "  当客户端主动升级协议后,将会触发本事件." 注释 = "  当客户端从HTTP1.0协议升级为HTTP1.1协议后,服务器将通过本事件通知" 注释 = "用户."
            注释 = "  本事件返回值拥有具体意义,请您参考如下返回值:" 注释 = "    0  - 本次操作成功,默认返回值." 注释 = "    -1 - 本次操作失败,主动与客户断开连接."
            注释 = "  请注意:如果本事件返回-1,将会触发事件\"解析错误\",您可以忽略本次\"解析" 注释 = "错误\"事件." 返回值注释 = "返回-1则会关闭该连接.">
    参数 来源对象 <类型 = HP_HTTP服务器 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 连接ID <类型 = 变整数>
    参数 协议类型 <类型 = HPHTTP协议升级类型>
    {
        变量 请求体 <类型 = 字节集类>
        变量 WS升级头 <类型 = HP请求头数组类>
        如果 (协议类型 == HPHTTP协议升级类型.HTTP隧道)
        {
            来源对象.回复请求 (连接ID, 200, "Connection Established", WS升级头, 请求体)
        }
        否则 (协议类型 == HPHTTP协议升级类型.WebSocket)
        {
            变量 Accept <类型 = 文本型>
            Accept = 升级协议处理 (来源对象.取请求头值 (连接ID, "Sec-WebSocket-Key"))
            如果 (文本是否为空 (Accept))
            {
                返回 (-1)  // 握手失败
            }
            变量 头 <类型 = HP请求头类>
            头.名称 = "Upgrade"
            头.值 = "websocket"
            WS升级头.加入成员 (头)
            头.名称 = "Connection"
            头.值 = "Upgrade"
            WS升级头.加入成员 (头)
            头.名称 = "Sec-WebSocket-Accept"
            头.值 = Accept
            WS升级头.加入成员 (头)
            头.名称 = "Sec-WebSocket-Protocol"
            头.值 = 来源对象.取请求头值 (连接ID, "Sec-WebSocket-Protocol")
            如果 (头.值 != "")
            {
                WS升级头.加入成员 (头)
            }
            如果 (来源对象.回复请求 (连接ID, 101, "", WS升级头, 请求体))
            {
                返回 (0)
            }
            否则
            {
                返回 (-1)  // 握手失败
            }
        }
        返回 (0)
    }

    方法 HP_HTTP安全服务器_协议升级 <接收事件 类型 = 整数 注释 = "  当客户端主动升级协议后,将会触发本事件." 注释 = "  当客户端从HTTP1.0协议升级为HTTP1.1协议后,服务器将通过本事件通知"
