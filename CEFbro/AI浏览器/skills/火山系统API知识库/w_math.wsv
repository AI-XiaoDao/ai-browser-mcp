    方法 求反正弦 <公开 静态 类型 = 小数 注释 = "反正弦函数为正弦函数的反函数" @嵌入式方法 = "">
    参数 欲求反正弦的小数 <类型 = 小数>
    {
        @ asin (@<欲求反正弦的小数>)
    }

    方法 "// 求反余弦" <公开 静态 类型 = 小数 注释 = "反余弦函数为余弦函数的反函数">
    参数 欲求反余弦的小数 <类型 = 小数 注释 = "输入参数必须大于等于-1或小于等于1">
    {
        变量 返回值 <类型 = 小数>
        如果 (欲求反余弦的小数 >= -1 || 欲求反余弦的小数 <= 1)
        {
            如果 (小数是否相等 (欲求反余弦的小数, 1))
            {
                返回值 = 0
            }
            否则 (小数是否相等 (欲求反余弦的小数, -1))
            {
                返回值 = 常数.PI
            }
            否则 (小数是否为零 (欲求反余弦的小数))
            {
                返回值 = 常数.PI / 2
            }
            否则 (欲求反余弦的小数 > 0 && 欲求反余弦的小数 < 1)
            {
                返回值 = 求反正切 (求平方根 (1 - 欲求反余弦的小数 * 欲求反余弦的小数) / 欲求反余弦的小数)
            }
            否则 (欲求反余弦的小数 > -1 && 欲求反余弦的小数 < 0)
            {
                返回值 = 求反正切 (求平方根 (1 - 欲求反余弦的小数 * 欲求反余弦的小数) / 欲求反余弦的小数) + 常数.PI
            }
        }
        返回 (返回值)
    }

    方法 "// 求反正弦" <公开 静态 类型 = 小数 注释 = "反正弦函数为正弦函数的反函数">
    参数 欲求反正弦的小数 <类型 = 小数>
    {
        变量 返回值 <类型 = 小数>
        如果 (欲求反正弦的小数 >= -1 || 欲求反正弦的小数 <= 1)
        {
            如果 (小数是否相等 (欲求反正弦的小数, 1))
            {
                返回值 = 常数.PI / 2
            }
            否则 (小数是否相等 (欲求反正弦的小数, -1))
            {
                返回值 = -1 * 常数.PI / 2
            }
            否则
            {
                返回值 = 求反正切 (欲求反正弦的小数 / 求平方根 (1 - 欲求反正弦的小数 * 欲求反正弦的小数))
            }
        }
        返回 (返回值)
    }

    方法 求整数最大公因数 <公开 静态 类型 = 整数 注释 = "如果一个整数同时是几个整数的因数,称这个整数为它们的公因数.公因数中最大的称为最大公因数.">
    参数 欲求最大公因数的整数1 <类型 = 整数>
    参数 欲求最大公因数的整数2 <类型 = 整数>
    {
        如果 (欲求最大公因数的整数2 == 0)
        {
            返回 (欲求最大公因数的整数1)
        }
        否则
        {
            返回 (求整数最大公因数 (欲求最大公因数的整数2, 欲求最大公因数的整数1 % 欲求最大公因数的整数2))
        }
    }

    方法 求整数阶乘 <公开 静态 类型 = 整数 注释 = "一个正整数的阶乘是所有小于及等于该数的正整数的积">
    参数 欲求阶乘的整数 <类型 = 整数>
    {
        如果 (欲求阶乘的整数 < 0)
        {
            返回 (0)
        }
        否则 (欲求阶乘的整数 == 0)
        {
            返回 (1)
        }
        否则
        {
            返回 (欲求阶乘的整数 * 求整数阶乘 (欲求阶乘的整数 - 1))
        }
    }
}

