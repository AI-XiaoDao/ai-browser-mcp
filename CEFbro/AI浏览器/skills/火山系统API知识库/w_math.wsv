    参数 纵向放大尺寸 <类型 = 小数>
    {
        左边 = 左边 - 横向放大尺寸
        右边 = 右边 + 横向放大尺寸
        顶边 = 顶边 - 纵向放大尺寸
        底边 = 底边 + 纵向放大尺寸
    }

    方法 缩小 <公开>
    参数 横向缩小尺寸 <类型 = 小数>
    参数 纵向缩小尺寸 <类型 = 小数>
    {
        左边 = 左边 + 横向缩小尺寸
        右边 = 右边 - 横向缩小尺寸
        顶边 = 顶边 + 纵向缩小尺寸
        底边 = 底边 - 纵向缩小尺寸
    }

    方法 包含指定矩形 <公开 注释 = "扩充本矩形以包含所指定矩形">
    参数 所欲包含的矩形 <类型 = 小数矩形类>
    {
        如果 (所欲包含的矩形.是否为空 () == 假)
        {
            如果 (是否为空 ())
            {
                检查复制对象 (所欲包含的矩形)
            }
            否则
            {
                左边 = 取较小值 (左边, 所欲包含的矩形.左边)
                顶边 = 取较小值 (顶边, 所欲包含的矩形.顶边)
                右边 = 取较大值 (右边, 所欲包含的矩形.右边)
                底边 = 取较大值 (底边, 所欲包含的矩形.底边)
            }
        }
    }

    方法 包含指定点 <公开 注释 = "扩充本矩形以包含所指定点的位置">
    参数 所欲包含点横坐标 <类型 = 小数>
    参数 所欲包含点纵坐标 <类型 = 小数>
    {
        如果 (所欲包含点横坐标 + 1 > 右边)
        {
            右边 = 所欲包含点横坐标 + 1
        }
        如果 (所欲包含点横坐标 < 左边)
        {
            左边 = 所欲包含点横坐标
        }
        如果 (所欲包含点纵坐标 + 1 > 底边)
        {
            底边 = 所欲包含点纵坐标 + 1
        }
        如果 (所欲包含点纵坐标 < 顶边)
        {
            顶边 = 所欲包含点纵坐标
        }
    }

    方法 乘于 <公开 注释 = "将本矩形的所有成员乘于所指定的值">
    参数 所欲乘于的值 <类型 = 小数>
    {
        左边 = 左边 * 所欲乘于的值
        右边 = 右边 * 所欲乘于的值
        顶边 = 顶边 * 所欲乘于的值
        底边 = 底边 * 所欲乘于的值
    }

    方法 除于 <公开 注释 = "将本矩形的所有成员除于所指定的值">
    参数 所欲除于的值 <类型 = 小数>
    {
        如果 (小数是否为零 (所欲除于的值) == 假)
        {
            左边 = 左边 / 所欲除于的值
            右边 = 右边 / 所欲除于的值
            顶边 = 顶边 / 所欲除于的值
            底边 = 底边 / 所欲除于的值
        }
    }

    方法 取面积 <公开 类型 = 小数 注释 = "返回本矩形的面积">
    {
        返回 ((底边 - 顶边) * (右边 - 左边))
    }

    方法 取中心点 <公开 类型 = 小数位置类 注释 = "返回本矩形的中心点位置">
    {
        变量 中心点位置 <类型 = 小数位置类>
        中心点位置.横向位置 = (右边 + 左边) / 2
        中心点位置.纵向位置 = (底边 + 顶边) / 2
        返回 (中心点位置)
    }

    方法 取中心横向位置 <公开 类型 = 小数 注释 = "返回本矩形中心点的横向位置">
    {
        返回 ((右边 + 左边) / 2)
    }

    方法 取中心纵向位置 <公开 类型 = 小数 注释 = "返回本矩形中心点的纵向位置">
    {
        返回 ((底边 + 顶边) / 2)
    }

    方法 取右下角位置 <公开 类型 = 小数位置类 注释 = "返回本矩形右下角的位置">
    {
        变量 位置1 <类型 = 小数位置类>
        位置1.横向位置 = 右边
        位置1.纵向位置 = 底边
        返回 (位置1)
    }

    方法 规范化 <公开 注释 = "整理本矩形的各个成员,去除左右边或上下边反转的情况,使其规范化.">
    {
        变量 变量1 <类型 = 小数>
        如果 (左边 > 右边)
        {
            变量1 = 右边
            右边 = 左边
            左边 = 变量1
        }
        如果 (顶边 > 底边)
        {
            变量1 = 底边
            底边 = 顶边
            顶边 = 变量1
        }
    }

    方法 是否包含指定点 <公开 类型 = 逻辑型 注释 = "返回所指定点的位置是否在本矩形中">
    参数 所检测点横坐标 <类型 = 小数>
    参数 所检测点纵坐标 <类型 = 小数>
    {
        返回 (所检测点横坐标 >= 左边 && 所检测点横坐标 < 右边 && 所检测点纵坐标 >= 顶边 && 所检测点纵坐标 < 底边)
    }

    方法 是否位于矩形内部 <公开 类型 = 逻辑型 注释 = "返回本矩形是否完全位于所指定矩形内部">
    参数 所欲检查的矩形 <类型 = 小数矩形类>
    {
        返回 (左边 >= 所欲检查的矩形.左边 && 右边 <= 所欲检查的矩形.右边 && 顶边 >= 所欲检查的矩形.顶边 && 底边 <= 所欲检查的矩形.底边)
    }

    方法 是否相交 <公开 类型 = 逻辑型 注释 = "返回本矩形是否与所指定矩形具有相交部分">
    参数 所欲检查的矩形 <类型 = 小数矩形类>
    {
        如果 (是否为空 () || 所欲检查的矩形.是否为空 ())
        {
            返回 (假)
        }
        返回 (左边 < 所欲检查的矩形.右边 && 右边 > 所欲检查的矩形.左边 && 顶边 < 所欲检查的矩形.底边 && 底边 > 所欲检查的矩形.顶边)
    }

    方法 取相交矩形 <公开 类型 = 逻辑型 注释 = "  返回本矩形是否与所指定矩形具有相交部分并将" 注释 = "相交部分矩形填入所指定参数中">
    参数 所欲检查的矩形 <类型 = 小数矩形类>
    参数 相交结果矩形 <类型 = 小数矩形类 注释 = "  本参数用作存储本矩形与所检查矩形的相交部分," 注释 = "如果没有相交,则将被清零.">
    {
        如果 (是否相交 (所欲检查的矩形) == 假)
        {
            相交结果矩形.清零 ()
            返回 (假)
        }
        否则
        {
            相交结果矩形.左边 = 取较大值 (左边, 所欲检查的矩形.左边)
            相交结果矩形.顶边 = 取较大值 (顶边, 所欲检查的矩形.顶边)
            相交结果矩形.右边 = 取较小值 (右边, 所欲检查的矩形.右边)
            相交结果矩形.底边 = 取较小值 (底边, 所欲检查的矩形.底边)
            返回 (真)
        }
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "{ 左边: " + 到文本 (左边) + "; 顶边: " + 到文本 (顶边) + ", 右边: " + 到文本 (右边) + ", 底边: " + 到文本 (底边) + " }"
    }

