<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <@文档 = "category = \"算数运算\"">

类 数值范围 <公开 注释 = "提供各种整数数值类型的最大和最小值">
{
    常量 最小字节值 <公开 类型 = 整数 值 = @_VOL_SBYTE_MIN>
    常量 最大字节值 <公开 类型 = 整数 值 = @_VOL_SBYTE_MAX>
    常量 最小短整数值 <公开 类型 = 整数 值 = @_VOL_SHRT_MIN>
    常量 最大短整数值 <公开 类型 = 整数 值 = @_VOL_SHRT_MAX>
    常量 最小字符值 <公开 类型 = 整数 值 = 0>
    常量 最大字符值 <公开 类型 = 整数 值 = @_VOL_WORD_MAX>
    常量 最小整数值 <公开 类型 = 整数 值 = @_VOL_INT_MIN>
    常量 最大整数值 <公开 类型 = 整数 值 = @_VOL_INT_MAX>
    常量 最小长整数值 <公开 类型 = 长整数 值 = @_VOL_INT64_MIN>
    常量 最大长整数值 <公开 类型 = 长整数 值 = @_VOL_INT64_MAX>
    常量 最小变整数值 <公开 类型 = 变整数 值 = @_VOL_INT_P_MIN>
    常量 最大变整数值 <公开 类型 = 变整数 值 = @_VOL_INT_P_MAX>
    常量 最小日期时间值 <公开 类型 = 小数 值 = @_VOL_MIN_DATE 注释 = "提供所允许的最小日期时间值(用小数表达),为100年1月1日.">
    常量 最大日期时间值 <公开 类型 = 小数 值 = @_VOL_MAX_DATE 注释 = "提供所允许的最大日期时间值(用小数表达),为9999年1月1日.">
}

类 常数 <公开 注释 = "提供各种常数值">
{
    常量 接近零小数值 <公开 类型 = 小数 值 = @NEAR_ZERO_DOUBLE 注释 = "提供一个无限接近零的小数值,可以用作在进行小数比较操作时使用.">
    常量 PI <公开 类型 = 小数 值 = 3.14159265358979323846 注释 = "圆周率,圆的周长与直径的比值.">
    常量 E <公开 类型 = 小数 值 = 2.7182818284590452354 注释 = "自然常数,自然对数函数的底数,有时被称为欧拉数.">
}

# ===

类 矩形类 <公开 基础类 = 扩展对象类 注释 = "用作记录一个矩形数据" @视窗.结构类 = 0>
{
    变量 左边 <公开 类型 = 整数 @属性变量 = 真>
    变量 顶边 <公开 类型 = 整数 @属性变量 = 真>
    变量 右边 <公开 类型 = 整数 @属性变量 = 真>
    变量 底边 <公开 类型 = 整数 @属性变量 = 真>

    # 属性 --

    方法 位置 <公开 属性读 类型 = 位置类 注释 = "返回本矩形的左上角位置">
    {
        变量 位置1 <类型 = 位置类>
        位置1.横向位置 = 左边
        位置1.纵向位置 = 顶边
        返回 (位置1)
    }

    方法 位置 <公开 属性写 注释 = "设置本矩形的左上角位置">
    参数 所欲设置位置 <类型 = 位置类>
    {
        左边 = 所欲设置位置.横向位置
        顶边 = 所欲设置位置.纵向位置
    }

    方法 尺寸 <公开 属性读 类型 = 尺寸类 注释 = "返回本矩形的尺寸">
    {
        变量 尺寸1 <类型 = 尺寸类>
        尺寸1.宽度 = 右边 - 左边
        尺寸1.高度 = 底边 - 顶边
        返回 (尺寸1)
    }

    方法 尺寸 <公开 属性写 注释 = "设置本矩形的尺寸">
    参数 所欲设置尺寸 <类型 = 尺寸类>
    {
        右边 = 左边 + 所欲设置尺寸.宽度
        底边 = 顶边 + 所欲设置尺寸.高度
    }

    方法 宽度 <公开 属性读 类型 = 整数 注释 = "返回本矩形的宽度">
    {
        返回 (右边 - 左边)
    }

    方法 宽度 <公开 属性写 注释 = "设置本矩形的宽度">
    参数 所欲设置宽度 <类型 = 整数>
    {
        右边 = 左边 + 所欲设置宽度
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "返回本矩形的高度">
    {
        返回 (底边 - 顶边)
    }

    方法 高度 <公开 属性写 注释 = "设置本矩形的高度">
    参数 所欲设置高度 <类型 = 整数>
    {
        底边 = 顶边 + 所欲设置高度
    }

    # 方法 --

    方法 到小数矩形 <公开 类型 = 小数矩形类 注释 = "将本整数矩形转换为小数矩形">
    {
        变量 变量1 <类型 = 小数矩形类>
        变量1.左边 = 左边
        变量1.右边 = 右边
        变量1.顶边 = 顶边
        变量1.底边 = 底边
        返回 (变量1)
    }

    方法 清零 <公开>
    {
        左边 = 0
        顶边 = 0
        右边 = 0
        底边 = 0
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本矩形的面积是否为空">
    {
        返回 (右边 <= 左边 || 底边 <= 顶边)
    }

    方法 设置 <公开>
    参数 所欲设置左边位置 <类型 = 整数>
    参数 所欲设置顶边位置 <类型 = 整数>
    参数 所欲设置右边位置 <类型 = 整数>
    参数 所欲设置底边位置 <类型 = 整数>
    {
        左边 = 所欲设置左边位置
        顶边 = 所欲设置顶边位置
        右边 = 所欲设置右边位置
        底边 = 所欲设置底边位置
    }

    方法 基于位置设置 <公开>
    参数 左上角位置 <类型 = 位置类>
    参数 右下角位置 <类型 = 位置类>
    {
        左边 = 左上角位置.横向位置
        顶边 = 左上角位置.纵向位置
        右边 = 右下角位置.横向位置
        底边 = 右下角位置.纵向位置
    }

    方法 基于位置和尺寸设置 <公开>
    参数 所设置位置 <类型 = 位置类>
    参数 所设置尺寸 <类型 = 尺寸类>
    {
        左边 = 所设置位置.横向位置
        顶边 = 所设置位置.纵向位置
        右边 = 左边 + 所设置尺寸.宽度
        底边 = 顶边 + 所设置尺寸.高度
    }

    方法 置左上角位置 <公开>
    参数 所欲设置左边位置 <类型 = 整数>
    参数 所欲设置顶边位置 <类型 = 整数>
    {
        左边 = 所欲设置左边位置
        顶边 = 所欲设置顶边位置
    }

    方法 置右下角位置 <公开>
    参数 所欲设置右边位置 <类型 = 整数>
    参数 所欲设置底边位置 <类型 = 整数>
    {
        右边 = 所欲设置右边位置
        底边 = 所欲设置底边位置
    }

    方法 置尺寸 <公开>
    参数 所欲设置的宽度 <类型 = 整数>
    参数 所欲设置的高度 <类型 = 整数>
    {
        右边 = 左边 + 所欲设置的宽度
        底边 = 顶边 + 所欲设置的高度
    }

    方法 横向移动 <公开>
    参数 横向移动距离 <类型 = 整数>
    {
        左边 = 左边 + 横向移动距离
        右边 = 右边 + 横向移动距离
    }

    方法 纵向移动 <公开>
    参数 纵向移动距离 <类型 = 整数>
    {
        顶边 = 顶边 + 纵向移动距离
        底边 = 底边 + 纵向移动距离
    }

    方法 移动 <公开>
    参数 横向移动距离 <类型 = 整数>
    参数 纵向移动距离 <类型 = 整数>
    {
        左边 = 左边 + 横向移动距离
        右边 = 右边 + 横向移动距离
        顶边 = 顶边 + 纵向移动距离
        底边 = 底边 + 纵向移动距离
    }

    方法 放大 <公开>
    参数 横向放大尺寸 <类型 = 整数>
    参数 纵向放大尺寸 <类型 = 整数>
    {
        左边 = 左边 - 横向放大尺寸
        右边 = 右边 + 横向放大尺寸
        顶边 = 顶边 - 纵向放大尺寸
        底边 = 底边 + 纵向放大尺寸
    }

    方法 缩小 <公开>
    参数 横向缩小尺寸 <类型 = 整数>
    参数 纵向缩小尺寸 <类型 = 整数>
    {
        左边 = 左边 + 横向缩小尺寸
        右边 = 右边 - 横向缩小尺寸
        顶边 = 顶边 + 纵向缩小尺寸
        底边 = 底边 - 纵向缩小尺寸
    }

    方法 包含指定矩形 <公开 注释 = "扩充本矩形以包含所指定矩形">
    参数 所欲包含的矩形 <类型 = 矩形类>
    {
        如果 (所欲包含的矩形.是否为空 () == 假)
        {
            如果 (是否为空 ())
            {
                检查复制对象 (所欲包含的矩形)
            }
            否则
            {
                左边 = 取较小值 (左边, 所欲包含的矩形.左边)
                顶边 = 取较小值 (顶边, 所欲包含的矩形.顶边)
                右边 = 取较大值 (右边, 所欲包含的矩形.右边)
                底边 = 取较大值 (底边, 所欲包含的矩形.底边)
            }
        }
    }

    方法 包含指定点 <公开 注释 = "扩充本矩形以包含所指定点的位置">
    参数 所欲包含点横坐标 <类型 = 整数>
    参数 所欲包含点纵坐标 <类型 = 整数>
    {
        如果 (所欲包含点横坐标 + 1 > 右边)
        {
            右边 = 所欲包含点横坐标 + 1
        }
        如果 (所欲包含点横坐标 < 左边)
        {
            左边 = 所欲包含点横坐标
        }
        如果 (所欲包含点纵坐标 + 1 > 底边)
        {
            底边 = 所欲包含点纵坐标 + 1
        }
        如果 (所欲包含点纵坐标 < 顶边)
        {
            顶边 = 所欲包含点纵坐标
        }
    }

    方法 乘于 <公开 注释 = "将本矩形的所有成员乘于所指定的值">
    参数 所欲乘于的值 <类型 = 小数>
    {
        左边 = (整数)((小数)左边 * 所欲乘于的值 + 0.5)
        右边 = (整数)((小数)右边 * 所欲乘于的值 + 0.5)
        顶边 = (整数)((小数)顶边 * 所欲乘于的值 + 0.5)
        底边 = (整数)((小数)底边 * 所欲乘于的值 + 0.5)
    }

    方法 除于 <公开 注释 = "将本矩形的所有成员除于所指定的值">
    参数 所欲除于的值 <类型 = 小数>
    {
        如果 (小数是否为零 (所欲除于的值) == 假)
        {
            左边 = (整数)((小数)左边 / 所欲除于的值 + 0.5)
            右边 = (整数)((小数)右边 / 所欲除于的值 + 0.5)
            顶边 = (整数)((小数)顶边 / 所欲除于的值 + 0.5)
            底边 = (整数)((小数)底边 / 所欲除于的值 + 0.5)
        }
    }

    方法 取面积 <公开 类型 = 整数 注释 = "返回本矩形的面积">
    {
        返回 ((底边 - 顶边) * (右边 - 左边))
    }

    方法 取中心点 <公开 类型 = 位置类 注释 = "返回本矩形的中心点位置">
    {
        变量 中心点位置 <类型 = 位置类>
        中心点位置.横向位置 = (右边 + 左边) / 2
        中心点位置.纵向位置 = (底边 + 顶边) / 2
        返回 (中心点位置)
    }

    方法 取中心横向位置 <公开 类型 = 整数 注释 = "返回本矩形中心点的横向位置">
    {
        返回 ((右边 + 左边) / 2)
    }

    方法 取中心纵向位置 <公开 类型 = 整数 注释 = "返回本矩形中心点的纵向位置">
    {
        返回 ((底边 + 顶边) / 2)
    }

    方法 取右下角位置 <公开 类型 = 位置类 注释 = "返回本矩形右下角的位置">
    {
        变量 位置1 <类型 = 位置类>
        位置1.横向位置 = 右边
        位置1.纵向位置 = 底边
        返回 (位置1)
    }

    方法 规范化 <公开 注释 = "整理本矩形的各个成员,去除左右边或上下边反转的情况,使其规范化.">
    {
        变量 整数1 <类型 = 整数>
        如果 (左边 > 右边)
        {
            整数1 = 右边
            右边 = 左边
            左边 = 整数1
        }
        如果 (顶边 > 底边)
        {
            整数1 = 底边
            底边 = 顶边
            顶边 = 整数1
        }
    }

    方法 是否包含指定点 <公开 类型 = 逻辑型 注释 = "返回所指定点的位置是否在本矩形中">
    参数 所检测点横坐标 <类型 = 整数>
    参数 所检测点纵坐标 <类型 = 整数>
    {
        返回 (所检测点横坐标 >= 左边 && 所检测点横坐标 < 右边 && 所检测点纵坐标 >= 顶边 && 所检测点纵坐标 < 底边)
    }

    方法 是否位于矩形内部 <公开 类型 = 逻辑型 注释 = "返回本矩形是否完全位于所指定矩形内部">
    参数 所欲检查的矩形 <类型 = 矩形类>
    {
        返回 (左边 >= 所欲检查的矩形.左边 && 右边 <= 所欲检查的矩形.右边 && 顶边 >= 所欲检查的矩形.顶边 && 底边 <= 所欲检查的矩形.底边)
    }

    方法 是否相交 <公开 类型 = 逻辑型 注释 = "返回本矩形是否与所指定矩形具有相交部分">
    参数 所欲检查的矩形 <类型 = 矩形类>
    {
        如果 (是否为空 () || 所欲检查的矩形.是否为空 ())
        {
            返回 (假)
        }
        返回 (左边 < 所欲检查的矩形.右边 && 右边 > 所欲检查的矩形.左边 && 顶边 < 所欲检查的矩形.底边 && 底边 > 所欲检查的矩形.顶边)
    }

    方法 取相交矩形 <公开 类型 = 逻辑型 注释 = "  返回本矩形是否与所指定矩形具有相交部分并将" 注释 = "相交部分矩形填入所指定参数中">
    参数 所欲检查的矩形 <类型 = 矩形类>
    参数 相交结果矩形 <类型 = 矩形类 注释 = "  本参数用作存储本矩形与所检查矩形的相交部分," 注释 = "如果没有相交,则将被清零.">
    {
        如果 (是否相交 (所欲检查的矩形) == 假)
        {
            相交结果矩形.清零 ()
            返回 (假)
        }
        否则
        {
            相交结果矩形.左边 = 取较大值 (左边, 所欲检查的矩形.左边)
            相交结果矩形.顶边 = 取较大值 (顶边, 所欲检查的矩形.顶边)
            相交结果矩形.右边 = 取较小值 (右边, 所欲检查的矩形.右边)
            相交结果矩形.底边 = 取较小值 (底边, 所欲检查的矩形.底边)
            返回 (真)
        }
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "{ 左边: " + 到文本 (左边) + "; 顶边: " + 到文本 (顶边) + ", 右边: " + 到文本 (右边) + ", 底边: " + 到文本 (底边) + " }"
    }

    # --
    #
    # @begin
    #
    # <> <include>
    # inline_ @sn<current_class> (const RECT* prtCopy) : @sn<current_class> ()
    # {
    #     Copy (prtCopy);
    # }
    #
    # void Copy (const RECT* prtCopy);
    #
    # inline_ CMRect ToRect () const
    # {
    #     return CMRect (@<左边>, @<顶边>, @<右边>, @<底边>);
    # }
    # <> </include>
    #
    # void @sn<current_class>::Copy (const RECT* prtCopy)
    # {
    #     ASSERT (prtCopy != NULL);
    #     @<左边> = prtCopy->left;
    #     @<顶边> = prtCopy->top;
    #     @<右边> = prtCopy->right;
    #     @<底边> = prtCopy->bottom;
    # }
    #
    # @end
}

# ===

类 小数矩形类 <公开 基础类 = 扩展对象类 注释 = "用作记录一个小数矩形数据" @视窗.结构类 = 0>
{
    变量 左边 <公开 类型 = 小数 @属性变量 = 真>
    变量 顶边 <公开 类型 = 小数 @属性变量 = 真>
    变量 右边 <公开 类型 = 小数 @属性变量 = 真>
    变量 底边 <公开 类型 = 小数 @属性变量 = 真>

    # 属性 --

    方法 位置 <公开 属性读 类型 = 小数位置类 注释 = "返回本矩形的左上角位置">
    {
        变量 位置1 <类型 = 小数位置类>
        位置1.横向位置 = 左边
        位置1.纵向位置 = 顶边
        返回 (位置1)
    }

    方法 位置 <公开 属性写 注释 = "设置本矩形的左上角位置">
    参数 所欲设置位置 <类型 = 小数位置类>
    {
        左边 = 所欲设置位置.横向位置
        顶边 = 所欲设置位置.纵向位置
    }

    方法 尺寸 <公开 属性读 类型 = 小数尺寸类 注释 = "返回本矩形的尺寸">
    {
        变量 尺寸1 <类型 = 小数尺寸类>
        尺寸1.宽度 = 右边 - 左边
        尺寸1.高度 = 底边 - 顶边
        返回 (尺寸1)
    }

    方法 尺寸 <公开 属性写 注释 = "设置本矩形的尺寸">
    参数 所欲设置尺寸 <类型 = 小数尺寸类>
    {
        右边 = 左边 + 所欲设置尺寸.宽度
        底边 = 顶边 + 所欲设置尺寸.高度
    }

    方法 宽度 <公开 属性读 类型 = 小数 注释 = "返回本矩形的宽度">
    {
        返回 (右边 - 左边)
    }

    方法 宽度 <公开 属性写 注释 = "设置本矩形的宽度">
    参数 所欲设置宽度 <类型 = 小数>
    {
        右边 = 左边 + 所欲设置宽度
