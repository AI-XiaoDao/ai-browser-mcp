类 小数尺寸类 <公开 基础类 = 扩展对象类 注释 = "用作记录一个小数尺寸数据" @视窗.结构类 = 0>
{
    变量 宽度 <公开 类型 = 小数 @属性变量 = 真>
    变量 高度 <公开 类型 = 小数 @属性变量 = 真>

    方法 到尺寸 <公开 类型 = 尺寸类 注释 = "将本小数尺寸转换为整数尺寸,注意将会存在精度转换误差.">
    {
        变量 变量1 <类型 = 尺寸类>
        变量1.宽度 = (整数)宽度
        变量1.高度 = (整数)高度
        返回 (变量1)
    }

    方法 清零 <公开>
    {
        宽度 = 0
        高度 = 0
    }

    方法 设置 <公开>
    参数 所欲设置的宽度 <类型 = 小数>
    参数 所欲设置的高度 <类型 = 小数>
    {
        宽度 = 所欲设置的宽度
        高度 = 所欲设置的高度
    }

    方法 为零尺寸 <公开 类型 = 逻辑型>
    {
        返回 (小数是否为零 (宽度) && 小数是否为零 (高度))
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "{ 宽度: " + 到文本 (宽度) + "; 高度: " + 到文本 (高度) + " }"
    }
}

