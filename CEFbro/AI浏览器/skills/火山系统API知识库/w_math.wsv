    方法 文本到逻辑值 <公开 静态 类型 = 逻辑型 注释 = "将所指定文本转换到逻辑值并返回" @嵌入式方法 = "">
    参数 所欲转换的文本 <类型 = 文本型 注释 = "  提供所欲转换到逻辑值的文本内容(其首尾空白文本被忽略),\"真\"/\"true\"(不区分大小写)/\"1\"" 注释 = "被转换为逻辑值真,其它文本内容被转换为逻辑值假.">
    {
        @ (BOOL)StrToBool (@<所欲转换的文本>.GetText ())
    }

    方法 取十六进制文本 <公开 静态 类型 = 文本型 注释 = "返回所指定整数所对应的十六进制文本" @禁止流程检查 = 真>
    参数 所欲转换的整数 <类型 = 整数>
    参数 所需要的最小宽度 <类型 = 整数 注释 = "指定所需求的最小宽度(数字数目),如果有效数值宽度小于该值,则自动在首部加0." 注释 = "为0表示去除所有的前置\'0\'数字." @默认值 = 0>
    {
        @ TCHAR buf [64];
        @ return CVolString (DWordToHexStr ((DWORD)@<所欲转换的整数>, @<所需要的最小宽度>, buf, NUM_ELEMENTS_OF (buf)));
    }

    方法 取长整数十六进制文本 <公开 静态 类型 = 文本型 注释 = "返回所指定长整数所对应的十六进制文本" @禁止流程检查 = 真>
    参数 所欲转换的长整数 <类型 = 长整数>
    参数 所需要的最小宽度 <类型 = 整数 注释 = "指定所需求的最小宽度(数字数目),如果有效数值宽度小于该值,则自动在首部加0." 注释 = "为0表示去除所有的前置\'0\'数字." @默认值 = 0>
    {
        @ TCHAR buf [64];
        @ return CVolString (U64ToHexStr ((UINT64)@<所欲转换的长整数>, @<所需要的最小宽度>, buf, NUM_ELEMENTS_OF (buf)));
    }

    方法 取变整数十六进制文本 <公开 静态 类型 = 文本型 注释 = "返回所指定变整数所对应的十六进制文本" @禁止流程检查 = 真>
    参数 所欲转换的变整数 <类型 = 变整数>
    参数 所需要的最小宽度 <类型 = 整数 注释 = "指定所需求的最小宽度(数字数目),如果有效数值宽度小于该值,则自动在首部加0." 注释 = "为0表示去除所有的前置\'0\'数字." @默认值 = 0>
    {
        @ TCHAR buf [64];
        @ return CVolString (UPToHexStr ((UINT_P)@<所欲转换的变整数>, @<所需要的最小宽度>, buf, NUM_ELEMENTS_OF (buf)));
    }

    方法 数值到大写 <公开 静态 类型 = 文本型 注释 = "将数值转换为简体或繁体的大写形式,返回转换后的文本." @禁止流程检查 = 真>
    参数 所欲转换的数值 <类型 = 小数 注释 = "提供所欲转换的数值,其小数位被舍入到两位.">
    参数 是否转化为简体 <类型 = 逻辑型 注释 = "为真转换为简体,为假则转换为繁体." @默认值 = 假>
    {
        @ CVolString strResult;
        @ NumberToCNText (@<所欲转换的数值>, @<是否转化为简体>, strResult);
        @ return strResult;
    }

    方法 数值到金融 <公开 静态 类型 = 文本型 注释 = "将数值转换为货币的简体或繁体大写形式,返回转换后的文本." @禁止流程检查 = 真>
    参数 所欲转换的数值 <类型 = 小数 注释 = "提供所欲转换的数值,其小数位被舍入到两位.">
    参数 是否转化为简体 <类型 = 逻辑型 注释 = "为真转换为简体,为假则转换为繁体." @默认值 = 假>
    {
        @ CVolString strResult;
        @ NumberToCurrency (@<所欲转换的数值>, @<是否转化为简体>, strResult);
        @ return strResult;
    }

    方法 数值到格式文本 <公开 静态 类型 = 文本型 注释 = "将指定数值转换到所指定的格式化文本后返回" @禁止流程检查 = 真>
    参数 欲转换为文本的数值 <类型 = 小数>
    参数 小数保留位数 <类型 = 整数 注释 = "  如果大于0,表示小数点右边应四舍五入保留的位数; 如果等于0.表示舍入到整数;如果小于0,"
            注释 = "表示小数点左边舍入到的位置.如果为\"数值范围.最大整数值\",则保留所有实际存在的小数位."
            注释 = "  例如: 数值到格式文本 (66.66, 1, 假) 将返回\"66.7\"; 数值到格式文本 (66.66, 0, 假)"
            注释 = "将返回\"67\";  数值到格式文本 (66.66, -1, 假) 将返回\"70\"." @默认值 = 数值范围.最大整数值>
    参数 是否进行千分位分隔 <类型 = 逻辑型 注释 = "如果为真,数值文本的每个千分位上都将被自动插入一个逗号进行分隔." @默认值 = 假>
    {
        @ CVolString strResult;
        @ NumberToFormatText (@<欲转换为文本的数值>, @<小数保留位数>, @<是否进行千分位分隔>, strResult);
        @ return strResult;
    }

    方法 反转整数字节序 <公开 静态 类型 = 整数 注释 = "  将所指定整数的组成字节的顺序反转,返回反转后的结果值.譬如十六进制整数0x12345678,"
            注释 = "反转后将返回0x78563412. 本命令在与类似Java这样的语言进行数据交互时很有用处." @禁止流程检查 = 真>
    参数 所欲反转的整数 <类型 = 整数>
    {
        @ DWORD dwResult = ((@<所欲反转的整数> & 0x000000FF) << 24);
        @ dwResult |= ((@<所欲反转的整数> & 0x0000FF00) << 8);
        @ dwResult |= ((@<所欲反转的整数> & 0x00FF0000) >> 8);
        @ dwResult |= ((@<所欲反转的整数> & 0xFF000000) >> 24);
        @ return (INT)dwResult;
    }

    方法 反转长整数字节序 <公开 静态 类型 = 长整数 注释 = "  将所指定长整数的组成字节的顺序反转,返回反转后的结果值.譬如十六进制整数0x12345678,"
            注释 = "反转后将返回0x78563412. 本命令在与类似Java这样的语言进行数据交互时很有用处." @禁止流程检查 = 真>
    参数 所欲反转的长整数 <类型 = 长整数>
    {
        @ const BYTE* pbSrc = (const BYTE*)&@<所欲反转的长整数>;
        @ UINT64 u64;
        @ BYTE* pbDest = (BYTE*)&u64;
        @ for (INT_P npIndex = 0; npIndex <= sizeof (UINT64) - 1; npIndex++)
        @     pbDest [sizeof (UINT64) - 1 - npIndex] = pbSrc [npIndex];
        @ return (INT64)u64;
    }

    方法 十六进制文本到整数 <公开 静态 类型 = 整数 注释 = "将所指定的十六进制文本(可以以\"0x\"开头)转换为对应的整数值并返回" @嵌入式方法 = "">
    参数 十六进制文本 <类型 = 文本型>
    {
        @ (INT)Hex2UP (@<十六进制文本>.GetText ())
    }

    方法 十六进制文本到长整数 <公开 静态 类型 = 长整数 注释 = "将所指定的十六进制文本(可以以\"0x\"开头)转换为对应的长整数值并返回" @嵌入式方法 = "">
    参数 十六进制文本 <类型 = 文本型>
    {
        @ (INT64)Hex2U64 (@<十六进制文本>.GetText ())
    }
}

