类 算术运算类 <公开 @全局类 = 真>
{
    方法 小数是否为零 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的小数是否近似为0." 注释 = "由于小数值存在精度误差,因此检查小数值是否为0最好不要直接与0进行比较,使用本方法替代." @嵌入式方法 = "">
    参数 所欲检查的小数值 <类型 = 小数>
    {
        @ (BOOL)IsDoubleEqualZero (@<所欲检查的小数值>)
    }

    方法 小数是否相等 <公开 静态 类型 = 逻辑型 注释 = "返回两个所指定的小数是否近似相等." 注释 = "由于小数值存在精度误差,因此检查小数值是否相等最好不要直接进行比较,使用本方法替代." @嵌入式方法 = "">
    参数 欲检查的小数值1 <类型 = 小数>
    参数 欲检查的小数值2 <类型 = 小数>
    {
        @ (BOOL)IsDoubleEqual (@<欲检查的小数值1>, @<欲检查的小数值2>)
    }

    方法 取较小值 <公开 静态 注释 = "返回两个同类型数值中较小的那个" @嵌入式方法 = "">
    参数 待比较数值1 <@匹配类型 = 通用数值型 @返回值类型 = 0>
    参数 待比较数值2 <@匹配类型 = 等于前参数值类型>
    {
        @ GetMin ((@pdt<待比较数值1>)@<待比较数值1>, (@pdt<待比较数值1>)@<待比较数值2>)
    }

    方法 取较大值 <公开 静态 注释 = "返回两个同类型数值中较大的那个" @嵌入式方法 = "">
    参数 待比较数值1 <@匹配类型 = 通用数值型 @返回值类型 = 0>
    参数 待比较数值2 <@匹配类型 = 等于前参数值类型>
    {
        @ GetMax ((@pdt<待比较数值1>)@<待比较数值1>, (@pdt<待比较数值1>)@<待比较数值2>)
    }

    方法 取较小值3 <公开 静态 注释 = "返回三个同类型数值中最小的那个" @嵌入式方法 = "">
    参数 待比较数值1 <@匹配类型 = 通用数值型 @返回值类型 = 0>
    参数 待比较数值2 <@匹配类型 = 等于前参数值类型>
    参数 待比较数值3 <@匹配类型 = 等于前参数值类型>
    {
        @ GetMin3 ((@pdt<待比较数值1>)@<待比较数值1>, (@pdt<待比较数值1>)@<待比较数值2>, (@pdt<待比较数值1>)@<待比较数值3>)
    }

    方法 取较大值3 <公开 静态 注释 = "返回三个同类型数值中最大的那个" @嵌入式方法 = "">
    参数 待比较数值1 <@匹配类型 = 通用数值型 @返回值类型 = 0>
    参数 待比较数值2 <@匹配类型 = 等于前参数值类型>
    参数 待比较数值3 <@匹配类型 = 等于前参数值类型>
    {
        @ GetMax3 ((@pdt<待比较数值1>)@<待比较数值1>, (@pdt<待比较数值1>)@<待比较数值2>, (@pdt<待比较数值1>)@<待比较数值3>)
    }

    方法 剪切值 <公开 静态 注释 = "  如果所指定数值小于所提供的最小值,则返回该最小值," 注释 = "如果所指定数值大于所提供的最大值,则返回该最大值,否" 注释 = "则返回该数值本身." @嵌入式方法 = "">
    参数 待检查数值 <@匹配类型 = 通用数值型 @返回值类型 = 0>
    参数 所允许的最小值 <注释 = "如果所指定数值小于此值,则返回此值." @匹配类型 = 等于前参数值类型>
    参数 所允许的最大值 <注释 = "如果所指定数值大于此值,则返回此值." @匹配类型 = 等于前参数值类型>
    {
        @ GetClipValue ((@pdt<待检查数值>)@<待检查数值>, (@pdt<待检查数值>)@<所允许的最小值>, (@pdt<待检查数值>)@<所允许的最大值>)
    }

    方法 小数整除 <公开 静态 类型 = 小数 注释 = "将两个小数相除,返回其整数部分." @禁止流程检查 = 真>
    参数 被除数 <类型 = 小数>
    参数 除数 <类型 = 小数 注释 = "如果除数为0,本方法将返回0.">
    {
        @ DOUBLE db = 0;
        @ if (IsDoubleEqualZero (@<除数>) == FALSE)
        @     modf (@<被除数> / @<除数>, &db);
        @ return db;
    }

    方法 求余数 <公开 静态 类型 = 小数 注释 = "将两个小数相除,返回其余数部分." @禁止流程检查 = 真>
    参数 被除数 <类型 = 小数>
    参数 除数 <类型 = 小数 注释 = "如果除数为0,本方法将返回0.">
    {
        @ return (IsDoubleEqualZero (@<除数>) == FALSE ? fmod (@<被除数>, @<除数>) : 0);
    }

    方法 取符号 <公开 静态 类型 = 整数 注释 = "  返回一个整数,如果小于零,表明给定数值为负,如果等于零," 注释 = "表明给定数值为零,如果大于零,表明给定数值为正." @嵌入式方法 = "">
    参数 所欲判断的数值 <@匹配类型 = 通用数值型>
    {
        @ (INT)GetSign (@<所欲判断的数值>)
    }

    方法 取整数绝对值 <公开 静态 类型 = 整数 注释 = "返回所指定整数的绝对值" @嵌入式方法 = "">
    参数 所欲处理的整数值 <类型 = 整数>
    {
        @ abs (@<所欲处理的整数值>)
    }

    方法 取长整数绝对值 <公开 静态 类型 = 长整数 注释 = "返回所指定长整数的绝对值" @嵌入式方法 = "">
    参数 所欲处理的长整数值 <类型 = 长整数>
    {
        @ llabs (@<所欲处理的长整数值>)
    }

    方法 取小数绝对值 <公开 静态 类型 = 小数 注释 = "返回所指定小数的绝对值" @嵌入式方法 = "">
    参数 所欲处理的小数值 <类型 = 小数>
    {
        @ fabs ((DOUBLE)@<所欲处理的小数值>)
    }

    方法 取整 <公开 静态 类型 = 整数 注释 = "  返回一个小数的整数部分. 本命令与\"绝对取整\"命令不相同之处为:" 注释 = "  如果给定小数为负数,则本方法返回小于或等于该小数的第一个负整数,而\"绝对取整\""
            注释 = "方法则会返回大于或等于该小数的第一个负整数. 例如,本命令将 -7.8 转换成 -8, 而" 注释 = "\"绝对取整\"命令将 -7.8 转换成 -7 ." @嵌入式方法 = "">
    参数 所欲处理的小数值 <类型 = 小数>
    {
        @ (INT)FloorDouble (@<所欲处理的小数值>)
    }

    方法 绝对取整 <公开 静态 类型 = 整数 注释 = "  返回一个小数的整数部分. 本方法与\"取整\"命令不相同之处为:" 注释 = "  如果给定小数为负数,则本方法返回大于或等于该小数的第一个负整数,而\"取整\""
            注释 = "方法则会返回小于或等于该小数的第一个负整数. 例如,本命令将 -7.8 转换成 -7, 而" 注释 = "\"取整\"命令将 -7.8 转换成 -8 ." @嵌入式方法 = "">
    参数 所欲处理的小数值 <类型 = 小数>
    {
        @ (INT)FixDouble (@<所欲处理的小数值>)
    }

    方法 四舍五入 <公开 静态 类型 = 小数 注释 = "返回按照指定的方式进行四舍五入运算的结果数值" @嵌入式方法 = "">
    参数 欲被四舍五入的值 <类型 = 小数>
    参数 被舍入的位置 <类型 = 整数 注释 = "如果大于0,表示小数点右边应保留的位数; 如果等于0,表示舍入到整数; 如果小于0,表示小数点左边舍入到的位置."
            注释 = "例如: 四舍五入 (1056.65, 1) 返回 1056.7; 四舍五入 (1056.65, 0) 返回 1057; 四舍五入 (1056.65, -1) 返回 1060." @默认值 = 0>
    {
        @ RoundDouble (@<欲被四舍五入的值>, @<被舍入的位置>)
    }

    方法 求次方 <公开 静态 类型 = 小数 注释 = "返回指定数值的指定次方" @嵌入式方法 = "">
    参数 欲求次方数值 <类型 = 小数 注释 = "指定欲求其某次方的数值">
    参数 次方数 <类型 = 小数 注释 = "指定对欲求次方数值的运算指数">
    {
        @ pow ((DOUBLE)@<欲求次方数值>, (DOUBLE)@<次方数>)
    }

    方法 求平方根 <公开 静态 类型 = 小数 注释 = "返回指定数值的平方根" @嵌入式方法 = "">
    参数 所欲处理的数值 <类型 = 小数>
    {
        @ sqrt ((DOUBLE)@<所欲处理的数值>)
    }

    方法 弧度到角度 <公开 静态 类型 = 小数 注释 = "将所指定以弧度为单位的角度值转换为以度为单位" @嵌入式方法 = "">
    参数 欲转换的角度值 <类型 = 小数 注释 = "以弧度为单位">
    {
        @ (DOUBLE)@<欲转换的角度值> * 180 / 3.1415926535
    }

    方法 角度到弧度 <公开 静态 类型 = 小数 注释 = "将所指定以度为单位的角度值转换为以弧度为单位" @嵌入式方法 = "">
    参数 欲转换的角度值 <类型 = 小数 注释 = "以度为单位">
    {
        @ (DOUBLE)@<欲转换的角度值> * 3.1415926535 / 180
    }

    方法 求正弦 <公开 静态 类型 = 小数 注释 = "返回指定角的正弦值" @嵌入式方法 = "">
    参数 欲进行计算的角 <类型 = 小数 注释 = "所使用单位为弧度">
    {
        @ sin ((DOUBLE)@<欲进行计算的角>)
    }

    方法 求余弦 <公开 静态 类型 = 小数 注释 = "返回指定角的余弦值" @嵌入式方法 = "">
    参数 欲进行计算的角 <类型 = 小数 注释 = "所使用单位为弧度">
    {
        @ cos ((DOUBLE)@<欲进行计算的角>)
    }

    方法 求正切 <公开 静态 类型 = 小数 注释 = "返回指定角的正切值" @嵌入式方法 = "">
    参数 欲进行计算的角 <类型 = 小数 注释 = "所使用单位为弧度">
    {
        @ tan ((DOUBLE)@<欲进行计算的角>)
    }

    方法 求反正切 <公开 静态 类型 = 小数 注释 = "返回指定角的反正切值" @嵌入式方法 = "">
    参数 欲进行计算的角 <类型 = 小数 注释 = "所使用单位为弧度">
    {
        @ atan ((DOUBLE)@<欲进行计算的角>)
    }

    方法 求自然对数 <公开 静态 类型 = 小数 注释 = "返回指定参数的自然对数值." 注释 = "自然对数是以 E 为底的对数." @嵌入式方法 = "">
    参数 欲求其自然对数的值 <类型 = 小数>
    {
        @ log ((DOUBLE)@<欲求其自然对数的值>)
    }

    方法 求反对数 <公开 静态 类型 = 小数 注释 = "返回 E（自然对数的底）的某次方" @嵌入式方法 = "">
    参数 欲求其反对数的值 <类型 = 小数 注释 = "注意如果参数值超过 709.782712893 ,将导致计算溢出.">
    {
        @ exp ((DOUBLE)@<欲求其反对数的值>)
    }

    方法 是否运算正确 <公开 静态 类型 = 逻辑型 注释 = "  对乘/除/求次方/求平方根/求正弦值/求余弦值/求正切值/求反正切值/求自然对数/求反对数"
            注释 = "等各种数学运算方法所计算出来的双精度结果数值进行校验,如果该数值正确有效,返回真.如果" 注释 = "该数值是运算错误或运算溢出后的结果,返回假." @嵌入式方法 = "">
    参数 所欲检查的小数值 <类型 = 小数>
    {
        @ _finite ((DOUBLE)@<所欲检查的小数值>) != 0
    }

    方法 置随机数种子 <公开 静态 注释 = "  为随机数生成器初始化一个种子值,不同的种子值将导致后续的" 注释 = "取随机数系列方法返回不同的随机数系列值." 注释 = "  本方法的调用不是必需的,如果在未调用本方法时调用后续的取"
            注释 = "随机数系列方法,将自动首先使用一个随机值来初始化种子." @嵌入式方法 = "">
    参数 欲置入的种子数值 <类型 = 整数 注释 = "本参数值如果为0,将使用当前计算机系统的时钟毫秒值." @默认值 = 0>
    {
        @ SetRandSeed (@<欲置入的种子数值>)
    }

    方法 取随机数 <公开 静态 类型 = 整数 注释 = "  返回一个所指定范围内的随机整数值,注意范围" 注释 = "两侧的最小和最大值本身被包括在内." @嵌入式方法 = "">
    参数 欲取随机数的最小值 <类型 = 整数 @默认值 = 0>
    参数 欲取随机数的最大值 <类型 = 整数 注释 = "参数必须大于等于所指定的最小值" @默认值 = 数值范围.最大整数值>
    {
        @ randint2 (@<欲取随机数的最小值>, @<欲取随机数的最大值>)
    }

    方法 取随机数2 <公开 静态 类型 = 整数 注释 = "返回一个在0到所指定值之间(包括两者本身)的随机整数值" @嵌入式方法 = "">
    参数 欲取随机数的最大值 <类型 = 整数 注释 = "参数值必须大于等于0">
    {
        @ (INT)randint (@<欲取随机数的最大值>)
    }

    方法 取随机短整数 <公开 静态 类型 = 整数 注释 = "返回一个在0到32627之间(包括两者本身)的随机整数值" @嵌入式方法 = "">
    {
        @ (INT)randint ()
    }

    方法 取随机整数 <公开 静态 类型 = 整数 注释 = "返回一个从0到最大整数值之间(包括两者本身)的整数值" @嵌入式方法 = "">
    {
        @ (INT)randdword ()
    }

    方法 取随机小数 <公开 静态 类型 = 小数 注释 = "  返回一个所指定范围内的随机小数值,注意范围" 注释 = "两侧的最小和最大值本身被包括在内." @嵌入式方法 = "">
    参数 欲取随机数的最小值 <类型 = 小数 @默认值 = 0>
    参数 欲取随机数的最大值 <类型 = 小数 注释 = "参数必须大于等于所指定的最小值">
    {
        @ randdouble (@<欲取随机数的最小值>, @<欲取随机数的最大值>)
    }

    方法 取随机小数2 <公开 静态 类型 = 小数 注释 = "返回一个在0到1之间(包括0和1本身)的小数值" @嵌入式方法 = "">
    {
        @ randdouble ()
    }

    方法 合并整数 <公开 静态 类型 = 整数 注释 = "  将第一个整数的低16位放置到结果整数的低16位,将第二个整数的低16位" 注释 = "放置到结果整数的高16位,以此合并成一个整数,并返回合并后的结果." @嵌入式方法 = "">
    参数 用作合并的整数1 <类型 = 整数>
    参数 用作合并的整数2 <类型 = 整数>
    {
        @ (INT)MAKELONG ((WORD)@<用作合并的整数1>, (WORD)@<用作合并的整数2>)
    }

    方法 合并短整数 <公开 静态 类型 = 短整数 注释 = "  将第一个整数的低8位放置到结果短整数的低8位,将第二个整数的低8位" 注释 = "放置到结果短整数的高8位,以此合并成一个短整数,并返回合并后的结果." @嵌入式方法 = "">
    参数 用作合并的整数1 <类型 = 整数>
    参数 用作合并的整数2 <类型 = 整数>
    {
        @ (SHORT)MAKEWORD ((WORD)@<用作合并的整数1>, (WORD)@<用作合并的整数2>)
    }

    方法 求反正切2 <公开 静态 类型 = 小数 注释 = "返回以弧度表示的 参数1/参数2 的反正切.反正切函数是正切函数的反函数." 返回值注释 = "返回单位是弧度" @嵌入式方法 = "">
    参数 参数1 <类型 = 小数>
    参数 参数2 <类型 = 小数>
    {
        @  atan2 ((DOUBLE)@<参数1>, (DOUBLE)@<参数2>)
    }

    方法 求两直线夹角 <公开 静态 类型 = 小数 注释 = "返回两直线夹角,采用正切公式计算两直线的夹角." 返回值注释 = "返回单位是弧度">
    参数 参数1 <类型 = 小数 注释 = "直线1的斜率">
    参数 参数2 <类型 = 小数 注释 = "直线2的斜率">
    {
        变量 返回值 <类型 = 小数>
        如果 (小数是否相等 (参数1 * 参数2, -1))
        {
            返回值 = 常数.PI / 2
        }
        否则
        {
            返回值 = 求反正切 (绝对取整 ((参数1 - 参数2) / (1 + 参数1 * 参数2)))
        }
        返回 (返回值)
    }

    方法 是否是2的幂 <公开 静态 类型 = 逻辑型 注释 = "返回某数是否是2的幂">
    参数 欲求值的数值 <类型 = 整数>
    {
        返回 (位与 (欲求值的数值, 欲求值的数值 - 1) == 0 && 欲求值的数值 != 0)
    }

    方法 求双曲正切 <公开 静态 类型 = 小数 @嵌入式方法 = "">
    参数 欲求双曲正切的数值 <类型 = 小数>
    {
        @ tanh ((DOUBLE)@<欲求双曲正切的数值>)
    }

    方法 "// 求双曲正切" <公开 静态 类型 = 小数 注释 = "双曲正切是双曲函数的其中一种">
    参数 欲求双曲正切的小数 <类型 = 小数>
    {
        返回 ((求反对数 (欲求双曲正切的小数) - 求反对数 (-欲求双曲正切的小数)) / (求反对数 (欲求双曲正切的小数) + 求反对数 (-欲求双曲正切的小数)))
    }

    方法 求反双曲正切 <公开 静态 类型 = 小数 注释 = "反双曲正切函数是双曲正切函数的反函数">
    参数 欲求反双曲正切的小数 <类型 = 小数 注释 = "输入参数必须大于-1且小于1" 注释 = "当输入参数小于等于-1或大于等于1返回0">
    {
        如果 (欲求反双曲正切的小数 <= -1 || 欲求反双曲正切的小数 >= 1)
        {
            返回 (0)
        }
        返回 (0.5 * 求自然对数 ((1 + 欲求反双曲正切的小数) / (1 - 欲求反双曲正切的小数)))
    }

    方法 求双曲余切 <公开 静态 类型 = 小数 注释 = "双曲余切是双曲函数的其中一种" "">
