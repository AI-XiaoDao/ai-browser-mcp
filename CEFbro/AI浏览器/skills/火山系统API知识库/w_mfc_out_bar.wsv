    方法 菜单字体 <公开 属性写 注释 = "设置菜单所使用的字体" @视窗.设置时机 = 组件创建前后 @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->SetFolderFont (@<字体描述文本>.GetText ());
    }

    方法 项目字体 <公开 属性写 注释 = "设置菜单内的项目所使用的字体" @视窗.设置时机 = 组件创建前后 @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->SetItemFont (@<字体描述文本>.GetText ());
    }

