    # 方法 --

    方法 加入菜单 <公开 类型 = 逻辑型 注释 = "加入一个新的菜单" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单名称 <类型 = 文本型>
    参数 加入位置 <类型 = 整数 注释 = "指定将加入的菜单所在位置,如果为-1,则自动添加在尾部." @默认值 = -1>
    参数 菜单数值 <类型 = 变整数 注释 = "指定与该菜单相关联的附加数值,供用户自己使用." @默认值 = 0>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->InsertFolder (@<加入位置>, @<菜单名称>.GetText (), @<菜单数值>)
    }

    方法 加入项目 <公开 类型 = 逻辑型 注释 = "在指定菜单中加入一个新的项目" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 项目名称 <类型 = 文本型>
    参数 菜单索引 <类型 = 整数 注释 = "指定在哪个菜单中插入项目. 索引从0开始,如果参数值为-1,表示在当前菜单中插入项目." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "指定项目插入的位置. 索引从0开始,如果参数值为-1,表示在所指定菜单(前一个参数决定)的尾部插入项目." @默认值 = -1>
    参数 图片索引 <类型 = 整数 注释 = "指定该项目所使用的图片. 索引从0开始,如果参数值为-1,表示不使用图片." @默认值 = -1>
    参数 项目数值 <类型 = 变整数 注释 = "指定与该项目相关联的附加数值,供用户自己使用." @默认值 = 0>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->InsertItem (@<菜单索引>, @<项目索引>, @<项目名称>.GetText (), @<图片索引>, @<项目数值>)
    }

    方法 删除菜单 <公开 类型 = 逻辑型 注释 = "删除指定的菜单" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "索引值从0开始. 如果为-1,表示要删除所有菜单(相当于调用\"清除\").">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->RemoveFolder (@<菜单索引>)
    }

    方法 删除项目 <公开 类型 = 逻辑型 注释 = "删除指定菜单中的指定项目" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "指定欲删除项目的位置. 索引从0开始,如果参数值为-1,表示删除指定菜单中的所有项目." @默认值 = -1>
    参数 菜单索引 <类型 = 整数 注释 = "索引值从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->RemoveItem (@<项目索引>, @<菜单索引>)
    }

    方法 取菜单数 <公开 类型 = 整数 注释 = "返回菜单的数目" @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderCount ()
    }

    方法 取项目数 <公开 类型 = 整数 注释 = "返回指定菜单中的项目数目" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "索引值从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->GetItemCount (@<菜单索引>)
    }

    方法 取菜单名称 <公开 类型 = 文本型 注释 = "返回指定菜单的名称文本" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "索引值从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ CVolString ((const TCHAR*)((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderText (@<菜单索引>))
    }

    方法 取项目名称 <公开 类型 = 文本型 注释 = "返回指定菜单中指定项目的名称文本" @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 菜单索引 <类型 = 整数 注释 = "索引值从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ CVolString ((const TCHAR*)((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetItemText (@<项目索引>, @<菜单索引>))
    }

    方法 置菜单名称 <公开 类型 = 逻辑型 注释 = "设置指定菜单的名称文本. 调用本方法将触发\"菜单名称被改变\"事件." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 菜单索引 <类型 = 整数 注释 = "提供所欲修改菜单的索引位置,从0开始.">
    参数 菜单名称 <类型 = 文本型 注释 = "提供所欲修改到的菜单名称">
    {
        @ CGfxOutBarCtrl* pOutBar = &((CVWnd_OutBar*)GetMfcWndPtr ())->m_OutBar;
        @ if (@<菜单索引> < 0 || @<菜单索引> >= pOutBar->GetFolderCount () || @<菜单名称被改变> (@<菜单索引>, @<菜单名称>) != 0)
        @     return FALSE;
        @ pOutBar->SetFolderText (@<菜单索引>, @<菜单名称>.GetText ());
        @ if (pOutBar->m_hWnd != NULL)  pOutBar->Invalidate ();
        @ return TRUE;
    }

    方法 置项目名称 <公开 类型 = 逻辑型 注释 = "设置指定菜单中指定项目的名称文本. 调用本方法将触发\"项目名称被改变\"事件." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 项目名称 <类型 = 文本型 注释 = "提供项目所欲修改到的名称">
    参数 菜单索引 <类型 = 整数 注释 = "提供项目所处菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ CGfxOutBarCtrl* pOutBar = &((CVWnd_OutBar*)GetMfcWndPtr ())->m_OutBar;
        @ if (@<菜单索引> < 0)  @<菜单索引> = pOutBar->GetSelFolder ();
        @ if (@<项目索引> < 0 || @<项目索引> >= pOutBar->GetItemCount (@<菜单索引>) ||
        @         @<项目名称被改变> (@<菜单索引>, @<项目索引>, @<项目名称>) != 0 ||
        @         pOutBar->SetItemText (@<项目索引>, @<项目名称>.GetText (), @<菜单索引>) == FALSE)
        @     return FALSE;
        @ if (pOutBar->m_hWnd != NULL)  pOutBar->Invalidate ();
        @ return TRUE;
    }

    方法 取菜单数值 <公开 类型 = 变整数 注释 = "返回指定菜单的用户关联数值,如不存在则返回0(注意正常值也可能为0)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderData (@<菜单索引>)
    }

    方法 取项目数值 <公开 类型 = 变整数 注释 = "获取指定菜单中指定项目的用户关联数值,如不存在则返回0(注意正常值也可能为0)." @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetItemData (@<项目索引>, @<菜单索引>)
    }

    方法 置菜单数值 <公开 类型 = 逻辑型 注释 = "设置指定菜单的用户关联数值" 返回值注释 = "成功返回真,所提供菜单位置无效返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始.">
    参数 菜单数值 <类型 = 变整数 注释 = "提供所欲设置的用户关联数值">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetFolderData (@<菜单索引>, @<菜单数值>)
    }

    方法 置项目数值 <公开 类型 = 逻辑型 注释 = "设置指定菜单中指定项目的用户关联数值" 返回值注释 = "成功返回真,所提供项目位置无效返回假." @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 项目数值 <类型 = 变整数 注释 = "提供所欲设置的用户关联数值">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetItemData (@<项目索引>, @<项目数值>, @<菜单索引>)
    }

    方法 取项目图片 <公开 类型 = 整数 注释 = "获取指定菜单中指定项目的图片索引,如所指定项目不存在或无图片则返回-1." @嵌入式方法 = "">
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetItemImage (@<项目索引>, @<菜单索引>)
    }

    方法 置项目图片 <公开 类型 = 逻辑型 注释 = "设置指定菜单中指定项目的图片索引" 返回值注释 = "成功返回真,所提供项目位置无效返回假." @禁止流程检查 = 真>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 图片索引 <类型 = 整数 注释 = "提供所欲设置的图片索引值">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    {
        @ CGfxOutBarCtrl* pOutBar = &((CVWnd_OutBar*)GetMfcWndPtr ())->m_OutBar;
        @ if (pOutBar->SetItemImage (@<项目索引>, @<图片索引>, @<菜单索引>) == FALSE)  return FALSE;
        @ if (pOutBar->m_hWnd != NULL)  pOutBar->Invalidate ();
        @ return TRUE;
    }

    方法 清除 <公开 注释 = "删除所有菜单以及所有项目" @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.RemoveAll ()
    }

    方法 加入组件菜单 <公开 类型 = 逻辑型 注释 = "在指定位置添加新的菜单,该菜单将容纳所指定的窗口组件(不能再容纳普通项目)." 注释 = "本组件必须已经成功创建." 返回值注释 = "成功返回真,失败返回假.">
    参数 菜单名称 <类型 = 文本型 注释 = "提供所加入菜单的名称文本">
    参数 窗口组件对象 <类型 = 窗口组件 注释 = "提供要加入的窗口组件. 该窗口组件将被自动调整大小,以便恰好放置于菜单中."
            注释 = "建议使用容器类窗口组件,因为容器类窗口组件中再可放其它组件.即使被加入的组件不可视,必要时也会被自动显示出来." 注释 = "如果加入的是窗口,将自动取消其标题栏并禁止最大化/最小化和关闭.">
    参数 加入位置 <类型 = 整数 注释 = "指定将加入的菜单所在位置,如果为-1,则自动添加在尾部." @默认值 = -1>
    参数 菜单数值 <类型 = 变整数 注释 = "指定与该菜单相关联的附加数值,供用户自己使用." @默认值 = 0>
    {
        返回 (加入组件菜单2 (菜单名称, 窗口组件对象.取窗口句柄 (), 加入位置, 菜单数值))
    }

    方法 加入组件菜单2 <公开 类型 = 逻辑型 注释 = "在指定位置添加新的菜单,该菜单将容纳所指定的窗口组件(不能再容纳普通项目)." 注释 = "本组件必须已经成功创建." 返回值注释 = "成功返回真,失败返回假."
            @嵌入式方法 = "">
    参数 菜单名称 <类型 = 文本型 注释 = "提供所加入菜单的名称文本">
    参数 窗口组件句柄 <类型 = 变整数 注释 = "提供要加入的窗口组件句柄值. 该窗口组件将被自动调整大小,以便恰好放置于菜单中."
            注释 = "建议使用容器类窗口组件,因为容器类窗口组件中再可放其它组件.即使被加入的组件不可视,必要时也会被自动显示出来." 注释 = "如果加入的是窗口,将自动取消其标题栏并禁止最大化/最小化和关闭.">
    参数 加入位置 <类型 = 整数 注释 = "指定将加入的菜单所在位置,如果为-1,则自动添加在尾部." @默认值 = -1>
    参数 菜单数值 <类型 = 变整数 注释 = "指定与该菜单相关联的附加数值,供用户自己使用." @默认值 = 0>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.InsertFolderBar (@<加入位置>, @<菜单名称>.GetText (), (HWND)@<窗口组件句柄>, @<菜单数值>)
    }

    方法 置菜单图标 <公开 注释 = "设置指定菜单的图标" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示设置现有全部菜单的图标.">
    参数 图标索引 <类型 = 整数>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetFolderIcon (@<菜单索引>, @<图标索引>)
    }

    方法 取菜单图标 <公开 类型 = 整数 注释 = "返回指定菜单的图标索引位置,如果所提供菜单位置无效或尚未设置图标,将返回-1." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始.">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderIcon (@<菜单索引>)
    }

    方法 置菜单底图 <公开 注释 = "设置指定菜单的背景图片" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示设置现有全部菜单的背景图片.">
    参数 正常图片索引 <类型 = 整数 注释 = "索引值从0开始,如果为-1,表示无图片." @默认值 = -1>
    参数 选中图片索引 <类型 = 整数 注释 = "索引值从0开始,如果为-1,表示无图片." @默认值 = -1>
    参数 正常加亮图片索引 <类型 = 整数 注释 = "索引值从0开始,如果为-1,表示无图片." @默认值 = -1>
    参数 选中加亮图片索引 <类型 = 整数 注释 = "索引值从0开始,如果为-1,表示无图片." @默认值 = -1>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetFolderBackImage (@<菜单索引>, @<正常图片索引>, @<选中图片索引>, @<正常加亮图片索引>, @<选中加亮图片索引>)
    }

    方法 取菜单底图 <公开 注释 = "获取指定菜单的背景图片" @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始.">
    参数 正常图片索引 <类型 = 整数类 注释 = "用作保存所获取到的图片索引,为空对象表示忽略本参数." @默认值 = 空对象>
    参数 选中图片索引 <类型 = 整数类 注释 = "用作保存所获取到的图片索引,为空对象表示忽略本参数." @默认值 = 空对象>
    参数 正常加亮图片索引 <类型 = 整数类 注释 = "用作保存所获取到的图片索引,为空对象表示忽略本参数." @默认值 = 空对象>
    参数 选中加亮图片索引 <类型 = 整数类 注释 = "用作保存所获取到的图片索引,为空对象表示忽略本参数." @默认值 = 空对象>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderBackImage (@<菜单索引>, @<正常图片索引.值>, @<选中图片索引.值>, @<正常加亮图片索引.值>, @<选中加亮图片索引.值>)
    }

    方法 菜单是否已禁止 <公开 类型 = 逻辑型 注释 = "返回所指定菜单是否已经被禁止,如果所指定菜单不存在,将返回假(注意正常也可能返回假)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.IsFolderDisabled (@<菜单索引>)
    }

    方法 禁止菜单 <公开 类型 = 逻辑型 注释 = "禁止或取消禁止指定菜单." 注释 = "被禁止的菜单不接受鼠标点击,外观上也与正常菜单有所区别." 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    参数 是否禁止 <类型 = 逻辑型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.DisableFolder (@<菜单索引>, @<是否禁止>)
    }

    方法 项目是否已禁止 <公开 类型 = 逻辑型 注释 = "返回指定项目是否已被禁止. 如果所指定项目不存在,将返回假(注意正常情况下也可能返回假)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.IsItemDisabled (@<菜单索引>, @<项目索引>)
    }

    方法 禁止项目 <公开 类型 = 逻辑型 注释 = "禁止或取消禁止指定项目." 注释 = "被禁止的项目不接受鼠标点击,外观上也与正常项目有所区别." 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 是否禁止 <类型 = 逻辑型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.DisableItem (@<菜单索引>, @<项目索引>, @<是否禁止>)
    }

    方法 菜单是否已隐藏 <公开 类型 = 逻辑型 注释 = "返回所指定菜单是否已经被隐藏,如果所指定菜单不存在,将返回假(注意正常也可能返回假)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.IsFolderHided (@<菜单索引>)
    }

    方法 隐藏菜单 <公开 类型 = 逻辑型 注释 = "隐藏或取消隐藏指定菜单." 注释 = "被隐藏的菜单不可见,且不可被设置为当前菜单." 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    参数 是否隐藏 <类型 = 逻辑型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.HideFolder (@<菜单索引>, @<是否隐藏>)
    }

    方法 项目是否已隐藏 <公开 类型 = 逻辑型 注释 = "返回指定项目是否已被隐藏. 如果所指定项目不存在,将返回假(注意正常情况下也可能返回假)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.IsItemHided (@<菜单索引>, @<项目索引>)
    }

    方法 隐藏项目 <公开 类型 = 逻辑型 注释 = "隐藏或取消隐藏指定项目" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 是否隐藏 <类型 = 逻辑型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.HideItem (@<菜单索引>, @<项目索引>, @<是否隐藏>)
    }

    方法 取菜单提示文本 <公开 类型 = 文本型 注释 = "返回所指定菜单的提示文本." 注释 = "如果所指定菜单不存在,将返回空文本(注意正常也可能返回空文本)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    {
        @ @an<CVolString> (((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetFolderTipText (@<菜单索引>))
    }

    方法 置菜单提示文本 <公开 类型 = 逻辑型 注释 = "设置指定菜单的提示文本" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单.">
    参数 提示文本 <类型 = 文本型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetFolderTipText (@<菜单索引>, @<提示文本>.GetText ())
    }

    方法 取项目提示文本 <公开 类型 = 文本型 注释 = "返回所指定项目的提示文本." 注释 = "如果所指定项目不存在,将返回空文本(注意正常也可能返回空文本)." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    {
        @ @an<CVolString> (((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetItemTipText (@<菜单索引>, @<项目索引>))
    }

    方法 置项目提示文本 <公开 类型 = 逻辑型 注释 = "设置指定项目的提示文本" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 菜单索引 <类型 = 整数 注释 = "提供菜单的索引位置,从0开始. 如果为-1,表示为当前选中菜单." @默认值 = -1>
    参数 项目索引 <类型 = 整数 注释 = "提供项目的位置,索引从0开始.">
    参数 提示文本 <类型 = 文本型>
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.SetItemTipText (@<菜单索引>, @<项目索引>, @<提示文本>.GetText ())
    }

    # --
    #
    # @begin
    # <> <include>
    # virtual void OnItemSelected (INT nFolerIndex, INT nItemIndex)  { @<项目被选择> (nFolerIndex, nItemIndex); }
    # virtual void OnFolerChanged (INT nFolerIndex)  { @<菜单被改变> (nFolerIndex); }
    # virtual BOOL OnItemNameChanged (INT nFolderIndex, INT nItemIndex, const TCHAR* szItemName)  { return (@<项目名称被改变> (nFolderIndex, nItemIndex, @an<CVolString> (szItemName)) == 0); }
    # virtual BOOL OnFolerNameChanged (INT nFolerIndex, const TCHAR* szFolerName)  { return (@<菜单名称被改变> (nFolerIndex, @an<CVolString> (szFolerName)) == 0); }
    # virtual void OnFolerClicked (INT nFolerIndex)  { @<菜单被单击> (nFolerIndex); }
    # virtual void OnFolerRClicked (INT nFolerIndex)  { @<菜单被右击> (nFolerIndex); }
    # virtual void OnItemRClicked (INT nFolerIndex, INT nItemIndex)  { @<项目被右击> (nFolerIndex, nItemIndex); }
    # virtual void OnItemDblClicked (INT nFolerIndex, INT nItemIndex)  { @<项目被双击> (nFolerIndex, nItemIndex); }
    # <> </include>
    # @end
}
