<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.卷帘式菜单

类 卷帘菜单排列方式 <公开 @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 图标方式 <公开 值 = 0>
    常量 列表方式 <公开 值 = 1>
}

类 卷帘菜单风格 <公开 @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 无 <公开 值 = 0>
    常量 蓝色XP风格 <公开 值 = 1>
    常量 绿色XP风格 <公开 值 = 2>
    常量 银色XP风格 <公开 值 = 3>
    常量 自定义 <公开 值 = 4>
}

类 卷帘式菜单 <公开 基础类 = 窗口组件 @视窗.外部头文件 = "src\\mfc_out_bar.h"
        @视窗.外部源文件 = "src\\mfc_out_bar.cpp\r\nsrc\\lib\\GfxGroupEdit.cpp\r\nsrc\\lib\\GfxOutBarCtrl.cpp\r\nsrc\\lib\\OutBarDC.cpp\r\nsrc\\lib\\OutBarTipWnd.cpp"
        @视窗.后缀文本 = "public IOutBarEventListener" @视窗.外部资源文件 = "src\\lib\\res\\vol_out_bar.rc"
        @视窗.窗口组件 = "icon=\"res\\vol_out_bar.bmp\"\ndefault_size = \"100, 240\"">
{

    # @ @m<DECLARE_MFC_CONTROL_DEFAULT> (CVWnd_OutBar, IOutBarEventListener, 0, 0, WS_TABSTOP, 0)
    #
    # 事件 --

    方法 项目被选择 <公开 定义事件 类型 = 整数 注释 = "当用户单击项目时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">
    参数 项目索引 <类型 = 整数 注释 = "提供相关项目的索引位置,从0开始.">

    方法 菜单被改变 <公开 定义事件 类型 = 整数 注释 = "当菜单被改变时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">

    方法 项目名称被改变 <公开 定义事件 类型 = 整数 注释 = "当修改项目名称时产生本事件. 返回1表示不允许修改,返回0表示允许修改.">
    参数 菜单索引 <类型 = 整数 注释 = "提供名称被修改项目所处菜单的索引位置,从0开始.">
    参数 项目索引 <类型 = 整数 注释 = "提供名称被修改项目的索引位置,从0开始.">
    参数 项目文本 <类型 = 文本型 注释 = "提供所欲修改到的项目名称">

    方法 菜单名称被改变 <公开 定义事件 类型 = 整数 注释 = "当修改菜单名称时产生本事件. 返回1表示不允许修改,返回0表示允许修改.">
    参数 菜单索引 <类型 = 整数 注释 = "提供名称被修改菜单的索引位置,从0开始.">
    参数 菜单文本 <类型 = 文本型 注释 = "提供所欲修改到的菜单名称">

    方法 菜单被单击 <公开 定义事件 类型 = 整数 注释 = "当用户单击菜单时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">

    方法 菜单被右击 <公开 定义事件 类型 = 整数 注释 = "当用户用鼠标右键单击菜单时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">

    方法 项目被右击 <公开 定义事件 类型 = 整数 注释 = "当用户用鼠标右键单击项目时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">
    参数 项目索引 <类型 = 整数 注释 = "提供相关项目的索引位置,从0开始.">

    方法 项目被双击 <公开 定义事件 类型 = 整数 注释 = "当用户用鼠标左键双击项目时产生本事件">
    参数 菜单索引 <类型 = 整数 注释 = "提供相关菜单的索引位置,从0开始.">
    参数 项目索引 <类型 = 整数 注释 = "提供相关项目的索引位置,从0开始.">

    # 属性 --

    方法 项目 <公开 属性写 注释 = "设置组合框下拉列表部分中的列表项目内容" @视窗.设置时机 = 组件创建前后 @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nOutBarDesigner">
    参数 所欲设置的内容 <类型 = 文本型 注释 = "项目内容为以\'\\n\'字符分隔的文本数组" 编辑时信息 = "157FEA, 0, 0, 0">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->ResetOutBarItems (@<所欲设置的内容>);
    }

    方法 项目图标图片组 <公开 属性写 注释 = "提供当\"排列方式\"属性为\"图标方式\"时项目使用的图标" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组 <类型 = 图片组资源 注释 = "对图片组图片格式的要求请参见\"图片组资源\"类中的说明">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->TakeOverBigImageList ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲设置的图片组>));
    }

    方法 项目列表图片组 <公开 属性写 注释 = "提供当\"排列方式\"属性为\"列表方式\"时项目使用的图标" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的图片组 <类型 = 图片组资源 注释 = "对图片组图片格式的要求请参见\"图片组资源\"类中的说明">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->TakeOverSmallImageList ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲设置的图片组>));
    }

    方法 置项目图标图片组 <公开 注释 = "设置当\"排列方式\"属性为\"图标方式\"时项目使用的图标">
    参数 所欲设置的图片组 <类型 = 图片组对象类 注释 = "注意该参数对象内的图片组资源将移交本对象管理">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->TakeOverBigImageList ((HIMAGELIST)@<所欲设置的图片组>.DetachGDIHandle ());
    }

    方法 置项目列表图片组 <公开 注释 = "设置当\"排列方式\"属性为\"列表方式\"时项目使用的图标">
    参数 所欲设置的图片组 <类型 = 图片组对象类 注释 = "注意该参数对象内的图片组资源将移交本对象管理">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->TakeOverSmallImageList ((HIMAGELIST)@<所欲设置的图片组>.DetachGDIHandle ());
    }

    方法 背景颜色 <公开 属性写 @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_OutBar* pOutBar = (CVWnd_OutBar*)GetMfcWndPtr ();
        @ pOutBar->m_OutBar.SetColor (_T ("crBackGroundColor"), GetRealBackColor (pOutBar->m_BackColor = @<所欲设置的颜色>));
    }

    方法 背景颜色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_BackColor
    }

    方法 排列方式 <公开 属性写 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的方式 <类型 = 卷帘菜单排列方式>
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->SetRangeStyle (@<所欲设置的方式>);
    }

    方法 排列方式 <公开 属性读 类型 = 卷帘菜单排列方式 @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->RangeStyle
    }

    方法 现行选中菜单 <公开 属性写 注释 = "设置当前被选中菜单" @视窗.设置时机 = 组件创建前后>
    参数 菜单位置索引 <类型 = 整数 注释 = "菜单位置索引从0开始,为-1表示无现行选中菜单.">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->SetSelFolder (@<菜单位置索引>);
    }

    方法 现行选中菜单 <公开 属性读 类型 = 整数 注释 = "返回现行选中菜单位置索引,为-1表示无." @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetSelFolder ()
    }

    方法 现行选中项目 <公开 属性写 注释 = "设置现行被选中菜单中的当前被选中项目" @视窗.设置时机 = 组件创建前后>
    参数 项目位置索引 <类型 = 整数 注释 = "项目位置索引从0开始,为-1表示没有现行选中项目.">
    {
        @ ((CVWnd_OutBar*)GetMfcWndPtr ())->SetSelItem (@<项目位置索引>);
    }

    方法 现行选中项目 <公开 属性读 类型 = 整数 返回值注释 = "返回现行选中项目位置索引,为-1表示无." @嵌入式方法 = "">
    {
        @ ((CVWnd_OutBar*)@sn<this>.GetMfcWndPtr ())->m_OutBar.GetSelItem ()
    }

    方法 菜单底色 <公开 属性写 注释 = "注意仅当\"XP风格\"为无/自定义时候有效" @值细节类型 = 颜色支持默认 @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的颜色 <类型 = 整数 注释 = "可以使用\"颜色类\"所提供的颜色值">
    {
        @ CVWnd_OutBar* pOutBar = (CVWnd_OutBar*)GetMfcWndPtr ();
        @ pOutBar->m_OutBar.SetColor (_T ("crFolderBgColor"), GetRealBackColor (pOutBar->crFolderBgColor = @<所欲设置的颜色>));
    }

    方法 菜单底色 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
