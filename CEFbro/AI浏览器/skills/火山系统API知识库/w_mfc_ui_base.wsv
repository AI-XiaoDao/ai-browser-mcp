    }

    方法 取用户区矩形 <公开 类型 = 矩形类 注释 = "  获取并返回当前组件的用户区矩形位置,对窗口而言,用户区域为" 注释 = "窗口区域减去标题栏+菜单栏+边框后的区域.">
    {
        变量 矩形变量1 <类型 = 矩形类>
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetClientRect (&rt);
        @     @<矩形变量1>.Copy (&rt);  // 取回所获得的位置矩形
        @ }
        返回 (矩形变量1)
    }

    方法 取屏幕位置 <公开 类型 = 矩形类 注释 = "获取并返回当前组件在屏幕中的所处矩形位置">
    {
        变量 矩形变量1 <类型 = 矩形类>
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     @<矩形变量1>.Copy (&rt);  // 取回所获得的位置矩形
        @ }
