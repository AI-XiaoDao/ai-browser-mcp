        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
