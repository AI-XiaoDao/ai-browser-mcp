类 菜单类 <公开 基础类 = 可设计类 注释 = "  用作记录MFC菜单对象,提供有对应的菜单设计器,用户可以在" 注释 = "所有本类的继承类上点击右键,在弹出菜单中选择打开该设计器" 注释 = "进行菜单设计."
        编辑时信息 = "16153F, 0, 0, 0" @文档 = "category = \"常用功能\""
        @设计器 = "name = \"菜单设计器\"\r\ndll_file_name\r\n{\r\n    x64 = \"designer\\mfc_designer_x64.dll\"\r\n    win32 = \"designer\\mfc_designer_win32.dll\"\r\n}\r\nauto_generate_mark = \"mfc\"\r\nuser_param = 1"
        @可插入程序类 = "icon=\"res\\menu.bmp\"\r\nexplain=\"在所插入新菜单类上单击鼠标右键,选择\\\"打开菜单设计器\\\"菜单项即可设计该菜单的内容.\""
        @视窗.外部源文件 = "..\\base\\libs\\win_base\\cpp\\vol_menu.cpp">
{
    方法 重载 <公开 注释 = "如果本菜单的内容被修改,执行本方法可以将其重置到设计时状态.">
    {
        @ if (m_pRefObject != NULL)
        @     ((CRefVolMenu*)m_pRefObject)->LoadFromDesignContent (NULL);
    }

    方法 删除菜单项 <公开 类型 = 逻辑型 注释 = "删除所指定ID的菜单项,返回是否成功." @嵌入式方法 = "">
    参数 所欲删除菜单项ID <类型 = 整数>
    {
        @ (BOOL)@sn<this>.GetVolMenu ()->DeleteMenuItem ((UINT_P)@<所欲删除菜单项ID>)
    }

    方法 插入菜单项 <公开 类型 = 整数 注释 = "插入一个新的菜单项目" 返回值注释 = "成功返回所插入菜单项的ID值,失败或插入分隔条返回0." @嵌入式方法 = "">
    参数 新菜单项ID <类型 = 整数 注释 = "指定所欲插入新菜单项的ID值,必须尚不存在,否则将插入失败.如果为0,则自动计算使用一个不重复的ID值." @默认值 = 0>
    参数 新菜单项标题 <类型 = 文本型 注释 = "提供新菜单项的标题文本,如果为空文本,则插入一个分隔条.">
    参数 插入位置菜单项ID <类型 = 整数 注释 = "如果\"是否插入在尾部\"参数值为假,新菜单项将插入在为该ID的已有菜单项前面.">
    参数 是否插入在尾部 <类型 = 逻辑型 注释 = "如果本参数值为真,则将始终插入到\"插入位置菜单项ID\"参数所指定菜单项所处子菜单的尾部." @默认值 = 假>
    参数 新菜单项提示文本 <类型 = 文本型 注释 = "提供新菜单项的提示文本" @默认值 = "">
    参数 是否选中 <类型 = 逻辑型 注释 = "是否选中所插入的新菜单项" @默认值 = 假>
    参数 是否禁止 <类型 = 逻辑型 注释 = "是否禁止所插入的新菜单项" @默认值 = 假>
    参数 图标索引位置 <类型 = 整数 注释 = "提供菜单项的图标索引位置,为-1表示无." 注释 = "注意: 基本菜单类并不支持设置菜单项图标,此特性需要菜单继承类支持." @默认值 = -1>
    {
        @ (INT)@sn<this>.GetVolMenu ()->InsertNewMenuItem ((UINT_P)@<插入位置菜单项ID>, @<是否插入在尾部>, (UINT_P)@<新菜单项ID>, @<新菜单项标题>.GetText (), @<新菜单项提示文本>.GetText (), @<是否选中>, @<是否禁止>, @<图标索引位置>)
    }

    方法 选中菜单项 <公开 类型 = 逻辑型 注释 = "设置或取消所指定ID菜单项目的选中状态,返回是否成功." @禁止流程检查 = 真>
    参数 所欲操作菜单项ID <类型 = 整数>
    参数 是否选中 <类型 = 逻辑型>
    {
        @ return GetVolMenu ()->SetMenuItemFlags ((UINT_P)@<所欲操作菜单项ID>, (@<是否选中> ? VOLMF_CHECKED : 0), (@<是否选中> ? 0 : VOLMF_CHECKED), 0);
    }

    方法 翻转菜单项选中状态 <公开 类型 = 逻辑型 注释 = "翻转所指定ID菜单项目的当前选中状态,返回是否成功." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ @sn<this>.GetVolMenu ()->SetMenuItemFlags ((UINT_P)@<所欲操作菜单项ID>, 0, 0, VOLMF_CHECKED)
    }

    方法 允许菜单项 <公开 类型 = 逻辑型 注释 = "设置或取消所指定ID菜单项的操作允许状态,返回是否成功." @禁止流程检查 = 真>
    参数 所欲操作菜单项ID <类型 = 整数>
    参数 是否允许操作 <类型 = 逻辑型 注释 = "指定是否允许用户操作菜单项">
    {
        @ return GetVolMenu ()->SetMenuItemFlags ((UINT_P)@<所欲操作菜单项ID>, (@<是否允许操作> ? 0 : VOLMF_DISABLED), (@<是否允许操作> ? VOLMF_DISABLED : 0), 0);
    }

    方法 是否被选中 <公开 类型 = 逻辑型 注释 = "返回所指定ID菜单项是否处于被选中状态,如果所指定菜单项不存在,将始终返回假." @禁止流程检查 = 真>
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ return ((GetVolMenu ()->GetMenuItemFlags ((UINT_P)@<所欲操作菜单项ID>) & VOLMF_CHECKED) != 0);
    }

    方法 是否被允许 <公开 类型 = 逻辑型 注释 = "返回所指定ID菜单项是否处于被允许操作状态,如果所指定菜单项不存在,将始终返回假." @禁止流程检查 = 真>
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ return ((GetVolMenu ()->GetMenuItemFlags ((UINT_P)@<所欲操作菜单项ID>) & VOLMF_DISABLED) == 0);
    }

    方法 取菜单项标题 <公开 类型 = 文本型 注释 = "返回所指定ID菜单项目的标题文本,如果所指定菜单项不存在,将返回空文本." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ @sn<this>.GetVolMenu ()->GetMenuItemCaption ((UINT_P)@<所欲操作菜单项ID>)
    }

    方法 置菜单项标题 <公开 类型 = 逻辑型 注释 = "设置所指定ID菜单项目的标题文本,返回是否成功." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    参数 所欲设置的标题 <类型 = 文本型>
    {
        @ @sn<this>.GetVolMenu ()->SetMenuItemCaption ((UINT_P)@<所欲操作菜单项ID>, @<所欲设置的标题>.GetText ())
    }

    方法 取菜单项提示 <公开 类型 = 文本型 注释 = "返回所指定ID菜单项目的提示文本,如果所指定菜单项不存在,将返回空文本." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ @an<CVolString> (@sn<this>.GetVolMenu ()->GetMenuItemTip ((UINT_P)@<所欲操作菜单项ID>))
    }

    方法 置菜单项提示 <公开 类型 = 逻辑型 注释 = "设置所指定ID菜单项目的提示文本,返回是否成功." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    参数 所欲设置的提示文本 <类型 = 文本型>
    {
        @ (BOOL)@sn<this>.GetVolMenu ()->SetMenuItemTip ((UINT_P)@<所欲操作菜单项ID>, @<所欲设置的提示文本>.GetText ())
    }

    方法 取菜单项图标索引 <公开 类型 = 整数 注释 = "返回所指定ID菜单项目的图标索引位置,如果所指定菜单项不存在,将返回-1." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    {
        @ @sn<this>.GetVolMenu ()->GetMenuItemImageIndex ((UINT_P)@<所欲操作菜单项ID>)
    }

    方法 置菜单项图标索引 <公开 类型 = 逻辑型 注释 = "设置所指定ID菜单项目的图标索引位置,返回是否成功." 注释 = "注意: 基本菜单类并不支持设置菜单项图标,此特性及所使用到的图片组需要由菜单继承类支持." @嵌入式方法 = "">
    参数 所欲操作菜单项ID <类型 = 整数>
    参数 所欲设置的图标索引 <类型 = 整数 注释 = "提供所欲设置的图标索引位置,为-1表示无.">
    {
        @ (BOOL)@sn<this>.GetVolMenu ()->SetMenuItemImageIndex ((UINT_P)@<所欲操作菜单项ID>, @<所欲设置的图标索引>)
    }

