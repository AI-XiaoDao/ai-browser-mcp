        @     pWnd->ScreenToClient (&pt);
        @     @<待转换位置>.Copy (&pt);  // 取回所获得的位置
        @ }
    }

    方法 用户区位置到屏幕 <公开 注释 = "将所指定的用户区位置(基于本组件用户区左上角)转换到基于屏幕左上角">
    参数 待转换位置 <类型 = 位置类 注释 = "提供待转换的屏幕位置,转换完毕后的结果将写回此对象中.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CMPoint pt (@<待转换位置>.ToPoint ());
        @     pWnd->ClientToScreen (&pt);
        @     @<待转换位置>.Copy (&pt);  // 取回所获得的位置
        @ }
    }

    方法 禁止重画 <公开 注释 = "禁止本窗口组件重画,以避免当频繁进行操作时引起闪烁." 注释 = "注意调用本命令后必须调用\"允许重画\"命令进行恢复.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetRedraw (FALSE);
    }

    方法 允许重画 <公开 注释 = "如果本组件先前调用过\"禁止重画\"方法禁止了重画,调用本方法可以重新将其允许.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->SetRedraw (TRUE);
        @     pWnd->Invalidate ();
        @ }
    }

    方法 重画 <公开 注释 = "通知Windows系统本窗口组件上的显示内容需要被全部重画">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->Invalidate ();
    }

    方法 部分重画 <公开 注释 = "通知Windows系统本窗口组件上所指定用户区域内的显示内容需要被重画">
    参数 欲重画区域的左边 <类型 = 整数 注释 = "相对于本组件用户区域的左边">
    参数 欲重画区域的顶边 <类型 = 整数 注释 = "相对于本组件用户区域的顶边">
    参数 欲重画区域的宽度 <类型 = 整数>
    参数 欲重画区域的高度 <类型 = 整数>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->InvalidateRect (&CRect (@<欲重画区域的左边>, @<欲重画区域的顶边>, @<欲重画区域的左边> + @<欲重画区域的宽度>, @<欲重画区域的顶边> + @<欲重画区域的高度>));
    }

    方法 取消重画 <公开 注释 = "通知Windows系统本窗口组件不再需要被重画,保留现有的全部显示内容.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->ValidateRect (NULL);
    }

    方法 刷新显示 <公开 注释 = "  一般情况下,如果本窗口组件上的显示内容需要被全部或部分重画," 注释 = "Windows系统会等到下一次系统空闲时刷新显示,但是这样无法满足一"
            注释 = "些需要即时更新的场合,此时执行本方法可以立即对本窗口组件进行重" 注释 = "画更新.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->UpdateWindow ();
    }

    方法 移动 <公开 注释 = "改变窗口组件的位置或尺寸">
    参数 左边 <类型 = 整数 注释 = "  提供新的左边位置,如果当前组件为顶层窗口,则相对屏幕左边位置," 注释 = "否则相对其所处父组件的用户区左边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有左边位置不变."
            @默认值 = 数值范围.最小整数值>
    参数 顶边 <类型 = 整数 注释 = "  提供新的顶边位置,如果当前组件为顶层窗口,则相对屏幕顶边位置," 注释 = "否则相对其所处父组件的用户区顶边位置." 注释 = "  为\"数值范围.最小整数值\"常量值表示保持原有顶边位置不变."
            @默认值 = 数值范围.最小整数值>
    参数 宽度 <类型 = 整数 注释 = "提供组件新的宽度,如果为-1则保持原有宽度不变." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "提供组件新的高度,如果为-1则保持原有高度不变." @默认值 = -1>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CRect rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParentWnd = pWnd->GetParent ();
        @     if (pParentWnd != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParentWnd->ScreenToClient (&rt);
        @     CRect rtOld (rt);
        @     if (@<左边> != INT_MIN)  { rt.right = @<左边> + rt.Width ();  rt.left = @<左边>;  }
        @     if (@<顶边> != INT_MIN)  { rt.bottom = @<顶边> + rt.Height ();  rt.top = @<顶边>;  }
        @     if (@<宽度> != -1)  rt.right = rt.left + @<宽度>;
        @     if (@<高度> != -1)  rt.bottom = rt.top + @<高度>;
        @     if (rtOld != rt)
        @         pWnd->MoveWindow (&rt);
        @ }
    }

    方法 移动2 <公开 注释 = "改变窗口组件的位置或尺寸">
    参数 新位置 <类型 = 矩形类>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->MoveWindow (&@<新位置>.ToRect ());
    }

    方法 调整层次 <公开 注释 = "改变窗口组件的当前所处显示层次">
    参数 欲调整到的层次 <类型 = 组件层次>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     ::SetWindowPos (pWnd->m_hWnd, (HWND)@<欲调整到的层次>, 0, 0, 0, 0, SWP_NOACTIVATE | SWP_NOMOVE | SWP_NOSIZE);
    }

    方法 发送信息 <公开 类型 = 变整数 注释 = "将指定信息发送到本窗口组件,并等待且取回信息反馈值." @禁止流程检查 = 真>
    参数 信息值 <类型 = 整数>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)pWnd->SendMessage ((UINT)@<信息值>, (WPARAM)@<参数1>, (LPARAM)@<参数2>) : 0);
    }

    方法 投递信息 <公开 类型 = 逻辑型 注释 = "将指定信息发送到本窗口组件,不等待直接返回." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 信息值 <类型 = 整数>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? pWnd->PostMessage ((UINT)@<信息值>, (WPARAM)@<参数1>, (LPARAM)@<参数2>) : FALSE);
    }

    方法 置父窗口 <公开 注释 = "设置本窗口组件的父窗口组件">
    参数 所欲设置的父组件 <类型 = 窗口组件 注释 = "可以是窗口或窗口组件">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pParentWnd = @<所欲设置的父组件>.GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pParentWnd != NULL && pWnd->m_hWnd != pParentWnd->m_hWnd)
        @     pWnd->SetParent (pParentWnd);
    }

    方法 用户区截图 <公开 类型 = 逻辑型 注释 = "取回本组件上用户区内所有现有显示内容的图片对象" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 所取回图片 <类型 = 位图对象类 注释 = "组件上用户区内所有现有显示内容将被填入到此对象中">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "所取得图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如"
            注释 = "果大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "所取得图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如"
            注释 = "果大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ @<所取回图片.置位图句柄值> ((INT_P)CatchClientBitmap (@sn<this>.GetMfcWndPtr ()->m_hWnd, @<输出宽度>, @<输出高度>), TRUE)
    }

    方法 组件截图 <公开 类型 = 逻辑型 注释 = "取回本组件上整体(包括用户区与非用户区)所有现有显示内容的图片对象" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 所取回图片 <类型 = 位图对象类 注释 = "组件上整体所有现有显示内容将被填入到此对象中">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "所取得图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如"
            注释 = "果大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "所取得图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如"
            注释 = "果大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ @<所取回图片.置位图句柄值> ((INT_P)CatchWindowBitmap (@sn<this>.GetMfcWndPtr ()->m_hWnd, @<输出宽度>, @<输出高度>), TRUE)
    }

    方法 提到前方 <公开 注释 = "将本窗口的叠放位置提到其它窗口的前方">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->BringWindowToTop ();
    }

    方法 激活 <公开 注释 = "将本窗口设置为当前活动窗口. 仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetActiveWindow ();
    }

    方法 置为前台窗口 <公开 注释 = "将本窗口设置为系统前台窗口. 仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SetForegroundWindow ();
    }

    方法 执行 <公开 注释 = "执行所指定的命令行. 仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况.">
    参数 欲操作文件名 <类型 = 文本型 注释 = "提供欲操作文件或文件夹的名称">
    参数 命令类型 <类型 = 所执行命令类型 注释 = "本参数提供欲执行命令的类型" @默认值 = 所执行命令类型.默认>
    参数 命令行 <类型 = 文本型 注释 = "  如果欲进行操作的类型为\"打开文件\"且被打开文件为可执行文件,本参数提供" 注释 = "启动该可执行文件时欲附加的命令行文本,其它情况下本参数将被忽略." @默认值 = "">
    参数 默认当前目录 <类型 = 文本型 注释 = "提供命令执行时的默认当前目录" @默认值 = "">
    {
        @ ::ShellExecute (GetMfcWndHandle (), (@<命令类型> == 1 ? _T ("edit") : @<命令类型> == 2 ? _T ("explore") : @<命令类型> == 3 ? _T ("find") :
        @          @<命令类型> == 4 ? _T ("open") : @<命令类型> == 5 ? _T ("print") : NULL),
        @          @<欲操作文件名>.GetText (), @<命令行>.GetText (), @<默认当前目录>.GetText (), SW_SHOW);
    }

    方法 删除到回收站 <公开 类型 = 逻辑型 注释 = "将一个或一批文件删除到Windows系统回收站中. 仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况." 返回值注释 = "成功返回真,失败或被用户中止删除操作返回假."
            @禁止流程检查 = 真>
    参数 欲删除文件 <类型 = 文本型 注释 = "提供所欲删除的文件名(注意必须是全路径),支持使用通配字符\"*\"和\"?\".">
    参数 删除选项 <类型 = 整数 注释 = "本参数提供删除操作选项,可以为以下值之一或之和: 1.不询问删除; 2.不提示错误; 4.不显示进度." @默认值 = 0>
    {
        如果 (文本是否为空 (欲删除文件))
        {
            返回 (假)
        }
        @ CVolMem mem;
        @ mem.AddString (@<欲删除文件>.GetText ());
        @ mem.AddChar ('\0');
        @ SHFILEOPSTRUCT inf;
        @ ZERO_MEM (&inf, sizeof (inf));
        @ inf.hwnd = GetMfcWndHandle ();
        @ inf.wFunc = FO_DELETE;
        @ inf.pFrom = (LPCTSTR)mem.GetPtr ();
        @ inf.fFlags = FOF_ALLOWUNDO;
        @ if ((@<删除选项> & 1) != 0)  inf.fFlags |= FOF_NOCONFIRMATION;
        @ if ((@<删除选项> & 2) != 0)  inf.fFlags |= FOF_NOERRORUI;
        @ if ((@<删除选项> & 4) != 0)  inf.fFlags |= FOF_SILENT;
        @ return (SHFileOperation (&inf) == 0 && inf.fAnyOperationsAborted == FALSE);
    }

    方法 进度复制文件 <公开 类型 = 逻辑型 注释 = "将所指定文件复制或移动到另一个目录中,并同时显示一个进度对话框." 注释 = "仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况."
            返回值注释 = "成功返回真,失败或被用户中止删除操作返回假." @禁止流程检查 = 真>
    参数 目的目录 <类型 = 文本型 注释 = "本参数提供目的目录路径,如果该目录不存在,系统将自动询问是否创建.">
    参数 源文件 <类型 = 文本型 注释 = "提供所欲复制的文件名(注意必须是全路径),支持使用通配字符\"*\"和\"?\".">
    参数 是否为移动 <类型 = 逻辑型 注释 = "为真则移动文件,为假则复制文件." @默认值 = 假>
    {
        如果 (文本是否为空 (目的目录) || 文本是否为空 (源文件))
        {
            返回 (假)
        }
        @ CVolMem memDest, memSrc;
        @ memDest.AddString (@<目的目录>.GetText ());
        @ memDest.AddChar ('\0');
        @ memSrc.AddString (@<源文件>.GetText ());
        @ memSrc.AddChar ('\0');
        @ SHFILEOPSTRUCT inf;
        @ ZERO_MEM (&inf, sizeof (inf));
        @ inf.hwnd = GetMfcWndHandle ();
        @ inf.wFunc = (@<是否为移动> ? FO_MOVE : FO_COPY);
        @ inf.pFrom = (LPCTSTR)memSrc.GetPtr ();
        @ inf.pTo = (LPCTSTR)memDest.GetPtr ();
        @ return (SHFileOperation (&inf) == 0 && inf.fAnyOperationsAborted == FALSE);
    }

    方法 批量删除到回收站 <公开 类型 = 逻辑型 注释 = "将一个或一批文件删除到Windows系统回收站中. 仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况."
            返回值注释 = "成功返回真,失败或被用户中止删除操作返回假." @禁止流程检查 = 真>
    参数 欲删除文件数组 <类型 = 文本数组类 注释 = "提供所欲删除的所有文件名(注意必须是全路径),支持使用通配字符\"*\"和\"?\".">
    参数 删除选项 <类型 = 整数 注释 = "本参数提供删除操作选项,可以为以下值之一或之和: 1.不询问删除; 2.不提示错误; 4.不显示进度." @默认值 = 0>
    {
        如果 (欲删除文件数组.是否为空 ())
        {
            返回 (假)
        }
        @ CVolMem mem;
        @ const INT_P npCount = @<欲删除文件数组>.data ().GetCount ();
        @ for (INT_P npIndex = 0; npIndex < npCount; npIndex++)
        {
            @ mem.AddString (@<欲删除文件数组>.data ().GetAt (npIndex));
        }
        @ mem.AddChar ('\0');
        @ SHFILEOPSTRUCT inf;
        @ ZERO_MEM (&inf, sizeof (inf));
        @ inf.hwnd = GetMfcWndHandle ();
        @ inf.wFunc = FO_DELETE;
        @ inf.pFrom = (LPCTSTR)mem.GetPtr ();
        @ inf.fFlags = FOF_ALLOWUNDO;
        @ if ((@<删除选项> & 1) != 0)  inf.fFlags |= FOF_NOCONFIRMATION;
        @ if ((@<删除选项> & 2) != 0)  inf.fFlags |= FOF_NOERRORUI;
        @ if ((@<删除选项> & 4) != 0)  inf.fFlags |= FOF_SILENT;
        @ return (SHFileOperation (&inf) == 0 && inf.fAnyOperationsAborted == FALSE);
    }

    方法 批量进度复制文件 <公开 类型 = 逻辑型 注释 = "将一个或一批文件复制或移动到另一个目录中,并同时显示一个进度对话框." 注释 = "仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况."
            返回值注释 = "成功返回真,失败或被用户中止删除操作返回假." @禁止流程检查 = 真>
    参数 目的目录 <类型 = 文本型 注释 = "本参数提供目的目录路径,如果该目录不存在,系统将自动询问是否创建.">
    参数 源文件数组 <类型 = 文本数组类 注释 = "提供所有欲复制的文件名(注意必须是全路径),支持使用通配字符\"*\"和\"?\".">
    参数 是否为移动 <类型 = 逻辑型 注释 = "为真则移动文件,为假则复制文件." @默认值 = 假>
    {
        如果 (文本是否为空 (目的目录) || 源文件数组.是否为空 ())
        {
            返回 (假)
        }
        @ CVolMem memDest, memSrc;
        @ memDest.AddString (@<目的目录>.GetText ());
        @ memDest.AddChar ('\0');
        @ const INT_P npCount = @<源文件数组>.data ().GetCount ();
        @ for (INT_P npIndex = 0; npIndex < npCount; npIndex++)
        {
            @ memSrc.AddString (@<源文件数组>.data ().GetAt (npIndex));
        }
        @ memSrc.AddChar ('\0');
        @ SHFILEOPSTRUCT inf;
        @ ZERO_MEM (&inf, sizeof (inf));
        @ inf.hwnd = GetMfcWndHandle ();
        @ inf.wFunc = (@<是否为移动> ? FO_MOVE : FO_COPY);
        @ inf.pFrom = (LPCTSTR)memSrc.GetPtr ();
        @ inf.pTo = (LPCTSTR)memDest.GetPtr ();
        @ return (SHFileOperation (&inf) == 0 && inf.fAnyOperationsAborted == FALSE);
    }

    方法 浏览文件夹 <公开 类型 = 文本型 注释 = "  打开一个对话框,浏览系统中存在的所有文件夹,返回被选定" 注释 = "文件夹的路径名,如果未选中任何文件夹,则返回空文本."
            注释 = "  仅用作本对象的实际类型为\"窗口\"或\"MDI主窗口\"的情况.">
    参数 标题 <类型 = 文本型 注释 = "提供显示在对话框上部的标题文本">
    参数 是否包含文件 <类型 = 逻辑型 注释 = "指定是否在浏览框中同时列出文件名" @默认值 = 假>
    {
        变量 结果变量 <类型 = 文本型>
        @ BROWSEINFO inf;
        @ ZERO_MEM (&inf, sizeof (inf));
        @ inf.hwndOwner = GetMfcWndHandle ();
        @ TCHAR path [MAX_PATH];
        @ path [0] = '\0';
        @ inf.pszDisplayName = path;
        @ inf.lpszTitle = @<标题>.GetText ();
        @ inf.ulFlags = BIF_EDITBOX;
        @ if (@<是否包含文件>)
        @     inf.ulFlags |= BIF_BROWSEINCLUDEFILES;
        @ LPITEMIDLIST pItem = SHBrowseForFolder (&inf);
        @ if (pItem != NULL)
        @ {
        @     path [0] = '\0';
        @     if (SHGetPathFromIDList (pItem, path))
        @         @<结果变量>.SetText (path);
        @     IMalloc* pMalloc;
        @     if (SUCCEEDED (SHGetMalloc (&pMalloc)))
        @     {
        @         pMalloc->Free (pItem);
        @         pMalloc->Release ();
        @     }
        @ }
        返回 (结果变量)
    }

    方法 弹出菜单 <公开 类型 = 逻辑型 注释 = "在屏幕上指定位置弹出所指定的子菜单,用户点击该子菜单中菜单项所产生的命令将由本窗口组件接收处理." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲弹出的菜单 <类型 = 菜单类 注释 = "提供所欲弹出菜单类的数据类型,应该为\"菜单类\"的继承类.所实际弹出的菜单为该菜单的第一个子菜单." @需求类型 = 数据类型>
    参数 横向位置 <类型 = 整数 注释 = "指定所弹出子菜单的左边在屏幕上的横向位置,为\"数值范围.最小整数值\"常量值则使用当前鼠标在屏幕上的横向位置." @默认值 = 数值范围.最小整数值>
    参数 纵向位置 <类型 = 整数 注释 = "指定所弹出子菜单的顶边在屏幕上的纵向位置,为\"数值范围.最小整数值\"常量值则使用当前鼠标在屏幕上的纵向位置." @默认值 = 数值范围.最小整数值>
    参数 子菜单位置 <类型 = 整数 注释 = "指定所欲弹出子菜单在所提供菜单内顶层菜单项中的索引位置" @默认值 = 0>
    {
        @ @sn<this>.PopupSubMenuClass (@<横向位置>, @<纵向位置>, VOL_RUNTIME_CLASS (@<所欲弹出的菜单>), FALSE, @<子菜单位置>)
    }

    方法 弹出实例菜单 <公开 类型 = 逻辑型 注释 = "在屏幕上指定位置弹出所指定的子菜单,用户点击该子菜单中菜单项所产生的命令将由本窗口组件接收处理." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲弹出的菜单 <类型 = 菜单类 注释 = "提供所欲弹出的菜单类对象,所实际弹出的菜单为该菜单的第一个子菜单.">
    参数 横向位置 <类型 = 整数 注释 = "指定所弹出子菜单的左边在屏幕上的横向位置,为\"数值范围.最小整数值\"常量值则使用当前鼠标在屏幕上的横向位置." @默认值 = 数值范围.最小整数值>
    参数 纵向位置 <类型 = 整数 注释 = "指定所弹出子菜单的顶边在屏幕上的纵向位置,为\"数值范围.最小整数值\"常量值则使用当前鼠标在屏幕上的纵向位置." @默认值 = 数值范围.最小整数值>
    参数 子菜单位置 <类型 = 整数 注释 = "指定所欲弹出子菜单在所提供菜单内顶层菜单项中的索引位置" @默认值 = 0>
    {
        @ @<所欲弹出的菜单>.GetVolMenu ()->PopupSubMenu (@<横向位置>, @<纵向位置>, FALSE, @sn<this>.GetMfcWndHandle (), @<子菜单位置>)
    }

    方法 弹出托盘菜单 <公开 类型 = 逻辑型 注释 = "在当前鼠标位置弹出指定菜单,本方法一般用作支持托盘菜单的弹出." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲弹出的菜单 <类型 = 菜单类 注释 = "提供所欲弹出菜单类的数据类型,应该为\"菜单类\"的继承类.所实际弹出的菜单为该菜单的第一个子菜单." @需求类型 = 数据类型>
    参数 子菜单位置 <类型 = 整数 注释 = "指定所欲弹出子菜单在所提供菜单内顶层菜单项中的索引位置" @默认值 = 0>
    {
        @ @sn<this>.PopupSubMenuClass (INT_MIN, INT_MIN, VOL_RUNTIME_CLASS (@<所欲弹出的菜单>), TRUE, @<子菜单位置>)
    }

    方法 弹出托盘实例菜单 <公开 类型 = 逻辑型 注释 = "在当前鼠标位置弹出指定菜单,本方法一般用作支持托盘菜单的弹出." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲弹出的菜单 <类型 = 菜单类 注释 = "提供所欲弹出得菜单类对象,所实际弹出的菜单为该菜单的第一个子菜单.">
    参数 子菜单位置 <类型 = 整数 注释 = "指定所欲弹出子菜单在所提供菜单内顶层菜单项中的索引位置" @默认值 = 0>
    {
        @ @<所欲弹出的菜单>.GetVolMenu ()->PopupSubMenu (INT_MIN, INT_MIN, TRUE, @sn<this>.GetMfcWndHandle (), @<子菜单位置>)
    }

    方法 置窗口属性 <公开 类型 = 逻辑型 注释 = "设置关联到窗口句柄的一个命名属性值." 注释 = "注意: 当不再使用该属性时,需要调用\"删除窗口属性\"将其删除." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲设置的属性名称,不能为空文本.">
    参数 属性值 <类型 = 变整数 注释 = "提供所欲设置的属性值">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? ::SetProp (pWnd->m_hWnd, @<属性名称>.GetText (), (HANDLE)@<属性值>) : FALSE);
    }

    方法 取窗口属性 <公开 类型 = 变整数 注释 = "读取并返回关联到窗口句柄的指定命名属性值." 注释 = "该属性为使用\"置窗口属性\"方法设置." 返回值注释 = "成功返回所对应的属性值,失败返回0(注意也有可能本身属性值就为0)."
            @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲读取属性的名称,不能为空文本.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)::GetProp (pWnd->m_hWnd, @<属性名称>.GetText ()) : 0);
    }

    方法 删除窗口属性 <公开 类型 = 变整数 注释 = "删除通过使用\"置窗口属性\"方法所设置到窗口句柄上的关联属性" 返回值注释 = "成功返回该被删除属性所对应的属性值,失败返回0(注意也有可能本身属性值就为0)."
            @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型 注释 = "提供所欲删除属性的名称,不能为空文本.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? (INT_P)::RemoveProp (pWnd->m_hWnd, @<属性名称>.GetText ()) : 0);
    }

    方法 取分组编号 <公开 类型 = 整数 注释 = "返回本组件在设计时的分组编号,为-1表示无.">
    {
        返回 (取组件分组编号 (取窗口句柄 ()))
    }

    方法 取组件分组编号 <公开 静态 类型 = 整数 注释 = "返回所指定窗口句柄的组件在设计时的分组编号,为-1表示该组件设计时未分组或所提供窗口句柄不对应一个火山窗口组件." @嵌入式方法 = "">
    参数 组件窗口句柄值 <类型 = 变整数 注释 = "提供所欲获取其设计时分组编号的组件窗口句柄">
    {
        @ ::GetVolControlGroupNumber ((HWND)@<组件窗口句柄值>)
    }

    方法 置组件分组编号 <公开 静态 类型 = 逻辑型 注释 = "设置所指定窗口句柄的组件在设计时的分组编号" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 组件窗口句柄值 <类型 = 变整数 注释 = "提供所欲设置其设计时分组编号的组件窗口句柄">
    参数 新分组编号 <类型 = 整数 注释 = "提供所欲设置的新分组编号">
    {
        @ ::SetVolControlGroupNumber ((HWND)@<组件窗口句柄值>, @<新分组编号>)
    }

