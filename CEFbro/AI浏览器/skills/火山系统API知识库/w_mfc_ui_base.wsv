    方法 宽度 <公开 属性读 类型 = 整数 注释 = "返回当前组件的宽度,如果组件尚未被创建,将始终返回0." @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     return rt.right - rt.left;
        @ }
        @ return 0;
    }

    方法 宽度 <公开 属性写 注释 = "设置当前组件的宽度" @设计时隐藏 = 真>
    参数 所欲设置的宽度 <类型 = 整数>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     pWnd->SetWindowPos (NULL, 0, 0, @<所欲设置的宽度>, rt.bottom - rt.top, (SWP_NOMOVE | SWP_NOACTIVATE | SWP_NOZORDER));
        @ }
    }

    方法 高度 <公开 属性读 类型 = 整数 注释 = "返回当前组件的高度,如果组件尚未被创建,将始终返回0." @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     return rt.bottom - rt.top;
        @ }
        @ return 0;
    }

    方法 高度 <公开 属性写 注释 = "设置当前组件的高度" @设计时隐藏 = 真>
    参数 所欲设置的高度 <类型 = 整数>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     pWnd->SetWindowPos (NULL, 0, 0, rt.right - rt.left, @<所欲设置的高度>, (SWP_NOMOVE | SWP_NOACTIVATE | SWP_NOZORDER));
        @ }
    }

    方法 允许文件拖放 <公开 属性写 注释 = "  设置是否允许将文件拖放到本窗口组件上." 注释 = "  如果本属性被设置为真,则允许文件被拖放到本窗口组件上," 注释 = "当文件被拖放上来后,将发送\"文件被拖放\"事件.">
    参数 是否允许 <类型 = 逻辑型 注释 = "指定是否允许文件被拖放到本窗口组件上">
    {
        @ :: MyDragAcceptFiles (GetMfcWndHandle (), @<是否允许>);
    }

    方法 提示信息 <公开 属性写 注释 = "设置当鼠标移动到本组件上时所显示的提示文本信息">
    参数 提示文本内容 <类型 = 文本型 注释 = "提供具体的提示文本内容,为空文本清除已有提示文本.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     CVWnd_Container::sSetToolTip (pWnd, @<提示文本内容>.GetText ());
    }

    方法 禁止系统主题 <公开 属性写 注释 = "设置本组件是否禁止使用所处应用程序对应的Windows主题." 注释 = "禁止使用Windows主题可以保证本组件的一些外观属性(譬如颜色/字体等)显示正常.">
    参数 是否禁止 <类型 = 逻辑型>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     if (@<是否禁止>)
        @         ::SetWindowTheme (pWnd->m_hWnd, _T (""), _T (""));
        @     else
        @         ::SetWindowTheme (pWnd->m_hWnd, NULL, NULL);
        @ }
    }

    变量 标记 <公开 类型 = 文本型 注释 = "用作在组件中保存一个用户自定义标记文本值" @属性变量 = 真>

    # --

    方法 创建组件 <公开 类型 = 逻辑型 注释 = "创建本类的窗口组件" 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 父窗口容器组件 <类型 = 窗口容器组件 注释 = "提供所创建组件所处的父窗口容器组件">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建组件在所处父窗口容器组件中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建组件在所处父窗口容器组件中的顶边纵向坐标位置">
    参数 宽度 <类型 = 整数 注释 = "提供所创建组件的宽度值">
    参数 高度 <类型 = 整数 注释 = "提供所创建组件的高度值">
    参数 ID值 <类型 = 整数 注释 = "指定所创建组件在其父窗口容器组件中的ID值" @默认值 = 0xFFFF>
    参数 所处分组编号 <类型 = 整数 注释 = "指定所创建组件所处的设计时分组编号" @默认值 = -1>
    {
        @ @sn<this>.@an<CreateVolControl> (&@<父窗口容器组件>, @<左边位置>, @<顶边位置>, @<宽度>, @<高度>, @<ID值>, @<所处分组编号>)
    }

    方法 取窗口句柄 <公开 类型 = 变整数 注释 = "返回当前窗口组件的句柄,如果尚未创建或创建失败,则返回0." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.GetMfcWndPtr ()->m_hWnd
    }

    方法 取父窗口句柄 <公开 类型 = 变整数 注释 = "返回当前窗口组件的父窗口句柄,如果不存在则返回0." @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (INT_P)(pWnd != NULL ? pWnd->GetParent ()->GetSafeHwnd () : NULL);
    }

    方法 取所有者窗口句柄 <公开 类型 = 变整数 注释 = "返回当前窗口组件的所有者窗口的句柄,如果不存在则返回0." 注释 = "如果当前窗口组件没有所有者窗口,则默认返回其父窗口句柄." @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (INT_P)(pWnd != NULL ? pWnd->GetOwner ()->GetSafeHwnd () : NULL);
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回当前组件是否尚未成功创建" @嵌入式方法 = "">
    {
        @ @sn<this>.GetMfcWndPtr ()->m_hWnd == NULL
    }

    方法 销毁 <公开 注释 = "销毁本窗口组件,本方法调用后如欲继续使用本对象,必须再次创建.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->DestroyWindow ();
    }

    方法 信息框 <公开 类型 = 返回按钮类型 注释 = "显示一个信息框(本组件为其拥有窗口),等待用户单击按钮." 返回值注释 = "返回一个值告诉用户单击哪一个按钮."
            返回值注释 = "如果信息框有\"取消\"按钮,则按下 ESC 键与单击\"取消\"按钮的效果相同." @禁止流程检查 = 真>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 按钮 <类型 = 整数 注释 = "由\"信息框按钮\"类中的各组常量值相加后的值,具体请见该类中的说明." @默认值 = 0>
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "信息:">
    {
        @ const HWND hOldFocusWnd = ::GetFocus ();
        @ const INT nResult = ::MessageBox (GetMfcWndPtr ()->m_hWnd, @<提示信息>.GetText (), @<窗口标题>.GetText (), @<按钮>);
        @ if (hOldFocusWnd != NULL && ::IsWindow (hOldFocusWnd))
        @     ::SetFocus (hOldFocusWnd);
        @ return nResult;
    }

    方法 询问信息框 <公开 类型 = 逻辑型 注释 = "用户点击\"是\"按钮将返回真,点击\"否\"按钮将返回假.">
    参数 询问信息 <类型 = 文本型 注释 = "提供具体的询问提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "询问:">
    {
        返回 (信息框 (询问信息, 信息框按钮.询问图标 + 信息框按钮.是否钮, 窗口标题) == 返回按钮类型.是钮)
    }

    方法 错误信息框 <公开>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "错误:">
    {
        信息框 (提示信息, 信息框按钮.错误图标 + 信息框按钮.确认钮, 窗口标题)
    }

    方法 警告信息框 <公开>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "警告:">
    {
        信息框 (提示信息, 信息框按钮.警告图标 + 信息框按钮.确认钮, 窗口标题)
    }

    方法 输入框 <公开 类型 = 逻辑型 注释 = "在对话框中显示提示,等待用户输入正文并按下按钮." 注释 = "如果用户在确认输入后(按下\"确认输入\"按钮或回车键)退出,返回真,否则返回假."
            编辑时信息 = "BAA9F, 0, 0, 0" @禁止流程检查 = 真 @视窗.外部资源文件 = "src\\res\\input_box.rc">
    参数 存放输入内容的变量 <类型 = 文本型 注释 = "如果用户在确认输入后,相关输入内容将被填入到此文本变量中.">
    参数 提示信息 <类型 = 文本型 注释 = "提供输入提示信息,可以中间加入回车换行\"\\r\\n\"以包括多行." 注释 = "如果提示信息太长或行数过多,超过部分将不会被显示出来." @默认值 = "">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在对话框标题栏中的文本.如果为空文本,默认为\"请输入：\"." @默认值 = "">
    参数 初始文本 <类型 = 文本型 注释 = "指定初始设置到对话框输入文本框中的内容" @默认值 = "">
    参数 输入方式 <类型 = 输入框输入方式 注释 = "用作指定具体的输入方式" @默认值 = 输入框输入方式.输入文本>
    {
        @ CVDlg_Input dlg (GetMfcWndPtrWithValidHWnd (), (@<提示信息>.IsEmpty () ? _IDD_VOL_INPUT_DLG2 : _IDD_VOL_INPUT_DLG1));
        @ dlg.m_strCaption = @<窗口标题>;
        @ dlg.m_strTip = @<提示信息>;
        @ dlg.m_strInitialText = @<初始文本>;
        @ dlg.m_npInputMode = CLIP (@<输入方式>, 1, 4);
        @ if (dlg.DoModal () == IDOK)
        @ {
        @     @<存放输入内容的变量>.SetText ((const TCHAR*)dlg.m_strResult);
        @     return TRUE;
        @ }
        @ else
        @ {
        @     @<存放输入内容的变量>.Empty ();
        @     return FALSE;
        @ }
    }

