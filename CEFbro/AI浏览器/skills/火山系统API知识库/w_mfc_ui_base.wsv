# ===
#
# @begin
#
# // 用作定义组件类
# //   control_native_class_name: 窗口组件所使用的本地类名
# //   remove_style, remove_ex_style: 删除的默认窗口风格和扩展风格
# //   add_style, add_ex_style: 加入的默认窗口风格和扩展风格
# //   wnd_will_auto_delete: 提供所指定的control_native_class_name类MFC窗口在销毁时是否会自动删除自身(在PostNcDestroy中)
# // 注: 由于_OnInitExtra和_OnCleanupExtra为从构造和析构函数中调用过来的,而在这两个函数中类的虚拟机制是不起作用的,因此其初始化代码必须写在此处.
# @def_macro BASE_DECLARE_MFC_CONTROL(control_native_class_name, remove_style, remove_ex_style, add_style, add_ex_style, wnd_will_auto_delete)  \
# <>         <include>  \
#         void @an<_OnInitExtra> ();  \
#         inline_ void @an<_OnCleanupExtra> ()  {  DetachEventListener ();  }  \
#         virtual BOOL CreateMfcControl (CVolNativeWndCreateParam* pCreateParam) override;  \
#         virtual BOOL OnNativeWndMsg (MSG* pMsg) override  {  return OnProcessNativeWndMsg (pMsg);  }  \
#         virtual void AttachEventListener () override;  \
#         virtual void DetachEventListener () override;  \
#         virtual BOOL_P IsEventAttached () override;  \
# <>         </include>  \
#         void @sn<current_class>::@an<_OnInitExtra> ()  \
#         {  \
#             CMfcWndObject* pMfcWndObject = new CMfcWndObject (new control_native_class_name (), wnd_will_auto_delete);  \
#             pMfcWndObject->m_dwAttrInitialStyle = (pMfcWndObject->m_dwAttrInitialStyle & ~(remove_style)) | add_style;  \
#             pMfcWndObject->m_dwAttrInitialExStyle = (pMfcWndObject->m_dwAttrInitialExStyle & ~(remove_ex_style)) | add_ex_style;  \
#             TakeOverNewRefObject (pMfcWndObject);  \
#             _OnInitControl ();  \
#         }  \
#         BOOL @sn<current_class>::CreateMfcControl (CVolNativeWndCreateParam* pCreateParam)  \
#         {  \
#             ASSERT (pCreateParam != NULL);  \
#             control_native_class_name* pWnd = (control_native_class_name*)GetMfcWndPtr ();  \
#             ASSERT (pWnd != NULL);  \
#             pWnd->m_nGroupNumber = pCreateParam->m_nGroupNumber;  \
#             if (pWnd->m_hWnd == NULL)  \
#             {  \
#                 OnBeforeNativeWndCreate (pCreateParam);  \
#                 OnCalcNativeWndPos (pCreateParam);  \
#                 if (pWnd->CreateControl (pCreateParam))  \
#                 {  \
#                     if (pWnd->m_hWnd != NULL)  \
#                         OnAfterNativeWndCreate (pWnd, pCreateParam);  \
#                     return TRUE;  \
#                 }  \
#             }  \
#             return FALSE;  \
#         }
#
# // 用作定义组件类(设置/取回事件监听器基于所指定名称的方法)
# //   event_interface_class_name: 窗口组件的本地类所使用的事件监听接口类名
# //   md_get_event_listener: 窗口组件的本地类中取事件监听接口对象的方法名
# //   md_set_event_listener: 窗口组件的本地类中设置事件监听接口对象的方法名
# //   其它参数的解析见 BASE_DECLARE_MFC_CONTROL
# // 注意: 使用本宏的组件类必须继承并实现了 event_interface_class_name 事件接口类.
# @def_macro DECLARE_MFC_CONTROL(control_native_class_name, event_interface_class_name, md_get_event_listener, md_set_event_listener, remove_style, remove_ex_style, add_style, add_ex_style, wnd_will_auto_delete)  \
#     @m<BASE_DECLARE_MFC_CONTROL> (control_native_class_name, remove_style, remove_ex_style, add_style, add_ex_style, wnd_will_auto_delete)  \ 
#     void @sn<current_class>::AttachEventListener ()  \
#     {  \
#         control_native_class_name* pwndControl = (control_native_class_name*)GetMfcWndPtr ();  \
#         if (pwndControl->md_get_event_listener () != (event_interface_class_name*)this)  \
#             pwndControl->md_set_event_listener ((event_interface_class_name*)this);  \
#     }  \
#     void @sn<current_class>::DetachEventListener ()  \
#     {  \
#         control_native_class_name* pwndControl = (control_native_class_name*)GetMfcWndPtr ();  \
#         if (pwndControl->md_get_event_listener () == (event_interface_class_name*)this)  \
#             pwndControl->md_set_event_listener (NULL);  \
#     }  \
#     BOOL_P @sn<current_class>::IsEventAttached ()  \
#     {  \
#         return (((control_native_class_name*)GetMfcWndPtr ())->md_get_event_listener () != NULL);  \
#     }
#
# // 用作定义组件类(设置/取回事件监听器基于所指定名称的成员变量)
# //   var_event_listener: 窗口组件的本地类中保存事件监听接口对象的成员变量名
# // 注意: 使用本宏的组件类必须继承并实现了 event_interface_class_name 事件接口类.
# @def_macro DECLARE_MFC_CONTROL_V(control_native_class_name, event_interface_class_name, var_event_listener, remove_style, remove_ex_style, add_style, add_ex_style, wnd_will_auto_delete)  \
#     @m<BASE_DECLARE_MFC_CONTROL> (control_native_class_name, remove_style, remove_ex_style, add_style, add_ex_style, wnd_will_auto_delete)  \ 
#     void @sn<current_class>::AttachEventListener ()  \
#     {  \
#         ((control_native_class_name*)GetMfcWndPtr ())->var_event_listener = (event_interface_class_name*)this;  \
#     }  \
#     void @sn<current_class>::DetachEventListener ()  \
#     {  \
#         control_native_class_name* pwndControl = (control_native_class_name*)GetMfcWndPtr ();  \
#         if (pwndControl->var_event_listener == (event_interface_class_name*)this)  \
#             pwndControl->var_event_listener = NULL;  \
#     }  \
#     BOOL_P @sn<current_class>::IsEventAttached ()  \
#     {  \
#         return (((control_native_class_name*)GetMfcWndPtr ())->var_event_listener != NULL);  \
#     }
#
# // 用作定义具有事件的组件类(设置/取回事件监听器基于所指定默认名称的成员变量),并且auto_delete_while_destroyed参数始终为假.
# @def_macro DECLARE_MFC_CONTROL_DEFAULT(control_native_class_name, event_interface_class_name, remove_style, remove_ex_style, add_style, add_ex_style)  \
#     @m<DECLARE_MFC_CONTROL_V> (control_native_class_name, event_interface_class_name, m_pEventListener, remove_style, remove_ex_style, add_style, add_ex_style, FALSE)
#
# @end
