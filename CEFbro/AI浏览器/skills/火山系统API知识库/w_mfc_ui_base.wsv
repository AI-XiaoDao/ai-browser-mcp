<火山程序 类型 = "通常" 版本 = 1 />

包 火山.MFC界面.基本 <注释 = "本程序提供视窗项目的MFC界面基本支持功能." 注释 = "注意: 除非特别说明,本模块中所使用的所有显示单位均为像素." 注释 = "本模块默认采用静态链接方式,同时支持动态链接方式."
        编辑时信息 = "16553F, 0, 0, 0" @文档 = "category = \"基础类\"" "@视窗.外部头文件.全局-300" = "src\\mfc_ui_base.h"
        @视窗.外部资源文件 = "src\\res\\mfc_ui_base.rc" @视窗.外部源文件 = "src\\mfc_ui_base.cpp\r\nsrc\\mfc_ui_functions.cpp\r\n"
        @视窗.预定义宏.dynamic = "_AFXDLL" "@视窗.附加编译参数.debug-dynamic" = "cpp: /MDd" "@视窗.附加编译参数.release-dynamic" = "cpp: /MD">

类 组件边框类型 <公开 注释 = "提供组件的各种边框类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 无边框 <公开 值 = 0>
    常量 凹入式 <公开 值 = 1>
    常量 凸出式 <公开 值 = 2>
    常量 浅凹入式 <公开 值 = 3>
    常量 镜框式 <公开 值 = 4>
    常量 单线边框式 <公开 值 = 5>
}

类 组件层次 <公开 注释 = "提供窗口组件的各种显示层次" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 顶层 <公开 值 = 0 注释 = "将组件放置在具有相同父组件的其它组件的顶层,如果为窗口(无父组件),则放置在其它窗口的顶层. HWND_TOP">
    常量 底层 <公开 值 = 1 注释 = "将组件放置在具有相同父组件的其它组件的底层,如果为窗口(无父组件),则放置在其它窗口的底层. HWND_BOTTOM">
    常量 最高层 <公开 值 = -1 注释 = "将窗口放置在其它所有非最高层窗口的上方,即使窗口不再被激活依旧保持保留在此层次上. HWND_TOPMOST">
    常量 次高层 <公开 值 = -2 注释 = "将窗口放置在其它所有非最高层窗口的上方. HWND_NOTOPMOST">
}

类 输入框输入方式 <公开 注释 = "提供输入框的各种输入方式" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 输入文本 <公开 值 = 1>
    常量 输入整数 <公开 值 = 2>
    常量 输入小数 <公开 值 = 3>
    常量 输入密码 <公开 值 = 4>
}

类 所执行命令类型 <公开 @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 默认 <公开 值 = 0 注释 = "系统将首先搜寻注册表以获取对应于欲操作文件的一个合适命令类型,如果未找到将使用\"打开文件\"命令.">
    常量 编辑文档 <公开 值 = 1 注释 = "启动编辑软件打开\"欲操作文件名\"参数所指定的文档文件进行编辑">
    常量 浏览文件夹 <公开 值 = 2 注释 = "打开\"欲操作文件名\"参数所指定的文件夹进行浏览">
    常量 寻找文件 <公开 值 = 3 注释 = "打开\"欲操作文件名\"参数所指定的文件夹进行文件寻找操作">
    常量 打开文件 <公开 值 = 4 注释 = "打开\"欲操作文件名\"参数所指定的文件,该文件可以是可执行文件/文档文件或文件夹.">
    常量 打印文档 <公开 值 = 5 注释 = "打印\"欲操作文件名\"参数所指定的文档文件,注意该文档的编辑软件可能不支持本命令,故使用前需要先测试是否可用.">
}

类 窗口组件 <公开 基础类 = 参考对象类 注释 = "所有窗口组件的基础类" @文档 = "category = \"窗口组件.基础类\"" @视窗.外部头文件 = "src\\mfc_ui_base_controls.h"
        @视窗.外部源文件 = "src\\mfc_ui_base_controls.cpp" @输出名 = "@CVolWinControl">
{
    方法 鼠标左键被按下 <公开 定义事件 类型 = 整数 注释 = "当鼠标左键被按下时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标左键被放开 <公开 定义事件 类型 = 整数 注释 = "当鼠标左键被放开时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 被双击 <公开 定义事件 类型 = 整数 注释 = "当鼠标左键被双击时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标右键被按下 <公开 定义事件 类型 = 整数 注释 = "当鼠标右键被按下时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标右键被放开 <公开 定义事件 类型 = 整数 注释 = "当鼠标右键被放开时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标中键被按下 <公开 定义事件 类型 = 整数 注释 = "当鼠标中键被按下时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标中键被放开 <公开 定义事件 类型 = 整数 注释 = "当鼠标中键被放开时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 鼠标位置被移动 <公开 定义事件 类型 = 整数 注释 = "当鼠标位置被移动时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 横向位置 <类型 = 整数 注释 = "事件触发时的鼠标横向坐标位置,相对所处用户区的左边.">
    参数 纵向位置 <类型 = 整数 注释 = "事件触发时的鼠标纵向坐标位置,相对所处用户区的顶边.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 滚轮被滚动 <公开 定义事件 类型 = 整数 注释 = "当鼠标滚轮被滚动时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 滚动距离 <类型 = 整数 注释 = "表明鼠标滚轮所滚动的距离,大于零表示向前滚动,小于零表示向后滚动.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 按下某键 <公开 定义事件 类型 = 整数 注释 = "当用户按下某个按键时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 放开某键 <公开 定义事件 类型 = 整数 注释 = "当用户按下某个按键时事件被触发" 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">
    参数 键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值,注意不包括辅助键组合状态值.">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态,为\"辅助键状态\"类中各常量值的组合.">

    方法 获得焦点 <公开 定义事件 类型 = 整数 注释 = "  当本组件获得输入焦点后发送此事件." 注释 = "  所谓\"输入焦点\",即当前用户按键操作所对应的目标组件. 譬如: 用户正在编辑框中输入文本,"
            注释 = "那么此编辑框就具有输入焦点,因为它将获得目前用户所进行的所有按键操作. 所谓\"获得\"或者" 注释 = "\"失去\"输入焦点,即当前用户按键操作所对应的目标对象发生转移. 譬如: 用户现在正在编辑框1"
            注释 = "中输入文本,突然使用鼠标或其它方法切换到了编辑框2上去继续输入,那么此时编辑框1就\"失去\"" 注释 = "了输入焦点,编辑框2就\"获得\"了输入焦点,因为在此以后用户所进行的所有按键操作都将被"
            注释 = "编辑框2所获得." 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">

    方法 失去焦点 <公开 定义事件 类型 = 整数 注释 = "  当本组件失去输入焦点后发送此事件." 注释 = "  所谓\"输入焦点\",即当前用户按键操作所对应的目标组件. 譬如: 用户正在编辑框中输入文本,"
            注释 = "那么此编辑框就具有输入焦点,因为它将获得目前用户所进行的所有按键操作. 所谓\"获得\"或者" 注释 = "\"失去\"输入焦点,即当前用户按键操作所对应的目标对象发生转移. 譬如: 用户现在正在编辑框1"
            注释 = "中输入文本,突然使用鼠标或其它方法切换到了编辑框2上去继续输入,那么此时编辑框1就\"失去\"" 注释 = "了输入焦点,编辑框2就\"获得\"了输入焦点,因为在此以后用户所进行的所有按键操作都将被"
            注释 = "编辑框2所获得." 返回值注释 = "本事件的处理方法如果返回非0整数值,表明事件已经得到处理且不再需要后续处理.">

    方法 字符输入 <公开 定义事件 类型 = 整数 注释 = "  当用户输入一个字符后发生此事件,字符键包括任何可打印的键盘字符及回车(Enter)" 注释 = "和退格(BackSpace)键."
            返回值注释 = "  本事件的处理方法返回值如果小于0,表明事件已经得到处理且不再需要后续处理,如果" 返回值注释 = "大于0,则将该值作为新的替代字符代码继续进行后续处理.如果等于0,则使用原字符值继"
            返回值注释 = "续进行后续处理.">
    参数 字符代码 <类型 = 字符 注释 = "提供所输入的字符">

    方法 组件消息过滤 <公开 定义事件 类型 = 整数 注释 = "当用户组件接收到任何Windows消息在其被实际处理前,本事件被发送." 返回值注释 = "  返回0表示允许该Windows消息继续向后传递并处理,返回1表示该Windows"
            返回值注释 = "消息已经被处理且无需后续处理.">
    参数 窗口句柄 <类型 = 变整数 注释 = "提供消息所对应的本组件窗口句柄(HWND)">
    参数 消息值 <类型 = 整数 注释 = "提供消息的具体值">
    参数 消息参数1 <类型 = 变整数 注释 = "提供消息所附带的参数1的值">
    参数 消息参数2 <类型 = 变整数 注释 = "提供消息所附带的参数2的值">
    参数 消息地址 <类型 = 变整数 注释 = "提供消息的具体 MSG* 地址指针,用作备用.">

    方法 组件创建完毕 <公开 定义事件 类型 = 整数 注释 = "当组件被创建完毕后发送此事件">
    参数 父组件 <类型 = 窗口组件 注释 = "  提供组件所处的父组件,必定有效且已经成功创建." 注释 = "  可以使用\"属于\"操作符判断具体的父组件数据类型,如: \"如果 (父组件 属于 窗口容器组件)\","
            注释 = "\"如果 (父组件 属于 图片框)\" 等. 判断清楚具体数据类型后,可以使用强制转换将其转换到具体的" 注释 = "窗口组件类对象,如: \"(窗口容器组件)父组件\"">
    参数 组件ID <类型 = 整数 注释 = "提供组件在所处父组件中的ID值">

    方法 文件被拖放 <公开 定义事件 类型 = 整数 注释 = "当文件被拖放到本窗口组件上后,将发送本事件." 注释 = "注意: 仅当\"允许文件拖放\"属性被设置为真时,本事件才会被发送.">
    参数 所拖放文件 <类型 = 文本数组类 注释 = "提供所有被拖放到本组件上的文件名,数组成员数必定大于0.">

    # --

    方法 标题 <公开 属性读 类型 = 文本型 注释 = "返回本组件的当前标题文本" @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd  ();
        @ if (pWnd != NULL)
        @ {
        @     CString strCaption;
        @     pWnd->GetWindowText (strCaption);
        @     return (LPCTSTR)strCaption;
        @ }
        @ return GetMfcWndObject ()->m_strAttrCaption;
    }

    方法 标题 <公开 属性写 注释 = "  设置本组件的当前标题文本." 注释 = "  注意: 在某些组件中(譬如标签,按钮,选择框,单选框,分组框等),\'&\'字符本身不会被显示,"
            注释 = "而会导致其后方紧接的一个字符以下划线方式显示,表示Alt加该字符为此组件的快捷访问键." 注释 = "这种情况下如果需要显示\'&\'字符本身,需要使用连续两个该字符,即\"&&\"." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的标题 <类型 = 文本型 注释 = "提供所欲设置的标题文本">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->SetWindowText (@<所欲设置的标题>);
        @     if (P_IS_VOL_INSTANCE_OF (this, @dt<组件布局器>) == FALSE)
        @         pWnd->Invalidate ();
        @ }
        @ else
        @     GetMfcWndObject ()->m_strAttrCaption = @<所欲设置的标题>;
    }

    方法 标题字符串 <公开 属性写 注释 = "以字符串资源的方式设置本组件的当前标题文本" @视窗.设置时机 = 组件创建前后>
    参数 所欲设置的标题 <类型 = 字符串资源>
    {
        标题 = 载入字符串资源 (所欲设置的标题)
    }

    方法 可视 <公开 属性读 类型 = 逻辑型 注释 = "返回本组件当前是否可视" @禁止流程检查 = 真>
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本(编译设计器版本时不允许真实修改可视属性)?
        @     CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @     if (pWnd != NULL)
        @         return IsVolControlVisible (pWnd->m_hWnd);
        @ #endif
        @ return ((GetMfcWndObject ()->m_dwAttrInitialStyle & WS_VISIBLE) != 0);
    }

    方法 是否初始可视 <公开 类型 = 逻辑型 注释 = "返回本组件在实际创建前被设置的初始可视状态" 返回值注释 = "可视返回真,不可视返回假." @嵌入式方法 = "">
    {
        @ (@sn<this>.GetMfcWndObject ()->m_dwAttrInitialStyle & WS_VISIBLE) != 0
    }

    方法 可视 <公开 属性写 注释 = "设置本组件当前是否可视" @视窗.设置时机 = 组件创建前后>
    参数 是否可视 <类型 = 逻辑型 注释 = "指定本组件是否可视">
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本(编译设计器版本时不允许真实修改可视属性)?
        @     CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @     if (pWnd != NULL)
        @     {
        @         ::ShowVolControl (pWnd->m_hWnd, @<是否可视>);
        @         return;
        @     }
        @ #endif
        @ if (@<是否可视>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_VISIBLE;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~WS_VISIBLE;
    }

    方法 禁止 <公开 属性读 类型 = 逻辑型 注释 = "返回本组件当前是否被禁止操作" @禁止流程检查 = 真>
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本(编译设计器版本时不允许真实修改可视属性)?
        @     CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @     if (pWnd != NULL)
        @         return (pWnd->IsWindowEnabled () == FALSE);
        @ #endif
        @ return ((GetMfcWndObject ()->m_dwAttrInitialStyle & WS_DISABLED) != 0);
    }

    方法 禁止 <公开 属性写 注释 = "设置本组件当前是否被禁止操作" @视窗.设置时机 = 组件创建前后>
    参数 是否禁止 <类型 = 逻辑型 注释 = "指定本组件是否被禁止">
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本(编译设计器版本时不允许真实修改可视属性)?
        @     CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @     if (pWnd != NULL)
        @     {
        @         pWnd->EnableWindow (@<是否禁止> == FALSE);
        @         return;
        @     }
        @ #endif
        @ if (@<是否禁止>)
        @     GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_DISABLED;
        @ else
        @     GetMfcWndObject ()->m_dwAttrInitialStyle &= ~WS_DISABLED;
    }

    方法 首组件 <公开 属性读 类型 = 逻辑型 注释 = "  返回本组件是否为一组组件的首组件.同一组内组件之间的输入焦点可以使用光标键移动," 注释 = "其中所有单选框组件将被自动只选中一个." @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & WS_GROUP) != 0
    }

    方法 首组件 <公开 属性写 注释 = "设置本组件为一组组件的首组件,本组件及后续所有本属性值为假的兄弟组件均被认为在同一组中." 注释 = "同一组内组件之间的输入焦点可以使用光标键移动,其中所有单选框组件将被自动只选中一个."
            注释 = "如果同一父组件中的所有子组件均位于同一组中,则不需要设置本属性." 注释 = "注意本属性对\"窗口\"类对象不起作用." @视窗.设置时机 = 组件创建前后>
    参数 是否为组内的首组件 <类型 = 逻辑型>
    {
        如果 (本对象 属于 窗口)
        {
            返回
        }
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->ModifyStyle (WS_GROUP, (@<是否为组内的首组件> ? WS_GROUP : 0), (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE));
        @ else
        @ {
        @     if (@<是否为组内的首组件>)
        @         GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_GROUP;
        @     else
        @         GetMfcWndObject ()->m_dwAttrInitialStyle &= ~WS_GROUP;
        @ }
    }

    方法 可停留焦点 <公开 属性读 类型 = 逻辑型 注释 = "返回当用户使用TAB键在组件之间移动输入焦点时是否允许在本组件上停留" @嵌入式方法 = "">
    {
        @ (@sn<this>.GetControlStyle () & WS_TABSTOP) != 0
    }

    方法 可停留焦点 <公开 属性写 注释 = "设置当用户使用TAB键在组件之间移动输入焦点时是否允许在本组件上停留." 注释 = "注意:" 注释 = "    1. 对于编辑框,按钮之类可以接收按键输入的组件,本属性值默认为真;"
            注释 = "    2. 本属性对\"窗口\"类对象不起作用;" 注释 = "    3. 如欲设置各个组件之间的焦点停留顺序,请在界面布局设计器中的" 注释 = "布局内容树中拖动改变组件的创建顺序,也可在源程序中直接调整窗口类中"
            注释 = "组件成员变量的定义顺序;" 注释 = "    4(内部): 封装本属性时必须将本属性的设置时机置为\"组件创建后\"," 注释 = "以支持对本属性默认值(前面第一条决定)的覆盖修改."
            "// @视窗.设置时机" = 组件创建前后>
    参数 是否可停留焦点 <类型 = 逻辑型>
    {
        如果 (本对象 属于 窗口)
        {
            返回
        }
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->ModifyStyle (WS_TABSTOP, (@<是否可停留焦点> ? WS_TABSTOP : 0), (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE));
        @ else
        @ {
        @     if (@<是否可停留焦点>)
        @         GetMfcWndObject ()->m_dwAttrInitialStyle |= WS_TABSTOP;
        @     else
        @         GetMfcWndObject ()->m_dwAttrInitialStyle &= ~WS_TABSTOP;
        @ }
    }

    方法 标准鼠标指针 <公开 属性写 注释 = "设置当鼠标指针移动到本组件上时的标准鼠标指针形状类型." 注释 = "注意: 使用\"自定义鼠标指针\"所设置的鼠标指针形状将被覆盖." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置指针类型 <类型 = 标准鼠标指针类型>
    {
        @ if ((GetMfcWndObject ()->m_hAttrCustomCursur = ::LoadCursor (NULL, MAKEINTRESOURCE (@<所欲设置指针类型>))) != NULL)
        @ {
        @     AttachEventListenerIfNone ();
        @     POINT pt;
        @     ::GetCursorPos (&pt);
        @     ::SetCursorPos (pt.x, pt.y);
        @  }
    }

    方法 自定义鼠标指针 <公开 属性写 注释 = "设置当鼠标指针移动到本组件上时的自定义鼠标指针形状类型." 注释 = "注意: 使用\"标准鼠标指针\"所设置的鼠标指针形状将被覆盖." @视窗.设置时机 = 组件创建前后>
    参数 所欲设置指针形状 <类型 = 鼠标指针资源 注释 = "提供所欲设置的鼠标指针资源,如果该资源值为\"空资源.空鼠标指针\",则将取消自定义鼠标指针.">
    {
        @ if ((GetMfcWndObject ()->m_hAttrCustomCursur = (HCURSOR)g_objVolApp.LoadResImage (VRIT_CURSOR, @<所欲设置指针形状>)) != NULL)
        @ {
        @     AttachEventListenerIfNone ();
        @     POINT pt;
        @     ::GetCursorPos (&pt);
        @     ::SetCursorPos (pt.x, pt.y);
        @ }
    }

    方法 字体 <公开 属性写 注释 = "设置本组件显示文本时所使用的字体" @视窗.设置时机 = 组件创建前后 @值细节类型 = 字体>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"." "">
    {
        @ LOGFONT infFont;
        @ GetFontDescTextInfo (@<字体描述文本>, &infFont);
        @ CMfcWndObject* pMfcWndObject = GetMfcWndObject ();
        @ const HFONT hOldFont = pMfcWndObject->m_hFont;
        @ pMfcWndObject->m_hFont = ::CreateFontIndirect (&infFont);
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @     pWnd->SendMessage (WM_SETFONT, (WPARAM)pMfcWndObject->m_hFont, MAKELPARAM (TRUE, 0));
        @ if (hOldFont != NULL)
        @     ::DeleteObject (hOldFont);
    }

    方法 字体 <公开 属性读 类型 = 文本型 注释 = "返回本组件显示文本时所使用的字体,如果未设置则为空文本." @禁止流程检查 = 真>
    {
        @ CVolString strFontDesc;
        @ CMfcWndObject* pWndObject = GetMfcWndObject ();
        @ HFONT hFont = pWndObject->m_hFont;
        @ if (hFont == NULL)
        @ {
        @     CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @     if (pWnd != NULL)
        @         hFont = (HFONT)pWnd->SendMessage (WM_GETFONT, 0, 0);
        @ }
        @ if (hFont != NULL)
        @ {
        @     LOGFONT infFont;
        @     if (::GetObject (hFont, sizeof (LOGFONT), &infFont) != 0)
        @         GetFontDescText (infFont, strFontDesc);
        @ }
        @ return strFontDesc;
    }

    方法 组件边框 <公开 属性写 注释 = "设置组件的边框类型." 注释 = "注意本属性对\"窗口\"类对象不起作用,窗口类对象请使用\"窗口边框\"属性." @视窗.设置时机 = 组件创建后>
    参数 所设置边框类型 <类型 = 组件边框类型 注释 = "提供所欲设置的组件边框类型">
    {
        如果 (本对象 属于 窗口)
        {
            返回
        }
        @ DWORD dwStyle = 0, dwExStyle = 0;
        @ switch (@<所设置边框类型>)
        @ {
        @ case 1:  dwExStyle = WS_EX_CLIENTEDGE;  break;
        @ case 2:  dwExStyle = WS_EX_DLGMODALFRAME;  break;
        @ case 3:  dwExStyle = WS_EX_STATICEDGE;  break;
        @ case 4:  dwExStyle = (WS_EX_CLIENTEDGE | WS_EX_DLGMODALFRAME);  break;
        @ case 5:  dwStyle = WS_BORDER;  break;
        @ }
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->ModifyStyle (WS_BORDER, dwStyle, (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED | SWP_DRAWFRAME));
        @     pWnd->ModifyStyleEx (WS_EX_STATICEDGE | WS_EX_CLIENTEDGE | WS_EX_DLGMODALFRAME, dwExStyle,
        @             (SWP_NOSIZE | SWP_NOMOVE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED | SWP_DRAWFRAME));
        @ }
    }

    方法 组件位置 <公开 属性读 类型 = 矩形类 注释 = "获取并返回当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)中的所处矩形位置"
            返回值注释 = "如果当前组件存在父组件,所返回位置矩形基于其用户区左上角,否则基于屏幕左上角.">
    {
        变量 矩形变量1 <类型 = 矩形类>
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     @<矩形变量1>.Copy (&rt);  // 取回所获得的位置矩形
        @ }
        返回 (矩形变量1)
    }

    方法 组件位置 <公开 属性写 注释 = "设置当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)中的所处矩形位置">
    参数 所欲设置的矩形 <类型 = 矩形类 注释 = "如果当前组件存在父组件,为基于其用户区左上角,否则为基于屏幕左上角.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     pWnd->SetWindowPos (NULL, @<所欲设置的矩形.左边>, @<所欲设置的矩形.顶边>, @<所欲设置的矩形.宽度> (), @<所欲设置的矩形.高度> (),
        @     #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本?
        @         (SWP_NOACTIVATE | SWP_NOZORDER));
        @     #else
        @         (SWP_NOMOVE | SWP_NOACTIVATE | SWP_NOZORDER));
        @     #endif
        @ }
    }

    方法 左边 <公开 属性读 类型 = 整数 注释 = "  返回当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)" 注释 = "中的左边位置,如果组件尚未被创建,将始终返回0." @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     return rt.left;
        @ }
        @ return 0;
    }

    方法 左边 <公开 属性写 注释 = "设置当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)中的左边位置" @设计时隐藏 = 真>
    参数 所欲设置的位置 <类型 = 整数>
    {
        @ #ifndef @an<_VOL_FOR_UI_DESIGNER>  // 不为编译设计器版本?
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     pWnd->SetWindowPos (NULL, @<所欲设置的位置>, rt.top, 0, 0, (SWP_NOSIZE | SWP_NOACTIVATE | SWP_NOZORDER));
        @ }
        @ #endif
    }

    方法 顶边 <公开 属性读 类型 = 整数 注释 = "  返回当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)" 注释 = "中的顶边位置,如果组件尚未被创建,将始终返回0." @设计时隐藏 = 真 @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     RECT rt;
        @     pWnd->GetWindowRect (&rt);
        @     CWnd* pParent = pWnd->GetParent ();
        @     if (pParent != NULL && (pWnd->GetStyle () & WS_POPUP) == 0)
        @         pParent->ScreenToClient (&rt);
        @     return rt.top;
        @ }
        @ return 0;
    }

    方法 顶边 <公开 属性写 注释 = "设置当前组件在所处父组件用户区或屏幕(当无父组件时,譬如为顶层窗口)中的顶边位置" @设计时隐藏 = 真>
    参数 所欲设置的位置 <类型 = 整数>
    {
