# ===

类 窗口容器组件 <公开 基础类 = 窗口组件 注释 = "所有窗口容器组件的基础类" @文档 = "category = \"窗口组件.基础类\"" @输出名 = "@CVolWinContainer">
{
    方法 创建容器组件 <公开 类型 = 逻辑型 注释 = "使用调用本方法的本类实际继承类的设计时尺寸创建对应的窗口组件." 注释 = "如果调用本方法的继承类未被设计过布局,所创建的组件尺寸将为0." 返回值注释 = "返回是否成功"
            @嵌入式方法 = "">
    参数 父窗口容器组件 <类型 = 窗口容器组件 注释 = "提供所创建组件所处的父窗口容器组件">
    参数 左边位置 <类型 = 整数 注释 = "提供所创建组件在所处父窗口容器组件中的左边横向坐标位置">
    参数 顶边位置 <类型 = 整数 注释 = "提供所创建组件在所处父窗口容器组件中的顶边纵向坐标位置">
    参数 ID值 <类型 = 整数 注释 = "指定所创建组件在其父窗口容器组件中的ID值" @默认值 = 0xFFFF>
    参数 所处分组编号 <类型 = 整数 注释 = "指定所创建组件所处的设计时分组编号" @默认值 = -1>
    {
        @ @sn<this>.@an<CreateVolControl> (&@<父窗口容器组件>, @<左边位置>, @<顶边位置>, INT_MIN, INT_MIN, @<ID值>, @<所处分组编号>)
    }

    方法 创建时宽度 <公开 属性读 类型 = 整数 注释 = "返回本组件创建时的宽度" @嵌入式方法 = "">
    {
        @ @sn<this>.m_nCreateWidth
    }

    方法 创建时高度 <公开 属性读 类型 = 整数 注释 = "返回本组件创建时的高度" @嵌入式方法 = "">
    {
        @ @sn<this>.m_nCreateHeight
    }

    方法 取所有子组件句柄 <公开 类型 = 整数 注释 = "获取本容器组件所有直接子组件的窗口句柄值" 返回值注释 = "返回填入到\"结果数组\"参数数组中的窗口句柄数目">
    参数 结果句柄数组 <类型 = 变整数数组类 注释 = "用作存储所获得的所有直接子组件的窗口句柄值">
    {
        结果句柄数组.删除所有成员 ()
        @ const HWND hParentWnd = GetMfcWndHandle ();
        @ if (hParentWnd != NULL)
        @ {
        @     for (HWND hWndChild = ::GetWindow (hParentWnd, GW_CHILD); hWndChild != NULL; hWndChild = ::GetWindow (hWndChild, GW_HWNDNEXT))
        @         @<结果句柄数组>.data ().Add ((INT_P)hWndChild);
        @ }
        返回 (结果句柄数组.取成员数 ())
    }

    方法 显示子组件组 <公开 注释 = "显示或隐藏本容器组件中的一组设计时指定的子组件(仅限直接子组件)" @嵌入式方法 = "">
    参数 子组件分组编号 <类型 = 整数 注释 = "提供需处理子组件位于的设计时分组编号,为-1表示没有进行分组的所有子组件.">
    参数 是否显示 <类型 = 逻辑型 注释 = "为真则显示位于该分组内的所有子组件,为假则隐藏." @默认值 = 真>
    参数 处理其它组子组件 <类型 = 逻辑型 注释 = "为真则处理所有位于其它分组内的子组件,处理方式为相反,即: \"是否显示\"参数为真则隐藏,否则显示." @默认值 = 真>
    参数 处理未分组子组件 <类型 = 逻辑型 注释 = "为真则处理所有未进行分组的子组件,处理方式为相反,即: \"是否显示\"参数为真则隐藏,否则显示." @默认值 = 假>
    {
        @ @sn<this>.ProcessChildControlGroup (@<子组件分组编号>, 0, @<是否显示>, @<处理其它组子组件>, @<处理未分组子组件>)
    }

    方法 禁止子组件组 <公开 注释 = "禁止或允许对本容器组件中的一组设计时指定的子组件(仅限直接子组件)进行操作" @嵌入式方法 = "">
    参数 子组件分组编号 <类型 = 整数 注释 = "提供需处理子组件位于的设计时分组编号,为-1表示没有进行分组的所有子组件.">
    参数 是否禁止 <类型 = 逻辑型 注释 = "为真则禁止位于该分组内的所有子组件,为假则允许." @默认值 = 真>
    参数 处理其它组子组件 <类型 = 逻辑型 注释 = "为真则处理所有位于其它分组内的子组件,处理方式为相反,即: \"是否禁止\"参数为真则允许,否则禁止." @默认值 = 真>
    参数 处理未分组子组件 <类型 = 逻辑型 注释 = "为真则处理所有未进行分组的子组件,处理方式为相反,即: \"是否禁止\"参数为真则允许,否则禁止." @默认值 = 假>
    {
        @ @sn<this>.ProcessChildControlGroup (@<子组件分组编号>, 1, (@<是否禁止> == FALSE), @<处理其它组子组件>, @<处理未分组子组件>)
    }

    # --
    #
    # @begin
    #
    # <> <include>
    # virtual INT @an<GetDesignClientWidth> () const  {  return 0;  }  // 所有被用户设计过布局的本类继承类编译器都会自动生成本方法的覆盖方法以返回正确的布局用户区宽度.
    # virtual INT @an<GetDesignClientHeight> () const  {  return 0;  }  // 同上
    # virtual void @an<OnWinContainerCreated> ()  {  }  // 同上
    # virtual void OnBeforeNativeWndCreate (CVolNativeWndCreateParam* pCreateParam) override;
    # virtual void OnCalcNativeWndPos (CVolNativeWndCreateParam* pCreateParam) override;
    # void ProcessChildControlGroup (INT_P npReqGroupNumber, INT_P npOperType, BOOL_P blpParam, BOOL_P blpProcessNotMatchChilds, BOOL_P blpProcessNotInsideGroupChilds);
    # INT m_nCreateWidth = 0, m_nCreateHeight = 0;
