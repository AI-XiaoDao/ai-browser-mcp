类 消息过滤器类 <公开 注释 = "用作接收所挂接窗口组件的消息" @视窗.后缀文本 = "public IVolWindowProcFilter">
{
    变量 所挂接窗口句柄 <公开 类型 = 变整数 注释 = "提供当前所已经挂接到窗口组件的句柄值,为0表示尚未被挂接.">

    方法 类_清理
    {
        取消挂接 ()
    }

    方法 消息过滤 <公开 定义事件 类型 = 整数 注释 = "当接收到所挂接窗口组件的消息后,本事件被发送." 返回值注释 = "返回0表示允许消息继续向后传递并处理,返回1表示取消掉该消息的后续处理.">
    参数 窗口句柄 <类型 = 变整数 注释 = "提供消息所对应的窗口句柄(HWND)">
    参数 消息值 <类型 = 整数 注释 = "提供消息的具体值">
    参数 消息参数1 <类型 = 变整数 注释 = "提供消息所附带的参数1的值">
    参数 消息参数2 <类型 = 变整数 注释 = "提供消息所附带的参数2的值">
    参数 返回值 <类型 = 变整数类 注释 = "当本方法返回假时用作提供具体的返回值,默认为0.">

    方法 挂接 <公开 类型 = 逻辑型 注释 = "  将本消息过滤器挂接到所指定的窗口组件,挂接后该窗口组件的" 注释 = "所有Windows消息都会首先调用本类的\"消息过滤\"事件进行过滤."
            返回值注释 = "挂接成功返回真,失败返回假.">
    参数 欲挂接的组件 <类型 = 窗口组件 注释 = "提供欲将本消息过滤器挂接到的窗口组件">
    {
        返回 (挂接2 (欲挂接的组件.取窗口句柄 ()))
    }

    方法 挂接2 <公开 类型 = 逻辑型 注释 = "  将本消息过滤器挂接到所指定的窗口组件,挂接后该窗口组件的" 注释 = "所有Windows消息都会首先调用本类的\"消息过滤\"事件进行过滤."
            返回值注释 = "挂接成功返回真,失败返回假.">
    参数 欲挂接组件的句柄 <类型 = 变整数 注释 = "提供欲将本消息过滤器挂接到窗口组件的句柄值">
    {
        取消挂接 ()  // 取消先前可能已有的挂接
        @ if (@<欲挂接组件的句柄> != 0 && CVolWindowProcFilters::sRegisterFilter ((HWND)@<欲挂接组件的句柄>, this))
        {
            所挂接窗口句柄 = 欲挂接组件的句柄
            返回 (真)
        }
        返回 (假)
    }

    方法 取消挂接 <公开 注释 = "如果本消息过滤器已经挂接到窗口组件,取消其挂接." 注释 = "本方法调用不是必需的,本类对象被销毁时,将自动调用本方法.">
    {
        如果 (所挂接窗口句柄 != 0)
        {
            @ CVolWindowProcFilters::sUnregisterFilter ((HWND)@<所挂接窗口句柄>, this);
            所挂接窗口句柄 = 0
        }
    }

    # --
    # @begin
    # <> <include>
    # virtual BOOL_P FilterBeforeDefProc (HWND hWnd, UINT message, WPARAM wParam, LPARAM lParam, LRESULT& lResult) override;
    # <> </include>
    # BOOL_P @sn<current_class>::FilterBeforeDefProc (HWND hWnd, UINT message, WPARAM wParam, LPARAM lParam, LRESULT& lResult)
    # {
    #     @dt<变整数类> r;
    #     if (@<消息过滤> ((INT_P)hWnd, (INT)message, (INT_P)wParam, (INT_P)lParam, r) != 0)
    #     {
    #         lResult = (LRESULT)r.@n<变整数类.值>;
    #         return TRUE;
    #     }
    #     return FALSE;
    # }
    # @end
}

