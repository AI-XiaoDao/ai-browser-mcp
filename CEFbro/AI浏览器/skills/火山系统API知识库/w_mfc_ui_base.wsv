    方法 可有焦点 <公开 类型 = 逻辑型 注释 = "返回当前窗口组件是否具有输入焦点" @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ return (pWnd != NULL ? ::GetFocus () == pWnd->m_hWnd : FALSE);
    }

    方法 取用户区宽度 <公开 类型 = 整数 注释 = "  返回窗口或窗口组件用户区域的宽度,对窗口而言,用户区域" 注释 = "为窗口区域减去标题栏+菜单栏+边框后的区域." @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CRect rtClient;
        @     pWnd->GetClientRect (&rtClient);
        @     return rtClient.Width ();
        @ }
        @ return 0;
    }

    方法 取用户区高度 <公开 类型 = 整数 注释 = "  返回窗口或窗口组件用户区域的高度,对窗口而言,用户区域为" 注释 = "窗口区域减去标题栏+菜单栏+边框后的区域." @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CRect rtClient;
        @     pWnd->GetClientRect (&rtClient);
        @     return rtClient.Height ();
        @ }
