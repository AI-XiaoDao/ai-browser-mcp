    }

    方法 屏幕矩形到用户区 <公开 注释 = "将所指定的屏幕矩形位置转换到基于本组件用户区左上角">
    参数 待转换矩形 <类型 = 矩形类 注释 = "提供待转换的屏幕矩形位置,转换完毕后的结果将写回此对象中.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CMRect rt (@<待转换矩形>.ToRect ());
        @     pWnd->ScreenToClient (&rt);
        @     @<待转换矩形>.Copy (&rt);  // 取回所获得的位置矩形
        @ }
    }

    方法 用户区矩形到屏幕 <公开 注释 = "将所指定的用户区矩形位置(基于本组件用户区左上角)转换到基于屏幕左上角">
    参数 待转换矩形 <类型 = 矩形类 注释 = "提供待转换的屏幕矩形位置,转换完毕后的结果将写回此对象中.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
        @ {
        @     CMRect rt (@<待转换矩形>.ToRect ());
        @     pWnd->ClientToScreen (&rt);
        @     @<待转换矩形>.Copy (&rt);  // 取回所获得的位置矩形
        @ }
    }

    方法 屏幕位置到用户区 <公开 注释 = "将所指定的屏幕位置转换到基于本组件用户区左上角">
    参数 待转换位置 <类型 = 位置类 注释 = "提供待转换的屏幕位置,转换完毕后的结果将写回此对象中.">
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL)
