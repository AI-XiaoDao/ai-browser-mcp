类 对象栈模板类 <公开 基础类 = 扩展对象类 注释 = "对象栈类,用作对象类型填充." 注释 = "  模板类型1: 成员数据类型" @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<stack>"
        @模板基础类 = 真 @输出到部件 = 假>
{
    方法 压入 <公开 注释 = "在当前栈顶添加指定成员." @嵌入式方法 = "">
    参数 值 <类型 = 模板类型1 注释 = "提供所欲添加的成员.">
    {
        @ @sn<this>.m_stack.push(CVolWrapperObject(@<值>))
    }

    方法 压入指定类型对象 <公开 注释 = "在当前栈顶添加一个指定类型的对象成员." @嵌入式方法 = "">
    参数 对应对象类 <类型 = 对象类 注释 = "  提供指定的火山类数据类型,类库将会创建一个新的该数据" 注释 = "类型对象然后将其压入本栈的顶部." @需求类型 = 数据类型>
    {
        @ @sn<this>.m_stack.push(CVolWrapperObject(VOL_RUNTIME_CLASS(@<对应对象类>)))
    }

    方法 弹出 <公开 注释 = "删除栈顶成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_stack.pop()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "判断本栈是否为空栈." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_stack.empty()
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本栈中已有成员的数目." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_stack.size ()
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "返回本栈栈顶成员的参考." 注释 = "注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "  挂接事件 (栈1.取成员 ())"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的队列中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    {
        @ (@dt<模板类型1>&)@sn<this>.m_stack.top().GetVolObject (CVolObject ())
    }

    方法 取指定类型成员 <公开 注释 = "返回本栈栈顶成员的参考." 注释 = "注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "  挂接事件 (队列1.取首成员 ())"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的队列中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    参数 所欲获取对象的类型 <类型 = 对象类 注释 = "  提供所欲获取成员对象的数据类型,如果在本队列中火山对象实例" 注释 = "不匹配该数据类型(为其或其继承类对象),将返回一个为该数据类型"
            注释 = "的空对象(其\"是否为空对象\"方法返回真)." @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)@sn<this>.GetVolObject (VOL_RUNTIME_CLASS (@<所欲获取对象的类型>), @<所欲获取对象的类型> ())
    }

    方法 交换 <公开 注释 = "交换两个栈中的数据." @嵌入式方法 = "">
    参数 所欲交换的栈 <类型 = 对象栈模板类>
    {
        @ @sn<this>.m_stack.swap (@<所欲交换的栈>.m_stack)
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "栈成员数: " + 到文本 (取成员数 ()) + "\r\n"
        展示内容 = 展示内容 + "栈顶成员: " + 取调试文本2 (最大展示数据尺寸, 取成员 ())
    }

    # @begin
    # <> <include>
    # std::stack<CVolWrapperObject> m_stack;
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_stack = objCopyFrom.m_stack; }
    # inline_ CVolObject& GetVolObject (const CVolRuntimeClass* pRuntimeClass, CVolObject& objDummy)
    # {
    #     ASSERT (pRuntimeClass != NULL && objDummy.IsVolInstanceOf (pRuntimeClass));
    #     return m_stack.top().GetVolObject (pRuntimeClass, objDummy);
    # }
    # <> </include>
    # @end
}

类 对象栈类 <公开 基础类 = 对象栈模板类 @文档 = "category = \"数据处理.栈\"" @模板实现类 = "对象类">

