类 变量操作类 <公开 @文档 = "category = \"变量操作\"" @全局类 = 真>
{
    方法 连续赋值 <公开 静态 注释 = "将一个值连续赋予到所指定的一系列同类型变量中" @嵌入式方法 = "">
    参数 所欲赋予的值 <@匹配类型 = 通用型>
    参数 所欲赋值到的变量 <@需求类型 = 可写入变量 @匹配类型 = 匹配前参数值类型 @可扩展 = "d_text = \" = \"">
    {
        @ @<所欲赋值到的变量> = @<所欲赋予的值>
    }

    方法 连续清零 <公开 静态 注释 = "将所指定的一系列数值变量清零,逻辑型变量则清除为假." @嵌入式方法 = "">
    参数 所欲清零的变量 <@需求类型 = 可写入变量 @匹配类型 = 通用非文本基本型 @可扩展 = "d_text = \" = \"">
    {
        @ @<所欲清零的变量> = 0
    }

    方法 连续清空 <公开 静态 注释 = "将所指定的一系列文本型变量清除为空文本" @嵌入式方法 = "">
    参数 所欲清空的变量 <类型 = 文本型 @需求类型 = 可写入变量 @可扩展 = "d_text = \".Empty (); \"">
    {
        @ @<所欲清空的变量>.Empty ()
    }

    方法 交换变量 <公开 静态 注释 = "交换两个同类型变量的值" @嵌入式方法 = "">
    参数 变量1 <@需求类型 = 可写入变量 @匹配类型 = 通用型>
    参数 变量2 <@需求类型 = 可写入变量 @匹配类型 = 等于前参数值类型>
    {
        @ SWAP (@pdt<变量1>, @<变量1>, @<变量2>)
    }

    方法 连续位或 <公开 静态 类型 = 整数 注释 = "将多个整数值进行位或运算,返回运算后的结果." @嵌入式方法 = "">
    参数 欲进行运算的值1 <类型 = 整数>
    参数 欲进行运算的值2 <类型 = 整数 @可扩展 = "d_text = \" | \"">
    {
        @ @<欲进行运算的值1> | @<欲进行运算的值2>
    }

    方法 连续位与 <公开 静态 类型 = 整数 注释 = "将多个整数值进行位与运算,返回运算后的结果." @嵌入式方法 = "">
    参数 欲进行运算的值1 <类型 = 整数>
    参数 欲进行运算的值2 <类型 = 整数 @可扩展 = "d_text = \" & \"">
    {
        @ @<欲进行运算的值1> & @<欲进行运算的值2>
    }

    方法 连续位异或 <公开 静态 类型 = 整数 注释 = "将多个整数值进行位异或运算,返回运算后的结果." @嵌入式方法 = "">
    参数 欲进行运算的值1 <类型 = 整数>
    参数 欲进行运算的值2 <类型 = 整数 @可扩展 = "d_text = \" ^ \"">
    {
        @ @<欲进行运算的值1> ^ @<欲进行运算的值2>
    }
}

