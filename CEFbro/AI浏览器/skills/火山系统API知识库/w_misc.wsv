类 GUID类 <公开 注释 = "用作生成及管理GUID(全局唯一标识符)." 注释 = "提示: 对比两个本类对象中的GUID是否相等,使用\"对象内容是否相同\"方法进行比较即可." @文档 = "category = \"常用功能\"">
{
    方法 创建 <公开 类型 = 逻辑型 注释 = "创建一个GUID(全局唯一标识符)并填入本对象,返回是否成功." @禁止流程检查 = 真>
    {
        @ return SUCCEEDED (::CoCreateGuid (&m_guid));
    }

    方法 从文本创建 <公开 类型 = 逻辑型 注释 = "从所指定的GUID文本创建对应的GUID并填入本对象中,返回是否成功." @禁止流程检查 = 真>
    参数 GUID文本 <类型 = 文本型 注释 = "提供所欲转换的文本格式的GUID,格式类似: \"{bdfff072-497b-407b-a8f2-450d6e7b6827}\"">
    {
        @ return SUCCEEDED (::IIDFromString (@<GUID文本>.GetText (), &m_guid));
    }

    方法 从字节集创建 <公开 类型 = 逻辑型 注释 = "从所指定的GUID字节集创建对应的GUID并填入本对象中,返回是否成功." @禁止流程检查 = 真>
    参数 GUID字节集 <类型 = 字节集类 注释 = "提供所欲转换的字节集格式的GUID,该字节集应由本类的\"取字节集\"方法返回.">
    {
        @ if (@<GUID字节集>.GetSize () != sizeof (GUID))
        @     return FALSE;
        @ COPY_MEM (&m_guid, @<GUID字节集>.GetPtr (), sizeof (GUID));
        @ return TRUE;
    }

    方法 取文本 <公开 类型 = 文本型 注释 = "  返回本对象中所保存GUID对应的文本,所返回文本格式" 注释 = "类似: \"{bdfff072-497b-407b-a8f2-450d6e7b6827}\"" @禁止流程检查 = 真>
    {
        @ TCHAR acGUID [64];
        @ acGUID [0] = '\0';
        @ ::StringFromGUID2 (m_guid, acGUID, NUM_ELEMENTS_OF (acGUID));
        @ return CVolString (acGUID);
    }

    方法 取字节集 <公开 类型 = 字节集类 注释 = "返回本对象中所保存GUID对应的字节集数据" @禁止流程检查 = 真>
    {
        @ return CVolMem (&m_guid, sizeof (GUID));
    }

    # --
    # @begin
    # <> <include>
    # inline_ void @an<_OnInitExtra> ()  { m_guid = GUID_NULL; }
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { COPY_MEM (&m_guid, &objCopyFrom.m_guid, sizeof (GUID)); }
    # inline_ BOOL @an<_IsSelfEqualExtra> (const @sn<current_class>& objCompare) const  { return ::IsEqualGUID (m_guid, objCompare.m_guid); }
    # GUID m_guid;
    # <> </include>
    # @end
}

