<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本

类 星期类 <公开 注释 = "提供星期内各天的常量值" @文档 = "category = \"时间操作.辅助类\"" @常量类 = 整数>
{
    常量 星期一 <公开 值 = 0>
    常量 星期二 <公开 值 = 1>
    常量 星期三 <公开 值 = 2>
    常量 星期四 <公开 值 = 3>
    常量 星期五 <公开 值 = 4>
    常量 星期六 <公开 值 = 5>
    常量 星期日 <公开 值 = 6>
}

类 颜色类 <公开 注释 = "提供对颜色值的各种操作支持" @文档 = "category = \"其它\"" @全局类 = 真>
{
    常量 黑色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 0, 0)">
    常量 墨绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 128, 0)">
    常量 红褐色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 0, 0)">
    常量 褐绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 128, 0)">
    常量 灰色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 128, 128)">
    常量 绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 255, 0)">
    常量 红色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 0, 0)">
    常量 黄色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 255, 0)">
    常量 蓝灰色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 128, 255)">
    常量 嫩绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 224, 0)">
    常量 黄褐色 <公开 类型 = 整数 值 = @"@(INT)RGB (192, 96, 0)">
    常量 嫩黄色 <公开 类型 = 整数 值 = @"@(INT)RGB (216, 216, 0)">
    常量 紫色 <公开 类型 = 整数 值 = @"@(INT)RGB (144, 0, 255)">
    常量 灰绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 160, 128)">
    常量 橙黄色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 128, 0)">
    常量 芙红色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 128, 192)">
    常量 藏青色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 0, 128)">
    常量 深青色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 128, 128)">
    常量 紫红色 <公开 类型 = 整数 值 = @"@(INT)RGB (128, 0, 128)">
    常量 浅灰色 <公开 类型 = 整数 值 = @"@(INT)RGB (192, 192, 192)">
    常量 蓝色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 0, 255)">
    常量 艳青色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 255, 255)">
    常量 品红色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 0, 255)">
    常量 白色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 255, 255)">
    常量 藏蓝色 <公开 类型 = 整数 值 = @"@(INT)RGB (88, 48, 224)">
    常量 青绿色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 224, 128)">
    常量 粉红色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 168, 255)">
    常量 银白色 <公开 类型 = 整数 值 = @"@(INT)RGB (236, 236, 236)">
    常量 天蓝色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 136, 255)">
    常量 青蓝色 <公开 类型 = 整数 值 = @"@(INT)RGB (0, 96, 192)">
    常量 桃红色 <公开 类型 = 整数 值 = @"@(INT)RGB (255, 80, 128)">
    常量 深灰色 <公开 类型 = 整数 值 = @"@(INT)RGB (96, 96, 96)">
    常量 默认色 <公开 类型 = 整数 值 = @"@(INT)CLR_DEFAULT" 注释 = "注意: 本颜色值不见得能够使用,能否使用请参阅对应接口的文档.">
    常量 透明色 <公开 类型 = 整数 值 = @"@(INT)CLR_NONE" 注释 = "注意: 本颜色值不见得能够使用,能否使用请参阅对应接口的文档.">

    方法 取颜色值 <公开 静态 类型 = 整数 注释 = "将指定的RGB颜色分量组合为颜色值返回" @嵌入式方法 = "">
    参数 红色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的红色分量值.">
    参数 绿色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的绿色分量值.">
    参数 蓝色分量值 <类型 = 整数 注释 = "数值范围从 0 到 255,表示颜色中的蓝色分量值.">
    {
        @ RGB (@<红色分量值>, @<绿色分量值>, @<蓝色分量值>)
    }

    方法 取颜色红色分量 <公开 静态 类型 = 整数 注释 = "从指定颜色值中取出其红色分量,即red." @嵌入式方法 = "">
    参数 颜色值 <类型 = 整数>
    {
        @ GetRValue (@<颜色值>)
    }

    方法 取颜色绿色分量 <公开 静态 类型 = 整数 注释 = "从指定颜色值中取出其绿色分量,即green." @嵌入式方法 = "">
    参数 颜色值 <类型 = 整数>
    {
        @ GetGValue (@<颜色值>)
    }

    方法 取颜色蓝色分量 <公开 静态 类型 = 整数 注释 = "从指定颜色值中取出其蓝色分量,即blue." @嵌入式方法 = "">
    参数 颜色值 <类型 = 整数>
    {
        @ GetBValue (@<颜色值>)
    }

    方法 颜色偏移 <公开 静态 类型 = 整数 注释 = "将颜色值加上所指定的偏移量后返回" @嵌入式方法 = "">
    参数 所欲处理的颜色值 <类型 = 整数>
    参数 所欲添加的偏移量 <类型 = 整数 注释 = "偏移量可以是正值或负值">
    {
        @ OffsetColor ((COLORREF)@<所欲处理的颜色值>, @<所欲添加的偏移量>)
    }
}

# ===

类 时间转换部分 <公开 @文档 = "category = \"时间操作.辅助类\"" @常量类 = 整数>
{
    常量 全部转换 <公开 值 = 0>
    常量 日期部分 <公开 值 = 1>
    常量 时间部分 <公开 值 = 2>
}

类 时间字段类型 <公开 @文档 = "category = \"时间操作.辅助类\"" @常量类 = 整数>
{
    常量 年份 <公开 值 = 0>
    常量 季度 <公开 值 = 1>
    常量 月份 <公开 值 = 2>
    常量 周 <公开 值 = 3>
    常量 日 <公开 值 = 4>
    常量 小时 <公开 值 = 5>
    常量 分钟 <公开 值 = 6>
    常量 秒 <公开 值 = 7>
    常量 毫秒 <公开 值 = 8>
}

类 时间部分类型 <公开 @文档 = "category = \"时间操作.辅助类\"" @常量类 = 整数>
{
    常量 年份 <公开 值 = 0 注释 = "">
    常量 季度 <公开 值 = 1>
    常量 月份 <公开 值 = 2>
    常量 自年首周数 <公开 值 = 3 注释 = "从1开始">
    常量 日 <公开 值 = 4>
    常量 小时 <公开 值 = 5>
    常量 分钟 <公开 值 = 6>
    常量 秒 <公开 值 = 7>
    常量 星期几 <公开 值 = 8>
    常量 自年首天数 <公开 值 = 9 注释 = "从1开始">
}

类 时间操作类 <公开 注释 = "提供常用日期时间操作支持." 注释 = "注意: 日期时间值使用小数来记录" @文档 = "category = \"时间操作\"" @全局类 = 真>
{
    方法 时间到文本 <公开 静态 类型 = 文本型 注释 = "将所指定的日期时间值转换到文本格式后返回." 注释 = "所返回日期时间文本内容的格式如下(时分秒为0将被省略):" 注释 = "中文格式: 1973年11月15日12时30分25秒"
            注释 = "非中文格式: 11/15/1973 12:30:25" 返回值注释 = "成功返回对应的日期时间文本,失败返回空文本." @禁止流程检查 = 真>
    参数 日期时间值 <类型 = 小数 注释 = "提供具体所欲转换的日期时间值">
    参数 转换部分 <类型 = 时间转换部分 注释 = "提供时间的哪些部分需要被转换" @默认值 = 时间转换部分.全部转换>
    参数 是否采用中文格式 <类型 = 逻辑型 注释 = "指定是否返回中文格式的日期时间文本" @默认值 = 真>
    {
        @ CVolString strDateTime;
        @ DateTimeToStr (@<日期时间值>, strDateTime, @<转换部分>, @<是否采用中文格式>);
        @ return strDateTime;
    }

    方法 时间到格式文本 <公开 静态 类型 = 文本型 注释 = "将日期时间值按照所指定的格式转换到文本格式后返回" 返回值注释 = "成功返回对应的日期时间文本,失败返回空文本." @嵌入式方法 = "">
    参数 日期时间值 <类型 = 小数 注释 = "提供具体所欲转换的日期时间值">
    参数 转换格式 <类型 = 文本型 注释 = "提供具体的转换格式文本,其中可以包括以\'%\'开头的替换符,可以使用的替换符由如下这些:" 注释 = "    %a: 星期缩写名称;" 注释 = "    %A: 星期完整名称;"
            注释 = "    %b: 月份缩写名称;" 注释 = "    %B: 月份完整名称;" 注释 = "    %c: 本地日期时间描述文本;"
            注释 = "    %#c: 本地日期时间长描述文本,如: \"Tuesday, March 14, 1995, 12:41:29\";" 注释 = "    %d: 在月份中的日 (01 – 31);"
            注释 = "    %H: 小时(24小时制) (00 – 23);" 注释 = "    %I: 小时(12小时制) (01 – 12);" 注释 = "    %j: 在年中的日 (001 – 366);"
            注释 = "    %m: 月份 (01 – 12);" 注释 = "    %M: 分钟 (00 – 59);" 注释 = "    %p: 现行本地的 A.M./P.M 标识, 用作表示12小时时钟;"
            注释 = "    %S: 秒 (00 – 59);" 注释 = "    %U: 在年中的星期,以周日为每星期的第一天 (00 – 53);" 注释 = "    %w: 在星期中的天 (0 – 6; 周日为 0);"
            注释 = "    %W: 在年中的星期,以周一为每星期的第一天 (00 – 53);" 注释 = "    %x: 本地日期描述文本;"
            注释 = "    %#x 本地日期长描述文本,如: \"Tuesday, March 14, 1995\";" 注释 = "    %X: 本地时间描述文本;" 注释 = "    %y: 不携带世纪部分的年份 (00 – 99);"
            注释 = "    %Y: 年份;" 注释 = "    %z, %Z: 时区的名称或缩写,为空如果时区未知;" 注释 = "    %%: 百分号字符本身;"
            注释 = "    %#d, %#H, %#I, %#j, %#m, %#M, %#S, %#U, %#w, %#W, %#y, %#Y: 不加\'#\'字符的对应替换符,但是替换文本去除掉首部的零."
            注释 = "格式文本中的非替换符部分原样输出到转换结果文本中." @默认值 = "%Y年%#m月%#d日%#H时%#M分%#S秒">
    {
        @ CVolString ().FormatDateTime ((DATE)@<日期时间值>, @<转换格式>.GetText ())
    }

    方法 到时间 <公开 静态 类型 = 小数 注释 = "  指定文本转换为时间并返回,如果给定文本不符合书写格式要求或者时间值错误导致不能进行转换,"
            注释 = "将返回\"数值范围.最小日期时间值\"常量值(100年1月1日),可以使用\"为最小时间\"方法进行判断." @嵌入式方法 = "">
    参数 日期时间文本 <类型 = 文本型 注释 = "提供具体所欲转换的日期时间文本内容,年份以后的所有部分均可以省略. 格式要求如下:" 注释 = "中文格式(年月日排列顺序为年月日),例如:"
            注释 = "  1. 1973年11月15日12时30分25秒" 注释 = "  2. 1973/11/15 12:30:25" 注释 = "  3. 1973/11/15/12/30/25"
            注释 = "  4. 1973/11/15/12:30:25" 注释 = "  5. 1973-11-15-12-30-25" 注释 = "  6. 1973-11-15-12:30:25"
            注释 = "  7. 1973.11.15 12:30:25" 注释 = "  8. 19731115123025" 注释 = "非中文格式(年月日排列顺序为月日年),例如:" 注释 = "  1. 11/15/1973 12:30:25"
            注释 = "  2. 11/15/1973/12/30/25" 注释 = "  4. 11/15/1973/12:30:25" 注释 = "  5. 11-15-1973-12-30-25"
            注释 = "  6. 11-15-1973-12:30:25" 注释 = "  7. 11.15.1973 12:30:25">
    参数 是否为中文格式 <类型 = 逻辑型 注释 = "指定所提供的日期时间文本内容是否为中文格式" @默认值 = 真>
    {
        @ StrToDateTime (@<日期时间文本>.GetText (), @<是否为中文格式>)
    }

    方法 为有效时间 <公开 静态 类型 = 逻辑型 注释 = "返回所提供的日期时间值是否有效">
    参数 日期时间值 <类型 = 小数 注释 = "提供具体所欲检查的日期时间值">
    {
        返回 (日期时间值 >= 数值范围.最小日期时间值 - 常数.接近零小数值 && 日期时间值 <= 数值范围.最大日期时间值 + 常数.接近零小数值)
    }

    方法 为最小时间 <公开 静态 类型 = 逻辑型 注释 = "返回所提供的日期时间值是否为最小有效时间">
    参数 日期时间值 <类型 = 小数 注释 = "提供具体所欲检查的日期时间值">
    {
        返回 (小数是否相等 (日期时间值, 数值范围.最小日期时间值))
    }

    方法 增减时间 <公开 静态 类型 = 小数 注释 = "返回一个时间,这一时间被加上或减去了一段间隔." 注释 = "如果改变后的时间无效,将自动靠近最近的有效时间." @嵌入式方法 = "">
    参数 被处理的时间 <类型 = 小数>
    参数 被增加字段 <类型 = 时间字段类型 注释 = "指定时间的哪一部分被进行增减操作">
    参数 增加值 <类型 = 长整数 注释 = "相对于被增加部分的增加或减少数值">
    {
        @ TimeChange (@<被处理的时间>, @<被增加字段>, @<增加值>)
    }

    方法 取时间间隔 <公开 静态 类型 = 小数 注释 = "返回\"时间1\"减去\"时间2\"之后的间隔数目." 注释 = "注意: 每个星期以星期天为第一天." @嵌入式方法 = "">
    参数 时间1 <类型 = 小数>
    参数 时间2 <类型 = 小数>
    参数 所欲取间隔的字段 <类型 = 时间字段类型>
    {
        @ GetTimeDiff (@<时间1>, @<时间2>, @<所欲取间隔的字段>)
    }

    方法 取某月天数 <公开 静态 类型 = 整数 注释 = "返回指定月份所包含的天数,如果给定的月份无效,返回0." @嵌入式方法 = "">
    参数 年份 <类型 = 整数 注释 = "指定年份,有效参数值从 100 到 9999.">
    参数 月份 <类型 = 整数 注释 = "指定月份,有效参数值从 1 到 12.">
    {
        @ (INT)GetDaysOfMonth (@<年份>, @<月份>)
    }

    方法 取时间部分 <公开 静态 类型 = 整数 注释 = "返回一个包含已知时间指定部分的值,如所提供时间无效,将返回-1." @嵌入式方法 = "">
    参数 欲取其部分的时间 <类型 = 小数>
    参数 欲取的时间部分 <类型 = 时间部分类型>
    {
        @ (INT)GetTimePart (@<欲取其部分的时间>, @<欲取的时间部分>)
    }

    方法 取年份 <公开 静态 类型 = 整数 注释 = "返回一个值为 100 到 9999 之间的整数,表示指定时间中的年份." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 0)
    }

    方法 取月份 <公开 静态 类型 = 整数 注释 = "返回一个值为 1 到 12 之间的整数,表示指定时间中的月份." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 2)
    }

    方法 取日 <公开 静态 类型 = 整数 注释 = "返回一个值为 1 到 31 之间的整数,表示一个月中的某一日." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 4)
    }

    方法 取星期几 <公开 静态 类型 = 整数 注释 = "返回一个值为 1 到 7 之间的整数,表示一个星期中的某一日." 注释 = "星期日为 1,星期一为 2,依此类推." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 8)
    }

    方法 取小时 <公开 静态 类型 = 整数 注释 = "返回一个值为 0 到 23 之间的整数,表示一天中的某一小时." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 5)
    }

    方法 取分钟 <公开 静态 类型 = 整数 注释 = "返回一个值为 0 到 59 之间的整数,表示一小时中的某一分钟." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 6)
    }

    方法 取秒 <公开 静态 类型 = 整数 注释 = "返回一个值为 0 到 59 之间的整数,表示一分钟中的某一秒." @嵌入式方法 = "">
    参数 欲处理的时间 <类型 = 小数>
    {
        @ (INT)GetTimePart (@<欲处理的时间>, 7)
    }

    方法 指定时间 <公开 静态 类型 = 小数 注释 = "  返回包含指定年,月,日,小时,分,秒的时间." 注释 = "  如果指定了无效时间,将返回\"数值范围.最小日期时间值\"常量值(100年1月1日),"
            注释 = "可以使用\"为最小时间\"方法进行判断." @嵌入式方法 = "">
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数 @默认值 = 1>
    参数 日 <类型 = 整数 @默认值 = 1>
    参数 小时 <类型 = 整数 @默认值 = 0>
    参数 分钟 <类型 = 整数 @默认值 = 0>
    参数 秒 <类型 = 整数 @默认值 = 0>
    {
        @ ToDate (@<年>, @<月>, @<日>, @<小时>, @<分钟>, @<秒>, 0, _VOL_MIN_DATE)
    }

    方法 取现行时间 <公开 静态 类型 = 小数 注释 = "返回当前操作系统日期及时间" @嵌入式方法 = "">
    {
        @ GetCurrentDateTime ()
    }

    方法 置现行时间 <公开 静态 类型 = 逻辑型 注释 = "设置当前操作系统日期及时间,返回是否成功." @嵌入式方法 = "">
    参数 所欲设置的时间 <类型 = 小数>
    {
        @ SetCurrentDateTime (@<所欲设置的时间>)
    }

    方法 取日期 <公开 静态 类型 = 小数 注释 = "返回一个日期时间型数据的日期部分,其小时/分钟/秒被固定设置为0时0分0秒." @嵌入式方法 = "">
    参数 所欲处理的时间 <类型 = 小数>
    {
        @ GetDatePart (@<所欲处理的时间>)
    }

    方法 取时间 <公开 静态 类型 = 小数 注释 = "返回一个日期时间型数据的时间部分,其年/月/日被固定设置为2000年1月1日." @嵌入式方法 = "">
    参数 所欲处理的时间 <类型 = 小数>
    {
        @ GetTimePart (@<所欲处理的时间>)
    }

    方法 取经历秒数 <公开 静态 类型 = 整数 注释 = "返回基于一个过去特定基准时间(北京时间 2017/7/5 15:55)的已经经过的秒数,必定大于等于0." @嵌入式方法 = "">
    {
        @ GetSecondsFromMyBaseTime ()
    }

    方法 取时间戳 <公开 静态 类型 = 整数 注释 = "返回所指定时间相对1970年1月1日0时0分0秒所经过的秒数(UNIX时间戳)" "">
    参数 欲处理的时间 <类型 = 小数>
    {
        变量 变量1 <类型 = 整数>
        @ TIME_ZONE_INFORMATION tz;
        @ tz.Bias = 0;
        @ ::GetTimeZoneInformation (&tz);
        @ @<变量1> = (INT)tz.Bias * 60;
        返回 ((整数)取时间间隔 (欲处理的时间, 25569, 时间字段类型.秒) + 变量1)
    }

    方法 时间戳到时间 <公开 静态 类型 = 小数 注释 = "将所指定时间戳值转换到时间">
    参数 欲处理的时间戳 <类型 = 长整数 注释 = "相对1970年1月1日0时0分0秒所经过的秒数(UNIX时间戳)">
    {
        变量 变量1 <类型 = 长整数>
        @ TIME_ZONE_INFORMATION tz;
        @ tz.Bias = 0;
        @ ::GetTimeZoneInformation (&tz);
        @ @<变量1> = (INT64)tz.Bias * 60;
        返回 (增减时间 (25569, 时间字段类型.秒, 欲处理的时间戳 - 变量1))
    }

    方法 取毫秒时间戳 <公开 静态 类型 = 长整数 注释 = "返回所指定时间相对1970年1月1日0时0分0秒所经过的毫秒数(UNIX时间戳)" "">
    参数 欲处理的时间 <类型 = 小数>
    {
        变量 变量1 <类型 = 长整数>
        @ TIME_ZONE_INFORMATION tz;
        @ tz.Bias = 0;
        @ ::GetTimeZoneInformation (&tz);
        @ @<变量1> = (INT64)tz.Bias * 60 * 1000;
        返回 ((长整数)取时间间隔 (欲处理的时间, 25569, 时间字段类型.毫秒) + 变量1)
    }

    方法 毫秒时间戳到时间 <公开 静态 类型 = 小数 注释 = "将所指定毫秒时间戳值转换到时间">
    参数 欲处理的时间戳 <类型 = 长整数 注释 = "相对1970年1月1日0时0分0秒所经过的毫秒数(UNIX时间戳)">
    {
        变量 变量1 <类型 = 长整数>
        @ TIME_ZONE_INFORMATION tz;
        @ tz.Bias = 0;
        @ ::GetTimeZoneInformation (&tz);
        @ @<变量1> = (INT64)tz.Bias * 60 * 1000;
        返回 (增减时间 (25569, 时间字段类型.毫秒, 欲处理的时间戳 - 变量1))
    }
}

