类 通用队列模板类 <公开 基础类 = 扩展对象类 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "通用队列类,用作基本类型填充." 注释 = "  模板类型1: 成员数据类型"
        @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<queue>" @模板基础类 = 真 @输出到部件 = 假>
{
    方法 压入 <公开 注释 = "在当前队列的尾部添加指定成员." @嵌入式方法 = "">
    参数 值 <类型 = 模板类型1 注释 = "提供所欲添加的成员.">
    {
        @ @sn<this>.m_queue.push(@<值>)
    }

    方法 弹出 <公开 注释 = "删除队列中第一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_queue.pop()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "判断本队列是否为空队列." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_queue.empty()
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本队列中已有成员的数目." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_queue.size ()
    }

    方法 取首成员 <公开 类型 = 模板类型1 注释 = "取出队列中的第一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_queue.front()
    }

    方法 取尾成员 <公开 类型 = 模板类型1 注释 = "取出队列中最末尾的一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_queue.back()
    }

    方法 交换 <公开 注释 = "交换两个队列中的数据." @嵌入式方法 = "">
    参数 所欲交换的队列 <类型 = 通用队列模板类>
    {
        @ @sn<this>.m_queue.swap (@<所欲交换的队列>.m_queue)
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "队列成员数: " + 到文本 (取成员数 ()) + "\r\n"
        展示内容 = 展示内容 + "队首成员: " + 取调试文本2 (最大展示数据尺寸, 取首成员 ()) + "\r\n"
        展示内容 = 展示内容 + "队尾成员: " + 取调试文本2 (最大展示数据尺寸, 取尾成员 ())
    }

    # @ <include>
    # @ std::queue<@dt<模板类型1>> m_queue;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_queue = objCopyFrom.m_queue; }
    # @ </include>
}

