    方法 取屏幕高度 <公开 静态 类型 = 整数 注释 = "返回屏幕当前显示区域的高度,单位为像素." @嵌入式方法 = "">
    {
        @ ::GetSystemMetrics (SM_CYSCREEN)
    }

    方法 取颜色数 <公开 静态 类型 = 整数 注释 = "返回当前显示方式所提供的最大颜色显示数目" @禁止流程检查 = 真>
    {
        @ const HDC hDC = ::GetDC (NULL);
        @ const INT nNumColors = (INT)pow (2.0, (INT)(::GetDeviceCaps (hDC, BITSPIXEL) * ::GetDeviceCaps (hDC, PLANES)));
        @ ::ReleaseDC (NULL, hDC);
        @ return nNumColors;
    }

    方法 鸣叫 <公开 静态 注释 = "通过计算机媒体设备或者喇叭发出一个声音" @嵌入式方法 = "">
