类 标准数组模板类 <公开 注释 = "本模板类封装了C++标准数组模板类\"std::vector\"" @文档 = "category = \"数据处理.标准数组\"" @模板基础类 = 真
        @别名 = "std::vector<模板类型1>" @别名类型 = 本地类 @视窗.外部头文件 = "<vector>\r\n<algorithm>">
{
    方法 预分配尺寸 <公开 静态 属性写 注释 = "提前为本数组分配指定数目成员的空间,用作支持在后面快速进行成员添加.">
    参数 当前对象 <类型 = 标准数组模板类>
    参数 尺寸 <类型 = 整数>
    {
        @ @<当前对象>.reserve (@<尺寸>);
    }

    方法 预分配尺寸 <公开 静态 属性读 类型 = 整数 @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准数组模板类>
    {
        @ (INT)@<当前对象>.capacity ()
    }

    # 方法--

    方法 枚举循环 <公开 静态 注释 = "  启动一个循环来枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值,调用\"取枚举索引\"" 注释 = "方法来获取当前所枚举到成员的索引位置."
            编辑时信息 = "D2D20, 0, 0, 0" @嵌入式方法 = "name = std_vector\r\nhas_loop_body = true">
    参数 当前对象 <类型 = 标准数组模板类 编辑时信息 = "D2D20, 0, 0, 0">
    {
        @ for (INT_P __vol_std_vector_index = 0; __vol_std_vector_index < (INT_P)@<当前对象>.size(); __vol_std_vector_index++) 
    }

    方法 逆向枚举循环 <公开 静态 注释 = "  启动一个循环来逆向枚举本数组中的每一个成员,在循环中可以调用" 注释 = "\"取枚举索引\"/\"取枚举值\"方法来获取当前所枚举索引和对应值."
            注释 = "注意: 不能嵌套使用本循环,否则编译将报错." @嵌入式方法 = "name = r_std_vector\r\nhas_loop_body = true">
    参数 当前对象 <类型 = 标准数组模板类>
    {
        @ for (INT_P __vol_std_vector_index = (INT_P)@<当前对象>.size () - 1; __vol_std_vector_index >= 0; __vol_std_vector_index--)
    }

    方法 取枚举值 <公开 静态 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
