    {
        @ @m<_VOL_REG_OPER_HEADER>
        @ return @<取字节集注册项2> (@<根目录>, strPath, CVolString (szItemName), @<默认值>);
    }

    方法 取字节集注册项2 <公开 静态 类型 = 字节集类 注释 = "在 Windows 注册表中返回指定的字节集类型注册表项值">
    参数 根目录 <类型 = 注册表根目录类型>
    参数 表项路径 <类型 = 文本型 注释 = "提供表项所处的注册表路径文本,路径分隔符为\'\\\\\'字符.">
    参数 表项名称 <类型 = 文本型 注释 = "提供表项的具体名称,如欲读取注册项默认值,请提供空文本.">
    参数 默认值 <类型 = 字节集类 注释 = "  如果指定的注册表项不存在,将返回此默认字节集.如果为空" 注释 = "对象,将返回空字节集." @默认值 = 空对象>
    {
        变量 结果变量 <类型 = 字节集类>
        如果 (是否为空对象 (默认值) == 假)
        {
            结果变量 = 默认值
        }
        @ HKEY hKey;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<根目录>, @<表项路径>.GetText (), 0, KEY_READ, &hKey) == ERROR_SUCCESS)
        @ {
        @     DWORD dwType, dwDataSize = 0;
        @     if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, &dwType, NULL, &dwDataSize) == ERROR_SUCCESS && dwType == REG_BINARY)
        @     {
        @         CVolMem memBuf;
        @         if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, NULL, memBuf.Alloc ((INT_P)(UINT_P)dwDataSize), &dwDataSize) == ERROR_SUCCESS)
        @             @<结果变量> = memBuf;
        @     }
        @     ::RegCloseKey (hKey);
        @ }
        返回 (结果变量)
    }

