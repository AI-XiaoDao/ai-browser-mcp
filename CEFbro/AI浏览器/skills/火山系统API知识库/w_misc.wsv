    方法 删除注册项 <公开 静态 类型 = 逻辑型 注释 = "在 Windows 注册表中删除指定注册表项或注册表目录." 注释 = "如欲删除注册项默认值,请在项目名后加\'\\\\\'字符,如\"vol\\\\\"."
            返回值注释 = "返回是否成功" @禁止流程检查 = 真>
    参数 根目录 <类型 = 注册表根目录类型>
    参数 全路径注册项名 <类型 = 文本型>
    {
        @ @m<_VOL_REG_OPER_HEADER>
        @ if (@<删除注册项2> (@<根目录>, strPath, CVolString (szItemName)) == FALSE)
        @     return (::RegDeleteKey ((HKEY)(UINT_P)@<根目录>, @<全路径注册项名>.GetText ()) == ERROR_SUCCESS);
        @ return TRUE;
    }

    方法 删除注册项2 <公开 静态 类型 = 逻辑型 注释 = "在 Windows 注册表中删除指定注册表项" 返回值注释 = "返回是否成功" @禁止流程检查 = 真>
    参数 根目录 <类型 = 注册表根目录类型>
    参数 表项路径 <类型 = 文本型 注释 = "提供表项所处的注册表路径文本,路径分隔符为\'\\\\\'字符.">
    参数 表项名称 <类型 = 文本型 注释 = "提供表项的具体名称,如欲删除注册项默认值,请提供空文本.">
    {
        @ HKEY hKey;
        @ BOOL_P blpSucceeded = FALSE;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<根目录>, @<表项路径>.GetText (), 0, KEY_WRITE, &hKey) == ERROR_SUCCESS)
        @ {
        @     blpSucceeded = (::RegDeleteValue (hKey, @<表项名称>.GetText ()) == ERROR_SUCCESS);
        @     ::RegCloseKey (hKey);
        @ }
        @ return (BOOL)blpSucceeded;
    }

    方法 注册项是否存在 <公开 静态 类型 = 逻辑型 注释 = "返回所指定注册表项是否存在." 注释 = "如欲检查注册项是否具有默认值,请在项目名后加\'\\\\\'字符,如\"vol\\\\\"." @禁止流程检查 = 真>
