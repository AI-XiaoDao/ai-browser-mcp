类 宏操作类 <公开 注释 = "提供相关宏操作支持" @文档 = "category = \"宏操作\"" @全局类 = 真>
{
    方法 宏如果 <公开 静态 注释 = "  如果所指定名称的宏被定义,则本地编译器将编译本语句的子语句体内容并" 注释 = "跳过所有后续的\"宏否则\"及\"宏默认\"判断语句,否则将会忽略此子语句体内容."
            注释 = "  本方法后必须跟随\"宏否则\"/\"宏默认\"/\"宏结束\"方法的调用语句."
            @嵌入式方法 = "name = m_ifdef\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nnext= \"m_elif, m_else, m_endif\"\r\n">
    参数 欲检查的宏名 <类型 = 文本型 注释 = "提供用作检查其是否被定义的宏名称文本,必须为有效的英文名称." 编辑时信息 = "17553E, 0, 0, 0" @需求类型 = 立即数或常量>
    {
        @ #if defined (@pvpn<欲检查的宏名>)
    }

    方法 宏否则 <公开 静态 注释 = "  如果所指定名称的宏被定义,则本地编译器将编译本语句的子语句体内容并跳过所" 注释 = "有后续的\"宏否则\"及\"宏默认\"判断语句,否则将会忽略此子语句体内容."
            注释 = "  本方法只能位于\"宏如果\"或\"宏否则\"方法的调用语句后方,后面必须跟随\"宏否则\"" 注释 = "/\"宏默认\"/\"宏结束\"方法的调用语句." 编辑时信息 = "145541, 0, 0, 0"
            @嵌入式方法 = "name = m_elif\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nprev = \"m_ifdef, m_elif\"\r\nnext= \"m_elif, m_else, m_endif\"\r\n">
    参数 欲检查的宏名 <类型 = 文本型 注释 = "提供用作检查其是否被定义的宏名称文本,必须为有效的英文名称." 编辑时信息 = "145541, 0, 0, 0" @需求类型 = 立即数或常量>
    {
        @ #elif defined (@pvpn<欲检查的宏名>)
    }

    方法 宏默认 <公开 静态 注释 = "  如果前方所有宏判断语句(\"宏如果\"及\"宏否则\")中的宏均未被定义,则本地编译器" 注释 = "将编译本语句的子语句体内容,否则将会忽略此子语句体内容."
            注释 = "  本方法只能位于\"宏如果\"或\"宏否则\"方法的调用语句后方,后面必须跟随\"宏结束\"" 注释 = "方法的调用语句." 编辑时信息 = "147FEB, 0, 0, 0"
            @嵌入式方法 = "name = m_else\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"@none\"\r\nprev = \"m_ifdef, m_elif\"\r\nnext= \"m_endif\"\r\n">
    {
        @ #else
    }

    方法 宏结束 <公开 静态 注释 = "用作标志以\"宏如果\"方法调用语句开始的整个宏判断结束." 注释 = "本方法只能位于\"宏如果\"/\"宏否则\"/\"宏默认\"方法的调用语句后方."
            编辑时信息 = "153FEA, 0, 0, 0" @嵌入式方法 = "name = m_endif\r\nno_end_sem\r\nprev = \"m_ifdef, m_elif, m_else\"\r\n">
    {
        @ #endif
    }
}

