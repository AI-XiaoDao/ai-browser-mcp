    {
        @ ::MessageBeep (@<声音类型>)
    }

    方法 延时 <公开 静态 注释 = "暂停当前程序的运行并等待指定的时间" @嵌入式方法 = "">
    参数 欲等待的时间 <类型 = 整数 注释 = "指定欲暂停程序执行的时间,单位为毫秒.">
    {
        @ ::Sleep ((DWORD)@<欲等待的时间>)
    }

