# ===

类 多值哈希表模板类 <公开 注释 = "本模板类封装了C++标准列表模板类\"std::multimap\"." 注释 = "多值哈希表模板类:" 注释 = "    模板类型1: 关键字" 注释 = "    模板类型2: 值"
        注释 = "本类特点如下:" 注释 = "    1. 与通常哈希表不同的是: 本类允许关键字有多个关联值;" 注释 = "    2. 内部的元素会根据键自动排序;" 注释 = "    3. 插入新元素的速度非常快;"
        注释 = "    4. 支持高效的查找和删除操作：你可以用关键字来查找元素,或者删除具有某个关键字的所有值." @别名类型 = 本地类 @视窗.外部头文件 = "<map>\r\n<algorithm>"
        @文档 = "category = \"数据处理.多值哈希表\"" @别名 = "std::multimap<模板类型1, 模板类型2>" @模板基础类 = 真>
{
    方法 初始化 <公开 静态 @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 初始列表 <类型 = 文本型 注释 = "本参数用作提供数据表中的初始键值对列表的字符串格式."
            注释 = "\"整数到文本多值哈希表\"的\"初始列表\"例如: \"{1,\\\"火\\\"},{2,\\\"山\\\"},{3,\\\"软\\\"}\"">
    {
        @ @<当前对象> = { @pvpt<初始列表> }
    }

    方法 插入 <公开 静态 注释 = "插入一个键值对进哈希表中,如果指定关键字已经存在,不会将其覆盖,会建立一个新的键值对." @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 关键字 <类型 = 模板类型1 注释 = "提供关键字">
    参数 对应值 <类型 = 模板类型2 注释 = "提供关键字所对应的值">
    {
        @ @<当前对象>.insert(std::make_pair(@<关键字>, @<对应值>))
    }

    方法 枚举值 <公开 静态 注释 = "枚举指定关键字所有值." 注释 = "在本方法的子语句体内调用\"取值\"方法即可取出对应值." 编辑时信息 = "CBFF3, 0, 0, 0"
            @嵌入式方法 = "name = multimap_equal_range\r\nhas_loop_body = true">
    参数 当前对象 <类型 = 多值哈希表模板类 编辑时信息 = "CBFF3, 0, 0, 0">
    参数 关键字 <类型 = 模板类型1 注释 = "提供欲查找其值的关键字" 编辑时信息 = "CBFF3, 0, 0, 0">
    {
        @ for (auto __vol_multimap =  @<当前对象>.equal_range(@<关键字>); __vol_multimap.first != __vol_multimap.second; ++__vol_multimap.first)
    }

    方法 取值 <公开 静态 类型 = 模板类型2 注释 = "只能在本类的\"枚举值\"语句的子语句体中使用,用作取回当前所枚举到键值对成员的值." @嵌入式方法 = "parent = \"multimap_equal_range\"">
    {
        @ __vol_multimap.first->second
    }

    方法 枚举循环 <公开 静态 注释 = "  启动一个循环来正向枚举本哈希表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举关键字\"/\"取枚举值\"方法来获取当前所枚举到键值对的关键字及" 注释 = "其对应值."
            编辑时信息 = "ED546, 0, 0, 0" @嵌入式方法 = "name = multimap_iter\r\nhas_loop_body = true">
    参数 当前对象 <类型 = 多值哈希表模板类 编辑时信息 = "ED546, 0, 0, 0">
    {
        @ for (const auto &__vol_multimap_pair : @<当前对象>)
    }

    方法 取枚举关键字 <公开 静态 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的关键字,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近"
            注释 = "层\"枚举循环\"所枚举到键值对成员的关键字." @嵌入式方法 = "parent = \"multimap_iter\"">
    {
        @ __vol_multimap_pair.first
    }

    方法 取枚举值 <公开 静态 类型 = 模板类型2 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的值,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近层"
            注释 = "\"枚举循环\"所枚举到键值对成员的值." @嵌入式方法 = "parent = \"multimap_iter\"">
    {
        @ __vol_multimap_pair.second 
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回本哈希表中已有键值对成员的数目" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    {
        @ (INT)@<当前对象>.size ()
    }

    方法 是否存在 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的关键字是否已经存在" @禁止流程检查 = 真>
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ return (@<当前对象>.find (@<关键字>) != @<当前对象>.end ());
    }

    方法 删除所有值 <公开 静态 注释 = "删除指定关键字及其所有关联键值对">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ auto range = @<当前对象>.equal_range(@<关键字>); 
        @ @<当前对象>.erase(range.first, range.second); 
    }

    方法 删除首值 <公开 静态 注释 = "删除指定关键字的第一个关联键值对">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ auto it = @<当前对象>.find(@<关键字>); 
        @ if (it != @<当前对象>.end())
        @     @<当前对象>.erase(it); // 删除第一个找到的值
    }

    方法 删除指定值 <公开 静态 注释 = "删除指定关键字的所有指定值">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 值 <类型 = 模板类型2 注释 = "提供欲删除的该关键字的值">
    {
        @ for (auto it = @<当前对象>.begin(); it != @<当前对象>.end(); ) {
        @     if (it->first == @<关键字> && it->second == @<值>)
        @         it = @<当前对象>.erase(it);
        @     else
        @         it++;
        @ }
    }

    方法 清空 <公开 静态 注释 = "清除本哈希表中的所有内容" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    {
        @ @<当前对象>.clear ()
    }

    方法 交换 <公开 静态 注释 = "交换两个哈希表中的数据" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    参数 所欲交换的哈希表 <类型 = 多值哈希表模板类>
    {
        @ @<当前对象>.swap (@<所欲交换的哈希表>)
    }

    方法 是否为空 <公开 静态 类型 = 逻辑型 注释 = "返回本哈希表是否为空" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希表模板类>
    {
        @ (BOOL)@<当前对象>.empty ()
    }
}

类 整数到整数多值哈希表 <公开 基础类 = 多值哈希表模板类 @文档 = "category = \"数据处理.多值哈希表\"" @模板实现类 = "整数, 整数">

类 整数到文本多值哈希表 <公开 基础类 = 多值哈希表模板类 @文档 = "category = \"数据处理.多值哈希表\"" @模板实现类 = "整数, 文本型">

