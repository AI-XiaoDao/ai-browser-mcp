    参数 文本数据 <类型 = 文本型>
    {
        @ std::wstring (@<文本数据>.GetText ())
    }

    方法 取文本 <公开 静态 类型 = 文本型 注释 = "取回本类对象中的文本内容" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准宽文本类>
    {
        @ @an<CVolString> (@<当前对象>.c_str ())
    }
}

