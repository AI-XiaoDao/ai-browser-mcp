    常量 冬眠 <公开 值 = 5>
}

类 返回按钮类型 <公开 注释 = "用作提供信息框方法的返回按钮类型" @文档 = "category = \"常用功能.辅助类\"" @常量类 = 整数>
{
    常量 确认钮 <公开 值 = @IDOK>
    常量 取消钮 <公开 值 = @IDCANCEL>
    常量 放弃钮 <公开 值 = @IDABORT>
    常量 重试钮 <公开 值 = @IDRETRY>
    常量 忽略钮 <公开 值 = @IDIGNORE>
    常量 是钮 <公开 值 = @IDYES>
    常量 否钮 <公开 值 = @IDNO>
}

类 信息框按钮 <公开 注释 = "用作指定信息框方法所显示按钮的类型." 注释 = "可以将本类中的常量值相加以组合\"信息框\"方法的\"按钮\"参数值,注意每组常量只能取用一个(第五组除外)"
        @文档 = "category = \"常用功能.辅助类\"">
{
    常量 "// 第一组: 描述对话框中显示按钮的类型与数目"
    常量 确认钮 <公开 类型 = 整数 值 = @MB_OK>
    常量 确认取消钮 <公开 类型 = 整数 值 = @MB_OKCANCEL>
    常量 放弃重试忽略钮 <公开 类型 = 整数 值 = @MB_ABORTRETRYIGNORE>
    常量 取消是否钮 <公开 类型 = 整数 值 = @MB_YESNOCANCEL>
    常量 是否钮 <公开 类型 = 整数 值 = @MB_YESNO>
    常量 重试取消钮 <公开 类型 = 整数 值 = @MB_RETRYCANCEL>
    常量 ""
    常量 "// 第二组: 描述图标的样式"
    常量 错误图标 <公开 类型 = 整数 值 = @MB_ICONERROR>
    常量 询问图标 <公开 类型 = 整数 值 = @MB_ICONQUESTION>
    常量 警告图标 <公开 类型 = 整数 值 = @MB_ICONEXCLAMATION>
    常量 信息图标 <公开 类型 = 整数 值 = @MB_ICONINFORMATION>
    常量 ""
    常量 "// 第三组: 指定哪一个按钮是缺省默认值"
    常量 默认按钮一 <公开 类型 = 整数 值 = @MB_DEFBUTTON1>
    常量 默认按钮二 <公开 类型 = 整数 值 = @MB_DEFBUTTON2>
    常量 默认按钮三 <公开 类型 = 整数 值 = @MB_DEFBUTTON3>
    常量 默认按钮四 <公开 类型 = 整数 值 = @MB_DEFBUTTON4>
    常量 ""
    常量 "// 第四组: 决定如何等待消息框结束"
    常量 程序等待 <公开 类型 = 整数 值 = @MB_APPLMODAL>
    常量 系统等待 <公开 类型 = 整数 值 = @"@MB_SYSTEMMODAL + MB_TASKMODAL">
    常量 ""
    常量 "// 第五组: 其它"
    常量 位于前台 <公开 类型 = 整数 值 = @MB_SETFOREGROUND>
}

类 系统电源状态 <公开 注释 = "用于记录电源状态" @文档 = "category = \"常用功能.辅助类\"">
{
    变量 电源状态 <公开 类型 = 整数 注释 = "0 未连接电源线" 注释 = "1 连接电源线" 注释 = "255 未知状态">
    变量 电池当前状态 <公开 类型 = 系统电池状态 注释 = "取出电池状态">
    变量 电池剩余电量 <公开 类型 = 整数 注释 = "电池剩余电量的百分比,此成员可以是 0 到 100 范围内的值，如果状态未知，则可以是 255。">
    变量 电池剩余使用时间 <公开 类型 = 长整数 注释 = "电池剩余时间的秒数,如果剩余秒数未知或设备连接到交流电源,则为–1。">
    变量 电池可用时间 <公开 类型 = 长整数 注释 = "完全充电时电池寿命的秒数,如果电池的完整寿命未知或设备连接到交流电源,则为–1">
}

类 系统电池状态 <公开 注释 = "用于记录电池状态的常量类" @文档 = "category = \"常用功能.辅助类\"" @常量类 = 整数>
{
    常量 大于66 <公开 值 = 1 注释 = "百分比">
    常量 小于33 <公开 值 = 2 注释 = "百分比">
    常量 小于5 <公开 值 = 4 注释 = "百分比">
    常量 充电中 <公开 值 = 8 注释 = "表示充电中">
    常量 无电池 <公开 值 = 128 注释 = "表示没有电池">
    常量 未知 <公开 值 = 255 注释 = "未知状态">
}

类 常用功能类 <公开 @文档 = "category = \"常用功能\"" @全局类 = 真>
{
    方法 取CPU核心数 <公开 静态 类型 = 整数 注释 = "返回当前计算机中CPU核心的数量,此值可以用作确定多线程程序中的推荐工作线程数目." @嵌入式方法 = "">
    {
        @ (INT)::GetNumProcessorsInsideSystem ()
    }

    方法 取推荐工作线程数 <公开 静态 类型 = 整数 注释 = "  根据当前计算机中CPU核心的数量计算并返回推荐工作线程的数目," 注释 = "使用该数目的工作线程能够最大限度地利用计算机资源而又不会让"
            注释 = "操作系统在线程切换上消耗过多." @嵌入式方法 = "">
    参数 最多线程数 <类型 = 整数 注释 = "提供所允许的最多线程数目,为0表示无限制." @默认值 = 0>
    {
        @ (INT)::GetRecommendWorkingThreadCount (@<最多线程数>)
    }

    方法 取系统电源状态 <公开 静态 类型 = 系统电源状态 注释 = "取出并返回系统当前电源状态">
    {
        变量 电源状态 <类型 = 系统电源状态>
        @ SYSTEM_POWER_STATUS sysPowerStatus;
        @ ZERO_MEM (&sysPowerStatus, sizeof (sysPowerStatus));
        @ GetSystemPowerStatus(&sysPowerStatus);
        @ @<电源状态.电源状态>=(INT)sysPowerStatus.ACLineStatus;
        @ @<电源状态.电池当前状态>=(@dt<系统电池状态>)sysPowerStatus.BatteryFlag;
        @ @<电源状态.电池剩余电量>=(INT)sysPowerStatus.BatteryLifePercent;
        @ @<电源状态.电池剩余使用时间>=sysPowerStatus.BatteryLifeTime;
        @ @<电源状态.电池可用时间>=sysPowerStatus.BatteryFullLifeTime;
        返回 (电源状态)
    }

    方法 为64位程序 <公开 静态 类型 = 逻辑型 注释 = "返回当前编译的是否为64位目标程序" @嵌入式方法 = "">
    {
        @ sizeof (INT_P) == 8
    }

    方法 取目标操作系统 <公开 静态 类型 = 目标操作系统类别 注释 = "返回当前程序所对应的目标操作系统类型" @禁止流程检查 = 真>
    {
        @ #if defined (_PF_WINDOWS)
        @     return @<目标操作系统类别.Windows>;
        @ #elif defined (_PF_LINUX)
        @     return @<目标操作系统类别.Linux>;
        @ #else
        @     return @<目标操作系统类别.未知>;
        @ #endif
    }

    方法 置入代码 <公开 静态 注释 = "将所指定的代码字节系列插入到当前程序语句编译位置." 注释 = "注意: 本方法仅在编译32位程序时有效" @嵌入式方法 = "no_end_sem = true"
            "//@视窗.需求目标平台" = @"32位平台">
    参数 代码字节 <类型 = 整数 @可扩展 = "d_text = \" __asm _emit \"">
    {
        @ __asm _emit @<代码字节>
    }

    方法 交换鼠标左右键 <公开 静态 类型 = 逻辑型 注释 = "互换鼠标左右键的功能" 返回值注释 = "返回真表示鼠标按钮的功能在调用这个函数之前已经互换,否则返回假." @嵌入式方法 = "">
    参数 是否交换 <类型 = 逻辑型 注释 = "为真则互换两个鼠标按钮的功能,假则恢复正常状态." @默认值 = 真>
    {
        @ SwapMouseButton (@<是否交换>)
    }

    方法 显示鼠标指针 <公开 静态 类型 = 整数 注释 = "显示或隐藏当前鼠标指针" @嵌入式方法 = "">
    参数 是否显示 <类型 = 逻辑型 注释 = "为真则显示鼠标指针,为假则隐藏." @默认值 = 真>
    {
        @ ShowCursor (@<是否显示>)
    }

    方法 取鼠标位置 <公开 静态 类型 = 位置类 注释 = "返回鼠标当前在屏幕上的位置" @禁止流程检查 = 真>
    {
        @ POINT ptCursor;
        @ VERIFY (::GetCursorPos (&ptCursor));
        @ return @dt<位置类> (&ptCursor);
    }

    方法 取鼠标水平位置 <公开 静态 类型 = 整数 注释 = "返回鼠标当前在屏幕上的水平方向位置" @禁止流程检查 = 真>
    {
        @ POINT ptCursor;
        @ VERIFY (::GetCursorPos (&ptCursor));
