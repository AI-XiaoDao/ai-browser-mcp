类 流程控制类 <公开 注释 = "提供对于流程控制的相关额外支持" @文档 = "category = \"流程控制\"" @全局类 = 真>
{
    方法 如果真 <公开 静态 注释 = "当所指定的条件参数值为真,则执行子语句体,否则将其跳过." @嵌入式方法 = "has_body = true">
    参数 条件参数 <类型 = 逻辑型>
    {
        @ if (@<条件参数>)
    }

    方法 计次循环 <公开 静态 注释 = "将子语句体循环指定所指定的次数." 注释 = "在子语句体中,可以使用\"取循环索引\"方法取回当前循环索引值(0到\"循环次数\"参数值-1)."
            @嵌入式方法 = "name = counter\r\nhas_loop_body = true">
    参数 循环次数 <类型 = 整数 编辑时信息 = "11AA99, 0, 0, 0">
    {
        @ for (INT_P __vol_counter_index = 0; __vol_counter_index < @<循环次数>; __vol_counter_index++)
    }

    方法 逆向计次循环 <公开 静态 注释 = "将子语句体逆向循环指定所指定的次数." 注释 = "在子语句体中,可以使用\"取循环索引\"方法取回当前循环索引值(\"循环次数\"参数值-1 到 0)."
            @嵌入式方法 = "name = rcounter\r\nhas_loop_body = true">
    参数 循环次数 <类型 = 整数 编辑时信息 = "11AA99, 0, 0, 0">
    {
        @ for (INT_P __vol_counter_index = @<循环次数> - 1; __vol_counter_index >= 0; __vol_counter_index--)
    }

    方法 取循环索引 <公开 静态 类型 = 整数 注释 = "  只能在\"计次循环\"/\"逆向计次循环\"语句的子语句体中使用,用作取回当前循环索引值,"
            注释 = "所取回的值范围为从0到\"计次循环\"调用语句中所指定的\"循环次数\"参数值-1." 注释 = "  如果有多层\"计次循环\"/\"逆向计次循环\"嵌套,本方法将返回所处最近层\"计次循环\"/"
            注释 = "\"逆向计次循环\"的索引值." @嵌入式方法 = "parent = \"counter, rcounter\"">
    {
        @ (INT)__vol_counter_index
    }

    方法 循环判断首 <公开 静态 注释 = "首先执行循环子语句体,在子语句体的尾部判断是否是否继续循环." 注释 = "本语句的后面必须跟随一个\"循环判断尾\"语句."
            @嵌入式方法 = "name = do\r\nhas_loop_body = true\r\nnext = while">
    {
        @ do
    }

    方法 循环判断尾 <公开 静态 注释 = "本方法的调用语句必须紧跟在\"循环判断首\"语句的后面,用作根据所提供的条件参数决定是否继续循环." @嵌入式方法 = "name = while\r\nprev = do">
    参数 是否继续循环 <类型 = 逻辑型 注释 = "参数值为真继续循环,否则退出循环.">
    {
        @ while (@<是否继续循环>)
    }

    方法 分支判断 <公开 静态 注释 = "开始对一个整数参数的值进行分支判断处理." 注释 = "本方法的子语句体中只能存在\"分支\"或\"默认分支\"方法的调用语句,并且至少包含一个." 编辑时信息 = "17553E, 0, 0, 0"
            @嵌入式方法 = "name = switch\r\nhas_body = true\r\nchild = \"case, default\"">
    参数 欲判断检查的值 <类型 = 整数 编辑时信息 = "17553E, 0, 0, 0">
    {
        @ switch (@<欲判断检查的值>)
    }

    方法 分支 <公开 静态 注释 = "  本方法的调用语句只能在\"分支判断\"语句的直接子语句体中使用,用作提供一个判断检查分支."
            注释 = "  当\"分支判断\"语句的\"欲判断检查的值\"参数等于本语句中的\"欲检查是否相等的值\"时,将去执" 注释 = "行本语句的子语句体中的代码并跳过后续所有其它判断检查分支,否则将跳过本语句的子语句体"
            注释 = "转去检查后续的下一分支是否满足要求." 注释 = "  注意: 不能多个判断检查分支具有相同的\"欲检查是否相等的值\",此时对应本地编译器将会报错." 编辑时信息 = "C9548, 0, 0, 0"
            @嵌入式方法 = "name = case\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"    break; }\"\r\nparent = \"switch\"\r\nlineal_parent = true\r\nprev = \"case, @none\"\r\nnext = \"case, @none, default\"">
    参数 欲检查是否相等的值 <类型 = 整数 注释 = "本参数值只能提供立即数或常量值" @需求类型 = 立即数或常量>
    {
        @ case @<欲检查是否相等的值>: {
    }

    方法 默认分支 <公开 静态 注释 = "本方法的调用语句只能在\"分支判断\"语句的直接子语句体的尾部使用,用作提供一个判断检查分支." 注释 = "当前面所有判断检查分支均不满足时将最终执行本语句的子语句体中的代码."
            编辑时信息 = "16BFE9, 0, 0, 0"
            @嵌入式方法 = "name = default\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"    break; }\"\r\nparent = \"switch\"\r\nlineal_parent = true\r\nprev = \"case, @none\"\r\nnext = \"@none\"">
    {
        @ default: {
    }

    方法 跳出分支 <公开 静态 注释 = "  本语句只能在\"分支\"或\"默认分支\"语句的直接/间接子语句体中使用," 注释 = "用作跳转去执行所处\"分支判断\"语句的下一条语句."
            @嵌入式方法 = "parent = \"case, default\"">
    {
        @ break
    }

    方法 结束 <公开 静态 注释 = "  结束当前程序的运行." 注释 = "  尽量以关闭程序主窗口的方式而不要使用本方法来结束程序," 注释 = "以正常释放程序运行中所占用的资源以及作相关善后处理." @嵌入式方法 = "">
    参数 结束代码 <类型 = 整数 注释 = "本结束代码值将被返回到程序的调用方" @默认值 = 0>
    {
        @ ExitProcess (@<结束代码>)
    }

    方法 选择 <公开 静态 注释 = "根据所提供参数的值,返回两个备选参数中的一个." @嵌入式方法 = "">
    参数 用作选择的逻辑值 <类型 = 逻辑型 注释 = "如果参数值为真,将返回备选参数1,否则返回备选参数2.">
    参数 备选参数1 <注释 = "如果\"用作选择的逻辑值\"参数值为真,方法将返回本参数值." @匹配类型 = 通用型 @返回值类型 = 0>
    参数 备选参数2 <注释 = "如果\"用作选择的逻辑值\"参数值为假,方法将返回本参数值." @匹配类型 = 等于前参数值类型>
    {
        @ @<用作选择的逻辑值> ? @<备选参数1> : @<备选参数2>
    }

    方法 多项选择 <公开 静态 注释 = "从参数列表项目中选择并返回一个值" @嵌入式方法 = "req_obj_param_pointer = true">
    参数 索引值 <类型 = 整数 注释 = "  方法会根据本索引值来返回选择项列表中的某个值,索引值从0开始." 注释 = "如果索引值是0,则命令会返回列表中的第1个选择项.如果索引值是1,"
            注释 = "则会返回列表中的第2个选择项,以此类推.">
    参数 待选择数据1 <注释 = "提供待选择的数据" @匹配类型 = 通用基本型 @返回值类型 = 0>
    参数 后续待选择数据 <@匹配类型 = 等于前参数值类型 @可扩展 = "">
    {
        @ ChooseOneValue_@pdt<待选择数据1> (@<索引值>, @sn<pm_count> - 1, @<待选择数据1>, @<后续待选择数据>)
    }
}

