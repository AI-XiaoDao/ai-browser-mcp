    {
        @ POINT ptCursor;
        @ VERIFY (::GetCursorPos (&ptCursor));
        @ return ptCursor.y;
    }

    方法 显示任务栏 <公开 静态 注释 = "显示/隐藏当前系统任务栏">
    参数 是否显示任务栏 <类型 = 逻辑型>
    {
        @ const HWND hWnd = ::FindWindow (_T ("Shell_traywnd"), _T (""));
        @ if (hWnd != NULL)
        @     ShowWindow (hWnd, (@<是否显示任务栏> ? SW_SHOW : SW_HIDE));
    }

    方法 任务栏是否可视 <公开 静态 类型 = 逻辑型 注释 = "返回系统当前任务栏是否可视" @禁止流程检查 = 真>
    {
        @ const HWND hWnd = ::FindWindow (_T ("Shell_traywnd"), _T (""));
        @ return (hWnd != NULL && ::IsWindowVisible (hWnd));
    }

