类 整数到对象哈希表 <公开 基础类 = 对象哈希表模板类 @文档 = "category = \"数据处理.哈希表\"" @模板实现类 = "整数">

类 文本到对象哈希表 <公开 基础类 = 对象哈希表模板类 @文档 = "category = \"数据处理.哈希表\"" @模板实现类 = "文本型">

# ===

类 哈希集模板类 <基础类 = 扩展对象类 注释 = "哈希集处理类." 注释 = "  模板类型1: 关键字数据类型" @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<set>" @模板基础类 = 真
        @输出到部件 = 假>
{
    方法 插入 <公开 类型 = 逻辑型 注释 = "插入一个值进哈希集中" 返回值注释 = "如果所指定值已经存在返回假,否则返回真." @嵌入式方法 = "">
    参数 所欲插入的值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_set.insert (@<所欲插入的值>).second
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本哈希集中已有成员的数目" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_set.size ()
    }

    方法 是否存在 <公开 类型 = 逻辑型 注释 = "返回所指定的值是否已经存在" @禁止流程检查 = 真>
    参数 所欲检查的值 <类型 = 模板类型1>
    {
        @ return (m_set.find (@<所欲检查的值>) != m_set.end ());
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "删除所指定的值,返回其是否存在." @嵌入式方法 = "">
    参数 所欲删除的值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_set.erase (@<所欲删除的值>) > 0
    }

    方法 清空 <公开 注释 = "清除本哈希集中的所有内容" @嵌入式方法 = "">
    {
        @ @sn<this>.m_set.clear ()
    }

    方法 交换 <公开 注释 = "交换两个哈希集中的数据" @嵌入式方法 = "">
    参数 所欲交换的哈希集 <类型 = 哈希集模板类>
    {
        @ @sn<this>.m_set.swap (@<所欲交换的哈希集>.m_set)
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本哈希集是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_set.empty ()
    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来正向枚举本哈希集中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = iter\r\nhas_loop_body = true">
    {
        @ std::set<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_set;
        @ for (std::set<@dt<模板类型1>>::iterator _vsetitr = @sn<rand_name0>.begin (); _vsetitr != @sn<rand_name0>.end (); _vsetitr++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个循环来逆向枚举本哈希集中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = r_iter\r\nhas_loop_body = true">
    {
        @ std::set<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_set;
        @ for (std::set<@dt<模板类型1>>::reverse_iterator _vsetitr = @sn<rand_name0>.rbegin (); _vsetitr != @sn<rand_name0>.rend (); _vsetitr++)
    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前所枚举到的成员值,"
            注释 = "如果有多层本类或本类继承类的\"枚举循环\"/\"逆向枚举循环\"嵌套,本方法将返回最近层\"枚举循环\"/" 注释 = "\"逆向枚举循环\"所枚举到的成员值."
            @嵌入式方法 = "parent = \"iter, r_iter\"">
    {
        @ *_vsetitr
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "哈希集成员数: " + 到文本 (取成员数 ()) + "\r\n"
        枚举循环 ()
        {
            展示内容 = 展示内容 + "关键字: " + 取调试文本2 (最大展示数据尺寸, 取枚举值 ()) + "\r\n"
        }
    }

    # @ <include>
    # @ std::set<@dt<模板类型1>> m_set;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_set = objCopyFrom.m_set; }
    # @ </include>
}

