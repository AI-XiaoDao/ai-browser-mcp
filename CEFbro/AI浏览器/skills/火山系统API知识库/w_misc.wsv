类 基本无序哈希表模板类 <公开 基础类 = 扩展对象类 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "无序哈希表处理类." 注释 = "  模板类型1: 关键字数据类型,仅支持非文本型的基本类型."
        注释 = "  模板类型2: 值数据类型" @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<unordered_map>" @模板基础类 = 真 @输出到部件 = 假>
{
    方法 插入 <公开 注释 = "  插入一个键值对进哈希表中,如果所指定关键字已经存在," 注释 = "则其所对应的先前值数据将被覆盖." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应值 <类型 = 模板类型2 注释 = "提供关键字所对应的值">
    {
        @ @sn<this>.m_unordered_map [@<关键字>] = @<对应值>
    }

    方法 唯一性插入 <公开 类型 = 逻辑型 注释 = "插入一个键值对进哈希表中,如果所指定关键字已经存在,则返回失败." 返回值注释 = "所欲插入关键字如果不存在,则成功返回真,否则返回假." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应值 <类型 = 模板类型2 注释 = "提供关键字所对应的值">
    {
        @ @sn<this>.m_unordered_map.insert (std::pair <@dt<模板类型1>, @dt<模板类型2>> (@<关键字>, @<对应值>)).second
    }

    方法 取值 <公开 类型 = 模板类型2 注释 = "  返回所指定关键字在本哈希表中所对应的值,如果该关键字" 注释 = "不存在,将新建一个空值并将其插入哈希表中后返回." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ @sn<this>.m_unordered_map [@<关键字>]
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本哈希表中已有键值对成员的数目" @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_unordered_map.size ()
    }

    方法 是否存在 <公开 类型 = 逻辑型 注释 = "返回所指定的关键字是否已经存在" @禁止流程检查 = 真>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ return (m_unordered_map.find (@<关键字>) != m_unordered_map.end ());
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "删除所指定的键值对,返回是否存在所指定的关键字." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ @sn<this>.m_unordered_map.erase (@<关键字>) > 0
    }

    方法 清空 <公开 注释 = "清除本哈希表中的所有内容" @嵌入式方法 = "">
    {
        @ @sn<this>.m_unordered_map.clear ()
    }

    方法 交换 <公开 注释 = "交换两个哈希表中的数据" @嵌入式方法 = "">
    参数 所欲交换的哈希表 <类型 = 基本无序哈希表模板类>
    {
        @ @sn<this>.m_unordered_map.swap (@<所欲交换的哈希表>.m_unordered_map)
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本哈希表是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_unordered_map.empty ()
    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来正向枚举本哈希表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举关键字\"/\"取枚举值\"方法来获取当前所枚举到键值对的关键字及" 注释 = "其对应值."
            @嵌入式方法 = "name = iter\r\nhas_loop_body = true">
    {
        @ std::unordered_map<@dt<模板类型1>, @dt<模板类型2>>& @sn<rand_name0> = @sn<this>.m_unordered_map;
        @ for (std::unordered_map<@dt<模板类型1>, @dt<模板类型2>>::iterator _vmapitr_@dt<模板类型1>_@dt<模板类型2> = @sn<rand_name0>.begin (); _vmapitr_@dt<模板类型1>_@dt<模板类型2> != @sn<rand_name0>.end (); _vmapitr_@dt<模板类型1>_@dt<模板类型2>++)
    }

    方法 取枚举关键字 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的关键字,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近"
            注释 = "层\"枚举循环\"所枚举到键值对成员的关键字." @嵌入式方法 = "parent = \"iter\"">
    {
        @ _vmapitr_@dt<模板类型1>_@dt<模板类型2>->first
    }

    方法 取枚举值 <公开 类型 = 模板类型2 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的值,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近层"
            注释 = "\"枚举循环\"所枚举到键值对成员的值." @嵌入式方法 = "parent = \"iter\"">
    {
        @ _vmapitr_@dt<模板类型1>_@dt<模板类型2>->second
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "哈希表成员数: " + 到文本 (取成员数 ()) + "\r\n"
        枚举循环 ()
        {
            展示内容 = 展示内容 + "关键字: " + 取调试文本2 (最大展示数据尺寸, 取枚举关键字 ()) + "; 对应值: " + 取调试文本2 (最大展示数据尺寸, 取枚举值 ()) + "\r\n"
        }
    }

    # @ <include>
    # @ std::unordered_map<@dt<模板类型1>, @dt<模板类型2>> m_unordered_map;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_unordered_map = objCopyFrom.m_unordered_map; }
    # @ </include>
}

类 整数到整数无序哈希表 <公开 基础类 = 基本无序哈希表模板类 @文档 = "category = \"数据处理.无序哈希表\"" @模板实现类 = "整数, 整数">

类 整数到文本无序哈希表 <公开 基础类 = 基本无序哈希表模板类 @文档 = "category = \"数据处理.无序哈希表\"" @模板实现类 = "整数, 文本型">

类 "// 整数到对象无序哈希表" <公开 基础类 = 基本无序哈希表模板类 @文档 = "category = \"数据处理.无序哈希表\"" @模板实现类 = "整数, 对象类">

类 "// 整数到字节集无序哈希表" <公开 基础类 = 基本无序哈希表模板类 @文档 = "category = \"数据处理.无序哈希表\"" @模板实现类 = "整数, 字节集类">

类 对象无序哈希表模板类 <公开 基础类 = 扩展对象类 注释 = "无序哈希表处理类." 注释 = "  模板类型1: 关键字数据类型,仅支持\"文本型\",\"字节集类\"两种类型实现."
        @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<unordered_map>" @模板基础类 = 真 @输出到部件 = 假>
{
    方法 插入 <公开 注释 = "  插入一个键值对进哈希表中,如果所指定关键字已经存在,则其所对应的" 注释 = "先前值数据将被覆盖." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应对象 <类型 = 对象类 注释 = "  提供关键字所对应的火山类对象,类库将会创建一个新的同实际数据类型" 注释 = "对象然后将其内容复制进去后插入哈希表.">
    {
        @ @sn<this>.m_unordered_map [@<关键字>] = CVolWrapperObject (@<对应对象>)
    }

    方法 唯一性插入 <公开 类型 = 逻辑型 注释 = "插入一个键值对进哈希表中,如果所指定关键字已经存在,则返回失败." 返回值注释 = "所欲插入关键字如果不存在,则成功返回真,否则返回假." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应对象 <类型 = 对象类 注释 = "  提供关键字所对应的火山类对象,类库将会创建一个新的同实际数据类型" 注释 = "对象然后将其内容复制进去后插入哈希表.">
    {
        @ @sn<this>.m_unordered_map.insert (std::pair <@dt<模板类型1>, CVolWrapperObject> (@<关键字>, CVolWrapperObject (@<对应对象>))).second
    }

    方法 插入新对象 <公开 注释 = "  插入一个键值对进哈希表中,如果所指定关键字已经存在,则其所对应的" 注释 = "先前值数据将被覆盖." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应对象类 <类型 = 对象类 注释 = "  提供关键字所对应对象的火山类数据类型,类库将会创建一个新的该数据" 注释 = "类型对象然后将其插入哈希表." @需求类型 = 数据类型>
    {
        @ @sn<this>.m_unordered_map [@<关键字>] = CVolWrapperObject (VOL_RUNTIME_CLASS (@<对应对象类>))
    }

    方法 唯一性插入新对象 <公开 类型 = 逻辑型 注释 = "插入一个键值对进哈希表中,如果所指定关键字已经存在,则返回失败." 返回值注释 = "所欲插入关键字如果不存在,则成功返回真,否则返回假." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 对应对象类 <类型 = 对象类 注释 = "  提供关键字所对应对象的火山类数据类型,类库将会创建一个新的该数据" 注释 = "类型对象然后将其插入哈希表." @需求类型 = 数据类型>
    {
        @ @sn<this>.m_unordered_map.insert (std::pair <@dt<模板类型1>, CVolWrapperObject> (@<关键字>, CVolWrapperObject (VOL_RUNTIME_CLASS (@<对应对象类>)))).second
    }

    方法 取值 <公开 类型 = 对象类 注释 = "  返回所指定关键字在本哈希表中所对应类对象的参考,如果该关键字不存在,将新" 注释 = "建一个数据类型为\"对象类\"的空对象(其\"是否为空对象\"方法返回真)并将其插入哈"
            注释 = "希表中后返回." 注释 = "  注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:" 注释 = "    挂接事件 ((对象实际数据类型)哈希表1.取值 (关键字))"
            注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一" 注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的哈希表中保存的对象." @嵌入式方法 = ""
            @视窗.返回参考 = 真>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ @sn<this>.m_unordered_map [@<关键字>].GetVolObject (CVolObject ())
    }

    方法 取指定类型对象 <公开 注释 = "返回所指定关键字在本哈希表中所对应类对象的参考." 注释 = "注意: 如果所获取对象需要动态挂接事件,请按类似以下格式挂接:"
            注释 = "  挂接事件 (哈希表1.取指定类型对象 (关键字, 对象实际数据类型))" 注释 = "  因为火山视窗的赋值操作采用的是值复制方式,所以如果将返回对象赋值到另一"
            注释 = "个变量后再挂接这个变量的话,将导致事件挂接在一个复制出来的对象上而不是所" 注释 = "期望的数组中保存的对象." @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 所欲获取对象的类型 <类型 = 对象类 注释 = "  提供所欲获取对象的数据类型,如果在哈希表中不存在所指定的关键字或其对应的" 注释 = "火山对象实例不匹配该数据类型(为其或其继承类对象),将返回一个为该数据类型的"
            注释 = "空对象(其\"是否为空对象\"方法返回真)." @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)@sn<this>.GetVolObject (@<关键字>, VOL_RUNTIME_CLASS (@<所欲获取对象的类型>), @<所欲获取对象的类型> ())
    }

    方法 匹配指定类 <公开 类型 = 逻辑型 注释 = "  返回所指定关键字在本哈希表中是否存在及所对应类对象的" 注释 = "实际数据类型是否匹配所指定的类(为其或其继承类)." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    参数 所检查的类型 <类型 = 对象类 注释 = "提供所欲检查是否匹配的类数据类型" @需求类型 = 数据类型>
    {
        @ @sn<this>.IsVolObjectClass (@<关键字>, VOL_RUNTIME_CLASS (@<所检查的类型>))
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本哈希表中已有键值对成员的数目" @嵌入式方法 = "">
