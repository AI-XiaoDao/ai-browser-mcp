    方法 是否存在 <公开 类型 = 逻辑型 注释 = "返回所指定的关键字是否已经存在" @禁止流程检查 = 真>
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ return (m_unordered_map.find (@<关键字>) != m_unordered_map.end ());
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "删除所指定的键值对,返回是否存在所指定的关键字." @嵌入式方法 = "">
    参数 关键字 <类型 = 模板类型1 注释 = "提供所对应的关键字">
    {
        @ @sn<this>.m_unordered_map.erase (@<关键字>) > 0
    }

    方法 清空 <公开 注释 = "清除本哈希表中的所有内容" @嵌入式方法 = "">
    {
        @ @sn<this>.m_unordered_map.clear ()
    }

    方法 交换 <公开 注释 = "交换两个哈希表中的数据" @嵌入式方法 = "">
    参数 所欲交换的哈希表 <类型 = 对象无序哈希表模板类>
    {
        @ @sn<this>.m_unordered_map.swap (@<所欲交换的哈希表>.m_unordered_map)
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "返回本哈希表是否为空" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_unordered_map.empty ()
    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来正向枚举本哈希表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举关键字\"/\"取枚举值\"方法来获取当前所枚举到键值对的关键字及" 注释 = "其对应值."
            @嵌入式方法 = "name = iter\r\nhas_loop_body = true">
    {
        @ std::unordered_map<@dt<模板类型1>, CVolWrapperObject, @sn<current_class_def>::HashFunc>& @sn<rand_name0> = @sn<this>.m_unordered_map;
        @ for (std::unordered_map<@dt<模板类型1>, CVolWrapperObject, @sn<current_class_def>::HashFunc>::iterator _vobjmapitr_@dt<模板类型1> = @sn<rand_name0>.begin (); _vobjmapitr_@dt<模板类型1> != @sn<rand_name0>.end (); _vobjmapitr_@dt<模板类型1>++)
    }

    方法 取枚举关键字 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的关键字,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近"
            注释 = "层\"枚举循环\"所枚举到键值对成员的关键字." @嵌入式方法 = "parent = \"iter\"">
    {
        @ _vobjmapitr_@dt<模板类型1>->first
    }

    方法 取枚举值 <公开 类型 = 对象类 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的值,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近层"
            注释 = "\"枚举循环\"所枚举到键值对成员的值." @嵌入式方法 = "parent = \"iter\"" @视窗.返回参考 = 真>
    {
        @ _vobjmapitr_@dt<模板类型1>->second.GetVolObject (CVolObject ())
    }

    方法 取指定类型枚举值 <公开 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前所枚举到键值对" 注释 = "成员的值,如果有多层本类或本类继承类的\"枚举循环\"嵌套,本方法将返回最近层"
            注释 = "\"枚举循环\"所枚举到键值对成员的值." @嵌入式方法 = "parent = \"iter\"" @视窗.返回参考 = 真>
    参数 所欲获取对象的类型 <类型 = 对象类 注释 = "  提供所欲获取对象的数据类型,如果当前所枚举到的对象成员不匹配该数据类型(为其或其继承类" 注释 = "对象),将返回一个为该数据类型的空对象(其\"是否为空对象\"方法返回真)."
            @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ (@<所欲获取对象的类型>&)_vobjmapitr_@dt<模板类型1>->second.GetVolObject (VOL_RUNTIME_CLASS (@<所欲获取对象的类型>), @<所欲获取对象的类型> ())
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "对象哈希表成员数: " + 到文本 (取成员数 ()) + "\r\n"
        枚举循环 ()
        {
            展示内容 = 展示内容 + "关键字: " + 取调试文本2 (最大展示数据尺寸, 取枚举关键字 ()) + "; 对应值: " + 取调试文本2 (最大展示数据尺寸, 取枚举值 ()) + "\r\n"
        }
    }

