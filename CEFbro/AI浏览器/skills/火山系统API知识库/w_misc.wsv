    方法 排序 <公开 静态 注释 = "对数组中的所有成员进行排序">
    参数 当前对象 <类型 = 标准数组模板类 "">
    参数 从小到大排序 <类型 = 逻辑型 注释 = "为真表示从小到大进行排序,为假表示从大到小进行排序." @默认值 = 真>
    {
        @ if (@<从小到大排序>) {
        @    std::sort (@<当前对象>.begin(), @<当前对象>.end());
        @ } else {
        @    std::sort (@<当前对象>.begin(), @<当前对象>.end (), [](@dt<模板类型1> a, @dt<模板类型1> b) {
        @        return a > b;
        @    });
        @ }
    }

    方法 反转顺序 <公开 静态 注释 = "反转数组顺序,例如: 1,2,3 变 3,2,1">
    参数 当前对象 <类型 = 标准数组模板类 "">
    {
