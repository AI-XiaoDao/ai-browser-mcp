类 按键操作类 <公开 注释 = "提供常用按键操作功能" @文档 = "category = \"常用功能\"" @全局类 = 真>
{
    方法 取按键名称 <公开 静态 类型 = 文本型 注释 = "返回所指定按键代码对应的名称文本" @禁止流程检查 = 真>
    参数 按键代码值 <类型 = 整数 注释 = "为\"按键码\"类中的按键代码常量值,可以加入辅助键组合状态值以代表一个组合键.">
    {
        @ CVolString strBuf;
        @ return CVolString (GetKeyName ((UINT_P)@<按键代码值>, strBuf));
    }

    方法 按键码是否有效 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的按键代码是否对应有真实的按键." @嵌入式方法 = "">
    参数 按键代码值 <类型 = 整数 注释 = "为\"按键码\"类中的按键代码常量值,可以加入辅助键组合状态值以代表一个组合键.">
    {
        @ IsKeyCodeValid ((UINT_P)@<按键代码值>)
    }

    方法 取按键字符 <公开 静态 类型 = 字符 注释 = "如果所指定的按键代码对应有一个文本字符,将其返回,否则返回零字符." @嵌入式方法 = "">
    参数 按键代码值 <类型 = 整数 注释 = "为\"按键码\"类中的按键代码常量值,注意不能包含辅助键组合状态值.">
    {
        @ GetKeyAsciiChar ((UINT_P)@<按键代码值>)
    }

    方法 取锁定键状态 <公开 静态 类型 = 逻辑型 注释 = "返回指定锁定键的当前锁定状态" 返回值注释 = "返回真表示已经锁定,返回假表示未锁定." @嵌入式方法 = "">
    参数 欲检查锁定键 <类型 = 整数 注释 = "为\"按键码.CapsLock键\"/\"按键码.NumLock键\"/\"按键码.ScrollLock键\"三个常量值之一">
    {
        @ (::GetKeyState (@<欲检查锁定键>) & 1) != 0
    }

    方法 取键按下状态 <公开 静态 类型 = 逻辑型 注释 = "返回所指定键当前是否处于被按下状态" @嵌入式方法 = "">
    参数 欲检查键代码 <类型 = 整数 注释 = "为\"按键码\"类中的常量值之一">
    {
        @ ::GetKeyState ((INT)GetVirtualKeyFromKeyCode ((UINT_P)@<欲检查键代码>)) < 0
    }
}

# ===

类 系统热键类 <公开 注释 = "用作登记并处理Windows系统全局热键" @外部基础类 = "CVolRegHotKeyObject"
        @视窗.外部头文件 = "libs\\win_base\\include\\vol_reg_hot_key.h" @视窗.外部源文件 = "libs\\win_base\\cpp\\vol_reg_hot_key.cpp">
{
    方法 热键被按下 <公开 定义事件 类型 = 整数 注释 = "当所登记的热键按下后本事件被发送">

    方法 热键 <公开 属性写 注释 = "  设置所欲登记到Windows系统中的热键,后设置的热键将覆盖前面所设置的热键," 注释 = "如欲同时设置多个热键,请建立本类的多个对象实例."
            注释 = "  本类对象被释放时,所登记热键将被自动取消.">
    参数 按键代码值 <类型 = 整数 注释 = "为\"按键码\"类中的按键代码常量值,可以加入辅助键组合状态值以代表一个组合键." 注释 = "如果为\"按键码.空\",则取消先前所登记的热键.">
    {
        @ VolRegHotKey ((UINT_P)@<按键代码值>);
    }

    # @ <include>
    # @ virtual void OnHotKeyPressed () override  { @<热键被按下> (); }
    # @ </include>
}

