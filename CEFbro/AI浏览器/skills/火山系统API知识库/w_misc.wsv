类 多值哈希集模板类 <公开 注释 = "本模板类封装了C++标准列表模板类\"std::multiset\",提供了有序的哈希集数据存储支持." @别名类型 = 本地类 @模板基础类 = 真
        @视窗.外部头文件 = "<set>\r\n<algorithm>" @文档 = "category = \"数据处理.多值哈希集\"" @别名 = "std::multiset<模板类型1>">
{
    方法 初始化 <公开 静态 注释 = "从一个或多个值初始化当前对象" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 值 <类型 = 模板类型1 @可扩展 = "">
    {
        @ @<当前对象> = { @<值> }
    }

    方法 插入 <公开 静态 注释 = "插入一个值进哈希集中,允许记录重复的值." @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 所欲插入的值 <类型 = 模板类型1>
    {
        @ @<当前对象>.insert (@<所欲插入的值>)
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回本哈希集中已有成员的数目" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    {
        @ (INT)@<当前对象>.size ()
    }

    方法 是否存在 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的值是否已经存在" @禁止流程检查 = 真>
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 所欲检查的值 <类型 = 模板类型1>
    {
        @ return (@<当前对象>.find (@<所欲检查的值>) != @<当前对象>.end ());
    }

    方法 删除 <公开 静态 类型 = 整数 注释 = "删除所有满足条件的值,并返回删除的值数量." @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 所欲删除的值 <类型 = 模板类型1>
    {
        @ (INT)@<当前对象>.erase (@<所欲删除的值>) 
    }

    方法 清空 <公开 静态 注释 = "清除本哈希集中的所有内容" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    {
        @ @<当前对象>.clear ()
    }

    方法 交换 <公开 静态 注释 = "交换两个哈希集中的数据" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 所欲交换的哈希集 <类型 = 多值哈希集模板类>
    {
        @ @<当前对象>.swap (@<所欲交换的哈希集>)
    }

    方法 是否为空 <公开 静态 类型 = 逻辑型 注释 = "返回本哈希集是否为空" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    {
        @ (BOOL)@<当前对象>.empty ()
    }

    方法 取指定值数目 <公开 静态 类型 = 整数 注释 = "返回指定成员值在本哈希集中的记录数目" @嵌入式方法 = "">
    参数 当前对象 <类型 = 多值哈希集模板类>
    参数 欲检查的值 <类型 = 模板类型1>
    {
        @ (INT)@<当前对象>.count(@<欲检查的值>)
    }

    方法 枚举循环 <公开 静态 注释 = "  启动一个循环来枚举本列表中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值" 编辑时信息 = "DD547, 0, 0, 0"
            @嵌入式方法 = "name = std_multiset\r\nhas_loop_body = true">
    参数 当前对象 <类型 = 多值哈希集模板类 编辑时信息 = "DD547, 0, 0, 0">
    {
        @ for (const auto &__vol_std_multiset_value : @<当前对象>) 
    }

    方法 取枚举值 <公开 静态 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"语句的子语句体中使用,用作取回当前枚举到的成员值,如果有多层"
            注释 = "本类或本类继承类的\"枚举循环\"嵌套,本方法将返回所处最近层\"枚举循环\"的枚举成员值." @嵌入式方法 = "parent = \"std_multiset\"">
    {
        @ __vol_std_multiset_value
    }
}

