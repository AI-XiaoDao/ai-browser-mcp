类 标准文本类 <公开 注释 = "本类封装了C++标准文本类\"std::string\"." 注释 = "" @别名类型 = 本地类 @视窗.外部头文件 = "<string>" @文档 = "category = \"数据处理\""
        @别名 = "std::string">
{
    方法 创建 <公开 静态 类型 = 标准文本类 注释 = "基于所指定文本内容创建对应的utf-8编码标准文本数据" @嵌入式方法 = "">
    参数 文本数据 <类型 = 文本型>
    {
        @ std::string ((const char *)CU8String (@<文本数据>).GetText ())
    }

    方法 取文本 <公开 静态 类型 = 文本型 注释 = "取回本类对象中的文本内容." 注释 = "注意: 本方法假设本类对象中文本的编码格式为utf-8." @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准文本类>
    {
        @ @an<CVolString> (@<当前对象>.c_str ())
    }
}

