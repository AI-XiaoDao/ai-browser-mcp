类 驱动通信类 <公开 @文档 = "category = \"驱动通信\"" @视窗.外部头文件 = "winsvc.h" @全局类 = 真>
{
    方法 驱动通信 <公开 静态 类型 = 逻辑型 注释 = "与所指定驱动进行通信,返回是否成功." @禁止流程检查 = 真>
    参数 控制码 <类型 = 整数
            注释 = "控制码必须大于等于0x800,小于0x800为系统保留使用, 默认METHOD_BUFFERED缓冲区方式通信,必须与驱动里创建设备时设置的通信方式一致,通信方式不同则传入的缓冲区在驱动里的地址保存不同">
    参数 输入数据 <类型 = 字节集类 注释 = "提供输入数据" "">
    参数 输出缓冲区 <类型 = 变整数 注释 = "输出数据的缓冲区地址指针,确保内存地址有效,如果驱动未验证确保地址有效性,则会蓝屏.">
    参数 输出缓冲区尺寸 <类型 = 整数 注释 = "提供输出缓冲区的尺寸">
    参数 符号名 <类型 = 文本型
            注释 = "驱动里通过IoCreateSymbolicLink创建的符号名格式为 L\"\\\\??\\\\符号名\" , 应用层调用格式为 \"\\\\\\\\.\\\\符号名\"  符号名必须与驱动里创建的一致" "">
    {
        @ #define _MY_CTL_CODE(DeviceType, Function, Method, Access)  (((DeviceType) << 16) | ((Access) << 14) | ((Function) << 2) | (Method))
        @ const HANDLE hDevice = CreateFile (@<符号名>.GetText (), (GENERIC_READ | GENERIC_WRITE), 0, NULL, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
        @ if (hDevice == INVALID_HANDLE_VALUE)
        @     return FALSE;
        @ DWORD dwBytesReturned = 0;
        @ const BOOL blSucceeded = DeviceIoControl (hDevice, _MY_CTL_CODE (0x22, @<控制码>, 0, 0), (PVOID)@<输入数据>.GetPtr (),  (DWORD)@<输入数据>.GetSize (), (PVOID)@<输出缓冲区>, (DWORD)@<输出缓冲区尺寸>, &dwBytesReturned, NULL);
        @ CloseHandle (hDevice);
        @ return blSucceeded;
    }

    方法 加载驱动 <公开 静态 类型 = 逻辑型 注释 = "加载所指定的驱动,返回是否成功.">
    参数 驱动文件路径 <类型 = 文本型>
    参数 服务名 <类型 = 文本型 注释 = "用于服务数据库标记和创建服务,如果系统已经存在则会直接打开服务.">
    {
        变量 结果变量 <类型 = 逻辑型 值 = 假>
        @ const SC_HANDLE hSCManager = OpenSCManager (NULL, NULL, SC_MANAGER_CREATE_SERVICE);
        @ if (hSCManager!= NULL)
        @ {
        @     SC_HANDLE hService = CreateService (hSCManager, @<服务名>.GetText (), @<服务名>.GetText (), SERVICE_ALL_ACCESS, SERVICE_KERNEL_DRIVER, SERVICE_DEMAND_START, SERVICE_ERROR_IGNORE, @<驱动文件路径>.GetText(), NULL, NULL, NULL, NULL, NULL);
        @     if (hService == NULL && GetLastError () == ERROR_SERVICE_EXISTS)  // 服务已经存在?
        @         hService = OpenService (hSCManager, @<服务名>.GetText (), SERVICE_ALL_ACCESS);
        @     if (hService != NULL)
        @     {
        @         if (StartService (hService, 0, NULL) || GetLastError () == ERROR_SERVICE_ALREADY_RUNNING)
        @             @<结果变量> = TRUE;
        @         CloseServiceHandle (hService);
        @     }
        @     CloseServiceHandle (hSCManager);
        @ }
        返回 (结果变量)
    }

    方法 卸载驱动 <公开 静态 类型 = 逻辑型 注释 = "卸载所指定的驱动,返回是否成功.">
    参数 服务名 <类型 = 文本型 注释 = "必须与调用\"加载驱动\"方法时所传入的服务名一致">
    {
        变量 结果变量 <类型 = 逻辑型 值 = 假>
        @ const SC_HANDLE hSCManager = OpenSCManager (NULL, NULL, SC_MANAGER_CREATE_SERVICE);
        @ if (hSCManager!= NULL)
        @ {
        @     const SC_HANDLE hService = OpenService (hSCManager, @<服务名>.GetText (), SERVICE_ALL_ACCESS);  // 如果驱动已经运行,则服务已经存在,直接将其打开.
        @     if (hService != NULL)
        @     {
        @         SERVICE_STATUS ss;
        @         if (ControlService (hService, SERVICE_CONTROL_STOP, &ss))  // 停止运行
        @               @<结果变量> = TRUE;
        @          DeleteService (hService);
        @          CloseServiceHandle (hService);
        @     }
        @     CloseServiceHandle (hSCManager);
        @ }
        返回 (结果变量)
    }
}

