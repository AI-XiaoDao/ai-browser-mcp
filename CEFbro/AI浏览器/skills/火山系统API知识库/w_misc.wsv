类 指针操作类 <公开 注释 = "提供对于指针的相关操作支持." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本类中的方法." @文档 = "category = \"常用功能\"" @全局类 = 真>
{
    方法 取静态方法地址 <公开 静态 类型 = 变整数 注释 = "返回所指定类静态方法的地址指针值" @嵌入式方法 = "">
    参数 所欲处理的方法 <注释 = "指定欲获取其地址的类静态方法" @匹配方法 = "">
    {
        @ (INT_P)&@<所欲处理的方法>
    }

    方法 调用静态方法 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法地址 <类型 = 变整数 注释 = "提供所欲调用类静态方法的地址,该地址可以使用\"取静态方法地址\"方法获取." "">
    参数 返回值类型 <注释 = "  该返回值数据类型必须与被调用方法的返回值数据类型保持一致," 注释 = "否则将导致不可意料的问题." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    参数 调用参数表 <注释 = "  调用参数表的格式务必和被调用方法的参数表一致,否则将导致不" 注释 = "可意料的问题." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((@<返回值类型> (CALLBACK *) (@pdt_list<调用参数表>))@<所欲调用的方法地址>) (@<调用参数表>)
    }

    方法 调用无参数静态方法 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法地址 <类型 = 变整数 注释 = "提供所欲调用类静态方法的地址,该地址可以使用\"取静态方法地址\"方法获取.">
    参数 返回值类型 <注释 = "  该返回值数据类型必须与被调用方法的返回值数据类型保持一致," 注释 = "否则将导致不可意料的问题." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    {
        @ ((@<返回值类型> (CALLBACK *) ())@<所欲调用的方法地址>) ()
    }

    方法 调用无返回值静态方法 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法地址 <类型 = 变整数 注释 = "提供所欲调用类静态方法的地址,该地址可以使用\"取静态方法地址\"方法获取.">
    参数 调用参数表 <注释 = "调用参数表的格式务必和被调用方法的参数表一致,否则将导致不可意料的问题." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((void (CALLBACK *) (@pdt_list<调用参数表>))@<所欲调用的方法地址>) (@<调用参数表>)
    }

    方法 调用无参数无返回值静态方法 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法地址 <类型 = 变整数 注释 = "提供所欲调用类静态方法的地址,该地址可以使用\"取静态方法地址\"方法获取.">
    {
        @ ((void (CALLBACK *) ())@<所欲调用的方法地址>) ()
    }

    方法 调用静态方法2 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法 <注释 = "指定欲调用的类静态方法" @匹配方法 = "">
    参数 返回值类型 <注释 = "  该返回值数据类型必须与被调用方法的返回值数据类型保持一致," 注释 = "否则将导致不可意料的问题." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    参数 调用参数表 <注释 = "  调用参数表的格式务必和被调用方法的参数表一致,否则将导致不" 注释 = "可意料的问题." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((@<返回值类型> (CALLBACK *) (@pdt_list<调用参数表>))@<所欲调用的方法>) (@<调用参数表>)
    }

    方法 调用无参数静态方法2 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法 <注释 = "指定欲调用的类静态方法" @匹配方法 = "">
    参数 返回值类型 <注释 = "  该返回值数据类型必须与被调用方法的返回值数据类型保持一致," 注释 = "否则将导致不可意料的问题." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    {
        @ ((@<返回值类型> (CALLBACK *) ())@<所欲调用的方法>) ()
    }

    方法 调用无返回值静态方法2 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法 <注释 = "指定欲调用的类静态方法" @匹配方法 = "">
    参数 调用参数表 <注释 = "调用参数表的格式务必和被调用方法的参数表一致,否则将导致不可意料的问题." @可扩展 = "" @匹配类型 = 通用型>
    {
        @ ((void (CALLBACK *) (@pdt_list<调用参数表>))@<所欲调用的方法>) (@<调用参数表>)
    }

    方法 调用无参数无返回值静态方法2 <公开 静态 注释 = "调用所指定的类静态方法" @嵌入式方法 = "">
    参数 所欲调用的方法 <注释 = "指定欲调用的类静态方法" @匹配方法 = "">
    {
        @ ((void (CALLBACK *) ())@<所欲调用的方法>) ()
    }

    方法 取变整数尺寸 <公开 静态 类型 = 整数 注释 = "  变整数在编译64位程序时其字节数为8,编译32位程序时字节数为4," 注释 = "本方法可以根据当前实际情况返回对应的字节数." @嵌入式方法 = "">
    {
        @ (INT)sizeof (INT_P)
    }

    方法 取数据类型尺寸 <公开 静态 类型 = 整数 注释 = "返回指定数据类型所占用的存储空间尺寸(单位字节)" @嵌入式方法 = "">
    参数 所欲检查的数据类型 <@需求类型 = 数据类型 @匹配类型 = 通用型>
    {
        @ (INT)sizeof (@<所欲检查的数据类型>)
    }

    方法 取数据尺寸 <公开 静态 类型 = 整数 注释 = "返回指定数据所占用的存储空间尺寸(单位字节)" @嵌入式方法 = "">
    参数 所检查数据 <@匹配类型 = 通用型>
    {
        @ (INT)sizeof (@pdt<所检查数据>)
    }

    方法 取数组数据尺寸 <公开 静态 类型 = 整数 注释 = "返回所指定数组数据所占用的存储空间尺寸(单位字节)" @嵌入式方法 = "">
    参数 数组数据 <@匹配类型 = 通用型数组>
    {
        @ (INT)sizeof (@<数组数据>)
    }

    方法 取结构数据尺寸 <公开 静态 类型 = 整数 注释 = "返回所指定结构类中封装的C++结构数据部分尺寸" @嵌入式方法 = "">
    参数 结构类型 <类型 = 对象类 注释 = "注意: 所提供类的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错." @需求类型 = 数据类型>
    {
        @ (INT)sizeof (@<结构类型>::@an<S>)
    }

    方法 取结构数据 <公开 静态 类型 = 变整数 注释 = "获取指定结构类对象对应的C++结构数据" 返回值注释 = "返回保存到\"数据存储字节集\"参数中的C++结构数据地址指针" @嵌入式方法 = "">
    参数 结构类对象 <类型 = 对象类 注释 = "注意: 所提供结构类对象的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错.">
    参数 数据存储字节集 <类型 = 字节集类 注释 = "提供用作保存所获取结果数据的字节集对象,所获取的C++结构数据将保存到此字节集中.">
    {
        @ (INT_P)@<结构类对象>.GetStruct ((@pdt<结构类对象>::@an<S>*)@<数据存储字节集>.Alloc (sizeof (@pdt<结构类对象>::@an<S>)))
    }

    方法 取结构数据到地址 <公开 静态 注释 = "获取指定结构类对象对应的C++结构数据" @嵌入式方法 = "">
    参数 结构类对象 <类型 = 对象类 注释 = "注意: 所提供结构类对象的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错.">
    参数 所欲保存到的地址 <类型 = 变整数 注释 = "  提供用作保存所获取结果数据的地址指针,所获取的C++结构数据将保存到该地址处," 注释 = "因此必须确保该地址处具有足够的存储空间.">
    {
        @ @<结构类对象>.GetStruct ((@pdt<结构类对象>::@an<S>*)@<所欲保存到的地址>)
    }

    方法 加入结构数据 <公开 静态 类型 = 变整数 注释 = "获取指定结构类对象对应的C++结构数据并将其添加到指定字节集尾部" 返回值注释 = "返回添加到\"欲加入到字节集\"参数字节集尾部的C++结构数据地址指针" @嵌入式方法 = "">
    参数 结构类对象 <类型 = 对象类 注释 = "注意: 所提供结构类对象的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错.">
    参数 欲加入到字节集 <类型 = 字节集类 注释 = "提供用作保存所获取结果数据的字节集对象,所获取的C++结构数据将添加到此字节集尾部.">
    {
        @ (INT_P)@<结构类对象>.GetStruct ((@pdt<结构类对象>::@an<S>*)@<欲加入到字节集>.AddSpace (sizeof (@pdt<结构类对象>::@an<S>), TRUE))
    }

    方法 插入结构数据 <公开 静态 类型 = 变整数 注释 = "获取指定结构类对象对应的C++结构数据并将其插入到字节集的指定位置" 返回值注释 = "返回插入到\"欲插入到字节集\"参数字节集中的C++结构数据地址指针" @嵌入式方法 = "">
    参数 结构类对象 <类型 = 对象类 注释 = "注意: 所提供结构类对象的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错.">
    参数 欲插入到字节集 <类型 = 字节集类 注释 = "提供用作保存所获取结果数据的字节集对象,所获取的C++结构数据将插入到此字节集指定位置.">
    参数 插入偏移位置 <类型 = 整数 注释 = "提供具体的插入偏移位置">
    {
        @ (INT_P)@<结构类对象>.GetStruct ((@pdt<结构类对象>::@an<S>*)@<欲插入到字节集>.InsertSpace (@<插入偏移位置>, sizeof (@pdt<结构类对象>::@an<S>), TRUE))
    }

    方法 置结构数据 <公开 静态 注释 = "将所提供的C++结构数据填写进对应的结构类对象中" @嵌入式方法 = "">
    参数 结构类对象 <类型 = 对象类 注释 = "提供所欲填写的结构类对象." 注释 = "注意: 所提供结构类对象的类型必须为结构类(即定义有\"@视窗.结构类\"属性),否则将编译出错.">
    参数 结构数据 <类型 = 字节集类 注释 = "  提供欲填入\"结构类对象\"的C++结构数据,注意必须为\"取结构数据\"方法所返回或在其基础上修" 注释 = "改后的数据内容,尺寸必须等于\"取结构数据尺寸\"方法的返回值.">
    参数 起始偏移 <类型 = 整数 @默认值 = 0>
    {
        @ @<结构类对象>.SetStruct ((const @pdt<结构类对象>::@an<S>*)(@<结构数据>.GetPtr () + @<起始偏移>))
    }

    方法 取变量地址 <公开 静态 类型 = 变整数 注释 = "返回指定基本数据类型变量的内存空间地址指针值." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 变量数据 <@需求类型 = 可写入变量 @匹配类型 = 通用型>
    {
        @ (INT_P)&@<变量数据>
    }

    方法 取数组变量地址 <公开 静态 类型 = 变整数 注释 = "返回指定基本数据类型数组变量的内存空间地址指针值." 注释 = "除非必要且对指针概念有透彻的了解,不要使用本方法." @嵌入式方法 = "">
    参数 数组变量数据 <@需求类型 = 可写入变量 @匹配类型 = 通用型数组>
    {
        @ (INT_P)@<数组变量数据>
    }

    方法 内存复制 <公开 静态 注释 = "将一段所指定数据复制到指针所指向的内存空间." 注释 = "与\"内存移动\"方法不同的是: 复制的来源和目的空间地址不能相互重叠." "">
    参数 目的内存空间指针 <类型 = 变整数 注释 = "  指向所欲复制到的目的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲复制数据尺寸\"的内存空间可写.">
    参数 来源内存空间指针 <类型 = 变整数 注释 = "  指向所欲复制来源数据的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲复制数据尺寸\"的内存空间可读.">
    参数 欲复制数据尺寸 <类型 = 整数 注释 = "提供所欲复制来源数据的尺寸,必须大于等于0.">
    {
        @ ASSERT_R_ADR ((void*)@<来源内存空间指针>, @<欲复制数据尺寸>);
        @ ASSERT_RW_ADR ((void*)@<目的内存空间指针>, @<欲复制数据尺寸>);
        @ COPY_MEM (@<目的内存空间指针>, @<来源内存空间指针>, @<欲复制数据尺寸>);
    }

    方法 内存移动 <公开 静态 注释 = "将一段所指定数据复制到指针所指向的内存空间." 注释 = "与\"内存复制\"方法不同的是: 复制的来源和目的空间地址可以相互重叠." "">
    参数 目的内存空间指针 <类型 = 变整数 注释 = "  指向所欲复制到的目的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲复制数据尺寸\"的内存空间可写.">
    参数 来源内存空间指针 <类型 = 变整数 注释 = "  指向所欲复制来源数据的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲复制数据尺寸\"的内存空间可读.">
    参数 欲复制数据尺寸 <类型 = 整数 注释 = "提供所欲复制来源数据的尺寸,必须大于等于0.">
    {
        @ ASSERT_R_ADR ((void*)@<来源内存空间指针>, @<欲复制数据尺寸>);
        @ ASSERT_RW_ADR ((void*)@<目的内存空间指针>, @<欲复制数据尺寸>);
        @ MOVE_MEM (@<目的内存空间指针>, @<来源内存空间指针>, (size_t)@<欲复制数据尺寸>);
    }

    方法 内存清零 <公开 静态 注释 = "将一段所指定内存空间清零" "">
    参数 内存空间指针 <类型 = 变整数 注释 = "  指向所欲清零的目的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲清零空间尺寸\"的内存空间可写.">
    参数 欲清零空间尺寸 <类型 = 整数 注释 = "提供所欲清零空间的尺寸,必须大于等于0.">
    {
        @ ASSERT_RW_ADR ((void*)@<内存空间指针>, @<欲清零空间尺寸>);
        @ ZERO_MEM (@<内存空间指针>, @<欲清零空间尺寸>);
    }

    方法 内存填充 <公开 静态 注释 = "将一段所指定内存空间用所指定字节值填充" "">
    参数 内存空间指针 <类型 = 变整数 注释 = "  指向所欲填充的目的内存空间地址指针,必须确保从该指针地址" 注释 = "开始的尺寸为\"欲填充空间尺寸\"的内存空间可写.">
    参数 欲填充空间尺寸 <类型 = 整数 注释 = "提供所欲填充空间的尺寸,必须大于等于0.">
    参数 所欲填充值 <类型 = 字节 注释 = "提供具体的所欲填充的字节值">
    {
        @ ASSERT_RW_ADR ((void*)@<内存空间指针>, @<欲填充空间尺寸>);
        @ FILL_MEM (@<内存空间指针>, @<欲填充空间尺寸>, @<所欲填充值>);
    }

    方法 读指针处值 <公开 静态 注释 = "读取并返回指针所指向地址处的非文本基本数据类型值" @嵌入式方法 = "">
    参数 数据指针值 <类型 = 变整数 注释 = "提供所欲读取其中值的数据指针">
    参数 所欲读取值的类型 <注释 = "  提供所欲读取值的数据类型,必须确保指针所指向的尺寸为" 注释 = "此数据类型尺寸的内存空间可读." @需求类型 = 数据类型 @匹配类型 = 通用非文本基本型 @返回值类型 = 0>
    {
        @ READ_POINTER_NUMBER (@<数据指针值>, @<所欲读取值的类型>)
    }

    方法 写指针处值 <公开 静态 注释 = "设置指针所指向地址处的非文本基本数据类型值" @嵌入式方法 = "">
    参数 数据指针值 <类型 = 变整数 注释 = "提供所欲修改其中值的数据指针">
    参数 所欲写入的值 <注释 = "  提供具体所欲写入的值,必须确保指针所指向的尺寸为" 注释 = "此值数据类型尺寸的内存空间可写." @匹配类型 = 通用非文本基本型>
    {
        @ WRITE_POINTER_NUMBER (@<数据指针值>, @pdt<所欲写入的值>, @<所欲写入的值>)
    }

    方法 创建对象指针 <公开 静态 类型 = 变整数 注释 = "创建并返回指向所指定类型对象的指针." 注释 = "注意: 该指针不再使用时,必须使用\"销毁对象指针\"方法将其释放."
            注释 = "访问所返回的指针对象可以使用\"读指针处对象\"/\"写指针处对象\"方法" @嵌入式方法 = "">
    参数 所欲创建对象的类型 <类型 = 对象类 注释 = "提供所欲创建对象的数据类型" @需求类型 = 数据类型>
    {
        @ (INT_P)@<所欲创建对象的类型>::sCreateNewObject ()
    }

    方法 销毁对象指针 <公开 静态 注释 = "释放并销毁由\"创建对象指针\"所创建的对象指针" @嵌入式方法 = "">
    参数 对象指针 <类型 = 变整数 注释 = "该指针值必须为\"创建对象指针\"方法所返回">
    {
        @ ((CVolObject*)@<对象指针>)->SafeDestroy ()
    }

    方法 读指针处对象 <公开 静态 注释 = "读取并返回指针所指向地址处类对象实例的参考" @嵌入式方法 = "" @视窗.返回参考 = 真>
    参数 数据指针值 <类型 = 变整数 注释 = "提供所欲读取其中值的数据指针">
    参数 所欲读取对象的类型 <类型 = 对象类 @需求类型 = 数据类型 @返回值类型 = 0>
    {
        @ *(@<所欲读取对象的类型>*)@<数据指针值>
    }

    方法 写指针处对象 <公开 静态 类型 = 逻辑型 注释 = "  如果所提供欲复制对象的实际数据类型匹配\"对象指针值\"参数所指向对象的实际数" 注释 = "据类型(为该对象的实际数据类型或其继承类),则将所指定对象的内容复制到该对象中"
            注释 = "后返回真,否则失败返回假." @嵌入式方法 = "">
    参数 对象指针值 <类型 = 变整数 注释 = "提供所欲写入其中内容的对象指针">
    参数 所欲复制的对象 <类型 = 对象类 注释 = "  提供所欲复制到\"对象指针值\"参数所指向对象的内容对象,其实际数据类型需要与" 注释 = "\"对象指针值\"参数所指向对象的实际数据类型匹配(为该对象的实际数据类型或其继承类),"
            注释 = "否则本方法将失败返回假.">
    {
        @ ((CVolObject*)@<对象指针值>)->CheckCopyFrom (@<所欲复制的对象>)
    }

    方法 分配内存 <公开 静态 类型 = 变整数 注释 = "  分配一段所指定尺寸的内存,返回所分配内存的地址指针." 注释 = "  注意: 所返回的内存地址指针在不再使用后必须使用\"释放内存\""
            注释 = "方法将其释放(除非调用了\"重分配内存\"方法将其重新分配)." 返回值注释 = "成功返回所分配内存的地址指针,失败返回0." @嵌入式方法 = "">
    参数 所欲分配内存的尺寸 <类型 = 整数 注释 = "提供所欲分配内存的尺寸,必须大于0.">
    {
        @ (INT_P)malloc ((size_t)@<所欲分配内存的尺寸>)
    }

    方法 重分配内存 <公开 静态 类型 = 变整数 注释 = "重新分配先前所已分配内存的尺寸,返回重分配后的内存地址指针." 注释 = "注意: 先前内存中的数据内容将被保留,即使本方法返回了不同的地址指针."
            返回值注释 = "成功返回所重分配内存的地址指针,失败返回0." @嵌入式方法 = "">
    参数 先前所分配内存地址 <类型 = 变整数 注释 = "  提供先前调用\"分配内存\"或\"重分配内存\"方法所返回的内存地址指针,注" 注释 = "意所提供的先前内存地址指针在重分配后将不再有效(注意本方法也可能返"
            注释 = "回相同的地址指针值).">
    参数 所欲重分配内存的尺寸 <类型 = 整数 注释 = "提供所欲重新分配内存的尺寸,必须大于0.">
    {
        @ (INT_P)realloc ((void*)@<先前所分配内存地址>, (size_t)@<所欲重分配内存的尺寸>)
    }

    方法 释放内存 <公开 静态 注释 = "释放先前调用\"分配内存\"或\"重分配内存\"方法所分配的内存" @嵌入式方法 = "">
    参数 先前所分配内存地址 <类型 = 变整数 注释 = "  提供先前调用\"分配内存\"或\"重分配内存\"方法所返回的内存地址指针," 注释 = "注意所提供的内存地址指针在释放后将不再有效.">
    {
        @ free ((void*)@<先前所分配内存地址>)
    }
}

