类 打印机操作类 <公开 注释 = "提供打印机操作相关功能" @文档 = "category = \"打印机操作\"" @视窗.外部头文件.全局 = "<Winspool.h>" @全局类 = 真>
{
    方法 取默认打印机 <公开 静态 类型 = 文本型 注释 = "返回当前默认打印机的名称" @禁止流程检查 = 真>
    {
        @ TCHAR buf [1024];
        @ DWORD dwSize = NUM_ELEMENTS_OF (buf) - 1;
        @ CVolString strPrinterName;
        @ if (GetDefaultPrinter (buf, &dwSize))  strPrinterName.SetText (buf);
        @ return strPrinterName;
    }

    方法 置默认打印机 <公开 静态 类型 = 逻辑型 注释 = "设置当前默认打印机" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 欲设置打印机名称 <类型 = 文本型 注释 = "提供打印机的名称,如果是远程打印机,请按照\"\\\\远程主机名称\\\\打印机名称\"格式提供.">
    {
        @ SetDefaultPrinter (@<欲设置打印机名称>.GetText ())
    }

    方法 取打印机状态 <公开 静态 类型 = 打印机状态码 注释 = "获取所指定名称打印机的当前状态" 返回值注释 = "返回对应打印机状态码" @禁止流程检查 = 真>
    参数 打印机名称 <类型 = 文本型 注释 = "提供所欲获取打印机的名称,为空文本表示为默认打印机." @默认值 = "">
    {
        如果 (文本是否为空 (打印机名称))
        {
            打印机名称 = 取默认打印机 ()
        }
        @ HANDLE hPrinter;
        @ if (OpenPrinter((LPTSTR)@<打印机名称>.GetText (), (LPHANDLE)&hPrinter, NULL) == FALSE)  return -1;
        @ INT nRetCode = -1;
        @ DWORD dwSizeNeeded = 0;
        @ GetPrinter (hPrinter, 2, NULL, 0, &dwSizeNeeded);
        @ CVolMem memBuf;
        @ PRINTER_INFO_2* pPrinterInfo = (PRINTER_INFO_2*)memBuf.Alloc ((INT_P)(UINT_P)dwSizeNeeded);
        @ if (GetPrinter (hPrinter, 2, (LPBYTE)pPrinterInfo, dwSizeNeeded, &dwSizeNeeded))
        @     nRetCode = (INT)pPrinterInfo->Status;
        @ ClosePrinter (hPrinter);
        @ return nRetCode;
    }

    方法 取所有打印机 <公开 静态 类型 = 整数 注释 = "获取当前所有可用打印机名称" 返回值注释 = "返回所获取到的打印机名称数目">
    参数 打印机名称数组 <类型 = 文本数组类 注释 = "用作存储所获得的所有打印机名称">
    参数 是否包括网络打印机 <类型 = 逻辑型 注释 = "指定是否获取网络/远程打印机" @默认值 = 假>
    {
        打印机名称数组.删除所有成员 ()
        @ const DWORD dwFlags = (@<是否包括网络打印机> ? (PRINTER_ENUM_LOCAL | PRINTER_ENUM_CONNECTIONS /*PRINTER_ENUM_NETWORK | PRINTER_ENUM_REMOTE*/) : PRINTER_ENUM_LOCAL);
        @ DWORD dwSizeNeeded = 0, dwNumPrinters;
        @ EnumPrinters (dwFlags, NULL, 1, NULL, 0, &dwSizeNeeded, &dwNumPrinters);
        @ CVolMem memBuf;
        @ PRINTER_INFO_1* pPrinterInfo = (PRINTER_INFO_1*)memBuf.Alloc ((INT_P)(UINT_P)dwSizeNeeded);
        @ dwNumPrinters = 0;
        @ if (EnumPrinters (dwFlags, NULL, 1, (LPBYTE)pPrinterInfo, dwSizeNeeded, &dwSizeNeeded, &dwNumPrinters))
        @ {
        @     for (INT_P npIndex = 0; npIndex < (INT_P)(UINT_P)dwNumPrinters; npIndex++, pPrinterInfo++)
        @         @<打印机名称数组>.data ().Add (pPrinterInfo->pName);
        @ }
        返回 (打印机名称数组.取成员数 ())
    }
}

类 打印机状态码 <公开 注释 = "提供打印机的相关状态码值" @文档 = "category = \"打印机操作.辅助类\"" @常量类 = 整数>
{
    常量 失败 <公开 值 = -1 注释 = "获取打印机状态码失败">
    常量 正常 <公开 值 = 0>
    常量 忙碌 <公开 值 = @PRINTER_STATUS_BUSY>
    常量 门被打开 <公开 值 = @PRINTER_STATUS_DOOR_OPEN>
    常量 出错 <公开 值 = @PRINTER_STATUS_ERROR>
    常量 正在初始化 <公开 值 = @PRINTER_STATUS_INITIALIZING>
    常量 正在传输 <公开 值 = @PRINTER_STATUS_IO_ACTIVE>
    常量 需手动供纸 <公开 值 = @PRINTER_STATUS_MANUAL_FEED>
    常量 缺墨 <公开 值 = @PRINTER_STATUS_NO_TONER>
    常量 不可用 <公开 值 = @PRINTER_STATUS_NOT_AVAILABLE>
    常量 离线 <公开 值 = @PRINTER_STATUS_OFFLINE>
    常量 内存溢出 <公开 值 = @PRINTER_STATUS_OUT_OF_MEMORY>
    常量 输出纸盒已满 <公开 值 = @PRINTER_STATUS_OUTPUT_BIN_FULL>
    常量 无法打印当前页 <公开 值 = @PRINTER_STATUS_PAGE_PUNT>
    常量 卡纸 <公开 值 = @PRINTER_STATUS_PAPER_JAM>
    常量 缺纸 <公开 值 = @PRINTER_STATUS_PAPER_OUT>
    常量 纸张有问题 <公开 值 = @PRINTER_STATUS_PAPER_PROBLEM>
    常量 暂停 <公开 值 = @PRINTER_STATUS_PAUSED>
    常量 作业删除中 <公开 值 = @PRINTER_STATUS_PENDING_DELETION>
    常量 节能模式 <公开 值 = @PRINTER_STATUS_POWER_SAVE>
    常量 正在打印 <公开 值 = @PRINTER_STATUS_PRINTING>
    常量 正在处理作业 <公开 值 = @PRINTER_STATUS_PROCESSING>
    常量 未知 <公开 值 = @PRINTER_STATUS_SERVER_UNKNOWN>
    常量 少墨 <公开 值 = @PRINTER_STATUS_TONER_LOW>
    常量 需用户处理 <公开 值 = @PRINTER_STATUS_USER_INTERVENTION>
    常量 等待 <公开 值 = @PRINTER_STATUS_WAITING>
    常量 正在预热 <公开 值 = @PRINTER_STATUS_WARMING_UP>
}

