    方法 取文本注册项 <公开 静态 类型 = 文本型 注释 = "在 Windows 注册表中返回指定的文本类型注册表项值." 注释 = "如欲读取注册项默认值,请在项目名后加\'\\\\\'字符,如\"vol\\\\\"."
            @禁止流程检查 = 真>
    参数 根目录 <类型 = 注册表根目录类型>
    参数 全路径注册项名 <类型 = 文本型>
    参数 默认值 <类型 = 文本型 注释 = "如果指定的注册表项不存在,将返回此默认值文本." @默认值 = "">
    {
        @ @m<_VOL_REG_OPER_HEADER>
        @ return @<取文本注册项2> (@<根目录>, strPath, CVolString (szItemName), @<默认值>);
    }

    方法 取文本注册项2 <公开 静态 类型 = 文本型 注释 = "在 Windows 注册表中返回指定的文本类型注册表项值">
    参数 根目录 <类型 = 注册表根目录类型>
    参数 表项路径 <类型 = 文本型 注释 = "提供表项所处的注册表路径文本,路径分隔符为\'\\\\\'字符.">
    参数 表项名称 <类型 = 文本型 注释 = "提供表项的具体名称,如欲读取注册项默认值,请提供空文本.">
    参数 默认值 <类型 = 文本型 注释 = "如果指定的注册表项不存在,将返回此默认值文本." @默认值 = "">
    {
        变量 结果变量 <类型 = 文本型>
        结果变量 = 默认值
        @ HKEY hKey;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<根目录>, @<表项路径>.GetText (), 0, KEY_READ, &hKey) == ERROR_SUCCESS)
        @ {
        @     DWORD dwType, dwDataSize = 0;
        @     if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, &dwType, NULL, &dwDataSize) == ERROR_SUCCESS && (dwType == REG_SZ || dwType == REG_EXPAND_SZ))
        @     {
        @         CVolMem memBuf1, memBuf2;
        @         if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, NULL, memBuf1.Alloc ((INT_P)(UINT_P)(dwDataSize + sizeof (TCHAR)), TRUE), &dwDataSize) == ERROR_SUCCESS)
        @         {
        @             const TCHAR* ps = memBuf1.GetTextPtr ();
        @             if (dwType == REG_EXPAND_SZ)
        @             {
        @                 const INT_P npReqNumChars = (INT_P)(UINT_P)::ExpandEnvironmentStrings (ps, NULL, 0) + 1;
        @                 ::ExpandEnvironmentStrings (ps, (TCHAR*)memBuf2.Alloc ((npReqNumChars + 1) * (INT_P)sizeof (TCHAR), TRUE), (DWORD)npReqNumChars);
        @                 ps = memBuf2.GetTextPtr ();
        @             }
        @             @<结果变量>.SetText (ps);
        @         }
        @     }
        @     ::RegCloseKey (hKey);
        @ }
        返回 (结果变量)
    }

    方法 取数值注册项 <公开 静态 类型 = 整数 注释 = "在 Windows 注册表中返回指定的数值类型注册表项值." 注释 = "如欲读取注册项默认值,请在项目名后加\'\\\\\'字符,如\"vol\\\\\"." @禁止流程检查 = 真>
    参数 根目录 <类型 = 注册表根目录类型>
    参数 全路径注册项名 <类型 = 文本型>
    参数 默认值 <类型 = 整数 注释 = "如果指定的注册表项不存在,将返回此默认值." @默认值 = 0>
    {
        @ @m<_VOL_REG_OPER_HEADER>
        @ return @<取数值注册项2> (@<根目录>, strPath, CVolString (szItemName), @<默认值>);
    }

    方法 取数值注册项2 <公开 静态 类型 = 整数 注释 = "在 Windows 注册表中返回指定的数值类型注册表项值">
    参数 根目录 <类型 = 注册表根目录类型>
    参数 表项路径 <类型 = 文本型 注释 = "提供表项所处的注册表路径文本,路径分隔符为\'\\\\\'字符.">
    参数 表项名称 <类型 = 文本型 注释 = "提供表项的具体名称,如欲读取注册项默认值,请提供空文本.">
    参数 默认值 <类型 = 整数 注释 = "如果指定的注册表项不存在,将返回此默认值." @默认值 = 0>
    {
        变量 结果变量 <类型 = 整数>
        结果变量 = 默认值
        @ HKEY hKey;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<根目录>, @<表项路径>.GetText (), 0, KEY_READ, &hKey) == ERROR_SUCCESS)
        @ {
        @     DWORD dwType, dwDataSize = 0;
        @     if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, &dwType, NULL, &dwDataSize) == ERROR_SUCCESS && dwType == REG_DWORD && dwDataSize == sizeof (DWORD))
        @     {
        @         DWORD dw = 0;
        @         if (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, NULL, (BYTE*)&dw, &dwDataSize) == ERROR_SUCCESS)
        @             @<结果变量> = (INT)dw;
        @     }
        @     ::RegCloseKey (hKey);
        @ }
        返回 (结果变量)
    }

    方法 取字节集注册项 <公开 静态 类型 = 字节集类 注释 = "在 Windows 注册表中返回指定的字节集类型注册表项值." 注释 = "如欲读取注册项默认值,请在项目名后加\'\\\\\'字符,如\"vol\\\\\"."
            @禁止流程检查 = 真>
    参数 根目录 <类型 = 注册表根目录类型>
