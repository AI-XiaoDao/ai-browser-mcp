类 通用双端队列模板类 <公开 基础类 = 扩展对象类 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "通用双端队列类,用作基本类型填充." 注释 = "  模板类型1: 成员数据类型"
        @文档 = "category = \"数据处理.辅助类\"" @视窗.外部头文件 = "<deque>" @模板基础类 = 真 @输出到部件 = 假>
{
    方法 压入到首部 <公开 注释 = "在本队列的首部添加指定成员." @嵌入式方法 = "">
    参数 值 <类型 = 模板类型1 注释 = "提供所欲添加的值.">
    {
        @ @sn<this>.m_deque.push_front(@<值>)
    }

    方法 压入到尾部 <公开 注释 = "在本队列的尾部添加指定成员." @嵌入式方法 = "">
    参数 值 <类型 = 模板类型1 注释 = "提供所欲添加的值.">
    {
        @ @sn<this>.m_deque.push_back(@<值>)
    }

    方法 插入 <公开 类型 = 整数 注释 = "插入指定成员到本队列中指定索引位置." 返回值注释 = "返回所插入成员在本队列中的索引位置(如插入个数大于1则返回首个插入成员的位置)." @禁止流程检查 = 真>
    参数 插入索引位置 <类型 = 整数 注释 = "提供所欲插入的成员索引位置,必须大于等于0且小于等于本队列的成员数目.">
    参数 所欲插入的成员 <类型 = 模板类型1 注释 = "提供所欲插入的成员值.">
    参数 所欲插入的个数 <类型 = 整数 注释 = "本次所欲插入该成员的个数." @默认值 = 1>
    {
        @ std::deque<@dt<模板类型1>>::iterator retPos = this->m_deque.insert(this->m_deque.begin() + @<插入索引位置>, @<所欲插入的个数>, @<所欲插入的成员>);
        @ return (INT)(retPos - this->m_deque.begin());
    }

    方法 删除 <公开 注释 = "删除本队列中指定索引位置处的成员." @嵌入式方法 = "">
    参数 删除索引位置 <类型 = 整数 注释 = "提供所欲删除的成员索引位置,必须大于等于0且小于等于本队列的成员数目.">
    {
        @ std::deque<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_deque;
        @ @sn<rand_name0>.erase(@sn<rand_name0>.begin() + @<删除索引位置>)
    }

    方法 弹出首部 <公开 注释 = "删除本队列中第一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_deque.pop_front()
    }

    方法 弹出尾部 <公开 注释 = "删除本队列中最后一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_deque.pop_back()
    }

    方法 是否为空 <公开 类型 = 逻辑型 注释 = "判断本队列是否为空队列." @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.m_deque.empty()
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "返回本队列中已有成员的数目." @嵌入式方法 = "">
    {
        @ (INT)@sn<this>.m_deque.size ()
    }

    方法 取首成员 <公开 类型 = 模板类型1 注释 = "取出本队列中的第一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_deque.front()
    }

    方法 取尾成员 <公开 类型 = 模板类型1 注释 = "取出本队列中最末尾的一个成员." @嵌入式方法 = "">
    {
        @ @sn<this>.m_deque.back()
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "取出本队列中的指定索引位置处的成员." @嵌入式方法 = "">
    参数 索引位置 <类型 = 整数 注释 = "提供所欲获取成员在本队列中所处的索引位置.">
    {
        @ @sn<this>.m_deque[@<索引位置>]
    }

    方法 交换 <公开 注释 = "交换两个队列中的数据." @嵌入式方法 = "">
    参数 所欲交换的队列 <类型 = 通用双端队列模板类>
    {
        @ @sn<this>.m_deque.swap (@<所欲交换的队列>.m_deque)
    }

    方法 枚举循环 <公开 注释 = "  启动一个循环来正向枚举本队列中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = iter\r\nhas_loop_body = true">
    {
        @ std::deque<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_deque;
        @ for (std::deque<@dt<模板类型1>>::iterator _vsetitr_@dt<模板类型1> = @sn<rand_name0>.begin (); _vsetitr_@dt<模板类型1> != @sn<rand_name0>.end (); _vsetitr_@dt<模板类型1>++)
    }

    方法 逆向枚举循环 <公开 注释 = "  启动一个循环来逆向枚举本队列中的每一个成员,在循环中可以调用" 注释 = "\"取枚举值\"方法来获取当前所枚举到的成员值."
            @嵌入式方法 = "name = r_iter\r\nhas_loop_body = true">
    {
        @ std::deque<@dt<模板类型1>>& @sn<rand_name0> = @sn<this>.m_deque;
        @ for (std::deque<@dt<模板类型1>>::reverse_iterator _vsetitr_@dt<模板类型1> = @sn<rand_name0>.rbegin (); _vsetitr_@dt<模板类型1> != @sn<rand_name0>.rend (); _vsetitr_@dt<模板类型1>++)
    }

    方法 取枚举值 <公开 类型 = 模板类型1 注释 = "  只能在本类的\"枚举循环\"/\"逆向枚举循环\"语句的子语句体中使用,用作取回当前所枚举到的成员值,"
            注释 = "如果有多层本类或本类继承类的\"枚举循环\"/\"逆向枚举循环\"嵌套,本方法将返回最近层\"枚举循环\"/" 注释 = "\"逆向枚举循环\"所枚举到的成员值."
            @嵌入式方法 = "parent = \"iter, r_iter\"">
    {
        @ *_vsetitr_@dt<模板类型1>
    }

    方法 清空 <公开 注释 = "清除本队列中的所有成员内容" @嵌入式方法 = "">
    {
        @ @sn<this>.m_deque.clear ()
    }

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = "双端队列成员数: " + 到文本 (取成员数 ()) + "\r\n"
        枚举循环 ()
        {
            展示内容 = 展示内容 + 取调试文本2 (最大展示数据尺寸, 取枚举值 ()) + "\r\n"
        }
    }

    # @ <include>
    # @ std::deque<@dt<模板类型1>> m_deque;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_deque = objCopyFrom.m_deque; }
    # @ </include>
}

