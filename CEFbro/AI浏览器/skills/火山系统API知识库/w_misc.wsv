类 程序调试类 <公开 @文档 = "category = \"程序调试\"" @全局类 = 真>
{
    方法 取源文件名 <公开 静态 类型 = 文本型 注释 = "返回当前语句所处源文件的名称" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_source_file>)
    }

    方法 取源行号 <公开 静态 类型 = 文本型 注释 = "返回当前语句在所处源文件中的行号位置" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_source_line>)
    }

    方法 取源包名 <公开 静态 类型 = 文本型 注释 = "返回当前语句所处包的名称" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_source_package>)
    }

    方法 取源类名 <公开 静态 类型 = 文本型 注释 = "返回当前语句所处类的名称" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_source_class>)
    }

    方法 取源方法名 <公开 静态 类型 = 文本型 注释 = "返回当前语句所处方法的名称" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_source_method>)
    }

    方法 取当前语句位置 <公开 静态 类型 = 文本型 注释 = "返回当前语句的详细源代码位置文本,文本格式为: <所处源文件名>, 所处源文件行号, 所处包名.所处类名, 所处方法名" @嵌入式方法 = "">
    {
        @ _CT (@sn<current_statment>)
    }

    方法 调试输出当前语句位置 <公开 静态 注释 = "向系统调试器内输出当前语句的位置信息" @嵌入式方法 = "">
    {
        @ _DEBUG_STATMENT (DebugTrace (FALSE, 0, 0, _T_PMT_VOL_STRING, _T (@sn<current_statment>)))
    }

    方法 调试输出 <公开 静态 注释 = "向系统调试器内输出所指定数据的调试用文本并自动换行" 编辑时信息 = "B554A, 0, 0, 0"
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 所欲输出的数据 <注释 = "  支持提供对象数据(譬如字节集类,所有基本数据封装类,以及所有以\"扩展对象类\"" 注释 = "为直接/间接基础类并覆盖了其\"取展示内容\"方法的类对象."
            注释 = "  每个所输出数据后附加一个\", \"文本用作分隔,输出行的最后添加一个换行符." 编辑时信息 = "B554A, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ _DEBUG_STATMENT (DebugTrace (FALSE, 0, 0, _T (@sn<pm_types>), @<所欲输出的数据>))
    }

