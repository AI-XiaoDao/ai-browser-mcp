    }

    方法 注册项是否存在2 <公开 静态 类型 = 逻辑型 注释 = "返回所指定注册表项是否存在">
    参数 根目录 <类型 = 注册表根目录类型>
    参数 表项路径 <类型 = 文本型 注释 = "提供表项所处的注册表路径文本,路径分隔符为\'\\\\\'字符.">
    参数 表项名称 <类型 = 文本型 注释 = "提供表项的具体名称,如欲检查注册项是否具有默认值,请提供空文本.">
    {
        @ HKEY hKey;
        @ if (::RegOpenKeyEx ((HKEY)(UINT_P)@<根目录>, @<表项路径>.GetText (), 0, KEY_READ, &hKey) == ERROR_SUCCESS)
        @ {
        @     DWORD dwType, dwDataSize;
        @     const BOOL_P blpExist = (::RegQueryValueEx (hKey, @<表项名称>.GetText (), NULL, &dwType, NULL, &dwDataSize) == ERROR_SUCCESS);
        @     ::RegCloseKey (hKey);
        @     return (BOOL)blpExist;
        @ }
        返回 (假)
    }

    方法 取默认底色 <公开 静态 类型 = 整数 注释 = "返回Windows系统的默认窗口背景颜色" @嵌入式方法 = "">
    {
        @ (INT)::GetSysColor (COLOR_BTNFACE)
    }

    方法 快照 <公开 静态 类型 = 逻辑型 注释 = "取回指定窗口或屏幕上所有现有显示内容的图片对象." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所取回图片 <类型 = 位图对象类 注释 = "所取得的现有显示内容将被填入到此对象中">
    参数 窗口句柄 <类型 = 变整数 注释 = "提供欲捕获其显示内容的窗口句柄,如果为0则为捕获屏幕显示内容." @默认值 = 0>
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "所取得图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如"
            注释 = "果大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "所取得图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如"
            注释 = "果大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ return @<所取回图片.置位图句柄值> ((INT_P)(@<窗口句柄> == 0 ? CatchScreenBitmap (@<输出宽度>, @<输出高度>) : CatchWindowBitmap ((HWND)@<窗口句柄>, @<输出宽度>, @<输出高度>)), TRUE);
    }

    方法 读配置项 <公开 静态 类型 = 文本型 注释 = "读取并返回所指定配置文件中指定项目的文本内容">
    参数 配置文件名 <类型 = 文本型 注释 = "指定配置文件的名称,通常以\"ini\"作为文件名后缀.">
    参数 节名称 <类型 = 文本型 注释 = "指定欲读入配置项所处节的名称">
    参数 配置项名称 <类型 = 文本型 注释 = "指定欲读入配置项在其节中的名称">
    参数 默认值 <类型 = 文本型 注释 = "如果所指定配置项不存在,将返回此默认值文本." @默认值 = "">
    {
        变量 结果变量 <类型 = 文本型>
        如果 (文本是否为空 (配置文件名) == 假 && 文本是否为空 (节名称) == 假 && 文本是否为空 (配置项名称) == 假)
        {
            @ TCHAR buf [10240];
            @ buf [0] = '\0';
            @ GetPrivateProfileString (@<节名称>.GetText (), @<配置项名称>.GetText (), @<默认值>.GetText (), buf, NUM_ELEMENTS_OF (buf),  @<配置文件名>.GetText ());
            @ @<结果变量>.SetText (buf);
        }
        返回 (结果变量)
    }

    方法 写配置项 <公开 静态 类型 = 逻辑型 注释 = "  将指定文本内容写入指定配置项中或者删除指定的配置项或节," 注释 = "如果指定配置文件不存在,将会自动创建." 返回值注释 = "返回是否成功" @禁止流程检查 = 真>
    参数 配置文件名 <类型 = 文本型 注释 = "指定配置文件的名称,通常以\"ini\"作为文件名后缀.">
    参数 节名称 <类型 = 文本型 注释 = "指定欲写入配置项所处节的名称">
    参数 配置项名称 <类型 = 文本型 注释 = "指定欲写入配置项在其节中的名称.如果为空对象,则删除指定节及其下的所有配置项." @默认值 = 空对象>
    参数 欲写入值 <类型 = 文本型 注释 = "指定欲写入到指定配置项中的文本,如果为空对象,则删除所指定配置项." @默认值 = 空对象>
    {
        @ return WritePrivateProfileString (@<节名称>.GetText (), (@<配置项名称>.IsNullObject () ? NULL : @<配置项名称>.GetText ()), (@<欲写入值>.IsNullObject () ? NULL : @<欲写入值>.GetText ()), @<配置文件名>.GetText ());
    }

    方法 取配置节名 <公开 静态 类型 = 文本数组类 注释 = "返回指定配置文件中所有已有节名的文本数组">
    参数 配置文件名 <类型 = 文本型 注释 = "指定配置文件的名称,通常以\"ini\"作为文件名后缀.">
    {
        变量 结果变量 <类型 = 文本数组类>
        @ TCHAR buf [256 * 1024];
        @ buf [0] = '\0';
        @ GetPrivateProfileSectionNames (buf, NUM_ELEMENTS_OF (buf), @<配置文件名>.GetText ());
        @ const TCHAR* ps = buf;
        @ while (*ps != '\0')
        @ {
        @     @<结果变量>.data ().Add (ps);
        @     ps += _tcslen (ps) + 1;
        @ }
        返回 (结果变量)
    }

    方法 取操作系统类型 <公开 静态 类型 = 整数 注释 = "返回当前Windows操作系统的平台类型" 返回值注释 = "返回值为以下值之一:" 返回值注释 = "  0.未知;" 返回值注释 = "  1.Windows 32S;"
            返回值注释 = "  2.Windows 9X (包含Win95/Win98/WinME等);" 返回值注释 = "  3.Windows NT (包含WinNT、Win2000、WinXP等);"
            返回值注释 = "  5. Windows 10;" 返回值注释 = "  6. Windows Server 2016 Technical Preview;" 返回值注释 = "  7. Windows 8.1;"
            返回值注释 = "  8. Windows Server 2012 R2;" 返回值注释 = "  9. Windows 8;" 返回值注释 = "  10. Windows Server 2012;"
            返回值注释 = "  11. Windows 7;" 返回值注释 = "  12. Windows Server 2008 R2;" 返回值注释 = "  13. Windows Server 2008;"
            返回值注释 = "  14. Windows Vista" @禁止流程检查 = 真 @视窗.外部清单文件 = "res\\GetOSVersion.manifest">
    {
        @ #define M_VER_NT_WORKSTATION 1
        @ OSVERSIONINFOEX inf;
        @ inf.dwOSVersionInfoSize = sizeof (inf);
        @ GetVersionEx ((LPOSVERSIONINFO)&inf);
        @ return (
        @     (inf.dwMajorVersion == 10 && inf.dwMinorVersion == 0 && inf.wProductType == M_VER_NT_WORKSTATION) ? 5 :  // win 10
        @     (inf.dwMajorVersion == 10 && inf.dwMinorVersion == 0 && inf.wProductType != M_VER_NT_WORKSTATION) ? 6 :  // Windows Server 2016 Technical Preview
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 3 && inf.wProductType == M_VER_NT_WORKSTATION) ? 7 :  // win 8.1
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 3 && inf.wProductType != M_VER_NT_WORKSTATION) ? 8 :  // Windows Server 2012 R2
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 2 && inf.wProductType == M_VER_NT_WORKSTATION) ? 9 :  // Windows 8
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 2 && inf.wProductType != M_VER_NT_WORKSTATION) ? 10 :  // Windows Server 2012
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 1 && inf.wProductType == M_VER_NT_WORKSTATION) ? 11 :  // Windows 7
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 1 && inf.wProductType != M_VER_NT_WORKSTATION) ? 12 :  // Windows Server 2008 R2
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 0 && inf.wProductType != M_VER_NT_WORKSTATION) ? 13 :  // Windows Server 2008
        @     (inf.dwMajorVersion == 6 && inf.dwMinorVersion == 0 && inf.wProductType == M_VER_NT_WORKSTATION) ? 14 :  // Windows Vista
        @     inf.dwPlatformId == VER_PLATFORM_WIN32s ? 1 : inf.dwPlatformId == VER_PLATFORM_WIN32_WINDOWS ? 2 : inf.dwPlatformId == VER_PLATFORM_WIN32_NT ? 3 : 0);
    }

    方法 取最后错误 <公开 静态 类型 = 整数 注释 = "调用操作系统的GetLastError函数,返回该API函数被调用后的返回值." @嵌入式方法 = "">
    {
        @ (INT)::GetLastError ()
    }

    方法 取可执行文件位数 <公开 静态 类型 = 可执行文件位数 注释 = "返回所指定可执行文件运行时需求的CPU位数" 返回值注释 = "无法识别或所指定文件读取失败将返回\"可执行文件位数.未知\"" @嵌入式方法 = "">
    参数 文件名 <类型 = 文本型 注释 = "提供所欲检查的可执行文件的名称">
    {
        @ (INT)GetImageFileMachineBits (@<文件名>.GetText ())
    }

    方法 取可执行文件设备类型 <公开 静态 类型 = 整数 注释 = "  返回所指定可执行文件运行时需求的设备类型,具体可能返回值参见Windows SDK"
            注释 = "的\"winnt.h\"头文件中定义的\"IMAGE_FILE_MACHINE_xxx\"系列宏值." @嵌入式方法 = "">
    参数 文件名 <类型 = 文本型 注释 = "提供所欲检查的可执行文件的名称">
    {
        @ (INT)GetImageFileMachineType (@<文件名>.GetText ())
    }

    方法 创建快捷方式 <公开 静态 类型 = 逻辑型 注释 = "建立指定的快捷方式文件,返回是否成功." @禁止流程检查 = 真>
    参数 快捷方式文件名 <类型 = 文本型 注释 = "如果文件名不包含后缀,将自动加上\".lnk\"后缀名.">
    参数 指向文件路径 <类型 = 文本型 注释 = "提供快捷方式所指向文件的全路径名">
    参数 备注信息 <类型 = 文本型 注释 = "提供对应此快捷方式的描述文本信息" @默认值 = "">
    参数 命令行文本 <类型 = 文本型 注释 = "提供启动快捷方式指向文件时附加的命令行文本" @默认值 = "">
    参数 工作目录 <类型 = 文本型 注释 = "提供启动快捷方式指向文件时所需预置的工作目录" @默认值 = "">
    {
        @ BOOL blSucceeded = FALSE;
        @ IShellLink* piShellLink;
        @ if (SUCCEEDED (CoCreateInstance (CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER, IID_IShellLink, (void**)&piShellLink)))
        @ {
        @     IPersistFile* piPersistFile;
        @     if (SUCCEEDED (piShellLink->QueryInterface (IID_IPersistFile, (void**)&piPersistFile)))
        @     {
        @         piShellLink->SetPath (@<指向文件路径>.GetText ());
        @         piShellLink->SetShowCmd (SW_SHOW);
        @         if (@<备注信息>.IsEmpty () == FALSE)  piShellLink->SetDescription (@<备注信息>.GetText ());
        @         if (@<命令行文本>.IsEmpty () == FALSE)  piShellLink->SetArguments (@<命令行文本>.GetText ());
        @         if (@<工作目录>.IsEmpty () == FALSE)  piShellLink->SetWorkingDirectory (@<工作目录>.GetText ());
        @         blSucceeded = SUCCEEDED (piPersistFile->Save ((_tcschr (@<快捷方式文件名>.GetText (), '.') != NULL ? @<快捷方式文件名>.GetText () : (@<快捷方式文件名> + _T (".lnk")).GetText ()), TRUE));
        @         piPersistFile->Release ();
        @     }
        @     piShellLink->Release ();
        @ }
        @ return blSucceeded;
    }

    方法 查询快捷方式 <公开 静态 类型 = 文本型 注释 = "  从指定快捷方式文件中获取该快捷方式所指向的文件路径名," 注释 = "如果该文件不是快捷方式文件或执行失败则返回空文本." "">
    参数 快捷方式文件名 <类型 = 文本型 注释 = "提供所欲查询的快捷方式文件名">
    {
        变量 结果变量 <类型 = 文本型>
        @ SHFILEINFO info;
        @ if (SHGetFileInfo (@<快捷方式文件名>.GetText (), 0, &info, sizeof (info), SHGFI_ATTRIBUTES) != 0 && (info.dwAttributes & SFGAO_LINK) != 0)
        @ {
        @     IShellLink* piShellLink;
        @     if (SUCCEEDED (CoCreateInstance (CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER, IID_IShellLink, (void**)&piShellLink)))
        @     {
        @         IPersistFile* piPersistFile;
        @         if (SUCCEEDED (piShellLink->QueryInterface (IID_IPersistFile, (void**)&piPersistFile)))
        @         {
        @             if (SUCCEEDED (piPersistFile->Load (@<快捷方式文件名>.GetText (), STGM_READ)))
        @             {
        @                 TCHAR  path [MAX_PATH];
        @                 path [0] = '\0';
        @                 if (SUCCEEDED (piShellLink->GetPath (path, MAX_PATH, NULL, 0)))
        @                     @<结果变量>.SetText (path);
        @             }
        @             piPersistFile->Release ();
        @         }
        @         piShellLink->Release ();
        @     }
        @ }
        返回 (结果变量)
    }

    方法 取特定目录 <公开 静态 类型 = 文本型 注释 = "返回指定的Windows系统特定目录,所返回目录名均以\'\\\\\'路径字符结束,如失败返回空文本.">
    参数 所欲获取目录类型 <类型 = 特定目录类型 注释 = "提供所欲获取特定目录的类型">
    {
        变量 结果变量 <类型 = 文本型>
        @ TCHAR path [MAX_PATH];
        @ path [0] = '\0';
        @ BOOL_P blpSucceeded = FALSE;
        @ const INT_P npDirType = @<所欲获取目录类型>;
        @ if (npDirType >= 1 && npDirType <= 8)
        @     blpSucceeded = SHGetSpecialFolderPath (NULL, path, (npDirType == 1 ? CSIDL_PERSONAL : npDirType == 2 ? CSIDL_FAVORITES : npDirType == 3 ? CSIDL_DESKTOPDIRECTORY :
        @             npDirType == 4 ? CSIDL_FONTS : npDirType == 5 ? CSIDL_STARTMENU : npDirType == 6 ? CSIDL_PROGRAMS : npDirType == 7 ? CSIDL_STARTUP : CSIDL_APPDATA), FALSE);
        @ else if (npDirType == 9)
        @     blpSucceeded = (GetWindowsDirectory (path, NUM_ELEMENTS_OF (path)) > 0);
        @ else if (npDirType == 10)
        @     blpSucceeded = (GetSystemDirectory (path, NUM_ELEMENTS_OF (path)) > 0);
        @ else if (npDirType == 11)
        @     blpSucceeded = (GetTempPath (NUM_ELEMENTS_OF (path), path) > 0);
        @ if (blpSucceeded)
        @ {
        @     @<结果变量>.SetText (path);
        @     @<结果变量>.CheckAddPathChar ();
        @ }
        返回 (结果变量)
    }

    方法 取特定目录2 <公开 静态 类型 = 文本型 注释 = "返回指定的Windows系统特定目录,所返回目录名均以\'\\\\\'路径字符结束,如失败返回空文本.">
    参数 所欲获取目录类型 <类型 = 特定目录类型2 注释 = "提供所欲获取特定目录的类型">
    {
        变量 结果变量 <类型 = 文本型>
        @ TCHAR path [MAX_PATH];
        @ path [0] = '\0';
        @ if (SHGetSpecialFolderPath (NULL, path, @<所欲获取目录类型>, FALSE))
        @ {
        @     @<结果变量>.SetText (path);
        @     @<结果变量>.CheckAddPathChar ();
        @ }
        返回 (结果变量)
    }

    方法 关闭系统 <公开 静态 类型 = 逻辑型 注释 = "可以执行关机/重启/注销等Windows系统操作." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 关闭方式 <类型 = 系统关闭方式>
    参数 是否强制执行 <类型 = 逻辑型 注释 = "是否不等待当前正在运行的所有软件正常结束而立即执行指定的操作" @默认值 = 假>
    {
        @ (BOOL)::ExitWindowSystem (@<关闭方式>, @<是否强制执行>)
    }

    方法 取系统界面缩放比例 <公开 静态 类型 = 小数 注释 = "返回所指定显示器在Windows系统中设置的界面缩放比例(DPI)" @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "  如果窗口句柄不为0,将返回该窗口当前所处显示器的DPI," 注释 = "否则将返回桌面窗口所处显示器的DPI." @默认值 = 0>
    {
        @ GetMoniterDPI ((HWND)@<窗口句柄>)
    }

    方法 注册文件关联 <公开 静态 注释 = "将所指定后缀类型的文件注册关联到所指定的EXE文件" @嵌入式方法 = "">
    参数 欲关联的应用程序 <类型 = 文本型 注释 = "提供欲关联的应用程序文件名(例如: \"C:\\MyApp\\MyApp.exe\"),为空文本表示使用当前程序.">
    参数 欲注册的扩展名 <类型 = 文本型 注释 = "提供欲注册文件的扩展名(例如: \".txt\"),需要以句点开始,不能为空文本.">
    参数 欲注册的键值 <类型 = 文本型 注释 = "提供欲注册文件的扩展名在注册表中的对应键值(例如: \"txtfile\"),不能为空文本.">
    参数 图标所处文件名 <类型 = 文本型 注释 = "提供被注册文件类型图标所处的文件名,为空文本表示使用当前程序.">
    参数 图标索引位置 <类型 = 整数 注释 = "提供图标在\"图标所处文件名\"所指定文件的图标资源中的索引位置,为小于-1的负值表示为ID,不能等于-1.">
    参数 文件类型描述 <类型 = 文本型 注释 = "提供文件类型的描述文本" @默认值 = "">
    {
        @ RegisterFileRelation (@<欲关联的应用程序>.GetText (), @<欲注册的扩展名>.GetText (), @<欲注册的键值>.GetText (), @<图标所处文件名>.GetText (), @<图标索引位置>, @<文件类型描述>.GetText ())
    }

    方法 取屏幕坐标颜色 <公开 静态 类型 = 整数 注释 = "返回屏幕上所指定位置处的颜色值" @禁止流程检查 = 真>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    {
        @ const HDC hDC = ::GetDC (NULL);
        @ const COLORREF clr = ::GetPixel (hDC, @<横坐标>, @<纵坐标>);
        @ ::ReleaseDC (NULL, hDC);
        @ return (INT)clr;
    }

    方法 为子窗口 <公开 静态 类型 = 逻辑型 注释 = "返回\"子窗口句柄\"所对应窗口是否为\"父窗口句柄\"所对应窗口的子窗口" @嵌入式方法 = "">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供欲检测父窗口的句柄">
    参数 子窗口句柄 <类型 = 变整数 注释 = "提供欲检测子窗口的句柄">
    {
        @ ::IsChild ((HWND)@<父窗口句柄>, (HWND)@<子窗口句柄>)
    }

    方法 全局信息框 <公开 静态 类型 = 返回按钮类型 注释 = "显示一个信息框,等待用户单击按钮." 返回值注释 = "返回一个值告诉用户单击哪一个按钮."
            返回值注释 = "如果信息框有\"取消\"按钮,则按下 ESC 键与单击\"取消\"按钮的效果相同." @禁止流程检查 = 真>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 按钮 <类型 = 整数 注释 = "由\"信息框按钮\"类中的各组常量值相加后的值,具体请见该类中的说明." @默认值 = 0>
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "信息:">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供父窗口的窗口句柄值,为0表示使用默认父窗口." @默认值 = 0>
    {
        @ const HWND hOldFocusWnd = ::GetFocus ();
        @ HWND hParentWnd = (HWND)@<父窗口句柄>;
        @ if (hParentWnd == NULL)
        @ {
        @ #ifdef _AFX
        @     CWinApp* pWinApp = AfxGetApp ();
        @     if (pWinApp != NULL)
        @         hParentWnd = pWinApp->m_pMainWnd->GetSafeHwnd ();
        @ #endif
        @     if (hParentWnd == NULL)  hParentWnd = ::GetActiveWindow ();
        @     if (hParentWnd == NULL)  hParentWnd = ::GetDesktopWindow ();
        @ }
        @ const INT nResult = ::MessageBox (hParentWnd, @<提示信息>, @<窗口标题>, @<按钮>);
        @ if (hOldFocusWnd != NULL && ::IsWindow (hOldFocusWnd))
        @     ::SetFocus (hOldFocusWnd);
        @ return nResult;
    }

    方法 全局询问信息框 <公开 静态 类型 = 逻辑型 注释 = "用户点击\"是\"按钮将返回真,点击\"否\"按钮将返回假.">
    参数 询问信息 <类型 = 文本型 注释 = "提供具体的询问提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "询问:">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供父窗口的窗口句柄值,为0表示使用默认父窗口." @默认值 = 0>
    {
        返回 (全局信息框 (询问信息, 信息框按钮.询问图标 + 信息框按钮.是否钮, 窗口标题, 父窗口句柄) == 返回按钮类型.是钮)
    }

    方法 全局错误信息框 <公开 静态>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "错误:">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供父窗口的窗口句柄值,为0表示使用默认父窗口." @默认值 = 0>
    {
        全局信息框 (提示信息, 信息框按钮.错误图标 + 信息框按钮.确认钮, 窗口标题, 父窗口句柄)
    }

    方法 全局警告信息框 <公开 静态>
    参数 提示信息 <类型 = 文本型 注释 = "提供具体的提示文本">
    参数 窗口标题 <类型 = 文本型 注释 = "指定显示在信息框标题栏中的文本" @默认值 = "警告:">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供父窗口的窗口句柄值,为0表示使用默认父窗口." @默认值 = 0>
    {
        全局信息框 (提示信息, 信息框按钮.警告图标 + 信息框按钮.确认钮, 窗口标题, 父窗口句柄)
    }

    方法 显示鼠标 <公开 静态 注释 = "显示或隐藏鼠标光标." @嵌入式方法 = "">
    参数 是否显示 <类型 = 逻辑型 注释 = "  注意: 每显示一次,内部计数会加一,每隐藏一次,内部计数会减一," 注释 = "只有当内部计数值大于等于0时,鼠标光标才会被显示.">
    {
        @ ::ShowCursor (@<是否显示>)
    }

    方法 取屏幕DPI <公开 静态 类型 = 小数 注释 = "返回系统主屏幕的DPI比例值(相对基准96 DPI)." 注释 = "注意本方法的返回值受到\"关注屏幕DPI\"方法的影响." @嵌入式方法 = "">
    {
        @ g_objVolApp.GetDPI ()
    }

    方法 乘于屏幕DPI <公开 静态 类型 = 整数 注释 = "将指定尺寸值乘于系统主屏幕DPI比例值(相对基准96 DPI)后返回结果值." 注释 = "注意本方法的返回值受到\"关注屏幕DPI\"方法的影响." @嵌入式方法 = "">
    参数 所欲使用尺寸值 <类型 = 整数>
    {
        @ g_objVolApp.MulDPI (@<所欲使用尺寸值>)
    }

    方法 除于屏幕DPI <公开 静态 类型 = 整数 注释 = "将指定尺寸值除于系统主屏幕DPI比例值(相对基准96 DPI)后返回结果值." 注释 = "注意本方法的返回值受到\"关注屏幕DPI\"方法的影响." @嵌入式方法 = "">
    参数 所欲使用尺寸值 <类型 = 整数>
    {
        @ g_objVolApp.DivDPI (@<所欲使用尺寸值>)
    }

    方法 关注屏幕DPI <公开 静态 注释 = "设置本程序是否关注系统默认显示器的DPI(缩放比例)" @嵌入式方法 = "">
    参数 是否关注 <类型 = 逻辑型 注释 = "为真则关注系统默认显示器的DPI,此时获取屏幕DPI将得到正确的缩放比例." 注释 = "为假表示不关注,此时获取屏幕DPI将始终得到固定值1.">
    {
        @ MSetProcessDpiAwareness (@<是否关注> ? 2 : 0)
    }

    方法 选择目录 <公开 静态 类型 = 文本型 注释 = "打开对话框选择所指定的目录,成功返回所选择目录,失败或用户取消关闭对话框则返回空文本."
            注释 = "注意: 本方法要求操作系统版本最低为 Windows Vista, 不支持 WinXP." @禁止流程检查 = 真 @视窗.外部头文件.全局 = "<shobjidl.h>"
            @视窗.预定义宏 = "_WIN32_WINNT=0x0600">
    参数 父窗口句柄 <类型 = 变整数 注释 = "提供所打开对话框的父窗口句柄,为0表示无." @默认值 = 0>
    {
        @ CVolString strDir;
        @ IFileOpenDialog* pFileOpenDialog;
        @ if (SUCCEEDED (CoCreateInstance (CLSID_FileOpenDialog, NULL, CLSCTX_ALL, IID_IFileOpenDialog, reinterpret_cast<void**>(&pFileOpenDialog))))
        @ {
        @     IShellItem* pFolder;
        @     if (SUCCEEDED (pFileOpenDialog->SetOptions (FOS_PICKFOLDERS)) && SUCCEEDED (pFileOpenDialog->Show ((HWND)@<父窗口句柄>)) && SUCCEEDED ((pFileOpenDialog->GetFolder (&pFolder))))
        @     {
        @         PWSTR szFolderPath;
        @         if (SUCCEEDED (pFolder->GetDisplayName (SIGDN_FILESYSPATH, &szFolderPath)))
        @         {
        @             strDir.SetText (szFolderPath);
        @             CoTaskMemFree (szFolderPath);
        @         }
        @         pFolder->Release ();
        @     }
        @     pFileOpenDialog->Release ();
        @ }
        @ return strDir;
    }
}

类 鼠标等待器 <公开 注释 = "  当建立此类的对象实例时,会将鼠标形状自动设置为沙漏形,用作" 注释 = "在即将长时间执行程序前提示用户. 当该对象实例超出其作用区域" 注释 = "被销毁时,会自动把鼠标形状恢复到先前形状."
        @文档 = "category = \"常用功能\"">
{
    变量 先前鼠标句柄 <类型 = 变整数>

    方法 类_初始化
    {
        @ @<先前鼠标句柄> = (INT_P)::SetCursor (::LoadCursor (NULL, IDC_WAIT));
    }

    方法 类_清理
    {
        恢复鼠标 ()
    }

    方法 恢复鼠标 <公开 注释 = "用作在本对象实例被销毁前提前恢复鼠标的先前形状">
    {
        @ if (@<先前鼠标句柄> != 0)
        @ {
        @     ::SetCursor ((HCURSOR)@<先前鼠标句柄>);
        @     @<先前鼠标句柄> = 0;
        @ }
    }
}

# ===

类 控制台程序运行结果 <公开 @文档 = "category = \"控制台操作.辅助类\"" @常量类 = 整数>
{
    常量 成功 <公开 值 = @CARR_SUCCEEDED 注释 = "运行成功">
    常量 失败 <公开 值 = @CARR_FAIL 注释 = "运行失败">
    常量 超时 <公开 值 = @CARR_TIMEOUT 注释 = "超出最大等待时间">
}

类 控制台程序编码类型 <公开 注释 = "指定控制台程序运行时所输出文本(标准输出/错误输出)的编码类型" @文档 = "category = \"控制台操作.辅助类\"" @常量类 = 整数>
{
    常量 多字节 <公开 值 = @CAOCS_MBS>
    常量 UTF8 <公开 值 = @CAOCS_UTF8>
}

类 控制台程序输出方向 <公开 @文档 = "category = \"控制台操作.辅助类\"" @常量类 = 整数>
{
    常量 标准输出设备 <公开 值 = 1>
    常量 错误输出设备 <公开 值 = 2>
}

类 控制台操作类 <公开 @文档 = "category = \"控制台操作\"" @全局类 = 真>
{
    方法 运行控制台程序 <公开 静态 类型 = 控制台程序运行结果 注释 = "运行指定的控制台程序(不会打开控制台窗口),返回具体运行结果." @禁止流程检查 = 真>
    参数 欲运行的命令行 <类型 = 文本型 注释 = "提供所具体运行的命令行文本">
    参数 标准输出内容结果 <类型 = 文本型 注释 = "如果不为空对象,控制台程序在运行期间输出到标准输出设备的所有内容将被存放到此参数中返回." @默认值 = 空对象>
    参数 错误输出内容结果 <类型 = 文本型 注释 = "如果不为空对象,控制台程序在运行期间输出到标准错误设备的所有内容将被存放到此参数中返回."
            注释 = "提供本参数时,可以与\"标准输出内容结果\"参数提供同一文本变量,此时标准错误输出文本将附加在该变量后面." @默认值 = 空对象>
    参数 返回值结果 <类型 = 整数类 注释 = "如果不为空对象,则控制台程序的运行结果值将存放到此参数中返回." @默认值 = 空对象>
    参数 工作目录 <类型 = 文本型 注释 = "指定所运行命令行的工作目录,为空文本表示自动从所提供的命令行中获取,为空对象则使用本程序的当前目录." @默认值 = 空对象>
    参数 最长等待时间 <类型 = 整数 注释 = "等待命令行运行结束的最大等待毫秒数,为0表示无限等待." @默认值 = 0>
    参数 是否删除所有空行 <类型 = 逻辑型 注释 = "是否自动删除在\"标准输出内容结果\"和\"错误输出内容结果\"中所返回文本中的所有空白行" @默认值 = 假>
    参数 输出编码类型 <类型 = 控制台程序编码类型 注释 = "提供所运行控制台程序标准和错误输出内容的编码格式,方法将据此来将这些内容转换存储进所提供的结果文本参数中." @默认值 = 控制台程序编码类型.多字节>
    {
        @ return (INT)RunConsoleAppWithTimeoutCheck (@<欲运行的命令行>.GetText (), (@<工作目录>.IsNullObject () ? NULL : @<工作目录>.GetText ()),
        @         (CONSOLE_APP_OUT_CHAR_SET)@<输出编码类型>, (@<标准输出内容结果>.IsNullObject () ? NULL : &@<标准输出内容结果>),
        @         (@<错误输出内容结果>.IsNullObject () ? NULL : &@<错误输出内容结果>), @<是否删除所有空行>, 
        @         (@<返回值结果>.IsNullObject () ? NULL : (DWORD*)&@<返回值结果.值>), (DWORD)MAX (0, @<最长等待时间>));
    }

    方法 是否输出到控制台 <公开 静态 类型 = 逻辑型 注释 = "返回所指定输出方向是否将文本信息输出到了控制台上." 注释 = "输出到标准输出设备或标准错误设备上的信息可能会被输出到管道或文件,本方法检查是否为输出到了控制台终端上."
            @嵌入式方法 = "">
    参数 欲检查输出方向 <类型 = 控制台程序输出方向 注释 = "提供内容所输出到的设备" @默认值 = 控制台程序输出方向.标准输出设备>
    {
        @ GetFileType (GetStdHandle (@<欲检查输出方向> == 1 ? STD_OUTPUT_HANDLE : STD_ERROR_HANDLE)) == FILE_TYPE_CHAR
    }

    方法 标准输出 <公开 静态 注释 = "  在标准输出设备或标准错误设备上输出指定的一系列内容."
            注释 = "  提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式(几乎所有现代终端: Windows Terminal、"
            注释 = "macOS Terminal、Linux 终端都支持),参数具体格式为: \"\\033[设置值m\". 其中\"设置值\"为使用分号分隔的一个或多个颜色值或样式值,常用颜色值"
            注释 = "表如下(每个颜色的描述字段顺序为\"普通前景色\",\"高亮前景色\",\"背景颜色\"):"
            注释 = "  黑色 30 90 40, 红色 31 91 41, 绿色 32 92 42, 黄色 33 93 43, 蓝色 34 94 44, 紫色 35 95 45, 青色 36 96 46, 白色 37 97 47 ."
            注释 = "  可以使用的样式值有如下: 1: 粗体; 4: 下划线; 5; 闪烁; 7: 反色." 注释 = "  \"\\033[0m\"表示重置所有颜色和样式,如果文本中设置有控制参数则必须以此参数结尾,否则会影响后续输出."
            注释 = "  例如:" 注释 = "  标准输出 (. \"\\033[31m红色文字\\033[0m\");" 注释 = "  标准输出 (. \"\\033[32m绿色文字\\033[0m\");"
            注释 = "  标准输出 (. \"\\033[41;33m黄字红底\\033[0m\");" 注释 = "  标准输出 (. \"\\033[1;41;33m粗体黄字红底\\033[0m\")" @嵌入式方法 = "">
    参数 输出方向 <类型 = 控制台程序输出方向 注释 = "提供内容所输出到的设备" @默认值 = 控制台程序输出方向.标准输出设备>
    参数 欲输出内容 <注释 = "提供所有需要输出的内容,每份内容之间自动使用逗号文本分隔." @匹配类型 = 通用基本型 @可扩展 = "d_text = \").GetText (), CVolString (\"">
    {
        @ vol_print ((@<输出方向> == 1 ? stdout : stderr), @sn<pm_count> - 1, FALSE, CVolString (@<欲输出内容>).GetText ())
    }

    方法 标准输出行 <公开 静态 注释 = "在标准输出设备或标准错误设备上输出指定的一系列内容行." 注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法."
            @嵌入式方法 = "">
    参数 输出方向 <类型 = 控制台程序输出方向 注释 = "提供内容所输出到的设备" @默认值 = 控制台程序输出方向.标准输出设备>
    参数 欲输出内容 <注释 = "提供所有需要输出的内容,每份内容后会自动添加换行文本." @匹配类型 = 通用基本型 @可扩展 = "d_text = \").GetText (), CVolString (\"">
    {
        @ vol_print ((@<输出方向> == 1 ? stdout : stderr), @sn<pm_count> - 1, TRUE, CVolString (@<欲输出内容>).GetText ())
    }

    方法 标准输出2 <公开 静态 注释 = "在标准输出设备上输出指定的一系列内容." 注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法."
            @嵌入式方法 = "">
    参数 欲输出内容 <注释 = "提供所有需要输出的内容,每份内容之间自动使用逗号文本分隔." @匹配类型 = 通用基本型 @可扩展 = "d_text = \").GetText (), CVolString (\"">
    {
        @ vol_print (stdout, @sn<pm_count>, FALSE, CVolString (@<欲输出内容>).GetText ())
    }

    方法 标准输出行2 <公开 静态 注释 = "在标准输出设备上输出指定的一系列内容行." 注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法."
            @嵌入式方法 = "">
    参数 欲输出内容 <注释 = "提供所有需要输出的内容,每份内容后会自动添加换行文本." @匹配类型 = 通用基本型 @可扩展 = "d_text = \").GetText (), CVolString (\"">
    {
        @ vol_print (stdout, @sn<pm_count>, TRUE, CVolString (@<欲输出内容>).GetText ())
    }

    方法 格式标准输出 <公开 静态 注释 = "在标准输出设备或标准错误设备上输出所指定格式数据的文本."
            注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法." @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 输出方向 <类型 = 控制台程序输出方向 注释 = "提供内容所输出到的设备" @默认值 = 控制台程序输出方向.标准输出设备>
    参数 格式文本 <类型 = 文本型 注释 = "提供其中可以包含格式替换符的文本,其中的格式替换符将被后续对应参数所替换." 注释 = "以下为常用的格式替换符,详细信息请参阅C++文档中关于sprintf函数的说明."
            注释 = "    %c: 字符" 注释 = "    %d: 整数(以有符号十进制格式替换)" 注释 = "    %o: 整数(以无符号八进制格式替换)" 注释 = "    %u: 整数(以无符号十进制格式替换)"
            注释 = "    %x: 整数(以无符号小写十六进制格式替换)" 注释 = "    %X: 整数(以无符号大写十六进制格式替换)" 注释 = "    %I64d: 长整数(以有符号十进制格式替换)"
            注释 = "    %I64o: 长整数(以无符号八进制格式替换)" 注释 = "    %I64u: 长整数(以无符号十进制格式替换)" 注释 = "    %I64x: 长整数(以无符号小写十六进制格式替换)"
            注释 = "    %I64X: 长整数(以无符号大写十六进制格式替换)" 注释 = "    %e, %E: 小数(以指数形式替换)" 注释 = "    %f: 小数(以非指数形式替换)"
            注释 = "    %.8f: 小数(用来表达小数的带宽度限制的常用格式替换符)" 注释 = "    %g, %G: 小数(根据值大小自动选择是否以指数形式替换)" 注释 = "    %s: 文本型"
            注释 = "    %%: 百分号字符本身" 注释 = "注意: 如果欲格式化\"变整数\"值,请务必将其先强制转换为整数或者长整数,再使用对应的格式替换符." 编辑时信息 = "B7FF4, 0, 0, 0">
    参数 替换数据 <注释 = "用作给格式文本中的格式替换符提供替换数据,格式替换符的数目和数据类型必须与替换数据保持一致." 编辑时信息 = "B7FF4, 0, 0, 0" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ vol_print ((@<输出方向> == 1 ? stdout : stderr), 1, FALSE, @an<CVolString> ().Format (@<格式文本>, @<替换数据>).GetText ())
    }

    方法 格式标准输出行 <公开 静态 注释 = "在标准输出设备或标准错误设备上输出所指定格式数据的文本并附加一个换行."
            注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法." @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 输出方向 <类型 = 控制台程序输出方向 注释 = "提供内容所输出到的设备" @默认值 = 控制台程序输出方向.标准输出设备>
    参数 格式文本 <类型 = 文本型 注释 = "请参见\"格式标准输出\"方法的同名参数" 编辑时信息 = "B7FF4, 0, 0, 0">
    参数 替换数据 <注释 = "用作给格式文本中的格式替换符提供替换数据,格式替换符的数目和数据类型必须与替换数据保持一致." 编辑时信息 = "B7FF4, 0, 0, 0" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ vol_print ((@<输出方向> == 1 ? stdout : stderr), 1, TRUE, @an<CVolString> ().Format (@<格式文本>, @<替换数据>).GetText ())
    }

    方法 格式标准输出2 <公开 静态 注释 = "在标准输出设备上输出所指定格式数据的文本." 注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法."
            @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 格式文本 <类型 = 文本型 注释 = "请参见\"格式标准输出\"方法的同名参数" 编辑时信息 = "B7FF4, 0, 0, 0">
    参数 替换数据 <注释 = "用作给格式文本中的格式替换符提供替换数据,格式替换符的数目和数据类型必须与替换数据保持一致." 编辑时信息 = "B7FF4, 0, 0, 0" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ vol_print (stdout, 1, FALSE, @an<CVolString> ().Format (@<格式文本>, @<替换数据>).GetText ())
    }

    方法 格式标准输出行2 <公开 静态 注释 = "在标准输出设备上输出所指定格式数据的文本并附加一个换行."
            注释 = "提示: 如果所提供文本最终输出到控制台,可以使用内嵌颜色和样式控制参数设置文本的显示颜色和样式,具体请参见\"标准输出\"方法." @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 格式文本 <类型 = 文本型 注释 = "请参见\"格式标准输出\"方法的同名参数" 编辑时信息 = "B7FF4, 0, 0, 0">
    参数 替换数据 <注释 = "用作给格式文本中的格式替换符提供替换数据,格式替换符的数目和数据类型必须与替换数据保持一致." 编辑时信息 = "B7FF4, 0, 0, 0" @匹配类型 = 通用基本型 @可扩展 = "">
    {
        @ vol_print (stdout, 1, TRUE, @an<CVolString> ().Format (@<格式文本>, @<替换数据>).GetText ())
    }

    方法 标准输入 <公开 静态 类型 = 文本型 注释 = "在标准输入设备上请求输入最多包含2048个字符的一行文本,返回用户所输入的内容." @视窗.外部头文件 = "<conio.h>">
    参数 是否回显 <类型 = 逻辑型 注释 = "决定输入时是否显示所输入字符" @默认值 = 真>
    {
        变量 结果变量 <类型 = 文本型>
        @ TCHAR buf [2048 + 1];
        @ if (@<是否回显>)
        @ {
        @     const TCHAR* ps = _fgetts (buf, NUM_ELEMENTS_OF (buf) - 1, stdin);
        @     if (ps != NULL)
        @         @<结果变量>.SetText (ps);
        @ }
        @ else
        @ {
        @     INT_P npIndex = 0;
        @     for (; npIndex < NUM_ELEMENTS_OF (buf) - 1; npIndex++)
        @     {
        @         buf [npIndex] = (TCHAR)_getch ();
        @         if (buf [npIndex] == '\r' || buf [npIndex] == '\0')
        @             break;
        @     }
        @     buf [npIndex] = '\0';
        @     @<结果变量>.SetText (buf);
        @ }
        删自身尾空 (结果变量)
        返回 (结果变量)
    }

    方法 标准输入字符 <公开 静态 类型 = 字符 注释 = "在标准输入设备上请求输入并返回一个字符" @视窗.外部头文件 = "<conio.h>" @禁止流程检查 = 真>
    参数 是否回显 <类型 = 逻辑型 注释 = "指定是否回显所输入的字符" @默认值 = 真>
    {
        @ return (TCHAR)(@<是否回显> ? getche () : _getch ());
    }
}

# ===

类 环境存取类 <公开 @文档 = "category = \"环境存取\"" @全局类 = 真>
{
    方法 取命令行 <公开 静态 类型 = 整数 注释 = "取出在启动程序时附加在其可执行文件名后面的所有以空格分隔的命令行文本参数" 返回值注释 = "返回所填写到\"命令行文本返回数组\"参数中的成员数目" @嵌入式方法 = "">
    参数 命令行文本返回数组 <类型 = 文本数组类 注释 = "本数组用作存放所获取的命令行参数,其中原有内容将被清除.">
    {
        @ GetCommandLineArray (@<命令行文本返回数组>.data ())
    }

    方法 取运行目录 <公开 静态 类型 = 文本型 注释 = "返回当前被执行程序文件所处的目录." 注释 = "注意: 所返回目录路径必定以路径字符结束,如: \"c:\\app\\\"." @禁止流程检查 = 真>
    {
        @ CVolString strPath;
        @ GetInstancePath (strPath);
        @ return strPath;
    }

    方法 取模块目录 <公开 静态 类型 = 文本型 注释 = "返回当前被载入程序模块文件所处的目录." 注释 = "与\"取运行目录\"相比,如果本程序为DLL文件,前者返回载入该DLL的EXE文件所处目录,本方法返回DLL文件自身所处目录."
            注释 = "注意: 所返回目录路径必定以路径字符结束,如: \"c:\\app\\\"." @禁止流程检查 = 真>
    {
        @ CVolString strPath;
        @ GetInstancePath (g_objVolApp.GetInstanceHandle (), strPath);
        @ return strPath;
    }

    方法 取执行文件名 <公开 静态 类型 = 文本型 注释 = "返回当前被执行程序文件的名称" @禁止流程检查 = 真>
    {
        @ CVolString strFileName;
        @ TCHAR buf [MAX_PATH + 1];
        @ buf [0] = '\0';
        @ if (::GetModuleFileName (NULL, buf, NUM_ELEMENTS_OF (buf) - 1) > 0)
        @ {
        @     const TCHAR* ps = _tcsrchr (buf, OS_PATH_CHAR);
        @     strFileName.SetText (ps == NULL ? buf : ps + 1);
        @ }
        @ return strFileName;
    }

    方法 读环境变量 <公开 静态 类型 = 文本型 注释 = "返回所指定操作系统环境变量的值,如不存在则返回空文本." @嵌入式方法 = "">
    参数 环境变量名称 <类型 = 文本型 注释 = "提供所欲获取其值的环境变量名称">
    {
        @ CVolString (_tgetenv (@<环境变量名称>.GetText ()))
    }

    方法 写环境变量 <公开 静态 类型 = 逻辑型 注释 = "设置所指定操作系统环境变量的值,返回是否成功." @禁止流程检查 = 真>
    参数 环境变量名称 <类型 = 文本型 注释 = "提供所欲设置其值的环境变量名称">
    参数 所欲设置的值 <类型 = 文本型>
    {
        @ return (_tputenv ((@<环境变量名称> + _T ("=") + @<所欲设置的值>).GetText ()) == 0);
    }
}

# ===

类 目录删除模式 <公开 @文档 = "category = \"磁盘操作.辅助类\"" @常量类 = 整数>
{
    常量 全部删除 <公开 值 = @DTRM_REMOVE_ALL 注释 = "删除所指定目录及其中的所有内容(包括所有直接或间接子目录)">
    常量 仅删除文件 <公开 值 = @DTRM_ONLY_REMOVE_FILES 注释 = "仅删除所指定目录(包括所有直接或间接子目录)中的所有文件">
    常量 保留自身 <公开 值 = @DTRM_CLEAN_CONTENT 注释 = "删除所指定目录(包括所有直接或间接子目录)中的所有内容,但是不删除所指定目录本身.">
}

类 文件覆盖模式 <公开 @文档 = "category = \"磁盘操作.辅助类\"" @常量类 = 整数>
{
    常量 覆盖 <公开 值 = @FCOM_OVERRIDE 注释 = "如果所欲复制到的文件已经存在,则将其覆盖.">
    常量 忽略 <公开 值 = @FCOM_IGNORE 注释 = "如果所欲复制到的文件已经存在,则跳过不复制.">
    常量 快速 <公开 值 = @FCOM_FAST 注释 = "如果所欲复制到的文件已经存在且其尺寸和最后修改时间与源文件一致,则跳过不复制,否则将其覆盖.">
    常量 报错 <公开 值 = @FCOM_FAIL 注释 = "如果所欲复制到的文件已经存在,则返回复制失败.">
}

类 磁盘操作类 <公开 @文档 = "category = \"磁盘操作\"" @全局类 = 真>
{
    方法 取磁盘总空间 <公开 静态 类型 = 长整数 注释 = "返回以1024 字节（KB）为单位的指定磁盘全部空间. 如果失败,返回-1." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所欲取其空间尺寸的盘符字符(如\'C\',\'D\'等).如果为\'\\0\',表示为当前驱动器." @默认值 = '\0'>
    {
        @ TCHAR drive [4];
        @ drive [0] = (@<盘符字符> == '\0' ? (TCHAR)(_getdrive () - 1 + 'A') : @<盘符字符>);
        @ _tcscpy (&drive [1], _T (":") OS_PATH_CHAR_TEXT);
        @ ULARGE_INTEGER i64FreeBytesToCaller, i64TotalBytes, i64FreeBytes;
        @ return (GetDiskFreeSpaceEx (drive, &i64FreeBytesToCaller, &i64TotalBytes, &i64FreeBytes) ? (INT64)i64TotalBytes.QuadPart / 1024 : -1);
    }

    方法 取磁盘剩余空间 <公开 静态 类型 = 长整数 注释 = "返回以1024 字节（KB）为单位的指定磁盘剩余可用空间. 如果失败,返回-1." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所欲取其空间尺寸的盘符字符(如\'C\',\'D\'等).如果为\'\\0\',表示为当前驱动器." @默认值 = '\0'>
    {
        @ TCHAR drive [4];
        @ drive [0] = (@<盘符字符> == '\0' ? (TCHAR)(_getdrive () - 1 + 'A') : @<盘符字符>);
        @ _tcscpy (&drive [1], _T (":") OS_PATH_CHAR_TEXT);
        @ ULARGE_INTEGER i64FreeBytesToCaller, i64TotalBytes, i64FreeBytes;
        @ return (GetDiskFreeSpaceEx (drive, &i64FreeBytesToCaller, &i64TotalBytes, &i64FreeBytes) ? (INT64)i64FreeBytesToCaller.QuadPart / 1024 : -1);
    }

    方法 取磁盘卷标 <公开 静态 类型 = 文本型 注释 = "成功返回指定磁盘的卷标文本,失败返回空文本." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所欲取其卷标文本的盘符字符(如\'C\',\'D\'等).如果为\'\\0\',表示为当前驱动器." @默认值 = '\0'>
    {
        @ TCHAR drive [4];
        @ drive [0] = (@<盘符字符> == '\0' ? (TCHAR)(_getdrive () - 1 + 'A') : @<盘符字符>);
        @ _tcscpy (&drive [1], _T (":") OS_PATH_CHAR_TEXT);
        @ TCHAR achVolumeName [512];
        @ achVolumeName [0] = '\0';
        @ DWORD dwMaximumComponentLength, dwFileSystemFlags;
        @ if (::GetVolumeInformation (drive, achVolumeName, NUM_ELEMENTS_OF (achVolumeName) - 1, NULL, &dwMaximumComponentLength, &dwFileSystemFlags, NULL, 0) == FALSE)
        @     achVolumeName [0] = '\0';
        @ return CVolString (achVolumeName);
    }

    方法 置磁盘卷标 <公开 静态 类型 = 逻辑型 注释 = "设置指定磁盘的卷标文本.成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所设置其卷标的盘符字符(如\'C\',\'D\'等).如果为\'\\0\',表示为当前驱动器." @默认值 = '\0'>
    参数 所欲设置的卷标文本 <类型 = 文本型>
    {
        @ TCHAR drive [4];
        @ drive [0] = (@<盘符字符> == '\0' ? (TCHAR)(_getdrive () - 1 + 'A') : @<盘符字符>);
        @ _tcscpy (&drive [1], _T (":") OS_PATH_CHAR_TEXT);
        @ return ::SetVolumeLabel (drive, @<所欲设置的卷标文本>.GetText ());
    }

    方法 取磁盘序列号 <公开 静态 类型 = 整数 注释 = "成功返回指定磁盘的序列号值,失败返回-1." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所欲取其序列号的盘符字符(如\'C\',\'D\'等).如果为\'\\0\',表示为当前驱动器." @默认值 = '\0'>
    {
        @ TCHAR drive [4];
        @ drive [0] = (@<盘符字符> == '\0' ? (TCHAR)(_getdrive () - 1 + 'A') : @<盘符字符>);
        @ _tcscpy (&drive [1], _T (":") OS_PATH_CHAR_TEXT);
        @ DWORD dwVolumeSerialNumber, dwMaximumComponentLength, dwFileSystemFlags;
        @ return (::GetVolumeInformation (drive, NULL, 0, &dwVolumeSerialNumber, &dwMaximumComponentLength, &dwFileSystemFlags, NULL, 0) ? (INT)dwVolumeSerialNumber : -1);
    }

    方法 改变驱动器 <公开 静态 类型 = 逻辑型 注释 = "改变当前的缺省驱动器,返回是否成功." @禁止流程检查 = 真>
    参数 盘符字符 <类型 = 字符 注释 = "提供所欲改变驱动器的盘符字符(如\'C\',\'D\'等)">
    {
        @ return (_chdrive (TO_UPPER_CASE (@<盘符字符>) - 'A' + 1) == 0);
    }

    方法 改变目录 <公开 静态 类型 = 逻辑型 注释 = "改变现行目录位置,返回是否成功." @嵌入式方法 = "">
    参数 所欲改变到的目录 <类型 = 文本型>
    {
        @ (BOOL)::MSetCurrentDirectory (@<所欲改变到的目录>.GetText ())
    }

    方法 取当前目录 <公开 静态 类型 = 文本型 注释 = "返回现行目录位置" @禁止流程检查 = 真>
    {
        @ TCHAR path [MAX_PATH + 1];
        @ if (::MGetCurrentDirectory  (path, NUM_ELEMENTS_OF (path) - 1) == FALSE)
        @     path [0] = '\0';
        @ return CVolString (path);
    }

    方法 创建目录 <公开 静态 类型 = 逻辑型 注释 = "创建所指定目录,返回是否成功." 注释 = "注意: 所提供路径内的中间目录如果不存在,将会自动创建." @嵌入式方法 = "">
    参数 所欲创建的目录 <类型 = 文本型>
    {
        @ (BOOL)::CreateDirectoryTree (@<所欲创建的目录>.GetText ())
    }

    方法 删除目录 <公开 静态 类型 = 逻辑型 注释 = "删除所指定目录,返回是否成功." 注释 = "由于本方法会自动删除所有直接/间接子目录,请务必谨慎使用本命令." @嵌入式方法 = "">
    参数 所欲删除的目录 <类型 = 文本型>
    参数 删除模式 <类型 = 目录删除模式>
    参数 仅检测文件删除失败 <类型 = 逻辑型 注释 = "指定是否仅当删除文件失败时才会出错返回(即允许目录删除失败)" @默认值 = 假>
    {
        @ (BOOL)RemoveDirectoryTree (@<所欲删除的目录>.GetText (), @<删除模式>, @<仅检测文件删除失败>)
    }

    方法 文件尺寸和时间是否相同 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的两个文件是否均存在且文件尺寸和最后修改时间都一致" @嵌入式方法 = "">
    参数 文件名1 <类型 = 文本型>
    参数 文件名2 <类型 = 文本型>
    {
        @ (BOOL)::IsFileSizeAndTimeSame (@<文件名1>.GetText (), @<文件名2>.GetText ())
    }

    方法 复制文件 <公开 静态 类型 = 逻辑型 注释 = "将所指定的文件复制到另一位置,返回是否成功." @嵌入式方法 = "">
    参数 被复制文件的名称 <类型 = 文本型 注释 = "指定被复制文件的名称,必须已经存在.">
    参数 复制到文件的名称 <类型 = 文本型 注释 = "指定所欲复制到文件的名称,如果该文件所处目录尚不存在,则自动将其创建.">
    参数 覆盖模式 <类型 = 文件覆盖模式 注释 = "指定具体的复制覆盖模式" @默认值 = 文件覆盖模式.覆盖>
    {
        @ (BOOL)::MCopyFileAutoCreateDir (@<被复制文件的名称>.GetText (), @<复制到文件的名称>.GetText (), (FILE_COPY_OVERRIDE_MODE)@<覆盖模式>)
    }

    方法 复制目录 <公开 静态 类型 = 逻辑型 注释 = "将所指定源目录中的所有匹配文件复制到目标目录中去." 返回值注释 = "全部复制成功返回真,存在文件/目录复制失败则返回假."
            返回值注释 = "也就是说: 复制过程会一定完成,并不会因为某个文件复制失败而就中途退出." @禁止流程检查 = 真>
    参数 源目录名称 <类型 = 文本型 注释 = "提供所欲复制的源目录名称,该目录必须已经存在.">
    参数 目的目录名称 <类型 = 文本型 注释 = "提供欲复制到的目的目录名称,该目录必须已经存在.">
    参数 所欲复制文件 <类型 = 文本型 注释 = "提供所欲复制文件的匹配名称容,支持使用多字符 (*) 和单字符 (?) 通配符." 注释 = "如果为空文本,则默认为\"*.*\"." @默认值 = "">
    参数 覆盖模式 <类型 = 文件覆盖模式 注释 = "提供目录中所有文件的具体复制覆盖模式" @默认值 = 文件覆盖模式.覆盖>
    参数 是否复制子目录内容 <类型 = 逻辑型 注释 = "  指定是否递归复制源目录中的所有直接/间接子目录,如果本参数值为真,注意复制目的目录" 注释 = "中的这些子目录不需要一定存在,复制时如不存在会自动创建." @默认值 = 假>
    参数 复制出错记录数组 <类型 = 文本数组类 注释 = "如果不为空对象,则将所有复制失败的源文件和目的文件名加入进去(每两个成员为一个记录)." @默认值 = 空对象>
    {
        @ return (BOOL)MCopyFiles (@<源目录名称>.GetText (), @<目的目录名称>.GetText (), @<所欲复制文件>.GetText (), (FILE_COPY_OVERRIDE_MODE)@<覆盖模式>, @<是否复制子目录内容>, (@<复制出错记录数组>.IsNullObject () ? NULL : &@<复制出错记录数组>.data ()));
    }

    方法 移动文件 <公开 静态 类型 = 逻辑型 注释 = "将所指定的文件移动到另一位置,返回是否成功." @禁止流程检查 = 真>
    参数 被移动文件的名称 <类型 = 文本型 注释 = "指定被移动文件的名称,必须已经存在.">
    参数 所欲移动到位置 <类型 = 文本型>
    {
        @ if (::MoveFile (@<被移动文件的名称>.GetText (), @<所欲移动到位置>.GetText ()))
        @     return TRUE;
        @ return (::CopyFile (@<被移动文件的名称>.GetText (), @<所欲移动到位置>.GetText (), FALSE) && ::DeleteFile (@<被移动文件的名称>.GetText ()));
    }

    方法 删除文件 <公开 静态 类型 = 逻辑型 注释 = "删除所指定的文件,返回是否成功." @嵌入式方法 = "">
    参数 所欲删除文件的名称 <类型 = 文本型>
    {
        @ ::DeleteFile (@<所欲删除文件的名称>.GetText ())
    }

    方法 文件更名 <公开 静态 类型 = 逻辑型 注释 = "重新命名一个文件或目录,返回是否成功." @嵌入式方法 = "">
    参数 欲更名的文件或目录名 <类型 = 文本型>
    参数 欲更改到的文件或目录名 <类型 = 文本型>
    {
        @ ::MoveFile (@<欲更名的文件或目录名>.GetText (), @<欲更改到的文件或目录名>.GetText ())
    }

    方法 文件是否存在 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的文件或目录是否存在" @嵌入式方法 = "">
    参数 所欲检测的文件或目录名 <类型 = 文本型>
    {
        @ (BOOL)IsOSFileExist (@<所欲检测的文件或目录名>.GetText ())
    }

    方法 目录是否存在 <公开 静态 类型 = 逻辑型 注释 = "返回所指定的目录是否存在" @嵌入式方法 = "">
    参数 所欲检测的目录名 <类型 = 文本型>
    {
        @ (BOOL)IsOSDirExist (@<所欲检测的目录名>.GetText ())
    }

    方法 取文件时间 <公开 静态 类型 = 小数 注释 = "  返回指定文件或目录被创建或最后修改后的日期和时间,如果该文件不存在,将返回\"数值范围.最小日期时间值\""
            注释 = "常量值(100年1月1日),可以使用\"为最小时间\"方法进行判断." @禁止流程检查 = 真>
    参数 所欲检测的文件或目录名 <类型 = 文本型>
    {
        @ WIN32_FIND_DATA inf;
        @ const HANDLE handle = ::FindFirstFile (@<所欲检测的文件或目录名>.GetText (), &inf);
        @ if (handle != INVALID_HANDLE_VALUE)
        @ {
        @     ::FindClose (handle);
        @     return ConvertFileTime (inf.ftLastWriteTime);
        @ }
        @ return _VOL_MIN_DATE;
    }

    方法 取文件尺寸 <公开 静态 类型 = 长整数 注释 = "返回所指定文件的尺寸,单位字节,如果所指定文件不存在则返回-1." @禁止流程检查 = 真>
    参数 所欲取长度的文件名 <类型 = 文本型>
    {
        @ WIN32_FIND_DATA inf;
        @ const HANDLE handle = ::FindFirstFile (@<所欲取长度的文件名>.GetText (), &inf);
        @ if (handle != INVALID_HANDLE_VALUE)
        @ {
        @     ::FindClose (handle);
        @     return (((INT64)inf.nFileSizeHigh << 32) | (INT64)inf.nFileSizeLow);
        @ }
        @ return -1;
    }

    方法 取文件属性 <公开 静态 类型 = 整数 注释 = "  返回所指定文件的属性值,如果所指定文件不存在则返回-1." 注释 = "  所返回属性值可以通过使用\"位与\"关键字与\"文件属性\"类中的相关常量值"
            注释 = "进行比较来判断某属性是否被置位." @禁止流程检查 = 真>
    参数 所欲检测的文件名 <类型 = 文本型>
    {
        @ const DWORD dwFlags = ::GetFileAttributes (@<所欲检测的文件名>.GetText ());
        @ return (dwFlags == 0xffffffff ? -1 : (INT)dwFlags);
    }

    方法 置文件属性 <公开 静态 类型 = 逻辑型 注释 = "设置所指定文件的属性,返回是否成功." @嵌入式方法 = "">
    参数 所欲设置属性的文件名 <类型 = 文本型>
    参数 所欲设置的属性值 <类型 = 整数 注释 = "参数值可以为\"文件属性\"类中各个常量值的和,用作同时指定多个匹配属性.">
    {
        @ ::SetFileAttributes (@<所欲设置属性的文件名>.GetText (), (DWORD)@<所欲设置的属性值>)
    }

    方法 取临时文件名 <公开 静态 类型 = 文本型 注释 = "返回一个在指定目录中确定不存在的后缀为\".tmp\"的全路径文件名称" @禁止流程检查 = 真>
    参数 目录名 <类型 = 文本型 注释 = "提供所欲处理的目录名,为空文本表示使用系统的标准临时目录." @默认值 = "">
    {
        @ CVolString strPath;
        @ if (@<目录名>.IsEmpty ())
        @ {
        @     TCHAR path [MAX_PATH + 1];
        @     if (GetTempPath (NUM_ELEMENTS_OF (path) - 1, path) > 0)
        @         strPath.SetText (path);
        @ }
        @ else
        @    strPath.SetText (@<目录名>);
        @ strPath.CheckAddPathChar ();
        @ CVolString strResFileName;
        @ TCHAR chFileName [64];
        @ DWORD dw = GetTickCount ();
        @ while (TRUE)
        @ {
        @     wsprintf (chFileName, _T ("vol_%x.tmp"), dw);
        @     strResFileName.SetText (strPath);
        @     strResFileName.AddText (chFileName);
        @     if (IsOSFileExist (strResFileName.GetText ()) == FALSE)
        @         break;
        @     dw++;
        @ }
        @ return strResFileName;
    }

    方法 读入文件 <公开 静态 类型 = 字节集类 注释 = "从所指定路径文件中读入指定尺寸的数据,返回所实际读入的数据." @禁止流程检查 = 真>
    参数 所欲读取文件名 <类型 = 文本型 注释 = "提供所欲读取文件的路径名称">
    参数 所欲读取数据尺寸 <类型 = 整数 注释 = "提供所欲读取数据的尺寸,为-1表示全部读取." @默认值 = -1>
    {
        @ CVolMem mem;
        @ mem.ReadFromFile (@<所欲读取文件名>, @<所欲读取数据尺寸>);
        @ return mem;
    }

    方法 写到文件 <公开 静态 类型 = 逻辑型 注释 = "将所指定的字节集数据写出到所指定名称的文件,文件中的原有内容将被覆盖,返回是否成功." @嵌入式方法 = "">
    参数 所欲写到文件的名称 <类型 = 文本型>
    参数 字节集数据 <类型 = 字节集类 注释 = "提供所欲写出的字节集数据">
    参数 所欲写出数据尺寸 <类型 = 整数 注释 = "提供所欲写出数据的尺寸,为-1表示全部写出." @默认值 = -1>
    {
        @ (BOOL)@<字节集数据>.WriteIntoFile (@<所欲写到文件的名称>.GetText (), @<所欲写出数据尺寸>)
    }

    方法 为绝对路径 <公开 静态 类型 = 逻辑型 注释 = "返回所指定路径是否为绝对路径" @嵌入式方法 = "">
    参数 所欲检测的路径 <类型 = 文本型>
    {
        @ (BOOL)IsAbsPath (@<所欲检测的路径>.GetText ())
    }

    方法 到相对路径文件名 <公开 静态 类型 = 文本型 注释 = "将所指定的绝对路径文件名转换为基于所指定路径的相对路径文件名" 返回值注释 = "返回所转换后的相对路径文件名" @视窗.返回参考 = 真>
    参数 所欲转换的绝对路径文件名 <类型 = 文本型 注释 = "提供所欲转换的绝对路径文件名">
    参数 所基于的绝对路径 <类型 = 文本型 注释 = "所提供的绝对路径文件名将被转换到基于此目录的相对路径文件名">
    参数 结果相对路径文件名 <类型 = 文本型 注释 = "用作存放所转换后的相对路径文件名">
    {
        @ AbsPathFileName2Rel (@<所基于的绝对路径>.GetText (), @<所欲转换的绝对路径文件名>.GetText (), @<结果相对路径文件名>);
        返回 (结果相对路径文件名)
    }

    方法 到相对路径 <公开 静态 类型 = 文本型 注释 = "将所指定的绝对路径转换为基于所指定路径的相对路径" 返回值注释 = "返回所转换后的相对路径" @视窗.返回参考 = 真>
    参数 所欲转换的绝对路径 <类型 = 文本型 注释 = "提供所欲转换的绝对路径">
    参数 所基于的绝对路径 <类型 = 文本型 注释 = "所提供的绝对路径将被转换到基于此目录的相对路径">
    参数 结果相对路径 <类型 = 文本型 注释 = "用作存放所转换后的相对路径">
    {
        @ AbsPath2Rel (@<所基于的绝对路径>.GetText (), @<所欲转换的绝对路径>.GetText (), @<结果相对路径>);
        返回 (结果相对路径)
    }

    方法 到绝对路径 <公开 静态 类型 = 文本型 注释 = "根据现行目录建立所指定路径的绝对路径" 返回值注释 = "返回所转换后的绝对路径" @视窗.返回参考 = 真>
    参数 所欲转换的相对路径 <类型 = 文本型 注释 = "提供所欲转换的相对路径">
    参数 结果路径 <类型 = 文本型 注释 = "用作存放所转换后的绝对路径">
    {
        返回 (连接路径 (取当前目录 (), 所欲转换的相对路径, 结果路径))
    }

    方法 连接路径 <公开 静态 类型 = 文本型 注释 = "将两个路径连接起来,返回连接后的结果路径." 返回值注释 = "返回连接结果路径" @视窗.返回参考 = 真>
    参数 所欲连接的路径1 <类型 = 文本型>
    参数 所欲连接的路径2 <类型 = 文本型>
    参数 连接结果路径 <类型 = 文本型 注释 = "用作存放连接后的结果路径">
    {
        @ CVolMem memBuf;
        @ @<连接结果路径>.SetText (LinkOSPath (@<所欲连接的路径1>.GetText (), @<所欲连接的路径2>.GetText (), memBuf, OS_PATH_CHAR));
        返回 (连接结果路径)
    }

    方法 取文件名后缀 <公开 静态 类型 = 文本型 注释 = "返回所指定文件名的后缀名称(注意不以\'.\'字符开头),如果不存在则返回空文本." @嵌入式方法 = "">
    参数 所欲取后缀的文件名 <类型 = 文本型>
    {
        @ CVolString (GetFileExtName (@<所欲取后缀的文件名>.GetText ()))
    }

    方法 改变文件名后缀 <公开 静态 类型 = 文本型 注释 = "改变所指定文件名的后缀名称,然后将其返回." @嵌入式方法 = "">
    参数 所改变后缀的文件名 <类型 = 文本型>
    参数 所改变到的后缀 <类型 = 文本型 注释 = "提供所改变到的后缀名称(注意不以\'.\'字符开头)">
    {
        @ ChangeFileNameExt (@<所改变后缀的文件名>.GetText (), @<所改变到的后缀>.GetText ())
    }

    方法 取文件名路径 <公开 静态 类型 = 文本型 注释 = "如所指定文件名中存在路径部分,将其返回,否则返回空文本." @禁止流程检查 = 真>
    参数 欲取其路径的文件名 <类型 = 文本型>
    {
        @ CVolString strPath;
        @ GetAbsOSPathOfFileName (@<欲取其路径的文件名>.GetText (), strPath);
        @ return strPath;
    }

    方法 取文件名无路径部分 <公开 静态 类型 = 文本型 注释 = "返回所指定文件名的无路径部分" @嵌入式方法 = "">
    参数 所处理的文件名 <类型 = 文本型>
    {
        @ CVolString (GetOSFileNameWithoutPath (@<所处理的文件名>.GetText ()))
    }

    方法 浏览选中文件 <公开 静态 注释 = "调用资源管理器打开指定文件所处的文件夹并将其选中" @嵌入式方法 = "">
    参数 所欲选中的文件名 <类型 = 文本型>
    {
        @ ShellOpenFileInsideFolder (@<所欲选中的文件名>)
    }
}

# ---

类 文件属性 <公开 注释 = "提供文件的各种属性值" @文档 = "category = \"磁盘操作.辅助类\"">
{
    常量 存档文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_ARCHIVE>
    常量 子目录 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_DIRECTORY>
    常量 隐藏文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_HIDDEN>
    常量 通常文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_NORMAL>
    常量 只读文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_READONLY>
    常量 系统文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_SYSTEM>
    常量 临时文件 <公开 类型 = 整数 值 = @FILE_ATTRIBUTE_TEMPORARY>
}

类 文件查找句柄类 <@文档 = "category = \"磁盘操作.辅助类\"" @禁止创建对象 = 真>
{
    方法 类_清理
    {
        关闭 ()
    }

    方法 关闭 <公开>
    {
        如果 (查找句柄 != 0)
        {
            @ ::FindClose ((HANDLE)@<查找句柄>);
            查找句柄 = 0
        }
    }

    变量 查找句柄 <公开 类型 = 变整数>
}

类 文件查找类 <公开 基础类 = 参考对象模板类 注释 = "用作支持查找所指定名称的文件." 注释 = "参考数据中记录当前文件搜寻句柄值,为0表示无."
        注释 = "之所以将文件搜寻句柄值放在参考数据中,是为了支持本对象的复制对象与本对象共享同一句柄." @文档 = "category = \"磁盘操作\"" @模板实现类 = "文件查找句柄类">
{
    方法 找到文件 <公开 定义事件 类型 = 整数 注释 = "  每当找到任何一个文件或目录,在进行\"欲寻找文件的属性\"参数值所指定的" 注释 = "属性匹配检查之前,就会发送此事件."
            返回值注释 = "事件处理方法返回1表示认可此文件并将其返回,返回0表示不进行任何处理.">
    参数 欲寻找文件的属性 <类型 = 整数 注释 = "调用\"寻找文件\"所提供的\"欲寻找文件的属性\"参数值">
    参数 当前文件名称 <类型 = 文本型 注释 = "提供当前所找到的文件或目录的名称">
    参数 当前文件属性 <类型 = 整数 注释 = "  提供当前所找到的文件或目录的属性,为\"文件属性\"类中各个常量值的组合," 注释 = "可以使用\"位与\"关键字分别判断.">

    方法 寻找文件 <公开 类型 = 文本型 注释 = "寻找所指定名称的文件" 返回值注释 = "  成功返回所找到的文件名或目录名,未找到则返回空文本.一旦返回值为空文本,再次调用本方法时,就必须指定"
            返回值注释 = "非空\"欲寻找文件\"参数值.寻找过程中随时可以使用一个新的非空\"欲寻找文件\"参数值来启动新的文件寻找." @禁止流程检查 = 真>
    参数 欲寻找文件 <类型 = 文本型 注释 = "  第一次调用本方法时,本参数内容不能为空,其中支持使用多字符 (*) 和单字符 (?) 通配符,在第一次调用以"
            注释 = "后如果想继续得到其它匹配的文件名,再一次调用本方法且为本参数提供空文本内容." 注释 = "  查找过程中,\".\"和\"..\"子目录将会被始终跳过.">
    参数 欲寻找文件的属性 <类型 = 整数 注释 = "  参数值可以为\"文件属性\"类中各个常量值的和,用作同时指定多个匹配属性.凡是文件具有本参数中所指定的任" 注释 = "一属性,则认为其通过匹配.如果为-1,则匹配除子目录外的所有文件."
            @默认值 = -1>
    参数 欲跳过文件的属性 <类型 = 整数 注释 = "  参数值可以为\"文件属性\"类中各个常量值的和,用作同时指定多个匹配属性.凡是文件具有本参数中所指定的任"
            注释 = "一属性,则认为其未通过匹配(将其跳过). 本参数优先级在\"欲寻找文件的属性\"参数及\"找到文件\"事件之前." 注释 = "  默认值6等于\"文件属性.系统文件 + 文件属性.隐藏文件\"." @默认值 = 6>
    {
        @ BOOL_P blpIsFindNext = IsEmptyStr (@<欲寻找文件>);
        @ WIN32_FIND_DATA infFindData;
        @ BOOL_P blpSucceeded = FALSE;
        @ HANDLE hFileFind = (HANDLE)GetData ().@n<文件查找句柄类.查找句柄>;
        @ while (TRUE)
        @ {
        @     if (blpIsFindNext)
        @         blpSucceeded = (hFileFind == NULL ? FALSE : ::FindNextFile (hFileFind, &infFindData));
        @     else
        @     {
        @         if (hFileFind != NULL)
        @             ::FindClose (hFileFind);
        @         hFileFind = ::FindFirstFile (@<欲寻找文件>.GetText (), &infFindData);
        @         blpSucceeded = (hFileFind != INVALID_HANDLE_VALUE);
        @         if (blpSucceeded == FALSE)
        @             hFileFind = NULL;
        @         blpIsFindNext = TRUE;
        @     }
        @     if (blpSucceeded == FALSE)
        @     {
        @         if (hFileFind != NULL)
        @         {
        @             ::FindClose (hFileFind);
        @             hFileFind = NULL;
        @         }
        @         break;
        @     }
        @     if (((infFindData.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0 && IsDotSubDirName (infFindData.cFileName)) ||  // 为"."或".."目录?
        @             (infFindData.dwFileAttributes & @<欲跳过文件的属性>) != 0)  // 需要被跳过?
        @         continue;
        @     if (@<找到文件> (@<欲寻找文件的属性>, CVolString (infFindData.cFileName), infFindData.dwFileAttributes) == 1 ||
        @             (@<欲寻找文件的属性> == 0 && infFindData.dwFileAttributes == 0) ||
        @             (@<欲寻找文件的属性> == -1 ? (infFindData.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) == 0 : (infFindData.dwFileAttributes & @<欲寻找文件的属性>) != 0))
        @     {
        @         break;
        @     }
        @ }
        @ GetData ().@n<文件查找句柄类.查找句柄> = (INT_P)hFileFind;
        @ return CVolString (blpSucceeded ? infFindData.cFileName : _T (""));
    }

    方法 停止寻找文件 <公开 注释 = "  如果先前启动了文件寻找,调用本方法可以停止寻找." 注释 = "  本方法调用不是必需的,本类对象被清理时会自动停止寻找," 注释 = "但是调用本方法可以提前清理相关所占用的资源." "">
    {
        参考数据.关闭 ()
    }
}

# ===

类 文件打开方式 <公开 注释 = "提供文件的各种打开方式" @文档 = "category = \"文件读写.辅助类\"" @常量类 = 整数>
{
    常量 读入 <公开 值 = 1 注释 = "从指定文件读入数据,如果该文件不存在则失败.">
    常量 写出 <公开 值 = 2 注释 = "写出数据到指定文件,如果该文件不存在则失败.">
    常量 读写 <公开 值 = 3 注释 = "从文件中读入数据或者写出数据到文件,如果该文件不存在则失败.">
    常量 重写 <公开 值 = 4 注释 = "写出数据到指定文件.如果该文件不存在则先创建一个新文件,如果已经存在就先清除其中的所有数据.">
    常量 改写 <公开 值 = 5 注释 = "写出数据到指定文件.如果该文件不存在则创建一个新文件,如果已经存在就直接打开.">
    常量 改读 <公开 值 = 6 注释 = "从文件中读入数据或者写出数据到文件.如果该文件不存在则创建一个新文件,如果已经存在就直接打开.">
}

类 文件共享方式 <公开 注释 = "提供文件在进程之间的各种共享方式" @文档 = "category = \"文件读写.辅助类\"" @常量类 = 整数>
{
    常量 无限制 <公开 值 = 1 注释 = "允许其它进程任意读写此文件">
    常量 禁止读 <公开 值 = 2 注释 = "禁止其它进程读此文件">
    常量 禁止写 <公开 值 = 3 注释 = "禁止其它进程写此文件">
    常量 禁止读写 <公开 值 = 4 注释 = "禁止其它进程读写此文件">
}

类 文件基准位置 <公开 @文档 = "category = \"文件读写.辅助类\"" @常量类 = 整数>
{
    常量 文件首 <公开 值 = @FILE_BEGIN>
    常量 文件尾 <公开 值 = @FILE_END>
    常量 现行位置 <公开 值 = @FILE_CURRENT>
}

类 文件读写句柄类 <@文档 = "category = \"文件读写.辅助类\"" @禁止创建对象 = 真>
{
    方法 类_清理
    {
        关闭 ()
    }

    方法 关闭 <公开>
    {
        如果 (文件句柄 != 0)
        {
            @ ::CloseHandle ((HANDLE)@<文件句柄>);
            文件句柄 = 0
        }
    }

    变量 文件句柄 <公开 类型 = 变整数>
}

类 文件读写类 <公开 基础类 = 参考对象模板类 注释 = "用作支持读写所指定名称的文件." 注释 = "参考数据中记录当前文件被打开后的句柄值,为0表示无."
        注释 = "之所以将文件句柄值放在参考数据中,是为了支持本对象的复制对象与本对象共享同一句柄." @文档 = "category = \"文件读写\"" @模板实现类 = "文件读写句柄类"
        @视窗.外部头文件 = "libs\\win_base\\include\\vol_file_io.h" @视窗.外部源文件 = "libs\\win_base\\cpp\\vol_file_io.cpp">
{
    方法 是否已打开 <公开 类型 = 逻辑型 注释 = "返回是否已经打开了文件">
    {
        返回 (参考数据.文件句柄 != 0)
    }

    方法 取文件句柄 <公开 类型 = 变整数 注释 = "如果当前已经打开了文件,返回其句柄值,否则返回0.">
    {
        返回 (参考数据.文件句柄)
    }

    方法 打开文件 <公开 类型 = 逻辑型 注释 = "打开所指定的文件,以对文件进行读写操作,返回是否打开成功." 注释 = "先前被打开的文件将被自动关闭.">
    参数 欲打开的文件名称 <类型 = 文本型>
    参数 打开方式 <类型 = 文件打开方式 注释 = "提供文件的具体打开方式" @默认值 = 文件打开方式.读写>
    参数 共享方式 <类型 = 文件共享方式 注释 = "指定限制其它进程操作此文件的方式" @默认值 = 文件共享方式.无限制>
    {
        关闭文件 ()  // 首先关闭已经打开的当前文件
        @ const HANDLE hFile = CVolFileProcessor::sOpenFile (@<欲打开的文件名称>.GetText (), @<打开方式>, @<共享方式>);
        @ if (hFile == INVALID_HANDLE_VALUE)
        @     return FALSE;
        @ GetData ().@n<文件读写句柄类.文件句柄> = (INT_P)hFile;
        返回 (真)
    }

    方法 关闭文件 <公开>
    {
        参考数据.关闭 ()
    }

    方法 锁住文件 <公开 类型 = 逻辑型 注释 = "  在有若干个进程访问同一个文件的环境中,使用本方法可以拒绝其它进程" 注释 = "对被打开文件中的某个区域进行读写访问." 注释 = "  文件必须已经被打开,返回是否成功."
            @嵌入式方法 = "">
    参数 欲加锁数据的偏移位置 <类型 = 长整数 注释 = "指定欲加锁区域在文件中的偏移位置">
    参数 欲加锁数据的尺寸 <类型 = 长整数 注释 = "指定欲加锁区域的尺寸,单位字节.">
    参数 加锁重试时间 <类型 = 整数 注释 = "  本参数指定加锁失败后反复进行重试的毫秒数.为0表示一旦失败立即返回," 注释 = "为-1则反复进行重试直到加锁成功为止." @默认值 = 0>
    {
        @ CVolFileProcessor::sLockFile (@sn<this>.GetFileHandle (), @<欲加锁数据的偏移位置>, @<欲加锁数据的尺寸>, @<加锁重试时间>)
    }

    方法 解锁文件 <公开 类型 = 逻辑型 注释 = "解除由\"锁住文件\"命令对文件所进行的锁定,返回是否成功." 注释 = "注意: 本方法调用时所提供的参数值必须与调用\"锁住文件\"方法时所提供的参数值完全一致." @禁止流程检查 = 真>
    参数 欲解锁数据的偏移位置 <类型 = 长整数 注释 = "指定欲解锁区域在文件中的偏移位置">
    参数 欲解锁数据的尺寸 <类型 = 长整数 注释 = "指定欲解锁区域的尺寸,单位字节.">
    {
        @ return ::UnlockFile (GetFileHandle (), (DWORD)@<欲解锁数据的偏移位置>, (DWORD)(@<欲解锁数据的偏移位置> >> 32), (DWORD)@<欲解锁数据的尺寸>, (DWORD)(@<欲解锁数据的尺寸> >> 32));
    }

    方法 移动读写位置 <公开 类型 = 逻辑型 注释 = "设置下一次读或写操作的位置,返回是否成功." @禁止流程检查 = 真>
    参数 基准移动位置 <类型 = 文件基准位置 注释 = "指定从文件中开始移动的基准位置" @默认值 = 文件基准位置.文件首>
    参数 移动距离 <类型 = 长整数 注释 = "指定相对于起始移动位置的移动尺寸,单位字节.">
    {
        @ LARGE_INTEGER dis;
        @ dis.QuadPart = (ULONGLONG)@<移动距离>;
        @ return ::SetFilePointerEx (GetFileHandle (), dis, NULL, (DWORD)@<基准移动位置>);
    }

    方法 移到文件首 <公开 类型 = 逻辑型 注释 = "设置下一次读或写操作的位置到文件首部,返回是否成功." @禁止流程检查 = 真>
    {
        @ return (::SetFilePointer (GetFileHandle (), 0, NULL, FILE_BEGIN) != INVALID_SET_FILE_POINTER);
    }

    方法 移到文件尾 <公开 类型 = 逻辑型 注释 = "设置下一次读或写操作的位置到文件尾部,返回是否成功." @禁止流程检查 = 真>
    {
        @ return (::SetFilePointer (GetFileHandle (), 0, NULL, FILE_END) != INVALID_SET_FILE_POINTER);
    }

    方法 读入字节集 <公开 类型 = 字节集类 注释 = "从文件中当前读写位置读取并返回一段字节集数据,实际读入长度(即所返回字节集的尺寸)可能会小于欲读入长度."
            注释 = "如果读入失败,将返回一个空字节集并且自动将当前文件读写位置移到文件尾部." @嵌入式方法 = "">
    参数 欲读入数据的尺寸 <类型 = 整数>
    {
        @ CVolFileProcessor::sReadBin (@sn<this>.GetFileHandle (), @<欲读入数据的尺寸>, CVolMem ())
    }

    方法 写出字节集 <公开 类型 = 逻辑型 注释 = "写出一个字节集数据到文件中当前读写位置处,返回是否成功." @禁止流程检查 = 真>
    参数 欲写出的字节集数据 <类型 = 字节集类>
    {
        @ return WriteData (@<欲写出的字节集数据>.GetPtr (), @<欲写出的字节集数据>.GetSize ());
    }

    方法 读入文本 <公开 类型 = 文本型 注释 = "  从文件中当前读写位置读取并返回一段文本数据,实际读入长度(即返回文本的尺寸)可能" 注释 = "会小于欲读入长度.如果该数据中存在字符值0或26(文本结束标志),将仅返回该字符之前的"
            注释 = "数据(后续读写将跳过该字符).如果读入失败,将返回一个空文本(注意正常情况下也可能返" 注释 = "回空文本)并且自动将当前文件读写位置移到文件尾部." @嵌入式方法 = "">
    参数 欲读入的最多字符数 <类型 = 整数 注释 = "指定欲读入文本数据的最多字符数目. 注意:如果是UTF-16编码,一个字符将占用两个字节." 注释 = "如果为-1,则读入文件中当前读写位置后的所有文本." @默认值 = -1>
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供欲读入文本数据的字符集编码格式" @默认值 = 文本编码类型.UTF16>
    {
        @ CVolFileProcessor::sReadText (@sn<this>.GetFileHandle (), @<欲读入的最多字符数>, @<文本编码>, NULL, NULL, CVolString ())
    }

    方法 写出文本 <公开 类型 = 逻辑型 注释 = "写出一段文本数据到文件中当前读写位置处,返回是否成功." @嵌入式方法 = "">
    参数 所欲写出的文本 <类型 = 文本型>
    参数 是否写出结束零 <类型 = 逻辑型 注释 = "指定是否在所写出文本后添加写出一个\'\\0\'字符" @默认值 = 假>
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供写出前欲将文本转换到的字符集编码格式" @默认值 = 文本编码类型.UTF16>
    {
        @ CVolFileProcessor::sWriteText (@sn<this>.GetFileHandle (), @<所欲写出的文本>.GetText (), @<是否写出结束零>, @<文本编码>)
    }

    方法 读入一行 <公开 类型 = 文本型 注释 = "从文件中当前读写位置读取并返回一行文本数据,行末的回车及换行符将被抛弃."
            注释 = "如果读入失败,将返回一个空文本(注意正常情况下也可能返回空文本)并且自动将当前文件读写位置移到文件尾部." @嵌入式方法 = "">
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供欲读入文本数据的字符集编码格式" @默认值 = 文本编码类型.UTF16>
    {
        @ CVolFileProcessor::sReadLine (@sn<this>.GetFileHandle (), @<文本编码>, CVolString ())
    }

    方法 写文本行 <公开 类型 = 逻辑型 注释 = "写出一段文本数据并附加\"\\r\\n\"回车换行文本到文件中当前读写位置处,返回是否成功." @嵌入式方法 = "">
    参数 所欲写出的文本 <类型 = 文本型>
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供写出前欲将文本转换到的字符集编码格式" @默认值 = 文本编码类型.UTF16>
    {
        @ CVolFileProcessor::sWriteLine (@sn<this>.GetFileHandle (), @<文本编码>, @<所欲写出的文本>.GetText ())
    }

    方法 读入数据 <公开 类型 = 逻辑型 注释 = "  从文件中当前读写位置读取并返回指定类型的数据,如果读入成功," 注释 = "返回真,否则将返回假并且自动将当前文件读写位置移到文件尾部." @嵌入式方法 = "">
    参数 所读入数据的存储变量 <注释 = "  所读入数据将存放到此变量中,所读入数据的尺寸将由此变量的存" 注释 = "储空间尺寸决定." @需求类型 = 可写入变量 @匹配类型 = 通用非文本基本型>
    {
        @ @sn<this>.ReadData (_VOL_GET_VAR_ADR_AND_SIZE (@<所读入数据的存储变量>))
    }

    方法 写出数据 <公开 类型 = 逻辑型 注释 = "将所指定数据写出到文件中当前读写位置,返回是否成功." @嵌入式方法 = "">
    参数 所欲写出的数据 <注释 = "如欲明确指定其数据类型,可以使用强制类型转换操作符." @匹配类型 = 通用非文本基本型>
    {
        @ @sn<this>.Write_@pdt<所欲写出的数据> (@<所欲写出的数据>)
    }

    方法 读入数组数据 <公开 类型 = 逻辑型 注释 = "  从文件中当前读写位置读取并返回指定类型的数组数据,如果读入成功," 注释 = "返回真,否则将返回假并且自动将当前文件读写位置移到文件尾部." @嵌入式方法 = "">
    参数 所读入数据的存储变量 <注释 = "  所读入数据将存放到此数组变量中,所读入数据的尺寸将由此变量的存" 注释 = "储空间尺寸决定." @需求类型 = 可写入变量 @匹配类型 = 通用非文本基本型数组>
    {
        @ @sn<this>.ReadData (_VOL_GET_ARY_VAR_ADR_AND_SIZE (@<所读入数据的存储变量>))
    }

    方法 写出数组数据 <公开 类型 = 逻辑型 注释 = "将所指定数组数据写出到文件中当前读写位置,返回是否成功." @嵌入式方法 = "">
    参数 所欲写出的数组 <注释 = "所写出数据的尺寸将由此数组变量的存储空间尺寸决定" @匹配类型 = 通用非文本基本型数组>
    {
        @ @sn<this>.WriteData (_VOL_GET_ARY_VAR_ADR_AND_SIZE (@<所欲写出的数组>))
    }

    方法 是否在文件尾 <公开 类型 = 逻辑型 注释 = "返回当前读写位置是否已经处于文件数据的尾部" @嵌入式方法 = "">
    参数 是否为判断文本已读完 <类型 = 逻辑型 注释 = "如果本参数值为真而且下一即将读入的字符值为\'\\0\'或26(文本结束标志)或者当前读写位置已处于文件数据的尾部,方法将返回真." @默认值 = 假>
    参数 文本编码 <类型 = 文本编码类型 注释 = "提供欲检查文本数据的字符集编码格式,仅当\"是否为判断文本已读完\"参数值为真时有效." @默认值 = 文本编码类型.UTF16>
    {
        @ CVolFileProcessor::sIsEof (@sn<this>.GetFileHandle (), @<是否为判断文本已读完>, @<文本编码>)
    }

    方法 取读写位置 <公开 类型 = 长整数 注释 = "返回当前被打开文件的当前读/写位置,位置值从0开始." 注释 = "如果当前尚未打开文件或失败,将返回-1." @禁止流程检查 = 真>
    {
        @ const HANDLE hFile = GetFileHandle ();
        @ return (hFile == NULL ? -1 : CVolFileProcessor::sGetCurrentPos (hFile));
    }

    方法 取文件长度 <公开 类型 = 长整数 注释 = "返回当前被打开文件的长度,单位为字节." 注释 = "如果当前尚未打开文件或失败,将返回-1." @嵌入式方法 = "">
    {
        @ CVolFileProcessor::sGetFileSize (@sn<this>.GetFileHandle ())
    }

    方法 置文件尾 <公开 类型 = 逻辑型 注释 = "针对一个打开的文件,将当前文件读写位置设为文件末尾." @禁止流程检查 = 真>
    {
        @ return (::SetEndOfFile (GetFileHandle ()) != 0);
    }

    # --
    # @begin
    # <> <include>
    # inline_ BOOL Write_S_BYTE (S_BYTE sb)  { return WriteData (&sb, sizeof (sb));    }
    # inline_ BOOL Write_SHORT (SHORT sht)   { return WriteData (&sht, sizeof (sht));  }
    # inline_ BOOL Write_TCHAR (TCHAR ch)    { return WriteData (&ch, sizeof (ch));    }
    # inline_ BOOL Write_INT (INT n)         { return WriteData (&n, sizeof (n));      }
    # inline_ BOOL Write_INT64 (INT64 n64)   { return WriteData (&n64, sizeof (n64));  }
    # inline_ BOOL Write_FLOAT (FLOAT flt)   { return WriteData (&flt, sizeof (flt));  }
    # inline_ BOOL Write_DOUBLE (DOUBLE db)  { return WriteData (&db, sizeof (db));    }
    # inline_ BOOL Write_BOOL (BOOL bl)      { return WriteData (&bl, sizeof (bl));    }
    # HANDLE GetFileHandle ();
    # inline_ BOOL ReadData (void* pData, const INT_P npDataSize)  { return CVolFileProcessor::sReadData (GetFileHandle (), pData, npDataSize); }
    # inline_ BOOL WriteData (const void* pData, const INT_P npDataSize)  { return CVolFileProcessor::sWriteData (GetFileHandle (), pData, npDataSize); }
    # <> </include>
    # HANDLE @sn<current_class>::GetFileHandle ()  { return (HANDLE)GetData ().@n<文件读写句柄类.文件句柄>; }
    # @end
}

