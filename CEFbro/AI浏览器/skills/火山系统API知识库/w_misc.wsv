        @ @<当前对象>.push_back(@<值>)
    }

    方法 删除首成员 <公开 静态 注释 = "删除本列表的首成员" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.pop_front()
    }

    方法 删除尾成员 <公开 静态 注释 = "删除本列表的最后一个成员" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.pop_back()
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回本列表中的成员数目" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    {
        @ (INT)@<当前对象>.size()
    }

    方法 插入成员 <公开 静态 注释 = "在指定索引位置处插入成员">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 索引位置 <类型 = 整数 注释 = "提供欲插入成员的索引位置,必须大于等于0且小于等于列表成员数目.">
    参数 值 <类型 = 模板类型1 注释 = "提供欲插入的成员值">
    {
        @ auto it = @<当前对象>.begin();
        @ std::advance(it, @<索引位置>);
        @ @<当前对象>.insert(it, @<值>);
    }

    方法 插入多个成员 <公开 静态 注释 = "在指定索引位置插入多个相同成员">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 索引位置 <类型 = 整数 注释 = "提供欲插入成员的索引位置,必须大于等于0且小于等于列表成员数目.">
    参数 插入数量 <类型 = 整数>
    参数 值 <类型 = 模板类型1>
    {
        @ auto it = @<当前对象>.begin();
        @ std::advance(it, @<索引位置>);
        @ @<当前对象>.insert(it,@<插入数量> ,@<值>);
    }

    方法 插入列表到首部 <公开 静态 注释 = "插入一个列表到当前列表首部">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲插入的列表 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.insert (@<当前对象>.begin(), @<欲插入的列表>.begin(), @<欲插入的列表>.end());
    }

    方法 加入列表 <公开 静态 注释 = "将指定列表内容添加到当前列表尾部">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲添加的列表 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.insert (@<当前对象>.end(), @<欲添加的列表>.begin(), @<欲添加的列表>.end());
    }

    方法 移动列表到首部 <公开 静态 注释 = "将指定列表的所有内容移动到本列表首部">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲移动的列表 <类型 = 标准列表模板类 注释 = "注意: 移动后此列表内容将清空">
    {
        @ @<当前对象>.splice(@<当前对象>.begin(), @<欲移动的列表>);
    }

    方法 移动列表到尾部 <公开 静态 注释 = "将指定列表的所有内容移动到本列表尾部">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲移动的列表 <类型 = 标准列表模板类 注释 = "注意: 移动后此列表内容将清空">
    {
        @ @<当前对象>.splice(@<当前对象>.end(), @<欲移动的列表>);
    }

    方法 删除成员 <公开 静态 注释 = "删除列表中的成员">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 起始索引 <类型 = 整数 注释 = "提供欲删除成员的起始索引位置,必须大于等于0且小于列表成员数目.">
    参数 删除成员数量 <类型 = 整数 注释 = "提供欲删除成员的数目" @默认值 = 1>
    {
        @ if (@<删除成员数量> <=  0)  return;
        @ auto start = @<当前对象>.begin();
        @ std::advance (start, @<起始索引>);
        @ if (start == @<当前对象>.end())  return;
        @ if (@<删除成员数量> == 1)  { @<当前对象>.erase (start); return; }
        @ auto end = @<当前对象>.begin();
        @ std::advance (end, @<起始索引> + @<删除成员数量>);
        @ @<当前对象>.erase (start, end);
    }

    方法 交换所有成员 <公开 静态 注释 = "将当前列表的内容和另外一个列表的内容进行交换" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲交换的列表 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.swap(@<欲交换的列表>)
    }

    方法 重置成员数 <公开 静态 注释 = "重置当前列表的成员数量,如果新的成员数小于当前成员数,则多余的成员数会被删除." @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 新成员数 <类型 = 整数>
    {
        @ @<当前对象>.resize(@<新成员数>)
    }

    方法 重置列表 <公开 静态 注释 = "重置当前列表的成员数量,并设置新增成员的初始值.">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 新成员数 <类型 = 整数>
    参数 初始值 <类型 = 模板类型1 注释 = "提供新增成员的初始值">
    参数 清空内容 <类型 = 逻辑型 注释 = "是否清空原有内容" @默认值 = 真>
    {
        如果 (清空内容)
        {
            @ @<当前对象>.assign (@<新成员数>, @<初始值>);
        }
        否则
        {
            @ @<当前对象>.resize (@<新成员数>,@<初始值>);
        }
    }

    方法 删除所有成员 <公开 静态 注释 = "删除列表中的当前所有成员" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.clear()
    }

    方法 删除匹配成员 <公开 静态 注释 = "删除列表中所有等于指定值的成员" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲删除的值 <类型 = 模板类型1 注释 = "列表中所有等于该值的成员都将被删除">
    {
        @ @<当前对象>.remove (@<欲删除的值>)
    }

    方法 删除连续重复成员 <公开 静态 注释 = "删除列表中所有连续重复的成员,只保留其中的一个." @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类>
    {
        @ @<当前对象>.unique ()
    }

    方法 排序合并 <公开 静态 注释 = "排序两个列表并将两者内容合并到当前列表">
    参数 当前对象 <类型 = 标准列表模板类>
    参数 欲合并的列表 <类型 = 标准列表模板类 注释 = "合并后本列表将清空">
    {
        当前对象.排序 ()
        欲合并的列表.排序 ()
        @ @<当前对象>.merge (@<欲合并的列表>);
    }

    方法 反转 <公开 静态 注释 = "反转当前列表中成员的排列顺序" @嵌入式方法 = "">
    参数 当前对象 <类型 = 标准列表模板类 "">
    {
        @ @<当前对象>.reverse ()
    }

    方法 排序 <公开 静态 注释 = "对列表中的所有成员进行排序">
    参数 当前对象 <类型 = 标准列表模板类 "">
    参数 从小到大排序 <类型 = 逻辑型 注释 = "为真表示从小到大进行排序,为假表示从大到小进行排序." @默认值 = 真>
    {
        @ if (@<从小到大排序>)
        @    @<当前对象>.sort ();
        @ else
        @    @<当前对象>.sort([](@dt<模板类型1> a, @dt<模板类型1> b) { return a > b; });
    }
}

类 文本标准列表类 <公开 基础类 = 标准列表模板类 @文档 = "category = \"数据处理.标准列表\"" @模板实现类 = "文本型">

类 整数标准列表类 <公开 基础类 = 标准列表模板类 @文档 = "category = \"数据处理.标准列表\"" @模板实现类 = "整数">

