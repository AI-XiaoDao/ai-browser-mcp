<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.高性能键值表 <注释 = "采用腾讯开源的MMKV高性能键值表库." 注释 = "  https://github.com/tencent/mmkv" @视窗.外部头文件 = "mmkv\\MMKVTool.h"
        @视窗.附属文件.win32 = "mmkv\\win32\\MMKVToolx86.dll" @视窗.附属文件.x64 = "mmkv\\x64\\MMKVToolx64.dll"
        @视窗.外部库.win32 = "mmkv\\win32\\MMKVToolx86.lib" @视窗.外部库.x64 = "mmkv\\x64\\MMKVToolx64.lib">

类 高性能键值表事件 <公开 注释 = "全局只能定义一个" @文档 = "category = \"辅助类\"" @视窗.后缀文本 = "CMMKVEventBase">
{

    # @begin
    # <> <include>
    # virtual void ContentChangeHandler(const char* lpszmmapID)
    # {
    #     @<内容变化>(CVolString (lpszmmapID));
    # }
    # virtual int ErrorHandler(const char* lpszmmapID, int errorType)
    # {
    #     return @<遇到错误>(CVolString (lpszmmapID),errorType);
    # }
    # virtual void LogHandler(int level, const char* file, int line, const char* function, const char* message)
    # {
    #     @<日志内容>(level,CVolString (file),line,CVolString (file),CVolString (file));
    # }
    # <> </include>
    # @end

    常量 启用日志 <公开 类型 = 整数 值 = 1 注释 = "事件类型常量">
    常量 启用遇到错误 <公开 类型 = 整数 值 = 2 注释 = "事件类型常量">
    常量 启用内容变化 <公开 类型 = 整数 值 = 4 注释 = "事件类型常量">

    方法 类_初始化
    {
        @ MMKVTool_BindEventClass(this);
    }

    方法 启用事件 <公开 注释 = "是否启用键值表事件监听." @嵌入式方法 = "">
    参数 事件类型 <类型 = 整数 注释 = "事件类型共有3个：" 注释 = "   高性能键值表事件.启用日志" 注释 = "   高性能键值表事件.启用遇到错误" 注释 = "   高性能键值表事件.启用内容变化"
            注释 = " 如果要同时启用三个事件,可以将其相加起来." @默认值 = 7>
    参数 是否启用 <类型 = 逻辑型 @默认值 = 真>
    {
        @ MMKVTool_EnableEvent(@<事件类型>,@<是否启用>)
    }

    方法 内容变化 <公开 定义事件 类型 = 整数 注释 = "当内容被改变时触发本事件.">
    参数 表名称 <类型 = 文本型 注释 = "返回被改变的表名称">

    方法 遇到错误 <公开 定义事件 类型 = 整数 注释 = "遇到错误时触发本事件." 返回值注释 = "返回0表示终止,返回1表示恢复.">
    参数 表名称 <类型 = 文本型 注释 = "返回表名称">
    参数 错误类型 <类型 = 整数 注释 = "返回0表示循环冗余校验码(CRC)出错,返回1表示获取文件长度失败.">

    方法 日志内容 <公开 定义事件 类型 = 整数 注释 = "产生日志时触发本事件.">
    参数 日志等级 <类型 = 高性能键值表日志 注释 = "返回日志等级">
    参数 文件名称 <类型 = 文本型 注释 = "返回文件名称">
    参数 行号 <类型 = 整数 注释 = "返回行号">
    参数 函数名称 <类型 = 文本型 注释 = "返回名称">
    参数 消息内容 <类型 = 文本型 注释 = "返回消息内容">
}

类 高性能键值表日志 <公开 注释 = "用于存储高性能键值表日志等级" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 调试 <公开 值 = 0>
    常量 信息 <公开 值 = 1>
    常量 警告 <公开 值 = 2>
    常量 错误 <公开 值 = 3>
    常量 无 <公开 值 = 4>
}

类 高性能键值表 <公开 注释 = "腾讯开源项目(MMKV)高性能键值表">
{

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CVolMMKVWapper)
    # <> <include>
    # inline_ void* GetData()
    # {
    #     return data().GetData();
    # }
    # inline_ void SetData(void * pData)
    # {
    #     data().SetData(pData);
    # }
    # <> </include>
    # @end

    方法 置保存路径 <公开 静态 注释 = "设置数据存储路径,在使用键值表之前必须首先设置数据目录." 注释 = "注意: 本路径为全局路径,在所有高性能键值表对象中共享." @嵌入式方法 = "">
    参数 目录 <类型 = 文本型>
    {
        @ MMKVTool_InitDataPath(@<目录>)
    }

    常量 单进程模式 <公开 类型 = 整数 值 = 1 注释 = "本常量用于打开方法.">
    常量 多进程模式 <公开 类型 = 整数 值 = 2 注释 = "本常量用于打开方法.">

    方法 打开 <公开 注释 = "打开一个数据表,一个键值表对象只能打开一个表,想要操作多个键值表需要定义多个键值表变量." @禁止流程检查 = 真>
    参数 表名称 <类型 = 文本型 注释 = "类似数据库的表名称,如果为空,则打开默认的表" @默认值 = "">
    参数 模式 <类型 = 整数 注释 = "参考本类中的常量值,提供\"高性能键值表.单进程模式\"或\"高性能键值表.多进程模式\"." @默认值 = 单进程模式>
    参数 加密密码 <类型 = 文本型 注释 = "可空" @默认值 = "">
    {
        关闭 ()
        @ SetData( MMKVTool_Open( @<表名称>.IsEmpty () ? NULL : (const char*)CU8String (@<表名称>.GetText ()).GetText()  ,@<模式>, @<加密密码>.IsEmpty () ? NULL : (const char*)CU8String (@<加密密码>.GetText ()).GetText()  ) );
    }

    方法 关闭 <公开 静态 注释 = "关闭被打开的表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ @<所欲操作的本对象>.data().Close()
    }

    方法 取键数量 <公开 静态 类型 = 长整数 注释 = "取出当前键值表的键数量" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_Count(@<所欲操作的本对象>.GetData())
    }

    方法 取总大小 <公开 静态 类型 = 长整数 注释 = "取出当前表总大小" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_TotalSize(@<所欲操作的本对象>.GetData())
    }

    方法 取实际大小 <公开 静态 类型 = 长整数 注释 = "取当前表实际大小" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_ActualSize(@<所欲操作的本对象>.GetData())
    }

    方法 是否存在表 <公开 类型 = 逻辑型 注释 = "判断指定表名是否存在" @禁止流程检查 = 真>
    参数 表名称 <类型 = 文本型>
    参数 相对路径 <类型 = 文本型 @默认值 = "">
    {
        @ return MMKVTool_isFileValid((const char*)CU8String (@<表名称>.GetText ()).GetText(),(@<相对路径>.IsEmpty () ? NULL : @<相对路径>.GetText()));
    }

    方法 是否存在键 <公开 静态 类型 = 逻辑型 注释 = "判断当前表是否存在指定键名" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_IsExist(@<所欲操作的本对象>.GetData(),CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 删除键 <公开 静态 注释 = "删除指定键" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_RemoveValue(@<所欲操作的本对象>.GetData(),CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 清空 <公开 静态 注释 = "清空当前表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_ClearALL(@<所欲操作的本对象>.GetData())
    }

    方法 清空缓存 <公开 静态 注释 = "清理垃圾数据,释放空间,数据过多时防止表越来越大." @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_Trim(@<所欲操作的本对象>.GetData())
    }

    方法 锁定 <公开 静态 注释 = "锁定当前表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_Lock(@<所欲操作的本对象>.GetData())
    }

    方法 解锁 <公开 静态 注释 = "解锁当前表" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    {
        @ MMKVTool_UnLock(@<所欲操作的本对象>.GetData())
    }

    方法 置入逻辑值 <公开 静态 类型 = 逻辑型 注释 = "将指定的逻辑值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 逻辑型 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetBool(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>)
    }

    方法 取逻辑值 <公开 静态 类型 = 逻辑型 注释 = "取出指定键名所对应的逻辑值" 返回值注释 = "返回逻辑值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_GetBool(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 置入整数值 <公开 静态 类型 = 逻辑型 注释 = "将指定的整数值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 整数 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetInt32(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>)
    }

    方法 取整数值 <公开 静态 类型 = 整数 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_GetInt32(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 置入长整数值 <公开 静态 类型 = 逻辑型 注释 = "将指定的长整数值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 长整数 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetInt64(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>)
    }

    方法 取长整数值 <公开 静态 类型 = 长整数 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_GetInt64(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 置入小数值 <公开 静态 类型 = 逻辑型 注释 = "将指定的小数值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 小数 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetDouble(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>)
    }

    方法 取小数值 <公开 静态 类型 = 小数 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        @ MMKVTool_GetDouble(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText())
    }

    方法 置入文本值 <公开 静态 类型 = 逻辑型 注释 = "将指定的文本值置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 文本型 注释 = "提供要置入的键值">
    {
        @ MMKVTool_SetString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),(const char*)CU8String (@<值>.GetText ()).GetText())
    }

    方法 取文本值 <公开 静态 类型 = 文本型 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        变量 返回值 <类型 = 文本型>
        @ const char* pText = MMKVTool_GetString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText());
        @ if (pText != NULL)
        @ { 
        @     @<返回值>.SetText (pText);
        @     MMKVTool_FreeString (pText);
        @ }
        返回 (返回值)
    }

    方法 置入字节集 <公开 静态 类型 = 逻辑型 注释 = "将指定的字节集置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型 注释 = "提供键名">
    参数 值 <类型 = 字节集类 注释 = "提供要置入的键值">
    {
        @ return MMKVTool_SetBin(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),(void*)@<值>.GetPtr(),(int)@<值>.GetSize());
    }

    方法 取字节集 <公开 静态 类型 = 字节集类 注释 = "取出指定键名所对应的键值" 返回值注释 = "返回键值" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    {
        变量 结果变量 <类型 = 字节集类>
        取字节集2 (所欲操作的本对象, 键名称, 结果变量)
        返回 (结果变量)
    }

    方法 取字节集2 <公开 静态 注释 = "取出指定键名所对应的键值" @禁止流程检查 = 真>
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    参数 结果存储变量 <类型 = 字节集类 注释 = "用作保存所获取的字节集数据">
    {
        @ @<结果存储变量>.Free ();
        @ int nDataSize = 0;
        @ const char* pb = MMKVTool_GetBin(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),&nDataSize);
        @ if (pb != NULL && nDataSize > 0)
        @ {
        @     @<结果存储变量>.Append (pb,nDataSize);
        @     MMKVTool_FreeBin (pb);
        @ }
    }

    方法 置入数组值 <公开 静态 类型 = 逻辑型 注释 = "将指定的文本数组置入,当前键值表内指定名称键所对应的值中." 返回值注释 = "返回是否成功" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    参数 值 <类型 = 高性能文本数组类>
    {
        @ MMKVTool_SetVectorString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<值>.GetData())
    }

    方法 取数组值 <公开 静态 注释 = "通过键名取出文本数组" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 键名称 <类型 = 文本型>
    参数 用来保存文本数组 <类型 = 高性能文本数组类 注释 = "结果保存在此参数中">
    {
        @ MMKVTool_GetVectorString(@<所欲操作的本对象>.GetData(),(const char*)CU8String (@<键名称>.GetText ()).GetText(),@<用来保存文本数组>.GetData())
    }

    方法 取所有键名 <公开 静态 注释 = "取出当前表中所有键名" @嵌入式方法 = "">
    参数 所欲操作的本对象 <类型 = 高性能键值表>
    参数 数组 <类型 = 高性能文本数组类 注释 = "结果保存在此参数中">
    {
        @ MMKVTool_GetAllKey(@<所欲操作的本对象>.GetData(),@<数组>.GetData())
    }
}

类 高性能文本数组类 <公开 注释 = "此类可以配合\"高性能键值表\"使用,也可以单独使用,作用和\"文本数组类\"一致,但性能更高.">
{

    # @begin
    # <> <include>
    # inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)
    # {
    #     MMKVVectorStringTool_CopyConstruct(m_pData,objCopyFrom.m_pData);
    # }
    # public:
    # inline_ void* GetData()
    # {
    #     return m_pData;
    # }
    # void* m_pData;
    # <> </include>
    # @end

    方法 类_初始化
    {
        @ m_pData = MMKVVectorStringTool_New();
    }

    方法 类_清理
    {
        @ MMKVVectorStringTool_Delete(m_pData);
    }

    方法 取成员数 <公开 静态 类型 = 整数 注释 = "返回当前已有成员数目" @嵌入式方法 = "">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    {
        @ MMKVVectorStringTool_GetCount(@<欲操作的本对象>.GetData())
    }

    方法 取成员 <公开 静态 类型 = 文本型 注释 = "返回所指定索引位置处的成员值" @禁止流程检查 = 真>
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 索引 <类型 = 整数 注释 = "提供所欲操作成员的索引位置,必须大于等于0且小于数组成员数目.">
    {
        @ CVolString str;
        如果 (索引 >= 0 && 索引 < 欲操作的本对象.取成员数 ())
        {
            @ str.SetText (MMKVVectorStringTool_GetString(@<欲操作的本对象>.GetData(),@<索引>));
        }
        @ return str;
    }

    方法 加入成员 <公开 静态 注释 = "将一个文本型的成员值加入到本数组的尾部">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲添加成员值 <类型 = 文本型 注释 = "提供要添加到成员">
    {
        @ MMKVVectorStringTool_PushString(@<欲操作的本对象>.GetData(),(const char*) CU8String (@<所欲添加成员值>.GetText ()).GetText());
    }

    方法 删除成员 <公开 静态 注释 = "删除数组中所指定索引位置处的成员">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 索引 <类型 = 整数 注释 = "提供所欲删除成员的索引位置,必须大于等于0且小于等于数组成员数目.">
    {
        如果 (索引 >= 0 && 索引 < 欲操作的本对象.取成员数 ())
        {
            @ MMKVVectorStringTool_Erase(@<欲操作的本对象>.GetData(),@<索引>);
        }
    }

    方法 删除所有成员 <公开 静态 注释 = "删除当前数组中所有成员" @嵌入式方法 = "">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    {
        @ MMKVVectorStringTool_Clear(@<欲操作的本对象>.GetData())
    }

    方法 添加数组 <公开 静态 注释 = "将另一个高性能文本数组中的内容添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲添加的数组 <类型 = 高性能文本数组类>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
        }
    }

    方法 添加文本数组 <公开 静态 注释 = "将另一个文本数组中的内容添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲添加的数组 <类型 = 文本数组类>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
        }
    }

    方法 对比删除重复成员 <公开 静态 注释 = "将本数组中在\"所欲检查的数组\"内已经存在的成员删除掉">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲检查的数组 <类型 = 高性能文本数组类 注释 = "提供用作检查重复成员的文本数组">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        逆向计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (所欲检查的数组.查找首成员 (欲操作的本对象.取成员 (取循环索引 ()), 是否区分大小写) != -1)
            {
                欲操作的本对象.删除成员 (取循环索引 ())
            }
        }
    }

    方法 查找删除成员 <公开 静态 类型 = 逻辑型 注释 = "查找第一个等于所指定值的成员,如果找到则将其删除并返回真,否则返回假.">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲查找文本 <类型 = 文本型 注释 = "提供所欲查找并删除的成员值">
    {
        计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (欲操作的本对象.取成员 (取循环索引 ()) == 所欲查找文本)
            {
                欲操作的本对象.删除成员 (取循环索引 ())
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 添加数组独有成员 <公开 静态 注释 = "将另一个文本数组中在本数组内不存在的成员添加到本数组尾部">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲添加的数组 <类型 = 高性能文本数组类>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        计次循环 (所欲添加的数组.取成员数 ())
        {
            如果 (欲操作的本对象.查找首成员 (所欲添加的数组.取成员 (取循环索引 ()), 是否区分大小写) == -1)
            {
                欲操作的本对象.加入成员 (所欲添加的数组.取成员 (取循环索引 ()))
            }
        }
    }

    方法 查找首成员 <公开 静态 类型 = 整数 注释 = "正向查找等于所指定值的第一个成员,找到返回其索引位置,未找到返回-1.">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (文本比较 (欲操作的本对象.取成员 (取循环索引 ()), 所欲查找的成员值, 是否区分大小写) == 0)
            {
                返回 (取循环索引 ())
            }
        }
        返回 (-1)
    }

    方法 查找尾成员 <公开 静态 类型 = 整数 注释 = "逆向查找等于所指定值的最后一个成员,找到返回其索引位置,未找到返回-1.">
    参数 欲操作的本对象 <类型 = 高性能文本数组类>
    参数 所欲查找的成员值 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定判断文本是否相等时是否区分英文字母的大小写" @默认值 = 真>
    {
        逆向计次循环 (欲操作的本对象.取成员数 ())
        {
            如果 (文本比较 (欲操作的本对象.取成员 (取循环索引 ()), 所欲查找的成员值, 是否区分大小写) == 0)
            {
                返回 (取循环索引 ())
            }
        }
        返回 (-1)
    }
}
