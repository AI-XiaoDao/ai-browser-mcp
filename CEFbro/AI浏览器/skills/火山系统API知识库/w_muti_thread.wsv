<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "提供线程操作支持相关类" @文档 = "category = \"多线程\"">

类 互斥锁类 <公开 基础类 = 参考对象类 注释 = "用作加锁同时只能一个线程进入的关键段区域. 本线程锁可以重入.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CMMutex)

    方法 加锁 <公开 类型 = 逻辑型 注释 = "将本互斥锁加锁,如果本锁当前已经被另一线程锁住,则进入等待状态." 返回值注释 = "见\"是否仅尝试\"参数说明" @嵌入式方法 = "">
    参数 是否仅尝试 <类型 = 逻辑型 注释 = "  如果本参数值为真,则会尝试加锁,如果能够成功加锁,则加锁后返回真,如果不" 注释 = "能(譬如已经被其它线程锁住)则立即返回假."
            注释 = "  如果本参数值为假,则无限等待直到能够成功加锁,此时本方法始终返回真." @默认值 = 假>
    {
        @ (BOOL)@sn<this>.data ().lock (@<是否仅尝试>)
    }

    方法 解锁 <公开 注释 = "如果先前加锁成功,解开此锁,以允许其它线程加锁成功." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().unlock ()
    }
}

# ===

类 信号灯类 <公开 基础类 = 参考对象类 注释 = "用作在线程之间基于一个信号灯值进行同步,信号灯的初始值为0. 本线程锁可以重入.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CMSemaphore)

    方法 等待 <公开 类型 = 逻辑型 注释 = "如果当前信号灯值大于0,则将其减去1后返回." 返回值注释 = "见\"是否仅尝试\"参数说明" @嵌入式方法 = "">
    参数 是否仅尝试 <类型 = 逻辑型 注释 = "  如果本参数值为真,则只测试下信号灯值,如果值大于0," 注释 = "则将其减1后立即成功返回真,否则立即返回假." 注释 = "  如果本参数值为假,则无限等待直到信号值大于0,然后"
            注释 = "将其减1返回真." @默认值 = 假>
    {
        @ (BOOL)@sn<this>.data ().wait (@<是否仅尝试>)
    }

    方法 限时等待 <公开 类型 = 逻辑型 注释 = "  等待指定的毫秒数,直到信号值大于0,然后将其减1返回真." 注释 = "如果在所指定的时间内信号灯值一直小于等于0,则返回假." @嵌入式方法 = "">
    参数 最大等待时间 <类型 = 整数 注释 = "指定所欲等待的最多毫秒数,必须大于等于0.">
    {
        @ (BOOL)@sn<this>.data ().wait_timeout (@<最大等待时间>)
    }

    方法 放行 <公开 注释 = "将信号灯值加1,从而允许一个正在等待加锁信号灯的线程成功通过." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().post ()
    }

    方法 重置 <公开 注释 = "将信号灯值重置为0" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().reset ()
    }

    方法 取句柄 <公开 类型 = 变整数 注释 = "返回本对象所对应的Windows句柄值" @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.data ().GetHandle ()
    }
}

# ===

类 同步事件类 <公开 基础类 = 参考对象类 注释 = "用作在线程之间基于一个逻辑型的事件值进行同步,该事件值初始为假. 本线程锁可以重入.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CSyncEvent)

    方法 等待 <公开 类型 = 逻辑型 注释 = "如果当前事件值为真,则将其重置为假后返回." 返回值注释 = "见\"是否仅尝试\"参数说明" @嵌入式方法 = "">
    参数 是否仅尝试 <类型 = 逻辑型 注释 = "如果本参数值为真,且事件值为真,则将其重置为假后立即返回真,否则立即返回假." 注释 = "如果本参数值为假,则无限等待直到事件值为真,然后将其重置为假后返回真." @默认值 = 假>
    {
        @ (BOOL)@sn<this>.data ().wait (@<是否仅尝试>)
    }

    方法 限时等待 <公开 类型 = 逻辑型 注释 = "  等待指定的毫秒数,直到事件值为真,然后将其重置为假后返回真." 注释 = "如果在所指定的时间内事件值一直为假,则返回假." @嵌入式方法 = "">
    参数 最大等待时间 <类型 = 整数 注释 = "指定所欲等待的最多毫秒数,必须大于等于0.">
    {
        @ (BOOL)@sn<this>.data ().wait_timeout (@<最大等待时间>)
    }

    方法 放行 <公开 注释 = "将当前事件值设置为真,从而允许一个正在等待此事件的线程成功通过,然后立即将事件值重置为假." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().post ()
    }

    方法 重置 <公开 注释 = "将事件值重置为假" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().reset ()
    }

    方法 取句柄 <公开 类型 = 变整数 注释 = "返回本对象所对应的Windows句柄值" @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.data ().GetHandle ()
    }
}

# ===

类 读写锁类 <公开 基础类 = 参考对象类 注释 = "  用作支持多个线程读,单个线程写." 注释 = "  读写锁的特点: 任何时候,如果有写线程成功加锁,那么其它读/写线程都将不能再加锁(欲加锁将进入等待状态),"
        注释 = "如果有读线程成功加锁,那么其它写线程将不能加锁(欲加锁将进入等待状态),但是其它读线程能够成功加锁.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CMReadWriteLock)

    方法 开始读 <公开 注释 = "读线程调用本方法用作加锁以开始进行读操作,如果不能加锁,将一直等待." 注释 = "注意: 本方法返回后即表示当前线程获得了读权力,读操作完毕后必须调用\"结束读\"方法释放锁." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().LockRead ()
    }

    方法 结束读 <公开 注释 = "  先前调用\"开始读\"方法成功加锁的读线程必须调用" 注释 = "本方法结束读操作,以放行其它等待操作的线程." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().UnLockRead ()
    }

    方法 开始写 <公开 注释 = "写线程调用本方法用作加锁以开始进行写操作,如果不能加锁,将一直等待." 注释 = "注意: 本方法返回后即表示当前线程获得了写权力,写操作完毕后必须调用\"结束写\"方法释放锁." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().LockWrite ()
    }

    方法 结束写 <公开 注释 = "  先前调用\"开始写\"方法成功加锁的写线程必须调用" 注释 = "本方法结束写操作,以放行其它等待操作的线程." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().UnLockWrite ()
    }
}

# ===

类 简单完成端口信息 <公开>
{
    变量 信息码 <公开 类型 = 整数 注释 = "本成员对应 GetQueuedCompletionStatus 的 lpNumberOfBytes 参数.">
    变量 参数1 <公开 类型 = 变整数 注释 = "本成员对应 GetQueuedCompletionStatus 的 lpCompletionKey 参数.">
    变量 参数2 <公开 类型 = 变整数 注释 = "本成员对应 GetQueuedCompletionStatus 的 lpOverlapped 参数.">
}

类 简单完成端口类 <公开 基础类 = 参考对象类 注释 = "  本类实现了一个简单的基于完成端口(IOCP)的线程通讯类," 注释 = "用作在多线程之间传递简单数据使用.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CSimpleCompletionPort)

    方法 创建 <公开 类型 = 逻辑型 注释 = "创建完成端口,返回是否成功." 注释 = "如果先前已经创建了完成端口,将会自动被销毁." @嵌入式方法 = "">
    参数 所欲绑定文件句柄 <类型 = 变整数 注释 = "提供所欲绑定到完成端口的文件句柄值,为-1表示无." @默认值 = -1>
    参数 绑定到完成端口句柄 <类型 = 变整数 注释 = "提供所欲绑定到的完成端口句柄,为0表示无." @默认值 = 0>
    参数 用户参数 <类型 = 变整数 注释 = "将在\"等待\"方法的\"简单完成端口信息.参数1\"中返回." 注释 = "本参数对应 CreateIoCompletionPort 的 CompletionKey 参数." @默认值 = 0>
    {
        @ (BOOL)@sn<this>.data ().Create (@<所欲绑定文件句柄>, @<绑定到完成端口句柄>, @<用户参数>)
    }

    方法 销毁 <公开 注释 = "销毁所已经创建的完成端口." 注释 = "本方法调用不是必需的,本类对象销毁时,会自动销毁已创建的完成端口." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Cleanup ()
    }

    方法 取句柄 <公开 类型 = 变整数 注释 = "返回所已经创建的完成端口句柄,返回0表示尚未创建." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetHandle ()
    }

    方法 投递 <公开 类型 = 逻辑型 注释 = "在本完成端口对象上投递所指定的信息,返回是否成功." 注释 = "注意: 调用本方法之前必须已经成功创建." @嵌入式方法 = "">
    参数 信息码 <类型 = 整数 注释 = "本参数对应 PostQueuedCompletionStatus 的 dwNumberOfBytesTransferred 参数." @默认值 = 0>
    参数 参数1 <类型 = 变整数 注释 = "本参数对应 PostQueuedCompletionStatus 的 CompletionKey 参数." @默认值 = 0>
    参数 参数2 <类型 = 变整数 注释 = "本参数对应 PostQueuedCompletionStatus 的 lpOverlapped  参数." @默认值 = 0>
    {
        @ (BOOL)@sn<this>.data ().post (@<参数1>, @<参数2>, @<信息码>)
    }

    方法 投递2 <公开 类型 = 逻辑型 注释 = "在本完成端口对象上投递所指定的信息,返回是否成功." 注释 = "注意: 调用本方法之前必须已经成功创建.">
    参数 所欲投递的信息 <类型 = 简单完成端口信息>
    {
        返回 (投递 (所欲投递的信息.信息码, 所欲投递的信息.参数1, 所欲投递的信息.参数2))
    }

    方法 等待 <公开 类型 = 逻辑型 注释 = "等待本完成端口对象上通过\"投递\"/\"投递2\"方法发送过来信息,返回是否成功." 注释 = "注意: 调用本方法之前必须已经成功创建." @禁止流程检查 = 真>
    参数 所接收到的信息 <类型 = 简单完成端口信息 注释 = "当本方法返回真时,用作存储所获得的信息(由\"投递\"/\"投递2\"方法发送)">
    参数 最大等待时间 <类型 = 整数 注释 = "指定所欲等待的最多毫秒数,为-1表示无限等待." @默认值 = -1>
    {
        @ return (BOOL)data ().wait (&@<所接收到的信息.参数1>, &@<所接收到的信息.参数2>, &@<所接收到的信息.信息码>, @<最大等待时间>);
    }
}

# ===

类 线程优先级 <公开 注释 = "提供线程的优先级别,类中的常量按优先级从小到大顺序排列." @文档 = "category = \"多线程.辅助类\"" @常量类 = 整数>
{
    常量 空闲 <公开 值 = @THREAD_PRIORITY_IDLE>
    常量 通常低 <公开 值 = @THREAD_PRIORITY_BELOW_NORMAL>
    常量 通常 <公开 值 = @THREAD_PRIORITY_NORMAL>
    常量 通常高 <公开 值 = @THREAD_PRIORITY_ABOVE_NORMAL>
    常量 高 <公开 值 = @THREAD_PRIORITY_HIGHEST>
    常量 关键 <公开 值 = @THREAD_PRIORITY_TIME_CRITICAL>
}

类 线程状态类 <公开 基础类 = 参考对象类 注释 = "提供线程的当前状态,并提供相关操作支持." 注释 = "本类中的所有方法均支持在多线程环境中使用.">
{

    # @ @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CVolThreadState)

    方法 置用户对象1 <公开 注释 = "设置所欲保存到本对象中的用户对象1,先前所存在用户对象1将被覆盖." @嵌入式方法 = "">
    参数 所欲设置对象 <类型 = 对象类 注释 = "  本参数对象的内容将被复制到本对象中的用户对象1,如果为\"空对象\"" 注释 = "(\"是否为空对象\"全局方法返回真),则先前所存在用户对象1将被删除." "">
    {
        @ @sn<this>.data ().SetUserVolObject (0, @<所欲设置对象>)
    }

    方法 取用户对象1 <公开 类型 = 逻辑型 注释 = "  如果所提供欲填入对象的实际数据类型匹配本对象中所保存用户对象1的实际" 注释 = "数据类型(为其实际数据类型或基础类),则将本对象中所保存用户对象1的内容"
            注释 = "复制到\"所欲填入对象\"参数对象中后返回真,否则失败返回假." 注释 = "  如果本对象中尚未置入用户对象1,将返回假." @嵌入式方法 = "">
    参数 结果获取对象 <类型 = 对象类 注释 = "  提供欲将所获取的用户对象1数据填入的对象,其实际数据类型需要与本对象中" 注释 = "所保存用户对象1的实际数据类型匹配(为其实际数据类型或基础类).">
    {
        @ (BOOL)@sn<this>.data ().GetUserVolObject (0, @<结果获取对象>)
    }

    方法 置用户对象2 <公开 注释 = "设置所欲保存到本对象中的用户对象2,先前所存在用户对象2将被覆盖." @嵌入式方法 = "">
    参数 所欲设置对象 <类型 = 对象类 注释 = "  本参数对象的内容将被复制到本对象中的用户对象2,如果为\"空对象\"" 注释 = "(\"是否为空对象\"全局方法返回真),则先前所存在用户对象2将被删除." "">
    {
        @ @sn<this>.data ().SetUserVolObject (1, @<所欲设置对象>)
    }

    方法 取用户对象2 <公开 类型 = 逻辑型 注释 = "  如果所提供欲填入对象的实际数据类型匹配本对象中所保存用户对象2的实际" 注释 = "数据类型(为其实际数据类型或基础类),则将本对象中所保存用户对象2的内容"
            注释 = "复制到\"所欲填入对象\"参数对象中后返回真,否则失败返回假." 注释 = "  如果本对象中尚未置入用户对象2,将返回假." @嵌入式方法 = "">
    参数 结果获取对象 <类型 = 对象类 注释 = "  提供欲将所获取的用户对象2数据填入的对象,其实际数据类型需要与本对象中" 注释 = "所保存用户对象2的实际数据类型匹配(为其实际数据类型或基础类).">
    {
        @ (BOOL)@sn<this>.data ().GetUserVolObject (1, @<结果获取对象>)
    }

    方法 置用户值 <公开 注释 = "设置欲保存到本对象中的用户变整数值" @嵌入式方法 = "">
    参数 所欲设置的值 <类型 = 变整数>
    {
        @ @sn<this>.data ().m_npUserData = @<所欲设置的值>
    }

    方法 取用户值 <公开 类型 = 变整数 注释 = "返回所保存到本对象中的用户变整数值" @嵌入式方法 = "">
    {
        @ @sn<this>.data ().m_npUserData
    }

    方法 是否正在运行 <公开 类型 = 逻辑型 注释 = "返回所绑定线程是否处于正在运行状态" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().IsRunning ()
    }

    方法 通知并等待线程退出 <公开 类型 = 逻辑型 注释 = "  本方法只能在所绑定线程以外的线程中执行,用作通知并等待所绑定线程退出."
            注释 = "  为了支持本方法,所绑定线程必须尽可能快地频繁调用\"线程是否被通知退出\"方法,一旦发现" 注释 = "该方法返回真,则需要尽快结束线程的执行,否则本方法在无限等待的时候将进入死等状态."
            注释 = "  注意: 一旦使用本机制,在所绑定线程中不允许对窗口界面直接进行操作,否则可能导致死锁." 返回值注释 = "返回线程是否已经退出" @嵌入式方法 = "">
    参数 最大等待时间 <类型 = 整数 注释 = "指定最大等待线程退出的时间(单位毫秒),为-1表示无限等待,为0表示不等待." @默认值 = -1>
    {
        @ (BOOL)@sn<this>.data ().WaitThreadExit (@<最大等待时间>)
    }

    方法 线程是否被通知退出 <公开 类型 = 逻辑型 注释 = "  本方法只能在所绑定线程中执行,一旦发现本方法返回真,必须尽快结束线程的执行,否则将导"
            注释 = "致另一线程中的\"通知并等待线程退出\"方法调用在进行无限等待时进入死等状态." 注释 = "  本方法用作和\"通知并等待线程退出\"方法配套使用,如果外部线程中不会调用"
            注释 = "\"通知并等待线程退出\"方法,则亦无需调用本方法检查是否退出." 注释 = "  注意: 一旦使用本机制,在所绑定线程中不允许对窗口界面直接进行操作,否则可能导致死锁." 返回值注释 = "返回线程是否需要尽快退出"
            @嵌入式方法 = "">
    参数 最大检查等待时间 <类型 = 整数 注释 = "指定检查线程是否需要退出的最大等待时间(单位毫秒),为-1表示无限等待,为0表示不等待." @默认值 = 0>
    {
        @ (BOOL)@sn<this>.data ().IsNeedExit (@<最大检查等待时间>)
    }
}

# ===

类 线程操作类 <公开 注释 = "提供线程的相关操作功能支持" @全局类 = 真>
{
    常量 等待超时 <公开 类型 = 整数 值 = @"@(WAIT_TIMEOUT - WAIT_OBJECT_0)" 注释 = "用作表示等待事件已经超时">

    方法 等待多个事件 <公开 静态 类型 = 整数 注释 = "  同时等待多个多线程同步事件,如果其中任何一个事件等待通过或所指定的等待时" 注释 = "间达到,则返回."
            返回值注释 = "  如果任意一个事件成功等待通过,返回该事件句柄在\"事件句柄数组\"参数中的索引位置," 返回值注释 = "如果等待时间超时,返回\"线程操作类.等待超时\"常量值." @嵌入式方法 = "">
    参数 事件句柄数组 <类型 = "变整数 []" 注释 = "提供所欲等待的所有事件的句柄值,可以为\"信号灯类\"或\"同步事件类\"的\"取句柄\"的返回值.">
    参数 最大等待时间 <类型 = 整数 注释 = "指定所欲等待的最多毫秒数,为-1表示无限等待." @默认值 = -1>
    {
        @ (INT)::WaitForMultipleObjects (_WAITTING_EVENT_HANDLE_ARRAY (@<事件句柄数组>), FALSE, (DWORD)@<最大等待时间>) - (INT)WAIT_OBJECT_0
    }

    方法 线程模板函数1 <静态 类型 = 整数 注释 = "提供线程执行函数的模板方法" 返回值注释 = "返回值未被使用">
    参数 用户参数 <类型 = 变整数 注释 = "为启动线程线程时所提供的用户参数值">
    {
        返回 (0)
    }

    方法 启动线程 <公开 静态 类型 = 逻辑型 注释 = "启动一个线程" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 线程函数 <注释 = "提供所欲执行的线程函数" @匹配方法 = "线程模板函数1">
    参数 用户参数 <类型 = 变整数 注释 = "提供传递到线程函数的用户参数值" @默认值 = 0>
    参数 堆栈尺寸 <类型 = 整数 注释 = "提供线程所使用的堆栈尺寸,单位字节.为0表示使用默认尺寸." @默认值 = 0>
    参数 优先级 <类型 = 线程优先级 注释 = "提供线程的优先级别" @默认值 = 线程优先级.通常>
    参数 是否等待线程执行完毕 <类型 = 逻辑型 注释 = "指定本方法是否一直等待线程执行完毕后才会返回" @默认值 = 假>
    {
        @ (BOOL)VolBeginThread ((LPTHREAD_START_ROUTINE)&@<线程函数>, @<用户参数>, @<堆栈尺寸>, @<优先级>, @<是否等待线程执行完毕>)
    }

    方法 线程模板函数2 <静态 注释 = "提供线程执行函数的模板方法">
    参数 线程状态对象 <类型 = 线程状态类 注释 = "  为调用\"启动有状态线程\"方法时所提供的\"线程状态对象\"参数对象内容," 注释 = "用作在线程中通过对其进行相关操作.">

    方法 启动有状态线程 <公开 静态 类型 = 逻辑型 注释 = "启动一个绑定有对应\"线程状态类\"状态对象的线程" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 线程状态对象 <类型 = 线程状态类 注释 = "  本参数对象将与所启动线程绑定,用作对所启动线程进行相关操作." 注释 = "如果本参数对象已经与另一线程绑定且该线程处于正在运行状态,本" 注释 = "方法将失败返回假.">
    参数 线程函数 <注释 = "提供所欲执行的线程函数" @匹配方法 = "线程模板函数2">
    参数 堆栈尺寸 <类型 = 整数 注释 = "提供线程所使用的堆栈尺寸,单位字节.为0表示使用默认尺寸." @默认值 = 0>
    参数 优先级 <类型 = 线程优先级 注释 = "提供线程的优先级别" @默认值 = 线程优先级.通常>
    {
        @ (BOOL)@dt<线程操作类>::sVolBeginThreadWithState (@<线程状态对象>, (@dt<线程操作类>::FN_VOL_THREAD_MAIN)&@<线程函数>, @<堆栈尺寸>, @<优先级>)
    }

    方法 取主线程ID <公开 静态 类型 = 整数 注释 = "返回当前程序的主线程(即启动线程)ID" @嵌入式方法 = "">
    {
        @ g_objVolApp.GetMainThreadID ()
    }

    方法 取当前线程ID <公开 静态 类型 = 整数 注释 = "返回当前线程的ID值" @嵌入式方法 = "">
    {
        @ (INT)::GetCurrentThreadId ()
    }

    方法 是否为主线程 <公开 静态 类型 = 逻辑型 注释 = "返回当前线程是否为程序的主线程" @嵌入式方法 = "">
    {
        @ g_objVolApp.GetMainThreadID () == (INT)::GetCurrentThreadId ()
    }

    方法 取当前进程ID <公开 静态 类型 = 整数 注释 = "返回当前进程的ID值" @嵌入式方法 = "">
    {
        @ (INT)::GetCurrentProcessId ()
    }

    # --
    #
    # @begin
    # <> <include>
    # typedef void (CALLBACK *FN_VOL_THREAD_MAIN) (@dt<线程状态类>& objThreadState);
    # static BOOL_P sVolBeginThreadWithState (@dt<线程状态类>& objThreadState, FN_VOL_THREAD_MAIN fnThreadMain, INT_P npStackSize, INT_P npPriority);
    # <> </include>
    #
