    # {
    #     const VOL_THREAD_STARTUP_PARAM* pParam = (VOL_THREAD_STARTUP_PARAM*)pUserData;
    #     ASSERT_R_ADR (pParam, sizeof (VOL_THREAD_STARTUP_PARAM));
    #
    #     @dt<线程状态类> objState;
    #     objState.CopyFrom (*pParam->m_pobjState);
