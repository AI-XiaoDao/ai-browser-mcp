类 主线程处理器 <公开 注释 = "本类用作在其它线程中发送通知消息到程序的主UI线程中处理" @视窗.后缀文本 = "public IVolNoticeReceiver">
{
    方法 接收到通知 <公开 定义事件 类型 = 整数 注释 = "在其它线程中调用本对象的\"发送通知\"/\"投递通知\"方法后,本事件将被触发." 注释 = "本事件的接收方法将始终在程序的UI主线程中执行."
            注释 = "本事件中的参数值为调用\"发送通知\"/\"投递通知\"方法时所提供的对应参数值." 返回值注释 = "如果本事件由\"发送通知\"方法调用触发,事件处理方法的返回值将返回到\"发送通知\"方法的调用方.">
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数 注释 = "如果本事件由\"投递通知\"方法调用触发,本参数值将始终为0.">

    方法 发送通知 <公开 类型 = 整数 注释 = "  从其它线程发送通知到本对象,本对象的\"接收到通知\"事件将在" 注释 = "程序主线程中触发以处理该通知."
            注释 = "  本方法将等待本对象的\"接收到通知\"事件处理完毕后才会返回." 返回值注释 = "  返回\"接收到通知\"事件处理方法的返回值,如果发送通知失败," 返回值注释 = "将返回0(注意即使成功接收到通知,也可能返回0)."
            @禁止流程检查 = 真>
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    {
        @ INT_P npResult;
        @ Notify (@<通知码>, @<参数1>, @<参数2>, &npResult);
        @ return (INT)npResult;
    }

    方法 投递通知 <公开 注释 = "  从其它线程投递通知到本对象,本对象的\"接收到通知\"事件将稍后在" 注释 = "程序主线程中触发以处理该通知." 注释 = "  本方法调用后会立即返回,并不会等待本对象的\"接收到通知\"事件处"
            注释 = "理完毕,因此请确保调用本方法时所提供的参数能够在\"接收到通知\"事" 注释 = "件处理方法中保持有效." @嵌入式方法 = "">
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    {
        @ @sn<this>.Post (@<通知码>, @<参数1>)
    }

    # @ <include>
    # @ virtual INT_P OnNotify (INT_P npCode, INT_P npParam1, INT_P npParam2) override  { return @<接收到通知> (npCode, npParam1, npParam2); }
    # @ </include>
}

# ---

类 高级主线程处理器 <公开 注释 = "本类用作在其它线程中发送通知消息到程序的主UI线程中处理" @视窗.后缀文本 = "public IVolAdvNoticeReceiver">
{

    # 事件 --

    方法 接收到通知 <公开 定义事件 类型 = 整数 注释 = "在其它线程中调用本对象的\"发送通知\"/\"投递通知\"方法后,本事件将被触发." 注释 = "本事件的接收方法将始终在程序的UI主线程中执行."
            注释 = "本事件中的参数值为调用\"发送通知\"/\"投递通知\"方法时所提供的对应参数值." 返回值注释 = "如果本事件由\"发送通知\"方法调用触发,事件处理方法的返回值将返回到\"发送通知\"方法的调用方.">
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数>
    参数 参数2 <类型 = 变整数>
    参数 参数对象 <类型 = 对象包装类 注释 = "包装中为发送/投递通知时所提供对象的复制对象,如果未提供则为空(\"参数对象.是否为空\"方法返回真).">

    # 属性 --

    方法 通知保留时间 <公开 属性读 类型 = 整数 注释 = "  返回被投递(调用\"投递通知\"方法)通知的最大保留时间(单位毫秒)," 注释 = "为0表示永远保留直到投递成功." @嵌入式方法 = "">
    {
        @ @sn<this>.GetMaxPostedNoticeKeepTime ()
    }

    方法 通知保留时间 <公开 属性写 注释 = "  设置被投递(调用\"投递通知\"方法)通知的最大保留时间(单位毫秒)," 注释 = "超过最大保留时间尚未投递成功的通知将被自动删除,为0表示永远保"
            注释 = "留直到投递成功. 默认值为1000毫秒.">
    参数 欲设置属性值 <类型 = 整数>
    {
        @ SetMaxPostedNoticeKeepTime (@<欲设置属性值>);
    }

    # 方法 --

    方法 发送通知 <公开 类型 = 整数 注释 = "  从其它线程发送通知到本对象,本对象的\"接收到通知\"事件将在程序主线" 注释 = "程中触发以处理该通知."
            注释 = "  本方法将等待本对象的\"接收到通知\"事件处理完毕后才会返回." 返回值注释 = "  返回\"接收到通知\"事件处理方法的返回值,如果发送通知失败,将返回0(注" 返回值注释 = "意即使成功接收到通知,也可能返回0)."
            @禁止流程检查 = 真>
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    参数 参数对象 <类型 = 对象类 注释 = "提供欲传递到\"接收到通知\"事件的\"参数对象\"参数内容,为空对象表示无." @默认值 = 空对象>
    {
        @ CRefObjectWithData<CVolWrapperObject> obj;
        @ if (@<参数对象>.IsNullObject () == FALSE)
        @     obj.m_data.SetVolObject (@<参数对象>);
        @ INT_P npResult;
        @ SendNotice (@<通知码>, @<参数1>, @<参数2>, &obj, &npResult);
        @ return (INT)npResult;
    }

    方法 投递通知 <公开 注释 = "  从其它线程投递通知到本对象,本对象的\"接收到通知\"事件将稍后在程" 注释 = "序主线程中触发以处理该通知. 本方法调用后会立即返回,并不会等待本" 注释 = "对象的\"接收到通知\"事件处理完毕."
            注释 = "  被投递通知如果在\"通知保留时间\"属性所指定的时间内未投递成功,将" 注释 = "被销毁不再投递.">
    参数 通知码 <类型 = 变整数>
    参数 参数1 <类型 = 变整数 注释 = "  如果本参数为指向外部数据的指针,请确保此数据在\"接收到通知\"事件" 注释 = "触发时依旧有效." @默认值 = 0>
    参数 参数2 <类型 = 变整数 注释 = "  如果本参数为指向外部数据的指针,请确保此数据在\"接收到通知\"事件" 注释 = "触发时依旧有效." @默认值 = 0>
    参数 参数对象 <类型 = 对象类 注释 = "提供欲传递到\"接收到通知\"事件的\"参数对象\"参数内容,为空对象表示无." 注释 = "本参数对象将被自动创建一个同内容复制对象,因此无需保持其一直有效." @默认值 = 空对象>
    {
        @ CRefObjectWithData<CVolWrapperObject>* pObject = new CRefObjectWithData<CVolWrapperObject>;
        @ if (@<参数对象>.IsNullObject () == FALSE)
        @     pObject->m_data.SetVolObject (@<参数对象>);
        @ PostNotice (@<通知码>, @<参数1>, @<参数2>, pObject);
        @ pObject->Release ();
    }

    # @ <include>
    # @ virtual INT_P OnNotify (INT_P npCode, INT_P npParam1, INT_P npParam2, CRefObject* pParamObject) override  {
    # @     return @<接收到通知> (npCode, npParam1, npParam2, ((CRefObjectWithData<CVolWrapperObject>*)pParamObject)->m_data);
    # @ }
    # @ </include>
}

