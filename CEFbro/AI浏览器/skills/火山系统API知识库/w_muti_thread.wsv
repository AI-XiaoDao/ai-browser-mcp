类 线程类 <公开 基础类 = 参考对象类 注释 = "  用作封装一个单独的线程." 注释 = "  注意: 当本类对象被销毁(譬如离开其作用域)时,将自动调用本对象的\"停止\"方法通知"
        注释 = "本对象中的线程结束运行并等待对应的\"线程运行\"事件处理方法执行完毕.如果此时对应" 注释 = "的\"线程运行\"事件处理方法中没有及时检查处理本对象的\"是否需要退出\"方法,程序将进" 注释 = "入死锁状态.">
{
    方法 启动 <公开 类型 = 逻辑型 注释 = "启动本对象中的线程,开始执行其\"线程运行\"事件的处理方法." 注释 = "如果线程当前正在运行,将会直接返回真." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 堆栈尺寸 <类型 = 整数 注释 = "提供线程所使用的堆栈尺寸,单位字节.为0表示使用默认尺寸." @默认值 = 0>
    {
        @ return (BOOL)data ().Start ((VOL_THREAD_FUNC)@sn<current_class>::sThreadFunc, this, @<堆栈尺寸>);
    }

    方法 是否正在运行 <公开 类型 = 逻辑型 注释 = "返回本对象中的线程是否处于正在运行状态" @嵌入式方法 = "">
    {
        @ (BOOL)@sn<this>.data ().IsRunning ()
    }

    方法 停止 <公开 注释 = "  本方法只能在本对象中线程以外的线程(譬如主线程)中执行,用作通知并等待本对象的对" 注释 = "应\"线程运行\"事件处理方法执行完毕退出."
            注释 = "  为了支持本方法,本对象的对应\"线程运行\"事件处理方法中必须尽可能快地频繁调用本对" 注释 = "象的\"是否需要退出\"方法,一旦发现该方法返回真,则需要尽快结束执行并返回,否则本方法" 注释 = "将进入死等状态."
            @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Exit ()
    }

    方法 通知停止 <公开 注释 = "  本方法只能在本对象中线程以外的线程(譬如主线程)中执行,用作通知本对象的对应" 注释 = "\"线程运行\"事件处理方法执行完毕退出."
            注释 = "  本方法与\"停止\"方法不同之处在于,本方法仅仅发出退出通知而不会一直等待其退出." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().PostExitNotify ()
    }

    方法 是否需要退出 <公开 类型 = 逻辑型 注释 = "  本方法只能在本对象的线程(即对应\"线程运行\"事件处理方法)中执行,一旦" 注释 = "发现本方法返回真,必须尽快结束\"线程运行\"事件处理方法的执行并返回,否"
            注释 = "则将导致另一线程中的\"停止\"方法调用进入死等状态." 返回值注释 = "返回线程是否需要尽快退出" @嵌入式方法 = "">
    参数 最大检查等待时间 <类型 = 整数 注释 = "  指定检查线程退出通知(由\"停止\"或\"通知停止\"方法发出)的最大等待" 注释 = "时间(单位毫秒),为0表示不等待,为-1表示一直等待." @默认值 = 10>
    {
        @ (BOOL)@sn<this>.data ().IsNeedExit (@<最大检查等待时间>)
    }

    方法 线程运行 <公开 定义事件 类型 = 整数 注释 = "用户需要接收并处理本事件以执行所需要的功能,该事件处理方法将在一个单独的线程中运行." 注释 = "注意:"
            注释 = "  1. 在本事件的接收处理方法中,必须尽可能快地频繁调用本对象的\"是否需要退出\"方法," 注释 = "一旦发现该方法返回真,则需要尽快结束执行并返回,否则将导致另一线程中的\"停止\"方法调用" 注释 = "进入死等状态;"
            注释 = "  2. 在本事件的接收处理方法中不允许对窗口界面直接进行操作,否则可能导致死锁.">

    # @begin
    # @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CVolThread)
    # <> <include>
    # static void sThreadFunc (void* param, volatile const BOOL_P* pblpExit, HANDLE hExitEventOnWindows)  { ((@sn<current_class>*)param)->@<线程运行> (); }
    # void @an<_OnBeforeCleanup> ()  { data ().PostExitNotify (); }
    # <> </include>
    # @end
}

# ===

类 全局线程池 <公开 注释 = "用作提供对全局线程池的相关操作." 注释 = "注意本类中的方法除了\"是否需要退出\"均只能在主线程中执行.">
{
    方法 置最多空闲线程数 <公开 静态 注释 = "设置最多能同时保留的空闲线程数目,超出所指定数目的空闲线程将被释放." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    参数 最多空闲线程数 <类型 = 整数 注释 = "  提供最多能同时保留的空闲线程数目,为0表示使用默认值(根据计算机中当" 注释 = "前CPU计算核心的数目自动选择).">
    {
        @ g_objVolApp.GetThreadPool ().SetMaxNumIdleThreads (@<最多空闲线程数>)
    }

    方法 置最大允许空闲时间 <公开 静态 注释 = "设置线程最大允许空闲时间(单位毫秒),超出所指定时间的空闲线程将被释放." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    参数 最大允许空闲时间 <类型 = 整数 注释 = "提供线程最大允许空闲时间(单位毫秒),为0表示使用默认值16000毫秒.">
    {
        @ g_objVolApp.GetThreadPool ().SetMaxThreadIdleInterval (@<最大允许空闲时间>)
    }

    方法 更新 <公开 静态 注释 = "更新线程池,可以在需要时手动调用本方法进行更新." 注释 = "线程池更新时主要做以下工作:" 注释 = "  1. 检查删除线程池中所有超出最大空闲时间的线程;"
            注释 = "  2. 检查删除线程池中所保留的过多数目空闲线程." 注释 = "本方法调用不是必需的,对于MFC/WTL界面应用程序,系统会自动在系统空闲时调用本方法." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    参数 是否立即更新 <类型 = 逻辑型 注释 = "为真立即更新,为假则首先检查距上次更新是否超过了所指定时间,如已经超过则更新,未超过则不更新." 注释 = "在系统空闲时手动调用本方法时可以提供为假,以避免过于频繁地操作." @默认值 = 真>
    {
        @ g_objVolApp.GetThreadPool ().UpdatePool (@<是否立即更新>)
    }

    方法 清理 <公开 静态 注释 = "清理线程池的内容,停止并销毁本线程池中的所有线程(包括正在运行或空闲的线程)." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    {
        @ g_objVolApp.GetThreadPool ().Cleanup ()
    }

    方法 线程模板函数 <静态 注释 = "提供用户线程函数的模板方法">
    参数 线程句柄 <类型 = 变整数 注释 = "提供所启动线程在线程池中的句柄值,必定不为0.">
    参数 用户参数1 <类型 = 变整数 注释 = "提供启动时传递到线程函数的用户参数值1">
    参数 用户参数2 <类型 = 变整数 注释 = "提供启动时传递到线程函数的用户参数值2">
    参数 退出事件 <类型 = 变整数 注释 = "本参数普通用户无需使用">

    方法 启动线程 <公开 静态 类型 = 变整数 注释 = "创建并启动一个新线程,该线程会优先从线程池的空闲线程中提取使用." 注释 = "注意:"
            注释 = "  1. 在所提供用户线程函数执行完毕后,该线程将会被自动释放进线程池中,此时对应句柄值将自然永久失效;" 注释 = "  2. 如果所提供用户线程函数启动后一直在执行,可以调用\"停止线程\"方法通知用户线程函数停止执行."
            注释 = "  3. 本方法只能在主线程中执行." 返回值注释 = "成功返回所创建线程的非0句柄值,失败返回0." @嵌入式方法 = "">
    参数 线程函数 <注释 = "提供所欲执行的用户线程函数." 注释 = "注意:" 注释 = "  1. 在该用户线程函数中,必须尽可能快地频繁调用本对象的\"是否需要退出\"方法,一旦发现该方法返回真,"
            注释 = "则需要尽快结束执行并返回,否则将导致另一线程中的\"停止\"方法调用进入死等状态;" 注释 = "  2. 在该用户线程函数中不允许对窗口界面直接进行操作,否则可能导致死锁." @匹配方法 = "线程模板函数">
    参数 用户参数1 <类型 = 变整数 注释 = "提供传递到用户线程函数的用户参数值1" @默认值 = 0>
    参数 用户参数2 <类型 = 变整数 注释 = "提供传递到用户线程函数的用户参数值2" @默认值 = 0>
    {
        @ (INT_P)g_objVolApp.GetThreadPool ().StartNewThread ((VOL_POOL_THREAD_FUNC)@<线程函数>, (UINT_P)@<用户参数1>, (UINT_P)@<用户参数2>)
    }

    方法 停止线程 <公开 静态 注释 = "等待所指定线程的用户线程函数执行完毕,然后将该线程放进线程池用作以后使用." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数 注释 = "提供所欲停止的由\"启动线程\"方法返回的线程句柄值.如果该句柄值为0或已经自然失效,将返回不进行任何处理.">
    {
        @ g_objVolApp.GetThreadPool ().StopThread ((HVOLTHREAD)@<线程句柄>)
    }

    方法 是否正在运行 <公开 静态 类型 = 逻辑型 注释 = "返回所指定线程是否正在运行." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数 注释 = "提供所欲检查的由\"启动线程\"方法返回的线程句柄值.如果该句柄值为0或已经自然失效,将返回假.">
    {
        @ (BOOL)g_objVolApp.GetThreadPool ().IsThreadRunning ((HVOLTHREAD)@<线程句柄>)
    }

    方法 是否需要退出 <公开 静态 类型 = 逻辑型 注释 = "  本方法只能在\"启动线程\"方法所启动线程的用户线程函数中执行,一旦发现本方法返回真," 注释 = "用户线程函数必须尽快结束执行并返回,否则将导致程序卡死."
            返回值注释 = "返回线程是否需要尽快退出" @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数 注释 = "提供由\"启动线程\"方法返回的线程句柄值.如果该句柄值为0或已经自然失效,本方法将始终返回真.">
    参数 最大检查等待时间 <类型 = 整数 注释 = "指定检查线程是否需要退出的最大等待时间(单位毫秒),为0表示不等待,为-1表示一直等待." @默认值 = 10>
    {
        @ (BOOL)g_objVolApp.GetThreadPool ().IsThreadNeedBreak ((HVOLTHREAD)@<线程句柄>, @<最大检查等待时间>)
    }

    方法 取调试展示内容 <公开 静态 类型 = 文本型 注释 = "将全局线程池中的当前内容用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "本方法仅在调试版本中具有作用,非调试版本将返回空文本."
            注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    {
        @ g_objVolApp.GetThreadPool ().DebugGetDumpString (CVolString ())
    }

    方法 启用调试跟踪 <公开 静态 注释 = "  在对全局线程池进行操作时,调用本方法以在调试版本下启用" 注释 = "即时在火山开发环境调试窗口中显示相关操作跟踪信息." @视窗.预定义宏 = "_TRACE_VOL_THREAD_POOL">
}

# ---

类 缓存线程类 <公开 基础类 = 参考对象类 注释 = "支持自动在全局线程池中缓存的线程." 注释 = "注意:" 注释 = "  1. 当调用\"启动\"方法的本类对象被销毁(譬如离开其作用域)时,将自动调用本对象"
        注释 = "的\"停止\"方法通知本对象中的线程结束运行并等待对应的\"线程运行\"事件处理方法执行" 注释 = "完毕.如果此时对应的\"线程运行\"事件处理方法中没有及时检查处理本对象的\"是否需要"
        注释 = "退出\"方法,程序将进入死锁状态;" 注释 = "  2. 本类中的方法除了\"是否需要退出\"均只能在主线程中执行.">
{
    方法 启动 <公开 类型 = 逻辑型 注释 = "启动本对象中的线程,开始执行其\"线程运行\"事件的处理方法.如果线程当前正在运行,将会将其先停止." 注释 = "注意本方法只能在主线程中执行." 返回值注释 = "成功返回真,失败返回假."
            @禁止流程检查 = 真>
    参数 用户参数 <类型 = 变整数 注释 = "提供传递到\"线程运行\"事件方法的用户参数值" @默认值 = 0>
    {
        停止 ()
        @ const HVOLTHREAD hThread = g_objVolApp.GetThreadPool ().StartNewThread ((VOL_POOL_THREAD_FUNC)sThreadFunc, (UINT_P)this, (UINT_P)@<用户参数>);
        @ if (hThread != NULL) {
        @     data ().init (hThread, this);
        @     return TRUE;
        @ }
        @ return FALSE;
    }

    方法 停止 <公开 注释 = "  通知并等待本对象的对应\"线程运行\"事件处理方法执行完毕退出." 注释 = "  为了支持本方法,本对象的对应\"线程运行\"事件处理方法中必须尽可能快地频繁调用本对象的"
            注释 = "\"是否需要退出\"方法,一旦发现该方法返回真,则需要尽快结束执行并返回,否则本方法将进入死等状态." 注释 = "  注意本方法只能在主线程中执行.">
    {
        @ if (data ().m_hThreadHandle != 0) {
        @     g_objVolApp.GetThreadPool ().StopThread (data ().m_hThreadHandle);
        @     data ().init ();
        @ }
    }

    方法 是否正在运行 <公开 类型 = 逻辑型 注释 = "返回本对象的线程是否正在运行." 注释 = "注意本方法只能在主线程中执行." @嵌入式方法 = "">
    {
        @ (BOOL)g_objVolApp.GetThreadPool ().IsThreadRunning (@sn<this>.data ().m_hThreadHandle)
    }

    方法 是否需要退出 <公开 静态 类型 = 逻辑型 注释 = "  本方法只能在本对象的线程(即对应\"线程运行\"事件处理方法)中执行,一旦" 注释 = "发现本方法返回真,必须尽快结束\"线程运行\"事件处理方法的执行并返回,否"
            注释 = "则将导致另一线程中的\"停止\"方法调用进入死等状态." 返回值注释 = "返回线程是否需要尽快退出" @嵌入式方法 = "">
    参数 线程句柄 <类型 = 变整数 注释 = "需要提供在\"线程运行\"事件中提供过来的\"线程句柄\"参数值">
    参数 最大检查等待时间 <类型 = 整数 注释 = "  指定检查线程退出通知(由\"停止\"方法发出)的最大等待时间(单位毫秒)," 注释 = "为0表示不等待,为-1表示一直等待." @默认值 = 10>
    {
        @ (BOOL)g_objVolApp.GetThreadPool ().IsThreadNeedBreak (@<线程句柄>, @<最大检查等待时间>)
    }

    方法 线程运行 <公开 定义事件 类型 = 整数 注释 = "用户需要接收并处理本事件以执行所需要的功能,该事件处理方法将在一个单独的线程中运行." 注释 = "注意:"
            注释 = "  1. 在本事件的接收处理方法中,必须尽可能快地频繁调用本对象的\"是否需要退出\"方法," 注释 = "一旦发现该方法返回真,则需要尽快结束执行并返回,否则将导致另一线程中的\"停止\"方法调用" 注释 = "进入死等状态;"
            注释 = "  2. 在本事件的接收处理方法中不允许对窗口界面直接进行操作,否则可能导致死锁.">
    参数 线程句柄 <类型 = 变整数 注释 = "提供所启动线程在线程池中的句柄值,必定不为0.">
    参数 用户参数 <类型 = 变整数 注释 = "提供启动时传递到线程函数的用户参数值">
    参数 退出事件 <类型 = 变整数 注释 = "本参数普通用户无需使用">

    # @begin
    # @m<DECLARE_DERIVED_REF_OBJECT_CLASS_WITH_DATA> (CVolPoolThreadInfo)
    # <> <include>
    # static void CALLBACK sThreadFunc (HVOLTHREAD hVolThread, UINT_P upParam1, UINT_P upParam2, HANDLE hBreakEvent)  { ((@sn<current_class>*)upParam1)->@<线程运行> ((INT_P)hVolThread, (INT_P)upParam2, (INT_P)hBreakEvent); }
    # void @an<_OnBeforeCleanup> ();
    # <> </include>
    # @ void @sn<current_class>::@an<_OnBeforeCleanup> ()  {
    # @     if (data ().m_hThreadHandle != 0 && data ().m_pOwnerObject == this)  { 
    # @         g_objVolApp.GetThreadPool ().StopThread (data ().m_hThreadHandle);
    # @         data ().init ();
    # @     }
    # @ }
    # @end
}

#
