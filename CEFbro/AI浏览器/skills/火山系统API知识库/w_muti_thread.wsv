类 基本原子类型模板类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "本类用作支持在多线程中以原子的方式访问数据(即在同一时间只有一个线程能够访问该数据)." 注释 = "原子模板类."
        注释 = "  模板类型1: 值数据类型,仅支持非文本型基本类型实现." @视窗.外部头文件 = "<atomic>" @模板基础类 = 真 @输出到部件 = 假>
{
    方法 是否无锁 <公开 属性读 类型 = 逻辑型 注释 = "如果当前原子对象上的原子操作是无锁的,返回真,否则返回假." @嵌入式方法 = "">
    {
        @ @sn<this>.m_atomic.is_lock_free()
    }

    方法 取值 <公开 类型 = 模板类型1 注释 = "原子取值" @嵌入式方法 = "">
    {
        @ @sn<this>.m_atomic.load()
    }

    方法 置值 <公开 注释 = "原子置值" @嵌入式方法 = "">
    参数 欲写入值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_atomic.store(@<欲写入值>)
    }

    方法 替换值 <公开 类型 = 模板类型1 注释 = "原子替换当前原子数据的值" 返回值注释 = "返回被替换之前的值" @嵌入式方法 = "">
    参数 新值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_atomic.exchange(@<新值>)
    }

    方法 加 <公开 类型 = 模板类型1 注释 = "原子加法运算,将当前值与指定加数相加,当前对象中的值替换为运算结果." 返回值注释 = "返回运算之前的值" @嵌入式方法 = "">
    参数 加数 <类型 = 模板类型1 注释 = "提供加数">
    {
        @ @sn<this>.m_atomic.fetch_add(@<加数>)
    }

    方法 减 <公开 类型 = 模板类型1 注释 = "原子减法运算,将当前值与指定加数相减,当前对象中的值替换为运算结果." 返回值注释 = "返回运算之前的值" @嵌入式方法 = "">
    参数 减数 <类型 = 模板类型1 注释 = "提供减数">
    {
        @ @sn<this>.m_atomic.fetch_sub(@<减数>)
    }

    方法 按位与 <公开 类型 = 模板类型1 注释 = "原子位运算,将当前值的每一位指定值的对应位进行与操作,当前对象中的值替换为运算结果." 返回值注释 = "返回运算之前的值" @嵌入式方法 = "">
    参数 运算值 <类型 = 模板类型1 注释 = "提供所欲与其进行位运算的值">
    {
        @ @sn<this>.m_atomic.fetch_and(@<运算值>)
    }

    方法 按位或 <公开 类型 = 模板类型1 注释 = "原子位运算,将当前值的每一位指定值的对应位进行或操作,当前对象中的值替换为运算结果." 返回值注释 = "返回运算之前的值" @嵌入式方法 = "">
    参数 运算值 <类型 = 模板类型1 注释 = "提供所欲与其进行位运算的值">
    {
        @ @sn<this>.m_atomic.fetch_or(@<运算值>)
    }

    方法 按位异或 <公开 类型 = 模板类型1 注释 = "原子位运算,将当前值的每一位指定值的对应位进行异或操作,当前对象中的值替换为运算结果." 返回值注释 = "返回运算之前的值" @嵌入式方法 = "">
    参数 运算值 <类型 = 模板类型1 注释 = "提供所欲与其进行位运算的值">
    {
        @ @sn<this>.m_atomic.fetch_xor(@<运算值>)
    }

    方法 等待值改变 <公开 注释 = "阻塞当前线程直到当前原子对象的旧值的原子操作执行完毕." @嵌入式方法 = "">
    参数 旧值 <类型 = 模板类型1>
    {
        @ @sn<this>.m_atomic.wait(@<旧值>)
    }

    方法 比较赋值 <公开 类型 = 逻辑型 注释 = "提供指定值与当前原子对象中所包含值对比,对比完成后赋一个新值." 返回值注释 = "如果原子值与比较值相等返回真,否则返回假." @禁止流程检查 = 真>
    参数 比较值 <类型 = 模板类型1 注释 = "提供所欲与其对比的值,如果当前原子对象中所包含值与该比较值不匹配,新值将不会被赋值.">
    参数 新值 <类型 = 模板类型1 注释 = "提供所欲设置的新值,仅当比较成功(本方法返回真)后会赋新值,否则将丢弃该值.">
    {
        @ return std::atomic_compare_exchange_strong(&this->m_atomic, &@<比较值>, @<新值>);
    }

    # @ <include>
    # @ std::atomic<@dt<模板类型1>> m_atomic;
    # @ inline_ void @an<_CopySelfFromExtra> (const @sn<current_class>& objCopyFrom)  { m_atomic = objCopyFrom.m_atomic.load(); }
    # @ </include>
}

类 原子字节类 <公开 基础类 = 基本原子类型模板类 @模板实现类 = "字节">

类 原子短整数类 <公开 基础类 = 基本原子类型模板类 @模板实现类 = "短整数">

