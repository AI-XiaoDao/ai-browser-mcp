类 大整数类 <公开 基础类 = 扩展对象类 注释 = "提供大整数运算相关支持." @视窗.外部头文件 = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\include\\vol_bn.h">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (COpensslBNWraper)

    方法 取展示内容 <公开 注释 = "将本对象中的所有数据用文本方式填入到所提供的文本参数中,用作调试或其它场合展示时使用." 注释 = "" @虚拟方法 = 可覆盖>
    参数 展示内容 <类型 = 文本型 注释 = "用作填入本对象中所有数据的展示文本">
    参数 最大展示数据尺寸 <类型 = 整数 注释 = "提供用户所指定的最大允许展示数据尺寸,小于0表示全部展示,等于0表示展示默认尺寸数据.">
    {
        展示内容 = 取十进制值 ()  // 以十进制文本输出大数表示的数值
    }

    方法 是否为奇数 <公开 属性读 类型 = 逻辑型 注释 = "判断当前大数是否为一个奇数." 返回值注释 = "为奇数返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ return BN_is_odd(data().GetBN());
    }

    方法 是否为零 <公开 属性读 类型 = 逻辑型 注释 = "判断当前大数是否为零." 返回值注释 = "为0返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ return BN_is_zero(data().GetBN());
    }

    方法 是否为一 <公开 属性读 类型 = 逻辑型 注释 = "判断当前大数是否为一." 返回值注释 = "为1返回真,否则返回假." @禁止流程检查 = 真>
    {
        @ return BN_is_one(data().GetBN());
    }

    方法 位数 <公开 属性读 类型 = 整数 注释 = "表示当前大数实例实际需要的比特数(bits)." @禁止流程检查 = 真>
    {
        @ return BN_num_bits(data().GetBN());
    }

    方法 字节数 <公开 属性读 类型 = 整数 注释 = "表示当前大数实例实际需要的字节数." @禁止流程检查 = 真>
    {
        @ return BN_num_bytes(data().GetBN());
    }

    方法 是否为指定值 <公开 类型 = 逻辑型 注释 = "判断当前大数是否为指定的数值." @禁止流程检查 = 真>
    参数 数值 <类型 = 变整数 注释 = "提供所欲对比的数值.">
    参数 取绝对值 <类型 = 逻辑型 注释 = "是否取当前大数的绝对值来进行对比." @默认值 = 假>
    {
        如果 (取绝对值)
        {
            @ return BN_abs_is_word(data().GetBN(), (const BN_ULONG)@<数值>);
        }
        否则
        {
            @ return BN_is_word(data().GetBN(), (const BN_ULONG)@<数值>);
        }
    }

    方法 是否为素数 <公开 类型 = 逻辑型 注释 = "判断当前大数是否为素数." @禁止流程检查 = 真>
    {
        @ return BN_is_prime_ex(data().GetBN(), BN_prime_checks, data().GetContext(), NULL);
    }

    方法 复制 <公开 类型 = 大整数类 注释 = "将当前大数实例复制并返回." @禁止流程检查 = 真>
    {
        @ BIGNUM * temp = BN_dup(data().GetBN());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 交换 <公开 注释 = "将当前大数实例与另一大数实例交换内容." @禁止流程检查 = 真>
    参数 待交换值 <类型 = 大整数类 注释 = "提供所欲与其交换内容的大数.">
    {
        @ BN_swap(data().GetBN(), @<待交换值>.data().GetBN());
    }

    方法 置数值 <公开 类型 = 逻辑型 注释 = "将当前大数置为指定的数值." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 值 <类型 = 变整数 注释 = "提供所欲设置的数值.">
    {
        @ return BN_set_word(data().GetBN(), (const BN_ULONG)@<值>);
    }

    方法 置随机值 <公开 类型 = 逻辑型 注释 = "将当前大数实例生成一个强密码学伪随机数." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 位数 <类型 = 整数 注释 = "提供需要生成随机数的位数." @默认值 = 32>
    参数 最高位选项 <类型 = 整数 注释 = "该参数为-1表示生成随机数的最高位设置为0,为0表示最高位设置为1,为1时表示最高两位都设置为1." @默认值 = -1>
    参数 是否奇数 <类型 = 逻辑型 注释 = "指定所生成的随机数是否为奇数,提供真则生成偶数." @默认值 = 假>
    {
        @ return BN_rand(data().GetBN(), @<位数>, @<最高位选项>, @<是否奇数>);
    }

    方法 置素数值 <公开 类型 = 逻辑型 注释 = "将当前大数实例生成一个素数值." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 位数 <类型 = 整数 注释 = "提供需要生成素数的位数." @默认值 = 32>
    {
        @ return BN_generate_prime_ex(data().GetBN(), @<位数>, 0, NULL, NULL, NULL);
    }

    方法 置十进制值 <公开 类型 = 逻辑型 注释 = "将当前大数置为指定的十进制值." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 值 <类型 = 文本型 注释 = "提供所欲设置的值.">
    {
        @ CVolMem mem;
        @ const char * dec = GetMbsText (@<值>.GetText (), mem, NULL);
        @ BIGNUM * ptr = data().GetBN();
        @ return BN_dec2bn(&ptr, dec);
    }

    方法 置十六进制值 <公开 类型 = 逻辑型 注释 = "将当前大数置为指定的十六进制值." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 值 <类型 = 文本型 注释 = "提供所欲设置的值.">
    {
        @ CVolMem mem;
        @ const char * dec = GetMbsText (@<值>.GetText (), mem, NULL);
        @ BIGNUM * ptr = data().GetBN();
        @ return BN_hex2bn(&ptr, dec);
    }

    方法 置字节集值 <公开 类型 = 逻辑型 注释 = "将指定字节集中的正整数置为当前大数的值." 注释 = "注意:如果最高位为0,将会被忽略." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 值 <类型 = 字节集类 注释 = "提供所欲设置的值.">
    {
        @ BIGNUM * temp = NULL;
        @ temp = BN_bin2bn((unsigned char *)@<值>.GetPtr(), (INT)@<值>.GetSize(), NULL);
        @ data().SetBN(temp);    //释放并置入新值
        @ return temp != NULL;
    }

    方法 取数值 <公开 类型 = 变整数 注释 = "获取该大数的数值." 返回值注释 = "如果该大数可使用变整数表示,返回该大数的数值." @禁止流程检查 = 真>
    {
        @ return (INT_P)BN_get_word(data().GetBN());
    }

    方法 取十进制值 <公开 类型 = 文本型 注释 = "以十进制文本表示当前大数." @禁止流程检查 = 真>
    {
        @ char * dec = BN_bn2dec(data().GetBN());
        @ @an<CVolString> ret(dec);
        @ OPENSSL_free(dec);
        @ return ret;
    }

    方法 取十六进制值 <公开 类型 = 文本型 注释 = "以十进制文本表示当前大数." @禁止流程检查 = 真>
    {
        @ char * hex = BN_bn2hex(data().GetBN());
        @ @an<CVolString> ret(hex);
        @ OPENSSL_free(hex);
        @ return ret;
    }

    方法 取字节集值 <公开 类型 = 字节集类 注释 = "将当前大数实例以字符形式置入字节集内." 返回值注释 = "注意:如果最高位为0,将会被忽略." @禁止流程检查 = 真>
    {
        @ @an<CVolMem> mem;
        @ BN_bn2bin(data().GetBN(), (unsigned char *)mem.Alloc(BN_num_bytes(data().GetBN()), TRUE));
        @ return mem;
    }

    方法 比较绝对值 <公开 类型 = 整数 注释 = "将当前大数与另一大数进行绝对值的数值大小对比." 返回值注释 = "如果当前大数的绝对值小于另一大数返回-1,如果相等返回0,如果大于则返回1." @禁止流程检查 = 真>
    参数 欲比较大数 <类型 = 大整数类 注释 = "提供欲进行绝对值对比的另一的大数.">
    {
        @ return BN_ucmp(data().GetBN(), @<欲比较大数>.data().GetBN());
    }

    方法 比较 <公开 类型 = 整数 注释 = "将当前大数与另一大数进行数值大小对比." 返回值注释 = "如果当前大数的绝对值小于另一大数返回-1,如果相等返回0,如果大于则返回1." @禁止流程检查 = 真>
    参数 欲比较大数 <类型 = 大整数类 注释 = "提供欲进行对比的另一的大数.">
    {
        @ return BN_cmp(data().GetBN(), @<欲比较大数>.data().GetBN());
    }

    方法 加 <公开 类型 = 大整数类 注释 = "将当前大数实例与另一指定的大数进行加法运算." 返回值注释 = "返回本次运算后的结果." @禁止流程检查 = 真>
    参数 加数 <类型 = 大整数类>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_add(temp, data().GetBN(), @<加数>.data().GetBN());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 加数值 <公开 类型 = 逻辑型 注释 = "将当前大数实例与另一指定的数值进行加法运算." 返回值注释 = "返回本次运算是否成功." @禁止流程检查 = 真>
    参数 加数 <类型 = 变整数>
    {
        @ return BN_add_word(data().GetBN(), (BN_ULONG)@<加数>);
    }

    方法 减 <公开 类型 = 大整数类 注释 = "将当前大数实例与另一指定的大数进行减法运算." 返回值注释 = "返回本次运算后的结果." @禁止流程检查 = 真>
    参数 减数 <类型 = 大整数类>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_sub(temp, data().GetBN(), @<减数>.data().GetBN());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 减数值 <公开 类型 = 逻辑型 注释 = "将当前大数实例与另一指定的数值进行减法运算." 返回值注释 = "返回本次运算是否成功." @禁止流程检查 = 真>
    参数 减数 <类型 = 变整数>
    {
        @ return BN_sub_word(data().GetBN(), (BN_ULONG)@<减数>);
    }

    方法 乘 <公开 类型 = 大整数类 注释 = "将当前大数实例与另一指定的大数进行乘法运算." 返回值注释 = "返回本次运算后的结果." @禁止流程检查 = 真>
    参数 乘数 <类型 = 大整数类>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_mul(temp, data().GetBN(), @<乘数>.data().GetBN(), data().GetContext());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 乘数值 <公开 类型 = 逻辑型 注释 = "将当前大数实例与另一指定的数值进行乘法运算." 返回值注释 = "返回本次运算是否成功." @禁止流程检查 = 真>
    参数 乘数 <类型 = 变整数>
    {
        @ return BN_mul_word(data().GetBN(), (BN_ULONG)@<乘数>);
    }

    方法 求平方 <公开 类型 = 大整数类 注释 = "求当前大数实例的平方(相比\"实例.乘(实例)\"方法效率要高)." 返回值注释 = "返回当前实例的平方." @禁止流程检查 = 真>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_sqr(temp, data().GetBN(), data().GetContext());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 求次方 <公开 类型 = 大整数类 注释 = "求当前大数实例的指定次方." 返回值注释 = "返回本次运算后的结果." @禁止流程检查 = 真>
    参数 次方数 <类型 = 大整数类 注释 = "指定对欲求次方数值的运算指数.">
    {
        @ BIGNUM * temp = BN_new();
        @ BN_exp(temp, data().GetBN(), @<次方数>.data().GetBN(), data().GetContext());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 除 <公开 类型 = 大整数类 注释 = "将当前大数实例与另一指定的大数进行除法运算(当前实例作为被除数)." 返回值注释 = "返回本次运算后的结果." @禁止流程检查 = 真>
    参数 除数 <类型 = 大整数类>
    参数 余数 <类型 = 大整数类 注释 = "该参数将会返回本次除法运算后的余数." @默认值 = 空对象>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_div(temp, (BOOL)@<余数>.IsNullObject() ? NULL : @<余数>.data().GetBN(), data().GetBN(), @<除数>.data().GetBN(), data().GetContext());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 除数值 <公开 类型 = 变整数 注释 = "将当前大数实例与另一指定的数值进行除法运算(当前实例作为被除数)." 返回值注释 = "返回本次运算的结果." @禁止流程检查 = 真>
    参数 除数 <类型 = 变整数>
    {
        @ return (INT_P)BN_div_word(data().GetBN(), (BN_ULONG)@<除数>);
    }

    方法 求模 <公开 类型 = 变整数 注释 = "将当前大数实例与另一指定的数值进行取余运算." 返回值注释 = "返回本次运算的结果." @禁止流程检查 = 真>
    参数 除数 <类型 = 变整数>
    {
        @ return (INT_P)BN_mod_word(data().GetBN(), (BN_ULONG)@<除数>);
    }

    方法 求最大公约数 <公开 类型 = 大整数类 注释 = "求当前大数实例与另一大数的最大公约数." 返回值注释 = "返回最大公约数." @禁止流程检查 = 真>
    参数 值 <类型 = 大整数类>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_gcd(temp, data().GetBN(), @<值>.data().GetBN(), data().GetContext());
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 置指定位 <公开 类型 = 逻辑型 注释 = "将当前大数实例的第指定位设置为1." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 位 <类型 = 整数 注释 = "所欲设置的第几位,如果大数小于该位数将会被扩展.">
    {
        @ return BN_set_bit(data().GetBN(), @<位>);
    }

    方法 清除指定位 <公开 类型 = 逻辑型 注释 = "将当前大数实例的第指定位设置为0." 返回值注释 = "返回操作是否成功." @禁止流程检查 = 真>
    参数 位 <类型 = 整数 注释 = "所欲清除的第几位,如果大数小于该位数将返回失败.">
    {
        @ return BN_clear_bit(data().GetBN(), @<位>);
    }

    方法 截取 <公开 类型 = 整数 注释 = "将当前大数实例截断至指定位." 返回值注释 = "返回截断后的结果值" @禁止流程检查 = 真>
    参数 位 <类型 = 整数 注释 = "所欲截取到第几位,如果大数小于该位数将会返回失败.">
    {
        @ return BN_mask_bits(data().GetBN(), @<位>);
    }

    方法 左移 <公开 类型 = 大整数类 注释 = "将当前大数实例进行位左移运算." 返回值注释 = "返回左移后的结果." @禁止流程检查 = 真>
    参数 左移位数 <类型 = 整数 注释 = "所欲左移的位数." @默认值 = 1>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_lshift(temp, data().GetBN(), @<左移位数>);
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }

    方法 右移 <公开 类型 = 大整数类 注释 = "将当前大数实例进行位右移运算." 返回值注释 = "返回右移后的结果." @禁止流程检查 = 真>
    参数 左移位数 <类型 = 整数 注释 = "所欲右移的位数." @默认值 = 1>
    {
        @ BIGNUM * temp = BN_new();
        @ BN_rshift(temp, data().GetBN(), @<左移位数>);
        @ @sn<current_class> volBn;
        @ volBn.data().SetBN(temp);
        @ return volBn;
    }
}
