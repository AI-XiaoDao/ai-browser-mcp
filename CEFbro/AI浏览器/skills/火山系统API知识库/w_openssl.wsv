<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.OPENSSL <编辑时信息 = "34BFCB, 0, 0, 0"
        "@视窗.头文件搜寻目录.d:!_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\include"
        "@视窗.附属文件.win32-non_static - d:!_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\win32\\bin\\libcrypto-1_1.dll"
        "@视窗.附属文件.x64-non_static - d:!_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\x64\\bin\\libcrypto-1_1-x64.dll"
        "@视窗.外部库.non_static - d:!_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\$(p)\\lib\\libcrypto.lib"
        "@视窗.外部库.static - d:!_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\1\\$(vs)\\$(p)\\lib\\libcrypto.lib\r\n..\\..\\shared\\extern_lib\\common\\openssl\\1\\$(vs)\\$(p)\\lib\\libssl.lib\r\nCrypt32.lib"
        "@视窗.需求VS版本.static - d:!_VOL_OPENSSL_VER2" = "10,14-" ""
        "@视窗.头文件搜寻目录.d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\include"
        "@视窗.附属文件.win32-non_static - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\win32\\libcrypto-3.dll"
        "@视窗.附属文件.x64-non_static - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\x64\\libcrypto-3-x64.dll"
        "@视窗.外部库.non_static - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\$(p)\\libcrypto.lib"
        ""
        "@视窗.附属文件.win32-static-debug - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\win32\\libcrypto-3.dll"
        "@视窗.附属文件.x64-static-debug - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\x64\\libcrypto-3-x64.dll"
        "@视窗.外部库.static-debug - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\dll\\$(p)\\libcrypto.lib"
        ""
        "@视窗.外部库.static-release - d:_VOL_OPENSSL_VER2" = "..\\..\\shared\\extern_lib\\common\\openssl\\2\\lib\\$(d)\\$(p)\\libcrypto.lib\r\n..\\..\\shared\\extern_lib\\common\\openssl\\2\\lib\\$(d)\\$(p)\\libssl.lib\r\nCrypt32.lib"
        "@视窗.需求VS版本.static - d:_VOL_OPENSSL_VER2" = "16-" "" @视窗.使用静态运行时库.static = 真>

类 加解密类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "源码:https://www.openssl.org/source/ ."
        注释 = "如果用户程序中调用了本类中的\"使用新版本\"方法,将使用openssl最新3.5.0#1版进行编译,否则将使用openssl-1.1.1h版进行编译." 编辑时信息 = "14EA95, 0, 0, 0"
        @视窗.外部头文件 = "openssl\\evp.h\r\nopenssl\\aes.h\r\nopenssl\\des.h\r\nopenssl\\rsa.h\r\nopenssl\\pem.h\r\nopenssl\\conf.h\r\nopenssl\\engine.h\r\nopenssl\\err.h\r\nopenssl\\hmac.h">
{
    方法 使用新版本 <公开 静态 注释 = "调用本方法指示编译器使用openssl最新3.5.0#1版进行编译,如果不调用本方法,将使用openssl-1.1.1h版进行编译." 注释 = "注意:"
            注释 = "  1. 从 OpenSSL 3.0 开始，很多旧算法(如 MD2、MD5、DES、RC4、RC2 等)不再被支持。如果你尝试使用它们，就会返回\"算法不被支持\"错误。"
            注释 = "如果您确认要使用这些算法,请不要调用本方法以依旧使用openssl-1.1.1h版进行编译;"
            注释 = "  2. 本方法为编译时处理方法,系统在编译时只要检测到用户程序实际执行流程中任意位置调用了此方法,就启用对应的编译特性,和方法本身是否被执行到没有任何关系." @视窗.预定义宏 = "_VOL_OPENSSL_VER2"
            @视窗.编译信息 = "基于 OPENSSL 3.5.0#1 版本编译">
    {

    }

