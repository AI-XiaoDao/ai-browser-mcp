    }

    方法 数字签名 <公开 静态 类型 = 字节集类 注释 = "将指定数据进行数字签名,可通过\"验证签名\"验证数据完整性."
            注释 = "附: OPENSSL类库之数字签名与其他平台(如支付宝)通用的过程: http://bbs.voldp.com/forum.php?mod=viewthread&tid=7723"
            返回值注释 = "签名成功将会返回签名内容,签名失败返回空字节集." 编辑时信息 = "76AA3, 0, 0, 0" @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲签名的数据." 编辑时信息 = "76AA3, 0, 0, 0">
    参数 私钥数据 <类型 = 字节集类 注释 = "提供本次签名所使用的私钥数据." 编辑时信息 = "76AA3, 0, 0, 0">
    参数 PKCS8格式 <类型 = 逻辑型 注释 = "指定所提供私钥数据的格式." 编辑时信息 = "76AA3, 0, 0, 0" @默认值 = 假>
    参数 摘要算法 <类型 = 整数 注释 = "签名所使用的摘要算法." 编辑时信息 = "76AA3, 0, 0, 0" @默认值 = RSA数字签名算法.SHA1>
    {
        @ @an<CVolMem> sig;
        @ INT inLen = (INT)@<数据>.GetSize();
        @ if ((INT)@<私钥数据>.GetSize() == 0 || inLen == 0)
        @     return sig;
        @ RSA * tmpRsa = VolRSA_GenerateRsa(TRUE, @<私钥数据>, @<PKCS8格式>);
        @ if (tmpRsa != NULL)
        @ {
        @     unsigned char * pOut = (unsigned char *)sig.Alloc(RSA_size(tmpRsa), TRUE);
        @     unsigned int outLen = 0;
        @     RSA_sign(@<摘要算法>, (unsigned char *)@<数据>.GetPtr(), inLen, pOut, &outLen, tmpRsa);
        @     RSA_free(tmpRsa);
        @     if (outLen > 0)
        @         sig.Realloc(outLen);
        @     else
        @         sig.Free();
        @ }
        @ return sig;
    }

    方法 验证签名 <公开 静态 类型 = 逻辑型 注释 = "提供指定的数据以及该数据对应的签名内容,验证数据与签名是否对应,以保障数据的完整性."
            注释 = "附: OPENSSL类库之数字签名与其他平台(如支付宝)通用的过程: http://bbs.voldp.com/forum.php?mod=viewthread&tid=7723" 返回值注释 = "返回该数据签名是否验证成功."
            @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲验证签名的数据." 编辑时信息 = "9154C, 0, 0, 0">
    参数 签名内容 <类型 = 字节集类 注释 = "提供该数据对应的签名内容." 编辑时信息 = "9154C, 0, 0, 0">
    参数 公钥数据 <类型 = 字节集类 注释 = "提供本次验证所使用的公钥数据.">
    参数 PKCS8格式 <类型 = 逻辑型 注释 = "指定所提供公钥数据的格式." @默认值 = 假>
    参数 摘要算法 <类型 = 整数 注释 = "提供验签所使用的摘要算法,必须与签名时保持一致,否则会导致验签失败." 编辑时信息 = "9154C, 0, 0, 0" @默认值 = RSA数字签名算法.SHA1>
    {
        @ INT dataLen = (INT)@<数据>.GetSize();
        @ INT sigLen = (INT)@<签名内容>.GetSize();
        @ if ((INT)@<公钥数据>.GetSize() == 0 || dataLen == 0 || sigLen == 0)
        @     return FALSE;
        @ RSA * tmpRsa = VolRSA_GenerateRsa(FALSE, @<公钥数据>, @<PKCS8格式>);
        @ if (!tmpRsa)
        @     return FALSE;
        @ BOOL blSucceeded = (RSA_verify(@<摘要算法>, (unsigned char *)@<数据>.GetPtr(), dataLen, (unsigned char *)@<签名内容>.GetPtr(), sigLen, tmpRsa) == 1);
        @ RSA_free (tmpRsa);
        @ return blSucceeded;
    }
}

类 RSA密钥生成类 <公开 注释 = "本类实例提供RSA密钥对生成方法." @强制依赖 = "加解密类" @视窗.外部头文件 = "vol_rsa.h">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (COpensslRSAWraper)

    方法 生成密钥对 <公开 类型 = 逻辑型 注释 = "随机生成一个新的密钥对,包含私钥以及公钥,可使用\"取私钥数据()/取公钥数据()\"获取所生成的密钥数据." 返回值注释 = "返回密钥是否生成成功" @禁止流程检查 = 真>
    参数 密钥位 <类型 = 整数 注释 = "生成密钥所欲使用的位数." @默认值 = 1024>
    参数 奇数 <类型 = 变整数 注释 = "选择一个奇数以在生成密钥对时使用." @默认值 = 65537>
    {
        @ BIGNUM* bne = BN_new();
        @ BN_set_word(bne, @<奇数>);
        @ INT ret = RSA_generate_key_ex(data().GetPRsa(), @<密钥位>, bne, NULL);
        @ BN_clear_free(bne);
        @ data().SetKeyBits(@<密钥位>);    //记录密钥位
        @ return ret == 1;
    }

    方法 取私钥数据 <公开 类型 = 字节集类 注释 = "在调用\"生成密钥对\"方法后,取出生成的私钥数据." 返回值注释 = "返回私钥数据." @禁止流程检查 = 真>
    参数 PKCS8格式 <类型 = 逻辑型 注释 = "指定生成的密钥数据是否以PKCS#8格式返回." @默认值 = 假>
    {
        @ BIO* pBio = BIO_new(BIO_s_mem());
        @ INT ret;
        @ @an<CVolMem> keyData;
        @ if (@<PKCS8格式>)
        @ {
        @     EVP_PKEY* ppKey = EVP_PKEY_new();
        @     EVP_PKEY_set1_RSA(ppKey, data().GetPRsa());
        @     ret = PEM_write_bio_PKCS8PrivateKey(pBio, ppKey, NULL, NULL, NULL, NULL, NULL);
        @     EVP_PKEY_free(ppKey);
        @ }
        @ else
        @     ret = PEM_write_bio_RSAPrivateKey(pBio, data().GetPRsa(), NULL, NULL, NULL, NULL, NULL);
        @ if (ret > 0)    //可能还未生成密钥对
        @ {
        @     @an<CVolMem> readTemp;
        @     readTemp.Alloc(1024, FALSE);
        @     while(TRUE)
        @     {
        @         readTemp.Zero ();    //必须清零
        @         INT readLen = BIO_gets(pBio, (CHAR*)readTemp.GetPtr(), 1024);
        @         if (readLen <= 0)  break;
        @         keyData.Append(readTemp.GetPtr (), readLen);
        @     }
        @ }
        @ BIO_free(pBio);
        @ return keyData;
    }

    方法 取公钥数据 <公开 类型 = 字节集类 注释 = "在调用\"生成密钥对\"方法后,取出生成的公钥数据." 返回值注释 = "返回公钥数据." @禁止流程检查 = 真>
    {
        @ BIO* pBio = BIO_new(BIO_s_mem());
        @ @an<CVolMem> keyData;
        @ if (PEM_write_bio_RSA_PUBKEY(pBio, data().GetPRsa()) > 0)
        @ {
        @     @an<CVolMem> readTemp;
        @     readTemp.Alloc(1024, FALSE);
        @     while(TRUE)
        @     {
        @         readTemp.Zero ();    //必须清零
        @         INT readLen = BIO_gets(pBio, (CHAR*)readTemp.GetPtr(), 1024);
        @         if (readLen <= 0)  break;
        @         keyData.Append(readTemp.GetPtr (), readLen);
        @     }
        @ }
        @ BIO_free(pBio);
        @ return keyData;
    }
}

类 数据填充模式 <公开 注释 = "填充模式即数据的补码方式,参考资料:https://www.cnblogs.com/midea0978/articles/1437257.html" @文档 = "category = \"辅助类\""
        @常量类 = 整数>
{
    常量 无 <公开 值 = 0 注释 = "不进行任何填充,注意使用该模式后必须确保提供的数据为数据块的倍数,即 输入长度 % 16 = 0.">
    常量 PKCS7 <公开 值 = 1 注释 = "使用补码的字节序列长度值来填充.">
    常量 ANSIX923 <公开 值 = 2 注释 = "与\"零填充\"基本一致,但最后一位是补码的字节序列长度.">
    常量 ISO10126 <公开 值 = 3 注释 = "以随机字符补码,最后一位是补码的字节序列长度.">
    常量 零填充 <公开 值 = 4 注释 = "即ZeroPadding,在数据对齐时使用0补位.">
}

