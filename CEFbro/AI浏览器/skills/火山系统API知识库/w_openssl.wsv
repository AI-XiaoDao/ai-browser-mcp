    方法 加密_RSA_私钥 <公开 静态 类型 = 字节集类 注释 = "使用私钥对指定数据进行RSA加密后返回." 返回值注释 = "返回加密后的数据." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲加密的数据." 注释 = "注意输入的数据长度,不能超过(密钥位/8-填充尺寸),例如生成密钥为2048位,无填充的情况下可加密256字节的数据."
            编辑时信息 = "9554C, 0, 0, 0">
    参数 指定私钥 <类型 = 字节集类 注释 = "提供本次加密所欲使用的私钥数据.">
    参数 PKCS8格式 <类型 = 逻辑型 注释 = "指定所提供私钥数据的格式." @默认值 = 假>
    参数 填充方式 <类型 = RSA填充方式 注释 = "加密所欲使用的数据填充方式." 编辑时信息 = "9554C, 0, 0, 0" @默认值 = RSA填充方式.PKCS1>
    {
        @ @an<CVolMem> outData;
        @ VolRSA_Private_Encrypt(1, outData, @<数据>, @<指定私钥>, @<PKCS8格式>, @<填充方式>);
        @ return outData;
    }

    方法 加密_RSA_公钥 <公开 静态 类型 = 字节集类 注释 = "使用公钥对指定数据进行RSA加密后返回." 返回值注释 = "返回加密后的数据." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "提供所欲加密的数据." 注释 = "注意输入的数据长度,不能超过(密钥位/8-填充尺寸),例如生成密钥为2048位,无填充的情况下可加密256字节的数据."
            编辑时信息 = "9554C, 0, 0, 0">
    参数 指定公钥 <类型 = 字节集类 注释 = "提供本次加密所欲使用的公钥数据.">
    参数 PKCS8格式 <类型 = 逻辑型 注释 = "指定所提供公钥数据的格式." @默认值 = 假>
    参数 填充方式 <类型 = RSA填充方式 注释 = "加密所欲使用的数据填充方式." 编辑时信息 = "9554C, 0, 0, 0" @默认值 = RSA填充方式.PKCS1>
    {
        @ @an<CVolMem> outData;
        @ VolRSA_Pubkey_Encrypt(1, outData, @<数据>, @<指定公钥>, @<PKCS8格式>, @<填充方式>);
        @ return outData;
    }

    方法 解密_RSA_私钥 <公开 静态 类型 = 字节集类 注释 = "使用私钥对指定RSA公钥加密过的数据进行解密后返回." 返回值注释 = "返回解密后的数据." @禁止流程检查 = 真>
