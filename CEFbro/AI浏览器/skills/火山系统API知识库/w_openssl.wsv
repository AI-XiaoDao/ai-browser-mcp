    {
        @ @an<CVolMem> mem;
        @ VolCommEncrypt(mem, @<密钥位> == 192 ? EVP_camellia_192_ctr() : @<密钥位> == 256 ? EVP_camellia_256_ctr() : EVP_camellia_128_ctr(), @<数据>, @<密码>, NULL, @<填充方式>, 16, 0);
