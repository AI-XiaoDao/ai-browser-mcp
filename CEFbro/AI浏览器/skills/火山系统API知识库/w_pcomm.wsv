    方法 传输进度模板方法 <公开 静态 类型 = 整数 注释 = "提供当文件数据接收或发送进度发生改变后被调用静态方法的模板." 注释 = "本静态方法一般用作给最终用户提供一个友好的传输进度显示界面."
            返回值注释 = "返回值大于等于0继续传输,小于0立即停止传输,所有文件传输方法将返回\"PCM传输结果码.函数中止\".">
    参数 已传输数据尺寸 <类型 = 整数 注释 = "提供当前已经接收或发送完毕的数据尺寸,单位字节.">
    参数 保留参数1 <类型 = 整数 注释 = "仅在调试时使用">
    参数 保留参数2 <类型 = 变整数 注释 = "仅在调试时使用">
    参数 全部数据尺寸 <类型 = 整数 注释 = "提供需要接收或发送的全部数据尺寸,单位字节.">
    {
        返回 (0)
    }

    方法 发送文件 <公开 类型 = 整数 注释 = "基于所指定的协议传输一个文件数据" 返回值注释 = "大于等于0表示发送成功,失败返回小于0的以下结果码之一:"
            返回值注释 = "  1. \"PCM传输结果码.无效参数\", 所提供协议类型值无效;" 返回值注释 = "  2. \"PCM传输结果码.无效端口\", 所有协议均可能返回;"
            返回值注释 = "  3. \"PCM传输结果码.函数中止\", 所有协议均可能返回;" 返回值注释 = "  4. \"PCM传输结果码.打开文件失败\", 所有协议均可能返回;"
            返回值注释 = "  5. \"PCM传输结果码.视窗错误\", 所有协议均可能返回;"
            返回值注释 = "  6. \"PCM传输结果码.超时\", 以下协议可能返回: ASCII Ymodem Zmodem Xmodem1KCRC XmodemCheckSum XmodemCRC;"
            返回值注释 = "  7. \"PCM传输结果码.CAN中止\", 以下协议可能返回: Ymodem Zmodem Xmodem1KCRC XmodemCheckSum XmodemCRC;"
            返回值注释 = "  8. \"PCM传输结果码.协议出错\", 以下协议可能返回: Zmodem;" 返回值注释 = "  9. \"PCM传输结果码.跳过\", 以下协议可能返回: Zmodem." @嵌入式方法 = "">
    参数 所使用协议 <类型 = PCM文件传输协议 注释 = "指定所使用的文件传输协议类型">
    参数 所欲传输文件名 <类型 = 文本型 注释 = "提供所欲传输文件的名称">
    参数 进度反馈方法 <注释 = "当文件数据发送进度发生改变后,本静态方法被自动调用,一般用作给最终用户提供一个友好的传输进度显示界面." 注释 = "具体函数解释参见\"传输进度模板方法\"." @匹配方法 = "传输进度模板方法">
    {
        @ @sn<this>.SendFile (@<所使用协议>, @<所欲传输文件名>, (FN_PCOMM_FT_PROGRESS)&@<进度反馈方法>)
    }

    方法 接收文件 <公开 类型 = 整数 注释 = "基于所指定的协议接收一个文件数据" 返回值注释 = "大于等于0表示接收成功(提供所具体接收到文件的数目),失败返回小于0的以下结果码之一:"
            返回值注释 = "  1. \"PCM传输结果码.无效参数\", 所提供协议类型值无效;" 返回值注释 = "  2. \"PCM传输结果码.无效端口\", 所有协议均可能返回;"
            返回值注释 = "  3. \"PCM传输结果码.函数中止\", 所有协议均可能返回;" 返回值注释 = "  4. \"PCM传输结果码.打开文件失败\", 所有协议均可能返回;"
            返回值注释 = "  5. \"PCM传输结果码.视窗错误\", 所有协议均可能返回;" 返回值注释 = "  6. \"PCM传输结果码.超时\", 以下协议可能返回;"
            返回值注释 = "  7. \"PCM传输结果码.CAN中止\", 以下协议可能返回: Xmodem1KCRC XmodemCheckSum XmodemCRC." @嵌入式方法 = "">
    参数 所使用协议 <类型 = PCM文件传输协议 注释 = "指定所使用的文件传输协议类型">
    参数 文件名 <类型 = 文本型 注释 = "用作提供和返回所接收到数据存放到的本地文件名." 注释 = "注意: 所接收到的文件将存放到程序现行目录(可在接收文件前使用\"改变目录\"全局方法设置)下.">
    参数 进度反馈方法 <注释 = "当文件数据接收进度发生改变后,本静态方法被自动调用,一般用作给最终用户提供一个友好的传输进度显示界面." 注释 = "具体函数解释参见\"传输进度模板方法\"." @匹配方法 = "传输进度模板方法">
    参数 超时时间 <类型 = 整数 注释 = "提供一个具体的接收数据超时时间(单位秒),仅当协议类型为 ASCII 时有效." @默认值 = 5>
    {
        @ @sn<this>.RecvFile (@<所使用协议>, @<文件名>, (FN_PCOMM_FT_PROGRESS)&@<进度反馈方法>, @<超时时间>)
    }

    方法 接收一批文件 <公开 类型 = 整数 注释 = "基于所指定的协议接收一批文件数据" 返回值注释 = "大于等于0表示接收成功(提供所具体接收到文件的数目),失败返回小于0的以下结果码之一:"
            返回值注释 = "  1. \"PCM传输结果码.无效参数\", 所提供协议类型值无效或所提供参数值无效;" 返回值注释 = "  2. \"PCM传输结果码.无效端口\", 所有协议均可能返回;"
            返回值注释 = "  3. \"PCM传输结果码.超时\", 所有协议均可能返回;" 返回值注释 = "  4. \"PCM传输结果码.函数中止\", 所有协议均可能返回;"
            返回值注释 = "  5. \"PCM传输结果码.打开文件失败\", 所有协议均可能返回;" 返回值注释 = "  6. \"PCM传输结果码.视窗错误\", 所有协议均可能返回;"
            返回值注释 = "  7. \"PCM传输结果码.CAN中止\", 以下协议可能返回: Ymodem Zmodem;" 返回值注释 = "  8. \"PCM传输结果码.协议出错\", 以下协议可能返回: Zmodem."
            @嵌入式方法 = "">
    参数 所使用协议 <类型 = PCM文件传输协议 注释 = "指定所使用的文件传输协议类型. 注意仅支持以下几种协议: Kermit, Ymodem, Zmodem.">
    参数 最多接收文件数目 <类型 = 整数 注释 = "指定最多可以接收文件的数目">
    参数 所接收到文件名列表 <类型 = 文本数组类 注释 = "用作返回所有被接收到文件的本地文件名列表." 注释 = "注意: 所接收到的文件将存放到程序现行目录(可在接收文件前使用\"改变目录\"全局方法设置)下.">
    参数 进度反馈方法 <注释 = "当文件数据接收进度发生改变后,本静态方法被自动调用,一般用作给最终用户提供一个友好的传输进度显示界面." 注释 = "具体函数解释参见\"传输进度模板方法\"." @匹配方法 = "传输进度模板方法">
    {
        @ @sn<this>.RecvManyFiles (@<所使用协议>, @<最多接收文件数目>, @<所接收到文件名列表>.data (), (FN_PCOMM_FT_PROGRESS)&@<进度反馈方法>)
    }

    # 杂类 --

    方法 发送中断信号 <公开 类型 = 整数 注释 = "发送中断信号并等待所指定时间"
            返回值注释 = "成功返回\"PCM结果码.成功\",失败返回小于0的以下结果码之一: \"PCM结果码.无效端口\", \"PCM结果码.无效参数\", \"PCM结果码.视窗错误\"." @嵌入式方法 = "">
    参数 等待时间 <类型 = 整数 注释 = "指定开始发送中断信号后一直阻塞等待的时间,单位为\"滴答\"(1\"滴答\"等于55毫秒).">
    {
        @ sio_break (@sn<this>.@n<端口>, @<等待时间>)
    }

    方法 发送中断信号2 <公开 类型 = 整数 注释 = "发送中断信号并等待所指定时间." 注释 = "本方法与\"发送中断信号\"方法唯一的区别是等待时间单位为毫秒."
            返回值注释 = "成功返回\"PCM结果码.成功\",失败返回小于0的以下结果码之一: \"PCM结果码.无效端口\", \"PCM结果码.无效参数\", \"PCM结果码.视窗错误\"." @嵌入式方法 = "">
    参数 等待时间 <类型 = 整数 注释 = "指定开始发送中断信号后一直阻塞等待的时间,单位为毫秒.">
    {
        @ sio_break_ex (@sn<this>.@n<端口>, @<等待时间>)
    }

    方法 查看数据 <公开 类型 = 整数 注释 = "  从设备输入缓冲区中查看读入并返回一段数据." 注释 = "  本方法与\"读数据\"方法的区别在于: 本方法仅仅只查看在输入缓冲区中的数据,而并不将所读入数据从"
            注释 = "输入缓冲区中删除,该数据将仍旧保存在输入缓冲区中以供下次读入." 注释 = "  注意: 本方法仅当设备为 MOXA 多串口主板时有效."
            返回值注释 = "  成功返回大于等于0的实际读入数据尺寸(等于\"结果数据\"参数中所返回数据的尺寸),失败返回"
            返回值注释 = "小于0的以下结果码之一: \"PCM结果码.无效端口\", \"PCM结果码.端口不支持\", \"PCM结果码.视窗错误\"." @禁止流程检查 = 真>
    参数 欲读入数据尺寸 <类型 = 整数 注释 = "提供所欲读入的数据尺寸,必须大于等于0.">
    参数 结果数据 <类型 = 字节集类 注释 = "用作保存所读入的数据">
    {
        @ const int nResCode = sio_view (@<端口>, (char*)@<结果数据>.Alloc (@<欲读入数据尺寸>), @<欲读入数据尺寸>);
        @ @<结果数据>.Realloc (MAX (0, nResCode));
        @ return nResCode;
    }

    方法 置低水平线 <公开 类型 = 整数 注释 = "设置设备Tx缓冲区的低水平线阀值,有效值范围在0到1024字节之间."
            注释 = "当缓冲区中的已有数据尺寸小于等于此低水平线阀值时,设备将发送一个\"Tx缓冲区空\"事件从而触发下一次数据写操作." 注释 = "注意: 本方法仅当设备为 MOXA 多串口主板时有效."
            返回值注释 = "成功返回\"PCM结果码.成功\",失败返回小于0的以下结果码之一:"
            返回值注释 = "  \"PCM结果码.无效端口\", \"PCM结果码.控制失败\", \"PCM结果码.无效参数\", \"PCM结果码.视窗错误\", \"PCM结果码.端口不支持\"." @嵌入式方法 = "">
    参数 低水平线值 <类型 = 整数 注释 = "提供设备Tx缓冲区的低水平线值,有效值范围在0到1024字节之间.">
    {
        @ sio_TxLowWater (@sn<this>.@n<端口>, @<低水平线值>)
    }

    方法 伪接收Xon字符 <公开 类型 = 整数 注释 = "假装接收到了一个 XON 字符,从而触发相应的传输操作."
            返回值注释 = "成功返回\"PCM结果码.成功\",失败返回小于0的以下结果码之一: \"PCM结果码.无效端口\", \"PCM结果码.视窗错误\"." @嵌入式方法 = "">
    {
        @ sio_ActXon (@sn<this>.@n<端口>)
    }

    方法 伪接收Xoff字符 <公开 类型 = 整数 注释 = "假装接收到了一个 XOFF 字符,从而触发相应的传输操作."
            返回值注释 = "成功返回\"PCM结果码.成功\",失败返回小于0的以下结果码之一: \"PCM结果码.无效端口\", \"PCM结果码.视窗错误\"." @嵌入式方法 = "">
    {
        @ sio_ActXoff (@sn<this>.@n<端口>)
    }
}
