<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.高级网页解析 <"">

类 网页元素数据类 <@文档 = "category = \"辅助类\"" @禁止创建对象 = 真>
{
    方法 类_清理
    {
        如果 (查询器句柄 != 0)
        {
            @ Gumbo_Query_Delete((void*)@<查询器句柄>);
            查询器句柄 = 0
        }
    }

    变量 查询器句柄 <公开 类型 = 变整数 值 = 0>
}

类 网页元素类 <公开 基础类 = 参考对象模板类 注释 = "提供网页元素操作" @文档 = "category = \"辅助类\"" @模板实现类 = "网页元素数据类">
{
    方法 _销毁 <公开 注释 = "内部方法,请勿调用.">
    {
        如果 (参考数据.查询器句柄 != 0)
        {
            @ Gumbo_Query_Delete((void*)GetData ().@n<网页元素数据类.查询器句柄>);
            参考数据.查询器句柄 = 0
        }
    }

    方法 取节点 <公开 注释 = "取指定索引节点">
    参数 索引 <类型 = 整数 注释 = "索引从0开始,不能大于节点数-1">
    参数 保存节点对象 <类型 = 网页节点类 注释 = "取出来的节点保存在此参数中">
    {
        如果 (索引 >= 取节点数 ())
        {
            索引 = 0
        }
        变量 节点句柄 <类型 = 变整数>
        @ @<节点句柄> = (@dt<变整数>)Gumbo_Query_GetNode((void*)GetData ().@n<网页元素数据类.查询器句柄>,@<索引>);
        保存节点对象._销毁 ()
        保存节点对象.参考数据.节点句柄 = 节点句柄
    }

    方法 取节点数 <公开 类型 = 整数 注释 = "取出当前元素的节点数量." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_GetCount((void*)GetData ().@n<网页元素数据类.查询器句柄>);

    }

    方法 查询元素 <公开>
    参数 选择器文本 <类型 = 文本型>
    参数 查询结果 <类型 = 网页元素类>
    {
        变量 查询器句柄 <类型 = 变整数>
        @ @<查询器句柄> = (INT_P)Gumbo_Query_Find((void*)GetData ().@n<网页元素数据类.查询器句柄> ,CU8String(@<选择器文本>.GetText ()).GetText ());
        查询结果._销毁 ()  // 防止传递过来的对象存在句柄,销毁一下。
        查询结果.参考数据.查询器句柄 = 查询器句柄


    }
}

类 高级网页解析器数据类 <@文档 = "category = \"辅助类\"" @视窗.外部头文件 = "pro_html\\GumboQueryTool.h"
        @视窗.外部库.x64 = "pro_html\\GumboQueryToolx64.lib" @视窗.外部库.win32 = "pro_html\\GumboQueryToolx86.lib"
        @视窗.附属文件.x64 = "pro_html\\GumboQueryToolx64.dll" @视窗.附属文件.win32 = "pro_html\\GumboQueryToolx86.dll" @禁止创建对象 = 真>
{
    方法 类_初始化
    {
        @ @<网页解析句柄>=(INT_P)Gumbo_Query_Document_new();
    }

    方法 类_清理
    {
        如果 (网页解析句柄 != 0)
        {
            @ Gumbo_Query_Document_Delete((void*)@<网页解析句柄>);
        }
    }

    变量 网页解析句柄 <公开 类型 = 变整数>
}

类 高级网页解析器 <公开 基础类 = 参考对象模板类 注释 = "通过本类可快速解析HTML文档,支持路径查询网页文档." @模板实现类 = "高级网页解析器数据类">
{
    变量 网页源码 <类型 = 字节集类>

    方法 创建 <公开 类型 = 逻辑型 注释 = "从HTML文本文档来创建解析器,创建成功后可调用\"查询元素\"方法查询HTML元素." 返回值注释 = "创建成功返回真" @禁止流程检查 = 真>
    参数 网页内容 <类型 = 文本型>
    {
        网页源码 = 文本到UTF8 (网页内容)
        @ return Gumbo_Query_Document_parse ((void*)GetData ().@n<高级网页解析器数据类.网页解析句柄>,(const char*)@<网页源码>.GetPtr());
    }

    方法 创建自文件 <公开 类型 = 逻辑型 注释 = "从本地文档创建解析器,创建成功后可调用\"查询元素\"方法查询HTML元素." 返回值注释 = "创建成功返回真">
    参数 网页本地路径 <类型 = 文本型 注释 = "提供完整的本地文档路径">
    {
        返回 (创建自字节集 (读入文件 (网页本地路径)))
    }

    方法 创建自资源 <公开 类型 = 逻辑型 注释 = "从资源创建解析器,创建成功后可调用\"查询元素\"方法查询HTML元素." 返回值注释 = "创建成功返回真">
    参数 文件资源 <类型 = 视窗文件资源>
    {
        变量 网页文件 <类型 = 字节集类>
        文件资源到字节集 (文件资源, 网页文件)
        返回 (创建自字节集 (网页文件))
    }

    方法 创建自字节集 <公开 类型 = 逻辑型 注释 = "从字节集创建解析器,创建成功后可调用\"查询元素\"方法查询HTML元素." 返回值注释 = "创建成功返回真" @禁止流程检查 = 真>
    参数 网页内容 <类型 = 字节集类 注释 = "必须保证提供的字节集是UTF8编码的.">
    {
        网页源码 = 网页内容
        @ return Gumbo_Query_Document_parse ((void*)GetData ().@n<高级网页解析器数据类.网页解析句柄>,(const char*)@<网页源码>.GetPtr());
    }

    方法 取位置源码 <公开 类型 = 文本型 注释 = "  通过本方法可以取出指定位置的网页源码." 注释 = "  注意：在取单标签源码时(如：input),需要使用\"节点变量.取节点开始位置2()\"和"
            注释 = "\"节点变量.取节点结束位置2()\",并且开始位置和结束位置需要互换位置." 注释 = "  如下: 解析器变量.取位置源码 (节点变量.取节点结束位置2 (), 节点变量.取节点开始位置2 ())">
    参数 开始位置 <类型 = 整数>
    参数 结束位置 <类型 = 整数>
    {
        变量 临时字节集 <类型 = 字节集类>
        临时字节集 = 取字节集中间 (网页源码, 开始位置, 结束位置 - 开始位置)
        返回 (UTF8到文本 (临时字节集))
    }

    方法 查询元素 <公开 注释 = "创建解析器成功后,可通过本方法在HTML文档中查找元素.">
    参数 路径文本 <类型 = 文本型 注释 = "所查询内容,支持如下格式:" 注释 = "  1.div.className -  通过元素名.类名来取得元素对象."
            注释 = "  2.div.className > a 通过元素名.类名,得到指定元素对象后,继续获取该元素下的第一个a标签元素." 注释 = "  3.a 取得当前节点元素中所有的div其中的a标签元素.">
    参数 查询结果 <类型 = 网页元素类 注释 = "查询结果保存在此参数中.">
    {
        变量 临时内容 <类型 = 字节集类>
        变量 查询句柄 <类型 = 变整数>
        临时内容 = 文本到UTF8 (路径文本)
        @ @<查询句柄> = (INT_P)Gumbo_Query_Document_Find((void*)GetData ().@n<高级网页解析器数据类.网页解析句柄>,(const char*)@<临时内容>.GetPtr());
        查询结果._销毁 ()  // 防止传递过来的对象存在句柄,销毁一下。
        查询结果.参考数据.查询器句柄 = 查询句柄
    }
}

类 网页节点数据类 <@文档 = "category = \"辅助类\"" @禁止创建对象 = 真>
{
    方法 类_清理
    {
        如果 (节点句柄 != 0)
        {
            @ Gumbo_Query_Node_Delete((void*)@<节点句柄>);
            节点句柄 = 0
        }
    }

    变量 节点句柄 <公开 类型 = 变整数 值 = 0>
}

类 网页节点类 <公开 基础类 = 参考对象模板类 注释 = "提供网页节点操作" @文档 = "category = \"辅助类\"" @模板实现类 = "网页节点数据类">
{
    方法 类_清理
    {
        _销毁 ()
    }

    方法 _销毁 <公开 注释 = "内部方法,请勿调用.">
    {
        如果 (参考数据.节点句柄 != 0)
        {
            @ Gumbo_Query_Node_Delete((void*)GetData ().@n<网页节点数据类.节点句柄>);
            参考数据.节点句柄 = 0
        }
    }

    方法 是否有效 <公开 类型 = 逻辑型 注释 = "判断当前节点是否有效" @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_valid((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取父节点 <公开 注释 = "取当前节点的父节点对象">
    参数 父节点结果 <类型 = 网页节点类 注释 = "结果通过此参数返回">
    {
        变量 临时句柄 <类型 = 变整数>
        @ @<临时句柄> = (INT_P)Gumbo_Query_Node_parent((void *)GetData ().@n<网页节点数据类.节点句柄>);
        父节点结果._销毁 ()  // 防止传递过来的对象存在句柄,销毁一下。
        父节点结果.参考数据.节点句柄 = 临时句柄
    }

    方法 取下一个节点 <公开 注释 = "取出当前节点的下一个节点对象">
    参数 节点结果 <类型 = 网页节点类 注释 = "结果通过此参数返回">
    {
        变量 临时句柄 <类型 = 变整数>
        @ @<临时句柄> = (INT_P)Gumbo_Query_Node_nextSibling((void*)GetData ().@n<网页节点数据类.节点句柄>);
        节点结果._销毁 ()  // 防止传递过来的对象存在句柄,销毁一下。
        节点结果.参考数据.节点句柄 = 临时句柄
    }

    方法 取上一个节点 <公开 注释 = "取出当前节点的上一个节点对象">
    参数 节点结果 <类型 = 网页节点类 注释 = "结果通过此参数返回">
    {
        变量 临时句柄 <类型 = 变整数>
        @ @<临时句柄> = (INT_P)Gumbo_Query_Node_prevSibling((void*)GetData ().@n<网页节点数据类.节点句柄>);
        节点结果._销毁 ()
        节点结果.参考数据.节点句柄 = 临时句柄
    }

    方法 取节点数 <公开 类型 = 整数 注释 = "取当前节点数量." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_childNum((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取节点 <公开 注释 = "取指定索引节点">
    参数 索引 <类型 = 整数 注释 = "索引从0开始">
    参数 节点结果 <类型 = 网页节点类 注释 = "结果通过此参数返回">
    {
        变量 临时句柄 <类型 = 变整数>
        @ @<临时句柄> = (INT_P)Gumbo_Query_Node_childAt((void*)GetData ().@n<网页节点数据类.节点句柄>,@<索引>);
        节点结果._销毁 ()
        节点结果.参考数据.节点句柄 = 临时句柄
    }

    方法 查询元素 <公开 注释 = "创建解析器成功后,可通过本方法在HTML文档中查找元素.">
    参数 选择器文本 <类型 = 文本型 注释 = "所查询内容,支持如下格式:" 注释 = "  1.div.className -  通过元素名.类名来取得元素对象."
            注释 = "  2.div.className > a 通过元素名.类名,得到指定元素对象后,继续获取该元素下的第一个a标签元素." 注释 = "  3.a 取得当前节点元素中所有的div其中的a标签元素.">
    参数 查询结果 <类型 = 网页元素类 注释 = "查询结果保存在此参数中.">
    {
        变量 临时选择器 <类型 = 字节集类>
        变量 查询器句柄 <类型 = 变整数>
        临时选择器 = 文本到UTF8 (选择器文本)
        @ @<查询器句柄> = (INT_P)Gumbo_Query_Node_find((void*)GetData ().@n<网页节点数据类.节点句柄>,(const char *)@<临时选择器>.GetPtr());
        查询结果._销毁 ()  // 防止传递过来的对象存在句柄,销毁一下。
        查询结果.参考数据.查询器句柄 = 查询器句柄
    }

    方法 取属性值 <公开 类型 = 文本型 注释 = "取得指定节点元素内的属性值,例如,\"<img src=? />\",可使用\"取属性值(src)" 注释 = "\",取得img中的src的值." @禁止流程检查 = 真>
    参数 属性名称 <类型 = 文本型>
    {
        @ return @an<CVolString> (Gumbo_Query_Node_attribute((void*)GetData ().@n<网页节点数据类.节点句柄>,(const char*)CU8String (@<属性名称>.GetText ()).GetText ()));
    }

    方法 取属性数量 <公开 类型 = 整数 注释 = "取出当前节点属性数量." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_attributeCount((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取指定属性名 <公开 类型 = 文本型 注释 = "取指定索引属性名称" @禁止流程检查 = 真>
    参数 索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ return CVolString( Gumbo_Query_Node_GetAttributeNameByIndex((void*)GetData ().@n<网页节点数据类.节点句柄>,@<索引>));
    }

    方法 取指定属性值 <公开 类型 = 文本型 注释 = "取指定索引属性值" @禁止流程检查 = 真>
    参数 索引 <类型 = 整数 注释 = "索引从0开始">
    {
        @ return CVolString( Gumbo_Query_Node_GetAttributeValueByIndex((void*)GetData ().@n<网页节点数据类.节点句柄>,@<索引>));
    }

    方法 取所有文本 <公开 类型 = 文本型 注释 = "本方法会取得当前元素中的所有文本内容, 例如 <a>文本1</a><a>文本2</a>,本方法将会" 注释 = "取出文本1和文本2,两个文本会直接拼接起来.">
    {
        变量 返回文本 <类型 = 文本型>
        @ void* pString = Gumbo_Query_Node_text((void*)GetData ().@n<网页节点数据类.节点句柄>);
        @ @<返回文本> = Gumbo_Query_String_GetText(pString);
        @ Gumbo_Query_String_Delete(pString);
        返回 (返回文本)
    }

    方法 取节点文本 <公开 类型 = 文本型 注释 = "取单独的节点文本,确保当前节点对象只有一个html标签时,本方法才有效.">
    {
        变量 返回文本 <类型 = 文本型>
        @ void* pString = Gumbo_Query_Node_ownText((void*)GetData ().@n<网页节点数据类.节点句柄>);
        @ @<返回文本> = Gumbo_Query_String_GetText(pString);
        @ Gumbo_Query_String_Delete(pString);
        返回 (返回文本)
    }

    方法 取节点开始位置2 <公开 类型 = 整数 注释 = "取出节点开始位置,不包含当前节点开始标签." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_startPos((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取节点结束位置2 <公开 类型 = 整数 注释 = "取出节点结束位置,不包含当前节点结束标签." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_endPos((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取节点开始位置 <公开 类型 = 整数 注释 = "取出节点开始位置,包含当前节点开始标签." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_startPosOuter((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取节点结束位置 <公开 类型 = 整数 注释 = "取出节点开始位置,包含当前节点结束标签." @禁止流程检查 = 真>
    {
        @ return Gumbo_Query_Node_endPosOuter((void*)GetData ().@n<网页节点数据类.节点句柄>);
    }

    方法 取节点标签名称 <公开 类型 = 文本型 注释 = "取出当前节点的HTML标签名称">
    {
        变量 返回文本 <类型 = 文本型>
        @ void* pString = Gumbo_Query_Node_tag((void*)GetData ().@n<网页节点数据类.节点句柄> );
        @ @<返回文本> = Gumbo_Query_String_GetText(pString);
        @ Gumbo_Query_String_Delete(pString);
        返回 (返回文本)
    }
}
