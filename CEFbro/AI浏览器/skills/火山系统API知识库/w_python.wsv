    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲检测关键字>.IsEmpty ()) ? -1 : PyDict_Contains (@<欲操作本对象>.Get (), @<欲检测关键字>.Get ()));
    }

    方法 字典_是否存在文本键 <公开 静态 类型 = 整数 注释 = "返回本字典对象中是否存在所指定文本型关键字. 存在返回 1,不存在返回 0,出错返回 -1."
            注释 = "相当于 Python 表达式 \"欲检测文本关键字 in 欲操作本对象\"." @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
