    {
        @ @<欲操作本对象>.IsTupleObject (@<是否检查子类>)
    }

    方法 元组_创建 <公开 静态 类型 = Py对象类 注释 = "成功返回一个为指定尺寸的新元组(tuple)对象,失败返回空对象并设置对应异常." 注释 = "所创建元组对象的所有成员均以空值对象(None)填充."
            @文档 = "category = \"元组对象\"" @嵌入式方法 = "">
    参数 初始成员数目 <类型 = 整数 注释 = "指定所创建元组对象中初始具有的成员数目">
    {
        @ CVolPyObject::sNewTuple (@<初始成员数目>)
    }

    方法 元组 <公开 静态 类型 = Py对象类 注释 = "将提供的所有Py对象打包到一个新建元组对象中,然后将其返回." 返回值注释 = "成功返回所新建元组对象,失败返回空对象并设置对应异常."
            @文档 = "category = \"元组对象\"" @嵌入式方法 = "">
    参数 欲加入成员对象 <类型 = Py对象类 注释 = "提供所有欲加入到新建元组中的Python对象,如果为空对象将被自动转换为空值对象(None)." @可扩展 = "d_text=\".GetNotNull (), \"">
    {
        @ CVolPyObject (PyTuple_Pack ((Py_ssize_t)@sn<pm_count>, @<欲加入成员对象>.GetNotNull ()))
    }

    方法 元组_取尺寸 <公开 静态 类型 = 整数 注释 = "返回本元组对象中成员的数目" @文档 = "category = \"元组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python元组(tuple)对象(\"为对象_元组\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT)PyTuple_Size (@<欲操作本对象>.Get ()));
    }

    方法 元组_取成员 <公开 静态 类型 = Py对象类 注释 = "返回本元组对象中指定索引位置处的成员对象"
            返回值注释 = "返回元组中位于指定索引位置处的对象,如果索引位置为负值或超出范围,则返回空对象并设置一个\"Py异常类型.无效索引\"异常." @文档 = "category = \"元组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python元组(tuple)对象(\"为对象_元组\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "指定欲获取成员所处的索引位置,必须大于等于0且小于本元组的已有成员数目.">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? CVolPyObject () : CVolPyObject_BorrowedRef (PyTuple_GetItem (@<欲操作本对象>.Get (), (Py_ssize_t)@<索引位置>)));
    }

    方法 元组_取片段 <公开 静态 类型 = Py对象类 注释 = "成功返回包含本元组对象中指定范围内所有成员的一个新元组对象,失败返回空对象."
            注释 = "等价于 Python 表达式 \"欲操作本对象 [起始索引位置 : 结束索引位置]\"." 注释 = "" @文档 = "category = \"元组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python元组(tuple)对象(\"为对象_元组\"方法返回真)">
    参数 起始索引位置 <类型 = 整数 注释 = "提供欲获取片段的起始成员索引位置">
    参数 结束索引位置 <类型 = 整数 注释 = "提供欲获取片段的结束成员索引位置,注意该位置处的成员本身并不包含在所返回的片段内.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyTuple_GetSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>));
    }

    方法 元组_置成员 <公开 静态 类型 = 逻辑型 注释 = "将所指定对象赋值给本元组对象指定索引位置处的成员. 成功返回真,失败设置异常并返回假."
            注释 = "相当于 Python 语句 \"欲操作本对象 [索引位置] = 欲置入对象\"." 注释 = "注意: 由于元组的只读属性,本方法应该仅在创建元组后初始化其内容时使用,一旦元组在其它位置被使用,不要再进行修改."
            @文档 = "category = \"元组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python元组(tuple)对象(\"为对象_元组\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "提供欲设置成员的索引位置">
    参数 欲置入对象 <类型 = Py对象类 注释 = "提供欲置入到指定位置处的对象数据">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲置入对象>.IsEmpty ()) ? FALSE : (PyTuple_SetItem (@<欲操作本对象>.Get (), @<索引位置>, Py_NewRef (@<欲置入对象>.Get ())) >= 0));
    }

