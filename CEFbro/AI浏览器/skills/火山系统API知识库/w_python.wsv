类 Python <公开 注释 = "本类封装了Python的重要全局方法,可以用作完成Py代码的编译,加载以及执行等工作." 注释 = ""
        注释 = "  注意: 先前类库\"Python脚本支持\"已经被抛弃,请改用本类库. 如果仍需使用先前的\"Python脚本支持\"类库,"
        注释 = "请下载 https://www.voldp.com/downloads/old_python_class_lib.rar 文件并将其解压覆盖到火山软件开" 注释 = "发平台的安装根目录中即可."
        @视窗.外部库 = "py\\3.14\\capi\\libs\\$(p)\\python314.lib" @视窗.附属文件 = "py\\3.14\\embed\\$(p)"
        @视窗.头文件搜寻目录 = "py\\3.14\\capi\\include" "@视窗.外部头文件.全局-0" = "py\\vol_python_sys.h" @视窗.外部头文件 = "py\\vol_python.h"
        @视窗.外部源文件 = "py\\vol_python.cpp" @类用途 = 访问静态成员>
{
    方法 初始化 <公开 静态 类型 = 逻辑型 注释 = "初始化Python运行时环境." 注释 = "注意: 在执行任何本类库中的功能前,必须首先调用本方法成功初始化Python运行时环境." 返回值注释 = "成功返回真,失败返回假."
            @文档 = "category = \"初始化\"" @嵌入式方法 = "">
    参数 模块附加搜寻目录 <类型 = 文本型 注释 = "提供欲添加的所有附加Python模块搜寻目录,多个目录之间使用分号字符分隔." 注释 = "所提供目录如果不为绝对路径,则相对当前被执行程序目录(\"取模块目录\"全局方法返回值)."
            注释 = "默认已经具有的搜寻目录:" 注释 = "1. 当前被执行程序目录本身;" 注释 = "2. 当前被执行程序目录下的\"python*.zip\"文件;" 注释 = "3. 当前被执行程序目录下的\"DLLs\"子目录;"
            注释 = "4. 当前被执行程序目录下的\"Lib\\site-packages\"子目录;" 注释 = "5. 当前被执行程序目录下的\"_py_ext_libs\"子目录." @默认值 = "">
    参数 调试输出 <类型 = 逻辑型 注释 = "指定在编译调试版本时是否将Python程序输出到标准和错误设备的信息转向到火山平台IDE的调试控制窗口" @默认值 = 真>
    {
        @ CVolPython::sGetVolPython ()->InitPython (@<模块附加搜寻目录>.GetText (), @<调试输出>)
    }

    方法 释放 <公开 静态 注释 = "释放已经初始化的Python运行时环境." 注释 = "执行本方法后,Python运行时环境将复位为未初始化状态." 注释 = "本调用不是必需的,程序退出时会自动释放."
            @文档 = "category = \"初始化\"" @嵌入式方法 = "">
    {
        @ CVolPython::sGetVolPython ()->Cleanup ()
    }

    方法 是否已初始化 <公开 静态 类型 = 逻辑型 注释 = "返回Python运行时环境当前是否已经成功初始化" @文档 = "category = \"初始化\"" @嵌入式方法 = "">
    {
        @ Py_IsInitialized ()
    }

    方法 取版本 <公开 静态 类型 = 文本型 注释 = "返回 Python 解释器的版本. 为如下格式的文本:"
            注释 = "\"3.0a5+ (py3k:63103M, May 12 2008, 00:53:55) \\n[GCC 4.2.3]\""
            注释 = "第一个单词(到第一个空格符为止)是当前的 Python 版本,前面的字符是以点号分隔的主要和次要版本号." @文档 = "category = \"初始化\"" @嵌入式方法 = "">
    {
        @ CVolString (Py_GetVersion ())
    }

    方法 取编译器 <公开 静态 类型 = 文本型 注释 = "返回用于编译当前 Python 版本的编译器指令,为带方括号的形式,如: \"[GCC 2.7.2.2]\"" @文档 = "category = \"初始化\""
            @嵌入式方法 = "">
    {
        @ CVolString (Py_GetCompiler ())
    }

    方法 取构建信息 <公开 静态 类型 = 文本型 注释 = "返回有关当前 Python 解释器实例的序列号和构建日期和时间的信息,例如: \"#67, Aug  1 1997, 22:34:28\""
            @文档 = "category = \"初始化\"" @嵌入式方法 = "">
    {
        @ CVolString (Py_GetBuildInfo ())
    }

    方法 添加模块搜寻目录 <公开 静态 类型 = 逻辑型 注释 = "将指定的目录路径添加到Python模块的搜寻路径中" 返回值注释 = "返回是否成功" @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲添加搜寻目录 <类型 = 文本型 注释 = "提供欲添加的Python模块搜寻目录,如果不为绝对路径,则相对当前被执行程序模块目录(\"取模块目录\"全局方法返回值).">
    参数 是否首先搜寻 <类型 = 逻辑型 注释 = "为真则在搜寻模块时首先搜寻此目录,否则最后搜寻此目录." @默认值 = 假>
    {
        @ CVolPython::sGetVolPython ()->AddModSearchPath (@<欲添加搜寻目录>.GetText (), @<是否首先搜寻>)
    }

    方法 取主模块 <公开 静态 类型 = Py对象类 注释 = "成功返回初始化时所创建的Python主模块(\"__main__\"模块)对象(\"为对象_模块\"返回真),失败返回空对象."
            @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyImport_AddModuleRef ("__main__"))
    }

    方法 取主模块全局空间 <公开 静态 类型 = Py对象类 注释 = "成功返回初始化时所创建的Python主模块(\"__main__\"模块)对象的全局命名空间字典对象(\"Py对象类.为对象_字典\"方法返回真),失败返回空对象."
            @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    {
        @ CVolPyObject_BorrowedRef (CVolPython::sGetMainGlobals ())
    }

    方法 导入模块 <公开 静态 类型 = Py对象类 注释 = "导入所指定名称的Python模块" 返回值注释 = "成功返回对应的模块对象(\"为对象_模块\"方法返回真),失败返回空对象."
            @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲导入模块名称 <类型 = 文本型 注释 = "提供欲导入模块的全名称(即包括包名),不支持使用相对路径.">
    {
        @ CVolPyObject (PyImport_ImportModule (_VolStr2Utf8 (@<欲导入模块名称>)))
    }

    方法 模块能否导入 <公开 静态 类型 = 整数 注释 = "返回所指定名称的 Python 模块能否被导入" 返回值注释 = "所指定名称模块能够被正常导入返回1,因为不存在无法导入返回0,因为其它原因无法导入返回-1."
            @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲检查模块名称 <类型 = 文本型 注释 = "提供欲检查模块的全名称(即包括包名),不支持使用相对路径.">
    {
        @ CVolPython::sIsModuleExist (@<欲检查模块名称>.GetText ())
    }

    方法 取模块登记表 <公开 静态 类型 = Py对象类 注释 = "返回用于Python模块管理的字典(即 sys.modules)"
            返回值注释 = "成功返回对应的字典对象(\"Py对象类.为对象_字典\"方法返回真),失败或不存在返回空对象." @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    {
        @ CVolPyObject_BorrowedRef (PyImport_GetModuleDict ())
    }

    方法 模块是否已登记 <公开 静态 类型 = 逻辑型 注释 = "返回指定名称的模块是否已经登记到\"sys.modules\"系统登记表中" 返回值注释 = "已经登记返回真,未登记或失败返回假."
            @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲检查模块名称 <类型 = 文本型 注释 = "  提供欲检查模块的名称." 注释 = "  注意: 本方法仅简单地检查所提供的名称是否位于\"sys.modules\"系统登记表中,如果该名称"
            注释 = "为使用句点分隔的全限定名称,本方法并不会自动拆分.">
    {
        @ CVolPyObject::sIsModuleRegistered (@<欲检查模块名称>.GetText ())
    }

    方法 查找模块 <公开 静态 类型 = Py对象类 注释 = "查找并返回所指定名称的Python模块" 返回值注释 = "  成功返回对应的模块对象(\"为对象_模块\"方法返回真),失败返回空对象并可能设置一个异常"
            返回值注释 = "(\"不存在是否创建\"参数值为假且模块尚不存在时不会设置)." @文档 = "category = \"模块操作\"" @禁止流程检查 = 真>
    参数 欲查找模块名称 <类型 = 文本型 注释 = "提供欲查找模块的全名称(即包括包名),不支持使用相对路径.">
    参数 不存在是否创建 <类型 = 逻辑型 注释 = "  如果该名称模块尚不存在且本参数值为真,将创建并返回一个新模块(注意不会加载或导入模块内容,"
            注释 = "你将得到一个内容为空白的模块对象),如果该名称模块尚不存在且本参数值为假,将返回空对象." @默认值 = 假>
    {
        @ return CVolPyObject (@<不存在是否创建> ? PyImport_AddModuleRef (_VolStr2Utf8 (@<欲查找模块名称>)) : PyImport_GetModule (CVolPyObject::sCreateFromVolStr (@<欲查找模块名称>).Get ()));
    }

    方法 取模块属性 <公开 静态 类型 = Py对象类 注释 = "导入指定名称的Python模块并获取其中指定属性的值" 返回值注释 = "成功返回所指定名称属性的值,失败返回空对象并设置以下相关异常:"
            返回值注释 = "1. 模块导入失败设置\"Py异常类型.导入出错\"异常;" 返回值注释 = "2. 指定属性不存在设置\"Py异常类型.属性出错\"异常." @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲查询属性全名 <类型 = 文本型 注释 = "提供所欲查询的模块及属性名,为\"模块名.属性名\"格式,如果未提供\"模块名\",则默认为 Python 主模块\"__main__\".">
    {
        @ CVolPython::sGetModuleAttr (@<欲查询属性全名>)
    }

    方法 取模块属性2 <公开 静态 类型 = Py对象类 注释 = "导入指定名称的Python模块并获取其中指定属性的值" 返回值注释 = "成功返回所指定名称属性的值,失败返回空对象并设置以下相关异常:"
            返回值注释 = "1. 模块导入失败设置\"Py异常类型.导入出错\"异常;" 返回值注释 = "2. 指定属性不存在设置\"Py异常类型.属性出错\"异常." @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲导入模块名称 <类型 = 文本型 注释 = "提供欲导入模块的名称">
    参数 欲查询属性名称 <类型 = 文本型 注释 = "提供在指定模块中欲查询属性的名称">
    {
        @ CVolPyObject (PyImport_ImportModuleAttrString (_VolStr2Utf8 (@<欲导入模块名称>), _VolStr2Utf8 (@<欲查询属性名称>)))
    }

    方法 取内置模块 <公开 静态 类型 = Py对象类 注释 = "返回 builtins 内置模块对象,如果不存在则返回空对象." @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    {
        @ CVolPyObject  (PyImport_ImportModule ("builtins")))
    }

    方法 取内置模块属性 <公开 静态 类型 = Py对象类 注释 = "返回 builtins 内置模块中指定名称属性的值,如果不存在则返回空对象" @文档 = "category = \"模块操作\"" @嵌入式方法 = "">
    参数 欲获取属性的名称 <类型 = 文本型 注释 = "提供要获取的内置模块属性名">
    {
        @ CVolPyObject (PyImport_ImportModuleAttrString ("builtins", _VolStr2Utf8 (@<欲获取属性的名称>)))
    }

    方法 取系统模块属性 <公开 静态 类型 = Py对象类 注释 = "返回 sys 模块中指定名称属性的值,如果不存在则返回空对象." 注释 = "本方法不会设置异常." @文档 = "category = \"模块操作\""
            @嵌入式方法 = "">
    参数 欲获取属性的名称 <类型 = 文本型 注释 = "提供要获取的 sys 模块属性名, 如: \"stdout\"、\"path\"、\"version\" 等.">
    {
        @ CVolPyObject_BorrowedRef (PySys_GetObject (_VolStr2Utf8 (@<欲获取属性的名称>)))
    }

    方法 置系统模块属性 <公开 静态 类型 = 逻辑型 注释 = "设置 sys 模块中指定名称属性的值,返回是否成功." @文档 = "category = \"模块操作\"" @禁止流程检查 = 真>
    参数 欲设置属性的名称 <类型 = 文本型 注释 = "提供要设置的 sys 模块属性名, 如: \"stdout\"、\"path\"、\"version\" 等.">
    参数 欲设置的属性值 <类型 = Py对象类 注释 = "提供欲设置的属性值,如果为空对象则删除此属性" @默认值 = 空对象>
    {
        @ return (PySys_SetObject (_VolStr2Utf8 (@<欲设置属性的名称>),  @<欲设置的属性值>.Get ()) == 0);
    }

    方法 调用模块函数 <公开 静态 类型 = Py对象类 注释 = "使用指定参数(由\"位置参数数据\"和\"关键字参数数据\"参数提供)调用所指定的Python模块函数" 返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常."
            @文档 = "category = \"模块操作\"">
    参数 欲调用模块函数全名 <类型 = 文本型 注释 = "提供所欲调用的模块及函数名,为\"模块名.属性名\"格式,如果未提供\"模块名\",则默认为 Python 主模块\"__main__\"."
            编辑时信息 = "104EB4, 0, 0, 0">
    参数 位置参数数据 <类型 = Py对象类 注释 = "关于本参数及下面参数的说明,请参见\"Py对象类.调用\"方法." @默认值 = 空对象>
    参数 关键字参数数据 <类型 = Py对象类 注释 = "" @默认值 = 空对象>
    参数 展开元组 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (取模块属性 (欲调用模块函数全名).调用 (位置参数数据, 关键字参数数据, 展开元组))
    }

    方法 格式调用模块函数 <公开 静态 类型 = Py对象类 注释 = "使用指定参数(由\"类型格式文本\"和\"所提供数据\"参数提供)调用所指定的Python模块函数. 本方法无法提供\"关键字参数数据\"."
            返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常." @文档 = "category = \"模块操作\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲调用模块函数全名 <类型 = 文本型 注释 = "提供所欲调用的模块及函数名,为\"模块名.属性名\"格式,如果未提供\"模块名\",则默认为 Python 主模块\"__main__\".">
    参数 类型格式文本 <类型 = 文本型 注释 = "具体请参见\"Py对象类.格式调用\"方法的\"类型格式文本\"参数说明." 编辑时信息 = "104EB4, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "104EB4, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ CVolPython::sGetModuleAttr (@<欲调用模块函数全名>).FormatCall (@<类型格式文本>.GetText (), _T (@sn<pm_types>) + 2, @<所提供数据>)
    }

    方法 安装包 <公开 静态 类型 = 逻辑型 注释 = "从网络上下载安装所指定名称的 Python 包. 注意:" 注释 = "1. 本类库中自行携带了所有Python标准包,这些包可以无需安装直接导入使用;"
            注释 = "2. 本方法会一直等待到下载安装完毕/确认出错/超时后才会返回,因此可以考虑将本方法放到另一线程中调用;"
            注释 = "3. 即使所指定包上次已经下载安装成功,调用本方法依旧会再次下载,可以通过提供有效的\"检测模块名\"参数来避免反复下载;"
            注释 = "4. 如果您的程序想直接携带相应Python包避免使用时下载,可以提前把包下载好然后放到应用程序的Python模块搜寻目录中,这"
            注释 = "些目录在\"Python.初始化\"方法的\"模块附加搜寻目录\"参数处有描述,一般情况下放到\"_py_ext_libs\"子目录下即可. 具体方法"
            注释 = "为: 在您的源程序\"启动类\"上定义\"@视窗.附属文件\"属性,属性值写为: \"您的Python包目录 > _py_ext_libs\" 或 \"您的"
            注释 = "Python脚本文件名 > _py_ext_libs\". 当然您也可以使用\"Python.添加模块搜寻目录\"方法添加自己的模块搜寻目录并把包放" 注释 = "到该目录中." 返回值注释 = "成功返回真,否则返回假."
            @文档 = "category = \"模块操作\"" @视窗.附属文件 = "py\\3.14\\embed\\pip\\$(p)" @禁止流程检查 = 真>
    参数 欲安装包名 <类型 = 文本型 注释 = "  提供欲安装的Python包名称,必须有效且不为空文本."
            注释 = "  注意: 包名为其在 PyPI 网站上的登记名称,如: \"opencv-python\", \"beautifulsoup4\", \"scikit-learn\"等,"
            注释 = "不等于需要在 Python 程序中导入的模块名. 如果需要使用某模块,必须自行查询其开发文档获取其安装包名.">
    参数 欲安装到目录 <类型 = 文本型 注释 = "  指定欲将指定包安装到的目录位置,如果为相对路径则自动调整到相对当前可执行文件所处目录,如果为空则默认"
            注释 = "为当前可执行文件所处目录的\"\"_py_ext_libs\"\"子目录(为Python模块的默认搜寻目录之一)."
            注释 = "  必须确保该目录具有可写权限. 如果安装成功,该目录路径会被自动加入到本类库的 Python 模块搜寻目录中." @默认值 = "">
    参数 检测模块名 <类型 = 文本型 注释 = "  如果本参数值不为空文本,则在下载安装指定包前,先尝试导入该名称的 Python 模块,如果导入成功,则不再下载安装. 注意:"
            注释 = "  1. 请注意模块名和包名的区别,模块名是在程序中使用的导入名称,而包名为其在 PyPI 网站上的登记名称;"
            注释 = "  2. 不要使用为空白内容的模块进行检查,本方法如果发现所指定模块内容为空(\"Py对象类.模块_为空\"方法返回真),则会认为" 注释 = "已下载内容已经无效,会去重新下载." @默认值 = "">
    参数 最长等待时间 <类型 = 整数 注释 = "指定建立网络连接的最长等待时间,单位秒. 为0表示使用默认值(15秒)." @默认值 = 0>
    参数 重试次数 <类型 = 整数 注释 = "指定建立网络连接的最多重试次数. 为0表示使用默认值(5次)." @默认值 = 0>
    参数 镜像源地址 <类型 = 文本型 注释 = "提供从网络下载指定包时所使用的镜像源地址,为空文本表示无." 注释 = "以下是常用的国内 PyPI 镜像源(这些地址由国内大厂或高校维护,速度极快,同步官方源):"
            注释 = "1. 阿里云 (最稳定、推荐首选): https://mirrors.aliyun.com/pypi/simple/ ;"
            注释 = "2. 清华大学 (高校源,速度极快): https://pypi.tuna.tsinghua.edu.cn/simple/ ;"
            注释 = "3. 中国科学技术大学 (高校源,稳定): https://pypi.mirrors.ustc.edu.cn/simple/ ;"
            注释 = "4. 豆瓣 (老牌源,有时会有缓存延迟): https://pypi.doubanio.com/simple/ ;"
            注释 = "5. 华为云 (企业级源): https://repo.huaweicloud.com/repository/pypi/simple/ ;"
            注释 = "6. 腾讯云 (腾讯内网/外网均可): https://mirrors.cloud.tencent.com/pypi/simple/ ." 注释 = "注意: 以上资料为从网络上查询获取,在使用时请自行验证正确性及可用性."
            @默认值 = "">
    参数 代理服务器地址 <类型 = 文本型 注释 = "提供从网络下载指定包时所使用的代理服务器地址,为空文本表示无." @默认值 = "">
    参数 附加安装参数 <类型 = 文本型 注释 = "提供执行\"pip install\"下载安装指令时的附加参数文本." @默认值 = "">
    参数 错误结果信息 <类型 = 文本型 注释 = "如果不为空对象且执行出错,则将具体错误信息置入其中." @默认值 = 空对象>
    {
        @ return CVolPython::sGetVolPython ()->CheckInstallModule (@<欲安装包名>.GetText (), @<欲安装到目录>.GetText (), @<检测模块名>.GetText (), @<最长等待时间>, @<重试次数>,
        @         @<镜像源地址>.GetText (), @<代理服务器地址>.GetText (), @<附加安装参数>.GetText (), (@<错误结果信息>.IsNullObject () ? NULL : &@<错误结果信息>));
    }

    方法 取内置函数字典 <公开 静态 类型 = Py对象类 注释 = "返回当前执行帧中Python内置函数(如\"print\"这些)字典对象(\"Py对象类.为对象_字典\"方法返回真),不存在则返回空对象."
            @文档 = "category = \"信息获取\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyEval_GetFrameBuiltins ())
    }

    方法 取当前全局空间 <公开 静态 类型 = Py对象类 注释 = "返回当前Python程序执行位置处全局命名空间字典对象(\"Py对象类.为对象_字典\"方法返回真),如果没有当前执行位置则返回空对象."
            @文档 = "category = \"信息获取\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyEval_GetFrameGlobals ())
    }

    方法 取当前局部空间 <公开 静态 类型 = Py对象类 注释 = "返回当前Python程序执行位置处局部命名空间字典对象(\"Py对象类.为对象_字典\"方法返回真),如果没有当前执行位置则返回空对象并设置相关异常."
            @文档 = "category = \"信息获取\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyEval_GetFrameLocals ())
    }

    方法 进入递归检查 <公开 静态 类型 = 逻辑型 注释 = "  标记一个递归层级调用即将被执行的位置,随后本方法将检查是否达到Python调用层级限制,"
            注释 = "如果是的话,将设置一个\"Py异常类型.递归溢出\"异常,并返回真,在其他情况下将返回假." 注释 = "  如果从Python脚本中调用到你的程序,然后在你的程序返回到该Python脚本前又去递归调用"
            注释 = "了其它Python脚本,就必须调用本方法进行递归调用层级检查,避免其溢出." @文档 = "category = \"递归控制\"" @嵌入式方法 = "">
    参数 位置提示文本 <类型 = 文本型 注释 = "如果递归调用层级溢出,所设置的\"Py异常类型.递归溢出\"异常将置入此文本信息." @默认值 = "">
    {
        @ Py_EnterRecursiveCall (_VolStr2Utf8 (@<位置提示文本>))
    }

    方法 退出递归检查 <公开 静态 注释 = "  结束当前递归调用层级检查. 每次成功调用\"进入递归检查\"方法后必须对应调用本方法一次," 注释 = "以退出本层级的Python递归调用层级检查."
            @文档 = "category = \"递归控制\"" @嵌入式方法 = "">
    {
        @ Py_LeaveRecursiveCall ()
    }

    方法 取递归层级限制 <公开 静态 类型 = 整数 注释 = "获取当前Python解释器的递归调用层级上限, 它可以通过\"置递归层级限制\"方法来设置." 注释 = "递归调用层级上限可以防止Python解释器的调用栈无限增长."
            @文档 = "category = \"递归控制\"" @嵌入式方法 = "">
    {
        @ Py_GetRecursionLimit ()
    }

    方法 置递归层级限制 <公开 静态 注释 = "设置Python解释器的递归调用层级限制" @文档 = "category = \"递归控制\"" @嵌入式方法 = "">
    参数 最大允许层级 <类型 = 整数 注释 = "提供欲设置的最大递归调用层级上限值">
    {
        @ Py_SetRecursionLimit (@<最大允许层级>)
    }

    方法 执行代码 <公开 静态 类型 = Py对象类 注释 = "  载入并执行一段Python代码文本."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误."
            返回值注释 = "如果源码类型参数为\"Py源码类型.表达式\",成功执行返回该表达式的计算结果,否则返回执行后的全局命名空间字典对象(可以在其中查询执行后的最新全局变量值)."
            返回值注释 = "失败返回空对象并设置对应异常(使用\"Py异常类\"进行查看处理)." @文档 = "category = \"代码执行\"" @嵌入式方法 = "">
    参数 欲运行的代码 <类型 = 文本型 注释 = "提供欲运行的Python源代码文本,其具体格式由\"源码类型\"参数指定.">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 所关联全局空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的全局命名空间(用作访问全局变量环境)字典对象(\"Py对象类.为对象_字典\"方法返回真),为空对象表示使用默认空间(首先使用当前"
            注释 = "Python程序执行位置所处的全局空间,如没有则使用\"取主模块全局空间\"方法返回的全局空间)."
            注释 = "  可以考虑使用\"Python.新建全局空间\"方法创建的新全局命名空间,以避免被执行代码污染了默认全局命名空间." @默认值 = 空对象>
    参数 所关联局部空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的局部命名空间(用作访问局部变量环境)映射对象(\"Py对象类.为接口_映射\"方法返回真),为空对象表示使用默认空间(使用当前"
            注释 = "Python程序执行位置所处的局部空间)." @默认值 = 空对象>
    {
        @ CVolPython::sRunPythonCode (_VolStr2Utf8 (@<欲运行的代码>), NULL, @<源码类型>, @<所关联全局空间>.Get (), @<所关联局部空间>.Get ())
    }

    方法 执行UTF8代码 <公开 静态 类型 = Py对象类 注释 = "  载入并执行一段为UTF8编码的Python代码文本."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误."
            返回值注释 = "如果源码类型参数为\"Py源码类型.表达式\",成功执行返回该表达式的计算结果,否则返回执行后的全局命名空间字典对象(可以在其中查询执行后的最新全局变量值)."
            返回值注释 = "失败返回空对象并设置对应异常(使用\"Py异常类\"进行查看处理)." @文档 = "category = \"代码执行\"" @禁止流程检查 = 真>
    参数 欲运行的代码 <类型 = 字节集类 注释 = "提供欲运行的为UTF8编码的Python源代码文本,其具体格式由\"源码类型\"参数指定.">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 所关联全局空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的全局命名空间(用作访问全局变量环境)字典对象(\"Py对象类.为对象_字典\"方法返回真),为空对象表示使用默认空间(首先使用当前"
            注释 = "Python程序执行位置所处的全局空间,如没有则使用\"取主模块全局空间\"方法返回的全局空间)."
            注释 = "  可以考虑使用\"Python.新建全局空间\"方法创建的新全局命名空间,以避免被执行代码污染了默认全局命名空间." @默认值 = 空对象>
    参数 所关联局部空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的局部命名空间(用作访问局部变量环境)映射对象(\"Py对象类.为接口_映射\"方法返回真),为空对象表示使用默认空间(使用当前"
            注释 = "Python程序执行位置所处的局部空间)." @默认值 = 空对象>
    {
        @ CVolMem memCode (@<欲运行的代码>);
        @ memCode.AddDWord (0);  // 加上结束零字符
        @ return CVolPython::sRunPythonCode ((const char*)memCode.GetPtr (), NULL, @<源码类型>, @<所关联全局空间>.Get (), @<所关联局部空间>.Get ());
    }

    方法 执行代码文件 <公开 静态 类型 = Py对象类 注释 = "  载入并执行为UTF8编码的Python源代码文件."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误."
            返回值注释 = "如果源码类型参数为\"Py源码类型.表达式\",成功执行返回该表达式的计算结果,否则返回执行后的全局命名空间字典对象(可以在其中查询执行后的最新全局变量值)."
            返回值注释 = "失败返回空对象并设置对应异常(使用\"Py异常类\"进行查看处理)." @文档 = "category = \"代码执行\"" @禁止流程检查 = 真>
    参数 欲运行的代码文件名 <类型 = 文本型 注释 = "提供欲运行的为UTF8编码的Python源代码文件名,其具体格式由\"源码类型\"参数指定.">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 所关联全局空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的全局命名空间(用作访问全局变量环境)字典对象(\"Py对象类.为对象_字典\"方法返回真),为空对象表示使用默认空间(首先使用当前"
            注释 = "Python程序执行位置所处的全局空间,如没有则使用\"取主模块全局空间\"方法返回的全局空间)."
            注释 = "  可以考虑使用\"Python.新建全局空间\"方法创建的新全局命名空间,以避免被执行代码污染了默认全局命名空间." @默认值 = 空对象>
    参数 所关联局部空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的局部命名空间(用作访问局部变量环境)映射对象(\"Py对象类.为接口_映射\"方法返回真),为空对象表示使用默认空间(使用当前"
            注释 = "Python程序执行位置所处的局部空间)." @默认值 = 空对象>
    {
        @ CVolMem memCode;
        @ if (memCode.ReadFromFile (@<欲运行的代码文件名>.GetText ()) < 0)  return CVolPyObject ();
        @ memCode.AddDWord (0);  // 加上结束零字符
        @ return CVolPython::sRunPythonCode ((const char*)memCode.GetPtr (), NULL, @<源码类型>, @<所关联全局空间>.Get (), @<所关联局部空间>.Get ());
    }

    方法 执行简单代码 <公开 静态 类型 = 逻辑型 注释 = "在Python程序主模块(\"__main__\"模块,如果尚不存在将被自动创建)中载入并执行一段Python代码文本" 返回值注释 = "成功返回真,失败返回假."
            @文档 = "category = \"代码执行\"" @禁止流程检查 = 真>
    参数 欲运行的代码 <类型 = 文本型 注释 = "提供欲运行的Python源代码文本">
    {
        @ return (PyRun_SimpleString (_VolStr2Utf8 (@<欲运行的代码>)) == 0);
    }

    方法 执行简单UTF8代码 <公开 静态 类型 = 逻辑型 注释 = "在Python程序主模块(\"__main__\"模块,如果尚不存在将被自动创建)中载入并执行一段为UTF8编码格式的Python代码文本"
            返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"代码执行\"" @禁止流程检查 = 真>
    参数 欲运行的代码 <类型 = 字节集类 注释 = "提供欲运行的为UTF8编码的Python源代码文本">
    {
        @ CVolMem memCode (@<欲运行的代码>);
        @ memCode.AddDWord (0);  // 加上结束零字符
        @ return (PyRun_SimpleString ((const char*)memCode.GetPtr ()) == 0);
    }

    方法 新建全局空间 <公开 静态 类型 = Py对象类 注释 = "新建一个字典对象并填写其\"__builtins__\"属性" @文档 = "category = \"代码执行\"" @嵌入式方法 = "">
    {
        @ CVolPython::sNewGlobalNameSpace ()
    }

    方法 脚本模板函数 <公开 静态 类型 = Py对象类 注释 = "提供\"登记函数\"方法所使用的模板方法." 注释 = "方法所接收到的\"位置参数数据\"和\"关键字参数数据\",请用\"Py对象类.解析参数\"方法进行解析."
            返回值注释 = "用作返回数据到 Python 脚本调用方" @文档 = "category = \"代码执行\"">
    参数 方法脚本全名 <类型 = 文本型 注释 = "提供所执行方法的脚本名称,为调用\"登记函数\"方法时提供的\"方法脚本全名\"参数值. 如果所处模块名称为\"__main__\"脚本程序主模块,则模块名将被省略.">
    参数 用户数据1 <类型 = 变整数 注释 = "为在调用\"登记函数\"方法时所提供的用户数据1">
    参数 用户数据2 <类型 = 变整数 注释 = "为在调用\"登记函数\"方法时所提供的用户数据2">
    参数 位置参数数据 <类型 = Py对象类 注释 = "提供在 Python 脚本中调用本方法时所有顺序传入的\"位置参数数据\",具体请参见\"Py对象类.解析参数\"方法中的同名参数说明."
            注释 = "可以调用\"Py对象类.解析参数\"方法来解析传递过来的本参数和下参数,其解析格式和在脚本中的调用格式需要匹配.">
    参数 关键字参数数据 <类型 = Py对象类 注释 = "提供在 Python 脚本中调用本方法时所有以键值对方式传入的\"关键字参数数据\",具体请参见\"Py对象类.解析参数\"方法中的同名参数说明."
            注释 = "如果 Python 脚本中调用本方法时没有提供关键字参数数据,则本参数值为空对象.">
    {
        返回 (空对象)
    }

    方法 登记函数 <公开 静态 类型 = 逻辑型 注释 = "将静态方法以指定的脚本名称登记到 Python 环境中,登记后即可在 Python 脚本中调用."
            返回值注释 = "\"方法脚本全名\"参数指定的全部方法脚本名称登记成功返回真,其中任一方法脚本名称登记失败即中断登记并返回假." @文档 = "category = \"代码执行\""
            @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 欲登记方法 <注释 = "提供对应需要执行的火山方法,同一个方法可以以多个不同的脚本名称登记." 注释 = "如果提供空对象,则取消指定的脚本名称登记." @匹配方法 = "@脚本模板函数">
    参数 用户数据1 <类型 = 变整数 注释 = "在调用\"欲登记方法\"参数所指定方法时提供到其\"用户数据1\"参数" @默认值 = 0>
    参数 用户数据2 <类型 = 变整数 注释 = "在调用\"欲登记方法\"参数所指定方法时提供到其\"用户数据2\"参数" @默认值 = 0>
    参数 方法脚本全名 <类型 = 文本型 注释 = "  提供所有欲登记到 Python 环境中的方法脚本名称, Python 脚本可以以其中任一名称来调用所登记的火山方法."
            注释 = "  格式为: \"欲登记到模块名称.方法脚本名称\",如果\"欲登记到模块名称\"未提供,则默认为\"__main__\"脚本程序主模"
            注释 = "块. 如果\"欲登记到模块名称\"指定名称的 Python 模块尚不存在,则首先尝试将其导入,如果导入时发现找不到该模块,"
            注释 = "则自动创建一个为该名称的新模块,如果导入时为其它原因导致的失败,则本方法失败并设置相应异常." @可扩展 = "">
    {
        @ CVolPython::sGetVolPython ()->RegisterPyFunctions ((FN_VOL_WITH_KEYWORDS)@<欲登记方法>, NULL, @<用户数据1>, @<用户数据2>, @sn<pm_count> - 3, @<方法脚本全名>)
    }

    方法 计算哈希值 <公开 静态 类型 = 变整数 注释 = "计算并返回指定字节集的哈希值,该算法与 bytes、memoryview 和其他实现\"缓冲区协议\"的内置对象的哈希算法一致." @文档 = "category = \"杂类\""
            @禁止流程检查 = 真>
    参数 欲计算数据 <类型 = 字节集类 注释 = "提供欲计算其哈希值的字节集数据">
    {
        @ return (INT_P)Py_HashBuffer (@<欲计算数据>.GetPtr (), (Py_ssize_t)@<欲计算数据>.GetSize ());
    }

    方法 栈空间是否已耗尽 <公开 静态 类型 = 逻辑型 注释 = "返回Python解释器是否已经耗尽堆栈空间" @文档 = "category = \"杂类\"" @嵌入式方法 = "">
    {
        @ PyOS_CheckStack ()
    }

    方法 加锁解释器 <公开 静态 类型 = 变整数 注释 = "  Python 解释器并非线程安全,为支持多线程 Python 程序,系统设置了名为\"解释器锁\"(GIL)的全局锁,当前"
            注释 = "线程必须首先获取该锁后才能使用本类库中的功能安全操作Python对象. 若未持有此锁,即便是最简单的操作也可" 注释 = "能引发多线程冲突问题: 例如当两个线程同时递增同一对象的引用计数时,最终引用计数可能只增加一次而非两次."
            注释 = "  因此,规则要求只有获得\"解释器锁\"的线程才能使用本类库中封装的任何功能." 注释 = "  如果您涉及到在多线程环境中使用本类库的功能,必须在进入线程后首先调用本方法获取\"解释器锁\",在退出"
            注释 = "线程时再调用\"解锁解释器\"方法释放\"解释器锁\"." 注释 = "  本方法的调用必须与\"解锁解释器\"方法调用一一对应,即调用一次本方法必须对等调用\"解锁解释器\"方法" 注释 = "一次,可以多层嵌套调用."
            注释 = "  使用了本类库功能的线程工作流程:" 注释 = "  1. 进入线程时调用\"加锁解释器\"方法获取\"解释器锁\",然后即可安全使用本类库中的功能;"
            注释 = "  2. 当在线程中开始进行不需要使用本类库功能的耗时工作(如图像处理、加密、复杂数学运算、磁盘 I/O 等)时,"
            注释 = "调用\"保存线程状态\"方法释放\"解释器锁\",允许其它使用了本类库功能的线程获取锁并运行. 注意此调用后绝对" 注释 = "不能再使用本类库中的任何功能(包括自动进行的Python数据类型转换等),否则会导致崩溃;"
            注释 = "  3. 工作完成后,调用\"恢复线程状态\"方法重新获取\"解释器锁\"(如果其它线程正在使用,此处会阻塞等待),恢" 注释 = "复之前保存的线程状态,之后即可再次安全使用本类库中的功能;"
            注释 = "  4. 退出线程时调用\"解锁解释器\"方法释放\"解释器锁\"." 注释 = "  另一种工作流程(本类库同时封装了一个便捷操作类和方法):" 注释 = "  1. 在线程进入位置处定义一个\"Py解释器锁\"类的局部变量;"
            注释 = "  2. 将在线程中不需要使用本类库功能的耗时工作代码放到\"无Python操作\"方法调用语句的子语句块中." 注释 = "  具体请参阅该类和该方法处的说明." 注释 = "注意:"
            注释 = "  1. 如果您的火山代码是从Python脚本中调用过来的(譬如使用\"登记函数\"登记的火山方法),那么在该方法中" 注释 = "不需要加锁解释器,因为Python脚本调用方必定已经加锁了解释器;"
            注释 = "  2. 调用\"Python.初始化\"方法的主线程已经默认加锁了解释器,如果在主线程中启动的子线程需要操作" 注释 = "Python,那么主线程必须先调用\"保存线程状态\"释放解释器,不然会导致子线程在尝试加锁时死锁."
            返回值注释 = "返回解释器在调用本方法之前的锁定状态,在调用对应\"解锁解释器\"方法时必须将本返回值传递过去." @文档 = "category = \"多线程\"" @嵌入式方法 = "">
    {
        @ (INT_P)PyGILState_Ensure ()
    }

    方法 解锁解释器 <公开 静态 注释 = "释放先前调用\"加锁解释器\"方法获取的\"解释器锁\",本方法应该在退出线程时调用." @文档 = "category = \"多线程\"" @嵌入式方法 = "">
    参数 先前锁定状态 <类型 = 变整数 注释 = "必须为对应\"加锁解释器\"方法调用后的返回值">
    {
        @ PyGILState_Release ((PyGILState_STATE)@<先前锁定状态>)
    }

    方法 保存线程状态 <公开 静态 类型 = 变整数 注释 = "  本方法和\"恢复线程状态\"方法用于手动管理\"解释器锁\"(GIL). 它们的核心目的是: 允许程序在执行耗时且不涉及到"
            注释 = "本类库功能调用时临时释放\"解释器锁\",从而让其它使用了本类库功能的线程有机会运行,避免整个程序被\"卡住\"." 注释 = "这两个方法必须成对出现,用作包裹住一段不包含任何本类库功能调用的耗时程序."
            注释 = "  工作流程如下:" 注释 = "  1. 初始状态:" 注释 = "  您的当前线程被调用,此时该线程必须持有了\"解释器锁\"." 注释 = "  2. 调用本方法:"
            注释 = "  释放\"解释器锁\",允许其它使用了本类库功能的线程获取锁并运行. 将当前线程的线程状态保存到局部变量,将当前线" 注释 = "程的线程状态置清空(表示当前线程暂时不再需要使用本类库功能)."
            注释 = "  3. 执行耗时操作: 执行未使用本类库功能的代码(如图像处理、加密、复杂数学运算、磁盘 I/O 等)." 注释 = "  禁忌: 在此期间绝对不能调用本类库中的任何功能(包括自动进行的类型转换等),否则会导致崩溃."
            注释 = "  4. 调用\"恢复线程状态\"方法:" 注释 = "  尝试重新获取\"解释器锁\"(如果其它线程正在使用,此处会阻塞等待),恢复之前保存的线程状态,当前线程后续可以再次" 注释 = "安全地使用本类库中的功能."
            注释 = "  本方法调用必须与\"恢复线程状态\"方法成对调用,而且不能嵌套,即调用本方法后在调用对应\"恢复线程状态\"方法之前不能"
            注释 = "再次调用本方法. 之所以需要使用本方法而不是\"解锁解释器\"来在非线程退出时释放\"解释器锁\",是因为本方法是" 注释 = "轻量级的释放方法且保存了当前线程状态用作后面恢复."
            返回值注释 = "返回当前线程状态,在调用对应\"恢复线程状态\"方法时必须将本返回值传递过去." @文档 = "category = \"多线程\"" @嵌入式方法 = "">
    {
        @ (INT_P)PyEval_SaveThread ()
    }

    方法 恢复线程状态 <公开 静态 注释 = "尝试重新获取\"解释器锁\"(如果其它线程正在使用,此处会阻塞等待),恢复之前保存的线程状态,后续可以安全地再次使用本类库中的功能."
            注释 = "本方法调用必须与\"保存线程状态\"方法成对调用,而且不能嵌套." @文档 = "category = \"多线程\"" @嵌入式方法 = "">
    参数 先前线程状态 <类型 = 变整数 注释 = "必须是先前调用\"保存线程状态\"方法后的返回值">
    {
        @ PyEval_RestoreThread ((PyThreadState*)@<先前线程状态>)
    }

    方法 无Python操作 <公开 静态 注释 = "  本方法封装了\"保存线程状态\"和\"恢复线程状态\"方法调用,用户只需要将未使用本类库功能的耗时代码放入本方法"
            注释 = "调用语句的子语句块中即可,本方法会自动在子语句块的进入位置调用\"保存线程状态\"方法,在子语句块的退出位置调" 注释 = "用\"恢复线程状态\"方法."
            注释 = "  注意: 在本方法的子语句块中,不能使用本类库中的任何功能对 Python 进行操作,也不允许嵌套调用本方法." 编辑时信息 = "183AFB, 0, 0, 0" @文档 = "category = \"多线程\""
            @嵌入式方法 = "name = gil_lock\r\nhas_body = true\r\nbody_header = \"@none\"\r\nbody_tail = \"PyEval_RestoreThread (_pThreadStateBak); }\"">
    {
        @ { PyThreadState* _pThreadStateBak = PyEval_SaveThread ();
    }

    方法 回收垃圾 <公开 静态 类型 = 整数 注释 = "如果垃圾回收器已启用的话,执行完全的垃圾回收." 返回值注释 = "返回已回收的 + 无法回收的不可获取对象的数量,如果垃圾回收器被禁用或已在执行回收,则立即返回0."
            @文档 = "category = \"垃圾回收\"" @嵌入式方法 = "">
    {
        @ (INT)PyGC_Collect ()
    }

    方法 启用垃圾回收器 <公开 静态 类型 = 逻辑型 注释 = "启用垃圾回收器: 类似于 gc.enable() ." 返回值注释 = "返回之前的垃圾回收器启用状态,假为禁用而真为启用."
            @文档 = "category = \"垃圾回收\"" @嵌入式方法 = "">
    {
        @ PyGC_Enable () != 0
    }

    方法 禁用垃圾回收器 <公开 静态 类型 = 逻辑型 注释 = "禁用垃圾回收器: 类似于 gc.disable() ." 返回值注释 = "返回之前的垃圾回收器启用状态,假为禁用而真为启用."
            @文档 = "category = \"垃圾回收\"" @嵌入式方法 = "">
    {
        @ PyGC_Disable () != 0
    }

    方法 垃圾回收器是否已启用 <公开 静态 类型 = 逻辑型 注释 = "查询垃圾回收器的状态,类似于 gc.isenabled() ." 返回值注释 = "返回当前的垃圾回收器启用状态,假为禁用而真为启用."
            @文档 = "category = \"垃圾回收\"" @嵌入式方法 = "">
    {
        @ PyGC_IsEnabled () != 0
    }
}

类 Py解释器锁 <公开 注释 = "  如果您需要在多线程环境下使用本类库功能,可以在线程入口位置定义一个数据类型为本类的局部变量,"
        注释 = "即可支持在线程进入时自动调用\"Python.加锁解释器\"方法,在线程退出(该局部变量被销毁)时自动" 注释 = "调用\"Python.解锁解释器\"方法.">
{
    变量 先前锁定状态 <类型 = 变整数>

    方法 类_初始化
    {
        先前锁定状态 = Python.加锁解释器 ()
    }

    方法 类_清理
    {
        Python.解锁解释器 (先前锁定状态)
    }
}

类 Py异常类 <公开 注释 = "提供所有对Python异常操作的支持. 注意:" 注释 = "  1. Python异常与C++异常的处理机制不同,设置Python异常仅会设置Python异常错误指示器的当前内容,从而导致后续"
        注释 = "Python脚本中断运行,但不会中断当前火山程序自身的运行,因此不需要使用try/catch机制俘获;"
        注释 = "  2. 如果当前存在已经被设置的异常尚未被清除,则Python脚本引擎将进入异常处理机制,从而导致本类库中很多方法执行"
        注释 = "失败. 因此如果发现本类库中某个方法执行始终莫名其妙地失败,应该检查是否前面有操作出错导致设置了异常但未被及时" 注释 = "处理清除,不确定可以在该方法调用语句前调用一下\"Py异常类.清除\"方法试试."
        注释 = "  为了确保程序执行不被已经存在的未处理异常影响,可以在重要功能入口处都调用一下\"Py异常类.清除\"方法." @类用途 = 访问静态成员>
{
    方法 清除 <公开 静态 注释 = "清空Python异常错误指示器" @嵌入式方法 = "">
    {
        @ PyErr_Clear ()
    }

    方法 打印 <公开 静态 注释 = "  如果Python异常错误指示器中当前记录有异常,将其内容打印输出到标准错误输出设备" 注释 = "然后将其清除(相当于调用了\"Py异常类.清除\"方法)."
            注释 = "  注意: 如果调用\"Python.初始化\"方法时\"调试输出\"参数值提供为真,在火山IDE中调试" 注释 = "执行程序时将打印到IDE的调试输出框." @嵌入式方法 = "">
    {
        @ if (PyErr_Occurred () != NULL)  PyErr_Print ()
    }

    方法 设置 <公开 静态 注释 = "将指定异常置入Python异常错误指示器中" @嵌入式方法 = "">
    参数 欲设置异常的类型 <类型 = Py异常类型 注释 = "指定所欲设置异常的类型. 在发现异常后可以使用\"Py异常类.取异常类型\"方法取出.">
    参数 关联错误信息 <类型 = 文本型 注释 = "提供具体的错误信息,该信息将被自动包装为关联用户对象," 注释 = "在发现异常后可以使用\"Py异常类.取异常文本\"方法取出." @默认值 = "">
    {
        @ PyErr_SetString (CVolPython::sGetPythonErrorTypeObject (@<欲设置异常的类型>), _VolStr2Utf8 (@<关联错误信息>))
    }

    方法 设置2 <公开 静态 注释 = "将指定异常置入Python异常错误指示器中" @嵌入式方法 = "">
    参数 欲设置异常的类型 <类型 = Py异常类型 注释 = "指定所欲设置异常的类型. 在发现异常后可以使用\"Py异常类.取异常类型\"方法取出.">
    参数 关联用户对象 <类型 = Py对象类 注释 = "提供具体的关联用户对象,可以是任意Python对象." 注释 = "在发现异常后可以使用\"Py异常类.取异常用户对象\"方法取出.">
    {
        @ PyErr_SetObject (CVolPython::sGetPythonErrorTypeObject (@<欲设置异常的类型>), @<关联用户对象>.Get ())
    }

    方法 设置3 <公开 静态 注释 = "将指定类型异常置入Python异常错误指示器中,关联用户对象为空值对象(None)" @嵌入式方法 = "">
    参数 欲设置异常的类型 <类型 = Py异常类型 注释 = "指定所欲设置异常的类型. 在发现异常后可以使用\"Py异常类.取异常类型\"方法取出.">
    {
        @ PyErr_SetNone (CVolPython::sGetPythonErrorTypeObject (@<欲设置异常的类型>))
    }

    方法 设置警告 <公开 静态 注释 = "设置指定的警告信息" @嵌入式方法 = "">
    参数 欲设置警告的类型 <类型 = Py警告类型>
    参数 警告信息 <类型 = 文本型 @默认值 = "">
    {
        @ PyErr_WarnEx (CVolPython::sGetPythonWarningTypeObject (@<欲设置警告的类型>), _VolStr2Utf8 (@<警告信息>), 1)
    }

    方法 发现异常 <公开 静态 类型 = 逻辑型 注释 = "返回当前Python异常错误指示器是否不为空(已经设置了异常)" @禁止流程检查 = 真>
    参数 是否清除 <类型 = 逻辑型 注释 = "指定如果发现了异常,是否将其清除(相当于调用\"Py异常类.清除\"方法)." @默认值 = 真>
    {
        @ if (PyErr_Occurred () != NULL)  { if (@<是否清除>) PyErr_Clear (); return TRUE; } else return FALSE;
    }

    方法 发现指定异常 <公开 静态 类型 = 逻辑型 注释 = "  如果当前Python异常错误指示器不为空(已经设置了异常),返回该异常错误的类型是否" 注释 = "匹配指定的一个或多个异常错误类型. 本方法不会清除异常错误指示器."
            @嵌入式方法 = "">
    参数 欲检查的异常类型 <类型 = Py异常类型 注释 = "提供需要检查的所有异常错误类型列表" @可扩展 = "">
    {
        @ CVolPython::sExceptionMatches (PyErr_Occurred (), 0, _T (@sn<pm_types>), @<欲检查的异常类型>)
    }

    方法 为指定异常 <公开 静态 类型 = 逻辑型 注释 = "返回指定的异常错误类型对象是否匹配指定的一个或多个异常类型. 本方法不会清除异常错误指示器." @嵌入式方法 = "">
    参数 异常类型对象 <类型 = Py对象类 注释 = "提供欲检查的异常错误类型对象,可以是\"Py异常类.取异常类型\"方法的返回值.">
    参数 欲检查的异常类型 <类型 = Py异常类型 注释 = "提供需要检查的所有异常错误类型列表" @可扩展 = "">
    {
        @ CVolPython::sExceptionMatches (@<异常类型对象>.Get (), 1, _T (@sn<pm_types>), @<欲检查的异常类型>)
    }

    方法 取异常类型 <公开 静态 类型 = Py对象类 注释 = "  如果当前Python异常错误指示器不为空(已经设置了异常),返回该异常错误的类型对象" 注释 = "(注意不是该异常的用户对象),否则返回空对象."
            注释 = "  所返回类型对象可以使用\"Py异常类.为指定异常\"方法进行匹配检查, 本方法不会清除异常错误指示器." @嵌入式方法 = "">
    {
        @ CVolPyObject_BorrowedRef (PyErr_Occurred ())
    }

    方法 取异常文本 <公开 静态 类型 = 文本型 注释 = "  如果当前Python异常错误指示器不为空(已经设置了异常),返回设置该异常错误时同时提供的关联文本,"
            注释 = "否则返回空文本(注意存在异常也可能返回空文本). 本方法不会清除异常错误指示器." @嵌入式方法 = "">
    {
        @ CVolPython::sGetCurrentExceptionString ()
    }

    方法 取异常用户对象 <公开 静态 类型 = Py对象类 注释 = "  如果当前Python异常错误指示器不为空(已经设置了异常),返回该异常错误的用户对象(在调用\"Py异常类.设置2\""
            注释 = "方法时提供的关联错误对象),否则返回空对象. 本方法不会清除异常错误指示器." @嵌入式方法 = "">
    {
        @ CVolPython::sGetCurrentExceptionValue ()
    }

    方法 取异常对象 <公开 静态 类型 = Py对象类 注释 = "  如果当前Python异常错误指示器不为空(已经设置了异常),返回对应的异常错误对象,同时清除异常错误指示器"
            注释 = "(相当于调用了\"Py异常类.清除\"方法). 如果错误指示器为空则返回空对象." 注释 = "  注意: 所返回的异常错误对象并不是设置该异常时提供的关联用户对象,其\"Py对象类.为对象_异常\"方法返回真."
            注释 = "  本方法可以用作在需要临时保存和恢复错误指示器内容时和\"Py异常类.置异常对象\"方法配合使用." @嵌入式方法 = "">
    {
        @ CVolPyObject (PyErr_GetRaisedException ())
    }

    方法 置异常对象 <公开 静态 注释 = "使用\"取异常对象\"方法返回的对象来恢复当前Python异常错误指示器内容" @嵌入式方法 = "">
    参数 异常对象 <类型 = Py对象类 注释 = "为\"Py异常类.取异常对象\"方法返回的对象,为空对象或空值对象将清除异常.">
    {
        @ CVolPython::sSetRaisedException (@<异常对象>.Get ())
    }
}

类 Py输出过滤器 <公开 注释 = "用作截获 Python 程序所有输出到标准输出设备和标准错误设备上的信息文本,以事件的方式通知到本类对象." @视窗.后缀文本 = "public IVolPythonStdMessageFilter">
{
    方法 行输出 <公开 定义事件 类型 = 整数 注释 = "本对象被登记到 Python 系统后,当 Python 程序输出一行文本时,本事件被触发."
            返回值注释 = "返回0表示后面继续输出本信息文本,返回1表示截获此信息文本的输出,后面不再处理.">
    参数 信息行 <类型 = 文本型 注释 = "提供具体的输出信息行文本,注意尾部不包含换行符.">
    参数 为错误信息 <类型 = 逻辑型 注释 = "为真表示该信息为输出到标准错误设备(stderr),为假表示该信息为输出到标准输出设备(stdout).">

    方法 登记 <公开 注释 = "将本过滤器登记到 Python 系统,先前所登记的过滤器将被覆盖." 注释 = "当本对象被销毁时,将自动取消登记." @嵌入式方法 = "">
    {
        @ CVolPython::sGetVolPython ()->SetStdMessageFilter (&@sn<this>)
    }

    方法 取消登记 <公开 注释 = "如果本过滤器已经登记到 Python 系统,取消其登记." @嵌入式方法 = "">
    {
        @ CVolPython::sGetVolPython ()->CheckClearStdMessageFilter (&@sn<this>)
    }

    方法 类_清理
    {
        取消登记 ()
    }

    # @ <include>
    # @ virtual BOOL OnPrintLine (BOOL blStdError, const TCHAR* szMessage) override  { return (@<行输出> (CVolString (szMessage), blStdError) == 0); }
    # @ </include>
}

类 Py函数登记器 <公开 注释 = "用作在 Python 环境中登记一个或多个函数,在其被调用时以事件的方式通知到本类对象." 注释 = "本方式相对\"Python.登记函数\"方法调用方式的优点在于可以在事件处理代码中访问所处类对象."
        @视窗.后缀文本 = "public IVolPyEventReceiver">
{
    方法 被调用 <公开 定义事件 类型 = 整数 注释 = "当所登记名称方法在 Python 脚本中被调用时,本事件被触发.">
    参数 方法脚本全名 <类型 = 文本型 注释 = "提供所执行方法的脚本名称,为调用\"登记\"方法时提供的\"方法脚本全名\"参数值. 如果所处模块名称为\"__main__\"脚本程序主模块,则模块名将被省略.">
    参数 用户数据1 <类型 = 变整数 注释 = "为在调用\"登记\"方法时所提供的用户数据1">
    参数 用户数据2 <类型 = 变整数 注释 = "为在调用\"登记\"方法时所提供的用户数据2">
    参数 位置参数数据 <类型 = Py对象类 注释 = "提供在 Python 脚本中调用所登记方法时所有顺序传入的\"位置参数数据\",具体请参见\"Py对象类.解析参数\"方法中的同名参数说明."
            注释 = "可以调用\"Py对象类.解析参数\"方法来解析传递过来的本参数和下参数,其解析格式和在脚本中的调用格式需要匹配.">
    参数 关键字参数数据 <类型 = Py对象类 注释 = "提供在 Python 脚本中调用所登记方法时所有以键值对方式传入的\"关键字参数数据\",具体请参见\"Py对象类.解析参数\"方法中的同名参数说明."
            注释 = "如果 Python 脚本中调用所登记方法时没有提供关键字参数数据,则本参数值为空对象.">
    参数 返回值 <类型 = Py对象类 注释 = "如果事件处理完毕后需要将值返回到 Python 脚本,填入本参数变量中即可.">

    方法 登记 <公开 类型 = 逻辑型 注释 = "将指定名称的脚本方法登记到 Python 环境中,登记后即可在 Python 脚本中调用,一旦被调用,本对象的\"被调用\"事件即被触发."
            返回值注释 = "\"方法脚本全名\"参数指定的全部方法脚本名称登记成功返回真,其中任一方法脚本名称登记失败即中断登记并返回假." @嵌入式方法 = "req_str_param_text_pointer = true">
    参数 用户数据1 <类型 = 变整数 注释 = "在发送\"被调用\"事件时提供到其\"用户数据1\"参数" @默认值 = 0>
    参数 用户数据2 <类型 = 变整数 注释 = "在发送\"被调用\"事件时提供到其\"用户数据2\"参数" @默认值 = 0>
    参数 方法脚本全名 <类型 = 文本型 注释 = "  提供所有欲登记到 Python 环境中的方法脚本名称, Python 脚本可以以其中任一名称来调用."
            注释 = "  格式为: \"欲登记到模块名称.方法脚本名称\",如果\"欲登记到模块名称\"未提供,则默认为\"__main__\"脚本程序主模"
            注释 = "块. 如果\"欲登记到模块名称\"指定名称的 Python 模块尚不存在,则首先尝试将其导入,如果导入时发现找不到该模块,"
            注释 = "则自动创建一个为该名称的新模块,如果导入时为其它原因导致的失败,则本方法失败并设置相应异常." @可扩展 = "">
    {
        @ CVolPython::sGetVolPython ()->RegisterPyFunctions (NULL, &@sn<this>, @<用户数据1>, @<用户数据2>, @sn<pm_count> - 2, @<方法脚本全名>)
    }

    方法 取消登记 <公开 注释 = "取消先前调用\"登记\"方法登记到 Python 环境中的脚本方法." 注释 = "一般情况下,无需手动调用本方法,本类对象被销毁时会自动调用." @嵌入式方法 = "">
    {
        @ CVolPython::sGetVolPython ()->UnregisterPyFunction (&@sn<this>)
    }

    方法 类_清理
    {
        取消登记 ()
    }

    # @begin
    # <> <include>
    # virtual CVolPyObject OnCallVolMethod (CVolString& strMethodFullName, INT_P npUserData1, INT_P npUserData2, CVolPyObject& args, CVolPyObject& kwargs) override
    # {
    #     CVolPyObject objResult;
    #     @<被调用> (strMethodFullName, npUserData1, npUserData2, args, kwargs, objResult);
    #     return objResult;
    # }
    # <> </include>
    # @end
}

类 Py对象数组类 <公开 基础类 = 对象数组模板类 注释 = "Python对象类的实例对象数组" @模板实现类 = "Py对象类">

类 Py对象类 <公开 注释 = "用作存储一个Python对象,该对象可以是各种类型的Python数据."
        注释 = "Python的语法特点是将所有各种类型的数据(包括基本数据类型)均视作一个对象,因此本类对象可以存储和操作所有Python类型的数据."
        注释 = "在程序中应该使用本类中提供的各种检查方法(\"为对象_xxx\"/\"为接口_xxx\"系列方法)来确定对象中所存储数据的具体类型,再根据此类型来进行对应操作." @别名 = "CVolPyObject">
{
    方法 为空 <公开 静态 类型 = 逻辑型 注释 = "返回本对象内容是否为空." 注释 = "注意: 本类同时支持使用\"本类对象 == 空对象\"表达式来获取对象内容是否为空,其效果与调用本方法一致."
            @文档 = "category = \"基本.检测\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsEmpty ()
    }

    方法 不为空 <公开 静态 类型 = 逻辑型 注释 = "返回本对象内容是否不为空." 注释 = "注意: 本类同时支持使用\"本类对象 != 空对象\"表达式来获取对象内容是否不为空,其效果与调用本方法一致."
            @文档 = "category = \"基本.检测\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsEmpty () == FALSE
    }

    方法 为空或空值 <公开 静态 类型 = 逻辑型 注释 = "返回本对象内容是否为空(\"为空\"方法返回真)或者为空值对象(None,\"为空值\"方法返回真)." @文档 = "category = \"基本.检测\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsEmptyOrNone ()
    }

    方法 为空值 <公开 静态 类型 = 逻辑型 注释 = "  返回本对象是否为Python的空值(None)对象." 注释 = "  注意空对象与空值对象的区别: 空对象表明本对象内现在未保存任何Python对象,而空值对象是一个真实存在"
            注释 = "的特殊Python对象(对应Pyton的None对象,在本类库中使用\"Py常量.空\"表示). 本对象中如果存储了空值对象," 注释 = "\"为空\"方法不会返回真." @文档 = "category = \"基本.检测\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ Py_IsNone (@<欲操作本对象>.Get ()) != 0
    }

    方法 为省略值 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否为Python的省略值(Ellipsis)对象" @文档 = "category = \"基本.检测\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ Py_Is (@<欲操作本对象>.Get (), Py_Ellipsis) != 0
    }

    方法 为未实现值 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否为Python的未实现标识值(NotImplemented)对象" @文档 = "category = \"基本.检测\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ Py_Is (@<欲操作本对象>.Get (), Py_NotImplemented) != 0
    }

    方法 清空 <公开 静态 注释 = "清空本对象的内容" @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.Cleanup ()
    }

    方法 取名称 <公开 静态 类型 = 文本型 注释 = "返回本对象的名称,如无则返回空文本. 本方法不会设置异常." 注释 = "此处所返回的名称为本对象的定义名称,不包括限定前缀. 具体参见\"取限定名称\"方法说明."
            @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.aGetObjectStrAttrValue ("__name__", CVolString ())
    }

    方法 取限定名称 <公开 静态 类型 = 文本型 注释 = "返回本对象的限定名称,如无则返回其名称. 本方法不会设置异常."
            注释 = "限定名称和名称的区别: 当函数或类被嵌套在其它类或函数内部时,\"限定名称\"会提供从外层到内层的完整\"点分路径\",而\"名称\"只提供其自身的简单名称."
            注释 = "譬如,假设 Python 类\"MyClass\"里面定义有一个名为\"test1\"的方法,则其限定名称为\"MyClass.test1\",名称为\"test1\"." @文档 = "category = \"基本.常用\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ CVolString strQualName;
        @ @<欲操作本对象>.aGetObjectStrAttrValue ("__qualname__", strQualName);
        @ if (strQualName.IsEmpty ())
        @     @<欲操作本对象>.aGetObjectStrAttrValue ("__name__", strQualName);
        @ return strQualName;
    }

    方法 取全限定名称 <公开 静态 类型 = 文本型 注释 = "返回本对象的全限定名称(\"模块名称.对象限定名称\"),如无则返回其限定名称." 注释 = "全限定名称和限定名称的区别是前面具有所处模块名称."
            @文档 = "category = \"基本.常用\"">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        变量 模块名称 <类型 = 文本型>
        变量 对象名称 <类型 = 文本型>
        对象名称 = 欲操作本对象.取限定名称 ()
        如果 (文本是否为空 (对象名称) == 假)
        {
            模块名称 = 欲操作本对象.取所处模块名称 ()
            如果 (文本是否为空 (模块名称) == 假)
            {
                返回 (模块名称 + "." + 对象名称)
            }
            否则
            {
                返回 (对象名称)
            }
        }
        返回 ("")
    }

    方法 取所处模块名称 <公开 静态 类型 = 文本型 注释 = "返回本对象所处模块的名称." 注释 = "提示: 如果你需要模块对象(例如为了访问模块内的其它变量),你需要获得模块名称后,再次调用\"导入模块\"方法进行导入."
            返回值注释 = "成功返回本对象所处模块的名称,失败或不存在模块名称记录则返回空文本. 本方法不会设置异常." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.GetInsideModuleName (CVolString ())
    }

    方法 取所处模块 <公开 静态 类型 = Py对象类 注释 = "返回本对象所处模块的对象" 返回值注释 = "成功返回本对象所处模块的对象(\"为对象_模块\"方法返回真),失败或不存在相关记录则返回空对象. 本方法不会设置异常."
            @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.GetInsideModule ()
    }

    方法 取文档 <公开 静态 类型 = 文本型 注释 = "返回本对象的文档信息,如无则返回空文本. 本方法不会设置异常." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.aGetObjectStrAttrValue ("__doc__", CVolString ())
    }

    方法 取指针 <公开 静态 类型 = 变整数 注释 = "返回本对象中保存的Python对象(PyObject*)指针. 一般情况下无需调用本方法." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ (INT_P)@<欲操作本对象>.Get ()
    }

    方法 复制 <公开 静态 类型 = Py对象类 注释 = "建立本对象的复制对象" 返回值注释 = "成功返回所复制的对象,失败返回空对象并设置相应异常." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否深复制 <类型 = 逻辑型 注释 = "为假则进行浅复制(对象的成员/属性只增加引用参考),为真则进行深复制(对象的成员/属性递归复制其值)." @默认值 = 假>
    {
        @ @<欲操作本对象>.MakeClone (@<是否深复制>)
    }

    方法 交换 <公开 静态 注释 = "与另一个对象交换其中的内容" @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 欲交换对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.Xchg (@<欲交换对象>)
    }

    方法 移入 <公开 静态 注释 = "将另一个对象的内容移动到本对象中,本对象中的原有内容将被替换,被移动对象中的内容将被清空." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 欲移入对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.MoveFrom (@<欲移入对象>)
    }

    方法 为文本 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python文本(str)的对象实例." 注释 = "Python文本一旦创建即不可修改,任何修改操作(如替换、拼接)都会生成新文本."
            注释 = "Python文本支持取哈希值,可以用作字典成员中的关键字." @文档 = "category = \"基本.文本\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsStrObject (@<是否检查子类>)
    }

    方法 文本到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的文本创建并返回str类型的Python对象."
            注释 = "注意: 本方法是类型转换方法,用作支持将文本型数据自动转换到本类对象,如: (Py对象类)\"abc\", 本类对象变量1 = \"abc\" ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真
            @禁止流程检查 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        @ return CVolPyObject::sCreateFromVolStr (@<文本内容>);
    }

    方法 对象到文本 <公开 静态 类型 = 文本型 注释 = "返回本对象内容的文本形式." 注释 = "注意:" 注释 = "1. 哪怕本对象不是文本对象,本方法也能返回对应的内容描述文本;"
            注释 = "2. 本方法是类型转换方法,用作支持将本类对象自动转换到文本型数据,如: (文本型)欲操作本对象, 文本变量1 = 欲操作本对象 ."
            注释 = "3. 本方法使用\"str\"来获取文本,用作返回针对用户的便于阅读的文本描述内容." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return @<欲操作本对象>.ToStr (TRUE);
    }

    方法 取文本长度 <公开 静态 类型 = 整数 注释 = "返回本文本(str)对象的长度" @文档 = "category = \"基本.文本\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python文本(str)对象(\"为文本\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsStrObject (TRUE) ? (INT)PyUnicode_GET_LENGTH (@<欲操作本对象>.Get ()) : 0);
    }

    方法 取表达式文本 <公开 静态 类型 = 文本型 注释 = "返回本对象内容的Python表达式文本形式."
            注释 = "与\"对象到文本\"方法不同的是: 本方法使用\"repr\"来获取文本,用作返回针对开发者的Python表达式格式的文本内容." 注释 = "注意: 哪怕本对象不是文本对象,本方法也能返回对应的内容描述文本."
            @文档 = "category = \"基本.文本\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.ToStr (FALSE)
    }

    方法 文本比较 <公开 静态 类型 = 整数 注释 = "将本文本(str)对象使用指定操作类型与另一个文本(str)对象进行比较,返回比较结果." 注释 = "等价于 Python 表达式: \"欲操作本对象 比较类型 欲比较对象\"."
            返回值注释 = "出错时返回-1并设置对应异常,比较成功(结果为逻辑值真)返回1,否则返回0." @文档 = "category = \"基本.文本\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python文本(str)对象(\"为文本\"方法返回真)">
    参数 比较类型 <类型 = Py比较类型 注释 = "指定欲进行的比较类型">
    参数 欲比较文本对象 <类型 = Py对象类 注释 = "提供欲与本对象进行比较的另一个文本(str)对象(\"为文本\"方法返回真)">
    {
        @ @<欲操作本对象>.RichCompareText (@<欲比较文本对象>.Get (), @<比较类型>)
    }

    方法 文本编码 <公开 静态 类型 = Py对象类 注释 = "返回本文本(str)对象中的内容使用指定编码类型进行编码后的结果" 返回值注释 = "成功返回编码后的结果字节串(bytes)对象,失败返回空对象并设置对应异常."
            @文档 = "category = \"基本.文本\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python文本(str)对象(\"为文本\"方法返回真)">
    参数 编码类型 <类型 = 文本型 注释 = "提供所使用的国际标准编码类型,常用的如: \"utf-8\", \"utf-16\", \"gbk\", \"latin-1\", \"ascii\", \"cp936\" 等."
            注释 = "详细可用编码类型列表请参见网址: https://docs.python.org/3/library/codecs.html#standard-encodings" @默认值 = "utf-8">
    参数 错误处理方式 <类型 = 文本型 注释 = "用作指定当遇到编码错误时如何处理,为以下文本值之一:" 注释 = "  \"strict\" (默认): 设置\"Py异常类型.宽文本解码出错\"异常,本方法返回空对象;"
            注释 = "  \"ignore\": 忽略非法数据,继续进行编码;" 注释 = "  \"replace\": 用\'?\'字符替换出错字符;"
            注释 = "  \"backslashreplace\": 用反斜杠转义序列(格式为 \\xhh \\uxxxx \\Uxxxxxxxx 的 Unicode 码值十六进制表示形式)来替换出错字符;"
            注释 = "  \"surrogateescape\": 将 U+DC80 至 U+DCFF 范围内的代理码值转换回原先的字符,这些码值在解码时通过\"surrogateescape\"错误处理方式置入;"
            注释 = "  \"surrogatepass\": 当使用utf系列编码类型(\"utf-8\", \"utf-16\", \"utf-32\", \"utf-16-be\", \"utf-16-le\", \"utf-32-be\", \"utf-32-le\")时,"
            注释 = "允许将代理码值 (U+D800 - U+DFFF) 作为正常码值来编码,否则这些编码器会将文本中出现的代理码值视为错误."
            注释 = "  \"xmlcharrefreplace\": 用 XML/HTML 数字字符引用来替换出错字符,即格式为 &#num; 的 Unicode 码值十进制表示形式;"
            注释 = "  \"namereplace\": 用 \\N{...} 转义序列来替换出错字符,花括号中的是来自 Unicode 字符数据库的 Name 属性." @默认值 = "strict">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyUnicode_AsEncodedString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<编码类型>), _VolStr2Utf8 (@<错误处理方式>)));
    }

    方法 文本解码 <公开 静态 类型 = Py对象类 注释 = "将文本(str)内容先前使用\"文本编码\"方法编码后的结果数据字节串(bytes)进行解码"
            返回值注释 = "成功返回解码后的结果文本(str)对象,失败返回空对象并设置对应异常." @文档 = "category = \"基本.文本\"" @禁止流程检查 = 真>
    参数 欲解码字节串 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真),该字节串中的数据由\"文本编码\"方法返回.">
    参数 编码类型 <类型 = 文本型 注释 = "提供所使用的国际标准编码类型,常用的如: \"utf-8\", \"utf-16\", \"gbk\", \"latin-1\", \"ascii\", \"cp936\" 等."
            注释 = "详细可用编码类型列表请参见网址: https://docs.python.org/3/library/codecs.html#standard-encodings" @默认值 = "utf-8">
    参数 错误处理方式 <类型 = 文本型 注释 = "用作指定当遇到解码错误时如何处理,为以下文本值之一:" 注释 = "  \"strict\" (默认): 设置\"Py异常类型.宽文本解码出错\"异常,本方法返回空对象;"
            注释 = "  \"ignore\": 忽略非法数据,继续进行解码;" 注释 = "  \"replace\": 用 U+FFFD 字符替换出错字节;"
            注释 = "  \"backslashreplace\": 用反斜杠转义序列(格式为 \\xhh 的字节值十六进制表示形式)来替换出错字节;"
            注释 = "  \"surrogateescape\": 将出错字节替换为 U+DC80 至 U+DCFF 范围内的单个代理码值;"
            注释 = "  \"surrogatepass\": 当使用utf系列编码类型(\"utf-8\", \"utf-16\", \"utf-32\", \"utf-16-be\", \"utf-16-le\", \"utf-32-be\", \"utf-32-le\")时,"
            注释 = "允许将代理码值 (U+D800 - U+DFFF) 作为正常码值来解码,否则这些解码器会将文本中出现的代理码值视为错误." @默认值 = "strict">
    {
        @ char* pBuffer = NULL;
        @ Py_ssize_t sstLength = 0;
        @ if (@<欲解码字节串>.IsEmpty () ||  PyBytes_AsStringAndSize (@<欲解码字节串>.Get (), &pBuffer, &sstLength) < 0)  return CVolPyObject ();
        @ return CVolPyObject (PyUnicode_Decode (pBuffer, sstLength, _VolStr2Utf8 (@<编码类型>), _VolStr2Utf8 (@<错误处理方式>)));
    }

    方法 为整数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python整数(int)的对象实例." 注释 = "注意: Python 的整数没有固定位数限制(受限于内存),可以处理极大的整数值,不会溢出."
            @文档 = "category = \"基本.整数\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsLongObject (@<是否检查子类>)
    }

    方法 字节到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的字节值创建并返回int类型的Python对象" @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
