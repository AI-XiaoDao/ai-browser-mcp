        @ @<欲操作本对象>.IsFrozenSetObject (@<是否检查子类>)
    }

    方法 为对象_任意集合 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python集合(set)或只读集合(frozenset)类型的对象实例."
            注释 = "集合和只读集合对象均可以被枚举(\"取枚举器\"方法返回非空对象)." 注释 = "本方法返回真,则\"为对象_集合\"和\"为对象_只读集合\"方法也必定返回真." @文档 = "category = \"集合对象\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsAnySetObject (@<是否检查子类>)
    }

    方法 集合_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个新的集合(set)/只读集合(frozenset)对象." 注释 = "" 返回值注释 = "成功返回所创建的对象,失败返回空对象."
            @文档 = "category = \"集合对象\"" @禁止流程检查 = 真>
    参数 是否创建只读集合 <类型 = 逻辑型 注释 = "本参数值为真创建只读集合(frozenset)对象,否则创建集合(set)对象." @默认值 = 假>
    参数 初始内容对象 <类型 = Py对象类 注释 = "提供一个可枚举对象(\"取枚举器\"方法返回非空对象),其中的所有内容将被拷贝进所创建的集合对象中."
            注释 = "如果为空对象,表示没有初始内容,如果提供了非空对象但是其不可被枚举,方法将失败并设置\"Py异常类型.类型无效\"异常." 注释 = "调用本方法时提供另一个集合对象可以建立该对象的复制集合." @默认值 = 空对象>
    {
        @ return CVolPyObject (@<是否创建只读集合> ? PyFrozenSet_New (@<初始内容对象>.Get ()) : PySet_New (@<初始内容对象>.Get ()));
    }

    方法 集合 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个新的集合(set)/只读集合(frozenset)对象并加入初始内容" 注释 = "" 返回值注释 = "成功返回所创建的对象,失败返回空对象."
            @文档 = "category = \"集合对象\"" @嵌入式方法 = "">
    参数 是否创建只读集合 <类型 = 逻辑型 注释 = "本参数值为真创建只读集合(frozenset)对象,否则创建集合(set)对象." @默认值 = 假>
    参数 初始加入对象 <类型 = Py对象类 注释 = "提供所有欲加入到所创建集合中的对象,必须支持计算哈希值. 所有空对象将被忽略." @可扩展 = "d_text=\".Get (), \"">
    {
        @ CVolPyObject::sNewSetWithItems (@<是否创建只读集合>, @sn<pm_count> - 1, @<初始加入对象>.Get ())
    }

    方法 集合_取尺寸 <公开 静态 类型 = 整数 注释 = "成功时返回本集合对象中成员的数目,失败时返回 -1 . 相当于Python的 \"len(欲操作本对象)\" 表达式." @文档 = "category = \"集合对象\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python任意集合(set/frozenset)对象(\"为对象_任意集合\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : (INT)PySet_Size (@<欲操作本对象>.Get ()));
    }

    方法 集合_是否存在 <公开 静态 类型 = 整数 注释 = "返回本集合对象中是否存在所指定关键字. 存在返回 1,不存在返回 0,出错返回 -1 并设置对应异常." @文档 = "category = \"集合对象\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python任意集合(set/frozenset)对象(\"为对象_任意集合\"方法返回真)">
    参数 欲检测关键字 <类型 = Py对象类 注释 = "提供欲检测其是否存在的关键字,必须支持计算哈希值.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲检测关键字>.IsEmpty ()) ? -1 : PySet_Contains (@<欲操作本对象>.Get (), @<欲检测关键字>.Get ()));
    }

    方法 集合_添加 <公开 静态 类型 = 逻辑型 注释 = "将指定所有对象添加到本集合对象中. 成功返回真,失败设置异常并返回假." 注释 = "本方法可用于只读集合(frozenset),用来为全新的只读集合在被其他代码使用之前填充初始值."
            @文档 = "category = \"集合对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python任意集合(set/frozenset)对象(\"为对象_任意集合\"方法返回真)">
    参数 欲添加对象 <类型 = Py对象类 注释 = "提供欲添加到本集合对象中的所有对象,必须支持计算哈希值. 所有空对象将被忽略." @可扩展 = "d_text=\".Get (), \"">
    {
        @ @<欲操作本对象>.SetAddItem (@sn<pm_count> - 1, @<欲添加对象>.Get ())
    }

    方法 集合_删除 <公开 静态 类型 = 整数 注释 = "将指定关键字从本集合对象中删除" 返回值注释 = "返回1表示找到了指定关键字且成功删除,返回0表示未找到该关键字,返回-1表示删除失败(此时会设置异常)."
            @文档 = "category = \"集合对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python集合(set)对象(\"为对象_集合\"方法返回真),不能是只读集合(frozenset)对象.">
    参数 欲删除关键字 <类型 = Py对象类 注释 = "提供欲从本集合对象中删除的关键字,必须支持计算哈希值.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲删除关键字>.IsEmpty ()) ? -1 : PySet_Discard (@<欲操作本对象>.Get (), @<欲删除关键字>.Get ()));
    }

    方法 集合_弹出 <公开 静态 类型 = Py对象类 注释 = "从本集合对象中随机移除一个关键字并将其返回,相当于 Python 方法调用 \"欲操作本对象.pop()\"."
            注释 = "由于集合是无序的,你无法预测会被移除的具体是哪个元素." 返回值注释 = "成功返回被移除的关键字,集合为空或移除失败返回空对象并设置对应异常." @文档 = "category = \"集合对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python集合(set)对象(\"为对象_集合\"方法返回真),不能是只读集合(frozenset)对象.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PySet_Pop (@<欲操作本对象>.Get ()));
    }

    方法 集合_清空 <公开 静态 类型 = 逻辑型 注释 = "清空本集合对象中的所有成员" 返回值注释 = "成功返回真,失败返回假且设置对应异常." @文档 = "category = \"集合对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python集合(set)对象(\"为对象_集合\"方法返回真),不能是只读集合(frozenset)对象.">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PySet_Clear (@<欲操作本对象>.Get ()) >= 0));
    }

    方法 为对象_函数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python函数(function)类型的对象实例."
            注释 = "函数类型的对象实现了Python可调用(callable)接口协议(\"为接口_可调用\"方法返回真)." @文档 = "category = \"函数对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsFunctionObject ()
    }

    方法 为对象_C函数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python C函数(cfunction)类型的对象实例,该类型的函数在外部C代码中实现."
            注释 = "C函数类型的对象实现了Python可调用(callable)接口协议(\"为接口_可调用\"方法返回真)." @文档 = "category = \"函数对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsCFunctionObject (@<是否检查子类>)
    }

    方法 函数_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个函数对象" 返回值注释 = "成功返回所创建的函数对象(其\"为对象_函数\"方法返回真),失败返回空对象并设置相应异常."
            @文档 = "category = \"函数对象\"" @嵌入式方法 = "">
    参数 所关联代码对象 <类型 = Py对象类 注释 = "提供欲与所创建函数关联的代码对象(其\"为对象_代码\"方法返回真),不能为空对象." 注释 = "本方法将从该对象中获取所创建函数的文档字符串和名称.">
    参数 所关联全局空间 <类型 = Py对象类 注释 = "  提供所创建函数在执行时需要访问的全局命名空间,必须为一个字典(dict)对象(\"为对象_字典\"方法返回真),用作在函数"
            注释 = "运行时查找全局变量、导入模块、解析未绑定名称等. 本方法将从该对象中获取函数所处模块等信息."
            注释 = "  如果为空对象,示使用默认空间(首先使用当前Python程序执行位置所处的全局空间,如没有则使用\"取主模块全局空间\"方" 注释 = "法返回的全局空间)."
            注释 = "  可以考虑使用\"Python.新建全局空间\"方法创建的新全局命名空间,以避免函数被执行时污染了默认全局命名空间." @默认值 = 空对象>
    参数 函数限定名称 <类型 = 文本型 注释 = "如果不为空文本,用作显式指定所创建函数的限定名(qualified name),即\"__qualname__\"属性,如: \"MyClass.my_method\"."
            注释 = "如果为空文本, 函数的 \"__qualname__\" 属性会被设为与代码对象的 \"co_qualname\" 属性相同的值." @默认值 = "">
    {
        @ CVolPython::sNewFunctionObject (@<所关联代码对象>.Get (), @<所关联全局空间>.Get (), @<函数限定名称>.GetText ())
    }

    方法 函数_取代码 <公开 静态 类型 = Py对象类 注释 = "成功返回与本函数对象关联的代码对象,失败返回空对象." @文档 = "category = \"函数对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python函数(function)对象(\"为对象_函数\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsFunctionObject () == FALSE ? CVolPyObject () : CVolPyObject_BorrowedRef (PyFunction_GetCode (@<欲操作本对象>.Get ())));
    }

    方法 函数_取全局空间 <公开 静态 类型 = Py对象类 注释 = "成功返回与本函数对象关联的全局空间字典对象(\"为对象_字典\"方法返回真),失败返回空对象." @文档 = "category = \"函数对象\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python函数(function)对象(\"为对象_函数\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsFunctionObject () == FALSE ? CVolPyObject () : CVolPyObject_BorrowedRef (PyFunction_GetGlobals (@<欲操作本对象>.Get ())));
    }

    方法 函数_取注解 <公开 静态 类型 = Py对象类 注释 = "  成功返回本函数对象的注解字典对象(\"为对象_字典\"方法返回真),失败或不存在返回空对象."
            注释 = "  函数的注解字典对象保存在函数对象的 \"__annotations__\" 属性中,这个字典存储了" 注释 = "函数的参数类型提示和返回值类型提示等信息." @文档 = "category = \"函数对象\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python函数(function)对象(\"为对象_函数\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsFunctionObject () == FALSE ? CVolPyObject () : CVolPyObject_BorrowedRef (PyFunction_GetAnnotations (@<欲操作本对象>.Get ())));
    }

    方法 为对象_方法 <公开 静态 类型 = 逻辑型 注释 = "  返回本对象是否是一个Python方法(method)类型的对象实例." 注释 = "  方法是绑定的函数对象,它总是会被绑定到一个用户自定义类的对象实例,未绑定方法(绑定"
            注释 = "到一个类的方法)已不再被最新Python版本支持." 注释 = "  方法类型的对象实现了Python可调用(callable)接口协议(\"为接口_可调用\"方法返回真)."
            注释 = "  方法与函数具有相同的调用方式,且总会自动把所绑定的对象实例作为函数的第一个参数传" 注释 = "递过去,后面跟随调用方提供的所有参数." @文档 = "category = \"方法对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsMethodObject ()
    }

    方法 为对象_C方法 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python C方法(cmethod)类型的对象实例,该类型的方法在外部C代码中实现."
            注释 = "C方法类型的对象实现了Python可调用(callable)接口协议(\"为接口_可调用\"方法返回真)." @文档 = "category = \"方法对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsCMethodObject (@<是否检查子类>)
    }

    方法 方法_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个新的方法对象. 有关方法对象的解释参见\"为对象_方法\"."
            返回值注释 = "成功返回所创建的方法对象(其\"为对象_方法\"方法返回真),失败返回空对象并设置相应异常." @文档 = "category = \"方法对象\"" @禁止流程检查 = 真>
    参数 所绑定对象实例 <类型 = Py对象类 注释 = "提供方法绑定到的对象实例,在方法被调用时将自动作为所绑定函数的 \"self\" 首参数提供过去.">
    参数 所绑定函数对象 <类型 = Py对象类 注释 = "提供方法绑定到的可调用(\"为接口_可调用\"方法返回真)对象,不能为空对象." 注释 = "在方法被调用时本参数对象将作为函数被调用.">
    {
        @ return CVolPyObject ((@<所绑定函数对象>.IsObjectImplCallable () == FALSE || @<所绑定对象实例>.IsEmpty ()) ? NULL : PyMethod_New (@<所绑定函数对象>.Get (), @<所绑定对象实例>.Get ()));
    }

    方法 方法_取函数 <公开 静态 类型 = Py对象类 注释 = "返回本方法对象所绑定到的可调用(\"为接口_可调用\"方法返回真)对象" @文档 = "category = \"方法对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python方法(method)对象(\"为对象_方法\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsMethodObject () == FALSE ? CVolPyObject () : CVolPyObject_BorrowedRef (PyMethod_Function (@<欲操作本对象>.Get ())));
    }

    方法 方法_取自身 <公开 静态 类型 = Py对象类 注释 = "返回本方法对象所绑定到的\"self\"对象实例" @文档 = "category = \"方法对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python方法(method)对象(\"为对象_方法\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsMethodObject () == FALSE ? CVolPyObject () : CVolPyObject_BorrowedRef (PyMethod_Self (@<欲操作本对象>.Get ())));
    }

    方法 为对象_代码 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python代码(Code)类型的对象实例" @文档 = "category = \"代码对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsCodeObject ()
    }

    方法 代码_创建模块 <公开 静态 类型 = Py对象类 注释 = "在本对象为代码对象(\"为对象_代码\"方法返回真)时,使用其中内容创建并返回一个模块."
            返回值注释 = "成功返回对应的模块对象(\"为对象_模块\"方法返回真),失败返回空对象并可能设置一个异常." @文档 = "category = \"代码对象\"">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是代码对象(\"为对象_代码\"方法返回真)">
    参数 欲创建模块名称 <类型 = 文本型 注释 = "提供欲创建模块的名称. 该名称用作引用模块中存在的名称,不能为空文本." 注释 = "注意: 一旦失败,此名称的模块会被从系统中移除,即使该名称的模块在执行本方法前已经存在.">
    参数 对应源文件名 <类型 = 文本型 注释 = "如果本参数值不为空文本,则会将其设为所返回模块对象的\"__file__\"属性值." @默认值 = "">
    {
        如果 (文本是否为空 (欲创建模块名称) == 假 && 欲操作本对象.为对象_代码 ())
        {
            如果 (文本是否为空 (对应源文件名))
            {
                @ return CVolPyObject (PyImport_ExecCodeModule (_VolStr2Utf8 (@<欲创建模块名称>), @<欲操作本对象>.Get ()));
            }
            否则
            {
                @ return CVolPyObject (PyImport_ExecCodeModuleEx (_VolStr2Utf8 (@<欲创建模块名称>), @<欲操作本对象>.Get (), _VolStr2Utf8 (@<对应源文件名>)));
            }
        }
        返回 (空对象)
    }

    方法 编译代码 <公开 静态 类型 = Py对象类 注释 = "  编译一段指定Python程序." 注释 = "  可以把需要频繁执行的Python程序先编译为代码对象后再执行,避免每次执行前都进行编译."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜"
            注释 = "寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\"方法时提供),否则代码编译时会报告模块导入失败错误."
            返回值注释 = "  成功返回对应的新建代码对象(\"为对象_代码\"方法返回真),失败返回空对象并设置对应异常(如\"Py异常类型.语法错误\"," 返回值注释 = "可使用\"Py异常类\"进行查看处理)."
            @文档 = "category = \"代码对象\"" @嵌入式方法 = "">
    参数 欲编译的代码 <类型 = 文本型 注释 = "提供欲编译的Python源代码文本">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 文件名 <类型 = 文本型 注释 = "本参数提供的文件名将被用来构建代码对象并可能出现在调用栈或\"Py异常类型.语法错误\"异常消息中,用作提示作用." @默认值 = "">
    参数 优化方式 <类型 = 整数 注释 = "指定编译器的优化级别:" 注释 = "-1: 选择与 -O 选项相同的解释器优化级别;" 注释 = "0: 无优化, __debug__ 为真;"
            注释 = "1: 断言被移除, __debug__ 为假;" 注释 = "2: 断言被移除, __debug__ 为假, 文档字符串也被移除." @默认值 = -1>
    {
        @ CVolPyObject (Py_CompileStringExFlags (_VolStr2Utf8 (@<欲编译的代码>), _VolStr2Utf8 (@<文件名>), @<源码类型>, NULL, @<优化方式>))
    }

    方法 编译UTF8代码 <公开 静态 类型 = Py对象类 注释 = "  编译一段为UTF8编码的指定Python程序." 注释 = "  可以把需要频繁执行的Python程序先编译为代码对象后再执行,避免每次执行前都进行编译."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜"
            注释 = "寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\"方法时提供),否则代码编译时会报告模块导入失败错误."
            返回值注释 = "  成功返回对应的新建代码对象(\"为对象_代码\"方法返回真),失败返回空对象并设置对应异常(如\"Py异常类型.语法错误\"," 返回值注释 = "可使用\"Py异常类\"进行查看处理)."
            @文档 = "category = \"代码对象\"" @禁止流程检查 = 真>
    参数 欲编译的代码 <类型 = 字节集类 注释 = "提供欲编译的为UTF8编码的Python源代码文本">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 文件名 <类型 = 文本型 注释 = "本参数提供的文件名将被用来构建代码对象并可能出现在调用栈或\"Py异常类型.语法错误\"异常消息中,用作提示作用." @默认值 = "">
    参数 优化方式 <类型 = 整数 注释 = "指定编译器的优化级别:" 注释 = "-1: 选择与 -O 选项相同的解释器优化级别;" 注释 = "0: 无优化, __debug__ 为真;"
            注释 = "1: 断言被移除, __debug__ 为假;" 注释 = "2: 断言被移除, __debug__ 为假, 文档字符串也被移除." @默认值 = -1>
    {
        @ CVolMem memCode (@<欲编译的代码>);
        @ memCode.AddDWord (0);  // 加上结束零字符
        @ return CVolPyObject (Py_CompileStringExFlags ((const char*)memCode.GetPtr (), _VolStr2Utf8 (@<文件名>), @<源码类型>, NULL, @<优化方式>));
    }

    方法 编译代码文件 <公开 静态 类型 = Py对象类 注释 = "  编译为UTF8编码的指定Python源程序文件." 注释 = "  可以把需要频繁执行的Python程序先编译为代码对象后再执行,避免每次执行前都进行编译."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜"
            注释 = "寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\"方法时提供),否则代码编译时会报告模块导入失败错误."
            返回值注释 = "  成功返回对应的新建代码对象(\"为对象_代码\"方法返回真),失败返回空对象并设置对应异常(如\"Py异常类型.语法错误\"," 返回值注释 = "可使用\"Py异常类\"进行查看处理)."
            @文档 = "category = \"代码对象\"" @禁止流程检查 = 真>
    参数 欲编译的代码文件名 <类型 = 文本型 注释 = "提供欲编译的为UTF8编码的Python源代码文件名">
    参数 源码类型 <类型 = Py源码类型 @默认值 = Py源码类型.多行语句>
    参数 文件名 <类型 = 文本型 注释 = "本参数提供的文件名将被用来构建代码对象并可能出现在调用栈或\"Py异常类型.语法错误\"异常消息中,用作提示作用." @默认值 = "">
    参数 优化方式 <类型 = 整数 注释 = "指定编译器的优化级别:" 注释 = "-1: 选择与 -O 选项相同的解释器优化级别;" 注释 = "0: 无优化, __debug__ 为真;"
            注释 = "1: 断言被移除, __debug__ 为假;" 注释 = "2: 断言被移除, __debug__ 为假, 文档字符串也被移除." @默认值 = -1>
    {
        @ CVolMem memCode;
        @ if (memCode.ReadFromFile (@<欲编译的代码文件名>.GetText ()) < 0)  return CVolPyObject ();
        @ memCode.AddDWord (0);  // 加上结束零字符
        @ return CVolPyObject (Py_CompileStringExFlags ((const char*)memCode.GetPtr (), _VolStr2Utf8 (@<文件名>), @<源码类型>, NULL, @<优化方式>));
    }

    方法 代码_执行 <公开 静态 类型 = Py对象类 注释 = "  执行一段已事先编译好的代码."
            注释 = "  注意: 如果该代码中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码运行时会报告模块导入失败错误."
            返回值注释 = "如果源码类型参数为\"Py源码类型.表达式\",成功执行返回该表达式的计算结果,否则返回执行后的全局命名空间字典对象(可以在其中查询执行后的最新全局变量值)."
            返回值注释 = "失败返回空对象并设置对应异常(使用\"Py异常类\"进行查看处理)." @文档 = "category = \"代码对象\"" @嵌入式方法 = "">
    参数 所编译的代码 <类型 = Py对象类 注释 = "本对象必须是代码对象(\"为对象_代码\"方法返回真),由\"编译代码\"方法返回.">
    参数 源码类型 <类型 = Py源码类型 注释 = "必须为在调用\"编译代码\"方法编译获取\"所编译的代码\"对象时所提供的\"源码类型\"参数值" @默认值 = Py源码类型.多行语句>
    参数 所关联全局空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的全局命名空间(用作提供或访问全局变量环境)字典对象(\"为对象_字典\"方法返回真),为空对象表示使用默认空间(首先使用当前"
            注释 = "Python程序执行位置所处的全局空间,如没有则使用\"取主模块全局空间\"方法返回的全局空间)."
            注释 = "  可以考虑使用\"Python.新建全局空间\"方法创建的新全局命名空间,以避免被执行代码污染了默认全局命名空间." @默认值 = 空对象>
    参数 所关联局部空间 <类型 = Py对象类 注释 = "  提供代码执行时将访问的局部命名空间(用作访问局部变量环境)映射对象(\"为接口_映射\"方法返回真),为空对象表示使用默认空间(使用当前"
            注释 = "Python程序执行位置所处的局部空间)." @默认值 = 空对象>
    {
        @ CVolPython::sRunPythonCode ("", @<所编译的代码>.Get (), @<源码类型>, @<所关联全局空间>.Get (), @<所关联局部空间>.Get ())
    }

    方法 为对象_模块 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python模块(Module)类型的对象实例" @文档 = "category = \"模块对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsModuleObject (@<是否检查子类>)
    }

    方法 模块_创建 <公开 静态 类型 = Py对象类 注释 = "创建指定名称的空模块" 注释 = "" 返回值注释 = "成功返回所创建的Python模块对象(\"为对象_模块\"返回真),失败返回空对象并有可能设置对应异常."
            @文档 = "category = \"模块对象\"" @嵌入式方法 = "">
    参数 欲创建模块名称 <类型 = 文本型 注释 = "提供欲创建模块的名称,该名称用作引用模块中存在的名称,不能为空文本.">
    参数 是否登记 <类型 = 逻辑型 注释 = "指定是否将所创建模块登记到\"sys.modules\"系统登记表中以让外部模块可以引用其中的内容." @默认值 = 假>
    参数 对应源文件名 <类型 = 文本型 注释 = "如果本参数值不为空文本,则会将其设为所返回模块对象的\"__file__\"属性值." @默认值 = "">
    {
        @ CVolPyObject::sNewModuleObject (@<欲创建模块名称>.GetText (), @<是否登记>, @<对应源文件名>.GetText ())
    }

    方法 模块_从代码创建 <公开 静态 类型 = Py对象类 注释 = "创建指定名称的模块,然后在其中载入所提供的Python源代码,并将其登记到\"sys.modules\"系统登记表中以让外部模块可以引用其中的内容." 注释 = ""
            返回值注释 = "成功返回所创建的Python模块对象(\"为对象_模块\"返回真),失败返回空对象并有可能设置对应异常." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲创建模块名称 <类型 = 文本型 注释 = "提供欲创建模块的名称,该名称用作引用模块中存在的名称,不能为空文本.">
    参数 欲载入的代码 <类型 = 文本型 注释 = "  提供欲载入到模块中的Python源代码文本,如果为空文本,表示仅创建模块."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误.">
    参数 对应源文件名 <类型 = 文本型 注释 = "如果本参数值不为空文本,则会将其设为所返回模块对象的\"__file__\"属性值." @默认值 = "">
    {
        如果 (文本是否为空 (欲载入的代码))  // 没有提供源代码?
        {
            返回 (模块_创建 (欲创建模块名称, 真, 对应源文件名))
        }
        否则
        {
            返回 (Py对象类.编译代码 (欲载入的代码).代码_创建模块 (欲创建模块名称, 对应源文件名))
        }
    }

    方法 模块_从UTF8代码创建 <公开 静态 类型 = Py对象类 注释 = "创建指定名称的模块,然后在其中载入所提供的为UTF8编码的Python源代码,并将其登记到\"sys.modules\"系统登记表中以让外部模块可以引用其中的内容."
            注释 = "" 返回值注释 = "成功返回所创建的Python模块对象(\"为对象_模块\"返回真),失败返回空对象并有可能设置对应异常." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲创建模块名称 <类型 = 文本型 注释 = "提供欲创建模块的名称,该名称用作引用模块中存在的名称,不能为空文本.">
    参数 欲载入的代码 <类型 = 字节集类 注释 = "  提供欲载入到模块中的为UTF8编码的Python源代码文本,如果为空字节集,表示仅创建模块."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误.">
    参数 对应源文件名 <类型 = 文本型 注释 = "如果本参数值不为空文本,则会将其设为所返回模块对象的\"__file__\"属性值." @默认值 = "">
    {
        如果 (欲载入的代码.字节集是否为空 ())  // 没有提供源代码?
        {
            返回 (模块_创建 (欲创建模块名称, 真, 对应源文件名))
        }
        否则
        {
            返回 (Py对象类.编译UTF8代码 (欲载入的代码).代码_创建模块 (欲创建模块名称, 对应源文件名))
        }
    }

    方法 模块_从代码文件创建 <公开 静态 类型 = Py对象类 注释 = "创建指定名称的模块,然后在其中载入所提供的为UTF8编码的Python源代码文件,并将其登记到\"sys.modules\"系统登记表中以让外部模块可以引用其中的内容."
            注释 = "" 返回值注释 = "成功返回所创建的Python模块对象(\"为对象_模块\"返回真),失败返回空对象并有可能设置对应异常." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲创建模块名称 <类型 = 文本型 注释 = "提供欲创建模块的名称,该名称用作引用模块中存在的名称,不能为空文本.">
    参数 欲载入的代码文件名 <类型 = 文本型 注释 = "  提供欲载入到模块中的为UTF8编码的Python源代码文件名,如果为空文本,表示仅创建模块."
            注释 = "  注意: 如果该代码文本中导入(import)了其它模块,需要确保此模块文件的所处目录位于Python系统的模块搜寻目录中(在调用\"初始化\"或\"添加模块搜寻目录\""
            注释 = "方法时提供),否则代码载入或运行时会报告模块导入失败错误.">
    参数 对应源文件名 <类型 = 文本型 注释 = "如果本参数值不为空文本,则会将其设为所返回模块对象的\"__file__\"属性值." @默认值 = "">
    {
        如果 (文本是否为空 (欲载入的代码文件名))  // 没有提供源代码?
        {
            返回 (模块_创建 (欲创建模块名称, 真, 对应源文件名))
        }
        否则
        {
            返回 (Py对象类.编译代码文件 (欲载入的代码文件名).代码_创建模块 (欲创建模块名称, 对应源文件名))
        }
    }

    方法 模块_重载 <公开 静态 类型 = Py对象类 注释 = "  在本对象为模块实例对象(\"为对象_模块\"方法返回真)时,重载该模块,返回一个指向被重载模块的新模块对"
            注释 = "象(\"为对象_模块\"方法返回真),失败时返回空对象并可能设置一个异常(在此情况下原模块仍然会存在)." 注释 = "本方法操作步骤:" 注释 = "  1. 从 sys.modules 中找到该模块的名称;"
            注释 = "  2. 重新执行该模块的源代码(如同首次导入);" 注释 = "  3. 用新模块对象覆盖 sys.modules [name];" 注释 = "  4. 返回新模块对象;"
            注释 = "原模块对象如果还有其他引用,会继续存在,但不再被Python系统使用." 注释 = "典型使用场景:" 注释 = "  1. 开发调试时热重载配置或逻辑模块;" 注释 = "  2. 插件系统中动态更新模块;"
            注释 = "  3. 测试中重置模块状态." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsModuleObject () ? PyImport_ReloadModule (@<欲操作本对象>.Get ()) : NULL);
    }

    方法 模块_登记 <公开 静态 类型 = 逻辑型 注释 = "  如果本模块对象不位于\"sys.modules\"系统登记表中,则将其登记进去,这样在其它模块中就可" 注释 = "以直接使用模块名称引用本模块中的内容."
            返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"模块对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲登记名称 <类型 = 文本型 注释 = "提供登记到\"sys.modules\"中的模块名称,如果为空文本,则使用模块对象自身创建时提供的名称." @默认值 = "">
    {
        @ @<欲操作本对象>.RegisterModule (@<欲登记名称>.GetText ())
    }

    方法 模块_是否已登记 <公开 静态 类型 = 逻辑型 注释 = "返回本模块对象是否已经登记到\"sys.modules\"系统登记表中" 返回值注释 = "已经登记返回真,未登记或失败返回假."
            @文档 = "category = \"模块对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)且设置有有效的名称(\"__name__\"属性)">
    {
        @ @<欲操作本对象>.IsModuleRegistered ()
    }

    方法 模块_内容为空 <公开 静态 类型 = 逻辑型 注释 = "返回本模块对象的内容是否为空(譬如为空包或命名空间包)" @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsModuleObject () ? CVolPython::sIsModuleEmpty (@<欲操作本对象>.Get ()) : FALSE);
    }

    方法 模块_取命名空间 <公开 静态 类型 = Py对象类 注释 = "返回本模块对象所处命名空间的字典对象,此对象与本模块对象的 \"__dict__\" 属性相同."
            返回值注释 = "成功返回对应的字典对象(\"为对象_字典\"方法返回真),失败返回空对象并设置相应异常." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyModule_GetDict (@<欲操作本对象>.Get ()));
    }

    方法 模块_取名称 <公开 静态 类型 = 文本型 注释 = "返回本模块对象的名称,该名称在本模块对象的 \"__name__\" 属性中设置." 返回值注释 = "成功返回模块名称,失败或本模块未提供则返回空文本并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? CVolString () : CVolString (PyModule_GetName (@<欲操作本对象>.Get ())));
    }

    方法 模块_取文件名 <公开 静态 类型 = 文本型 注释 = "返回本模块对象所对应的文件名,该文件名在本模块对象的 \"__file__\" 属性中设置."
            返回值注释 = "成功返回模块文件名,失败或本模块未提供则返回空文本并设置相应异常." @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    {
        @ CVolString strFileName;
        @ if (@<欲操作本对象>.IsEmpty () == FALSE)
        @     CVolPyObject::sToStr (PyModule_GetFilenameObject (@<欲操作本对象>.Get ()), TRUE, &strFileName);
        @ return strFileName;
    }

    方法 模块_加入属性 <公开 静态 类型 = 逻辑型 注释 = "将一个指定名称的 Python 对象作为属性添加到本模块中,可以在模块内容的初始化过程中使用." 返回值注释 = "成功返回真,失败返回假并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲加入属性名称 <类型 = 文本型 注释 = "提供欲加入属性的名称,不能为空文本.">
    参数 欲加入属性值 <类型 = Py对象类 注释 = "提供欲加入的属性值对象. 不能为空对象,否则将失败并设置异常.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲加入属性名称>.IsEmpty ()) ? FALSE : (PyModule_AddObjectRef (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<欲加入属性名称>), @<欲加入属性值>.Get ()) >= 0));
    }

    方法 模块_加入整数常量 <公开 静态 类型 = 逻辑型 注释 = "将一个指定名称的整数常量值添加到本模块中,可以在模块内容的初始化过程中使用." 返回值注释 = "成功返回真,失败返回假并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲加入常量名称 <类型 = 文本型 注释 = "提供欲加入常量的名称,不能为空文本.">
    参数 整数常量值 <类型 = 整数 注释 = "提供欲加入整数常量的值">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲加入常量名称>.IsEmpty ()) ? FALSE : (PyModule_AddIntConstant (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<欲加入常量名称>), (long)@<整数常量值>) >= 0));
    }

    方法 模块_加入文本常量 <公开 静态 类型 = 逻辑型 注释 = "将一个指定名称的文本常量值添加到本模块中,可以在模块内容的初始化过程中使用." 返回值注释 = "成功返回真,失败返回假并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲加入常量名称 <类型 = 文本型 注释 = "提供欲加入常量的名称,不能为空文本.">
    参数 文本常量值 <类型 = 文本型 注释 = "提供欲加入文本常量的值">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲加入常量名称>.IsEmpty ()) ? FALSE : (PyModule_AddStringConstant (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<欲加入常量名称>), _VolStr2Utf8 (@<文本常量值>)) >= 0));
    }

    方法 模块_加入类型 <公开 静态 类型 = 逻辑型 注释 = "将一个 Python 类型对象添加到本模块中,可以在模块内容的初始化过程中使用." 返回值注释 = "成功返回真,失败返回假并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲加入类型对象 <类型 = Py对象类 注释 = "提供欲加入的 Python 类型对象(\"为对象_类型\"方法返回真),不能为空对象.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲加入类型对象>.IsTypeObject (TRUE) == FALSE) ? FALSE : (PyModule_AddType (@<欲操作本对象>.Get (), (PyTypeObject*)@<欲加入类型对象>.Get ()) >= 0));
    }

    方法 模块_置文档 <公开 静态 类型 = 逻辑型 注释 = "设置本模块对象对应的文档字符串,可以在模块内容的初始化过程中使用." 返回值注释 = "成功返回真,失败返回假并设置相应异常."
            @文档 = "category = \"模块对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python模块对象(\"为对象_模块\"方法返回真)">
    参数 欲设置文档字符串 <类型 = 文本型 注释 = "提供欲设置的文档字符串内容">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyModule_SetDocString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<欲设置文档字符串>)) >= 0));
    }

    方法 为对象_范围 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否为 Python 范围(range)对象实例" @文档 = "category = \"范围对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () == FALSE && PyRange_Check (@<欲操作本对象>.Get ()));
    }

    方法 为对象_切片 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否为 Python 切片(slice)对象实例" @文档 = "category = \"切片对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () == FALSE && PySlice_Check (@<欲操作本对象>.Get ()));
    }

    方法 切片_创建 <公开 静态 类型 = Py对象类 注释 = "  创建并返回一个具有给定属性值的新 Python 切片(slice)对象."
            注释 = "  \"起始值\"、\"结束值\"、\"步长值\"参数会被用作该切片对象的\"start\"、\"stop\"、\"step\"属性值,"
            注释 = "这些参数值中的任何一个都可以为空对象,在此情况下本方法将使用 Python 空值对象(None)作为相应的属性值."
            注释 = "  所创建切片对象可以直接在\"取成员\"、\"置成员\"方法的\"成员索引值\"参数处使用,用作获取/设置/删除一批成员." 返回值注释 = "返回所创建的切片对象,当无法分配新对象时将返回空对象并设置一个异常."
            @文档 = "category = \"切片对象\"" @禁止流程检查 = 真>
    参数 起始值 <类型 = Py对象类 注释 = "提示: 由于本类对象提供了对应\"整数\"的类型转换方法,因此可以直接为本参数提供整数值. 下同." @默认值 = 空对象>
    参数 结束值 <类型 = Py对象类 @默认值 = 空对象>
    参数 步长值 <类型 = Py对象类 @默认值 = 空对象>
    {
        @ return CVolPyObject (PySlice_New (@<起始值>.Get (), @<结束值>.Get (), @<步长值>.Get ()));
    }

    方法 切片_取属性 <公开 静态 类型 = 逻辑型 注释 = "获取本切片对象中的\"start\"、\"stop\"、\"step\"属性值" 返回值注释 = "成功返回真,失败返回假并设置对应异常."
            @文档 = "category = \"切片对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python切片对象(\"为对象_切片\"方法返回真)">
    参数 起始值 <类型 = 整数 注释 = "本切片对象的\"start\"属性值将填入到本参数所指定变量中" @需求类型 = 可写入变量>
    参数 结束值 <类型 = 整数 注释 = "本切片对象的\"stop\"属性值将填入到本参数所指定变量中" @需求类型 = 可写入变量>
    参数 步长值 <类型 = 整数 注释 = "本切片对象的\"step\"属性值将填入到本参数所指定变量中" @需求类型 = 可写入变量>
    {
        @ @<欲操作本对象>.SliceUnpack (&@<起始值>, &@<结束值>, &@<步长值>)
    }

    方法 切片_规整 <公开 静态 类型 = 整数 注释 = "基于所指定长度值和计划步长值对\"起始值\"和\"结束值\"参数变量中的值进行自动规整,确保其位于所限定的有效范围 [0, 长度值] 内."
            注释 = "本方法支持规整从尾部开始计算的负数索引值,会将其规整为对应的正数值." 返回值注释 = "方法一定会执行成功,返回通过使用调整后的起始值(start)、结束值(stop)、计划步长值(step)最终能访问到的成员数量."
            返回值注释 = "后续程序可以直接使用本方法的返回值、调整后的起始值和结束值、所提供的计划步长值,安全地访问成员数目为\"长度值\"的序列对象内容." @文档 = "category = \"切片对象\"" @禁止流程检查 = 真>
    参数 起始值 <类型 = 整数 注释 = "提供需要规整的起始值,规整后结果值也将填回此参数变量中." @需求类型 = 可写入变量>
    参数 结束值 <类型 = 整数 注释 = "提供需要规整的停止值,规整后结果值也将填回此参数变量中." @需求类型 = 可写入变量>
    参数 长度值 <类型 = 整数>
    参数 计划步长值 <类型 = 整数>
    {
        @ Py_ssize_t ssStart = @<起始值>, ssEnd = @<结束值>;
        @ const INT nResult = (INT)PySlice_AdjustIndices ((Py_ssize_t)@<长度值>, &ssStart, &ssEnd, (Py_ssize_t)@<计划步长值>);
        @ @<起始值> = (INT)ssStart;
        @ @<结束值> = (INT)ssEnd;
        @ return nResult;
    }

    方法 取时间 <公开 静态 类型 = 小数 注释 = "返回指定Python日期/时间/日期时间对象所对应的火山时间值(由\"时间操作类\"管理)" 注释 = ""
            返回值注释 = "  成功返回所对应时间值,指定时间对象无效或失败返回\"数值范围.最小日期时间值\"常量值(100年1月1日)," 返回值注释 = "可以使用\"为最小时间\"方法进行判断."
            @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 欲转换的时间 <类型 = Py对象类 注释 = "提供所欲转换的Python日期/时间/日期时间对象,即\"为对象_日期\"/\"为对象_时间\"/\"为对象_日期时间\"方法之一必须返回真."
            注释 = "如果没有日期部分(为Python时间对象),日期被固定设置为2000年1月1日." 注释 = "如果没有时间部分(为Python日期对象),时间被固定设置为0时0分0秒.">
    {
        @ @<欲转换的时间>.PyDateToVol ()
    }

    方法 为对象_日期 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python日期(\"datetime.date\")类型的对象实例" @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsDateObject (@<是否检查子类>)
    }

    方法 日期_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个为指定年、月、日的Python日期对象(\"为对象_日期\"方法返回真)" @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数>
    参数 日 <类型 = 整数>
    {
        @ CVolPyObject (volPyDate_FromDate (@<年>, @<月>, @<日>))
    }

    方法 日期 <公开 静态 类型 = Py对象类 注释 = "基于指定火山时间值创建并返回一个Python日期对象(\"为对象_日期\"方法返回真)" 返回值注释 = "成功返回所创建对象,失败返回空对象."
            @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 欲转换的时间 <类型 = 小数 注释 = "提供所欲转换的火山时间值(由\"时间操作类\"管理)">
    {
        @ CVolPyObject::sVolDateToPy (@<欲转换的时间>, 0)
    }

    方法 日期_取年 <公开 静态 类型 = 整数 注释 = "从本日期或日期时间对象中取出并返回\"年份\"属性值" @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期对象(\"为对象_日期\"方法返回真)或Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return ((@<欲操作本对象>.IsDateObject (TRUE) == FALSE && @<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE) ? 0 : (INT)PyDateTime_GET_YEAR (@<欲操作本对象>.Get ()));
    }

    方法 日期_取月 <公开 静态 类型 = 整数 注释 = "从本日期或日期时间对象中取出并返回\"月份\"属性值,从0到12." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期对象(\"为对象_日期\"方法返回真)或Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return ((@<欲操作本对象>.IsDateObject (TRUE) == FALSE && @<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE) ? 0 : (INT)PyDateTime_GET_MONTH (@<欲操作本对象>.Get ()));
    }

    方法 日期_取日 <公开 静态 类型 = 整数 注释 = "从本日期或日期时间对象中取出并返回\"日\"属性值,从0到31." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期对象(\"为对象_日期\"方法返回真)或Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return ((@<欲操作本对象>.IsDateObject (TRUE) == FALSE && @<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE) ? 0 : (INT)PyDateTime_GET_DAY (@<欲操作本对象>.Get ()));
    }

    方法 为对象_日期时间 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python日期时间(\"datetime.datetime\")类型的对象实例."
            注释 = "注意: 本对象中的年月日字段可以使用\"日期_取年\"、\"日期_取月\"、\"日期_取日\"方法获取." @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsDateTimeObject (@<是否检查子类>)
    }

    方法 日期时间_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个为指定年、月、日、时、分、秒、微秒的Python日期时间对象(\"为对象_日期时间\"方法返回真)" @文档 = "category = \"日期时间\""
            @嵌入式方法 = "">
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数>
    参数 日 <类型 = 整数>
    参数 时 <类型 = 整数 @默认值 = 0>
    参数 分 <类型 = 整数 @默认值 = 0>
    参数 秒 <类型 = 整数 @默认值 = 0>
    参数 微秒 <类型 = 整数 @默认值 = 0>
    {
        @ CVolPyObject (volPyDateTime_FromDateAndTime (@<年>, @<月>, @<日>, @<时>, @<分>, @<秒>, @<微秒>))
    }

    方法 日期时间_创建2 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个为指定年、月、日、时、分、秒、微秒、夏令时的Python日期时间对象(\"为对象_日期时间\"方法返回真)"
            @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 年 <类型 = 整数>
    参数 月 <类型 = 整数>
    参数 日 <类型 = 整数>
    参数 时 <类型 = 整数 @默认值 = 0>
    参数 分 <类型 = 整数 @默认值 = 0>
    参数 秒 <类型 = 整数 @默认值 = 0>
    参数 微秒 <类型 = 整数 @默认值 = 0>
    参数 夏令时 <类型 = 整数 注释 = "0: 表示该时间属于第一次出现(夏令时期间,通常偏移量更大/更\"早\"的 UTC 时间);" 注释 = "1: 表示该时间属于第二次出现(标准时期间,通常偏移量更小/更\"晚\"的 UTC 时间)."
            @默认值 = 0>
    {
        @ CVolPyObject (volPyDateTime_FromDateAndTimeAndFold (@<年>, @<月>, @<日>, @<时>, @<分>, @<秒>, @<微秒>, @<夏令时>))
    }

    方法 日期时间 <公开 静态 类型 = Py对象类 注释 = "基于指定火山时间值创建并返回一个Python日期时间对象(\"为对象_日期时间\"方法返回真)" 返回值注释 = "成功返回所创建对象,失败返回空对象."
            @文档 = "category = \"日期时间\"" @嵌入式方法 = "">
    参数 欲转换的时间 <类型 = 小数 注释 = "提供所欲转换的火山时间值(由\"时间操作类\"管理)">
    {
        @ CVolPyObject::sVolDateToPy (@<欲转换的时间>, 2)
    }

    方法 日期时间_取时 <公开 静态 类型 = 整数 注释 = "从本日期时间对象中取出并返回\"小时\"属性值,从0到23." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
