    }

    方法 时区_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个新的时区对象(\"datetime.timezone\")."
            注释 = "时区类型(\"datetime.timezone\")为时区信息类型(\"datetime.tzinfo\")的子类,因此所返回对象的\"为对象_时区信息\"必定返回真."
            返回值注释 = "成功返回所创建时区对象,失败返回空对象并设置对应异常." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 时间偏移 <类型 = Py对象类 注释 = "本参数必须为一个时长对象(\"为对象_时长\"方法返回真),用作提供相对于 UTC 的固定偏移量,例如 8 小时时长: \"时长_创建 (0, 8 * 60 * 60, 0)\" 表示东八区.">
    参数 时区名称 <类型 = 文本型 注释 = "提供时区名称,为空文本表示无." @默认值 = "">
    {
        @ return CVolPyObject (@<时间偏移>.IsEmpty () ? NULL : (@<时区名称>.IsEmpty () ? volPyTimeZone_FromOffset (@<时间偏移>.Get ()) : volPyTimeZone_FromOffsetAndName (@<时间偏移>.Get (), CVolPyObject::sCreateFromVolStr (@<时区名称>).Get ())));
    }
