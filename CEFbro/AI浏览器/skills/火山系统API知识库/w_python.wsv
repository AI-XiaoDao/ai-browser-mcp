        @ const INT nResult = (@<欲操作本对象>.IsEmpty () ? -1 : PyIter_NextItem (@<欲操作本对象>.Get (), &pobjItem));
        @ @<所获取项>.Set_NewRef (pobjItem);
        @ return nResult;
    }

