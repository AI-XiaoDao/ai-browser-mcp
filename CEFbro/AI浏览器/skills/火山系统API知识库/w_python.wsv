            注释 = "Python列表对象支持创建后进行动态修改(增删改),列表中可以包括不同类型的Python对象." @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsListObject (@<是否检查子类>)
    }

    方法 列表_创建 <公开 静态 类型 = Py对象类 注释 = "成功返回一个为指定尺寸的新列表(list)对象,失败返回空对象并设置对应异常." 注释 = "所创建列表对象的所有成员均以空值对象(None)填充."
            @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 初始成员数目 <类型 = 整数 注释 = "指定所创建元组对象中初始具有的成员数目" @默认值 = 0>
    {
        @ CVolPyObject::sNewList (@<初始成员数目>)
    }

    方法 列表 <公开 静态 类型 = Py对象类 注释 = "成功返回一个具有指定初始内容的新列表(list)对象,失败返回空对象并设置对应异常." @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 欲添加对象 <类型 = Py对象类 注释 = "顺序提供所有欲添加到列表中的对象数据,空对象将被转换为空值对象(None)." @可扩展 = "d_text=\".Get (), \"">
    {
        @ CVolPyObject::sNewListWithItems (@sn<pm_count>, @<欲添加对象>.Get ())
    }

    方法 列表_取尺寸 <公开 静态 类型 = 整数 注释 = "返回本列表对象中成员的数目" @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT)PyList_Size (@<欲操作本对象>.Get ()));
    }

    方法 列表_取成员 <公开 静态 类型 = Py对象类 注释 = "返回本列表对象中指定索引位置处的成员对象"
            返回值注释 = "返回列表中位于指定索引位置处的对象,如果索引位置为负值或超出范围,则返回空对象并设置一个\"Py异常类型.无效索引\"异常." @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "指定欲获取成员所处的索引位置,必须大于等于0且小于本列表的已有成员数目.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyList_GetItemRef (@<欲操作本对象>.Get (), (Py_ssize_t)@<索引位置>));
    }

    方法 列表_置成员 <公开 静态 类型 = 逻辑型 注释 = "将所指定对象赋值给本列表对象指定索引位置处的成员. 成功返回真,失败设置异常并返回假. 相当于 Python 语句 \"欲操作本对象 [索引位置] = 欲置入对象\"."
            @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "提供欲设置成员的索引位置">
    参数 欲置入对象 <类型 = Py对象类 注释 = "提供欲置入到指定位置处的对象数据">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲置入对象>.IsEmpty ()) ? FALSE : (PyList_SetItem (@<欲操作本对象>.Get (), @<索引位置>, Py_NewRef (@<欲置入对象>.Get ())) >= 0));
    }

    方法 列表_插入 <公开 静态 类型 = 逻辑型 注释 = "将指定所有对象插入到本列表对象指定索引位置处. 成功返回真,失败设置异常并返回假. 相当于 Python 语句 \"欲操作本对象.insert (索引位置, 欲插入对象)\"."
            @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "提供欲插入到的索引位置">
    参数 欲插入对象 <类型 = Py对象类 注释 = "提供欲插入到指定位置处的所有对象数据,空对象将被转换为空值对象(None)." @可扩展 = "d_text=\".Get (), \"">
    {
        @ @<欲操作本对象>.ListInsertItem (@<索引位置>, @sn<pm_count> - 2, @<欲插入对象>.Get ())
    }

    方法 列表_添加 <公开 静态 类型 = 逻辑型 注释 = "将指定所有对象添加到本列表对象的尾部. 成功返回真,失败设置异常并返回假. 相当于 Python 语句 \"欲操作本对象.append (欲添加对象)\"."
            @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 欲添加对象 <类型 = Py对象类 注释 = "提供所有欲添加到尾部的对象数据,空对象将被转换为空值对象(None)." @可扩展 = "d_text=\".Get (), \"">
    {
        @ @<欲操作本对象>.ListAddItem (FALSE, @sn<pm_count> - 1, @<欲添加对象>.Get ())
    }

    方法 列表_添加内容 <公开 静态 类型 = 逻辑型 注释 = "将指定所有可枚举对象中的全部成员添加到本列表对象的尾部. 成功返回真,失败设置异常并返回假. 相当于 Python 语句 \"欲操作本对象.extend (欲添加内容)\"."
            @文档 = "category = \"列表对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 欲添加其内容的对象 <类型 = Py对象类 注释 = "提供所有欲添加到尾部的对象数据. 所提供对象必须可以被枚举(\"取枚举器\"方法返回非空对象),其中的所有成员将被添加到本列表尾部."
            @可扩展 = "d_text=\".Get (), \"">
    {
        @ @<欲操作本对象>.ListAddItem (TRUE, @sn<pm_count> - 1, @<欲添加其内容的对象>.Get ())
    }

    方法 列表_取片段 <公开 静态 类型 = Py对象类 注释 = "成功返回本列表对象中指定范围内的所有成员,失败返回空对象. 等价于 Python 表达式 \"欲操作本对象 [起始索引位置 : 结束索引位置]\"."
            @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 起始索引位置 <类型 = 整数 注释 = "提供欲获取片段的起始成员索引位置">
    参数 结束索引位置 <类型 = 整数 注释 = "提供欲获取片段的结束成员索引位置,注意该位置处的成员本身并不包含在所返回的片段内.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyList_GetSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>));
    }

    方法 列表_置片段 <公开 静态 类型 = 逻辑型 注释 = "用一个列表对象内容替换本列表对象指定范围内的所有成员. 相当于 Python 语句 \"欲操作本对象 [起始索引位置 : 结束索引位置] = 欲置入列表对象\"."
            返回值注释 = "成功返回真,失败返回假并设置对应异常." @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    参数 起始索引位置 <类型 = 整数 注释 = "提供欲设置范围的起始成员索引位置">
    参数 结束索引位置 <类型 = 整数 注释 = "提供欲设置范围的结束成员索引位置,注意该位置处的成员本身并不包含在内.">
    参数 欲置入列表对象 <类型 = Py对象类 注释 = "提供用来设置的对象,其类型必须是Python列表(list)对象(\"为对象_列表\"方法返回真)."
            注释 = "如果为空对象,则删除本列表对象中指定范围内的所有成员,相当于 Python 语句 \"del 欲操作本对象 [起始索引位置 : 结束索引位置]\".">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyList_SetSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>, @<欲置入列表对象>.Get ()) >= 0));
    }

    方法 列表_清空 <公开 静态 类型 = 逻辑型 注释 = "从本列表对象中移除所有成员. 相当于 Python 语句 \"欲操作本对象.clear ()\" 或 \"del 欲操作本对象[:]\"."
            返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyList_Clear (@<欲操作本对象>.Get ()) >= 0));
    }

    方法 列表_排序 <公开 静态 类型 = 逻辑型 注释 = "对本列表对象中的所有成员进行排序. 相当于 Python 语句 \"欲操作本对象.sort ()\"." 返回值注释 = "成功返回真,失败返回假."
            @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyList_Sort (@<欲操作本对象>.Get ()) >= 0));
    }

    方法 列表_反转 <公开 静态 类型 = 逻辑型 注释 = "反转本列表对象中所有成员的排列顺序. 相当于 Python 语句 \"欲操作本对象.reverse ()\"." 返回值注释 = "成功返回真,失败返回假."
            @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyList_Reverse (@<欲操作本对象>.Get ()) >= 0));
    }

    方法 列表_取元组 <公开 静态 类型 = Py对象类 注释 = "返回一个新的元组对象,其中包含本列表对象中的所有成员,相当于 Python 语句 \"tuple (欲操作本对象)\"."
            返回值注释 = "成功返回所创建的元组对象(\"为对象_元组\"方法返回真),失败返回空对象." @文档 = "category = \"列表对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python列表(list)对象(\"为对象_列表\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyList_AsTuple (@<欲操作本对象>.Get ()));
    }

    方法 为接口_映射 <公开 静态 类型 = 逻辑型 注释 = "如果本对象实现了Python映射(Map)接口协议或者支持\"下标访问子成员\"(如:\"欲操作本对象 [索引]\"),返回真,否则返回假."
            注释 = "映射接口协议是指对象支持类似字典的操作,譬如字典类型的对象就必定支持此协议." @文档 = "category = \"映射接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsObjectImplMap ()
    }

    方法 映射_取尺寸 <公开 静态 类型 = 整数 注释 = "成功时返回本对象中成员的数目,失败时返回 -1 . 相当于Python的 \"len(欲操作本对象)\" 表达式." @文档 = "category = \"映射接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : (INT)PyMapping_Length (@<欲操作本对象>.Get ()));
    }

    方法 映射_取键值 <公开 静态 类型 = Py对象类 注释 = "返回本对象中对应指定关键字的值,如果未找到或失败则返回空对象." 注释 = "与\"取成员\"方法不同的是,如果未找到指定关键字不会设置异常."
            @文档 = "category = \"映射接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    参数 关键字 <类型 = Py对象类 注释 = "提供欲获取其值的关键字">
    {
        @ @<欲操作本对象>.ObjGetMapOptionalItem (@<关键字>.Get ())
    }

    方法 映射_取文本键值 <公开 静态 类型 = Py对象类 注释 = "返回本对象中对应指定文本型关键字的值,如果未找到或失败则返回空对象." 注释 = "与\"取成员\"方法不同的是,如果未找到指定关键字不会设置异常."
            @文档 = "category = \"映射接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    参数 文本关键字 <类型 = 文本型 注释 = "提供欲获取其值的文本型关键字">
    {
        @ @<欲操作本对象>.StrGetMapOptionalItem (@<文本关键字>.GetText ())
    }

    方法 映射_置文本键值 <公开 静态 类型 = 逻辑型 注释 = "在本对象中插入/更新/删除指定的关键字,返回是否成功." 注释 = "如果指定关键字不存在于本字典对象中,则插入新的关键字; 如果指定关键字已存在,则用新的键值替换旧的值."
            注释 = "相当于 Python 语句 \"欲操作本对象 [文本关键字] = 欲设置键值\"." 注释 = "本对象不能为元组(tuple)、文本(str)、字节串(bytes)这些只读对象."
            返回值注释 = "成功返回真,失败设置异常并返回假." @文档 = "category = \"映射接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    参数 文本关键字 <类型 = 文本型 注释 = "提供欲设置其键值的文本关键字,如果文本关键字不存在,则将其创建." 注释 = "如果希望以对象键的方式设置成员键的值,请使用\"置成员\"方法.">
    参数 欲设置键值 <类型 = Py对象类 注释 = "提供欲具体设置的键值,如果为空对象,则删除该文本关键字,相当于 Python 语句 \"del 欲操作本对象 [文本关键字]\".">
    {
        @ if (@<欲操作本对象>.IsEmpty () || @<文本关键字>.IsEmpty ())  return FALSE;
        @ if (@<欲设置键值>.IsEmpty ())  return (PyMapping_DelItemString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<文本关键字>)) >= 0);
        @ return (PyMapping_SetItemString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<文本关键字>), @<欲设置键值>.Get ()) >= 0);
    }

    方法 映射_是否存在键 <公开 静态 类型 = 逻辑型 注释 = "返回本对象中是否存在指定的键. 相当于 Python 表达式 \"欲检测关键字 in 欲操作本对象\"." @文档 = "category = \"映射接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    参数 欲检测关键字 <类型 = Py对象类 注释 = "提供欲检查其是否存在的关键字">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲检测关键字>.IsEmpty ()) ? FALSE : (BOOL)PyMapping_HasKey (@<欲操作本对象>.Get (), @<欲检测关键字>.Get ()));
    }

    方法 映射_是否存在文本键 <公开 静态 类型 = 逻辑型 注释 = "返回本对象中是否存在指定的文本键. 相当于 Python 表达式 \"欲检测文本关键字 in 欲操作本对象\"." @文档 = "category = \"映射接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    参数 欲检测文本关键字 <类型 = 文本型 注释 = "提供欲检查其是否存在的文本关键字">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (BOOL)PyMapping_HasKeyString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<欲检测文本关键字>)));
    }

    方法 映射_取键列表 <公开 静态 类型 = Py对象类 注释 = "成功返回包含本对象中所有键的Python列表(list)对象,失败返回空对象." @文档 = "category = \"映射接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyMapping_Keys (@<欲操作本对象>.Get ()));
    }

    方法 映射_取值列表 <公开 静态 类型 = Py对象类 注释 = "成功返回包含本对象中所有键对应值的Python列表(list)对象,失败返回空对象." @文档 = "category = \"映射接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyMapping_Values (@<欲操作本对象>.Get ()));
    }

    方法 映射_取键值对列表 <公开 静态 类型 = Py对象类 注释 = "成功返回包含本对象中所有键值对的Python列表(list)对象,失败返回空对象."
            注释 = "每个键值对使用一个具有2个成员的Python元组(tuple)记录,分别记录键及其所对应的值." @文档 = "category = \"映射接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyMapping_Items (@<欲操作本对象>.Get ()));
    }

    方法 为对象_字典 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python字典(dict)类型的对象实例."
            注释 = "字典对象实现了Python映射接口协议(\"为接口_映射\"方法返回真)并且可以被枚举(\"取枚举器\"方法返回非空对象)." 注释 = "字典对象特点:"
            注释 = "1. 哈希表: 存储一系列键值对,可以进行查找/插入/删除;" 注释 = "2. 有序性: Python 3.7+ 保证保留插入顺序(这是语言规范,不仅仅是实现细节)." 注释 = "注意事项:"
            注释 = "1. 关键字限制: 字典项关键字必须是可哈希的对象;" 注释 = "2. 遍历修改: 严禁在遍历字典时直接删除或添加关键字,应先收集要删除的关键字列表,遍历结束后再删除." @文档 = "category = \"字典对象\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsDictObject (@<是否检查子类>)
    }

    方法 字典_创建 <公开 静态 类型 = Py对象类 注释 = "返回一个新建的空字典(dict)对象,失败时返回空对象." @文档 = "category = \"字典对象\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyDict_New ())
    }

    方法 字典 <公开 静态 类型 = Py对象类 注释 = "返回一个新建的字典(dict)对象并加入初始内容" 注释 = "" 返回值注释 = "成功返回所创建的对象,失败返回空对象." @文档 = "category = \"字典对象\""
            @嵌入式方法 = "">
    参数 初始加入键值对 <类型 = Py对象类 注释 = "  每两个参数提供一个欲加入到所创建字典中的键值对,键必须支持计算哈希值," 注释 = "如果为空对象则该键值对将被忽略,值如果为空对象,将被自动转换为空值对象."
            @可扩展 = "d_text=\".Get (), \"">
    {
        @ CVolPyObject::sNewDictWithItems (@sn<pm_count>, @<初始加入键值对>.Get ())
    }

    方法 字典_创建只读视图 <公开 静态 类型 = Py对象类 注释 = "  本方法接收一个映射对象,通常是字典(dict)或其他实现了映射接口协议(\"为接口_映射\"方法返回真)的对象,返回一个"
            注释 = "类型为\"Py类型.字典只读视图\"的视图对象." 注释 = "  所返回的对象是原映射对象的一个动态只读视图,具有以下特点:" 注释 = "  1. 实现了映射接口协议(\"为接口_映射\"方法返回真);"
            注释 = "  2. 只读: 你不能通过这个代理对象修改底层字典的内容(例如: 不能调用其\"字典_更新\"、\"字典_弹出\"等方法或直接赋值)," 注释 = "如果尝试修改,会出错并设置异常;"
            注释 = "  3. 动态: 如果底层的原始字典发生了变化,这些变化会反映在代理对象中. 它不是字典的快照,而是一个实时的窗口." 返回值注释 = "成功返回所创建的视图对象,失败返回空对象."
            @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的\"为接口_映射\"方法必须返回真">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyDictProxy_New (@<欲操作本对象>.Get ()));
    }

    方法 字典_清空 <公开 静态 注释 = "清空本字典对象中的所有关键字" @文档 = "category = \"字典对象\"">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字典(dict)对象(\"为对象_字典\"方法返回真)">
    {
        @ if (@<欲操作本对象>.IsEmpty () == FALSE)  PyDict_Clear (@<欲操作本对象>.Get ());
    }

    方法 字典_是否存在键 <公开 静态 类型 = 整数 注释 = "返回本字典对象中是否存在所指定关键字. 存在返回 1,不存在返回 0,出错返回 -1." 注释 = "相当于 Python 表达式 \"欲检测关键字 in 欲操作本对象\"."
            @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字典(dict)对象(\"为对象_字典\"方法返回真)">
