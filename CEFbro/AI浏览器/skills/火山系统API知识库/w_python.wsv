<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.Python <注释 = " 本类库对 Python 3.14 的 CAPI 接口进行了全面的封装">

类 Py常量 <公开 注释 = "提供Python常量对象的类型ID" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 空 <公开 值 = @Py_CONSTANT_NONE 注释 = "Python的None对象">
    常量 假值 <公开 值 = @Py_CONSTANT_FALSE 注释 = "Python的逻辑值假(False)对象">
    常量 真值 <公开 值 = @Py_CONSTANT_TRUE 注释 = "Python的逻辑值真(True)对象">
    常量 省略 <公开 值 = @Py_CONSTANT_ELLIPSIS 注释 = "Python的省略值(Ellipsis)对象">
    常量 未实现 <公开 值 = @Py_CONSTANT_NOT_IMPLEMENTED 注释 = "Python的NotImplemented对象">
    常量 零 <公开 值 = @Py_CONSTANT_ZERO 注释 = "整数值0">
    常量 一 <公开 值 = @Py_CONSTANT_ONE 注释 = "整数值1">
    常量 空文本 <公开 值 = @Py_CONSTANT_EMPTY_STR 注释 = "空文本(\'\')对象(str)">
    常量 空字节串 <公开 值 = @Py_CONSTANT_EMPTY_BYTES 注释 = "空字节串(b\'\')对象(bytes)">
    常量 空元组 <公开 值 = @Py_CONSTANT_EMPTY_TUPLE 注释 = "空元组()对象">
}

类 Py异常类型 <公开 注释 = "提供Python异常错误对象类型的索引" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 基本异常 <公开 值 = @PyErrInx_BaseException 注释 = "所有异常的基类">
    常量 基本异常组 <公开 值 = @PyErrInx_BaseExceptionGroup>
    常量 异常 <公开 值 = @PyErrInx_Exception 注释 = "所有内置的非系统退出类异常都派生自此类,所有用户自定义异常也应当派生自此类.">
    常量 算术出错 <公开 值 = @PyErrInx_ArithmeticError 注释 = "此基类用于派生针对各种算术类错误而设置的内置异常">
    常量 验证出错 <公开 值 = @PyErrInx_AssertionError 注释 = "当 assert 语句失败时将被设置">
    常量 属性出错 <公开 值 = @PyErrInx_AttributeError 注释 = "当属性引用或赋值失败时将被设置">
    常量 IO阻塞 <公开 值 = @PyErrInx_BlockingIOError 注释 = "当一个操作将在设置为非阻塞操作的对象(例如套接字)上发生阻塞时将被设置">
    常量 管道中断 <公开 值 = @PyErrInx_BrokenPipeError 注释 = "当试图写入一个管道而其另一端已关闭,或者试图写入一个套接字而其已关闭写入时将被设置.">
    常量 缓冲区出错 <公开 值 = @PyErrInx_BufferError 注释 = "当与缓冲区相关的操作无法执行时将被设置">
    常量 子进程出错 <公开 值 = @PyErrInx_ChildProcessError 注释 = "当一个子进程上的操作失败时将被设置">
    常量 连接中断 <公开 值 = @PyErrInx_ConnectionAbortedError 注释 = "当一个连接尝试被对端中止时将被设置">
    常量 连接出错 <公开 值 = @PyErrInx_ConnectionError 注释 = "与连接相关问题的基类">
    常量 连接被拒绝 <公开 值 = @PyErrInx_ConnectionRefusedError 注释 = "当一个连接尝试被对端拒绝时将被设置">
    常量 连接被重置 <公开 值 = @PyErrInx_ConnectionResetError 注释 = "当一个连接尝试被对端重置时将被设置">
    常量 到文件尾 <公开 值 = @PyErrInx_EOFError 注释 = "当 input 函数未读取任何数据即达到文件结束条件（EOF）时被设置">
    常量 文件已存在 <公开 值 = @PyErrInx_FileExistsError 注释 = "当试图创建一个已存在的文件或目录时将被设置">
    常量 文件未找到 <公开 值 = @PyErrInx_FileNotFoundError 注释 = "当所请求的文件或目录不存在时将被设置">
    常量 浮点出错 <公开 值 = @PyErrInx_FloatingPointError 注释 = "目前未被使用">
    常量 生成器退出 <公开 值 = @PyErrInx_GeneratorExit 注释 = "当一个生成器或协程被关闭时将被设置">
    常量 导入出错 <公开 值 = @PyErrInx_ImportError 注释 = "当 import 语句尝试加载模块遇到麻烦时将被设置">
    常量 缩进出错 <公开 值 = @PyErrInx_IndentationError 注释 = "与不正确的缩进相关的语法错误的基类">
    常量 无效索引 <公开 值 = @PyErrInx_IndexError 注释 = "当序列抽取超出范围时将被设置">
    常量 信号中断 <公开 值 = @PyErrInx_InterruptedError 注释 = "当一个系统调用被传入的信号中断时将被设置">
    常量 文件方式操作目录 <公开 值 = @PyErrInx_IsADirectoryError 注释 = "当请求对一个目录执行文件操作 (如 os.remove()) 时将被设置">
    常量 关键字不存在 <公开 值 = @PyErrInx_KeyError 注释 = "当在现有关键字集合中找不到指定的映射（字典）键时将被设置">
    常量 键盘中断 <公开 值 = @PyErrInx_KeyboardInterrupt 注释 = "当用户按下中断键 (通常为 Control-C 或 Delete) 时将被设置">
    常量 查找出错 <公开 值 = @PyErrInx_LookupError 注释 = "此基类用于派生当映射或序列所使用的关键字或索引无效时设置的异常">
    常量 内存出错 <公开 值 = @PyErrInx_MemoryError 注释 = "当一个操作耗尽内存但情况仍可（通过删除一些对象）进行挽救时将被设置">
    常量 模块未找到 <公开 值 = @PyErrInx_ModuleNotFoundError 注释 = "当一个模块无法被定位时将由 import 设置">
    常量 名称未找到 <公开 值 = @PyErrInx_NameError 注释 = "当某个局部或全局名称未找到时将被设置">
    常量 非目录方式操作目录 <公开 值 = @PyErrInx_NotADirectoryError 注释 = "当请求对一个非目录执行目录操作 (如 os.listdir()) 时将被设置">
    常量 未实现 <公开 值 = @PyErrInx_NotImplementedError 注释 = "所开发功能的具体实现尚待添加时设置此异常">
    常量 操作系统出错 <公开 值 = @PyErrInx_OSError
            注释 = "此异常在一个系统函数返回系统相关的错误时将被设置,此类错误包括 I/O 操作失败例如 \"文件未找到\" 或 \"磁盘已满\" 等(不包括非法参数类型或其他偶然性错误).">
    常量 数值溢出 <公开 值 = @PyErrInx_OverflowError 注释 = "当算术运算的结果大到无法表示时将被设置(这对整数来说不可能发生)">
    常量 权限不够 <公开 值 = @PyErrInx_PermissionError 注释 = "当在没有足够访问权限的情况下试图运行某个操作时将被设置,例如文件系统权限.">
    常量 进程不存在 <公开 值 = @PyErrInx_ProcessLookupError 注释 = "当给定的进程不存在时将被设置">
    常量 终止出错 <公开 值 = @PyErrInx_PythonFinalizationError 注释 = "在解释器关闭或 Python 终止期间当有操作被阻止时被设置">
    常量 递归溢出 <公开 值 = @PyErrInx_RecursionError 注释 = "在解释器检测发现超过最大递归深度时被设置">
    常量 弱引用出错 <公开 值 = @PyErrInx_ReferenceError 注释 = "将在使用 weakref.proxy() 函数所创建的弱引用来访问该引用的某个已被作为垃圾回收的属性时被设置">
    常量 运行时出错 <公开 值 = @PyErrInx_RuntimeError 注释 = "当检测到一个不归属于任何其他类别的错误时将被设置">
    常量 异步枚举停止 <公开 值 = @PyErrInx_StopAsyncIteration 注释 = "必须由一个 asynchronous iterator 对象的 __anext__() 方法来设置以停止枚举操作">
    常量 枚举停止 <公开 值 = @PyErrInx_StopIteration 注释 = "由内置函数 next() 和 iterator 的 __next__() 方法所设置,用来表示该枚举器不能产生下一项.">
    常量 语法错误 <公开 值 = @PyErrInx_SyntaxError 注释 = "当解析器遇到语法错误时设置">
    常量 系统出错 <公开 值 = @PyErrInx_SystemError 注释 = "当解释器发现内部错误,但情况看起来尚未严重到要放弃所有希望时将被设置.">
    常量 系统退出 <公开 值 = @PyErrInx_SystemExit 注释 = "此异常由 sys.exit() 函数设置">
    常量 制表符不一致 <公开 值 = @PyErrInx_TabError 注释 = "当缩进包含对制表符和空格符不一致的使用时将被设置">
    常量 超时 <公开 值 = @PyErrInx_TimeoutError 注释 = "当一个系统函数在系统层级发生超时的情况下将被设置">
    常量 类型无效 <公开 值 = @PyErrInx_TypeError 注释 = "当一个操作或函数被应用于类型不适当的对象时将被设置">
    常量 未绑定的局部变量 <公开 值 = @PyErrInx_UnboundLocalError 注释 = "当在函数或方法中对某个局部变量进行引用,但该变量并未绑定任何值时将被设置.">
    常量 文本解码出错 <公开 值 = @PyErrInx_UnicodeDecodeError 注释 = "当在解码过程中发生与 Unicode 相关的错误时将被设置">
    常量 文本编码出错 <公开 值 = @PyErrInx_UnicodeEncodeError 注释 = "当在编码过程中发生与 Unicode 相关的错误时将被设置">
    常量 文本处理出错 <公开 值 = @PyErrInx_UnicodeError 注释 = "当发生与 Unicode 相关的编码或解码错误时将被设置">
    常量 文本转写出错 <公开 值 = @PyErrInx_UnicodeTranslateError 注释 = "在转写过程中发生与 Unicode 相关的错误时将被设置">
    常量 值无效 <公开 值 = @PyErrInx_ValueError 注释 = "操作或函数接收到具有正确类型但值不适合的参数,并且情况不能用更精确的异常来描述时将被设置.">
    常量 除零 <公开 值 = @PyErrInx_ZeroDivisionError 注释 = "当除法或取余运算的第二个参数为零时将被设置">
}

类 Py警告类型 <公开 注释 = "提供Python警告对象类型的索引" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 基本警告 <公开 值 = @PyErrInx_Warning 注释 = "警告类别的基类">
    常量 字节串警告 <公开 值 = @PyErrInx_BytesWarning 注释 = "与字节串和字节数组相关警告的基类">
    常量 已弃用 <公开 值 = @PyErrInx_DeprecationWarning 注释 = "如果所发出的警告是针对其他 Python 开发者的,则以此作为与已弃用特性相关警告的基类.">
    常量 编码警告 <公开 值 = @PyErrInx_EncodingWarning 注释 = "与编码格式相关的警告的基类">
    常量 未来警告 <公开 值 = @PyErrInx_FutureWarning 注释 = "如果所发出的警告是针对以 Python 所编写应用的最终用户的,则以此作为与已弃用特性相关警告的基类.">
    常量 导入警告 <公开 值 = @PyErrInx_ImportWarning 注释 = "与在模块导入中可能的错误相关的警告的基类">
    常量 即将弃用 <公开 值 = @PyErrInx_PendingDeprecationWarning 注释 = "对于已过时并预计在未来弃用,但目前尚未弃用的特性相关警告的基类.">
    常量 资源警告 <公开 值 = @PyErrInx_ResourceWarning 注释 = "资源使用相关警告的基类">
    常量 运行时警告 <公开 值 = @PyErrInx_RuntimeWarning 注释 = "与模糊的运行时行为相关的警告的基类">
    常量 语法警告 <公开 值 = @PyErrInx_SyntaxWarning 注释 = "与模糊的语法相关的警告的基类. 该警告通常会在编译 Python 源代码时发出,而在运行已编译的代码时通常不会报告.">
    常量 文本警告 <公开 值 = @PyErrInx_UnicodeWarning 注释 = "与 Unicode 相关警告的基类">
    常量 用户警告 <公开 值 = @PyErrInx_UserWarning 注释 = "用户代码所产生警告的基类">
}

类 Py比较类型 <公开 注释 = "用作指定\"Py对象类.比较\"方法欲进行的比较操作类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 小于 <公开 值 = @Py_LT 注释 = "是否小于">
    常量 小于等于 <公开 值 = @Py_LE 注释 = "是否小于等于">
    常量 等于 <公开 值 = @Py_EQ 注释 = "是否等于">
    常量 不等于 <公开 值 = @Py_NE 注释 = "是否不等于">
    常量 大于 <公开 值 = @Py_GT 注释 = "是否大于">
    常量 大于等于 <公开 值 = @Py_GE 注释 = "是否大于等于">
}

类 Py源码类型 <公开 注释 = "用作指定所提供Python源代码的类型" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 表达式 <公开 值 = @Py_eval_input 注释 = "孤立的Python表达式,譬如: \"1 + 2\", 或 lambda 表达式.">
    常量 多行语句 <公开 值 = @Py_file_input 注释 = "从文件或其他来源获取到的任意长度的多行Python语句序列(即模块级别代码).">
    常量 单行语句 <公开 值 = @Py_single_input 注释 = "单独一行的Python语句. 此类源码执行后无返回值,返回空值对象(None).">
}

类 Py运算符 <公开 注释 = "用作提供使用\"Py对象类.运算\"方法进行Python运算的类型."
        注释 = "下面描述中,如果是单值运算,其操作数为\"o\",如果是多值运算,其操作数为\"o1\"、\"o2\"、\"o3\",这些操作数由\"Py对象类.运算\"方法的各个参数提供." @常量类 = 整数
        @文档 = "category = \"辅助类\"">
{
    常量 取负值 <公开 值 = @PYNO_Negative 注释 = "返回 o 的负值,等价于 Python 表达式 \"-o\".">
    常量 取正值 <公开 值 = @PYNO_Positive 注释 = "返回 o,等价于 Python 表达式 \"+o\".">
    常量 取绝对值 <公开 值 = @PYNO_Absolute 注释 = "返回 o 的绝对值,等价于 Python 表达式 \"abs(o)\".">
    常量 按位取反 <公开 值 = @PYNO_Invert 注释 = "返回 o 的按位取反后的结果,等价于 Python 表达式 \"~o\".">
    常量 取整数 <公开 值 = @PYNO_Long 注释 = "返回 o 转换为整数对象后的结果,等价于 Python 表达式 \"int(o)\".">
    常量 取小数 <公开 值 = @PYNO_Float 注释 = "返回 o 转换为浮点小数对象后的结果,等价于 Python 表达式 \"float(o)\".">
    常量 取索引 <公开 值 = @PYNO_Index 注释 = "成功时返回 o 转换为 Python 整数(int)类型后的结果,失败时返回空对象并设置\"Py异常类型.类型无效\"异常.">
    常量 ""
    常量 加 <公开 值 = @PYNO_Add 注释 = "返回 o1 和 o2 相加的结果,等价于 Python 表达式 \"o1 + o2\"y7tr6u.">
    常量 减 <公开 值 = @PYNO_Subtract 注释 = "返回 o1 减去 o2 的结果,等价于 Python 表达式 \"o1 - o2\".">
    常量 乘 <公开 值 = @PYNO_Multiply 注释 = "返回 o1 和 o2 相乘的结果,等价于 Python 表达式 \"o1 * o2\".">
    常量 矩阵乘 <公开 值 = @PYNO_MatrixMultiply 注释 = "返回 o1 和 o2 做矩阵乘法的结果,等价于 Python 表达式 \"o1 @ o2\".">
    常量 整除 <公开 值 = @PYNO_FloorDivide 注释 = "返回 o1 除以 o2 向下取整的值,这等价于 Python 表达式 \"o1 // o2\".">
    常量 除 <公开 值 = @PYNO_TrueDivide 注释 = "返回 o1 03以 o2 的数学值的合理近似值.返回的是\"近似值\"因为二进制浮点数本身就是近似值,不可能以二进制精确表示所有实数."
            注释 = "此运算符可以在传入两个整数时返回一个浮点值. 等价于 Python 表达式 \"o1 / o2\".">
    常量 取余数 <公开 值 = @PYNO_Remainder 注释 = "返回 o1 除以 o2 得到的余数,等价于 Python 表达式 \"o1 % o2\".">
    常量 取商和余数 <公开 值 = @PYNO_Divmod
            注释 = "返回由当对 o1 和 o2 使用整数除法时的商和余数组成的数字对,参考 Python 内置函数\"divmod\",等价于 Python 表达式 \"divmod(o1, o2)\".">
    常量 左移 <公开 值 = @PYNO_Lshift 注释 = "返回 o1 左移 o2 个比特后的结果,等价于 Python 表达式 \"o1 << o2\".">
    常量 右移 <公开 值 = @PYNO_Rshift 注释 = "返回 o1 右移 o2 个比特后的结果,等价于 Python 表达式 \"o1 >> o2\".">
    常量 按位与 <公开 值 = @PYNO_And 注释 = "返回 o1 和 o2 \"按位与\" 的结果,,等价于 Python 表达式 \"o1 & o2\".">
    常量 按位异或 <公开 值 = @PYNO_Xor 注释 = "返回 o1 和 o2 \"按位异或\" 的结果,等价于 Python 表达式 \"o1 ^ o2\".">
    常量 按位或 <公开 值 = @PYNO_Or 注释 = "返回 o1 和 o2 \"按位或\" 的结果,等价于 Python 表达式 \"o1 | o2\".">
    常量 加后赋值 <公开 值 = @PYNO_InPlaceAdd 注释 = "返回 o1 和 o2 相加的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 += o2\"."
            注释 = "如: 假设本对象类型为列表(list),当与另一个列表进行\"加赋值\"运算时,本对象的内容将被修改为相加后的结果; 如果进行\"加\"运算,则仅会返回相加结果而不会修改本对象内容.">
    常量 减后赋值 <公开 值 = @PYNO_InPlaceSubtract 注释 = "返回 o1 和 o2 相减的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 -= o2\".">
    常量 乘后赋值 <公开 值 = @PYNO_InPlaceMultiply 注释 = "返回 o1 和 o2 相乘的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中.  等价于 Python 语句 \"o1 *= o2\".">
    常量 矩阵乘后赋值 <公开 值 = @PYNO_InPlaceMatrixMultiply
            注释 = "返回 o1 和 o2 做矩阵乘法后的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 @= o2\".">
    常量 整除后赋值 <公开 值 = @PYNO_InPlaceFloorDivide
            注释 = "返回 o1 除以 o2 后向下取整的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 //= o2\".">
    常量 除后赋值 <公开 值 = @PYNO_InPlaceTrueDivide 注释 = "返回 o1 除以 o2 的数学值的合理近似值. 返回的是\"近似值\"因为二进制浮点数本身就是近似值,不可能以二进制精确表示所有实数."
            注释 = "此运算符可以在传入两个整数时返回一个浮点数. 当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 /= o2\".">
    常量 取余数后赋值 <公开 值 = @PYNO_InPlaceRemainder 注释 = "返回 o1 除以 o2 得到的余数,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 %= o2\".">
    常量 左移后赋值 <公开 值 = @PYNO_InPlaceLshift 注释 = "返回 o1 左移 o2 个比特后的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 <<= o2\".">
    常量 右移后赋值 <公开 值 = @PYNO_InPlaceRshift 注释 = "返回 o1 右移 o2 个比特后的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 >>= o2\".">
    常量 位与后赋值 <公开 值 = @PYNO_InPlaceAnd 注释 = "返回 o1 和 o2 \"按位与\" 的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 &= o2\".">
    常量 位异或后赋值 <公开 值 = @PYNO_InPlaceXor 注释 = "返回 o1 和 o2 \"按位异或\" 的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 ^= o2\".">
    常量 位或后赋值 <公开 值 = @PYNO_InPlaceOr 注释 = "返回 o1 和 o2 \"按位或\" 的结果,当 o1 对象内容支持被修改时,本运算将结果储存到其中. 等价于 Python 语句 \"o1 |= o2\".">
    常量 ""
    常量 求幂 <公开 值 = @PYNO_Power
            注释 = "返回 o1 的 o2 次幂; 如果 o3 不为空对象,则返回 o1 的 o2 次幂对 o3 取余(比 \"pow(o1, o2) % o3\" 更高效). 两参数形式 \"pow(o1, o2)\" 等价于乘方运算符: \"o1 ** o2\"."
            注释 = "参阅 Python 内置函数\"pow\",等价于 Python 表达式 \"pow(o1, o2, o3)\",其中 o3 是可选的,如果要忽略o3,请传入空对象.">
    常量 求幂后赋值 <公开 值 = @PYNO_InPlacePower 注释 = "进行\"求幂\"运算,当 o1 对象支持被修改且 o3 是空对象时,本运算将结果储存到其中,等价于 Python 语句 \"o1 **= o2\".">
}

类 Py类型 <公开 注释 = "提供各种Python内置类型,用作\"Py对象类.取内置类型\"之类方法使用." @常量类 = 整数 @文档 = "category = \"辅助类\"">
