        返回 (Py对象类.类型_创建 (类型名称).调用 (位置参数数据, 关键字参数数据, 展开元组))
    }

    方法 格式创建指定类型对象 <公开 静态 类型 = Py对象类 注释 = "使用指定构造参数(由\"类型格式文本\"和\"所提供数据\"参数提供)创建并返回一个为指定名称类型的新Python对象"
            返回值注释 = "成功返回所创建的Python对象,失败返回空对象." @文档 = "category = \"基本.对象创建\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 类型名称 <类型 = 文本型 注释 = "  提供所欲使用的类型名称,可以是Python内置类型名称(如\"list\",\"tuple\"等),也可以是外部Python模块中"
            注释 = "定义的类型名称(如\"types.SimpleNamespace\"),此时本方法会自动载入对应模块.">
    参数 类型格式文本 <类型 = 文本型 注释 = "具体请参见\"格式调用\"方法的\"类型格式文本\"参数说明." 编辑时信息 = "104EB4, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "104EB4, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ CVolPyObject::sFormatCreateNewPyObject (CVolPyObject ((PyObject*)CVolPython::sGetSpecNamePythonTypeObject (@<类型名称>.GetText ())).Get (), @<类型格式文本>.GetText (), _T (@sn<pm_types>) + 2, @<所提供数据>)
    }

    方法 格式创建 <公开 静态 类型 = Py对象类 注释 = "根据所提供的格式,创建并返回对应的Python对象." 返回值注释 = "成功返回所创建的Python对象,失败返回空对象."
            返回值注释 = "失败可能有以下几种原因: 类型格式文本无效; 类型格式文本与所提供数据的数目或数据类型不匹配等." 编辑时信息 = "913A8, 0, 0, 0" @文档 = "category = \"基本.对象创建\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 类型格式文本 <类型 = 文本型 注释 = "  提供一个格式文本用作指定所创建返回的Python对象的类型. 格式文本中所有空白(\' \')、逗号(\',\')、冒号(\':\')、分号(\';\')字符"
            注释 = "仅用作分隔标志都将被忽略." 注释 = "  格式文本由一个或多个格式项构成,如果由多个格式项组成,则认为是元组型组合格式项. 如果为空文本,等同于提供了与\"所提供数据\""
            注释 = "参数数目相同的\'*\'字符(见下),如: 格式创建 (\"\", 1, 2) 等同于调用: 格式创建 (\"**\", 1, 2) ." 注释 = "格式项具有以下两种类型:"
            注释 = "1. 替换格式项(由单个字符指定),下面描述方式为 \"格式字符: 所创建的Python对象类型 <- 所需求的火山数据类型\":"
            注释 = "  \'s\': 文本(str) <- 字符(被转换为具有此单个字符的Python文本)/文本型;"
            注释 = "  \'b\': 字节串(bytes) <- 字节集类/文本型/字符/空对象. \"文本型\"或\"字符\"将使用其转换到UTF8编码后的结果,空对象将转换" 注释 = "到空字节串;"
            注释 = "  \'B\': 字节数组(bytearray) <- 字节集类/文本型/字符/空对象. \"文本型\"或\"字符\"将使用其转换到UTF8编码后的结果,空对象" 注释 = "将转换到空字节数组;"
            注释 = "  \'d\': 整数(int) <- 数值型(所有整数或小数类型)/逻辑型(真为1,假为0);" 注释 = "  \'f\': 小数(float) <- 数值型;"
            注释 = "  \'p\': 逻辑型(bool) <- 逻辑型/所有整数类型(不等于0为真,等于0为假);"
            注释 = "  \'o\': 对象(object) <- Py对象类/空对象. Python对象类的空对象实例(\"为空\"返回真)和火山空对象都将置入一个空值对象(None)."
            注释 = "  \'*\': 根据当前位置处所提供参数的实际数据类型,将其以默认方式转换创建对应的Python对象,具体为: 文本型 -> 文本("
            注释 = "str); 字节集类 -> 字节串(bytes);  整数型(所有整数类型) -> 整数(int); 小数型(所有小数类型) -> 小数(float); 逻辑"
            注释 = "型 -> 逻辑型(bool); 空对象 -> 空值对象(None); Py对象类 -> Py对象类." 注释 = "2. 标记格式项:" 注释 = "  \'n\': 空值对象(None). 标记在此位置填入一个空值对象;"
            注释 = "  \'|\': 正常情况下,调用本方法时必须为每一个替换格式项提供对应的参数数据,否则将出错返回.使用本格式项标记可以不为其后"
            注释 = "的所有替换格式项提供参数数据,此时将填入默认值: 文本:空文本; 字节集:空字节串; 整数/小数:0; 逻辑型:假; 对象:空值对" 注释 = "象(None)."
            注释 = "3. 组合格式项. 用作创建组合类型的Python对象(元组/列表/字典),\"格式项列表\"中的每个格式项指定其中的一个成员." 注释 = "  \"(\" 格式项列表 \")\": 元组(tuple);"
            注释 = "  \"[\" 格式项列表 \"]\": 列表(list);" 注释 = "  \"<\" 格式项列表 \">\": 集合(set);" 注释 = "  \"<!\" 格式项列表 \">\": 只读集合(frozenset);"
            注释 = "  \"{\" 格式项列表 \"}\": 字典(dict),所提供的每一对连续数据作为一个键值对插入字典中(分别为键和键值),注意键类型必须是可哈希的." 注释 = "例子:"
            注释 = "  1. \"s\": Python文本对象;" 注释 = "  2. \"[]\": 空Python列表对象;"
            注释 = "  3. \"s|dd\": 具有1个文本成员和2个整数成员的Python元组对象,调用本方法时可以不为后2个整数格式项提供数据,此时将填入0;"
            注释 = "  4. \"**\": 具有2个成员的Python元组对象,成员类型由所提供参数数据的实际类型决定;" 注释 = "  5. \"( sn )\": 具有1个文本成员和1个空值成员的Python元组对象;"
            注释 = "  6. \"[ d, B, b ]\": 具有1个整数成员,1个字节数组成员,1个字节串成员的Python列表对象;"
            注释 = "  7. \"[ d, (<ss>, (d), ()) ]\": 具有2个成员的Python列表对象,第1个成员为整数,第2个成员为元组,该元组具有3个子成员,第1个"
            注释 = "为具有2个文本成员的集合,第2个为具有1个整数成员的元组,第3个为一个空元组;"
            注释 = "  8. \"{ s: <!dd>, d: f }\": 具有2个元素的Python字典对象,第1个元素的键为文本,值为一个具有2个整数的只读集合,第2个元素的键" 注释 = "为整数,值为小数."
            编辑时信息 = "913A8, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "913A8, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ CVolPyObject (CVolPyObject::sFormatCreate (@<类型格式文本>.GetText (), _T (@sn<pm_types>) + 1, @<所提供数据>))
    }

    方法 解析参数 <公开 静态 类型 = 逻辑型 注释 = "根据提供的被调用Python函数参数表定义文本和调用该方法时提供的实际参数数据,解析出其中的所有参数值并将其转换到火山格式后填入到接收变量表中."
            返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"基本.读写\"" @嵌入式方法 = "">
    参数 位置参数数据 <类型 = Py对象类 注释 = "  提供调用Python函数时所有顺序传入的\"位置参数数据\",必须为支持序列接口协议(\"为接口_序列\"方法返回真)的Python对象,譬如元组/列表之类,但是不能为"
            注释 = "文本(str)/字节串(bytes)/字节数组(bytearray),用作为\"仅位置参数\"和以顺序方式传入的\"位置或关键字参数\"提供数据."
            注释 = "  如函数调用: test (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数为元组: (1, 2, 3)." 注释 = "  如果不存在顺序传入的参数数据,本参数值可以为空对象.">
    参数 关键字参数数据 <类型 = Py对象类 注释 = "  提供调用Python函数时所有以键值对方式传入的参数数据,必须是Python字典对象(\"为对象_字典\"方法返回真),用作为以键值对方式传入的\"位置或关键字参数\"和"
            注释 = "\"仅关键字参数\"提供数据. 注意: 键值对中所有关键字的数据类型必定为文本型."
            注释 = "  如函数调用: test (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数为字典: { \"arg3\": 4, \"value1\": 5, \"value2\": 6 }."
            注释 = "  如果不存在需要以键值对方式传入的参数数据,本参数值可以为空对象." @默认值 = 空对象>
    参数 参数定义表 <类型 = 文本型 注释 = "  提供被调用Python函数的参数表定义文本,格式与在Python源程序中定义方法时一致,为使用逗号分隔的参数名称列表(\"仅位置参数\"、\"可变位置参数\"、"
            注释 = "\"可变关键字参数\"的名称可以省略为\"_\"文本,否则必须提供对应Python函数中正确的参数名称),支持使用可变位置参数\"*args\"和可变关键字参数\"**kwargs\","
            注释 = "以及\'/\'和\'*\'参数分隔字符." 注释 = "  如果参数名称首部有一个额外的等号\'=\'标志字符,表明该参数具有默认值可以省略其参数数据. 具有默认值的参数本方法所进行的唯一处理就是当发现未提供对应"
            注释 = "Python参数数据时不报错,用户需要自行进行默认值处理(譬如调用本方法前先将默认值置入对应的接收变量中去). 所有\"仅位置参数\"和\"位置或关键字参数\",一旦"
            注释 = "前方参数具有\'=\'标志字符,后续参数必须也要有此标志,这是由Python语法规定的."
            注释 = "  因为此处的参数表定义文本格式与Python源程序中方法的参数表定义文本格式一致,因此实际使用时将对应Python函数的参数表去掉类型注解后拷贝过来即可,唯一"
            注释 = "不同之处为: 需要在所有具有默认值的参数名称前加上等号\'=\'标志字符."
            注释 = "  如果本参数值为空文本,则等同于定义所提供接收变量数目的\"仅位置参数\". 如: 解析参数 (位置参数数据, 关键字参数数据, \"\", 接收变量1, 接收变量2), 此时"
            注释 = "参数定义表等同于 \"_, _, /\" ." 注释 = "  相关Python概念:" 注释 = "  1. \"仅位置参数\": 在Python中调用时必须按顺序传入值,不能以键值对的方式传入. 如下面例子2的调用格式;"
            注释 = "  2. \"位置或关键字参数\": 这是最常见的参数形式,在Python中调用时可以顺序传入也可以通过键值对方式传入,如下面例子1的调用格式;"
            注释 = "  3. \"仅关键字参数\":  在Python中调用时必须以键值对方式传入,如下面例子5的调用格式;" 注释 = "  4. \"可变位置参数\": 可以接收任意数量顺序传入的参数,其后方的所有参数均为\"仅关键字参数\";"
            注释 = "  5. \"可变关键字参数\": 可以接收任意数量的以键值对方式传入的参数,如果存在必须放在参数表的最后;"
            注释 = "  6. \'/\'分隔字符: 表明其前方的所有参数为\"仅位置参数\",如果同时存在\'*\'分隔字符,\'/\'必须在前方;" 注释 = "  7. \'*\'分隔字符: 表明其后方的所有参数为\"仅关键字参数\";"
            注释 = "  8. 既不在\'/\'分隔字符前方,也不在\'*\'分隔字符后方的参数为\"位置或关键字参数\";" 注释 = "  9. 参数的顺序传入: 以顺序列出参数值的方式传入调用参数数据,如: test (1, 2, 3);"
            注释 = "  10. 参数的键值对方式传入: 以键值对的方式传入调用参数数据,其中键为参数的名称文本,值为参数对应的值,如: test (arg1 = 1, arg2 = 2)."
            注释 = "  以下为一些常见参数表格式示例,调用方法为python表达式:"
            注释 = "  1. \"arg1, arg2\": 这是最常用的参数表格式,接收两个\"位置或关键字参数\"arg1和arg2, test (1, 2)、test (1, arg2 = 2) 调用方式都是正确的;"
            注释 = "  2. \"arg1, arg2, /\": 接收两个\"仅位置参数\"arg1和arg2,只能以 test (1, 2) 而不能以 test (1, arg2 = 2) 的方式调用;"
            注释 = "  3. \"arg1, =arg2, /, =arg3\": 接收两个\"仅位置参数\"arg1和arg2和一个\"位置或关键字参数\"arg3,其中arg2和arg3参数数据可以省略. 因此"
            注释 = "test (1)、test (1, 2)、test (1, 2, 3)、test (1, 2, arg3 = 3) 这几种调用方式都是正确的;"
            注释 = "  4. \"_, =_, /, =arg3\": 同3,只是两个\"仅位置参数\"被省略了名称;"
            注释 = "  5. \"arg1, =arg2, /, =arg3, *, =arg4, arg5\": 同3,再额外接收两个\"仅关键字参数\"arg4,arg5,其中arg4参数数据可以被省略."
            注释 = "调用示例如: test (1, arg5 = 5)、test (1, 2, 3, arg5 = 5, arg4 = 4);"
            注释 = "  6. \"arg1, *arg2\": 同1,只是arg2可以接收arg1后面所有顺序传入的位置参数,如函数调用 test (1, 2, 3),此时arg1为1,arg2为元组 (2, 3);"
            注释 = "  7. \"*arg1, **arg2\": arg1可以接收任意数量的顺序传入参数,arg2可以接收任意数量的以键值对方式传入的参数,如函数调用 test ("
            注释 = "1, 2, value1 = 3, value2 = 4), 此时arg1为元组 (1, 2),arg2为字典 { \"value1\": 3, \"value2\": 4 };"
            注释 = "  8. \"arg1, *arg2, arg3, **arg4\": arg1为\"位置或关键字参数\",arg2用作接收后续任意数量的顺序传入参数,arg3为\"仅关键字参数\",arg4用作接收所有除开"
            注释 = "\"arg3\"以外的以键值对方式传入的参数. 如函数调用 test (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时arg1为1,arg2为元组 (2, 3),arg3为4,"
            注释 = "arg4为字典 { \"value1\": 5, \"value2\": 6 };" 注释 = "  9. \"arg1, *_, arg3, **_\": 同8,只是arg2和arg4的参数名由于是可变参数被省略.">
    参数 接收变量表 <注释 = "  用作从\"位置参数数据\"和\"关键字参数数据\"中接收解析出来的所有参数结果数据."
            注释 = "  本参数的数目必须与\"参数定义表\"中提供的参数(包括使用\"_\"文本省略名称的参数)数目一致且一一对应,数据类型必须与调用Python函数时提供的对应参数数据" 注释 = "类型匹配,下方为具体的类型匹配表:"
            注释 = "  Python参数数据类型 -> 可以匹配的接收变量火山数据类型:"
            注释 = "  1. 文本(str) -> 文本型/字节集类/数值型. 为文本型时Python文本会被转换到UTF16编码,为字节集类时会直接存储该文本的UTF8编码,为数值型时会取该文本" 注释 = "首字符的编码;"
            注释 = "  2. 字节串(bytes)/字节数组(bytearray) -> 字节集类/文本型/数值型. 为\"字节集类\"时会获取全部字节数据; 为\"文本型\"时将假设所提供字节串数据为UTF8编"
            注释 = "码的文本,使用其转换到UTF16编码后的结果; 为数值型时会取首字节值;" 注释 = "  3. 整数(int)/小数(float) -> 数值型(所有整数或小数类型)/逻辑型(不等于0置为真,等于0置为假);"
            注释 = "  4. 逻辑型(bool) -> 逻辑型/所有数值类型(为真置为1,为假置为0);" 注释 = "  5. 所有类型 -> Py对象类. \"Py对象类\"接收变量可以匹配所有Python数据类型;"
            注释 = "  6. 所有类型 -> 文本型. 使用所提供Python数据调用其\"str\"方法转换后的文本内容;"
            注释 = "  7. 空值对象(None) -> 以上火山数据类型均可匹配. 具体对应值为: 数值0, 逻辑值假, 空文本, 空字节集, \"Py对象类\"空值对象;"
            注释 = "  8. \"可变位置参数\" -> Py对象类. 解析后会置入一个包含所有剩余\"位置参数数据\"的元组对象(\"为对象_元组\"方法返回真);"
            注释 = "  9. \"可变关键字参数\" -> Py对象类. 解析后会置入一个包含所有剩余\"关键字参数数据\"的字典对象(\"为对象_字典\"方法返回真)." @可扩展 = "d_text=\", &\"" @需求类型 = 可写入变量
            @匹配类型 = 通用型>
    {
        @ CVolPyObject::sParseArgs (@<位置参数数据>.Get (), @<关键字参数数据>.Get (), @<参数定义表>.GetText (), _T (@sn<pm_types>) + 3, &@<接收变量表>)
    }

    方法 解析参数2 <公开 静态 类型 = 逻辑型 注释 = "同\"解析参数\"方法,只是不提供\"关键字参数数据\".具体解释请参见该方法." 返回值注释 = "成功返回真,失败返回假."
            @文档 = "category = \"基本.读写\"" @嵌入式方法 = "">
    参数 位置参数数据 <类型 = Py对象类>
    参数 参数定义表 <类型 = 文本型>
    参数 接收变量表 <@可扩展 = "d_text=\", &\"" @需求类型 = 可写入变量 @匹配类型 = 通用型>
    {
        @ CVolPyObject::sParseArgs (@<位置参数数据>.Get (), NULL, @<参数定义表>.GetText (), _T (@sn<pm_types>) + 2, &@<接收变量表>)
    }

    方法 取格式文本 <公开 静态 类型 = 文本型 注释 = "返回本对象中内容格式化后的文本." 注释 = "调用本方法等于调用Python表达式: \"format (欲操作本对象, 格式指定文本)\""
            返回值注释 = "成功返回已格式化的文本,失败时返回空文本(注意可能格式化后文本本身即为空文本)且当\"格式指定文本\"参数文本语法错误时设置\"Py异常类型.值无效\"异常." @文档 = "category = \"基本.文本\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 格式指定文本 <类型 = 文本型 注释 = "提供用作格式化本对象内容的文本,如果为空文本,则等于调用Python表达式: \"format (欲操作本对象)\"."
            注释 = "在 Python 中,格式指定文本遵循一套被称为\"格式说明迷你语言\"的语法规则."
            注释 = "一. 语法规则(方括号(\"[]\")中表示为可选选项): [[填充]对齐][符号][#][0][宽度][分组选项][.精度][类型] ." 注释 = "  注意顺序: 各部分选项的顺序是固定的,不能随意调换."
            注释 = "二. 选项说明:" 注释 = "1. 填充与对齐(\"[填充]对齐\"),控制所输出文本的对齐和填充方式:"
            注释 = "  \"填充\"(可选): 任意字符,用于填充空白处,默认为空格(\' \'). 注意: 如果指定了\"填充\"字符,则必须紧跟一个\"对齐\"字符;"
            注释 = "  \"对齐\"(可选): 指定对齐方式,为以下字符之一: \'<\':左对齐; \'>\':右对齐(数值的默认方式); \'^\':居中; \'=\':强制将符号放在最左侧,填充字符放在符号和数字之间(仅对数值类型有效)."
            注释 = "  示例: \"<10\":左对齐,宽度10; \"*>10\":右对齐,宽度10,用\'*\'填充; \"0=+10\":符号在最前,\'0\'填充,宽度10(如+0000042)."
            注释 = "  请注意,除非定义了\"最小宽度\",否则字段宽度将始终与填充它的数据大小相同,因此在这种情况下,\"对齐\"选项没有意义." 注释 = "2. 符号(\"[符号]\"),仅适用于数值类型,用作控制符号的显示:"
            注释 = "  \'+\': 正数前显示\"+\",负数前显示\"-\";" 注释 = "  \'-\': 仅负数前显示\"-\"(默认方式);" 注释 = "  空格(\' \'): 正数前显示空格，负数前显示\"-\"."
            注释 = "3. 替代形式(\"[#]\"),改变某些类型的输出格式(类似 C 语言的\'#\'标志)." 注释 = "  二进制/八进制/十六进制: 添加对应前缀\"0b\"/\"0o\"/\"0x\";"
            注释 = "  小数: 即使没有小数位也显示小数点,对于\'g\'类型,不删除末尾的零;" 注释 = "  整数: 非零值前加\"0x\"等前缀." 注释 = "4. 零填充(\"[0]\"):"
            注释 = "  \'0\': 启用\"零填充\"对齐,这等价于: 填充=\'0\' 且 对齐=\'=\'." 注释 = "  注意: 如果显式指定了\"对齐\"选项,则此选项被忽略." 注释 = "5. 最小宽度(\"[宽度]\"):"
            注释 = "  为一个十进制整数,定义输出的最小总字符数. 如果格式化后的内容短于此宽度,则根据\"对齐\"选项进行填充." 注释 = "6. 分组选项(\"[分组选项]\"),用于数字的千位分隔符显示:"
            注释 = "  \'_\' (Python 3.6+): 对于整数表示类型 \'d\' 和 \'n\' 以外的小数表示类型每 3 个数位插入一个下划线,对于整数表示类型 \'b\', \'o\', \'x\' 和 \'X\', 则每 4 个数字插入一个下划线. 对于其它表示类型,此选项不被支持;"
            注释 = "  \',\': 对于整数表示类型 \'d\' 和 \'n\' 以外的小数表示类型每 3 个数位插入一个逗号,对于其他表示类型,此选项不被支持." 注释 = "7. 精度(\"[.精度]\"):"
            注释 = "  由一个小数点字符(\'.\')后跟一个十进制整数组成,含义取决于类型:" 注释 = "  小数 (f, F, g, G): 指定小数点后的位数;" 注释 = "  文本 (s): 指定最大截断长度(即只取前 N 个字符);"
            注释 = "  不允许对整数类型指定本选项." 注释 = "8. 表示类型(\"[类型]\"):"
            注释 = "  决定数据的呈现类型,这是最重要的部分,不同对象支持的类型不同. 按以下格式说明: 类型字符: 文本输出方式, 示例 (假设当前值为 42 或 3.14 或 \"Hi\" 时的输出文本)."
            注释 = "  整数类型(在本对象值类型为整数时适用):" 注释 = "  \'b\': 二进制, \"101010\" ;" 注释 = "  \'c\': 字符, \"*\" (Unicode编码值42对应的字符) ;"
            注释 = "  \'d\': 十进制(默认类型), \"42\" ;" 注释 = "  \'o\': 八进制, \"52\" ;" 注释 = "  \'x\': 十六进制小写, \"2a\" ;"
            注释 = "  \'X\': 十六进制大写, \"2A\" ;" 注释 = "  \'n\': 数字, 同\'d\'类型,区别在于它会使用当前语言区域设置来插入适当的数字组分隔符." 注释 = "  小数类型(在本对象值类型为小数时适用):"
            注释 = "  \'e\': 科学计数法小写, \"3.140000e+00\" ;" 注释 = "  \'E\': 科学计数法大写, \"3.140000E+00\" ;"
            注释 = "  \'f\': 定点数小写(默认精度6), \"3.140000\" ;" 注释 = "  \'F\': 定点数大写(NaN/Inf 大写), \"3.140000\" ;"
            注释 = "  \'g\': 通用格式小写(自动切换使用\'e\'或\'f\'方式), \"3.14\" ;" 注释 = "  \'G\': 通用格式大写, \"3.14\" ;"
            注释 = "  \'n\': 数字, 同\'g\'类型,区别在于它会使用当前语言区域来为数字的整数部分插入适当的数字组分隔符 ;"
            注释 = "  \'%\': 百分比(将数字乘以 100 并显示为定点\'f\'格式,后面带一个百分号), \"314.000000%\" ." 注释 = "  任意类型(在本对象值类型为任何类型时都适用):"
            注释 = "  \'s\': 文本(本对象值不为文本型时会自动转换), \"Hi\" ." 注释 = "三. 常用示例:" 注释 = "描述格式: 场景描述: 格式指定文本, 本对象当前假设值, 该假设值对应的输出文本."
            注释 = "1. 整数:" 注释 = "  十六进制小写: \"x\", 42, \"2a\" ;" 注释 = "  十六进制大写带前缀: \"#X\", 42, \"0X2A\" ;"
            注释 = "  二进制带前缀: \"#b\", 42, \"0b101010\" ;" 注释 = "  固定宽度补零: \"05d\", 42, \"00042\" ;"
            注释 = "  千位分隔符: \",d\", 10000, \"10,000\" ;" 注释 = "  下划线分隔符: \"_d\", 10000, \"10_000\" ;"
            注释 = "  右对齐星号填充: \"*^10\", 42, \"****42****\" ." 注释 = "2. 小数:" 注释 = "  保留2位小数: \".2f\", 3.14159, \"3.14\" ;"
            注释 = "  科学计数法: \".2e\", 3.14159, \"3.14e+00\" ;" 注释 = "  百分比: \".1%\", 0.85, \"85.0%\" ;"
            注释 = "  通用格式(去零): \"g\", 3.14000, \"3.14\" ;" 注释 = "  固定宽度右对齐: \">10.2f\", 3.14, \"      3.14\" ;"
            注释 = "  带符号保留2位: \"+.2f\", -3.14, \"-3.14\" (正数会显示 +) ." 注释 = "3. 文本:" 注释 = "  左对齐填充: \"<10\", \"Hi\", \"Hi        \" ;"
            注释 = "  居中对齐填充: \"^10\", \"Hi\", \"    Hi    \" ;" 注释 = "  自定义字符填充: \"*^10\", \"Hi\", \"****Hi****\" ;"
            注释 = "  截断长度: \".3s\", \"Hello\", \"Hel\" ;" 注释 = "  截断并填充: \"*<3.3s\", \"Hello\", \"Hel\" (先截断再判断宽度,此处宽度3已满足)."
            注释 = "四. 复杂示例:" 注释 = "1. 整数:" 注释 = "  \"+#010X\": 显示正负号,十六进制大写,带\"0X\"前缀,总宽度 10,不足部分用 0 填充(注意: 0 填充会自动放在符号和前缀之后);"
            注释 = "  \"*>15,d\": 显示千位逗号,总宽度 15,右对齐,空白处用\'*\'填充;" 注释 = "  \"<20_b\": 二进制表示,每4位用下划线分隔(Python 3.6+),左对齐,宽度 20."
            注释 = "2. 小数:" 注释 = "  \"+015.4E\": 科学计数法,始终显示符号,总宽度 15,精度 4,大写 E,不足部分用 0 填充(数字部分);"
            注释 = "  \".^20,.2%\": 转换为百分比,保留 2 位小数,总宽度 20,居中对齐,用\'.\'填充,数字部分带千位逗号(如果数值够大);"
            注释 = "  \"+=010.2f\": 这是\'=\'对齐方式的典型用法: 符号在最左边,然后填充 0,然后是数字,常用于财务报表;" 注释 = "3. 文本:"
            注释 = "  \"~^15.5s\": 文本只取前 5 个字符,总宽度 15,居中对齐,用\'~\'填充;" 注释 = "  \"<20.8s\": 左对齐,宽度 20, 最多显示 8 个字符,不足补空格.">
    {
        @ @<欲操作本对象>.Format (@<格式指定文本>, &CVolString ())
    }

    方法 序列化 <公开 静态 类型 = Py对象类 注释 = "将本对象的内容序列化后写出到一个Python字节串(bytes)并返回." 注释 = "注意:" 注释 = "  1. 本方法只支持Python自有对象,不支持自定义类实例;"
            注释 = "  2. 为了保证安全,最好只用作在程序内部存储和解析对象数据,因为反序列化所写出数据可能会执行" 注释 = "任意代码,尤其在处理Python代码对象(\"为对象_代码\"方法返回真)时."
            返回值注释 = "成功返回Python字节串对象(\"为对象_字节串\"返回真),失败返回空对象并设置相关异常." @文档 = "category = \"基本.读写\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 数据版本号 <类型 = 整数 注释 = "指定所写出数据的格式版本." 注释 = "-1: 当前 Python 版本;" 注释 = "0: 原始格式(兼容旧版);" 注释 = "1: 添加了对浮点数 NaN/Inf 的支持;"
            注释 = "2: Python 3.4+ 引入,支持更高效的整数编码;" 注释 = "3: Python 3.8+ 引入,改进了字符串和字节的处理;" 注释 = "4: Python 3.8+,支持小整数优化等;"
            注释 = "5: Python 3.9+." @默认值 = -1>
    {
        @ return (@<欲操作本对象>.IsEmpty () ? CVolPyObject () : CVolPyObject (PyMarshal_WriteObjectToString (@<欲操作本对象>.Get (), (@<数据版本号> < 0 ? Py_MARSHAL_VERSION : @<数据版本号>))));
    }

    方法 反序列化 <公开 静态 类型 = Py对象类 注释 = "反序列化\"序列化\"方法返回的数据,创建并填充返回对应的对象." 注释 = "注意:" 注释 = "  1. 本方法只支持Python自有对象,不支持自定义类实例;"
            注释 = "  2. 所提供的必须是\"序列化\"方法返回的有效数据,传入任意数据会导致异常或未定义行为;"
            注释 = "  3. 反序列化操作可能执行任意代码,特别是当所提供数据包含Python代码对象(\"为对象_代码\"方法返回真)时,因此切勿调用本方法来反序" 注释 = "列化来自不可信来源的数据;"
            注释 = "  4. 所提供数据版本必须兼容,用高版本Python序列化的数据,低版本可能无法读取."
            返回值注释 = "成功返回反序列化后的结果对象,失败返回空对象并设置相关异常(\"Py异常类型.到文件尾\",\"Py异常类型.值无效\",\"Py异常类型.类型无效\"等)." @文档 = "category = \"基本.读写\""
            @嵌入式方法 = "">
    参数 对象数据字节串 <类型 = Py对象类 注释 = "提供欲反序列化的对象数据,必须为\"序列化\"方法所返回的Python字节串对象(\"为对象_字节串\"返回真).">
    {
        @ CVolPython::sMarshal_ReadObjectFromString (@<对象数据字节串>.Get ())
    }

    方法 为对象_异常 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python异常(Exception)对象实例,即是否是\"Py异常类型.基本异常\"类的子类实例." @文档 = "category = \"异常对象\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ (@<欲操作本对象>.IsExceptionObject ()
    }

    方法 异常_取调用栈 <公开 静态 类型 = Py对象类 注释 = "在本对象为异常实例对象(\"为对象_异常\"方法返回真)时,返回其中保存的调用栈对象." 注释 = "如果本对象不为异常实例对象或其中没有已关联的调用栈对象,则返回空对象."
            @文档 = "category = \"异常对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是异常对象(\"为对象_异常\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsExceptionObject () == FALSE ? CVolPyObject () : CVolPyObject (PyException_GetTraceback (@<欲操作本对象>.Get ())));
    }

    方法 异常_取调用栈文本 <公开 静态 类型 = 文本型 注释 = "在本对象为异常实例对象(\"为对象_异常\"方法返回真)时,返回其中调用栈对象对应的文本信息."
            注释 = "如果本对象不为异常实例对象或其中没有已关联的调用栈对象,则返回空文本." @文档 = "category = \"异常对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是异常对象(\"为对象_异常\"方法返回真)">
    {
        @ @<欲操作本对象>.GetExceptionTracebackString ()
    }

    方法 异常_取上下文 <公开 静态 类型 = Py对象类 注释 = "  在本对象为异常实例对象(\"为对象_异常\"方法返回真)时,返回其中保存的与此异常相关联" 注释 = "的上下文(在处理异常过程中设置的另一个异常实例)对象."
            注释 = "  如果本对象不为异常实例对象或其中没有已关联的上下文对象,则返回空对象." @文档 = "category = \"异常对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是异常对象(\"为对象_异常\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsExceptionObject () == FALSE ? CVolPyObject () : CVolPyObject (PyException_GetContext (@<欲操作本对象>.Get ())));
    }

    方法 异常_取原因 <公开 静态 类型 = Py对象类 注释 = "  在本对象为异常实例对象(\"为对象_异常\"方法返回真)时,返回其中保存的与此异常相关联"
            注释 = "的原因(一个异常实例,可能为空值对象(None),由 raise ... from ... 设置)对象." 注释 = "  如果本对象不为异常实例对象或其中没有已关联的原因对象,则返回空对象."
            @文档 = "category = \"异常对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是异常对象(\"为对象_异常\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsExceptionObject () == FALSE ? CVolPyObject () : CVolPyObject (PyException_GetCause (@<欲操作本对象>.Get ())));
    }

    方法 异常_取参数 <公开 静态 类型 = Py对象类 注释 = "  在本对象为异常实例对象(\"为对象_异常\"方法返回真)时,返回其中保存的与此异常相关联" 注释 = "的参数(\"args\")对象."
            注释 = "  如果本对象不为异常实例对象或其中没有已关联的参数对象,则返回空对象." @文档 = "category = \"异常对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是异常对象(\"为对象_异常\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsExceptionObject () == FALSE ? CVolPyObject () : CVolPyObject (PyException_GetArgs (@<欲操作本对象>.Get ())));
    }

    方法 为对象_字节串 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python字节串(bytes)类型的对象实例."
            注释 = "字节串对象实现了Python序列接口协议(\"为接口_序列\"方法返回真)并且可以被枚举(\"取枚举器\"方法返回非空对象)." @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsBytesObject (@<是否检查子类>)
    }

    方法 取字节串 <公开 静态 类型 = Py对象类 注释 = "  计算本对象的字节串形式,成功返回一个Python字节串(bytes)对象,失败返回空对象."
            注释 = "这相当于 Python 表达式\"bytes (欲操作本对象)\"的结果,与 bytes 不同的是,当本对象中的值是整数时," 注释 = "会设置\"Py异常类型.类型无效\"异常而不是创建对应尺寸的空白字节串."
            @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "  可以是字节串(bytes)自身,也可以是字节数组(bytearray,用作将可变字节数据转换为不可变字节数据)."
            注释 = "对于其它类型,只要没有实现\"__bytes__\"魔术方法,均采用类似\"str(欲操作本对象).encode(\'utf-8\')\""
            注释 = "的间接方法,即先将对象内容转换为文本方式,再取回其 UTF-8 编码格式的字节串数据.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyObject_Bytes (@<欲操作本对象>.Get ()));
    }

    方法 为对象_索引整数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个索引用整数(int)值" @文档 = "category = \"基本.整数\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsIndexObject ()
    }

    方法 为接口_数值 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个实现了Python数值(Number)接口协议的对象实例" @文档 = "category = \"数值接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsObjectImplNumber ()
    }

    方法 数值_取进制文本 <公开 静态 类型 = Py对象类 注释 = "返回本对象转换成以\"进制基数\"参数为基数的文本后的结果" 返回值注释 = "成功返回结果值文本(str)对象,失败返回空对象."
            @文档 = "category = \"数值接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python数值协议(\"为接口_数值\"方法返回真),如果不是 Python 中的整数(int)类型,会先将它转换成整数类型.">
    参数 进制基数 <类型 = 整数 注释 = "提供进制转换基数,必须是 2 / 8 / 10 / 16 .对于基数 2 / 8 / 16 ,返回的文本将分别加上基数标识 \'0b\', \'0o\', \'0x\'." @默认值 = 10>
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyNumber_ToBase (@<欲操作本对象>.Get (), @<进制基数>));
    }

    方法 为接口_可调用 <公开 静态 类型 = 逻辑型 注释 = "  返回本对象是否是一个实现了Python可调用(callable)接口协议的对象实例."
            注释 = "  这些类型的对象包括: \"函数\",\"绑定方法\",\"类型\"等. 所有类型(\"为对象_类型\"方法返回真)对象" 注释 = "均支持本协议,调用类型对象将会创建一个该类型的新对象实例."
            @文档 = "category = \"可调用接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsObjectImplCallable ()
    }

    方法 可调用_取名称 <公开 静态 类型 = 文本型 注释 = "如果本对象为实现了可调用接口的对象(\"为接口_可调用\"方法返回真),返回其名称,否则返回其类型的名称." @文档 = "category = \"可调用接口\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.GetFuncName ()
    }

    方法 可调用_取类型描述 <公开 静态 类型 = 文本型 注释 = "如果本对象为实现了可调用接口的对象(\"为接口_可调用\"方法返回真),返回其类型描述信息,否则返回空文本." @文档 = "category = \"可调用接口\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.GetFuncDesc ()
    }

    方法 调用 <公开 静态 类型 = Py对象类 注释 = "以指定参数调用本对象,返回调用结果." 返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常." @文档 = "category = \"可调用接口\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python可调用接口协议(\"为接口_可调用\"方法返回真)">
    参数 位置参数数据 <类型 = Py对象类 注释 = "提供调用本对象时所有顺序传入的\"位置参数数据\",用作为\"仅位置参数\"和以顺序方式传入的\"位置或关键字参数\"提供数据,为以下几种类型之一:"
            注释 = "1. 空对象: 如果不存在位置参数数据,请将本参数值提供为空对象;"
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象 ()\",否则等价于: \"欲操作本对象 (*(), **关键字参数数据)\"."
            注释 = "2. 为Python元组对象(\"为对象_元组\"方法返回真)且\"展开元组\"参数值为真,其中所有成员被展开用作顺序提供所有位置参数数据;"
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象 (*位置参数数据)\",否则等价于: \"欲操作本对象 (*位置参数数据, **关键字参数数据)\"."
            注释 = "  如函数调用: 欲操作本对象 (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数值应该为Python元组: (1, 2, 3)."
            注释 = "3. 不为Python元组对象或\"展开元组\"参数值为假,用作提供一个位置参数数据."
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象 (位置参数数据)\",否则等价于: \"欲操作本对象 (位置参数数据, **关键字参数数据)\"." @默认值 = 空对象>
    参数 关键字参数数据 <类型 = Py对象类 注释 = "  提供调用本对象时所有以键值对方式传入的参数数据,必须是Python字典对象(\"为对象_字典\"方法返回真),用作为以键值对方式传入的\"位置或关键字参数\""
            注释 = "和\"仅关键字参数\"提供数据. 注意: 键值对中所有关键字的数据类型必须为文本型."
            注释 = "  如函数调用: 欲操作本对象 (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数应该为Python字典: { \"arg3\": 4, \"value1\": 5, \"value2\": 6 }."
            注释 = "  如果不存在需要以键值对方式传入的参数数据,本参数值可以为空对象." @默认值 = 空对象>
    参数 展开元组 <类型 = 逻辑型 注释 = "  本参数值为假且当\"位置参数数据\"为一个Python元组时,该元组数据自身将作为一个调用参数,为真时会把其中的所有成员展开为一系列的调用参数."
            注释 = "  如: 假设\"元组1\"为一个包含\"文本1\"和123两个成员的元组, 执行\"欲操作本对象.调用 (元组1, 真)\"时本对象将接收到两个分别为\"文本1\"和123的参数,"
            注释 = "执行\"欲操作本对象.调用 (元组1, 假)\"时本对象将仅接收到一个\"元组1\"参数本身," @默认值 = 真>
    {
        @ @<欲操作本对象>.Call (@<位置参数数据>.Get (), @<展开元组>, @<关键字参数数据>.Get ())
    }

    方法 格式调用 <公开 静态 类型 = Py对象类 注释 = "以指定格式文本创建位置参数数据后调用本对象,返回调用结果. 本方法无法提供\"关键字参数数据\"." 返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常."
            编辑时信息 = "15C4D6, 0, 0, 0" @文档 = "category = \"可调用接口\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python可调用接口协议(\"为接口_可调用\"方法返回真)" 编辑时信息 = "15C4D6, 0, 0, 0">
    参数 类型格式文本 <类型 = 文本型 注释 = "  提供一个格式文本用作创建调用本对象时所需要的所有位置参数数据."
            注释 = "  格式文本规范请见\"格式创建\"方法的\"类型格式文本\"参数说明,所创建参数数据的传递方式请见\"调用\"方法" 注释 = "的\"位置参数数据\"参数说明."
            注释 = "  注意: 假设格式文本为\"sd\"或\"(sd)\",虽然最终建立的参数都是具有一个文本和一个整数成员的元组数据,但是该元"
            注释 = "组数据的参数传递方式不同: 前者将会把元组展开为一系列的参数数据,后者将仅传递一个该元组参数数据."
            注释 = "  如: 欲操作本对象.格式调用 (\"sd\", \"文本1\", 123) 语句将传递给本对象两个分别为\"文本1\"和123的参数,"
            注释 = "而: 欲操作本对象.格式调用 (\"(sd)\", \"文本1\", 123) 语句将仅传递给本对象一个包含\"文本1\"和123成员的元组." 编辑时信息 = "15C4D6, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "15C4D6, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @<欲操作本对象>.FormatCall (@<类型格式文本>.GetText (), _T (@sn<pm_types>) + 2, @<所提供数据>)
    }

    方法 调用方法 <公开 静态 类型 = Py对象类 注释 = "以指定参数调用本对象中指定名称的方法,返回调用结果."
            注释 = "提示: 为了提高执行效率,可以先获取指定名称的方法属性,再通过\"调用\"方法进行调用,避免重复查找指定名称的方法." 注释 = "如以下步骤:" 注释 = "1. 方法对象1 = 欲操作本对象.取属性值 (\"方法1\") ;"
            注释 = "2. 方法对象1.调用 (...)" 返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常." @文档 = "category = \"可调用接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "可以是任意存在欲调用方法成员属性的对象,譬如模块对象,类实例对象等.">
    参数 欲调用成员方法名称 <类型 = 文本型 注释 = "提供欲调用本对象中成员方法的名称.本对象中必须存在为此名称的方法属性,可以是类似\"成员1.方法1\"的多级名称.">
    参数 位置参数数据 <类型 = Py对象类 注释 = "提供调用方法时所有顺序传入的\"位置参数数据\",用作为\"仅位置参数\"和以顺序方式传入的\"位置或关键字参数\"提供数据,为以下几种类型之一:"
            注释 = "1. 空对象: 如果不存在位置参数数据,请将本参数值提供为空对象;"
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象.欲调用方法 ()\",否则等价于: \"欲操作本对象.欲调用方法 (*(), **关键字参数数据)\"."
            注释 = "2. 为Python元组对象(\"为对象_元组\"方法返回真)且\"展开元组\"参数值为真,其中所有成员被展开用作顺序提供所有位置参数数据;"
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象.欲调用方法 (*位置参数数据)\",否则等价于: \"欲操作本对象.欲调用方法 (*位置参数数据, **关键字参数数据)\"."
            注释 = "  如方法调用: 欲操作本对象.方法1 (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数值应该为Python元组: (1, 2, 3)."
            注释 = "3. 不为Python元组对象或\"展开元组\"参数值为假,用作提供一个位置参数数据."
            注释 = "  \"关键字参数数据\"为空对象时等价于 Python 表达式: \"欲操作本对象.欲调用方法 (位置参数数据)\",否则等价于: \"欲操作本对象.欲调用方法 (位置参数数据, **关键字参数数据)\"."
            @默认值 = 空对象>
    参数 关键字参数数据 <类型 = Py对象类 注释 = "  提供调用本对象时所有以键值对方式传入的参数数据,必须是Python字典对象(\"为对象_字典\"方法返回真),用作为以键值对方式传入的\"位置或关键字参数\"和"
            注释 = "\"仅关键字参数\"提供数据. 注意: 键值对中所有关键字的数据类型必须为文本型."
            注释 = "  如方法调用: 欲操作本对象.方法1 (1, 2, 3, arg3 = 4, value1 = 5, value2 = 6),此时本参数应该为Python字典: { \"arg3\": 4, \"value1\": 5, \"value2\": 6 }."
            注释 = "  如果不存在需要以键值对方式传入的参数数据,本参数值可以为空对象." @默认值 = 空对象>
    参数 展开元组 <类型 = 逻辑型 注释 = "  本参数值为假且当\"位置参数数据\"为一个Python元组时,该元组数据自身将作为一个调用参数,为真时会把其中的所有成员展开为一系列的调用参数."
            注释 = "  如: 假设\"元组1\"为一个包含\"文本1\"和123两个成员的元组, 执行\"欲操作本对象.调用方法 (\"方法1\", 元组1, 真)\"时\"方法1\"将接收到两个分别为\"文本1\"和123的"
            注释 = "参数,执行\"欲操作本对象.调用方法 (\"方法1\", 元组1, 假)\"时\"方法1\"将仅接收到一个\"元组1\"参数本身," @默认值 = 真>
    {
        @ @<欲操作本对象>.CallMethod (@<欲调用成员方法名称>.GetText (), @<位置参数数据>.Get (), @<展开元组>, @<关键字参数数据>.Get ())
    }

    方法 格式调用方法 <公开 静态 类型 = Py对象类 注释 = "以指定格式文本创建位置参数数据后调用本对象,返回调用结果. 本方法无法提供\"关键字参数数据\"."
            注释 = "提示: 为了提高执行效率,可以先获取指定名称的方法属性,再通过\"格式调用\"方法进行调用,避免重复查找指定名称的方法." 注释 = "如以下步骤:"
            注释 = "1. 方法对象1 = 欲操作本对象.取属性值 (\"方法1\") ;" 注释 = "2. 方法对象1.格式调用 (...)" 返回值注释 = "成功返回非空结果对象,失败返回空对象并设置对应异常."
            @文档 = "category = \"可调用接口\"" @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "可以是任意存在欲调用方法成员属性的对象">
    参数 欲调用成员方法名称 <类型 = 文本型 注释 = "提供欲调用本对象中成员方法的名称.本对象中必须存在为此名称的方法属性,可以是类似\"成员1.方法1\"的多级名称.">
    参数 类型格式文本 <类型 = 文本型 注释 = "  提供一个格式文本用作创建调用本对象时所需要的所有位置参数数据."
            注释 = "  格式文本规范请见\"格式创建\"方法的\"类型格式文本\"参数说明,所创建参数数据的传递方式请见\"调用方法\"方法" 注释 = "的\"位置参数数据\"参数说明."
            注释 = "  注意: 假设格式文本为\"sd\"或\"(sd)\",虽然最终建立的参数都是具有一个文本和一个整数成员的元组数据,但是该元"
            注释 = "组数据的参数传递方式不同: 前者将会把元组展开为一系列的参数数据,后者将仅传递一个该元组参数数据."
            注释 = "  如: 欲操作本对象.格式调用方法 (\"方法1\", \"sd\", \"文本1\", 123) 语句将传递给\"方法1\"两个分别为\"文本1\"和123的参数,"
            注释 = "而: 欲操作本对象.格式调用方法 (\"方法1\", \"(sd)\", \"文本1\", 123) 语句将仅传递给\"方法1\"一个包含\"文本1\"和123成员的元组." 编辑时信息 = "15C4D6, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "15C4D6, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ @<欲操作本对象>.FormatCallMethod (@<欲调用成员方法名称>.GetText (), @<类型格式文本>.GetText (), _T (@sn<pm_types>) + 3, @<所提供数据>)
    }

    方法 可调用_取枚举器 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个用作枚举本可调用对象内容的通用枚举器对象."
            注释 = "所返回的枚举器对象在进行枚举时,会不断调用本可调用对象,直到本对象调用后的返回值等于所指定的\"枚举停止值\"参数值为止."
            返回值注释 = "成功返回所创建的枚举器对象(\"为对象_可调用对象枚举器\"方法返回真),失败返回空对象并设置对应异常." @文档 = "category = \"可调用接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python可调用接口协议(\"为接口_可调用\"方法返回真),且必须支持不携带参数进行调用.">
    参数 枚举停止值 <类型 = Py对象类 注释 = "用作提供一个比较值,当本对象被调用后返回此值时,枚举器停止枚举. 具体判断表达式为: \"本对象调用后返回值.比较 (Py比较类型.等于, 枚举停止值) > 0\"."
            注释 = "注意: \"枚举停止值\"本身不会被枚举出来,一旦本对象调用后返回的值与此值相等,枚举立即终止,该值不会被作为\"枚举器_取下一项\"或\"枚举器_取下一项2\"方法的调用结果返回." 注释 = "本参数不能为空对象.">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<枚举停止值>.IsEmpty ()) ? NULL : PyCallIter_New (@<欲操作本对象>.Get (), @<枚举停止值>.Get ()));
    }

    方法 为接口_序列 <公开 静态 类型 = 逻辑型 注释 = "  返回本对象是否是一个实现了Python序列(sequence)接口协议的对象实例,该类对象用作记录一系列"
            注释 = "成员数据的集合,这些类型的对象包括: 元组(tuple), 列表(list), 文本(str), 字节串(bytes)等."
            注释 = "  注意: 对序列对象进行操作的方法,如果不涉及到修改本对象或下标访问,同样可以在支持被枚举" 注释 = "(\"取枚举器\"方法返回非空对象)的对象上使用,具体在对应方法的参数处有描述."
            @文档 = "category = \"序列接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsObjectImplSequence ()
    }

    方法 序列_解析 <公开 静态 类型 = 逻辑型 注释 = "解析所提供序列数据中对应数目的成员,将其转换到火山格式填入到接收变量表中."
            注释 = "注意: 从Python文本(str)对象中解析出来的成员是另一个文本(str)对象,而不是字符." 返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"序列接口\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)">
    参数 起始索引 <类型 = 整数 注释 = "指定从本序列对象的第几个成员开始获取数据,索引值从0开始." @默认值 = 0>
    参数 接收变量表 <注释 = "用作从本序列对象中接收解析出来的指定数目成员数据."
            注释 = "参数的数目为欲获取序列成员的数目,数据类型必须与对应的序列成员数据类型匹配,具体数据类型匹配表请见\"解析参数\"方法的\"接收变量表\"参数的说明." @可扩展 = "d_text=\", &\"" @需求类型 = 可写入变量
            @匹配类型 = 通用型>
    {
        @ CVolPyObject::sParseSeqElements (@<欲操作本对象>.Get (), @<起始索引>, _T (@sn<pm_types>) + 2, &@<接收变量表>)
    }

    方法 序列_取尺寸 <公开 静态 类型 = 整数 注释 = "成功时返回本序列或可枚举对象中的成员数目,失败时返回 -1 . 相当于Python的 \"len(欲操作本对象)\" 表达式." @文档 = "category = \"序列接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : (INT)PySequence_Length (@<欲操作本对象>.Get ()));
    }

    方法 序列_连接 <公开 静态 类型 = Py对象类 注释 = "成功时返回本序列或可枚举对象和另一序列或可枚举对象的内容拼接对象,失败时返回空对象." 注释 = "等价于 Python 表达式 \"欲操作本对象 + 欲拼接对象\"."
            @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 欲拼接对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲拼接对象>.IsEmpty ()) ? NULL : PySequence_Concat (@<欲操作本对象>.Get (), @<欲拼接对象>.Get ()));
    }

    方法 序列_重复 <公开 静态 类型 = Py对象类 注释 = "返回本序列或可枚举对象内容重复指定次数的结果,失败时返回空对象. 等价于 Python 表达式 \"欲操作本对象 * 欲重复次数\"."
            @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 欲重复次数 <类型 = 整数 注释 = "指定欲将本对象内容重复的次数">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲重复次数> < 0) ? NULL : PySequence_Repeat (@<欲操作本对象>.Get (), @<欲重复次数>));
    }

    方法 序列_连接后赋值 <公开 静态 类型 = Py对象类 注释 = "成功时返回本序列对象和另一序列对象的内容拼接对象,失败时返回空对象."
            注释 = "如果本对象内容支持被修改(如列表),结果内容将被置入对象内, 等价于 Python 表达式 \"欲操作本对象 += 欲拼接对象\"." @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)">
    参数 欲拼接对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲拼接对象>.IsEmpty ()) ? NULL : PySequence_InPlaceConcat (@<欲操作本对象>.Get (), @<欲拼接对象>.Get ()));
    }

    方法 序列_重复后赋值 <公开 静态 类型 = Py对象类 注释 = "返回本序列对象内容重复指定次数的结果,失败时返回空对象."
            注释 = "如果本对象内容支持被修改(如列表),结果内容将被置入对象内, 等价于 Python 表达式 \"欲操作本对象 *= 欲重复次数\"." @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列(Sequence)接口协议(\"为接口_序列\"方法返回真)">
    参数 欲重复次数 <类型 = 整数 注释 = "指定欲将本对象内容重复的次数">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲重复次数> < 0) ? NULL : PySequence_InPlaceRepeat (@<欲操作本对象>.Get (), @<欲重复次数>));
    }

    方法 序列_取成员 <公开 静态 类型 = Py对象类 注释 = "成功返回本序列对象中指定索引位置处的成员,失败返回空对象. 等价于 Python 表达式 \"欲操作本对象 [索引位置]\"."
            @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "提供欲获取成员的索引位置">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PySequence_GetItem (@<欲操作本对象>.Get (), @<索引位置>));
    }

    方法 序列_置成员 <公开 静态 类型 = 逻辑型 注释 = "将所指定对象赋值给本序列对象指定索引位置处的成员. 成功返回真,失败设置异常并返回假. 相当于 Python 语句 \"欲操作本对象 [索引位置] = 欲置入对象\"."
            @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列(Sequence)接口协议(\"为接口_序列\"方法返回真)">
    参数 索引位置 <类型 = 整数 注释 = "提供欲获取成员的索引位置">
    参数 欲置入对象 <类型 = Py对象类 注释 = "提供欲置入到指定位置处的对象数据,如果为空对象,将删除该索引位置处的成员,相当于 Python 语句 \"del 欲操作本对象 [索引位置]\"."
            注释 = "注意: 由于元组(tuple)具有不可变性,因此不能删除元组中的成员.">
    {
        @ if (@<欲操作本对象>.IsEmpty ())  return FALSE;
        @ return ((@<欲置入对象>.IsEmpty () ? PySequence_DelItem (@<欲操作本对象>.Get (), @<索引位置>) : PySequence_SetItem (@<欲操作本对象>.Get (), @<索引位置>, @<欲置入对象>.Get ())) >= 0);
    }

    方法 序列_取片段 <公开 静态 类型 = Py对象类 注释 = "成功返回本序列或可枚举对象中指定范围内的所有成员,失败返回空对象. 等价于 Python 表达式 \"欲操作本对象 [起始索引位置 : 结束索引位置]\"."
            @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 起始索引位置 <类型 = 整数 注释 = "提供欲获取片段的起始成员索引位置">
    参数 结束索引位置 <类型 = 整数 注释 = "提供欲获取片段的结束成员索引位置,注意该位置处的成员本身并不包含在所返回的片段内.">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PySequence_GetSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>));
    }

    方法 序列_置片段 <公开 静态 类型 = 逻辑型 注释 = "用一个序列或可枚举对象内容替换本序列对象指定范围内的所有成员. 相当于 Python 语句 \"欲操作本对象 [起始索引位置 : 结束索引位置] = 欲置入序列对象\"."
            返回值注释 = "成功返回真,失败返回假并设置对应异常." @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列(Sequence)接口协议(\"为接口_序列\"方法返回真)">
    参数 起始索引位置 <类型 = 整数 注释 = "提供欲设置范围的起始成员索引位置">
    参数 结束索引位置 <类型 = 整数 注释 = "提供欲设置范围的结束成员索引位置,注意该位置处的成员本身并不包含在内.">
    参数 欲置入序列对象 <类型 = Py对象类 注释 = "提供用来设置的序列对象,其类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)"
            注释 = "如果为空对象,则删除本序列对象中指定范围内的所有成员,相当于 Python 语句 \"del 欲操作本对象 [起始索引位置 : 结束索引位置]\"."
            注释 = "注意: 由于元组(tuple)具有不可变性,因此不能删除元组中的成员.">
    {
        @ if (@<欲操作本对象>.IsEmpty ())  return FALSE;
        @ return ((@<欲置入序列对象>.IsEmpty () ? PySequence_DelSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>) : PySequence_SetSlice (@<欲操作本对象>.Get (), @<起始索引位置>, @<结束索引位置>, @<欲置入序列对象>.Get ())) >= 0);
    }

    方法 序列_计数 <公开 静态 类型 = 整数 注释 = "返回所指定值在本序列或可枚举对象中出现的次数,即返回使得 \"欲操作本对象 [索引] == 欲检测值\" 的成员数量, 失败返回 -1."
            注释 = "相当于 Python 表达式 \"欲操作本对象.count (欲检测值)\"." 注释 = "注意: 对于文本,由于其成员类型为字符,因此只能检查单个字符文本." @文档 = "category = \"序列接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 欲检测值 <类型 = Py对象类 注释 = "提供欲检测其出现次数的值">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲检测值>.IsEmpty ()) ? -1 : (INT)PySequence_Count (@<欲操作本对象>.Get (), @<欲检测值>.Get ()));
    }

    方法 序列_包含 <公开 静态 类型 = 整数 注释 = "返回本序列或可枚举对象中是否存在所指定值. 存在返回 1,不存在返回 0,出错返回 -1." 注释 = "相当于 Python 表达式 \"欲检测值 in 欲操作本对象\"."
            注释 = "注意: 对于文本,由于其成员类型为字符,因此只能检查单个字符文本." @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 欲检测值 <类型 = Py对象类 注释 = "提供欲检测其是否存在的值">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲检测值>.IsEmpty ()) ? -1 : PySequence_Contains (@<欲操作本对象>.Get (), @<欲检测值>.Get ()));
    }

    方法 序列_查找 <公开 静态 类型 = 整数 注释 = "查找本序列或可枚举对象中第一个等于指定值的成员所处索引位置. 找到返回大于等于0的索引位置值,未找到或出错返回 -1."
            注释 = "相当于 Python 表达式 \"欲操作本对象.index (欲查找值)\"." 注释 = "注意: 对于文本,由于其成员类型为字符,因此只能查找单个字符文本." @文档 = "category = \"序列接口\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
    参数 欲查找值 <类型 = Py对象类 注释 = "提供欲查找其所处位置的值">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲查找值>.IsEmpty ()) ? -1 : (INT)PySequence_Index (@<欲操作本对象>.Get (), @<欲查找值>.Get ()));
    }

    方法 序列_取列表 <公开 静态 类型 = Py对象类 注释 = "返回一个Python列表(list)对象(\"为对象_列表\"方法返回真),其内容与本序列或可枚举对象相同,失败时返回空对象. 所返回的列表保证是一个新对象."
            注释 = "等价于 Python 表达式 \"list (欲操作本对象)\"." 注释 = "本方法常用来将不可修改的元组数据转换为可修改的列表数据." @文档 = "category = \"序列接口\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须实现了Python序列接口协议(\"为接口_序列\"方法返回真)或可以被枚举(\"取枚举器\"方法返回非空对象)">
