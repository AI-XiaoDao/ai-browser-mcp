    }

    方法 对象到长整数 <公开 静态 类型 = 长整数 注释 = "  本对象中如果存储的是Python整数(int)/小数(float)/逻辑型(bool)/空值对象(None),"
            注释 = "将其转换到长整数后返回,否则返回0(注意正常情况下也可能返回0)." 注释 = "  注意: 本方法是类型转换方法,用作支持将本类对象自动转换到长整数值,如: (长整数)欲操作本对象, 长整数变量1 = 欲操作本对象 ."
            @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return @<欲操作本对象>.ToInt64 ();
    }

    方法 为小数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python小数(float)的对象实例." 注释 = "Python小数与火山程序的小数(IEEE 754)类型等同."
            @文档 = "category = \"基本.小数\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsFloatObject (@<是否检查子类>)
    }

    方法 单精度小数到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的单精度小数创建并返回float类型的Python对象" @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 单精度小数值 <类型 = 单精度小数>
    {
        @ return CVolPyObject (PyFloat_FromDouble ((DOUBLE)@<单精度小数值>));
    }

    方法 对象到单精度小数 <公开 静态 类型 = 单精度小数 注释 = "  本对象中如果存储的是Python整数(int)/小数(float)/逻辑型(bool)/空值对象(None),"
            注释 = "将其转换到单精度小数后返回,否则返回0(注意正常情况下也可能返回0)."
            注释 = "  注意: 本方法是类型转换方法,用作支持将本类对象自动转换到小数值,如: (单精度小数)欲操作本对象, 单精度小数变量1 = 欲操作本对象 ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (FLOAT)@<欲操作本对象>.ToDouble ();
    }

    方法 小数到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的小数创建并返回float类型的Python对象."
            注释 = "注意: 本方法是类型转换方法,用作支持将小数值自动转换到本类对象,如: (Py对象类)3.14, 本类对象变量1 = 3.14 ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真
            @禁止流程检查 = 真>
    参数 小数值 <类型 = 小数>
    {
        @ return CVolPyObject (PyFloat_FromDouble (@<小数值>));
    }

    方法 对象到小数 <公开 静态 类型 = 小数 注释 = "  本对象中如果存储的是Python整数(int)/小数(float)/逻辑型(bool)/空值对象(None),"
            注释 = "将其转换到小数后返回,否则返回0(注意正常情况下也可能返回0)." 注释 = "  注意: 本方法是类型转换方法,用作支持将本类对象自动转换到小数值,如: (小数)欲操作本对象, 小数变量1 = 欲操作本对象 ."
            @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return @<欲操作本对象>.ToDouble ();
    }

    方法 为逻辑值 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python逻辑型(bool)值的对象实例." 注释 = "Python逻辑型是Python整数(int)类型的子类."
            @文档 = "category = \"基本.逻辑值\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ @<欲操作本对象>.IsBoolObject ()
    }

    方法 逻辑值到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的逻辑值创建并返回bool类型的Python对象."
            注释 = "注意: 本方法是类型转换方法,用作支持将逻辑值自动转换到本类对象,如: (Py对象类)真, 本类对象变量1 = 假 ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 逻辑值 <类型 = 逻辑型>
    {
        @ return CVolPyObject (PyBool_FromLong (@<逻辑值> ? 1 : 0));
    }

    方法 对象到逻辑值 <公开 静态 类型 = 逻辑型 注释 = "  本对象中如果存储的是Python整数(int)/逻辑值(bool)/空值对象(None)," 注释 = "将其转换到逻辑值后返回,否则返回假(注意正常情况下也可能返回假)."
            注释 = "  注意: 本方法是类型转换方法,用作支持将本类对象自动转换到逻辑值,如: (逻辑型)欲操作本对象, 逻辑型变量1 = 欲操作本对象 ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return @<欲操作本对象>.ToBoolean ();
    }

    方法 为真 <公开 静态 类型 = 整数 注释 = "如果本对象可以被认为是逻辑值真,返回 1,否则返回 0,失败返回-1. 这相当于 Python 表达式\"bool (欲操作本对象)\"或\"not not 欲操作本对象\"."
            注释 = "以下是各种Python对象为真的判别条件: 逻辑值(bool)真, 非空文本(str), 非0整数(int), 非0小数(float), 非空元组(tuple)/非空列表(list)/非空字典(dict)/非空集合(set)."
            @文档 = "category = \"基本.逻辑值\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : PyObject_IsTrue (@<欲操作本对象>.Get ()));
    }

    方法 真值 <公开 静态 类型 = Py对象类 注释 = "返回一个Python的逻辑值真对象" @文档 = "category = \"基本.逻辑值\"" @嵌入式方法 = "">
    {
        @ CVolPyObject_BorrowedRef (Py_True)
    }

    方法 为假 <公开 静态 类型 = 整数 注释 = "如果本对象可以被认为是逻辑值真,返回 0,否则返回 1,失败返回-1. 这相当于 Python 表达式\"not 欲操作本对象\"."
            注释 = "以下是各种Python对象为假的判别条件: 逻辑值(bool)假, 空文本(str), 整数(int)0, 小数(float)0, 空值对象(None)/空元组(tuple)/空列表(list)/空字典(dict)/空集合(set)."
            @文档 = "category = \"基本.逻辑值\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : PyObject_Not (@<欲操作本对象>.Get ()));
    }

    方法 假值 <公开 静态 类型 = Py对象类 注释 = "返回一个Python的逻辑值假对象" @文档 = "category = \"基本.逻辑值\"" @嵌入式方法 = "">
    {
        @ CVolPyObject_BorrowedRef (Py_False)
    }

    方法 为复数 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python复数(complex)的对象实例" @文档 = "category = \"基本.复数\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsComplexObject (@<是否检查子类>)
    }

    方法 创建复数 <公开 静态 类型 = Py对象类 注释 = "基于所指定的复数值创建并返回complex类型的Python对象." 注释 = "当发生错误时将返回空对象并设置一个异常." @文档 = "category = \"基本.复数\""
            @嵌入式方法 = "">
    参数 实部 <类型 = 小数 注释 = "提供所欲创建复数值的实部值">
    参数 虚部 <类型 = 小数 注释 = "提供所欲创建复数值的虚部值">
    {
        @ CVolPyObject (PyComplex_FromDoubles (@<实部>, @<虚部>))
    }

    方法 取复数实部 <公开 静态 类型 = 小数 注释 = "  返回本复数对象的实部值,当失败时,本方法将返回 -1.0 并设置一个异常," 注释 = "因此调用本方法后应该使用\"Py异常类.发现异常\"方法进行检查是否成功."
            @文档 = "category = \"基本.复数\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python复数对象(\"为复数\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1.0 : PyComplex_RealAsDouble (@<欲操作本对象>.Get ()));
    }

    方法 取复数虚部 <公开 静态 类型 = 小数 注释 = "  返回本复数对象的虚部值,当失败时,本方法将返回 -1.0 并设置一个异常," 注释 = "因此调用本方法后应该使用\"Py异常类.发现异常\"方法进行检查是否成功."
            @文档 = "category = \"基本.复数\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python复数对象(\"为复数\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1.0 : PyComplex_ImagAsDouble (@<欲操作本对象>.Get ()));
    }

    方法 取常量 <公开 静态 类型 = Py对象类 注释 = "返回对应的Python常量对象,如果所提供常量类型无效,将返回空对象." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 常量类型 <类型 = Py常量>
    {
        @ CVolPyObject (Py_GetConstant ((unsigned int)@<常量类型>))
    }

    方法 是否有属性 <公开 静态 类型 = 逻辑型 注释 = "返回本对象中是否有指定名称(以Python对象方式提供)的属性" @文档 = "category = \"基本.属性\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性名称对象 <类型 = Py对象类 注释 = "提供欲检查其是否存在的属性名称对象." 注释 = "提示: 由于支持文本到Py对象类的自动类型转换,因此此参数也可以直接提供对应的属性名称文本.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<属性名称对象>.IsEmpty ()) ? FALSE : (BOOL)PyObject_HasAttr (@<欲操作本对象>.Get (), @<属性名称对象>.Get ()));
    }

    方法 是否有文本属性 <公开 静态 类型 = 逻辑型 注释 = "返回本对象中是否有指定名称的属性." 注释 = "本方法效果与\"是否有属性\"方法相同,不过直接使用文本属性名参数." @文档 = "category = \"基本.属性\""
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性名称 <类型 = 文本型 注释 = "提供欲检查其是否存在的属性名称文本">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (BOOL)PyObject_HasAttrString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<属性名称>)));
    }

    方法 取属性值 <公开 静态 类型 = Py对象类 注释 = "返回本对象中指定名称(以Python对象方式提供)属性的值,如果失败返回空对象. 注意:" 注释 = "1. 在模块对象中变量/方法/类的定义均为其属性;"
            注释 = "2. 获取对象的方法属性时,所获得的方法将携带其所处对象自身,调用该方法将会把其所处的对象" 注释 = "作为 self 参数传递过去." @文档 = "category = \"基本.属性\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性名称对象 <类型 = Py对象类 注释 = "  提供欲获取其值的属性名称对象." 注释 = "  提示: 由于支持文本到Py对象类的自动类型转换,因此此参数也可以直接提供对应的属性名称文本,"
            注释 = "不过本属性名称不支持多级属性名.">
    {
        @ @<欲操作本对象>.ObjGetOptionalAttr (@<属性名称对象>.Get ())
    }

    方法 取文本属性值 <公开 静态 类型 = Py对象类 注释 = "返回本对象中指定名称属性的值,如果失败返回空对象." 注释 = "本方法效果与\"取属性值\"方法相同,不过直接使用文本属性名参数,且支持使用由句点分隔的多级属性名."
            @文档 = "category = \"基本.属性\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性全名称 <类型 = 文本型 注释 = "提供欲获取其值的属性全名称,可以是以句点分隔的多级属性名,如: \"属性1.子属性2\".">
    {
        @ @<欲操作本对象>.StrGetOptionalAttr (@<属性全名称>.GetText ())
    }

    方法 置属性值 <公开 静态 类型 = 逻辑型 注释 = "设置本对象中指定名称属性的值." 注释 = "相当于 Python 语句\"欲操作本对象.属性名称 = 属性值\"."
            注释 = "注意: 本对象中必须存在\"__dict__\"成员(本对象所基于类为\"object\"的子类型,或为调用\"创建 (真)\"方法创建),不然将设置失败." 返回值注释 = "成功返回真,失败返回假并设置对应异常."
            @文档 = "category = \"基本.属性\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性名称对象 <类型 = Py对象类 注释 = "提供欲设置其值的属性名称对象,如果该名称的属性不存在,则将其创建."
            注释 = "提示: 由于支持文本到Py对象类的自动类型转换,因此此参数也可以直接提供对应的属性名称文本(不支持多级属性名).">
    参数 属性值 <类型 = Py对象类 注释 = "提供欲具体设置的属性值,如果为空对象,则删除该属性.">
    {
        @ @<欲操作本对象>.ObjSetAttrValue (@<属性名称对象>.Get (), @<属性值>.Get ())
    }

    方法 置文本属性值 <公开 静态 类型 = 逻辑型 注释 = "设置本对象中指定名称属性的值." 注释 = "相当于 Python 语句\"欲操作本对象.属性全名称 = 属性值\"."
            注释 = "注意: 本对象中必须存在\"__dict__\"成员(本对象所基于类为\"object\"的子类型,或为调用\"创建 (真)\"方法创建),不然将设置失败."
            注释 = "本方法效果与\"置属性值\"方法相同,不过直接使用文本属性名参数,且支持使用由句点分隔的多级属性名." 返回值注释 = "成功返回真,失败返回假并设置对应异常." @文档 = "category = \"基本.属性\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 属性全名称 <类型 = 文本型 注释 = "提供欲获取其值的属性全名称,可以是以句点分隔的多级属性名,如: \"属性1.子属性2\",如果最后一个名称的属性不存在,则将其创建.">
    参数 属性值 <类型 = Py对象类 注释 = "提供欲具体设置的属性值,如果为空对象,则删除该属性.">
    {
        @ @<欲操作本对象>.StrSetAttrValue (@<属性全名称>.GetText (), @<属性值>.Get ())
    }

    方法 取属性列表 <公开 静态 类型 = Py对象类 注释 = "成功返回一个包含本对象中所有有效属性名称的Python列表(\"为对象_列表\"方法返回真),这些名称通常都是文本对象,失败返回空对象且设置对应异常."
            注释 = "调用本方法等同于 Python 表达式: \"dir (欲操作本对象)\"." @文档 = "category = \"基本.属性\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return CVolPyObject (@<欲操作本对象>.IsEmpty () ? NULL : PyObject_Dir (@<欲操作本对象>.Get ()));
    }

    方法 比较 <公开 静态 类型 = 整数 注释 = "将本对象使用指定操作类型与另一个对象进行比较,返回比较结果." 注释 = "等价于 Python 表达式: \"欲操作本对象 比较类型 欲比较对象\"."
            返回值注释 = "出错时返回-1,比较成功(结果为逻辑值真)返回1,否则返回0." @文档 = "category = \"基本.常用\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 比较类型 <类型 = Py比较类型 注释 = "指定欲进行的比较类型">
    参数 欲比较对象 <类型 = Py对象类 注释 = "提供欲与本对象进行比较的另一个对象">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲比较对象>.IsEmpty ()) ? -1 : PyObject_RichCompareBool (@<欲操作本对象>.Get (), @<欲比较对象>.Get (), @<比较类型>));
    }

    方法 计算哈希值 <公开 静态 类型 = 变整数 注释 = "计算并返回本对象对应的哈希值,如果本对象不支持计算哈希值或失败返回-1." 注释 = "调用本方法相当于 Python 表达式: \"hash (欲操作本对象)\"."
            @文档 = "category = \"基本.常用\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : (INT_P)PyObject_Hash (@<欲操作本对象>.Get ()));
    }

    方法 取长度 <公开 静态 类型 = 整数 注释 = "返回本对象的长度,如果本对象支持序列或映射协议,则返回其长度. 出错时返回-1." 注释 = "调用本方法等同于 Python 表达式: \"len (欲操作本对象)\"."
            @文档 = "category = \"基本.成员\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        @ return (@<欲操作本对象>.IsEmpty () ? -1 : (INT)PyObject_Length (@<欲操作本对象>.Get ()));
    }

    方法 取成员 <公开 静态 类型 = Py对象类 注释 = "  返回本对象中对应指定索引位置处的成员值,失败或未找到返回空对象并设置对应异常."
            注释 = "  注意: 本对象必须为支持\"下标访问子成员\"(如:\"欲操作本对象 [索引]\")的Python对象,如列表(list)、字典(dict)、元组(tuple)、"
            注释 = "文本(str)、字节串(bytes)、字节数组(bytearray)等,而不支持集合(set或frozenset),因为集合是无序的,它没有索引或键的概念."
            注释 = "  调用本方法等同于 Python 表达式: \"欲操作本对象 [成员索引值]\"." @文档 = "category = \"基本.成员\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 成员索引值 <类型 = Py对象类 注释 = "提供所访问成员对应的索引值,可以是整数索引值,或成员关键字,或切片对象(\"为对象_切片\"方法返回真,用作获取一个指定区域的成员).">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<成员索引值>.IsEmpty ()) ? NULL : PyObject_GetItem (@<欲操作本对象>.Get (), @<成员索引值>.Get ()));
    }

    方法 置成员 <公开 静态 类型 = 逻辑型 注释 = "  设置本对象中对应指定索引位置处的成员值,成功返回真,失败返回假并设置对应异常."
            注释 = "  注意: 本对象必须为支持\"下标访问子成员\"(如:\"欲操作本对象 [索引]\")的可写Python对象,如列表(list)、字典(dict)等,不能为元组"
            注释 = "(tuple)、文本(str)、字节串(bytes)这些只读对象,且不支持集合(set或frozenset),因为集合是无序的,它没有索引或键的概念."
            注释 = "  调用本方法等同于 Python 语句: \"欲操作本对象 [成员索引值] = 欲设置值\"." @文档 = "category = \"基本.成员\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 成员索引值 <类型 = Py对象类 注释 = "提供所设置成员对应的索引值,可以是整数索引值,或成员关键字,或切片对象(\"为对象_切片\"方法返回真,用作设置一个指定区域的成员)."
            注释 = "如果本对象为Python字典对象(dict),且本参数为未对应任何已有成员的关键字,将自动添加一个新成员.">
    参数 欲设置值 <类型 = Py对象类 注释 = "提供欲设置的值,如果为空对象,将删除对应的成员(不存在将出错返回并设置异常),相当于 Python 语句: \"del 欲操作本对象 [成员索引值]\"." 注释 = "注意:"
            注释 = "  1. 由于元组(tuple)具有不可变性,因此不能删除元组中的成员;"
            注释 = "  2. 如果\"成员索引值\"参数为一个切片对象(\"为对象_切片\"方法返回真),则 Python 会认为本参数为一个可枚举对象,然后将该可枚举对象中"
            注释 = "的每个成员依次放入切片指定的位置. 譬如假设本参数值为一个文本\"abc\",而\"成员索引值\"为一个切片对象,那么 Python 会将 \"abc\" 拆开为"
            注释 = "三个单独的字符 \'a\', \'b\', \'c\',然后分别置入切片所指定的位置. 如想避免这种情况置入完整的\"abc\"文本\",请将文本用一个列表或元组包裹" 注释 = "起来再提供给本参数.">
    {
        @ if (@<欲操作本对象>.IsEmpty () || @<成员索引值>.IsEmpty ())  return FALSE;
        @ if (@<欲设置值>.IsEmpty ())  return (PyObject_DelItem (@<欲操作本对象>.Get (), @<成员索引值>.Get ()) >= 0);
        @ return (PyObject_SetItem (@<欲操作本对象>.Get (), @<成员索引值>.Get (), @<欲设置值>.Get ()) >= 0);
    }

    方法 删除成员 <公开 静态 类型 = 逻辑型 注释 = "删除本对象中对应指定文本型关键字的成员,成功返回真,失败返回假并设置对应异常." 注释 = "非文本型关键字的成员请使用\"置成员\"方法删除(\"欲设置值\"参数设置为空对象)."
            @文档 = "category = \"基本.成员\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    参数 成员文本关键字 <类型 = 文本型 注释 = "提供所需删除成员对应的文本关键字">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyObject_DelItemString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<成员文本关键字>)) >= 0));
    }

    方法 运算 <公开 静态 类型 = Py对象类 注释 = "返回本对象进行运算的结果,成功返回结果值对象,失败返回空对象并可能设置相应异常." @文档 = "category = \"基本.常用\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象的类型必须支持所指定的运算符,譬如相加操作: 可以是文本(str)/列表(list)/数值这些."
            注释 = "当进行单值运算时,本参数提供操作数\"o\",当进行多值运算时,提供操作数\"o1\".">
    参数 运算符 <类型 = Py运算符 注释 = "提供具体欲执行的 Python 运算符,具体含义请参见\"Py运算符\"类中的说明.">
    参数 操作数2 <类型 = Py对象类 注释 = "当进行运算需要两个操作数时,本参数提供操作数\"o2\",其类型必须支持所指定的运算符." 注释 = "如果运算不需要2个操作数,本参数被忽略,可以提供空对象." @默认值 = 空对象>
    参数 操作数3 <类型 = Py对象类 注释 = "当进行运算需要三个操作数时,本参数提供操作数\"o3\",其类型必须支持所指定的运算符." 注释 = "如果运算不需要3个操作数,本参数被忽略,可以提供空对象." @默认值 = 空对象>
    {
        @ @<欲操作本对象>.Calculation (@<运算符>, @<操作数2>.Get (), @<操作数3>.Get ())
    }

    方法 取 <公开 静态 注释 = "返回本对象中的Python值转换到指定火山数据类型后的结果值." 注释 = "本方法较少使用,一般情况下直接使用对应的类型转换方法即可." @文档 = "category = \"基本.读写\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 欲转换到数据类型 <注释 = "提供欲转换到的数据类型,支持所有基本数据类型、\"字节集类\"、\"Py对象类\"." 注释 = "数据类型匹配表请见\"解析参数\"方法的\"接收变量表\"参数的说明."
            注释 = "如果本对象中的Python值无法转换到该数据类型,将返回此数据类型的空值." @需求类型 = 数据类型 @匹配类型 = 通用型 @返回值类型 = 0>
    参数 是否成功 <类型 = 逻辑型类 注释 = "如果不为空对象,则在其中填入是否转换成功." @默认值 = 空对象>
    {
        @ @<欲操作本对象>.GetValue<@<欲转换到数据类型>> (*(_T (@sn<pm_types>) + 1), &@<是否成功.值>)
    }

    方法 置 <公开 静态 注释 = "将指定类型火山数据转换到Python数据后置入本对象中,失败将会把本对象内容清空." 注释 = "本方法较少使用,一般情况下直接使用对应的类型转换方法进行赋值操作即可."
            @文档 = "category = \"基本.读写\"" @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲操作本对象 <类型 = Py对象类 编辑时信息 = "DC4DE, 0, 0, 0">
    参数 欲置入数据 <注释 = "提供欲置入数据,该数据将被以默认方式转换为Python数据后置入本对象内."
            注释 = "支持所有基本数据类型、\"字节集类\"、\"Py对象类\". 具体转换方式参见\"格式创建\"方法的\"类型格式文本\"参数中对\'*\'替换格式项的描述." 编辑时信息 = "DC4DE, 0, 0, 0"
            @匹配类型 = 通用型>
    {
        @ @<欲操作本对象>.Set_NewRef (CVolPyObject::sFormatCreate (_T (""), _T (@sn<pm_types>) + 1, @<欲置入数据>))
    }

    方法 格式置入 <公开 静态 注释 = "将指定类型火山数据转换到Python数据后置入本对象中,失败将会把本对象内容清空." @文档 = "category = \"基本.读写\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
