    方法 字典_置键值 <公开 静态 类型 = 逻辑型 注释 = "在本字典对象中插入/更新/删除指定的关键字,返回是否成功." 注释 = "如果指定关键字不存在于本字典对象中,则插入新的关键字; 如果指定关键字已存在,则用新的键值替换旧的值."
            注释 = "相当于 Python 语句 \"欲操作本对象 [关键字] = 欲设置键值\"." 返回值注释 = "成功返回真,失败设置异常并返回假." @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字典(dict)对象(\"为对象_字典\"方法返回真)">
    参数 关键字 <类型 = Py对象类 注释 = "提供欲设置其键值的关键字对象,如果该关键字不存在,则将其创建." 注释 = "本关键字对象必须是可哈希的,如果不是,将失败并设置\"Py异常类型.类型无效\"异常.">
    参数 欲设置键值 <类型 = Py对象类 注释 = "提供欲具体设置的键值,如果为空对象,则删除该关键字,相当于 Python 语句 \"del 欲操作本对象 [关键字]\".">
    {
        @ if (@<欲操作本对象>.IsEmpty () || @<关键字>.IsEmpty ())  return FALSE;
        @ if (@<欲设置键值>.IsEmpty ())  return (PyDict_DelItem (@<欲操作本对象>.Get (), @<关键字>.Get ()) >= 0);
        @ return (PyDict_SetItem (@<欲操作本对象>.Get (), @<关键字>.Get (), @<欲设置键值>.Get ()) >= 0);
    }

    方法 字典_置文本键值 <公开 静态 类型 = 逻辑型 注释 = "在本字典对象中插入/更新/删除指定的文本关键字,返回是否成功."
            注释 = "如果指定关键字不存在于本字典对象中,则插入新的关键字; 如果指定关键字已存在,则用新的键值替换旧的值." 注释 = "相当于 Python 语句 \"欲操作本对象 [文本关键字] = 欲设置键值\"."
            返回值注释 = "成功返回真,失败设置异常并返回假." @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字典(dict)对象(\"为对象_字典\"方法返回真)">
    参数 文本关键字 <类型 = 文本型 注释 = "提供欲设置其键值的文本型关键字,如果该文本关键字不存在,则将其创建.">
    参数 欲设置键值 <类型 = Py对象类 注释 = "提供欲具体设置的键值,如果为空对象,则删除该文本关键字,相当于 Python 语句 \"del 欲操作本对象 [文本关键字]\".">
    {
        @ if (@<欲操作本对象>.IsEmpty () || @<文本关键字>.IsEmpty ())  return FALSE;
        @ if (@<欲设置键值>.IsEmpty ())  return (PyDict_DelItemString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<文本关键字>)) >= 0);
        @ return (PyDict_SetItemString (@<欲操作本对象>.Get (), _VolStr2Utf8 (@<文本关键字>), @<欲设置键值>.Get ()) >= 0);
    }

    方法 字典_取键值 <公开 静态 类型 = Py对象类 注释 = "返回本字典对象中对应指定关键字的值,如果未找到或失败则返回空对象." 注释 = "与\"取成员\"方法不同的是,如果未找到指定键不会设置异常."
            @文档 = "category = \"字典对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字典(dict)对象(\"为对象_字典\"方法返回真)">
    参数 关键字 <类型 = Py对象类 注释 = "提供欲获取其键值的关键字">
    参数 默认值 <类型 = Py对象类 注释 = "  如果本参数值不为空对象,则当所指定关键字不存在时,首先将\"关键字:默认值\"" 注释 = "键值对插入本字典对象中,然后返回所置入的本默认值.如果存在,则忽略本参数直"
            注释 = "接返回已有键值." @默认值 = 空对象>
    {
        @ if (@<欲操作本对象>.IsEmpty () || @<关键字>.IsEmpty ())  return CVolPyObject ();
        @ return CVolPyObject_BorrowedRef (@<默认值>.IsEmpty () ? PyDict_GetItem (@<欲操作本对象>.Get (), @<关键字>.Get ()) : PyDict_SetDefault (@<欲操作本对象>.Get (), @<关键字>.Get (), @<默认值>.Get ()));
    }

    方法 字典_取文本键值 <公开 静态 类型 = Py对象类 注释 = "返回本字典对象中对应指定文本型关键字的值,如果未找到或失败则返回空对象." 注释 = "与\"取成员\"方法不同的是,如果未找到指定键不会设置异常."
