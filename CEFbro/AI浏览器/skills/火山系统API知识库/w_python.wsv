    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (Py_IS_TYPE (@<欲操作本对象>.Get (), CVolPython::sGetPythonTypeObject ((PYTHON_INNER_TYPE)@<欲检查类型>)) != 0));
    }

    方法 为对象_类型 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python类型(type)的对象实例."
            注释 = "注意: 所有Python类型对象均支持可调用接口协议(即\"为接口_可调用\"方法同时返回真),调用类型对象将会创建一个该类型的新对象实例." @文档 = "category = \"类型对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsTypeObject (@<是否检查子类>)
    }

    方法 类型_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回对应指定名称的类型对象" 返回值注释 = "  成功返回为指定名称的类型对象(必定是Python类型对象,\"为对象_类型\"方法返回真),"
            返回值注释 = "失败返回空对象并可能设置相应异常." @文档 = "category = \"类型对象\"" @嵌入式方法 = "">
    参数 欲获取类型名称 <类型 = 文本型 注释 = "  可以是Python内置类型名称(如\"list\",\"tuple\"等),也可以是外部Python模块中"
            注释 = "定义的类型名称(如\"types.SimpleNamespace\"),此时本方法会自动载入对应模块.">
    {
        @ CVolPyObject ((PyObject*)CVolPython::sGetSpecNamePythonTypeObject (@<欲获取类型名称>.GetText ()))
    }

    方法 取内置类型 <公开 静态 类型 = Py对象类 注释 = "返回所指定内置Python类型的类型对象,所返回对象必定是Python类型对象(\"为对象_类型\"方法返回真)." @文档 = "category = \"类型对象\""
            @嵌入式方法 = "">
    参数 欲获取类型 <类型 = Py类型 注释 = "指定所欲获取其类型对象的内置Python类型">
    {
        @ CVolPyObject_BorrowedRef ((PyObject*)CVolPython::sGetPythonTypeObject ((PYTHON_INNER_TYPE)@<欲获取类型>))
    }

    方法 类型_为内置类型 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否为指定的内置Python类型对象" @文档 = "category = \"类型对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    参数 欲检查类型 <类型 = Py类型 注释 = "指定欲检查的内置Python类型">
    {
        @ @<欲操作本对象>.Get () == (PyObject*)CVolPython::sGetPythonTypeObject ((PYTHON_INNER_TYPE)@<欲检查类型>)
    }

    方法 类型_创建对象 <公开 静态 类型 = Py对象类 注释 = "使用指定构造参数(由\"位置参数数据\"和\"关键字参数数据\"参数提供)创建并返回一个为本类型的新Python对象"
            返回值注释 = "成功返回所创建的Python对象,失败返回空对象." @文档 = "category = \"类型对象\"">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)" 编辑时信息 = "104EB4, 0, 0, 0">
    参数 位置参数数据 <类型 = Py对象类 注释 = "关于本参数及下面参数的说明,请参见\"调用\"方法." @默认值 = 空对象>
    参数 关键字参数数据 <类型 = Py对象类 注释 = "" @默认值 = 空对象>
    参数 展开元组 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (欲操作本对象.调用 (位置参数数据, 关键字参数数据, 展开元组))
    }

    方法 类型_格式创建对象 <公开 静态 类型 = Py对象类 注释 = "使用指定构造参数(由\"类型格式文本\"和\"所提供数据\"参数提供)创建并返回一个为本类型的新Python对象"
            返回值注释 = "成功返回所创建的Python对象,失败返回空对象." @文档 = "category = \"类型对象\""
            @嵌入式方法 = "req_obj_param_pointer = true\r\nreq_str_param_text_pointer = true">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)" 编辑时信息 = "104EB4, 0, 0, 0">
    参数 类型格式文本 <类型 = 文本型 注释 = "具体请参见\"格式调用\"方法的\"类型格式文本\"参数说明." 编辑时信息 = "104EB4, 0, 0, 0">
    参数 所提供数据 <注释 = "用作为\"类型格式文本\"参数中每一个替换格式项顺序提供对应的数据,其数据类型必须匹配该替换格式项的要求." 编辑时信息 = "104EB4, 0, 0, 0" @匹配类型 = 通用型 @可扩展 = "">
    {
        @ CVolPyObject::sFormatCreateNewPyObject (@<欲操作本对象>.Get (), @<类型格式文本>.GetText (), _T (@sn<pm_types>) + 2, @<所提供数据>)
    }

    方法 类型_为子类 <公开 静态 类型 = 整数 注释 = "返回本Python类型是否与指定Python类型相同或者为其子类型"
            返回值注释 = "如果\"欲测试基础类\"参数为单个Python类型对象,本Python类型与其相同或者为其子类型时返回1,否则返回0;"
            返回值注释 = "如果\"欲测试基础类\"参数为Python元组对象,本Python类型与该元组中任何一个Python类型相同或者为其子类型时返回1,否则返回0." 返回值注释 = "如果出错或所提供参数不符合要求则返回-1并设置对应异常."
            @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    参数 欲测试基础类 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)或者Python元组对象(\"为对象_元组\"方法返回真)."
            注释 = "如果为元组对象,则元组中的所有成员必须均为Python类型对象.">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲测试基础类>.IsEmpty ()) ? -1 : PyObject_IsSubclass (@<欲操作本对象>.Get (), @<欲测试基础类>.Get ()));
    }

    方法 类型_为子类2 <公开 静态 类型 = 逻辑型 注释 = "返回本Python类型是否与指定Python类型相同或者为其子类型." 注释 = "与\"类型_为子类\"方法不同的是:" 注释 = "1. 本方法返回一个逻辑值;"
            注释 = "2. 本方法只检查实际的子类型,这意味着 \"__subclasscheck__\" 不会在\"欲测试基础类\"上被调用." @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    参数 欲测试基础类 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ return ((@<欲操作本对象>.IsTypeObject (TRUE) == FALSE || @<欲测试基础类>.IsTypeObject (TRUE) == FALSE) ? FALSE : (BOOL)PyType_IsSubtype ((PyTypeObject*)@<欲操作本对象>.Get (), (PyTypeObject*)@<欲测试基础类>.Get ()));
    }

    方法 类型_为实例 <公开 静态 类型 = 整数 注释 = "如果本对象为单个Python类型对象,\"欲测试实例\"参数为该Python类型或其子类型的实例对象时返回1,否则返回0;"
            注释 = "如果本对象为Python元组对象,\"欲测试实例\"参数为该元组中任何一个Python类型或其子类型的实例对象时返回1,否则返回0." 注释 = "如果出错或所提供参数不符合要求则返回-1并设置对应异常."
            @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)或者Python元组对象(该元组中的所有成员必须均为Python类型对象).">
    参数 欲测试实例 <类型 = Py对象类 注释 = "提供欲测试其类型的实例对象">
    {
        @ return ((@<欲操作本对象>.IsEmpty () || @<欲测试实例>.IsEmpty ()) ? -1 : PyObject_IsInstance (@<欲测试实例>.Get (), @<欲操作本对象>.Get ()));
    }

    方法 类型_清除缓存 <公开 静态 类型 = 整数 注释 = "  清空内部查找缓存,返回当前版本标签." 注释 = "  在 Python 中,当类继承结构发生变化(例如动态修改了基类 __bases__),或者在某些特定的 C 扩展操作中,"
            注释 = "类型对象的内部缓存可能会失效或变得不一致. 本方法的作用是强制刷新这些缓存,确保后续的属性查找和方法" 注释 = "调用能基于最新的类结构进行." @文档 = "category = \"类型对象\"" @嵌入式方法 = "">
    {
        @ (INT)PyType_ClearCache ()
    }

    方法 类型_重载 <公开 静态 注释 = "使本类型及其所有子类型的内部查找缓存失效,本方法必须在对本类型的属性或基类进行任何手动修改之后调用." @文档 = "category = \"类型对象\"">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ if (@<欲操作本对象>.IsTypeObject (TRUE))  PyType_Modified ((PyTypeObject*)@<欲操作本对象>.Get ());
    }

    方法 类型_取成员字典 <公开 静态 类型 = Py对象类 注释 = "本方法用于获取本类型对象的命名空间字典,这个字典通常存储了该类型的属性、方法、成员变量等."
            注释 = "注意: 不要对所返回的字典进行修改操作,除非你非常清楚自己在做什么." 返回值注释 = "成功返回所获得的Python字典对象(\"为对象_字典\"方法返回真),失败返回空对象."
            @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsTypeObject (TRUE) == FALSE ? NULL : PyType_GetDict ((PyTypeObject*)@<欲操作本对象>.Get ()));
    }

    方法 类型_取名称 <公开 静态 类型 = 文本型 注释 = "返回本类型的名称,等同于获取类型的 \"__name__\" 属性." 注释 = "此处所返回的名称为本类型的定义名称,不包括限定前缀. 具体参见\"类型_取限定名称\"方法说明."
            @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsTypeObject (TRUE) == FALSE ? NULL : PyType_GetName ((PyTypeObject*)@<欲操作本对象>.Get ())).ToStr (TRUE);
    }

    方法 类型_取限定名称 <公开 静态 类型 = 文本型 注释 = "返回本类型的限定名称,等同于获取类型的 \"__qualname__\" 属性."
            注释 = "限定名称和名称的区别: 当类被嵌套在其它类内部时,\"限定名称\"会提供从外层到内层的完整\"点分路径\",而\"名称\"只提供其自身的简单名称."
            注释 = "譬如,假设 Python 类\"MyClass\"里面定义有另一个名为\"MyChildClass\"的嵌套类,则其限定名称为\"MyClass.MyChildClass\",名称为\"MyChildClass\"."
            @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsTypeObject (TRUE) == FALSE ? NULL : PyType_GetQualName ((PyTypeObject*)@<欲操作本对象>.Get ())).ToStr (TRUE);
    }

    方法 类型_取全限定名称 <公开 静态 类型 = 文本型 注释 = "返回本类型的全限定名称,等同于获取类型的此Python表达式值: f\"{欲操作本对象.__module__}.{欲操作本对象.__qualname__}\""
            注释 = "全限定名称和限定名称的区别是前面具有所处模块名称." @文档 = "category = \"类型对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python类型对象(\"为对象_类型\"方法返回真)">
    {
        @ return CVolPyObject (@<欲操作本对象>.IsTypeObject (TRUE) == FALSE ? NULL : PyType_GetFullyQualifiedName ((PyTypeObject*)@<欲操作本对象>.Get ())).ToStr (TRUE);
    }

    方法 字节集到对象 <公开 静态 类型 = Py对象类 注释 = "基于所指定的字节集创建并返回bytes类型的Python字节串对象."
            注释 = "注意: 本方法是类型转换方法,用作支持将字节集数据自动转换到本类对象,如: (Py对象类)字节集变量1, 本类对象变量1 = 字节集变量1 ." 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
            @文档 = "category = \"基本.类型转换\"" @类型转换 = 真 @禁止流程检查 = 真>
    参数 字节集数据 <类型 = 字节集类>
    {
        @ return CVolPyObject (PyBytes_FromStringAndSize ((const char*)@<字节集数据>.GetPtr (), (Py_ssize_t)@<字节集数据>.GetSize ()));
    }

    方法 对象到字节集 <公开 静态 类型 = 字节集类 注释 = "  本对象中如果存储的是Python字节串(bytes)/字节数组(bytearray)/文本(str)/空值对象(None),将其"
            注释 = "转换到字节集后返回(文本会首先转换为UTF8编码),否则返回空字节集(注意正常情况下也可能返回空字节集)."
            注释 = "  注意: 本方法是类型转换方法,用作支持将本类对象自动转换到字节集数据,如: (字节集)欲操作本对象, 字节集变量1 = 欲操作本对象 ." @文档 = "category = \"基本.类型转换\"" @类型转换 = 真
            @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类>
    {
        变量 变量1 <类型 = 字节集类>
        欲操作本对象.取字节集 (变量1)
        返回 (变量1)
    }

    方法 取字节集 <公开 静态 类型 = 逻辑型 注释 = "  本对象中如果存储的是Python字节串(bytes)/字节数组(bytearray)/文本(str)/空值对象(None),"
            注释 = "获取其字节集内容(文本会首先转换为UTF8编码)." 注释 = "  本方法比\"对象到字节集\"方法的效率更高." 返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"基本.读写\""
            @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 接收变量 <类型 = 字节集类 注释 = "所获取的字节集内容将被填入到此变量中" @需求类型 = 可写入变量>
    {
        @ @<欲操作本对象>.ToBin (@<接收变量>)
    }

    方法 为字节串 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python字节串(bytes)的对象实例." 注释 = "注意: Python字节串一旦创建后即不能再进行修改."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsBytesObject (@<是否检查子类>)
    }

    方法 字节串_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个bytes类型的空Python字节串对象" 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    {
        @ CVolPyObject (PyBytes_FromStringAndSize ("", 0))
    }

    方法 字节串 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个bytes类型的Python字节串对象并顺序填入所有提供的字节" 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 字节数值 <类型 = 整数 注释 = "提供所欲加入的所有字节值,注意所提供值必须在0到255之间." @可扩展 = "">
    {
        @ CVolPyObject::sNewBytesOrByteArray (TRUE, @sn<pm_count>, @<字节数值>)
    }

    方法 字节串_从数组创建 <公开 静态 类型 = Py对象类 注释 = "基于所指定的数组数据创建并返回bytes类型的Python字节串对象" 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 所基于的数组数据 <@匹配类型 = 通用非文本基本型数组>
    {
        @ CVolPyObject (PyBytes_FromStringAndSize (_VOL_PY_GET_ARY_VAR_ADR_AND_SIZE (@<所基于的数组数据>)))
    }

    方法 字节串_从文本创建 <公开 静态 类型 = Py对象类 注释 = "基于指定文本转换为UTF-8编码后的内容创建并返回bytes类型的Python字节串对象" 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 所基于的文本 <类型 = 文本型 注释 = "该文本将被转换为UTF-8编码">
    {
        @ CVolPyObject (PyBytes_FromString (_VolStr2Utf8 (@<所基于的文本>)))
    }

    方法 字节串_从对象创建 <公开 静态 类型 = Py对象类 注释 = "将一个实现了Python缓冲区协议(\"为接口_缓冲区\"方法返回真)的对象转换为字节串对象并返回."
            返回值注释 = "成功返回所转换创建的字节串(bytes)对象,失败返回空对象." @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 被转换的对象 <类型 = Py对象类 注释 = "提供欲转换的对象,必须实现了Python缓冲区协议(\"为接口_缓冲区\"方法返回真),如: 字节串(bytes)自身,字节数组(bytearray)等.">
    {
        @ return CVolPyObject (@<被转换的对象>.IsEmpty () ? NULL : PyBytes_FromObject (@<被转换的对象>.Get ()));
    }

    方法 字节串_取尺寸 <公开 静态 类型 = 整数 注释 = "返回本字节串(bytes)对象的尺寸" @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT)PyBytes_Size (@<欲操作本对象>.Get ()));
    }

    方法 字节串_取指针 <公开 静态 类型 = 变整数 注释 = "返回本字节串(bytes)对象中数据的指针,该指针所指向数据总是会附加一个额外的零字节,无论本字节串尺寸值是否为0."
            注释 = "注意: 由于字节串对象的只读特性,除非是刚创建本字节串对象,否则不要对所返回指针指向的内容进行任何修改." 返回值注释 = "成功返回非0指针值,失败返回0并设置对应异常."
            @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT_P)PyBytes_AsString (@<欲操作本对象>.Get ()));
    }

    方法 字节串_取文本 <公开 静态 类型 = 文本型 注释 = "假设本字节串(bytes)对象中的内容为UTF8文本数据,将其转换到Unicode文本后返回." 返回值注释 = "成功返回所获取的文本内容,失败返回空文本且设置对应异常."
            @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? CVolString () : CVolString (PyBytes_AsString (@<欲操作本对象>.Get ())));
    }

    方法 字节串_取字节集 <公开 静态 类型 = 逻辑型 注释 = "获取本字节串(bytes)对象中的数据内容" 返回值注释 = "成功返回真并将所获取的数据内容写入到\"结果存储字节集\"参数中,失败返回假且设置对应异常."
            @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)">
    参数 结果存储字节集 <类型 = 字节集类 注释 = "所获得的数据内容将存储到此字节集中" @需求类型 = 可写入变量>
    {
        @ char* pBuffer = NULL;
        @ Py_ssize_t sstLength = 0;
        @ if (@<欲操作本对象>.IsEmpty () ||  PyBytes_AsStringAndSize (@<欲操作本对象>.Get (), &pBuffer, &sstLength) < 0)  return FALSE;
        @ @<结果存储字节集>.CopyFrom (pBuffer, (INT_P)sstLength);
        @ return TRUE;
    }

    方法 字节串_添加 <公开 静态 类型 = 逻辑型 注释 = "将指定数据添加到本字节串(bytes)对象中数据的尾部" 返回值注释 = "成功返回真,失败返回假并将本对象重置为空对象,且设置对应异常."
            @文档 = "category = \"字节串对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)">
    参数 欲添加数据对象 <类型 = Py对象类 注释 = "提供欲添加其数据的对象,必须实现了Python缓冲区协议(\"为接口_缓冲区\"方法返回真),如: 字节串(bytes)自身,字节数组(bytearray)等.">
    {
        @ @<欲操作本对象>.Bytes_Concat (@<欲添加数据对象>.Get ())
    }

    方法 字节串_连接 <公开 静态 类型 = Py对象类 注释 = "本方法用作高效拼接一序列字节数据,返回拼接后的新字节串(bytes)对象,类似于 Python 中的 \"sep.join(欲连接数据对象)\"."
            注释 = "本方法的效率比\"字节串_添加\"方法高." 返回值注释 = "成功返回拼接后的新字节串(bytes)对象,失败返回空对象且设置对应异常." @文档 = "category = \"字节串对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节串(bytes)对象(\"为字节串\"方法返回真)." 注释 = "本字节串用作提供拼接时使用的分隔字节串(例如 b\",\" 或 b\"\").">
    参数 欲拼接可枚举对象 <类型 = Py对象类 注释 = "  本对象必须是一个可枚举对象(\"取枚举器\"方法返回非空对象,如元组/列表等),该对象枚举出的每一个成员必须实现"
            注释 = "了Python缓冲区协议(\"为接口_缓冲区\"方法返回真),如: 字节串(bytes)自身,字节数组(bytearray)等."
            注释 = "  本方法会将枚举出来的所有字节数据使用\"欲操作本对象\"作为分隔数据拼接起来形成最终的字节串数据.">
    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲拼接可枚举对象>.IsEmpty ()) ? NULL : PyBytes_Join (@<欲操作本对象>.Get (), @<欲拼接可枚举对象>.Get ()));
    }

    方法 为字节数组 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个记录Python字节数组(bytearray)的对象实例."
            注释 = "Python字节数组与Python字节串的不同之处在于: 字节数组创建后可以进行修改,而字节串不能." @文档 = "category = \"字节数组对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
    参数 是否检查子类 <类型 = 逻辑型 注释 = "如果本参数值为真,返回本对象类型是否为欲检查类型或其子类,否则返回是否为欲检查类型本身(不检查子类)." @默认值 = 真>
    {
        @ @<欲操作本对象>.IsByteArrayObject (@<是否检查子类>)
    }

    方法 字节数组_创建 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个bytearray类型的空Python字节数组对象" 返回值注释 = "成功返回所创建的字节数组(bytearray)对象,失败返回空对象."
            @文档 = "category = \"字节数组对象\"" @嵌入式方法 = "">
    {
        @  CVolPyObject (PyByteArray_FromObject (CVolPyObject (PyBytes_FromStringAndSize ("", 0)).Get ()))
    }

    方法 字节数组 <公开 静态 类型 = Py对象类 注释 = "创建并返回一个bytearray类型的Python字节数组对象并顺序填入所有提供的字节" 返回值注释 = "成功返回所创建的字节串(bytes)对象,失败返回空对象."
