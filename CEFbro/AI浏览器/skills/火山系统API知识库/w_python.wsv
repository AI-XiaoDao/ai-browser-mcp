    方法 为对象_集合 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python集合(set)类型的对象实例." 注释 = "集合对象可以被枚举(\"取枚举器\"方法返回非空对象)." 注释 = "集合对象特点:"
            注释 = "1. 无序唯一: 元素唯一,无序(虽然实现上有顺序,但不保证逻辑顺序);" 注释 = "2. 集合运算: 高效支持交集 (&)、并集 (|)、差集 (-)运算." @文档 = "category = \"集合对象\""
