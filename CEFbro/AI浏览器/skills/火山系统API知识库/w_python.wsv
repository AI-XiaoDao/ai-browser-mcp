    {
        @ return CVolPyObject ((@<欲操作本对象>.IsEmpty () || @<欲连接数据对象>.IsEmpty ()) ? NULL : PyByteArray_Concat (@<欲操作本对象>.Get (), @<欲连接数据对象>.Get ()));
    }

    方法 为对象_元组 <公开 静态 类型 = 逻辑型 注释 = "返回本对象是否是一个Python元组(Tuple)类型的对象实例."
            注释 = "元组对象实现了Python序列接口协议(\"为接口_序列\"方法返回真)并且可以被枚举(\"取枚举器\"方法返回非空对象)."
            注释 = "注意: Python元组对象一旦创建,不可再进行动态修改. 其中可以包括不同类型的Python对象." @文档 = "category = \"元组对象\"" @嵌入式方法 = "">
    参数 欲操作本对象 <类型 = Py对象类>
