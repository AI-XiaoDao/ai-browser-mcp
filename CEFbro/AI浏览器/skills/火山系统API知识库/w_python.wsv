    {
        @ CU8String u8str (@<所基于的文本>.GetText ());
        @ return CVolPyObject (PyByteArray_FromStringAndSize ((const char*)u8str.GetText (), (Py_ssize_t)u8str.GetLength ()));
    }

    方法 字节数组_从对象创建 <公开 静态 类型 = Py对象类 注释 = "将一个实现了Python缓冲区协议(\"为接口_缓冲区\"方法返回真)的对象转换为字节数组对象并返回."
            返回值注释 = "成功返回所转换创建的字节数组(bytearray)对象,失败返回空对象." @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 被转换的对象 <类型 = Py对象类 注释 = "提供欲转换的对象,必须实现了Python缓冲区协议(\"为接口_缓冲区\"方法返回真),如: 字节串(bytes),字节数组(bytearray)自身等.">
    {
        @ return CVolPyObject (@<被转换的对象>.IsEmpty () ? NULL : PyByteArray_FromObject (@<被转换的对象>.Get ()));
    }

    方法 字节数组_取尺寸 <公开 静态 类型 = 整数 注释 = "返回本字节数组(bytearray)对象的尺寸" @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节数组(bytearray)对象(\"为字节数组\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT)PyByteArray_Size (@<欲操作本对象>.Get ()));
    }

    方法 字节数组_取指针 <公开 静态 类型 = 变整数 注释 = "返回本字节数组(bytearray)对象中数据的指针,该指针所指向数据总是会附加一个额外的零字节,无论本字节数组尺寸值是否为0."
            返回值注释 = "成功返回非0指针值,失败返回0并设置对应异常." @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节数组(bytearray)对象(\"为字节数组\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? 0 : (INT_P)PyByteArray_AsString (@<欲操作本对象>.Get ()));
    }

    方法 字节数组_置尺寸 <公开 静态 类型 = 逻辑型 注释 = "调整本字节数组(bytearray)对象的尺寸." 注释 = "注意: 如果增加已有尺寸,则新增字节数组空间中的内容为随机字节数据."
            返回值注释 = "成功返回真,失败返回假并设置相关异常." @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节数组(bytearray)对象(\"为字节数组\"方法返回真)">
    参数 欲调整到的尺寸 <类型 = 整数 注释 = "指定欲将本字节数组(bytearray)对象的内部缓冲区调整到的尺寸">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? FALSE : (PyByteArray_Resize (@<欲操作本对象>.Get (), (Py_ssize_t)@<欲调整到的尺寸>) >= 0));
    }

    方法 字节数组_取文本 <公开 静态 类型 = 文本型 注释 = "假设本字节数组(bytearray)对象中的内容为UTF8文本数据,将其转换到Unicode文本后返回."
            返回值注释 = "成功返回所获取的文本内容,失败返回空文本且设置对应异常." @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节数组(bytearray)对象(\"为字节数组\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsEmpty () ? CVolString () : CVolString (PyByteArray_AsString (@<欲操作本对象>.Get ())));
    }

    方法 字节数组_取字节集 <公开 静态 类型 = 逻辑型 注释 = "获取本字节数组(bytearray)对象中的数据内容" 返回值注释 = "成功返回真并将所获取的数据内容写入到\"结果存储字节集\"参数中,失败返回假且设置对应异常."
            @文档 = "category = \"字节数组对象\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python字节数组(bytearray)对象(\"为字节数组\"方法返回真)">
    参数 结果存储字节集 <类型 = 字节集类 注释 = "所获得的数据内容将存储到此字节集中" @需求类型 = 可写入变量>
    {
        @ if (@<欲操作本对象>.IsEmpty ())  return FALSE;
        @ const char* pBuffer = PyByteArray_AsString (@<欲操作本对象>.Get ());
        @ const Py_ssize_t sstLength = PyByteArray_Size (@<欲操作本对象>.Get ());
        @ if ((sstLength > 0 && pBuffer == NULL) || sstLength < 0)  return FALSE;
        @ @<结果存储字节集>.CopyFrom (pBuffer, (INT_P)sstLength);
        @ return TRUE;
    }

    方法 字节数组_清零 <公开 静态 类型 = 逻辑型 注释 = "将本字节数组(bytearray)中的全部内容清零" 返回值注释 = "成功返回真,失败返回假." @文档 = "category = \"字节数组对象\""
            @嵌入式方法 = "">
