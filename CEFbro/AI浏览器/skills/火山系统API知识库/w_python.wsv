    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE ? 0 : (INT)PyDateTime_DATE_GET_SECOND (@<欲操作本对象>.Get ()));
    }

    方法 日期时间_取微秒 <公开 静态 类型 = 整数 注释 = "从本日期时间对象中取出并返回\"微秒\"属性值,从0到999999." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE ? 0 : (INT)PyDateTime_DATE_GET_MICROSECOND (@<欲操作本对象>.Get ()));
    }

    方法 日期时间_取夏令时 <公开 静态 类型 = 整数 注释 = "从本日期时间对象中取出并返回\"夏令时\"属性值,为0或1." @文档 = "category = \"日期时间\"" @禁止流程检查 = 真>
    参数 欲操作本对象 <类型 = Py对象类 注释 = "本对象必须是Python日期时间对象(\"为对象_日期时间\"方法返回真)">
    {
        @ return (@<欲操作本对象>.IsDateTimeObject (TRUE) == FALSE ? 0 : (INT)PyDateTime_DATE_GET_FOLD (@<欲操作本对象>.Get ()));
