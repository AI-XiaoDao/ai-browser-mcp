    方法 生成文本二维码 <公开 静态 类型 = 增强位图类 注释 = "以指定文本内容生成二维码图像." 返回值注释 = "生成失败返回空白图像." @禁止流程检查 = 真>
    参数 内容 <类型 = 文本型 注释 = "二维码所包含的文本内容.">
    参数 等级 <类型 = 整数 注释 = "提供所欲使用的生成等级,1-40之间,值越大像素点越多,能表示的内容越多." @默认值 = 10>
    参数 容错 <类型 = 整数 注释 = "提供所生成二维码的容错等级,0-3之间." @默认值 = 3>
    参数 底色 <类型 = 整数 注释 = "提供所生成二维码图像的底图颜色." @默认值 = 颜色类.白色>
    参数 码颜色 <类型 = 整数 注释 = "提供所生成二维码图像的二维码像素点颜色." @默认值 = 颜色类.黑色>
    参数 放大倍数 <类型 = 整数 注释 = "提供所生成二维码图像的放大倍数" @默认值 = 1>
    {
        @ @dt<增强位图类> bmp;
        @ CU8String inData(@<内容>.GetText());
        @ QRcode * qrCode = QRcode_encodeString(inData.GetText(), @<等级>, (QRecLevel)@<容错>, QR_MODE_8, 1);
        @ QRcode2Bmp(qrCode, bmp, @<底色>, @<码颜色>, @<放大倍数>);
        @ QRcode_free(qrCode);
        @ return bmp;
    }

    方法 生成数据二维码 <公开 静态 类型 = 增强位图类 注释 = "以指定数据内容生成二维码图像." 返回值注释 = "生成失败返回空白图像." @禁止流程检查 = 真>
    参数 数据 <类型 = 字节集类 注释 = "二维码所包含的数据.">
    参数 等级 <类型 = 整数 注释 = "提供所欲使用的生成等级,1-40之间,值越大像素点越多,能表示的数据越多." @默认值 = 10>
    参数 容错 <类型 = 整数 注释 = "提供所生成二维码的容错等级,0-3之间." @默认值 = 3>
    参数 底色 <类型 = 整数 注释 = "提供所生成二维码图像的底图颜色." @默认值 = 颜色类.白色>
    参数 码颜色 <类型 = 整数 注释 = "提供所生成二维码图像的二维码像素点颜色." @默认值 = 颜色类.黑色>
    参数 放大倍数 <类型 = 整数 注释 = "提供所生成二维码图像的放大倍数" @默认值 = 1>
    {
        @ @dt<增强位图类> bmp;
        @ QRcode * qrCode = QRcode_encodeData((INT)@<数据>.GetSize(), (const unsigned char *)@<数据>.GetPtr(), @<等级>, (QRecLevel)@<容错>);
        @ QRcode2Bmp(qrCode, bmp, @<底色>, @<码颜色>, @<放大倍数>);
        @ QRcode_free(qrCode);
        @ return bmp;
    }

    方法 取版本信息 <公开 静态 类型 = 文本型 注释 = "获取该库的版本信息." @嵌入式方法 = "">
    {
        @ @an<CVolString> (QRcode_APIVersionString())
    }
}
