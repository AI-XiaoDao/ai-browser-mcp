<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.数据处理

类 二维码生成类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "封装自libqrencode 4.1.1版,提供对二维码生成的支持." 编辑时信息 = "11D543, 0, 0, 0"
        @视窗.需求VS版本.static = "16-" @视窗.使用静态运行时库.static = 真 "" "// @视窗.外部头文件" = "lib\\include\\qrencode.h"
        "// @视窗.外部库.static" = "lib\\$(p)\\qrencode-static-$(d).lib" "// @视窗.外部库.non_static" = "lib\\$(p)\\qrencode.lib"
        "// @视窗.附属文件.non_static" = "lib\\$(p)\\qrencode.dll" "" @视窗.外部头文件 = "lib2\\include\\qrencode.h"
        @视窗.外部库.non_static = "lib2\\$(p)\\qrencode.lib" @视窗.附属文件.non_static = "lib2\\$(p)\\qrencode.dll"
        "@视窗.外部库.static-debug" = "lib2\\$(p)\\qrencode.lib" "@视窗.附属文件.static-debug" = "lib2\\$(p)\\qrencode.dll"
        "@视窗.外部库.static-release" = "lib2\\$(p)\\qrencode-release.lib">
{

