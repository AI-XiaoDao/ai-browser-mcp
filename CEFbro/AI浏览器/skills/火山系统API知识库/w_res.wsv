类 GDI资源类 <公开 基础类 = 参考对象类 注释 = "用作记录一个GDI对象的句柄,支持在不使用后自动对其进行释放." @文档 = "category = \"资源.处理类\"">
{
    方法 为空 <公开 类型 = 逻辑型 注释 = "返回本对象内是否未记录有一个非0句柄值" @嵌入式方法 = "">
    {
        @ @sn<this>.GetGDIHandle () == NULL
    }

    方法 取句柄值 <公开 类型 = 变整数 注释 = "返回对象中所保存的GDI对象句柄值,不存在返回0." @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.GetGDIHandle ()
    }

    # --
    #
    # @begin
    # <> <include>
    #
    # <> <global>
    # // 用作指定GDI对象句柄的自动删除方式
