    #     GOADT_NOT = 0,  // 不自动删除
    #     GOADT_DELETE_OBJECT,  // 使用DeleteObject自动删除
    #     GOADT_DESTORY_ICON,  // 使用DestoryIcon自动删除
    #     GOADT_DESTORY_CURSOR,  // 使用DestoryCursor自动删除
    #     GOADT_DESTROY_IMAGELIST,  // 使用ImageList_Destroy自动删除
    # }
    # GDI_OBJ_AUTO_DELETE_TYPE;
    # <> </global>
    #
    # inline_ @sn<current_class> (const HGDIOBJ hGDIObject, const GDI_OBJ_AUTO_DELETE_TYPE enAutoDeleteType) : @sn<current_class> ()
    # {
    #     if (hGDIObject != NULL)
    #         TakeOverNewRefObject (new CGDIObjectHandle (hGDIObject, enAutoDeleteType));
    # }
    #
    # // 返回所设置的GDI句柄,不存在返回NULL.
    # inline_ HGDIOBJ GetGDIHandle ()
    # {
    #     ASSER_P_IS_NULL_OR_INSTANCE_OF (GetRefObject (), CGDIObjectHandle);  // 必定符合此条件
    #     return ((CGDIObjectHandle*)GetRefObject ())->SafeGetGDIHandle ();
    # }
