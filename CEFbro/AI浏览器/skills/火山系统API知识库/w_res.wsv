类 字体对象类 <公开 基础类 = GDI资源类 注释 = "用作记录一个字体句柄(HFONT)及对应的相关操作" @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{

    # @ @m<DECLARE_DERIVED_GDI_CLASS>

    方法 置字体句柄值 <公开 类型 = 逻辑型 注释 = "将一个所指定字体句柄(HFONT)置入本对象中." @禁止流程检查 = 真>
    参数 所欲设置的句柄值 <类型 = 变整数 注释 = "提供所欲置入的字体句柄值(HFONT),调用方必须确保该句柄值的正确性." 注释 = "注意: 该句柄的释放工作将交由本对象负责,调用方不再需要管理.">
    参数 是否自动释放 <类型 = 逻辑型 注释 = "指定是否需要自动释放所置入的句柄值">
    {
        @ return (TakeOverNewGDIObject ((HGDIOBJ)@<所欲设置的句柄值>, (@<是否自动释放> ? GOADT_DELETE_OBJECT : GOADT_NOT)) != NULL);
    }

    方法 磅字体尺寸到像素 <公开 静态 类型 = 整数 注释 = "将以磅为单位的字体尺寸转换为以屏幕像素为单位的尺寸" 返回值注释 = "返回转换尺寸结果,以屏幕像素为单位." @嵌入式方法 = "">
    参数 所欲转换的字体尺寸 <类型 = 整数 注释 = "本尺寸以磅为单位">
    {
        @ (INT)FontPtSize2Dp (@<所欲转换的字体尺寸>)
    }

    方法 像素字体尺寸到磅 <公开 静态 类型 = 整数 注释 = "将以屏幕像素为单位的字体尺寸转换为以磅为单位的尺寸" 返回值注释 = "返回转换尺寸结果,以磅为单位." @嵌入式方法 = "">
    参数 所欲转换的字体尺寸 <类型 = 整数 注释 = "本尺寸以屏幕像素为单位">
    {
        @ (INT)FontDpSize2Pt (@<所欲转换的字体尺寸>)
    }

    方法 从描述文本创建字体 <公开 静态 类型 = 字体对象类 注释 = "从一个指定格式的字体描述文本创建字体" 返回值注释 = "成功所返回的句柄对象不为空(\"为空\"方法返回假),失败为空(\"为空\"方法返回真)."
            @禁止流程检查 = 真>
    参数 字体描述文本 <类型 = 文本型 注释 = "  本参数的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅,旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\".">
    {
        @ LOGFONT infFont;
        @ GetFontDescTextInfo (@<字体描述文本>, &infFont);
        @ return @dt<字体对象类> (CreateFontIndirect (&infFont), GOADT_DELETE_OBJECT);
    }

    方法 取字体描述文本 <公开 类型 = 文本型 注释 = "  返回当前字体的描述文本." 注释 = "  描述文本的格式为: \"字体名, 字体尺寸, 是否为粗体, 是否为斜体, 是否有下划线, 是否有删除线, 旋转角度\","
            注释 = "其中\"是否\"字段,用1代表真,0代表假,可以被省略.字体尺寸单位为磅, 旋转角度单位为1/10度." 注释 = "  例子: \"宋体, 10\", \"宋体, 10, 0, 1, 1, 0, 100\"."
            @禁止流程检查 = 真>
    {
        @ HFONT hFont = (HFONT)GetGDIHandle ();
        @ if (hFont == NULL)
        @     hFont = g_objVolApp.GetDefaultFont ();
        @ LOGFONT infFont;
        @ VERIFY_NOT_EQUAL (::GetObject (hFont, sizeof (LOGFONT), &infFont), 0);  // 必定成功
        @ CVolString strFontDesc;
        @ GetFontDescText (infFont, strFontDesc);
        @ return strFontDesc;
    }

    方法 创建字体 <公开 静态 类型 = 字体对象类 注释 = "从指定参数创建并返回一个字体对象" 返回值注释 = "成功所返回的句柄对象不为空(\"为空\"方法返回假),失败为空(\"为空\"方法返回真)." @禁止流程检查 = 真>
    参数 字体名称 <类型 = 文本型 注释 = "提供所欲创建字体的名称">
    参数 字体尺寸 <类型 = 整数 注释 = "提供所欲创建字体的尺寸,单位为磅.">
    参数 是否粗体 <类型 = 逻辑型 @默认值 = 假>
    参数 是否斜体 <类型 = 逻辑型 @默认值 = 假>
    参数 是否有下划线 <类型 = 逻辑型 @默认值 = 假>
    参数 是否有删除线 <类型 = 逻辑型 @默认值 = 假>
    参数 旋转角度 <类型 = 整数 注释 = "提供字体的旋转角度,单位为十分之一度." @默认值 = 0>
    {
        @ // 使用默认字体的信息进行初始化
        @ LOGFONT infFont;
        @ GetDefaultFontInfo (&infFont);

        @ if (@<字体名称>.IsEmpty () == FALSE)
        @     _tcsncpy_z (infFont.lfFaceName, @<字体名称>.GetText (), NUM_ELEMENTS_OF (infFont.lfFaceName) - 1);

        @ const INT_P npFontSize = FontPtSize2Dp (@<字体尺寸>);
        @ if (npFontSize > 0)
        @     infFont.lfHeight = (LONG)npFontSize;

        @ INT_P npAngle = (@<旋转角度> % 3600);
        @ if (npAngle < 0)  npAngle += 3600;
        @ infFont.lfOrientation = infFont.lfEscapement = (LONG)npAngle;
        @ infFont.lfWeight = (@<是否粗体> ? FW_BOLD : FW_NORMAL);
        @ infFont.lfItalic = (BYTE)@<是否斜体>;
        @ infFont.lfUnderline = (BYTE)@<是否有下划线>;
        @ infFont.lfStrikeOut = (BYTE)@<是否有删除线>;

        @ return @dt<字体对象类> (CreateFontIndirect (&infFont), GOADT_DELETE_OBJECT);
    }

    方法 取默认GUI字体 <公开 静态 类型 = 字体对象类 注释 = "返回操作系统所使用的默认GUI字体" 返回值注释 = "所返回字体对象必定有效" @嵌入式方法 = "">
    {
        @ @dt<字体对象类> (g_objVolApp.GetDefaultFont (), GOADT_NOT)
    }

    方法 取字体句柄 <公开 类型 = 变整数 注释 = "返回本对象中所保存的字体句柄,如果为NULL,则返回操作系统所使用的默认GUI字体句柄." @禁止流程检查 = 真>
    {
        @ const HFONT hFont = (HFONT)GetGDIHandle ();
        @ return (INT_P)(hFont == NULL ? g_objVolApp.GetDefaultFont () : hFont);
    }

    方法 取文本尺寸 <公开 类型 = 尺寸类 注释 = "返回使用本字体在屏幕上绘制指定文本时所需要的尺寸,单位像素." @嵌入式方法 = "">
    参数 所欲检查文本 <类型 = 文本型>
    {
        @ @dt<尺寸类> (&GetTextDrawSize ((HFONT)@sn<this>.GetGDIHandle (), @<所欲检查文本>.GetText ()))
    }
}

#
