}

类 鼠标指针对象类 <公开 基础类 = GDI资源类 注释 = "用作记录一个鼠标指针句柄(HCURSOR)及对应的相关操作" @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{

    # @ @m<DECLARE_DERIVED_GDI_CLASS>

    方法 置鼠标指针句柄值 <公开 类型 = 逻辑型 注释 = "将一个所指定鼠标指针句柄(HCURSOR)置入本对象中." 返回值注释 = "返回所置入的句柄值是否不为NULL" @禁止流程检查 = 真>
    参数 所欲设置的句柄值 <类型 = 变整数 注释 = "提供所欲置入的鼠标指针句柄值(HCURSOR),调用方必须确保该句柄值的正确性." 注释 = "注意: 该句柄的释放工作将交由本对象负责,调用方不再需要管理.">
    参数 是否自动释放 <类型 = 逻辑型 注释 = "指定是否需要自动释放所置入的句柄值">
    {
        @ return (TakeOverNewGDIObject ((HGDIOBJ)@<所欲设置的句柄值>, (@<是否自动释放> ? GOADT_DESTORY_CURSOR : GOADT_NOT)) != NULL);
    }

    方法 载入鼠标指针资源 <公开 静态 类型 = 鼠标指针对象类 注释 = "载入所指定的鼠标指针资源,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的鼠标指针 <类型 = 鼠标指针资源>
    {
        @ @dt<鼠标指针对象类> ((HCURSOR)g_objVolApp.LoadResImage (VRIT_CURSOR, @<所欲载入的鼠标指针>), GOADT_NOT)
    }

    方法 载入鼠标指针文件 <公开 静态 类型 = 鼠标指针对象类 注释 = "载入所指定的鼠标指针文件,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的鼠标指针文件 <类型 = 文本型>
    {
        @ @dt<鼠标指针对象类> ((HCURSOR)g_objVolApp.LoadResImageFile (VRIT_CURSOR, @<所欲载入的鼠标指针文件>.GetText ()), GOADT_DESTORY_CURSOR)
    }

    方法 取标准鼠标指针 <公开 静态 类型 = 鼠标指针对象类 注释 = "获取所指定的标准鼠标指针资源,返回所载入的句柄对象." 返回值注释 = "成功所返回的句柄对象不为空(\"为空\"方法返回假),失败为空(\"为空\"方法返回真)."
            @嵌入式方法 = "">
    参数 所欲载入的鼠标指针 <类型 = 标准鼠标指针类型>
    {
        @ @dt<鼠标指针对象类> (::LoadCursor (NULL, MAKEINTRESOURCE (@<所欲载入的鼠标指针>)), GOADT_NOT)
    }
}

