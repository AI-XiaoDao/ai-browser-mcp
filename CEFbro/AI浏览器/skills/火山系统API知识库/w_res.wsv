    常量 箭头及沙漏型 <公开 值 = @"@(INT_P)IDC_APPSTARTING">
    常量 禁止符型 <公开 值 = @"@(INT_P)IDC_NO">
    常量 四向箭头型 <公开 值 = @"@(INT_P)IDC_SIZEALL">
    常量 北东箭头型 <公开 值 = @"@(INT_P)IDC_SIZENESW">
    常量 北南箭头型 <公开 值 = @"@(INT_P)IDC_SIZENS">
    常量 北西箭头型 <公开 值 = @"@(INT_P)IDC_SIZENWSE">
    常量 西东箭头型 <公开 值 = @"@(INT_P)IDC_SIZEWE">
