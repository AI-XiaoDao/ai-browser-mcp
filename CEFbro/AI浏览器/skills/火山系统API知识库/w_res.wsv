    #             case GOADT_DESTORY_ICON:
    #                 VERIFY (::DestroyIcon ((HICON)m_hGDIObject));
    #                 break;
    #             case GOADT_DESTORY_CURSOR:
    #                 VERIFY (::DestroyCursor ((HCURSOR)m_hGDIObject));
    #                 break;
    #             case GOADT_DESTROY_IMAGELIST:
    #                 VERIFY (::ImageList_Destroy ((HIMAGELIST)m_hGDIObject));
    #                 break;
    #             case GOADT_DELETE_OBJECT:
    #                 VERIFY (::DeleteObject (m_hGDIObject));
    #                 break;
    #             }
    #         }
    #     }
    #
    #     inline_ HGDIOBJ SafeGetGDIHandle () const
    #     {
    #         return (this == NULL ? NULL : m_hGDIObject);
    #     }
    #
    #     inline_ HGDIOBJ DetachGDIHandle ()
    #     {
    #         const HGDIOBJ hGDIObject = m_hGDIObject;
