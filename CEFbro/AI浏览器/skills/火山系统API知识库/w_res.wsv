<火山程序 类型 = "通常" 版本 = 1 />

包 火山.基本 <注释 = "提供视窗资源相关类" @文档 = "category = \"资源\"">

# 资源定义类 ===

类 字符串资源 <公开 注释 = "用作记录一个字符串资源" @输出名 = "@CVolWinStrRes" @常量类 = 文本到ID>

类 视窗文件资源 <公开 注释 = "  所有基于文件数据内容资源的基础类,所有以本类为基础类的资源将直接把" 注释 = "相关文件的全部数据以RCDATA类型(除非继承类中使用\"@视窗.资源类型\"属性"
        注释 = "进行了修改)放入到编译后的目的程序资源段中." 注释 = "  如果初始值提供一个空文件名,将代表为空文件资源.空资源一般用作取消先" 注释 = "前所已经设置资源的作用效果." 编辑时信息 = "101545, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 文件\r\nexplain = \"将所指定文件以资源的形式插入程序\"\r\nicon = \"@5\""
        @输出名 = "@CVolWinFileRes" @视窗.资源类型 = "RCDATA" @常量类 = 文本到ID @值细节类型 = 文件名>

类 图标资源 <公开 基础类 = 视窗文件资源 注释 = "  用作代表一个ico图标资源,本类资源将把所指定的ico图标数据以" 注释 = "ICON类型放入到编译后的目的程序资源段中."
        注释 = "  如果初始值提供一个空文件名,将代表为空图标资源." 编辑时信息 = "1A3FE5, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 图标\r\nexplain = \"将所指定图标文件以资源的形式插入程序\"\r\nicon = \"@11\"" @视窗.资源类型 = "ICON"
        @常量类 = 文本到ID @值细节类型 = 文件名 @附加文本 = "图标文件(*.ico)|*.ico|">

类 位图资源 <公开 基础类 = 视窗文件资源 注释 = "  用作代表一个通用位图资源,本类资源将把所指定的位图数据以" 注释 = "RCDATA类型放入到编译后的目的程序资源段中."
        注释 = "  如果初始值提供一个空文件名,将代表为空位图资源." 编辑时信息 = "EAA9C, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 图片\r\nexplain = \"将所指定图片文件以资源的形式插入程序\"\r\nicon = \"@9\"" @视窗.资源类型 = "RCDATA"
        @常量类 = 文本到ID @值细节类型 = 文件名
        @附加文本 = "所有图片文件|*.gif;*.bmp;*.emf;*.wmf;*.jpg;*.jpeg;*.png;*.tif;*.ico|GIF文件(*.gif)|*.gif|BMP文件(*.bmp)|*.bmp|EMF文件(*.emf)|*.emf|WMF文件(*.wmf)|*.wmf|JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|PNG文件(*.png)|*.png|TIFF文件(*.tif)|*.tif|ICO文件(*.ico)|*.ico|">

类 BMP位图资源 <公开 基础类 = 视窗文件资源 注释 = "  用作代表一个BITMAP位图资源,本类资源将把所指定的位图数据以" 注释 = "BITMAP类型放入到编译后的目的程序资源段中."
        注释 = "  如果初始值提供一个空文件名,将代表为空BITMAP位图资源." 编辑时信息 = "16153F, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = BMP位图\r\nexplain = \"将所指定BMP位图文件以资源的形式插入程序\"\r\nicon = \"@9\""
        @视窗.资源类型 = "BITMAP" @常量类 = 文本到ID @值细节类型 = 文件名 @附加文本 = "BMP图片文件(*.bmp)|*.bmp|">

类 图片组资源 <公开 基础类 = 位图资源 注释 = "  用作代表一个基于位图的图片组资源,本类资源将把所指定的位图数据以RCDATA" 注释 = "类型放入到编译后的目的程序资源段中."
        注释 = "  用来作为图片组的位图内容格式具有以下要求:" 注释 = "  1. 必须为图片组中所有单个图片的横向排列组合,即图片组中单个图片的高度" 注释 = "等于整个图片组位图的高度,图片组中所有单个图片的总宽度等于整个图片组位图"
        注释 = "的宽度;" 注释 = "  2. 图片组中单个图片的宽度等于其高度,如果不为偶数值,则就近向上取偶" 注释 = "(如:高度为15,则宽度为16);"
        注释 = "  3. 位图中的透明部分用洋红色(红绿蓝分量值分别为: 255, 0, 255)填充标记." 编辑时信息 = "D1548, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 图片组\r\nexplain = \"将所指定图片组文件以资源的形式插入程序\"\r\nicon = \"@4\"" @常量类 = 文本到ID
        @值细节类型 = 文件名
        @附加文本 = "所有图片文件|*.gif;*.bmp;*.emf;*.wmf;*.jpg;*.jpeg;*.png;*.tif;*.ico|GIF文件(*.gif)|*.gif|BMP文件(*.bmp)|*.bmp|EMF文件(*.emf)|*.emf|WMF文件(*.wmf)|*.wmf|JPG文件(*.jpg;*.jpeg)|*.jpg;*.jpeg|PNG文件(*.png)|*.png|TIFF文件(*.tif)|*.tif|ICO文件(*.ico)|*.ico|">

类 鼠标指针资源 <公开 基础类 = 视窗文件资源 注释 = "  用作代表一个鼠标指针图像资源,本类资源将把所指定的鼠标指针图片" 注释 = "数据以CURSOR类型放入到编译后的目的程序资源段中."
        注释 = "  如果初始值提供一个空文件名,将代表为空鼠标指针资源." 编辑时信息 = "17EA92, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 鼠标指针\r\nexplain = \"将所指定鼠标指针文件以资源的形式插入程序\"\r\nicon = \"@9\""
        @视窗.资源类型 = "CURSOR" @常量类 = 文本到ID @值细节类型 = 文件名 @附加文本 = "鼠标指针文件(*.cur)|*.cur|">

类 WAV资源 <公开 基础类 = 视窗文件资源 注释 = "用作代表一个wav声音文件资源." 注释 = "如果初始值提供一个空文件名,将代表为空wav资源." 注释 = "" 编辑时信息 = "14EA95, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = WAV声音\r\nexplain = \"将所指定WAV音频文件以资源的形式插入程序\"\r\nicon = \"@3\""
        @视窗.资源类型 = "WAVE" @常量类 = 文本到ID @值细节类型 = 文件名 @附加文本 = "WAV声音文件(*.wav)|*.wav|">

类 声音资源 <公开 基础类 = 视窗文件资源 注释 = "用作代表一个wav或mp3声音文件资源." 注释 = "如果初始值提供一个空文件名,将代表为空wav或mp3资源." 编辑时信息 = "1E7FE1, 0, 0, 0"
        @可插入程序类 = "type = \"const, var\"\r\nprefix = 声音\r\nexplain = \"将所指定WAV或MP3音频文件以资源的形式插入程序\"\r\nicon = \"@3\""
        @视窗.资源类型 = "RCDATA" @常量类 = 文本到ID @值细节类型 = 文件名
        @附加文本 = "所有声音文件(*.wav;*.mp3)|*.wav;*.mp3|WAV声音文件(*.wav)|*.wav|MP3声音文件(*.mp3)|*.mp3|">

类 空资源 <公开 注释 = "  提供以上各种资源所对应的空资源常量,空资源一般用作取消" 注释 = "先前所已经设置资源的作用效果.">
{
    常量 空字符串 <公开 类型 = 字符串资源 值 = "">
    常量 空图标 <公开 类型 = 图标资源 值 = "">
    常量 空位图 <公开 类型 = 位图资源 值 = "">
    常量 空BMP位图 <公开 类型 = BMP位图资源 值 = "">
    常量 空鼠标指针 <公开 类型 = 鼠标指针资源 值 = "">
    常量 空文件 <公开 类型 = 视窗文件资源 值 = "">
    常量 空WAV声音 <公开 类型 = WAV资源 值 = "">
    常量 空声音 <公开 类型 = 声音资源 值 = "">
}

# 资源处理类 ===

类 资源操作类 <公开 @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{
    方法 载入字符串资源 <公开 静态 类型 = 文本型 注释 = "载入并返回所指定的字符串资源,载入失败将返回空文本." @嵌入式方法 = "">
    参数 所欲载入的字符串 <类型 = 字符串资源>
    {
        @ g_objVolApp.LoadResString ((UINT_P)@<所欲载入的字符串>, CVolString ())
    }

    方法 载入字符串资源2 <公开 静态 注释 = "载入并返回所指定的字符串资源" @嵌入式方法 = "">
    参数 所欲载入的字符串 <类型 = 字符串资源>
    参数 结果存储参数 <类型 = 文本型 注释 = "所载入的字符串资源将保存进此参数中,载入失败将置入空文本.">
    {
        @ g_objVolApp.LoadResString ((UINT_P)@<所欲载入的字符串>, @<结果存储参数>)
    }
}

