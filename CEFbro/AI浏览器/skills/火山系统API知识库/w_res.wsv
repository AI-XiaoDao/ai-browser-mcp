    # {
    #     return (this == NULL ? NULL : GetGDIHandle ());
    # }
    #
    # inline_ HGDIOBJ DetachGDIHandle ()
    # {
    #     ASSER_P_IS_NULL_OR_INSTANCE_OF (GetRefObject (), CGDIObjectHandle);  // 必定符合此条件
    #     return ((CGDIObjectHandle*)GetRefObject ())->DetachGDIHandle ();
    # }
    #
    # // 接管所指定GDI句柄的释放工作,其不再由调用方负责,返回所提供的句柄值.
    # inline_ HGDIOBJ TakeOverNewGDIObject (const HGDIOBJ hGDIObject, const GDI_OBJ_AUTO_DELETE_TYPE enAutoDeleteType)
    # {
    #     TakeOverNewRefObject (new CGDIObjectHandle (hGDIObject, enAutoDeleteType));
    #     return hGDIObject;
