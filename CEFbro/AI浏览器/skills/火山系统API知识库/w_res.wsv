类 图片组对象类 <公开 基础类 = GDI资源类 注释 = "用作记录一个图片组句柄(HIMAGELIST)及对应的相关操作" @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{

    # @ @m<DECLARE_DERIVED_GDI_CLASS>

    方法 置图片组句柄值 <公开 类型 = 逻辑型 注释 = "将一个所指定图片组句柄(HIMAGELIST)置入本对象中." 返回值注释 = "返回所置入的句柄值是否不为NULL" @禁止流程检查 = 真>
    参数 所欲设置的句柄值 <类型 = 变整数 注释 = "提供所欲置入的图片组句柄值(HIMAGELIST),调用方必须确保该句柄值的正确性." 注释 = "注意: 该句柄的释放工作将交由本对象负责,调用方不再需要管理.">
    参数 是否自动释放 <类型 = 逻辑型 注释 = "指定是否需要自动释放所置入的句柄值">
    {
        @ return (TakeOverNewGDIObject ((HIMAGELIST)@<所欲设置的句柄值>, (@<是否自动释放> ? GOADT_DESTROY_IMAGELIST : GOADT_NOT)) != NULL);
    }

    方法 载入图片组资源 <公开 静态 类型 = 图片组对象类 注释 = "载入所指定的图片组资源,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的图片组 <类型 = 图片组资源>
    {
        @ @dt<图片组对象类> ((HIMAGELIST)g_objVolApp.LoadResImage (VRIT_IMAGE_LIST, @<所欲载入的图片组>), GOADT_DESTROY_IMAGELIST)
    }

    方法 载入图片组文件 <公开 静态 类型 = 图片组对象类 注释 = "载入所指定的图片组文件,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的图片组文件 <类型 = 文本型 注释 = "  提供用作保存图片组的图片文件名,该图片文件的格式必须符合" 注释 = "\"图片组资源\"类中所说明的要求.">
    {
        @ @dt<图片组对象类> ((HIMAGELIST)g_objVolApp.LoadResImageFile (VRIT_IMAGE_LIST, @<所欲载入的图片组文件>.GetText ()), GOADT_DESTROY_IMAGELIST)
    }

    方法 载入图片组数据 <公开 静态 类型 = 图片组对象类 注释 = "载入所指定的图片组数据,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的图片组文件数据 <类型 = 字节集类>
    {
        @ @dt<图片组对象类> (CreateImageListFromBitmapData (@<所欲载入的图片组文件数据>), GOADT_DESTROY_IMAGELIST)
    }
}

