# // 用作声明GDI资源类的继承类
# @ @def_macro DECLARE_DERIVED_GDI_CLASS  \
# @     <include>  \
# @     inline_ @sn<current_class> (const HGDIOBJ hGDIObject, const GDI_OBJ_AUTO_DELETE_TYPE enAutoDeleteType) : @dt<GDI资源类> (hGDIObject, enAutoDeleteType)  { }  \
# @     </include>
#
# ===

类 图标对象类 <公开 基础类 = GDI资源类 注释 = "用作记录一个图标句柄(HICON)及对应的相关操作" @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{

    # @ @m<DECLARE_DERIVED_GDI_CLASS>

    方法 置图标句柄值 <公开 类型 = 逻辑型 注释 = "将一个所指定图标句柄(HICON)置入本对象中." 返回值注释 = "返回所置入的句柄值是否不为NULL" @禁止流程检查 = 真>
    参数 所欲设置的句柄值 <类型 = 变整数 注释 = "提供所欲置入的图标句柄值(HICON),调用方必须确保该句柄值的正确性." 注释 = "注意: 该句柄的释放工作将交由本对象负责,调用方不再需要管理.">
    参数 是否自动释放 <类型 = 逻辑型 注释 = "指定是否需要自动释放所置入的句柄值">
    {
        @ return (TakeOverNewGDIObject ((HGDIOBJ)@<所欲设置的句柄值>, (@<是否自动释放> ? GOADT_DESTORY_ICON : GOADT_NOT)) != NULL);
    }

    方法 载入图标资源 <公开 静态 类型 = 图标对象类 注释 = "载入所指定的图标资源,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的图标 <类型 = 图标资源>
    {
        @ @dt<图标对象类> ((HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<所欲载入的图标>), GOADT_NOT)
    }

    方法 载入图标文件 <公开 静态 类型 = 图标对象类 注释 = "载入所指定的图标文件,返回所载入的句柄对象." 返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源"
            返回值注释 = "为空资源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的图标文件 <类型 = 文本型>
    {
        @ @dt<图标对象类> ((HICON)g_objVolApp.LoadResImageFile (VRIT_ICON, @<所欲载入的图标文件>.GetText ()), GOADT_DESTORY_ICON)
    }
}

# ---

类 位图对象类 <公开 基础类 = GDI资源类 注释 = "用作记录一个bmp位图句柄(HBITMAP)及对应的相关操作" @文档 = "category = \"资源.处理类\"" @全局类 = 真>
{

    # @ @m<DECLARE_DERIVED_GDI_CLASS>

    方法 载入位图资源 <公开 静态 类型 = 位图对象类 注释 = "  载入所指定的位图资源(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico)," 注释 = "返回所载入的句柄对象."
            返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源为空资" 返回值注释 = "源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的位图 <类型 = 位图资源>
    {
        @ @dt<位图对象类> ((HBITMAP)g_objVolApp.LoadResImage (VRIT_BITMAP, @<所欲载入的位图>), GOADT_DELETE_OBJECT)
    }

    方法 载入位图文件 <公开 静态 类型 = 位图对象类 注释 = "  载入所指定的位图文件(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico)," 注释 = "返回所载入的句柄对象."
            返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源为空资" 返回值注释 = "源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的位图文件 <类型 = 文本型>
    {
        @ @dt<位图对象类> ((HBITMAP)g_objVolApp.LoadResImageFile (VRIT_BITMAP, @<所欲载入的位图文件>.GetText ()), GOADT_DELETE_OBJECT)
    }

    方法 载入位图数据 <公开 静态 类型 = 位图对象类 注释 = "  载入所指定的位图数据(所支持格式: gif/bmp/emf/wmf/jpg//png/tif/ico)," 注释 = "返回所载入的句柄对象."
            返回值注释 = "  成功所返回的句柄对象不为空(\"为空\"方法返回假),失败或所提供资源为空资" 返回值注释 = "源则为空(\"为空\"方法返回真)." @嵌入式方法 = "">
    参数 所欲载入的位图数据 <类型 = 字节集类>
    {
        @ @dt<位图对象类> (g_objVolApp.LoadBitmapFromMemory (@<所欲载入的位图数据>), GOADT_DELETE_OBJECT)
    }

    方法 置位图句柄值 <公开 类型 = 逻辑型 注释 = "将一个所指定位图句柄(HBITMAP)置入本对象中." 返回值注释 = "返回所置入的句柄值是否不为NULL" @禁止流程检查 = 真>
    参数 所欲设置的句柄值 <类型 = 变整数 注释 = "提供所欲置入的位图句柄值(HBITMAP),调用方必须确保该句柄值的正确性." 注释 = "注意: 该句柄的释放工作将交由本对象负责,调用方不再需要管理.">
    参数 是否自动释放 <类型 = 逻辑型 注释 = "指定是否需要自动释放所置入的句柄值">
    {
        @ return (TakeOverNewGDIObject ((HGDIOBJ)@<所欲设置的句柄值>, (@<是否自动释放> ? GOADT_DELETE_OBJECT : GOADT_NOT)) != NULL);
    }

    方法 取图片尺寸 <公开 类型 = 尺寸类 注释 = "返回当前位图的尺寸,单位像素." 注释 = "如果当前尚未设置有效位图,则返回零尺寸.">
    {
        变量 图片尺寸 <类型 = 尺寸类>
        @ const HBITMAP hBitmap = (HBITMAP)GetGDIHandle ();
        @ if (hBitmap != NULL)
        @ {
        @     BITMAP infBitmap;
        @     if (::GetObject (hBitmap, sizeof (BITMAP), &infBitmap))
        @     {
        @         @<图片尺寸.宽度> = infBitmap.bmWidth;
        @         @<图片尺寸.高度> = infBitmap.bmHeight;
        @     }
        @ }
        返回 (图片尺寸)
    }

    方法 取图片数据 <公开 类型 = 逻辑型 注释 = "获取当前位图所对应的BMP图片文件数据" 返回值注释 = "成功返回真,失败返回假." @嵌入式方法 = "">
    参数 数据存放字节集 <类型 = 字节集类 注释 = "用作存放所获得的BMP图片文件数据">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "当前图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如果"
            注释 = "大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "当前图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如果"
            注释 = "大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ (BOOL)WriteBitmap ((HBITMAP)@sn<this>.GetGDIHandle (), @<数据存放字节集>, @<输出宽度>, @<输出高度>)
    }

    方法 写图片文件 <公开 类型 = 逻辑型 注释 = "获取当前位图所对应的BMP图片文件数据,并将其写出到所指定名称的文件." 返回值注释 = "成功返回真,失败返回假." @禁止流程检查 = 真>
    参数 所欲写到的文件名 <类型 = 文本型 注释 = "提供所欲写到的BMP文件名">
    参数 输出宽度 <类型 = 整数 注释 = "  指定图片的输出宽度. 如果小于0,参数值指定的是最终图片输出宽度相对于" 注释 = "当前图片宽度的百分比(最小为10%); 如果等于0,则按图片原宽度输出; 如果"
            注释 = "大于0,指定输出图片的绝对宽度." @默认值 = 0>
    参数 输出高度 <类型 = 整数 注释 = "  指定图片的输出高度. 如果小于0,参数值指定的是最终图片输出高度相对于" 注释 = "当前图片高度的百分比(最小为10%); 如果等于0,则按图片原高度输出; 如果"
            注释 = "大于0,指定输出图片的绝对高度." @默认值 = 0>
    {
        @ CVolMem mem;
        @ if (WriteBitmap ((HBITMAP)GetGDIHandle (), mem, @<输出宽度>, @<输出高度>) == FALSE)
        @     return FALSE;
        @ return (BOOL)mem.WriteIntoFile (@<所欲写到的文件名>);
    }
}

