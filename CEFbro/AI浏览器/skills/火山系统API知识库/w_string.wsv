    参数 欲寻找的文本 <类型 = 文本型 注释 = "提供所欲查找的文本内容">
    参数 起始搜寻位置 <类型 = 整数 注释 = "提供起始查找的索引位置,必须大于等于0且小于等于文本长度." @默认值 = 0>
    参数 是否不区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否不区分英文字母的大小写" @默认值 = 假>
    {
        @ (INT)@<被搜寻的文本>.SearchText (@<欲寻找的文本>.GetText (), @<起始搜寻位置>, @<是否不区分大小写>, FALSE)
    }

    方法 倒找文本 <公开 静态 类型 = 整数 注释 = "逆向查找当前文本中所指定文本的所处索引位置,未找到则返回-1." @嵌入式方法 = "">
    参数 被搜寻的文本 <类型 = 文本型>
    参数 欲寻找的文本 <类型 = 文本型 注释 = "提供所欲查找的文本内容">
    参数 起始搜寻位置 <类型 = 整数 注释 = "提供起始查找的索引位置,小于等于文本长度,如果小于0表示从文本尾部开始查找." @默认值 = -1>
    参数 是否不区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否不区分英文字母的大小写" @默认值 = 假>
    {
        @ (INT)@<被搜寻的文本>.SearchText (@<欲寻找的文本>.GetText (), @<起始搜寻位置>, @<是否不区分大小写>, TRUE)
    }

    方法 是否以字符开头 <公开 静态 类型 = 逻辑型 注释 = "返回当前文本是否以所指定字符开头" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 所欲检查的字符 <类型 = 字符 注释 = "提供用来检查是否以其开头的字符">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ (BOOL)@<所欲操作的文本>.LeadOf (@<所欲检查的字符>, @<是否区分大小写>)
    }

    方法 是否以文本开头 <公开 静态 类型 = 逻辑型 注释 = "返回当前文本是否以所指定文本开头" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 所欲检查的文本 <类型 = 文本型 注释 = "提供用来检查是否以其开头的文本">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ (BOOL)@<所欲操作的文本>.LeadOf (@<所欲检查的文本>, @<是否区分大小写>)
    }

    方法 是否以字符结束 <公开 静态 类型 = 逻辑型 注释 = "返回当前文本是否以所指定字符结束" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 所欲检查的字符 <类型 = 字符 注释 = "提供用来检查是否以其结束的字符">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ (BOOL)@<所欲操作的文本>.EndOf (@<所欲检查的字符>, @<是否区分大小写>)
    }

    方法 是否以文本结束 <公开 静态 类型 = 逻辑型 注释 = "返回当前文本是否以所指定文本结束" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 所欲检查的文本 <类型 = 文本型 注释 = "提供用来检查是否以其结束的文本">
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ (BOOL)@<所欲操作的文本>.EndOf (@<所欲检查的文本>, @<是否区分大小写>)
    }

    方法 取尾字符 <公开 静态 类型 = 字符 注释 = "返回当前文本的尾部字符,如果当前文本为空,则返回零字符." @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    {
        @ @<所欲操作的文本>.GetLastChar ()
    }

    方法 分割左右文本 <公开 静态 类型 = 逻辑型 注释 = "把文本在所指定字符首次出现的位置处分割成左右两个部分" 返回值注释 = "分割成功返回真,未找到所指定的分割字符返回假." @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割字符 <类型 = 字符 注释 = "提供分割所使用的字符,文本将在该字符首次出现的位置处分割成左右两个部分.">
    参数 左结果文本 <类型 = 文本型 注释 = "如果不为空对象且方法返回真,则将所分割出来的左边文本内容存放入此参数结果变量中." @默认值 = 空对象>
    参数 右结果文本 <类型 = 文本型 注释 = "如果不为空对象且方法返回真,则将所分割出来的右边文本内容存放入此参数结果变量中." @默认值 = 空对象>
    参数 是否删除首尾空 <类型 = 逻辑型 注释 = "是否自动删除左右分割结果文本的首尾空白" @默认值 = 真>
    {
        @ (BOOL)SplitString2 (@<所欲操作的文本>.GetText (), @<分割字符>, @<是否删除首尾空>, @<左结果文本>, @<右结果文本>)
    }

    方法 分割左右子文本 <公开 静态 类型 = 逻辑型 注释 = "把文本在所指定子文本首次出现的位置处分割成左右两个部分" 返回值注释 = "分割成功返回真,未找到所指定的分割子文本返回假." @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割用子文本 <类型 = 文本型 注释 = "提供分割所使用的子文本,文本将在该子文本首次出现的位置处分割成左右两个部分.">
    参数 左结果文本 <类型 = 文本型 注释 = "如果不为空对象且方法返回真,则将所分割出来的左边文本内容存放入此参数结果变量中." @默认值 = 空对象>
    参数 右结果文本 <类型 = 文本型 注释 = "如果不为空对象且方法返回真,则将所分割出来的右边文本内容存放入此参数结果变量中." @默认值 = 空对象>
    参数 是否删除首尾空 <类型 = 逻辑型 注释 = "是否自动删除左右分割结果文本的首尾空白" @默认值 = 真>
    {
        @ (BOOL)SplitSubString2 (@<所欲操作的文本>.GetText (), @<分割用子文本>.GetText (), @<是否删除首尾空>, @<左结果文本>, @<右结果文本>)
    }

    方法 分割文本 <公开 静态 类型 = 整数 注释 = "  将文本基于所指定的字符集合进行分割,然后将分割结果存放到所指定的数组中," 注释 = "返回存放到所指定数组中的成员数目(即所分割出来的结果文本数目)." @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割字符集合 <类型 = 文本型 注释 = "  提供进行分割时所基于的所有字符,其中的每个字符均在分割时被使用(即遇到其" 注释 = "中任何一个字符时均认为发现了一个分割点)."
            注释 = "  譬如: \",;\\n\", 即指定了基于逗号/分号/换行符三个字符进行分割,遇到了这三" 注释 = "个字符中的任何一个,均进行一次分割.">
    参数 结果存放数组 <类型 = 文本数组类 注释 = "用作提供存放所有分割结果文本用的数组,其中的原有内容将被覆盖.">
    参数 是否删除首尾空 <类型 = 逻辑型 注释 = "是否自动删除所有分割结果文本的首尾空白" @默认值 = 真>
    参数 是否忽略空白结果 <类型 = 逻辑型 注释 = "是否自动去除所有为空或全部为空白字符的分割结果文本" @默认值 = 真>
    {
        @ (INT)SplitStringsSupportManyDelimitChar (@<所欲操作的文本>.GetText (), @<结果存放数组>.data (), @<分割字符集合>.GetText (), @<是否删除首尾空>, @<是否忽略空白结果>)
    }

    方法 分割子文本 <公开 静态 类型 = 整数 注释 = "  将文本基于所指定的子文本进行分割,然后将分割结果存放到所指定的数组中," 注释 = "返回存放到所指定数组中的成员数目(即所分割出来的结果文本数目)." @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割用子文本 <类型 = 文本型 注释 = "提供进行分割时所基于的子文本">
    参数 结果存放数组 <类型 = 文本数组类 注释 = "用作提供存放所有分割结果文本用的数组,其中的原有内容将被覆盖.">
    参数 是否删除首尾空 <类型 = 逻辑型 注释 = "是否自动删除所有分割结果文本的首尾空白" @默认值 = 真>
    参数 是否忽略空白结果 <类型 = 逻辑型 注释 = "是否自动去除所有为空或全部为空白字符的分割结果文本" @默认值 = 真>
    {
        @ (INT)SplitSubStrings (@<所欲操作的文本>.GetText (), @<结果存放数组>.data (), @<分割用子文本>.GetText (), @<是否删除首尾空>, @<是否忽略空白结果>)
    }

    方法 分割整数文本 <公开 静态 类型 = 整数 注释 = "  将文本基于所指定的字符进行分割,然后将分割结果转换到整数后存放到所指定的数组中," 注释 = "返回存放到所指定数组中的成员数目(即所分割出来的结果整数数目)."
            @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割字符 <类型 = 字符 注释 = "提供进行分割时所基于的字符,在被分割文本中的每一个该字符均被认为是一个分割点.">
    参数 结果存放数组 <类型 = 整数数组类 注释 = "用作提供存放所有分割结果整数用的数组,其中的原有内容将被覆盖.">
    {
        @ (INT)SplitIntegers (@<所欲操作的文本>.GetText (), @<结果存放数组>.data (), @<分割字符>)
    }

    方法 分割小数文本 <公开 静态 类型 = 整数 注释 = "  将文本基于所指定的字符进行分割,然后将分割结果转换到小数后存放到所指定的数组中," 注释 = "返回存放到所指定数组中的成员数目(即所分割出来的结果小数数目)."
            @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 分割字符 <类型 = 字符 注释 = "提供进行分割时所基于的字符,在被分割文本中的每一个该字符均被认为是一个分割点.">
    参数 结果存放数组 <类型 = 小数数组类 注释 = "用作提供存放所有分割结果小数用的数组,其中的原有内容将被覆盖.">
    {
        @ (INT)SplitDoubles (@<所欲操作的文本>.GetText (), @<结果存放数组>.data (), @<分割字符>)
    }

    方法 近似等于 <公开 静态 类型 = 逻辑型 注释 = "当比较文本在被比较文本的首部被包容时返回真,否则返回假." @禁止流程检查 = 真>
    参数 被比较文本 <类型 = 文本型>
    参数 比较文本 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 @默认值 = 真>
    {
        @ const INT_P npLen = @<比较文本>.GetLength ();
        @ if (npLen > @<被比较文本>.GetLength ())
        @     return FALSE;
        @ return ((@<是否区分大小写> ? _tcsncmp (@<比较文本>.GetText (), @<被比较文本>.GetText (), (INT)npLen) : _tcsnicmp (@<比较文本>.GetText (), @<被比较文本>.GetText (), (INT)npLen)) == 0);
    }

    # --- 下面定义了文本数据类型的一系列类型转换方法,用作支持文本和其它数据类型的混合运算. 为了避免给用户编程造成困扰,这些方法默认为注释屏蔽状态,需要使用时取消其注释状态即可.

    方法 "// 文本2字节" <公开 静态 类型 = 字节 @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 ((字节)文本到整数 (文本内容))
    }

    方法 "// 文本2短整数" <公开 静态 类型 = 短整数 注释 = "将所指定文本转换到短整数并返回,支持\"0x\"开头的十六进制整数文本." @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到短整数 (文本内容))
    }

    方法 "// 文本2字符" <公开 静态 类型 = 字符 注释 = "返回文本的首字符,如无则返回零字符." @类型转换 = 真 @禁止流程检查 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        @ return @<文本内容>.SafeGetCharAt (0);
    }

    方法 "// 文本2整数" <公开 静态 类型 = 整数 注释 = "将所指定文本转换到整数并返回,支持\"0x\"开头的十六进制整数文本." @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到整数 (文本内容))
    }

    方法 "// 文本2长整数" <公开 静态 类型 = 长整数 注释 = "将所指定文本转换到长整数并返回,支持\"0x\"开头的十六进制长整数文本." @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到长整数 (文本内容))
    }

    方法 "// 文本2单精度小数" <公开 静态 类型 = 单精度小数 @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到单精度小数 (文本内容))
    }

    方法 "// 文本2小数" <公开 静态 类型 = 小数 @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到小数 (文本内容))
    }

    方法 "// 文本2逻辑值" <公开 静态 类型 = 逻辑型 @类型转换 = 真>
    参数 文本内容 <类型 = 文本型>
    {
        返回 (文本到逻辑值 (文本内容))
    }

    方法 "// 字节2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 字节>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 短整数2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 短整数>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 字符2文本" <公开 静态 类型 = 文本型 注释 = "返回文本的首字符,如无则返回零字符." @类型转换 = 真 @禁止流程检查 = 真>
    参数 待转换值 <类型 = 字符>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 整数2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 整数>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 长整数2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 长整数>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 单精度小数2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 单精度小数>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 小数2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 小数>
    {
        返回 (到文本 (待转换值))
    }

    方法 "// 逻辑值2文本" <公开 静态 类型 = 文本型 @类型转换 = 真>
    参数 待转换值 <类型 = 逻辑型>
    {
        返回 (到文本 (待转换值))
    }
}
