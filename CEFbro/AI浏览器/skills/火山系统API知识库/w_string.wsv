    }

    方法 文本替换 <公开 静态 注释 = "将指定文本的某一部分用其它的文本替换" @嵌入式方法 = "">
    参数 被替换文本 <类型 = 文本型 注释 = "提供欲被替换的文本">
    参数 起始替换索引位置 <类型 = 整数 注释 = "指定替换的起始索引位置,必须大于等于0且小于等于被替换文本长度.">
    参数 替换长度 <类型 = 整数 注释 = "  指定所欲替换的文本部分的长度,必须大于等于0且加上\"起始替换索引位置\"" 注释 = "后小于等于被替换文本长度.">
    参数 用作替换的文本 <类型 = 文本型>
    {
        @ @<被替换文本>.MReplaceText (@<起始替换索引位置>, @<替换长度>, @<用作替换的文本>.GetText ())
    }

    方法 子文本替换 <公开 静态 注释 = "将所指定文本中的指定内容子文本替换为另一个文本" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 欲被替换的子文本 <类型 = 文本型 注释 = "提供欲被替换的子文本">
    参数 用作替换的文本 <类型 = 文本型 注释 = "提供用作替换所指定子文本的文本">
    参数 起始替换索引位置 <类型 = 整数 注释 = "  指定在欲被替换文本中的起始搜寻索引位置,必须" 注释 = "大于等于0且小于欲被替换文本的长度." @默认值 = 0>
    参数 替换次数 <类型 = 整数 注释 = "指定所欲进行替换的次数,如果小于0则全部替换." @默认值 = -1>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "指定比较时是否区分英文字母的大小写" @默认值 = 真>
    {
        @ @<所欲操作的文本>.ReplaceSubText (@<欲被替换的子文本>, @<用作替换的文本>, @<起始替换索引位置>, @<替换次数>, !@<是否区分大小写>)
    }

    方法 替换所有子文本 <公开 静态 类型 = 逻辑型 注释 = "将所指定文本中的所有指定内容子文本均替换为另一个文本" 返回值注释 = "返回是否产生了实际替换" @嵌入式方法 = "">
    参数 所欲操作的文本 <类型 = 文本型>
    参数 欲被替换的子文本 <类型 = 文本型 注释 = "提供欲被替换的子文本">
    参数 用作替换的文本 <类型 = 文本型 注释 = "提供用作替换所指定子文本的文本">
    {
        @ (BOOL)@<所欲操作的文本>.Replace (@<欲被替换的子文本>, @<用作替换的文本>)
    }

    方法 替换字符 <公开 静态 类型 = 逻辑型 注释 = "将文本中所有指定字符均替换为另一个" 返回值注释 = "返回是否产生了实际替换" @嵌入式方法 = "">
