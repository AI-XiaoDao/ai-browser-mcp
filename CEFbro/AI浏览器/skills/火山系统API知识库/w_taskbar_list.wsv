类 任务栏列表4 <公开 基础类 = 任务栏列表3 注释 = "最低受支持的客户端 Windows 7 [仅限桌面应用]" 注释 = "最低受支持的服务器 Windows Server 2008 R2 [仅限桌面应用]" 折叠 折叠2>
{

    # @ @m<任务栏列表.DECLARE_ITASKBARLIST_HRINIT>(IID_ITaskbarList4, this->m_pTaskbarList)

    方法 置选项卡属性 <公开 类型 = 逻辑型 注释 = "允许选项卡指定主应用程序框架窗口或选项卡窗口是否应用作缩略图或在某些情况下的预览功能."
            注释 = "如果应用程序无法为选项卡生成自己的缩略图,也无法为实时显示其活动选项卡内容(如动画),则应用程序可能希望使用其关联父窗口的缩略图或预览表示形式." 返回值注释 = "如果此方法成功,则返回真.否则,它将返回假." 折叠 折叠2
            @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数 注释 = "要设置属性的选项卡窗口的句柄.此句柄必须已通过[注册选项卡]选项卡注册..">
    参数 属性标志 <类型 = 选项卡属性 注释 = "[选项卡属性]的一个或多个成员,这些成员指定显示的缩略图和选项卡缩略图的预览图像源.">
    {
        @ if(this->m_pTaskbarList == nullptr || @<窗口句柄> == 0) return FALSE;
        @ return SUCCEEDED(((ITaskbarList4*)this->m_pTaskbarList)->SetTabProperties((HWND)@<窗口句柄>, (STPFLAG)@<属性标志>));
    }
}

类 缩略图按钮 <公开 基础类 = 结构基础类 折叠>
{

    # @ @m<DECLARE_STRUCT_CLASS>(THUMBBUTTON)

    方法 掩码 <公开 属性读 类型 = 缩略图按钮掩码 注释 = "[缩略图按钮掩码]值的组合,指定此结构的成员包含有效数据;其他成员将被忽略,但\"标识符\"除外,这始终是必需的." 折叠 @嵌入式方法 = "">
    {
        @ (@dt<缩略图按钮掩码>)@sn<this>.pdata()->dwMask
    }

    方法 掩码 <公开 属性写 注释 = "[缩略图按钮掩码]值的组合,指定此结构的成员包含有效数据;其他成员将被忽略,但\"标识符\"除外,这始终是必需的." 折叠>
    参数 掩码标志 <类型 = 缩略图按钮掩码>
    {
        @ this->pdata()->dwMask = (THUMBBUTTONMASK)@<掩码标志>;
    }

    方法 标识符 <公开 属性读 类型 = 整数 注释 = "按钮的应用程序定义标识符,在工具栏中是唯一的." 折叠 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.pdata()->iId
    }

    方法 标识符 <公开 属性写 注释 = "按钮的应用程序定义标识符,在工具栏中是唯一的." 折叠>
    参数 标识符 <类型 = 整数>
    {
        @ this->pdata()->iId = @<标识符>;
    }

    方法 位图索引 <公开 属性读 类型 = 整数 注释 = "按钮的应用程序定义标识符,在工具栏中是唯一的." 折叠 @嵌入式方法 = "">
    {
        @ (@dt<整数>)@sn<this>.pdata()->iBitmap
    }

    方法 位图索引 <公开 属性写 注释 = "按钮的应用程序定义标识符,在工具栏中是唯一的." 折叠>
    参数 图标索引 <类型 = 整数>
    {
        @ this->pdata()->iBitmap = @<图标索引>;
    }

    方法 图标资源 <公开 属性读 类型 = 图标资源 注释 = "用作按钮图像的图标的句柄." 折叠 @嵌入式方法 = "">
    {
        @ (@dt<图标资源>)@sn<this>.pdata()->hIcon
    }

    方法 图标资源 <公开 属性写 注释 = "用作按钮图像的图标的句柄." 折叠>
    参数 图标资源 <类型 = 图标资源>
    {
        @ this->pdata()->hIcon = (HICON)g_objVolApp.LoadResImage(VRIT_ICON, @<图标资源>);
    }

    方法 提示文本 <公开 属性读 类型 = 文本型 注释 = "包含按钮工具提示文本的宽字符数组,当鼠标指针悬停在按钮上时显示." 折叠 @嵌入式方法 = "">
    {
        @ @dt<文本型>(@sn<this>.pdata()->szTip)
    }

    方法 提示文本 <公开 属性写 注释 = "包含按钮工具提示文本的宽字符数组,当鼠标指针悬停在按钮上时显示." 折叠>
    参数 提示文本 <类型 = 文本型>
    {
        @ _tcsncpy_z(this->pdata()->szTip, @<提示文本>.GetText(), NUM_ELEMENTS_OF(this->pdata()->szTip) - 1);
    }

    方法 选项标志 <公开 属性读 类型 = 缩略图按钮标志 注释 = "[缩略图按钮标志]值的组合,用于控制按钮的特定状态和行为." 折叠 @嵌入式方法 = "">
    {
        @ (@dt<缩略图按钮标志>)@sn<this>.pdata()->dwFlags
    }

    方法 选项标志 <公开 属性写 注释 = "[缩略图按钮标志]值的组合,用于控制按钮的特定状态和行为." 折叠>
    参数 标志 <类型 = 缩略图按钮标志>
    {
        @ this->pdata()->dwFlags = (THUMBBUTTONFLAGS)@<标志>;
    }
}

