<火山程序 类型 = "通常" 版本 = 1 />

包 火山.TTS语音引擎 <@视窗.外部头文件 = "lib\\TTSConstant.h">

类 TTS事件 <公开 @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 开始 <公开 值 = @SVEStartInputStream 注释 = "表示当引擎开始说流时发生的开始流事件">
    常量 结束 <公开 值 = @SVEEndInputStream 注释 = "表示结束流事件,当引擎在说话时遇到流的结束时发生.">
    常量 音量变化 <公开 值 = @SVEVoiceChange 注释 = "表示音量转换事件,当引擎在说话时遇到设置音量大小时发生.">
    常量 书签 <公开 值 = @SVEBookmark 注释 = "表示书签事件,当引擎在说话时遇到书签时发生,如:\"<BOOKMARK mark=\'123\' />\".">
    常量 文字边界 <公开 值 = @SVEWordBoundary 注释 = "表示文字边界事件,当引擎在说话时完成一个单词时发生.">
    常量 音素 <公开 值 = @SVEPhoneme 注释 = "表示音素事件,音素是指一种语言中能区别两个词的最小语音单位,当引擎在说话时完成一个音素时发生的事件.">
    常量 句子边界 <公开 值 = @SVESentenceBoundary 注释 = "表示句子边界事件,当引擎在说话时完成一个句子时发生.">
    常量 音素变化 <公开 值 = @SVEViseme 注释 = "表示可视音素事件,当引擎在说话时发生.">
    常量 音频变化 <公开 值 = @SVEAudioLevel 注释 = "表示音频级别事件,当引擎在说话时完成音频级别更改时发生.">
    常量 专用引擎 <公开 值 = @SVEPrivate 注释 = "表示一个专用的引擎事件">
    常量 所有 <公开 值 = @SVEAllEvents 注释 = "表示所有语音事件">
}

类 TTS文件创建模式 <公开 @常量类 = 文本型 @文档 = "category = \"辅助类\"">
{
    常量 只读 <公开 值 = @SSFMOpenForRead>
    常量 读写 <公开 值 = @SSFMOpenReadWrite>
    常量 创建 <公开 值 = @SSFMCreate>
    常量 写入 <公开 值 = @SSFMCreateForWrite>
}

类 TTS状态信息 <公开 注释 = "提供获取TTS语音运行状态信息的常量" @常量类 = 文本型 @文档 = "category = \"辅助类\"">
{
    常量 总长度 <公开 值 = "InputSentenceLength" 注释 = "朗读文本的总长度">
    常量 运行状态 <公开 值 = "RunningState" 注释 = "当结果为:0表示\"暂停朗读\";1时表示\"朗读完毕或未开始\";2表示\"正在朗读中\".">
    常量 引擎位置 <公开 值 = "InputSentencePosition" 注释 = "引擎当前使用的句子开始前一个字符的位置.仅当\"运行状态\"为\"正在朗读中\"时才有效.">
    常量 长度 <公开 值 = "InputWordLength" 注释 = "当前朗读到的文本长度.仅当\"运行状态\"为\"正在朗读中\"时才有效.">
    常量 位置 <公开 值 = "InputWordPosition" 注释 = "当前朗读到的位置.仅当\"运行状态\"为\"正在朗读中\"时才有效.">
    常量 输入流数量 <公开 值 = "CurrentStreamNumber" 注释 = "文本输入流的数量,仅当\"运行状态\"为\"正在朗读中\"时才有效.">
    常量 当前语音ID <公开 值 = "VisemeId" 注释 = "正在朗读的当前语音的ID">
    常量 音素ID <公开 值 = "PhonemeId" 注释 = "当前音素ID">
    常量 最后标签 <公开 值 = "LastBookmark" 注释 = "引擎遇到的最后一个书签的文本值">
    常量 最后标签ID <公开 值 = "LastBookmarkId" 注释 = "引擎遇到的最后一个书签的ID,以非数字字符开头的书签,ID始终为零.">
    常量 最后频流数量 <公开 值 = "LastStreamNumberQueued" 注释 = "由语音排队的最后一个音频流的数量">
    常量 最后执行结果 <公开 值 = "LastHResult" 注释 = "语音对象执行的最后一次\"语音或语音流\"操作中检索返回值或内部状态代码.">
}

类 TTS音频采样 <公开 注释 = "保存为WAV时的音频采样" @常量类 = 整数 @文档 = "category = \"辅助类\"">
{
    常量 默认频率 <公开 值 = @SAFTDefault 注释 = "SAFTDefault">
    常量 不指定格式 <公开 值 = @SAFTNoAssignedFormat 注释 = "SAFTNoAssignedFormat">
    常量 文本格式 <公开 值 = @SAFTText 注释 = "SAFTText">
    常量 非标准格式 <公开 值 = @SAFTNonStandardFormat 注释 = "SAFTNonStandardFormat">
    常量 扩展音频格式 <公开 值 = @SAFTExtendedAudioFormat 注释 = "SAFTExtendedAudioFormat">
    常量 单声道8位8千赫 <公开 值 = @SAFT8kHz8BitMono 注释 = "SAFT8kHz8BitMono">
    常量 立体声8位8千赫 <公开 值 = @SAFT8kHz8BitStereo 注释 = "SAFT8kHz8BitStereo">
    常量 单声道16位8千赫 <公开 值 = @SAFT8kHz16BitMono 注释 = "SAFT8kHz16BitMono">
    常量 立体声16位8千赫 <公开 值 = @SAFT8kHz16BitStereo 注释 = "SAFT8kHz16BitStereo">
