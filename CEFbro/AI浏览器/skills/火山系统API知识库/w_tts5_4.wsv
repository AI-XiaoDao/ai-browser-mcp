    常量 立体声8位11千赫 <公开 值 = @SAFT11kHz8BitStereo 注释 = "SAFT11kHz8BitStereo">
    常量 单声道16位11千赫 <公开 值 = @SAFT11kHz16BitMono 注释 = "SAFT11kHz16BitMono">
    常量 立体声16位11千赫 <公开 值 = @SAFT11kHz16BitStereo 注释 = "SAFT11kHz16BitStereo">
    常量 单声道8位12千赫 <公开 值 = @SAFT12kHz8BitMono 注释 = "SAFT12kHz8BitMono">
    常量 立体声8位12千赫 <公开 值 = @SAFT12kHz8BitStereo 注释 = "SAFT12kHz8BitStereo">
    常量 单声道16位12千赫 <公开 值 = @SAFT12kHz16BitMono 注释 = "SAFT12kHz16BitMono">
    常量 立体声16位12千赫 <公开 值 = @SAFT12kHz16BitStereo 注释 = "SAFT12kHz16BitStereo">
    常量 单声道8位16千赫 <公开 值 = @SAFT16kHz8BitMono 注释 = "SAFT16kHz8BitMono">
    常量 立体声8位16千赫 <公开 值 = @SAFT16kHz8BitStereo 注释 = "SAFT16kHz8BitStereo">
    常量 单声道16位16千赫 <公开 值 = @SAFT16kHz16BitMono 注释 = "SAFT16kHz16BitMono">
    常量 立体声16位16千赫 <公开 值 = @SAFT16kHz16BitStereo 注释 = "SAFT16kHz16BitStereo">
    常量 单声道8位22千赫 <公开 值 = @SAFT22kHz8BitMono 注释 = "SAFT22kHz8BitMono">
    常量 立体声8位22千赫 <公开 值 = @SAFT22kHz8BitStereo 注释 = "SAFT22kHz8BitStereo">
    常量 单声道16位22千赫 <公开 值 = @SAFT22kHz16BitMono 注释 = "SAFT22kHz16BitMono">
    常量 立体声16位22千赫 <公开 值 = @SAFT22kHz16BitStereo 注释 = "SAFT22kHz16BitStereo">
    常量 单声道8位24千赫 <公开 值 = @SAFT24kHz8BitMono 注释 = "SAFT24kHz8BitMono">
    常量 立体声8位24千赫 <公开 值 = @SAFT24kHz8BitStereo 注释 = "SAFT24kHz8BitStereo">
    常量 单声道16位24千赫 <公开 值 = @SAFT24kHz16BitMono 注释 = "SAFT24kHz16BitMono">
    常量 立体声16位24千赫 <公开 值 = @SAFT24kHz16BitStereo 注释 = "SAFT24kHz16BitStereo">
    常量 单声道8位32千赫 <公开 值 = @SAFT32kHz8BitMono 注释 = "SAFT32kHz8BitMono">
    常量 立体声8位32千赫 <公开 值 = @SAFT32kHz8BitStereo 注释 = "SAFT32kHz8BitStereo">
