<火山程序 类型 = "通常" 版本 = 1 />

包 火山.视窗.文件解压

类 RAR文件解压类 <公开 注释 = "★ 本类由\"飞翔的企鹅\"封装." 注释 = "基于Unrar实现对RAR压缩格式文件的访问处理" 编辑时信息 = "FFFF0, 0, 0, 0"
        @视窗.外部库.win32 = "libs\\win32\\UnRAR.lib" @视窗.附属文件.win32 = "libs\\win32\\UnRAR.dll" @视窗.外部库.x64 = "libs\\x64\\UnRAR64.lib"
        @视窗.附属文件.x64 = "libs\\x64\\UnRAR64.dll" @视窗.外部头文件 = "libs\\vol_unrar.h">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CUnrarWrapper)
    #
