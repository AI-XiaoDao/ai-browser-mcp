    # @         case UCM_CHANGEVOLUMEW:
    # @         {
    # @             if (P2 == RAR_VOL_ASK)
    # @             {
    # @                 CVolString next;
    # @                 INT ret = pThis->@n<RAR文件解压类.提供下一个分卷>(next);
    # @                 _tcscpy((wchar_t*)P1, (wchar_t*)next.GetText());
    # @                 return ret;
    # @             }
    # @             if (P2 == RAR_VOL_NOTIFY)
    # @                 return (pThis->@n<RAR文件解压类.所需分卷已打开>(CVolString((wchar_t*)P1)) == 0 ? 1 : -1);
    # @             return 0;
