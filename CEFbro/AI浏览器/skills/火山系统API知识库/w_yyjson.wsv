    方法 创建自文本数据 <公开 类型 = 逻辑型 注释 = "根据所提供指定数量的成员创建本数组对象,如已创建成功则无法重复创建." 返回值注释 = "返回是否创建成功" @禁止流程检查 = 真>
    参数 成员 <类型 = 文本数组类 注释 = "提供所欲使用的成员数据">
    {
        变量 U8文本 <类型 = 字节集数组类>
        成员.枚举循环 ()
        {
            U8文本.加入成员 (文本到UTF8 (成员.取枚举值 ()))
        }
        @ char** arr = new char*[@<U8文本>.GetCount()];
        @ for (INT_P i = 0; i < @<U8文本>.GetCount (); i++) { arr[i] = (char*)((CVolMem&)@<U8文本>.GetAt(i)).GetPtr(); }
        @ yyjson_mut_val* val = yyjson_mut_arr_with_strcpy(data().GetDoc(), (const char**)arr, (size_t)@<U8文本>.GetCount ());
        @ delete[] arr;
        @ return data().CreateArray(val);
    }

    方法 取成员数 <公开 类型 = 整数 注释 = "获取该数组内包含的成员数量" @嵌入式方法 = "">
