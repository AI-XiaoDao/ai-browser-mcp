类 YYJSON值类型 <公开 注释 = "表示一个JSON对象的类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 未知 <公开 值 = @YYJSON_TYPE_NONE>
    常量 空值 <公开 值 = @YYJSON_TYPE_NULL>
    常量 逻辑值 <公开 值 = @YYJSON_TYPE_BOOL>
    常量 数值 <公开 值 = @YYJSON_TYPE_NUM>
    常量 文本值 <公开 值 = @YYJSON_TYPE_STR>
    常量 数组值 <公开 值 = @YYJSON_TYPE_ARR>
    常量 对象值 <公开 值 = @YYJSON_TYPE_OBJ>
}

类 YYJSON值子类型 <公开 注释 = "表示一个JSON对象的子类型" @文档 = "category = \"辅助类\"" @常量类 = 整数>
{
    常量 未知 <公开 值 = @YYJSON_SUBTYPE_NONE>
    常量 为假 <公开 值 = @YYJSON_SUBTYPE_FALSE>
    常量 为真 <公开 值 = @YYJSON_SUBTYPE_TRUE>
    常量 为无符号整数 <公开 值 = @YYJSON_SUBTYPE_UINT>
    常量 为有符号整数 <公开 值 = @YYJSON_SUBTYPE_SINT>
    常量 为小数 <公开 值 = @YYJSON_SUBTYPE_REAL>
}

类 YYJSON格式化选项 <公开 注释 = "提供可使用的JSON格式化(到文本)时的可选项" @文档 = "category = \"辅助类\"" @禁止创建对象 = 真>
{
    常量 压缩 <公开 类型 = 整数 值 = @YYJSON_WRITE_NOFLAG 注释 = "以最小占用的方式输出内容">
    常量 缩进 <公开 类型 = 整数 值 = @YYJSON_WRITE_PRETTY 注释 = "以4个空格符号缩进方式输出内容">
    常量 输出A码 <公开 类型 = 整数 值 = @YYJSON_WRITE_ESCAPE_UNICODE 注释 = "将Unicode字符转义,仅输出ASCII码.">
    常量 转义 <公开 类型 = 整数 值 = @YYJSON_WRITE_ESCAPE_SLASHES 注释 = "将\'/\'转义为\'\\/\'">
    常量 字符表示无限 <公开 类型 = 整数 值 = @YYJSON_WRITE_ALLOW_INF_AND_NAN 注释 = "将inf或nan数字输出为\"无限\"和\"nan\"字符(非标准)">
    常量 空表示无限 <公开 类型 = 整数 值 = @YYJSON_WRITE_INF_AND_NAN_AS_NULL 注释 = "将inf或nan数字输出为null">
}
