    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.列表框项***">
    {
        如果 (事件类型 == 元素事件.列表框_项模板创建)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LISTBOX_TEMP_CREATE, &@dt<炫彩列表框>::OnListBoxTemplateCreate);
        }
        否则 (事件类型 == 元素事件.列表框_项模板创建完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LISTBOX_TEMP_CREATE_END, &@dt<炫彩列表框>::OnListBoxTemplateCreateEnd);
        }
        否则 (事件类型 == 元素事件.列表框_项模板销毁)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LISTBOX_TEMP_DESTROY, &@dt<炫彩列表框>::OnListBoxTemplateDestroy);
        }
        否则 (事件类型 == 元素事件.列表框_项绘制)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LISTBOX_DRAWITEM, &@dt<炫彩列表框>::OnListBoxDrawItem);
        }
        否则 (事件类型 == 元素事件.列表框_项选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LISTBOX_SELECT, &@dt<炫彩列表框>::OnListBoxSelect);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

