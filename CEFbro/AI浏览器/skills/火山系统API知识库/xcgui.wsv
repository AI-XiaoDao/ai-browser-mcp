    参数 是否展开 <类型 = 逻辑型>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数>
    {
        如果 (事件类型 == 元素事件.属性框_项值改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_VALUE_CHANGE, &@dt<炫彩属性框>::OnPGridValueChange);
        }
        否则 (事件类型 == 元素事件.属性框_项设置)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_ITEM_SET, &@dt<炫彩属性框>::OnPGridItemSet);
        }
        否则 (事件类型 == 元素事件.属性框_项选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_ITEM_SELECT, &@dt<炫彩属性框>::OnPGridItemSelect);
        }
        否则 (事件类型 == 元素事件.属性框_项调整坐标)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_ITEM_ADJUST_COORDINATE, &@dt<炫彩属性框>::OnPGridItemAdjustCoordinate);
        }
        否则 (事件类型 == 元素事件.属性框_项销毁)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_ITEM_DESTROY, &@dt<炫彩属性框>::OnPGridItemDestroy);
        }
        否则 (事件类型 == 元素事件.属性框_项展开)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PGRID_ITEM_EXPAND, &@dt<炫彩属性框>::OnPGridItemExpand);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 创建 <公开 类型 = 变整数 折叠 折叠2 @虚拟方法 = 可覆盖 @禁止流程检查 = 真>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 父句柄 <类型 = 变整数 注释 = "对象.句柄" "">
    {
        @ return set((vint)XPGrid_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, (HXCGUI)@<父句柄>));
    }

    方法 添加项 <公开 类型 = 整数 返回值注释 = "返回索引" @嵌入式方法 = "">
    参数 pName <类型 = 文本型>
    参数 类型 <类型 = 整数 注释 = "属性框项类型.**">
    参数 nParentID <类型 = 整数 注释 = "炫彩ID.**" @默认值 = 炫彩ID.根节点>
    {
        @ XPGrid_AddItem((HELE)@sn<this>.get(),@<pName>.GetText(), (propertyGrid_item_type_)@<类型>,@<nParentID>)
    }

    方法 添加项文本 <公开 类型 = 整数 返回值注释 = "返回索引" @嵌入式方法 = "">
    参数 pName <类型 = 文本型>
    参数 pValue <类型 = 文本型>
    参数 nParentID <类型 = 整数 注释 = "炫彩ID.**" @默认值 = 炫彩ID.根节点>
    {
        @ XPGrid_AddItemString((HELE)@sn<this>.get(),@<pName>.GetText(), @<pValue>.GetText(),@<nParentID>)
    }

    方法 添加项元素 <公开 类型 = 整数 返回值注释 = "返回索引" 折叠 @嵌入式方法 = "">
    参数 hElePanel <类型 = 变整数>
    参数 nParentID <类型 = 整数 注释 = "炫彩ID.**" @默认值 = 炫彩ID.根节点>
