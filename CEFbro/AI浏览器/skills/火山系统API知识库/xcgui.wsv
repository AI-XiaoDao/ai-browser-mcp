    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.***">
    {
        <折叠> 如果 (事件类型 == 元素事件.处理过程)  // 事件过程
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_ELEPROCE, &@dt<元素基类>::OnEventProc);
        }
        <折叠> 否则 (事件类型 == 2)  // 绘制事件
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_PAINT, &@dt<元素基类>::OnDraw);
        }
        <折叠> 否则 (事件类型 == 元素事件.绘制完成)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_PAINT_END, &@dt<元素基类>::OnPaintEnd);
        }
        <折叠> 否则 (事件类型 == 元素事件.绘制滚动视图)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_PAINT_SCROLLVIEW, &@dt<元素基类>::OnDrawScrollView);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标移动)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MOUSEMOVE, &@dt<元素基类>::OnMouseMove);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标进入)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MOUSESTAY, &@dt<元素基类>::OnMouseStay);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标悬停)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MOUSEHOVER, &@dt<元素基类>::OnMouseHover);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标离开)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MOUSELEAVE, &@sn<current_class>::OnMouseLeave);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标滚轮滚动)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MOUSEWHEEL, &@sn<current_class>::OnMouseWheel);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标左键按下)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LBUTTONDOWN, &@sn<current_class>::OnLButtonDown);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标左键弹起)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LBUTTONUP, &@sn<current_class>::OnLButtonUp);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标右键按下)  // 鼠标右键按下事件
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_RBUTTONDOWN, &@sn<current_class>::OnRButtonDown);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标右键弹起)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_RBUTTONUP, &@sn<current_class>::OnRButtonUp);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标左键双击)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LBUTTONDBCLICK, &@sn<current_class>::OnLButtonDBClick);
        }
        <折叠> 否则 (事件类型 == 元素事件.鼠标右键双击)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), 15, &@sn<current_class>::OnRButtonDBClick);
        }
        <折叠> 否则 (事件类型 == 元素事件.定时器炫彩)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_XC_TIMER, &@sn<current_class>::OnEleXCTimer);
        }
        <折叠> 否则 (事件类型 == 元素事件.获取焦点)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SETFOCUS, &@sn<current_class>::OnSetFocus);
        }
        <折叠> 否则 (事件类型 == 元素事件.失去焦点)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_KILLFOCUS, &@sn<current_class>::OnKillFocus);
        }
        <折叠> 否则 (事件类型 == 元素事件.销毁)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DESTROY, &@sn<current_class>::OnDestroy);
        }
        <折叠> 否则 (事件类型 == 元素事件.销毁完成)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DESTROY_END, &@sn<current_class>::OnDestroyeEnd);
        }
        <折叠> 否则 (事件类型 == 元素事件.大小改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SIZE, &@sn<current_class>::OnSize);
        }
        <折叠> 否则 (事件类型 == 元素事件.显示)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SHOW, &@sn<current_class>::OnShow);
        }
        <折叠> 否则 (事件类型 == 元素事件.置字体)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SETFONT, &@sn<current_class>::OnSetFont);
        }
        <折叠> 否则 (事件类型 == 元素事件.按键按下)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_KEYDOWN, &@sn<current_class>::OnEventKeyDown);
        }
        否则 (事件类型 == 元素事件.按键弹起)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_KEYUP, &@sn<current_class>::OnEventKeyUp);
        }
        <折叠> 否则 (事件类型 == 元素事件.输入字符)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_CHAR, &@sn<current_class>::OnEventChar);
        }
        <折叠> 否则 (事件类型 == 元素事件.置鼠标捕获)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SETCAPTURE, &@sn<current_class>::OnSetCapture);
        }
        <折叠> 否则 (事件类型 == 元素事件.失去鼠标捕获)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_KILLCAPTURE, &@sn<current_class>::OnKillCapture);
        }
        <折叠> 否则 (事件类型 == 元素事件.置鼠标光标)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_SETCURSOR, &@sn<current_class>::OnSetCursor);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_弹出)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_POPUP, &@sn<current_class>::OnMenuPopup);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_弹出窗口)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_POPUP_WND, &@sn<current_class>::OnMenuPopupWnd);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_项选择)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_SELECT, &@sn<current_class>::OnMenuSelect);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_绘制背景)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_DRAW_BACKGROUND, &@sn<current_class>::OnMenuDrawBackground);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_项绘制)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_DRAWITEM, &@sn<current_class>::OnMenuDrawItem);
        }
        <折叠> 否则 (事件类型 == 元素事件.菜单_退出)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_MENU_EXIT, &@sn<current_class>::OnMenuExit);
        }
        <折叠> 否则 (事件类型 == 元素事件.文件拖入)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DROPFILES, &@sn<current_class>::OnDropFiles);
        }
        否则 (事件类型 == 元素事件.布局调整完毕)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_ADJUSTLAYOUT_END, &@sn<current_class>::OnAdjustLayoutEnd);
        }
        否则 (事件类型 == 元素事件.弹出工具提示)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_TOOLTIP_POPUP, &@sn<current_class>::OnTooltipPopup);
        }

    }

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.***">
    {
        如果 (事件类型 == 元素事件.处理过程)  // 事件过程
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_ELEPROCE, &@dt<元素基类>::OnEventProc);
        }
        否则 (事件类型 == 2)  // 绘制事件
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PAINT, &@dt<元素基类>::OnDraw);
        }
        否则 (事件类型 == 元素事件.绘制完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PAINT_END, &@dt<元素基类>::OnPaintEnd);
        }
        否则 (事件类型 == 元素事件.绘制滚动视图)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PAINT_SCROLLVIEW, &@dt<元素基类>::OnDrawScrollView);
        }
        否则 (事件类型 == 元素事件.鼠标移动)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MOUSEMOVE, &@dt<元素基类>::OnMouseMove);
        }
        否则 (事件类型 == 元素事件.鼠标进入)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MOUSESTAY, &@dt<元素基类>::OnMouseStay);
        }
        否则 (事件类型 == 元素事件.鼠标悬停)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MOUSEHOVER, &@dt<元素基类>::OnMouseHover);
        }
        否则 (事件类型 == 元素事件.鼠标离开)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MOUSELEAVE, &@dt<元素基类>::OnMouseLeave);
        }
        否则 (事件类型 == 元素事件.鼠标滚轮滚动)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MOUSEWHEEL, &@dt<元素基类>::OnMouseWheel);
        }
        否则 (事件类型 == 元素事件.鼠标左键按下)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LBUTTONDOWN, &@dt<元素基类>::OnLButtonDown);
        }
        否则 (事件类型 == 元素事件.鼠标左键弹起)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LBUTTONUP, &@dt<元素基类>::OnLButtonUp);
        }
        否则 (事件类型 == 元素事件.鼠标右键按下)  // 鼠标右键按下事件
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_RBUTTONDOWN, &@dt<元素基类>::OnRButtonDown);
        }
        否则 (事件类型 == 元素事件.鼠标右键弹起)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_RBUTTONUP, &@dt<元素基类>::OnRButtonUp);
        }
        否则 (事件类型 == 元素事件.鼠标左键双击)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LBUTTONDBCLICK, &@dt<元素基类>::OnLButtonDBClick);
        }
        否则 (事件类型 == 元素事件.鼠标右键双击)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), 15, &@dt<元素基类>::OnRButtonDBClick);
        }
        否则 (事件类型 == 元素事件.定时器炫彩)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_XC_TIMER, &@dt<元素基类>::OnEleXCTimer);
        }
        否则 (事件类型 == 元素事件.获取焦点)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SETFOCUS, &@dt<元素基类>::OnSetFocus);
        }
        否则 (事件类型 == 元素事件.失去焦点)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_KILLFOCUS, &@dt<元素基类>::OnKillFocus);
        }
        否则 (事件类型 == 元素事件.销毁)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DESTROY, &@dt<元素基类>::OnDestroy);
        }
        否则 (事件类型 == 元素事件.销毁完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DESTROY_END, &@dt<元素基类>::OnDestroyeEnd);
        }
        否则 (事件类型 == 元素事件.大小改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SIZE, &@dt<元素基类>::OnSize);
        }
        否则 (事件类型 == 元素事件.显示)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SHOW, &@dt<元素基类>::OnShow);
        }
        否则 (事件类型 == 元素事件.置字体)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SETFONT, &@dt<元素基类>::OnSetFont);
        }
        否则 (事件类型 == 元素事件.按键按下)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_KEYDOWN, &@dt<元素基类>::OnEventKeyDown);
        }
        否则 (事件类型 == 元素事件.按键弹起)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_KEYUP, &@dt<元素基类>::OnEventKeyUp);
        }
        否则 (事件类型 == 元素事件.输入字符)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_CHAR, &@dt<元素基类>::OnEventChar);
        }
        否则 (事件类型 == 元素事件.置鼠标捕获)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SETCAPTURE, &@dt<元素基类>::OnSetCapture);
        }
        否则 (事件类型 == 元素事件.失去鼠标捕获)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_KILLCAPTURE, &@dt<元素基类>::OnKillCapture);
        }
        否则 (事件类型 == 元素事件.置鼠标光标)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_SETCURSOR, &@dt<元素基类>::OnSetCursor);
        }
        否则 (事件类型 == 元素事件.菜单_弹出)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_POPUP, &@dt<元素基类>::OnMenuPopup);
        }
        否则 (事件类型 == 元素事件.菜单_弹出窗口)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_POPUP_WND, &@dt<元素基类>::OnMenuPopupWnd);
        }
        否则 (事件类型 == 元素事件.菜单_项选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_SELECT, &@dt<元素基类>::OnMenuSelect);
        }
        否则 (事件类型 == 元素事件.菜单_绘制背景)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_DRAW_BACKGROUND, &@dt<元素基类>::OnMenuDrawBackground);
        }
        否则 (事件类型 == 元素事件.菜单_项绘制)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_DRAWITEM, &@dt<元素基类>::OnMenuDrawItem);
        }
        否则 (事件类型 == 元素事件.菜单_退出)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_MENU_EXIT, &@dt<元素基类>::OnMenuExit);
        }
        否则 (事件类型 == 元素事件.文件拖入)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DROPFILES, &@dt<元素基类>::OnDropFiles);
        }
        否则 (事件类型 == 元素事件.布局调整完毕)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_ADJUSTLAYOUT_END, &@dt<元素基类>::OnAdjustLayoutEnd);
        }
        否则 (事件类型 == 元素事件.弹出工具提示)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_TOOLTIP_POPUP, &@sn<current_class>::OnTooltipPopup);
        }

    }

    方法 置背景边框 <公开 折叠 @嵌入式方法 = "">
    参数 状态 <类型 = 整数 注释 = "组合状态.**">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    参数 线宽 <类型 = 整数 @默认值 = 1>
    {
        @ XEle_AddBkBorder((HELE)@sn<this>.get(), @<状态>,COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>), @<线宽>)
    }

