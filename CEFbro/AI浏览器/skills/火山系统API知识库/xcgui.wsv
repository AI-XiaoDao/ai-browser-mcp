    参数 重画 <类型 = 逻辑型 @默认值 = 假>
    参数 标识 <类型 = 整数 注释 = "布局标识.***" @默认值 = 布局标识.调整_自身>
    {
        @ XEle_SetRectEx((HELE)@sn<this>.get(), @<左边>, @<顶边>, @<宽度>, @<高度>, @<重画>, @<标识>)
    }

    方法 置矩形逻辑 <公开 类型 = 整数 注释 = "设置元素坐标,逻辑坐标,包含滚动视图偏移" 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    参数 重画 <类型 = 逻辑型 注释 = "是否重绘">
    参数 标识 <类型 = 整数 注释 = "布局标识.***,参数将被带入 XE_SIZE ,XE_ADJUSTLAYOUT 事件回调." @默认值 = 布局标识.调整_自身>
    {
        @ XEle_SetRectLogic((HELE)@sn<this>.get(), &RECT {@<左边>,@<顶边>,@<右边>,@<底边> }, @<重画>, @<标识>)
    }

    方法 置顶 <公开 类型 = 逻辑型 注释 = "设置元素置顶" 返回值注释 = "成功返回TRUE否则返回FALSE" 折叠 @嵌入式方法 = "">
    参数 是否置顶 <类型 = 逻辑型 注释 = "是否置顶显示">
    {
        @ XEle_EnableTopmost((HELE)@sn<this>.get(), @<是否置顶>)
    }

    方法 置用户数据 <公开 折叠 @嵌入式方法 = "">
    参数 用户数据 <类型 = 变整数>
    {
        @ XEle_SetUserData((HELE)@sn<this>.get(), (vint)@<用户数据>)
    }

    方法 置定时器 <公开 类型 = 逻辑型 返回值注释 = "如果成功返回TRUE,否则返回FALSE" 折叠 @嵌入式方法 = "">
    参数 事件ID <类型 = 整数>
    参数 延时毫秒 <类型 = 整数>
    {
        @ XEle_SetXCTimer((HELE)@sn<this>.get(), @<事件ID>, @<延时毫秒>)
    }

    方法 置Z序扩展 <公开 类型 = 逻辑型 返回值注释 = "成功返回TRUE否则返回FALSE." 折叠 @嵌入式方法 = "">
    参数 目标元素 <类型 = 变整数 注释 = "目标元素">
    参数 Z序位置 <类型 = 整数 注释 = "Z序位置.***">
    {
        @ XEle_SetZOrderEx((HELE)@sn<this>.get(), (HELE)@<目标元素>, (zorder_)@<Z序位置>)
    }

    方法 取窗口客户区矩形DPI <公开 折叠 @嵌入式方法 = "">
    参数 矩形 <类型 = 矩形_xc 注释 = "欲返回的矩形">
    {
        @ XEle_GetWndClientRectDPI((HELE)@sn<this>.get(), @<矩形>.pdata())
    }

    方法 坐标_元素到窗口DPI <公开 注释 = "客户区坐标到窗口客户区" 折叠 @禁止流程检查 = 真>
    参数 坐标 <类型 = 坐标_xc>
    {
        @ POINT *rc = @<坐标>.pdata ();
        @ XEle_PointClientToWndClientDPI((HELE)get(), rc);
        @ @<坐标.横坐标>(rc->x);
        @ @<坐标.纵坐标>(rc->y);
    }

    方法 矩形_窗口到元素DPI <公开 注释 = "窗口矩形到元素矩形" 折叠 @禁止流程检查 = 真>
    参数 矩形 <类型 = 矩形_xc>
    {
        @ RECT *rc = @<矩形>.pdata ();
        @ XEle_RectClientToWndClientDPI((HELE)get(),rc);
        @ @<矩形.左边>(rc->left);
        @ @<矩形.顶边>(rc->top);
        @ @<矩形.右边>(rc->right);
        @ @<矩形.底边>(rc->bottom);
    }
}

