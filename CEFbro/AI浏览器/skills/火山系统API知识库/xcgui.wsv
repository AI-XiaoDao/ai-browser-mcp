    方法 置托盘图标 <公开 类型 = 逻辑型 注释 = "在\"窗口_处理过程\"事件中判断消息=窗口事件.托盘,lParam参数为鼠标事件" 折叠 @禁止流程检查 = 真>
    参数 图标文件 <类型 = 图标资源>
    参数 提示文本 <类型 = 文本型>
    {
        // @ #include "shellapi.h" //托盘图标引用
        @ m_NotifyIconData.cbSize = sizeof(NOTIFYICONDATA);//长度
        @ m_NotifyIconData.uFlags = NIF_ICON | NIF_MESSAGE | NIF_TIP;//图标样式
        @ m_NotifyIconData.hWnd = XWnd_GetHWND((HWINDOW)get());//窗口句柄
        @ m_NotifyIconData.hIcon =(HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<图标文件>);

        // (HICON)LoadImage (0, @<图标文件>.GetText (), IMAGE_ICON, 0, 0, LR_LOADFROMFILE);//加载图标进去 LoadIcon(NULL,IDI_ERROR)
        @ m_NotifyIconData.uCallbackMessage = @<窗口事件.托盘>;//这个是点击图标的事件消息,我们在消息处理函数WndProc()里面写一个case WM_NOTIFYICON:去处理鼠标点击图标事件
        @ _tcscpy(m_NotifyIconData.szTip, @<提示文本>.GetText ());//当鼠标移动到图标的时候显示
        @ return Shell_NotifyIcon(NIM_ADD, &m_NotifyIconData);
    }

    方法 修改托盘图标 <公开 类型 = 逻辑型 注释 = "在\"窗口_处理过程\"事件中判断消息=窗口事件.托盘,lParam参数为鼠标事件" 折叠 @禁止流程检查 = 真>
    参数 图标文件 <类型 = 图标资源>
    {
        // @ #include "shellapi.h" //托盘图标引用
        @ m_NotifyIconData.uFlags = NIF_ICON | NIF_MESSAGE ;//图标样式
        @ m_NotifyIconData.hIcon =(HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<图标文件>);
        // (HICON)LoadImage (0, @<图标文件>.GetText (), IMAGE_ICON, 0, 0, LR_LOADFROMFILE);//加载图标进去 LoadIcon(NULL,IDI_ERROR)
        @ return Shell_NotifyIcon(NIM_MODIFY, &m_NotifyIconData);
    }

    方法 删除托盘图标 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ DestroyIcon(m_NotifyIconData.hIcon) ;
        @ return Shell_NotifyIcon(NIM_DELETE,&m_NotifyIconData);
    }

    方法 置托盘文本 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 提示文本 <类型 = 文本型>
    {
        @ m_NotifyIconData.uFlags = NIF_TIP;
        @ _tcscpy(m_NotifyIconData.szTip,@<提示文本>.GetText ());
        @ return Shell_NotifyIcon(NIM_MODIFY,&m_NotifyIconData);
    }

    方法 取图标 <公开 类型 = 炫彩图片 折叠 @嵌入式方法 = "">
