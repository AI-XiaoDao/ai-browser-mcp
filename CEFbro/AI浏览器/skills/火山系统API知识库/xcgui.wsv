<火山程序 类型 = "通常" 版本 = 1 />

包 xc.gui <@文档 = "category = \"炫彩基类\"">

类 xcbase <折叠>
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (XCGUIDATA)
    # @begin
    # <> <include>
    # public:
    #     inline_ vint get()   {  return data().GetP(); }
    #     inline_ vint set(vint p)   { return data().SetP(p);  }
    # <> </include>
    # @end

    方法 句柄 <公开 属性读 类型 = 变整数 注释 = "取句柄" 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.get()
    }

    方法 句柄 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        @ set((vint)@<指针>);
    }
}

类 炫彩基类 <公开 基础类 = xcbase 折叠 @输出名 = "xcguibase">
{
    方法 取类型 <公开 类型 = 整数 注释 = "炫彩对象_取类型" 返回值注释 = "返回 元素类型.***" 折叠 @嵌入式方法 = "">
    {
        @  (int)XObj_GetType((HXCGUI)@sn<this>.get())
    }

    方法 取基础类型 <公开 类型 = 整数 注释 = "炫彩对象_取基础类型" 返回值注释 = "返回 元素类型.***" 折叠 @嵌入式方法 = "">
    {
        @  (int)XObj_GetTypeBase((HXCGUI)@sn<this>.get())
    }

    方法 取类型扩展 <公开 类型 = 整数 注释 = "炫彩对象_取类型扩展" 返回值注释 = "按钮类型标识.***" 折叠 @嵌入式方法 = "">
    {
        @  (int)XObj_GetTypeEx((HXCGUI)@sn<this>.get())
    }

    方法 置类型 <公开 折叠 @嵌入式方法 = "">
    参数 类型 <类型 = 整数 注释 = "按钮类型标识.***">
    {
        @  XObj_SetTypeEx((HXCGUI)@sn<this>.get(),(XC_OBJECT_TYPE_EX)@<类型>);
    }
}

类 可视对象 <公开 基础类 = 炫彩基类 折叠 @输出名 = "widgetUI">
{
    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" @虚拟方法 = 可覆盖>

    方法 启用样式 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @  XUI_EnableCSS((HXCGUI)@sn<this>.get(),@<是否启用>)
    }

    方法 样式名称 <公开 属性读 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @  @an<CVolString>( XUI_GetCssName((HXCGUI)@sn<this>.get()))
    }

    方法 样式名称 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 名称 <类型 = 文本型>
    {
        @  XUI_SetCssName((HXCGUI)get(),@<名称>.GetText ());
    }

    方法 样式 <公开 属性写 注释 = "UI对象_置样式" 返回值注释 = "XUI_SetStyle" 折叠 @禁止流程检查 = 真>
    参数 样式 <类型 = 整数 注释 = "按钮样式.***">
    {
        @  XUI_SetStyle((HXCGUI)get(),(XC_OBJECT_STYLE)@<样式>);
    }

    方法 样式 <公开 属性读 类型 = 整数 注释 = "UI对象_取样式" 返回值注释 = "按钮样式.**" 折叠 @嵌入式方法 = "">
    {
        @  (int)XUI_GetStyle((HXCGUI)@sn<this>.get())
    }
}

类 炫彩窗口组件 <公开 基础类 = 可视对象 折叠 @输出名 = "XWidget">
{
