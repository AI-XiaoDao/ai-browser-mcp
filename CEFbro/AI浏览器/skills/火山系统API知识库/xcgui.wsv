    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_SELECT, &@dt<炫彩组合框>::OnComboBoxSelect);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_SELECT_END, &@dt<炫彩组合框>::OnComboBoxSelectEnd);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_POPUP_LIST, &@dt<炫彩组合框>::OnComboBoxPopupList);
        @     ((CVolEventReceiver*)(addr + size*2))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*3))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_EXIT_LIST, &@dt<炫彩组合框>::OnComboBoxExitList);
        @     ((CVolEventReceiver*)(addr + size*3))->sEndSendEvent (pEventReceiver); }
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_POPUP, &@dt<炫彩组合框>::OnComboBoxPopup);
        @     ((CVolEventReceiver*)(addr + size*4))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();
    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.组合框***">
    {
        如果 (事件类型 == 元素事件.组合框_项选择)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_SELECT, &@dt<炫彩组合框>::OnComboBoxSelect);
        }
        否则 (事件类型 == 元素事件.组合框_项选择完成)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_SELECT_END, &@dt<炫彩组合框>::OnComboBoxSelectEnd);
        }
        否则 (事件类型 == 元素事件.组合框_弹出列表)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_POPUP_LIST, &@dt<炫彩组合框>::OnComboBoxPopupList);
        }
        否则 (事件类型 == 元素事件.组合框_退出列表)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_EXIT_LIST, &@dt<炫彩组合框>::OnComboBoxExitList);
        }
        否则 (事件类型 == 元素事件.组合框_下拉列表即将弹出)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_COMBOBOX_POPUP, &@dt<炫彩组合框>::OnComboBoxPopup);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

