    方法 置项模板从内存 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 数据资源 <类型 = 视窗文件资源>
    {
        @ @an<CVolMem> memBuf;
        @ if( g_objVolApp.LoadResData (@<数据资源>, memBuf) ==0) {
        @ return 0; }
        @ return XList_SetItemTemplateXMLFromMem((HELE)get(),(void*)memBuf.GetPtr (),(INT)memBuf.GetSize ());
    }

