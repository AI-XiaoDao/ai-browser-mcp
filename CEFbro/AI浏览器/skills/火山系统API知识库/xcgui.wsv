    }

    方法 置图标 <公开 注释 = "如果不为ICO图标格式,任务栏图标会失败" 折叠 @禁止流程检查 = 真>
    参数 图标文件 <类型 = 图标资源>
    参数 窗口句柄 <类型 = 变整数 注释 = "此句柄为MFC窗口句柄,如:用挂接窗口方法才需填写此参数" @默认值 = 0>
    {
        // @ HIMAGE img = XImage_LoadFile(@<图标文件>.GetText ());
        @ HICON hIcon_y = (HICON)g_objVolApp.LoadResImage (VRIT_ICON, @<图标文件>);
        @ HIMAGE img = XImage_LoadFromHICON(hIcon_y);
        @ XImage_SetDrawType(img, image_draw_type_stretch);
        @ XWnd_SetIcon ((HWINDOW)get(),img);
        @ HWND hwnd_y;
        @ if (@<窗口句柄>== 0 )
        @        hwnd_y = XWnd_GetHWND ((HWINDOW)get());
        @ else
        @        hwnd_y = (HWND)@<窗口句柄>;
        // @ HANDLE hIcon = LoadImage (0, @<图标文件>.GetText (), IMAGE_ICON, 0, 0, LR_LOADFROMFILE);
        // @ DebugTrace (FALSE, 0, 0, _T ("p"),   g_objVolApp.LoadResImage (VRIT_ICON, @<图标文件>));
        @ SendMessage (hwnd_y, WM_SETICON, ICON_BIG, (LPARAM)hIcon_y);
        @ SendMessage (hwnd_y, WM_SETICON, ICON_SMALL, (LPARAM)hIcon_y);
    }

