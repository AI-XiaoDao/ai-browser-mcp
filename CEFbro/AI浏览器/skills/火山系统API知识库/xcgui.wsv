    }

    方法 显示任务栏 <公开 折叠 @嵌入式方法 = "">
    {
        @ HWND hWnd_xc = XWnd_GetHWND((HWINDOW)@sn<this>.get());
        @ LONG styleValue = ::GetWindowLongPtr(hWnd_xc, GWL_EXSTYLE);
        @ styleValue |= (WS_EX_APPWINDOW);//当窗口可见时将一个顶层窗口放置在任务栏上
        @ styleValue &= ~(WS_EX_TOOLWINDOW); //去掉工具栏窗口属性,使其在任务栏可见
        @ SetWindowLongPtr(hWnd_xc, GWL_EXSTYLE, styleValue);
    }

    方法 禁止靠边最大化 <公开 注释 = "不适用mfc" 折叠 @嵌入式方法 = "">
    {
        @ HWND hWnd_yt = XWnd_GetHWND((HWINDOW)@sn<this>.get());
        // @ LONG_PTR plptrWin1 = GetWindowLongPtr(hWnd_yt,GWL_STYLE);
        // @  SetWindowLongPtr (hWnd_yt,GWL_STYLE,2147483648 | plptrWin1);
        @ SetWindowLongPtr(hWnd_yt,GWL_STYLE,GetWindowLongPtr(hWnd_yt,GWL_STYLE) & ~WS_MAXIMIZEBOX);
        // @ SetWindowLongPtr(hWnd_yt,GWL_STYLE,GetWindowLongPtr(hWnd_yt,GWL_STYLE) & ~WS_MAXIMIZEBOX & ~WS_THICKFRAME);
    }

    方法 全屏显示 <公开 折叠 @嵌入式方法 = "">
    {
        @ HWND hWndy = XWnd_GetHWND((HWINDOW)@sn<this>.get());
        @ DWORD last_style = GetWindowLong(hWndy, GWL_STYLE); //存储上次的窗口风格
        // @ RECT last_rect;
        // @ GetWindowRect(hWndy, &last_rect);             //存储上次的窗口位置和大小
        // @ DebugTrace (FALSE, 0, 0, _T ("nnnn"), last_rect.left, last_rect.top, last_rect.right - last_rect.left, last_rect.bottom - last_rect.top);
        @ int w = GetSystemMetrics(SM_CXSCREEN);
        @ int h = GetSystemMetrics(SM_CYSCREEN);       // 获取最大化的窗口大小
        // @ if(@<是否全屏>){
        @ SetWindowLongPtr(hWndy, GWL_STYLE, WS_VISIBLE | WS_POPUP); // 去掉标题栏
        @ SetWindowPos(hWndy, NULL, 0, 0, w, h, SWP_FRAMECHANGED); // 设置位置和大小
        // @ } else {
        // @ SetWindowLong(hWndy, GWL_STYLE, last_style); // 恢复最大化之前的窗口风格
        // @ SetWindowPos(hWndy, NULL, last_rect.left, last_rect.top, last_rect.right - last_rect.left, last_rect.bottom - last_rect.top, NULL); // 恢复最大化之前的窗口位置和大小
        // @ }

    }

    方法 全屏恢复 <公开 折叠>
    参数 矩形 <类型 = 矩形_xc 注释 = "要恢复窗口的大小,可在全屏显示()方法前保存窗口大小">
    {
        @ HWND hWndyt = XWnd_GetHWND((HWINDOW)get());
        @ DWORD last_style = GetWindowLong(hWndyt, GWL_STYLE); //存储上次的窗口风格
        @ SetWindowLong(hWndyt, GWL_STYLE, last_style); // 恢复最大化之前的窗口风格
        @ SetWindowPos(hWndyt, NULL, @<矩形>.pdata ()->left, @<矩形>.pdata ()->top, @<矩形>.pdata ()->right - @<矩形>.pdata ()->left, @<矩形>.pdata ()->bottom - @<矩形>.pdata ()->top, NULL); // 恢复最大化之前的窗口位置和大小
    }

