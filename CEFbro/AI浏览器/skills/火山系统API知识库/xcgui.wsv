    {
        @ @sn<this>.set((vint)XModalWnd_Create(@<宽度>, @<高度>, @<标题>.GetText (), (HWND)@<父句柄>, @<库样式>))
    }

    方法 创建扩展 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 扩展风格 <类型 = 整数>
    参数 类名 <类型 = 文本型>
    参数 窗口标题 <类型 = 文本型>
    参数 窗口风格 <类型 = 整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 父句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 库样式 <类型 = 整数 注释 = "窗口样式.**" @默认值 = 窗口样式.模态简单>
    {
        @ @sn<this>.set((vint)XModalWnd_CreateEx(@<扩展风格>,@<窗口风格>,@<类名>.GetText (), @<左边>, @<顶边>, @<宽度>, @<高度>, @<窗口标题>.GetText (),(HWND)@<父句柄>, @<库样式>))
    }

    方法 启动 <公开 类型 = 整数 注释 = "启动显示模态窗口,当窗口关闭时返回" 返回值注释 = "消息框标识.***" 折叠 @嵌入式方法 = "">
    {
        @ XModalWnd_DoModal((HWINDOW)@sn<this>.get())
    }

    方法 启用自动关闭 <公开 注释 = "是否自动关闭窗口,当窗口失去焦点时" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
