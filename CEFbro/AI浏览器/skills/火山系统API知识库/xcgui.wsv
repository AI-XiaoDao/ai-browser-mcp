    方法 隐藏任务栏 <公开 注释 = "不适用mfc" 折叠 @嵌入式方法 = "">
    {
        @ HWND hWnd_x = XWnd_GetHWND((HWINDOW)@sn<this>.get());
        @ LONG_PTR plptrWin = GetWindowLongPtr(hWnd_x,GWL_EXSTYLE);
