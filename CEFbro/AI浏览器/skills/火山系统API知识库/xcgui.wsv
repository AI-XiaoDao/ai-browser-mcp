    参数 nUID <类型 = 整数>
    {
        @ XWidget_SetUID((HXCGUI)get(), @<nUID>);
    }

    方法 UID <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XWidget_GetUID((HXCGUI)@sn<this>.get())
    }

    方法 名称 <公开 属性读 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString>( XWidget_GetName((HELE)@sn<this>.get()))
    }

    方法 名称 <公开 属性写 注释 = "设置元素name." 折叠 @禁止流程检查 = 真>
    参数 字段名 <类型 = 文本型 注释 = "pName">
    {
        @ XWidget_SetName((HXCGUI)get(), @<字段名>.GetText ()); 
    }

    方法 取句柄 <公开 类型 = 变整数 注释 = "返回:炫彩窗口句柄" 返回值注释 = "XWidget_GetHWINDOW" @嵌入式方法 = "">
    {
        @  (vint)XWidget_GetHWINDOW((HXCGUI)@sn<this>.get())
    }

    方法 取父元素 <公开 类型 = 变整数 注释 = "XWidget_GetParentEle." 折叠 @嵌入式方法 = "">
    {
        @  (vint)XWidget_GetParentEle((HXCGUI)@sn<this>.get())
    }

    方法 取父对象 <公开 类型 = 变整数 注释 = "UI组件_取父对象" 返回值注释 = "XWidget_GetParent" 折叠 @嵌入式方法 = "">
    {
        @  (vint)XWidget_GetParent((HXCGUI)@sn<this>.get())
    }

    方法 取窗口句柄 <公开 类型 = 变整数 注释 = "UI组件_取HWND" 返回值注释 = "XWidget_GetHWND" 折叠 @嵌入式方法 = "">
    {
        @  (@dt<变整数>)XWidget_GetHWND((HXCGUI)@sn<this>.get())
    }

    方法 布局项启用换行 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XWidget_LayoutItem_EnableWrap ((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 布局项启用交换 <公开 注释 = "根据水平垂直布局变换, 交换属性(宽度,高度,最小宽度,最小高度)" 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XWidget_LayoutItem_EnableSwap ((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 布局项启用浮动 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XWidget_LayoutItem_EnableFloat ((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 布局项置高度 <公开 @嵌入式方法 = "">
    参数 标识 <类型 = 整数 注释 = "布局标识.尺寸_***">
    参数 高度 <类型 = 整数>
    {
        @ XWidget_LayoutItem_SetHeight((HXCGUI)@sn<this>.get(),(layout_size_) @<标识>, @<高度>)
    }

    方法 布局项置宽度 <公开 折叠 @嵌入式方法 = "">
    参数 标识 <类型 = 整数 注释 = "布局标识.尺寸_***">
    参数 宽度 <类型 = 整数>
    {
        @ XWidget_LayoutItem_SetWidth((HXCGUI)@sn<this>.get(), (layout_size_)@<标识>, @<宽度>)
    }

    方法 布局项取宽度 <公开 折叠 @嵌入式方法 = "">
    参数 标识 <类型 = 整数 注释 = "欲返回的:布局标识.尺寸_***">
    参数 宽度 <类型 = 整数 注释 = "返回布局项宽度">
    {
        // @ int pWidth;//@ layout_size_ ly;
        @ XWidget_LayoutItem_GetWidth((HXCGUI)@sn<this>.get(), (layout_size_*)&@<标识>,(int*)&@<宽度> )
        // @ return pWidth;
    }

    方法 布局项取高度 <公开 折叠 @嵌入式方法 = "">
    参数 标识 <类型 = 整数 注释 = "欲返回的:布局标识.尺寸_***">
    参数 高度 <类型 = 整数 注释 = "返回布局项高度">
    {
        // @ int pHeight;
        @ XWidget_LayoutItem_GetHeight((HXCGUI)@sn<this>.get(),(layout_size_*)&@<标识>, (int*)&@<高度>)
        // @ return pHeight;
    }

    方法 布局项置对齐 <公开 折叠 @嵌入式方法 = "">
    参数 标识 <类型 = 整数 注释 = "布局标识.对齐_***">
    {
        @ XWidget_LayoutItem_SetAlign ((HXCGUI)@sn<this>.get(), (layout_align_axis_)@<标识>)
    }

    方法 布局项置外间距 <公开 注释 = "" 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    {
        @ XWidget_LayoutItem_SetMargin((HXCGUI)@sn<this>.get(), @<左边>, @<顶边>, @<右边>, @<底边>)
    }

    方法 布局项取外间距 <公开 注释 = "" 折叠 @嵌入式方法 = "">
    参数 边框大小 <类型 = 边框大小_xc 注释 = "欲返回的边框大小">
    {
        @ XWidget_LayoutItem_GetMargin((HXCGUI)@sn<this>.get(), @<边框大小>.pdata())
    }

    方法 布局项置最小大小 <公开 注释 = "限制大小仅针对缩放有效(自动, 填充父, 比例, 百分比)" 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ XWidget_LayoutItem_SetMinSize ((HXCGUI)@sn<this>.get(), @<宽度>,@<高度>)
    }

    方法 布局项置位置 <公开 注释 = "相对位置, 值大于等于0有效" @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    {
        @ XWidget_LayoutItem_SetPosition((HXCGUI)@sn<this>.get(), @<左边>, @<顶边>, @<右边>, @<底边>)
    }
}

