    方法 取选择项全部 <公开 类型 = 整数 返回值注释 = "返回接收项数组数量." 折叠 @禁止流程检查 = 真>
    参数 项ID结构数组 <类型 = 列表视图_项ID结构数组 注释 = "欲要接受的数组">
    {
        变量 列表视图 <类型 = 列表视图_项ID结构>
        @ int count = XListView_GetSelectItemCount((HELE)get());
        @ listView_item_id_*  arr = new listView_item_id_[count];
        @ int  ret =  XListView_GetSelectAll((HELE)get(), arr, count);
        @ @<项ID结构数组>.RemoveAll ();
        @ for(int i=0; i<ret; i++) {
        // @ @<列表视图> = (@dt<列表视图_项ID结构>*)@<项ID结构数组>.GetAt (i);
        @    @<列表视图.组索引> (arr[i].iGroup);
        @    @<列表视图.项索引> (arr[i].iItem) ;
        @ @<项ID结构数组>.Add (@<列表视图>, NULL);
        @ }
        @ delete [] arr;
        @ return ret;
    }

