    参数 事件类型 <类型 = 整数 注释 = "元素事件.Tab***">
    {
        如果 (事件类型 == 元素事件.列表树_项模板创建)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_TEMP_CREATE, &@dt<炫彩列表树>::OnTreeTemplateCreate);
        }
        否则 (事件类型 == 元素事件.列表树_项模板创建完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_TEMP_CREATE_END, &@dt<炫彩列表树>::OnTreeTemplateCreateEnd);
        }
        否则 (事件类型 == 元素事件.列表树_项模板销毁)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_TEMP_DESTROY, &@dt<炫彩列表树>::OnTreeTemplateDestroy);
        }
        否则 (事件类型 == 元素事件.列表树_项绘制)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_DRAWITEM, &@dt<炫彩列表树>::OnTreeDrawItem);
        }
        否则 (事件类型 == 元素事件.列表树_项选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_SELECT, &@dt<炫彩列表树>::OnTreeSelect);
        }
        否则 (事件类型 == 元素事件.列表树_项展开)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_EXPAND, &@dt<炫彩列表树>::OnTreeExpand);
        }
        否则 (事件类型 == 元素事件.列表树_项正在拖动)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_DRAG_ITEM_ING, &@dt<炫彩列表树>::OnTreeDragItemIng);
        }
        否则 (事件类型 == 元素事件.列表树_项拖动完毕)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_TREE_DRAG_ITEM, &@dt<炫彩列表树>::OnTreeDragItem);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

