    方法 启用拖动文件 <公开 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部库 = "User32.lib" @视窗.外部头文件 = "<winuser.h>">
    参数 是否启用 <类型 = 逻辑型>
    {
        变量 mHwnd <类型 = 变整数>
        @ XWnd_EnableDragFiles((HWINDOW)get(), @<是否启用>);
        @ @<mHwnd> = (INT_P)XWnd_GetHWND((HWINDOW)get());
        ChangeWindowMessageFilterEx (mHwnd, 0X233, 1, 0)  // WM_DROPFILES 0x233
        ChangeWindowMessageFilterEx (mHwnd, 0x4A, 1, 0)  // VM_COPYDATA   0x04A
        ChangeWindowMessageFilterEx (mHwnd, 0x49, 1, 0)  // WM_COPYGLOBALDATA 0x49

    }

