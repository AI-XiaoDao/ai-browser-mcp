    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_SET, &@sn<current_class>::OnEditSet);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_CHANGED, &@sn<current_class>::OnEditChanged);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_POS_CHANGED, &@sn<current_class>::OnEditPosChanged);
        @     ((CVolEventReceiver*)(addr + size*2))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*3))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_STYLE_CHANGED, &@sn<current_class>::OnEditStyleChanged);
        @     ((CVolEventReceiver*)(addr + size*3))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*4))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_ENTER_GET_TABALIGN, &@sn<current_class>::OnEditEnterGetTabAlign);
        @     ((CVolEventReceiver*)(addr + size*4))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*5))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_SWAPROW, &@sn<current_class>::OnEditSwpaRow);
        @     ((CVolEventReceiver*)(addr + size*5))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();

    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.编辑框***">
    {
        如果 (事件类型 == 元素事件.编辑框_内容更改)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_CHANGED, &@dt<炫彩编辑框>::OnEditChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_置内容)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_SET, &@dt<炫彩编辑框>::OnEditSet);
        }
        否则 (事件类型 == 元素事件.编辑框_位置改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_POS_CHANGED, &@dt<炫彩编辑框>::OnEditPosChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_样式改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_STYLE_CHANGED, &@dt<炫彩编辑框>::OnEditStyleChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_回车TAB对齐)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_ENTER_GET_TABALIGN, &@dt<炫彩编辑框>::OnEditEnterGetTabAlign);
        }
        否则 (事件类型 == 元素事件.编辑框_交换行)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_SWAPROW, &@dt<炫彩编辑框>::OnEditSwpaRow);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.编辑框***">
    {
        如果 (事件类型 == 元素事件.编辑框_内容更改)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_CHANGED, &@dt<炫彩编辑框>::OnEditChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_置内容)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_SET, &@dt<炫彩编辑框>::OnEditSet);
        }
        否则 (事件类型 == 元素事件.编辑框_位置改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_POS_CHANGED, &@dt<炫彩编辑框>::OnEditPosChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_样式改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_STYLE_CHANGED, &@dt<炫彩编辑框>::OnEditStyleChanged);
        }
        否则 (事件类型 == 元素事件.编辑框_回车TAB对齐)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_ENTER_GET_TABALIGN, &@dt<炫彩编辑框>::OnEditEnterGetTabAlign);
        }
        否则 (事件类型 == 元素事件.编辑框_交换行)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_SWAPROW, &@dt<炫彩编辑框>::OnEditSwpaRow);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

