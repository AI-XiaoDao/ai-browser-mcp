类 炫彩日期框 <公开 基础类 = 元素基类 折叠 @文档 = "category = \"炫彩组件\"">
{

    # @begin
    # <>     <include>
    #        int OnDateTimeChange(HELE hEle,BOOL *pbHandled);  //定义一个回调函数 并添加到h中.
    #        int OnDateTimePopupMonthCal(HELE hEle,HWINDOW hMonthCalWnd,HELE hMonthCal,BOOL *pbHandled);
    #        int OnDateTimeExitMonthCal(HELE hEle,HWINDOW hMonthCalWnd,HELE hMonthCal,BOOL *pbHandled);
    # <>     </include>
    #     int @dt<炫彩日期框>::OnDateTimeChange(HELE hEle,BOOL *pbHandled) {
    #         set((vint)hEle);
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<日期框_内容改变>((INT_P) hEle,bHandle);
    #         *pbHandled =  bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    #     int @dt<炫彩日期框>::OnDateTimePopupMonthCal(HELE hEle,HWINDOW hMonthCalWnd,HELE hMonthCal,BOOL *pbHandled) {
    #         set((vint)hEle);
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<日期框_弹出月历>((INT_P) hEle,(INT_P)hMonthCalWnd,(INT_P)hMonthCal,bHandle);
    #         *pbHandled =  bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    #     int @dt<炫彩日期框>::OnDateTimeExitMonthCal(HELE hEle,HWINDOW hMonthCalWnd,HELE hMonthCal,BOOL *pbHandled) {
    #         set((vint)hEle);
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<日期框_退出月历>((INT_P) hEle,(INT_P)hMonthCalWnd,(INT_P)hMonthCal,bHandle);
    #         *pbHandled =  bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    # @end

    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_CHANGE, &@dt<炫彩日期框>::OnDateTimeChange);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr+size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_POPUP_MONTHCAL, &@dt<炫彩日期框>::OnDateTimePopupMonthCal);
        @     ((CVolEventReceiver*)(addr+size))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr+size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_EXIT_MONTHCAL, &@dt<炫彩日期框>::OnDateTimeExitMonthCal);
        @     ((CVolEventReceiver*)(addr+size*2))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();
    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.日期框***">
    {
        如果 (事件类型 == 元素事件.日期框_内容改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_CHANGE, &@dt<炫彩日期框>::OnDateTimeChange);
        }
        否则 (事件类型 == 元素事件.日期框_弹出月历)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_POPUP_MONTHCAL, &@dt<炫彩日期框>::OnDateTimePopupMonthCal);
        }
        否则 (事件类型 == 元素事件.日期框_退出月历)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_DATETIME_EXIT_MONTHCAL, &@dt<炫彩日期框>::OnDateTimeExitMonthCal);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 日期框_内容改变 <公开 定义事件 类型 = 整数 折叠>
    参数 日期框句柄 <类型 = 变整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真,如果拦截则不会执行炫彩内部代码.全交由用户处理">

    方法 日期框_弹出月历 <公开 定义事件 类型 = 整数 折叠>
    参数 日期框句柄 <类型 = 变整数 折叠>
    参数 月历窗口句柄 <类型 = 变整数>
    参数 月历元素句柄 <类型 = 变整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真,如果拦截则不会执行炫彩内部代码.全交由用户处理">

    方法 日期框_退出月历 <公开 定义事件 类型 = 整数 折叠>
    参数 日期框句柄 <类型 = 变整数>
    参数 月历窗口句柄 <类型 = 变整数>
    参数 月历元素句柄 <类型 = 变整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真,如果拦截则不会执行炫彩内部代码.全交由用户处理">

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.日期框***">
    {
        如果 (事件类型 == 元素事件.日期框_内容改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DATETIME_CHANGE, &@dt<炫彩日期框>::OnDateTimeChange);
        }
        否则 (事件类型 == 元素事件.日期框_弹出月历)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DATETIME_POPUP_MONTHCAL, &@dt<炫彩日期框>::OnDateTimePopupMonthCal);
        }
        否则 (事件类型 == 元素事件.日期框_退出月历)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_DATETIME_EXIT_MONTHCAL, &@dt<炫彩日期框>::OnDateTimeExitMonthCal);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    #

    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
