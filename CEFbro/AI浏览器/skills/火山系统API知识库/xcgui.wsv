    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "窗口事件.">
    {
        如果 (事件类型 == 窗口事件.绘制)
        {
            @ XWnd_RegEventCPP1((HWINDOW)get(), WM_PAINT, &@dt<窗口基类>::OnWndDrawWindow);
        }
        否则 (事件类型 == 窗口事件.关闭)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_CLOSE, &@dt<窗口基类>::OnWndClose);
        }
        否则 (事件类型 == 窗口事件.销毁)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_DESTROY, &@dt<窗口基类>::OnWndDestroy);
        }
        否则 (事件类型 == 窗口事件.鼠标移动)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_MOUSEMOVE, &@dt<窗口基类>::OnWndMouseMove);
        }
        否则 (事件类型 == 窗口事件.鼠标左键按下)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_LBUTTONDOWN, &@dt<窗口基类>::OnWndLButtonDown);
        }
        否则 (事件类型 == 窗口事件.鼠标左键弹起)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_LBUTTONUP, &@dt<窗口基类>::OnWndLButtonUp);
        }
        否则 (事件类型 == 窗口事件.鼠标右键按下)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_RBUTTONDOWN, &@dt<窗口基类>::OnWndRButtonDown);
        }
        否则 (事件类型 == 窗口事件.鼠标右键弹起)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_RBUTTONUP, &@dt<窗口基类>::OnWndRButtonUp);
        }
        否则 (事件类型 == 窗口事件.鼠标左键双击)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_LBUTTONDBLCLK, &@dt<窗口基类>::OnWndLButtonDBClick);
        }
        否则 (事件类型 == 窗口事件.鼠标右键双击)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_RBUTTONDBLCLK, &@dt<窗口基类>::OnWndRButtonDBClick);
        }
        否则 (事件类型 == 窗口事件.鼠标滚轮滚动)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_MOUSEWHEEL, &@dt<窗口基类>::OnWndMouseWheel);
        }
        否则 (事件类型 == 窗口事件.鼠标进入)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_MOUSEHOVER, &@dt<窗口基类>::OnWndMouseHover);
        }
        否则 (事件类型 == 窗口事件.鼠标离开)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_MOUSELEAVE, &@dt<窗口基类>::OnWndMouseLeave);
        }
        否则 (事件类型 == 窗口事件.尺寸改变)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_SIZE, &@dt<窗口基类>::OnWndSize);
        }
        否则 (事件类型 == 窗口事件.定时器)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_TIMER, &@dt<窗口基类>::OnWndTimer);
        }
        否则 (事件类型 == 窗口事件.获得焦点)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_SETFOCUS, &@dt<窗口基类>::OnWndSetFocus);
        }
        否则 (事件类型 == 窗口事件.失去焦点)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_KILLFOCUS, &@dt<窗口基类>::OnWndKillFocus);
        }
        否则 (事件类型 == 窗口事件.按键按下)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_KEYDOWN, &@dt<窗口基类>::OnWndKeyDown);
        }
        否则 (事件类型 == 窗口事件.鼠标捕获改变)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_CAPTURECHANGED, &@dt<窗口基类>::OnWndCaptureChanged);
        }
        否则 (事件类型 == 窗口事件.设置鼠标光标)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_SETCURSOR, &@dt<窗口基类>::OnWndSetCursor);
        }
        否则 (事件类型 == 窗口事件.输入字符)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_CHAR, &@dt<窗口基类>::OnWndChar);
        }
        否则 (事件类型 == 窗口事件.文件拖放)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_DROPFILES, &@dt<窗口基类>::OnDropFiles);
        }
        否则 (事件类型 == 窗口事件.处理过程)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_WINDPROC, &@dt<窗口基类>::OnWndProc);
        }
        否则 (事件类型 == 窗口事件.菜单弹出)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_POPUP, &@dt<窗口基类>::OnWndMenuPopup);
        }
        否则 (事件类型 == 窗口事件.菜单弹出窗口)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_POPUP_WND, &@dt<窗口基类>::OnWndMenuPopupWnd);
        }
        否则 (事件类型 == 窗口事件.菜单选择)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_SELECT, &@dt<窗口基类>::OnWndMenuSelect);
        }
        否则 (事件类型 == 窗口事件.菜单退出)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_EXIT, &@dt<窗口基类>::OnWndMenuExit);
        }
        否则 (事件类型 == 窗口事件.绘制菜单背景)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_DRAW_BACKGROUND, &@dt<窗口基类>::OnWndMenuDrawBackground);
        }
        否则 (事件类型 == 窗口事件.绘制菜单项)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_MENU_DRAWITEM, &@dt<窗口基类>::OnMenuDrawItem);
        }
        否则 (事件类型 == 窗口事件.绘制完成)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_PAINT_END, &@dt<窗口基类>::OnWndDrawWindowEnd);
        }
        否则 (事件类型 == 窗口事件.绘制完成并已显示)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_PAINT_DISPLAY, &@dt<窗口基类>::OnWndDrawWindowDisplay);
        }
        否则 (事件类型 == 窗口事件.定时器炫彩)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_XC_TIMER, &@dt<窗口基类>::OnWndXCTimer);
        }
        否则 (事件类型 == 窗口事件.位置改变)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), 0X03, &@dt<窗口基类>::OnMove);
        }
        否则 (事件类型 == 窗口事件.自定义事件)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), 10001, &@dt<窗口基类>::OnCustomevent);
        }
        否则 (事件类型 == 窗口事件.框架窗口码头弹出窗格)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_DOCK_POPUP, &@dt<窗口基类>::OnWndDocPopup);
        }
        否则 (事件类型 == 窗口事件.浮动窗口拖动)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_FLOATWND_DRAG, &@dt<窗口基类>::OnWndFloatWndDrag);
        }
        否则 (事件类型 == 窗口事件.窗格显示隐藏)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_PANE_SHOW, &@dt<窗口基类>::OnWndFloatWndDrag);
        }
        否则 (事件类型 == 窗口事件.按键弹起)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_KEYUP, &@dt<窗口基类>::OnWndKeyUp);
        }
        否则 (事件类型 == 窗口事件.系统按键按下)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), WM_SYSKEYDOWN, &@dt<窗口基类>::OnWndSYSKEYDOWN);
        }
        否则 (事件类型 == 窗口事件.获得焦点_元素)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_SETFOCUS_ELE, &@dt<窗口基类>::OnWndSYSKEYDOWN);
        }

    }

    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ addr = addr +  sizeof(NOTIFYICONDATA);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL ){
        @     XWnd_RegEventCPP1((HWINDOW)get(), WM_PAINT, &@sn<current_class>::OnWndDrawWindow);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver);}
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL ){
        @     XWnd_RegEventCPP1((HXCGUI)get(), WM_CLOSE, &@sn<current_class>::OnWndClose);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver);}
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL ){
        @     XWnd_RegEventCPP1((HXCGUI)get(), WM_DESTROY, &@dt<窗口基类>::OnWndDestroy);
