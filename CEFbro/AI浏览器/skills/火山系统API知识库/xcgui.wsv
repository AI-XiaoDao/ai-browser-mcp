    {
        @ XPGrid_HitTestOffset((HELE)@sn<this>.get(),@<pPt>.pdata(),(bool*)&@<pbExpandButton>)
    }

    方法 展开项 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
