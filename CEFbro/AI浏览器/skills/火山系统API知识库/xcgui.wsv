    方法 弹出 <公开 类型 = 逻辑型 折叠 编辑时信息 = "4732E, 0, 0, 0" @嵌入式方法 = "">
    参数 父窗口句柄 <类型 = 变整数 编辑时信息 = "4732E, 0, 0, 0">
    参数 左边 <类型 = 整数 编辑时信息 = "4732E, 0, 0, 0">
    参数 顶边 <类型 = 整数 编辑时信息 = "4732E, 0, 0, 0">
    参数 父元素句柄 <类型 = 变整数 注释 = "父元素句柄,如果该值不为NULL,hParentEle元素将接收菜单消息事件, 否则将由hParentWnd窗口接收菜单的消息事件" 编辑时信息 = "4732E, 0, 0, 0"
            @默认值 = 0>
    参数 弹出方向 <类型 = 整数 注释 = "菜单方向.弹出_***" 编辑时信息 = "4732E, 0, 0, 0" @默认值 = 菜单方向.弹出_左上角>
