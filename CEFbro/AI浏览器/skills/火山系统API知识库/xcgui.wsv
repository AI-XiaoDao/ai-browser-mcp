    参数 系统鼠标 <类型 = 逻辑型 注释 = "如为:鼠标指针.***此参数必须为假" @默认值 = 真>
    {
        如果 (系统鼠标)
        {
            @ XEle_SetCursor((HELE)get(), (HCURSOR)@<鼠标指针>);
        }
        否则
        {
            @ XEle_SetCursor((HELE)get(), (HCURSOR)LoadCursorW(0,(LPCWSTR)@<鼠标指针>));
        }

    }

