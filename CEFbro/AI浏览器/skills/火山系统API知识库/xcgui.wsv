    参数 是否启用 <类型 = 逻辑型>
    {
        @ XLayoutBox_EnableOverflowHide((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 布局盒子启用自动换行 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XLayoutBox_EnableAutoWrap ((HXCGUI)@sn<this>.get(), @<是否启用>)
    }
}

