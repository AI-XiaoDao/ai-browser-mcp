    参数 是否显示 <类型 = 逻辑型 注释 = "是否显示">
    {
        @  XWidget_Show((HXCGUI)@sn<this>.get(),@<是否显示>)
    }

    方法 ID <公开 属性写 注释 = "设置元素的ID" 折叠 @禁止流程检查 = 真>
    参数 nID <类型 = 整数>
    {
        @ XWidget_SetID((HXCGUI)get(), @<nID>);
    }

    方法 ID <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XWidget_GetID((HXCGUI)@sn<this>.get())
    }

