类 炫彩进度条 <公开 基础类 = 元素基类 折叠 @文档 = "category = \"炫彩组件\"">
{

    # @begin
    # <>     <include>
    #        int OnProgressBarChange(HELE hEle,int pos,BOOL *pbHandled);  //定义一个回调函数 并添加到h中.
    # <>     </include>
    #     int @dt<炫彩进度条>::OnProgressBarChange(HELE hEle,int pos,BOOL *pbHandled) {
    #         set((vint)hEle);
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<进度条_位置改变>((INT_P) hEle,pos,bHandle);
    #         *pbHandled =  bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    # @end

    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_PROGRESSBAR_CHANGE, &@dt<炫彩进度条>::OnProgressBarChange);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();
    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数>
    {
        如果 (事件类型 == 元素事件.进度条_位置改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_PROGRESSBAR_CHANGE, &@dt<炫彩进度条>::OnProgressBarChange);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 进度条_位置改变 <公开 定义事件 类型 = 整数 折叠>
    参数 进度条句柄 <类型 = 变整数>
    参数 位置 <类型 = 整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数>
    {
        如果 (事件类型 == 元素事件.进度条_位置改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_PROGRESSBAR_CHANGE, &@dt<炫彩进度条>::OnProgressBarChange);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    #

    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 父句柄 <类型 = 变整数>
    {
        @ @sn<this>.set((vint)XProgBar_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, (HXCGUI)@<父句柄>))
    }

    方法 进度 <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XProgBar_GetPos((HELE)@sn<this>.get())
    }

    方法 进度 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 pos <类型 = 整数>
    {
        @ XProgBar_SetPos((HELE)get(), @<pos>);

    }

    方法 范围 <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XProgBar_GetRange((HELE)@sn<this>.get())
    }

    方法 范围 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 range <类型 = 整数>
    {
        @ XProgBar_SetRange((HELE)get(), @<range>);

    }

    方法 启用水平 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XProgBar_EnableHorizon((HELE)@sn<this>.get(), @<是否启用>)
    }

    方法 置进度图片 <公开 折叠 @嵌入式方法 = "">
    参数 图片对象 <类型 = 炫彩图片>
    {
        @ XProgBar_SetImageLoad((HELE)@sn<this>.get(), @<图片对象>.GetP())
    }

    方法 置进度颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XProgBar_SetColorLoad((HELE)@sn<this>.get(),  COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 显示文本 <公开 折叠 @嵌入式方法 = "">
    参数 是否显示 <类型 = 逻辑型>
    {
        @ XProgBar_EnableShowText((HELE)@sn<this>.get(), @<是否显示>)
    }
}

