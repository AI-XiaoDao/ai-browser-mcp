    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_CREATE, &@sn<current_class>::OnListTemplateCreate);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_CREATE_END, &@sn<current_class>::OnListTemplateCreateEnd);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_DESTROY, &@sn<current_class>::OnListTemplateDestroy);
        @     ((CVolEventReceiver*)(addr + size*2))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*3))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_DRAWITEM, &@sn<current_class>::OnListDrawItem);
        @     ((CVolEventReceiver*)(addr + size*3))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*4))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_SELECT, &@sn<current_class>::OnListSelect);
        @     ((CVolEventReceiver*)(addr + size*4))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*5))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_DRAWITEM, &@sn<current_class>::OnListHeaderDrawItem);
        @     ((CVolEventReceiver*)(addr + size*5))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*6))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_CLICK, &@sn<current_class>::OnListHeaderClick);
        @     ((CVolEventReceiver*)(addr + size*6))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*7))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_WIDTH_CHANGE, &@sn<current_class>::OnListHeaderItemWidthChange);
        @     ((CVolEventReceiver*)(addr + size*7))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*8))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE, &@sn<current_class>::OnListHeaderTemplateCreate);
        @     ((CVolEventReceiver*)(addr + size*8))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*9))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE_END, &@sn<current_class>::OnListHeaderTemplateCreateEnd);
        @     ((CVolEventReceiver*)(addr + size*9))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*10))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_DESTROY, &@sn<current_class>::OnListHeaderTemplateDestroy);
        @     ((CVolEventReceiver*)(addr + size*10))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();
    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.列表***">
    {
        如果 (事件类型 == 元素事件.列表_项模板创建)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_CREATE, &@dt<炫彩列表>::OnListTemplateCreate);
        }
        否则 (事件类型 == 元素事件.列表_项模板创建完成)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_CREATE_END, &@dt<炫彩列表>::OnListTemplateCreateEnd);
        }
        否则 (事件类型 == 元素事件.列表_项模板销毁)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_TEMP_DESTROY, &@dt<炫彩列表>::OnListTemplateDestroy);
        }
        否则 (事件类型 == 元素事件.列表_项绘制)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_DRAWITEM, &@dt<炫彩列表>::OnListDrawItem);
        }
        否则 (事件类型 == 元素事件.列表_项选择)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_SELECT, &@dt<炫彩列表>::OnListSelect);
        }
        否则 (事件类型 == 元素事件.列表头_项绘制)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_DRAWITEM, &@dt<炫彩列表>::OnListHeaderDrawItem);
        }
        否则 (事件类型 == 元素事件.列表头_项点击)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_CLICK, &@dt<炫彩列表>::OnListHeaderClick);
        }
        否则 (事件类型 == 元素事件.列表头_项宽度改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_WIDTH_CHANGE, &@dt<炫彩列表>::OnListHeaderItemWidthChange);
        }
        否则 (事件类型 == 元素事件.列表头_项模板创建)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE, &@dt<炫彩列表>::OnListHeaderTemplateCreate);
        }
        否则 (事件类型 == 元素事件.列表头_项模板创建完成)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE_END, &@dt<炫彩列表>::OnListHeaderTemplateCreateEnd);
        }
        否则 (事件类型 == 元素事件.列表头_项模板销毁)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_LIST_HEADER_TEMP_DESTROY, &@dt<炫彩列表>::OnListHeaderTemplateDestroy);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 列表_项模板创建 <公开 定义事件 类型 = 整数 折叠>
    参数 列表句柄 <类型 = 变整数>
