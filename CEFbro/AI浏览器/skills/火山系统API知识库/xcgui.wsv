    }

    方法 置位置 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 hWndInsertAfter <类型 = 变整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 uFlags <类型 = 整数>
    {
        @ XWnd_SetWindowPos((HWINDOW)@sn<this>.get(),(HWND)@<hWndInsertAfter>, @<左边>, @<顶边>, @<宽度>, @<高度>, @<uFlags>)
    }

    方法 坐标_客户区到屏幕 <公开 @禁止流程检查 = 真>
    参数 坐标 <类型 = 坐标_xc>
    {
        @ POINT *rc = @<坐标>.pdata ();
        @ XWnd_ClientToScreen((HWINDOW)get(), rc);
        @ @<坐标.横坐标>(rc->x);
        @ @<坐标.纵坐标>(rc->y);
    }

    方法 坐标_屏幕到客户区 <公开 折叠 @禁止流程检查 = 真>
    参数 坐标 <类型 = 坐标_xc>
    {
        @ POINT *rc = @<坐标>.pdata ();
        @ XWnd_ScreenToClient((HWINDOW)get(),rc);
        @ @<坐标.横坐标>(rc->x);
        @ @<坐标.纵坐标>(rc->y);
    }

    方法 取DPI <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XWnd_GetDPI((HWINDOW)@sn<this>.get())
    }

    方法 置DPI <公开 @嵌入式方法 = "">
    参数 nDPI <类型 = 整数>
    {
        @ XWnd_SetDPI((HWINDOW)@sn<this>.get(),@<nDPI>)
    }

    方法 矩形到DPI <公开 折叠 @禁止流程检查 = 真>
    参数 矩形 <类型 = 矩形_xc>
    {
        @ RECT *rc = @<矩形>.pdata ();
        @ XWnd_RectToDPI((HWINDOW)get(),rc);
        @ @<矩形.左边>(rc->left);
        @ @<矩形.顶边>(rc->top);
        @ @<矩形.右边>(rc->right);
        @ @<矩形.底边>(rc->bottom);
    }

    方法 坐标到DPI <公开 折叠 @禁止流程检查 = 真>
    参数 坐标 <类型 = 坐标_xc>
    {
        @ POINT *rc = @<坐标>.pdata ();
        @ XWnd_PointToDPI((HWINDOW)get(),rc);
        @ @<坐标.横坐标>(rc->x);
        @ @<坐标.纵坐标>(rc->y);
    }

    方法 取光标位置 <公开 类型 = 逻辑型 @禁止流程检查 = 真>
    参数 坐标 <类型 = 坐标_xc>
    {
        @ return XWnd_GetCursorPos((HWINDOW)get(),@<坐标>.pdata ());
    }
}

类 普通窗口 <公开 基础类 = 窗口基类 折叠 折叠2 @输出名 = "XWnd" @文档 = "category = \"炫彩窗口\"">
