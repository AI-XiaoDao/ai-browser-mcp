    参数 是否启用 <类型 = 逻辑型>
    {
        @ XModalWnd_EnableEscClose((HWINDOW)@sn<this>.get(), @<是否启用>)
    }

    方法 结束 <公开 折叠 @嵌入式方法 = "">
    参数 值 <类型 = 整数 注释 = "由 启动 方法返回的值">
    {
        @ XModalWnd_EndModal((HWINDOW)@sn<this>.get(), @<值>)
    }
}

类 框架窗口 <公开 基础类 = 窗口基类 @文档 = "category = \"炫彩窗口\"">
{

    # @begin
    # <>     <include>
    #        int OnWndFloatPane(HWINDOW hWindow, HWINDOW hFloatWnd, HELE hPane, BOOL *pbHandled);  //浮动窗格, 窗格从框架窗口中弹出,变成浮动窗格
    #         int OnWndLayoutViewRect(HWINDOW hWindow,int width, int height, BOOL *pbHandled);
    # <>     </include>
    #     int @dt<框架窗口>::OnWndFloatPane(HWINDOW hWindow, HWINDOW hFloatWnd, HELE hPane, BOOL *pbHandled) {
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<框架窗口_浮动窗格>  ((INT_P)hWindow,@dt<浮动窗口>(hFloatWnd),(INT_P)hPane,bHandle);
    #         *pbHandled = bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    #     int @dt<框架窗口>::OnWndLayoutViewRect(HWINDOW hWindow, int width, int height,BOOL *pbHandled) {
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         @<框架窗口_主视图坐标改变> ((INT_P)hWindow,width,height,bHandle);
    #         *pbHandled = bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    #
    # @end

    方法 框架窗口_浮动窗格 <公开 定义事件 类型 = 整数 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 浮动窗口 <类型 = 浮动窗口>
    参数 元素句柄 <类型 = 变整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 框架窗口_主视图坐标改变 <公开 定义事件 类型 = 整数 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        // @ addr = addr +  sizeof(NOTIFYICONDATA);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL ){
        @     XWnd_RegEventCPP1((HXCGUI)get(), XWM_FLOAT_PANE, &@dt<框架窗口>::OnWndFloatPane);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver);}
        @ if ( pEventReceiver != NULL ){
        @     XWnd_RegEventCPP1((HXCGUI)get(), XWM_BODYVIEW_RECT, &@dt<框架窗口>::OnWndLayoutViewRect);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver);}
        @ __super::@<自动注册事件>();

    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数>
    {
        如果 (事件类型 == 窗口事件.窗格浮动)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_FLOAT_PANE, &@dt<框架窗口>::OnWndFloatPane);
        }
        否则 (事件类型 == 窗口事件.主视图坐标改变)
        {
            @ XWnd_RegEventCPP1((HXCGUI)get(), XWM_BODYVIEW_RECT, &@dt<框架窗口>::OnWndLayoutViewRect);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }
    }

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数>
    {
        如果 (事件类型 == 窗口事件.窗格浮动)
        {
            @ XWnd_RemoveEventCPP((HXCGUI)get(), XWM_FLOAT_PANE, &@dt<框架窗口>::OnWndFloatPane);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 挂接窗口 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 窗口句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()">
    参数 库样式 <类型 = 整数 @默认值 = 窗口样式.默认>
    {
        @ @sn<this>.set((vint)XFrameWnd_Attach((HWND)@<窗口句柄>,@<库样式>))
    }

    方法 创建 <公开 类型 = 变整数 返回值注释 = "HWINDOW" 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数 @默认值 = 0>
    参数 顶边 <类型 = 整数 @默认值 = 0>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 标题 <类型 = 文本型>
    参数 父句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 库样式 <类型 = 整数 注释 = "窗口样式.**" @默认值 = 窗口样式.默认>
    {
        @ @sn<this>.set((vint)XFrameWnd_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, @<标题>.GetText (), (HWND)@<父句柄>, @<库样式>))
    }

    方法 创建扩展 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 扩展风格 <类型 = 整数>
    参数 窗口类名 <类型 = 文本型>
    参数 窗口标题 <类型 = 文本型>
    参数 窗口风格 <类型 = 整数>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 父句柄 <类型 = 变整数 注释 = "对象.取窗口句柄()" @默认值 = 0>
    参数 库样式 <类型 = 整数 注释 = "窗口样式.**" @默认值 = 窗口样式.默认>
    {
        @ @sn<this>.set((vint)XFrameWnd_CreateEx(@<扩展风格>, @<窗口风格>,@<窗口类名>.GetText (),@<左边>, @<顶边>, @<宽度>, @<高度>,@<窗口标题>.GetText (), (HWND)@<父句柄>, @<库样式>))
    }

    方法 添加窗格 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 目标窗格 <类型 = 变整数>
    参数 当前窗格 <类型 = 变整数>
    参数 对齐方式 <类型 = 整数 注释 = "窗格对齐.***">
    {
        @ XFrameWnd_AddPane((HWINDOW)@sn<this>.get(), (HELE)@<目标窗格>,  (HELE)@<当前窗格>,(pane_align_) @<对齐方式>)
    }

    方法 取布局区域坐标 <公开 折叠 @嵌入式方法 = "">
    参数 矩形 <类型 = 矩形_xc 注释 = "返回">
    {
        @ XFrameWnd_GetLayoutAreaRect((HWINDOW)@sn<this>.get(), @<矩形>.pdata())
    }

    方法 加载布局文件 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 窗格句柄数组 <类型 = 变整数 注释 = "窗格句柄数组">
    参数 窗格数量 <类型 = 整数 注释 = "窗格数量.">
    参数 文件名 <类型 = 文本型 注释 = "文件名，如果文件名为空，将使用默认文件名frameWnd_layout.xml.">
    {
        @ XFrameWnd_LoadLayoutFile((HWINDOW )@sn<this>.get(), (HELE*)@<窗格句柄数组>, @<窗格数量>, @<文件名>.GetText ())
    }

    方法 合并窗格 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 目标窗格 <类型 = 变整数>
    参数 当前窗格 <类型 = 变整数>
    {
        @ XFrameWnd_MergePane((HWINDOW)@sn<this>.get(), (HELE)@<目标窗格>, (HELE)@<当前窗格>)
    }

    方法 保存布局到文件 <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 文件名 <类型 = 文本型 注释 = "如果文件名为空，将使用默认文件名frameWnd_layout.xml" @默认值 = 空对象>
    {
        @ XFrameWnd_SaveLayoutToFile((HWINDOW)@sn<this>.get(), @<文件名>.GetText ())
    }

    方法 置窗格分隔条颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XFrameWnd_SetPaneSplitBarColor((HWINDOW)@sn<this>.get(), COLORREF_MAKE2(@<颜色>,(BYTE)@<透明度>))
    }

    方法 置窗格分隔条宽度 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    {
        @ XFrameWnd_SetPaneSplitBarWidth((HWINDOW)@sn<this>.get(), @<宽度>)
    }

    方法 取窗格分隔条宽度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XFrameWnd_GetPaneSplitBarWidth((HWINDOW)@sn<this>.get())
    }

    方法 置TAB条高度 <公开 注释 = "设置窗格组TabBar高度" 折叠 @嵌入式方法 = "">
    参数 高度 <类型 = 整数>
    {
        @ XFrameWnd_SetTabBarHeight((HWINDOW)@sn<this>.get(),@<高度>)
    }

    方法 置布局外间距 <公开 注释 = "窗格区域布局的外间距" 折叠 @嵌入式方法 = "">
    参数 左边间隔 <类型 = 整数>
    参数 顶边间隔 <类型 = 整数>
    参数 右边间隔 <类型 = 整数>
    参数 底边间隔 <类型 = 整数>
    {
        @ XFrameWnd_SetLayoutMargin((HWINDOW)@sn<this>.get(),@<左边间隔>,@<顶边间隔>,@<右边间隔>,@<底边间隔>)
    }

    方法 置视图 <公开 注释 = "设置主视图元素" 折叠 @嵌入式方法 = "">
    参数 元素句柄 <类型 = 变整数>
    {
        @ XFrameWnd_SetView((HWINDOW)@sn<this>.get(),(HELE) @<元素句柄>)
    }

    方法 取拖动窗格停留位置标识 <公开 类型 = 整数 注释 = "取拖动浮动窗格停留位置标识" 返回值注释 = "返回 拖动窗格 所处框架窗口单元格标识:框架窗口单元格标识.**" 折叠 @嵌入式方法 = "">
    {
        @ XFrameWnd_GetDragFloatWndTopFlag((HWINDOW)@sn<this>.get())
    }

    方法 取主视图坐标 <公开 折叠 @嵌入式方法 = "">
    参数 矩形 <类型 = 矩形_xc>
    {
        @ XFrameWnd_GetViewRect((HWINDOW)@sn<this>.get(), @<矩形>.pdata())
    }

    方法 取码头 <公开 类型 = 变整数 注释 = "获取框架窗口停靠码头元素, 若是没有返回空" 返回值注释 = "返回码头句柄, 类型为基础元素" @嵌入式方法 = "">
    参数 码头编号 <类型 = 整数 注释 = "1:左侧码头, 2:顶部码头, 3:右侧码头, 4:底部码头">
    {
        @ return (@dt<变整数>)XFrameWnd_GetDock((HWINDOW)@sn<this>.get(), @<码头编号>)
    }
}

类 浮动窗口 <公开 基础类 = 窗口基类 折叠 @文档 = "category = \"炫彩窗口\"">
{

    # @begin
    # <> <include>
    # public:
    #     inline_ @sn<current_class>(HWINDOW Window):@sn<current_class>()    {
    #         data().SetP((vint)Window);
    #     }
    # <>  </include>
    # @end

    方法 启用关闭按钮 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型 @默认值 = 真>
    {
        @ XFloatWnd_EnableCaptionContent((HWINDOW)@sn<this>.get(),@<是否启用>)
    }

    方法 取布局句柄 <公开 类型 = 变整数 返回值注释 = "返回布局元素句柄" 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)XFloatWnd_GetCaptionLayout((HWINDOW)@sn<this>.get())
    }

    方法 取标题句柄 <公开 类型 = 变整数 返回值注释 = "返回形状文本句柄" 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)XFloatWnd_GetCaptionShapeText((HWINDOW)@sn<this>.get())
    }

    方法 取关闭按钮 <公开 类型 = 炫彩按钮 返回值注释 = "返回按钮" @嵌入式方法 = "">
    {
        @ @dt<炫彩按钮>((vint)XFloatWnd_GetCaptionButtonClose((HWINDOW)@sn<this>.get()))
    }

    方法 置标题 <公开 折叠 @嵌入式方法 = "">
    参数 标题 <类型 = 文本型>
    {
        @ XFloatWnd_SetTitle((HWINDOW)@sn<this>.get(),@<标题>.GetText())
    }

    方法 取标题 <公开 类型 = 文本型 折叠 @嵌入式方法 = "">
    {
        @ @an<CVolString> (XFloatWnd_GetTitle((HWINDOW)@sn<this>.get()))
    }
}

