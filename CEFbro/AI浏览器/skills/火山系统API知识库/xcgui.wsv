    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_MODIFY_ROWS, &@dt<炫彩代码框>::OnEditChangeRows);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_SETBREAKPOINT, &@dt<炫彩代码框>::OnEditorSetBreakpoint);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*2))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_REMOVEBREAKPOINT, &@dt<炫彩代码框>::OnEditorRemoveBreakpoint);
        @     ((CVolEventReceiver*)(addr + size*2))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*3))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @    XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_ROW_CHANGED, &@dt<炫彩代码框>::OnEditorBreakpointChanged);
        @     ((CVolEventReceiver*)(addr + size*3))->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size*4))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_AUTOMATCH_SELECT, &@dt<炫彩代码框>::OnEditorAutoMatchSelect);
        @     ((CVolEventReceiver*)(addr + size*4))->sEndSendEvent (pEventReceiver); }
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_SETBOOKMARK, &@dt<炫彩代码框>::OnEditorSetBookmark);
        @     ((CVolEventReceiver*)(addr + size*4))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();
    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.代码框***">
    {
        如果 (事件类型 == 元素事件.代码框_多行内容改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_MODIFY_ROWS, &@dt<炫彩代码框>::OnEditChangeRows);
        }
        否则 (事件类型 == 元素事件.代码框_设置断点)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_SETBREAKPOINT, &@dt<炫彩代码框>::OnEditorSetBreakpoint);
        }
        否则 (事件类型 == 元素事件.代码框_移除断点)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_REMOVEBREAKPOINT, &@dt<炫彩代码框>::OnEditorRemoveBreakpoint);
        }
        否则 (事件类型 == 元素事件.代码框_断点改变)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDIT_ROW_CHANGED, &@dt<炫彩代码框>::OnEditorBreakpointChanged);
        }
        否则 (事件类型 == 元素事件.代码框_自动选择)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_AUTOMATCH_SELECT, &@dt<炫彩代码框>::OnEditorAutoMatchSelect);
        }
        否则 (事件类型 == 元素事件.代码框_自动选择)
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_EDITOR_SETBOOKMARK, &@dt<炫彩代码框>::OnEditorSetBookmark);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.代码框***">
    {
        如果 (事件类型 == 元素事件.代码框_多行内容改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDITOR_MODIFY_ROWS, &@dt<炫彩代码框>::OnEditChangeRows);
        }
        否则 (事件类型 == 元素事件.代码框_设置断点)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDITOR_SETBREAKPOINT, &@dt<炫彩代码框>::OnEditorSetBreakpoint);
        }
        否则 (事件类型 == 元素事件.代码框_移除断点)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDITOR_REMOVEBREAKPOINT, &@dt<炫彩代码框>::OnEditorRemoveBreakpoint);
        }
        否则 (事件类型 == 元素事件.代码框_断点改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDIT_ROW_CHANGED, &@dt<炫彩代码框>::OnEditorBreakpointChanged);
        }
        否则 (事件类型 == 元素事件.代码框_自动选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_EDITOR_AUTOMATCH_SELECT, &@dt<炫彩代码框>::OnEditorAutoMatchSelect);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

