    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.组合框***">
    {
        如果 (事件类型 == 元素事件.组合框_项选择)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_COMBOBOX_SELECT, &@dt<炫彩组合框>::OnComboBoxSelect);
        }
        否则 (事件类型 == 元素事件.组合框_项选择完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_COMBOBOX_SELECT_END, &@dt<炫彩组合框>::OnComboBoxSelectEnd);
        }
        否则 (事件类型 == 元素事件.组合框_弹出列表)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_COMBOBOX_POPUP_LIST, &@dt<炫彩组合框>::OnComboBoxPopupList);
        }
        否则 (事件类型 == 元素事件.组合框_退出列表)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_COMBOBOX_EXIT_LIST, &@dt<炫彩组合框>::OnComboBoxExitList);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

