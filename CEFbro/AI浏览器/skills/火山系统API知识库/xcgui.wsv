类 炫彩按钮 <公开 基础类 = 元素基类 折叠 折叠2 @文档 = "category = \"炫彩组件\"" @输出名 = "xcann">
{

    # @begin
    # <>     <include>
    #         int OnBtnClick (HELE hEle,BOOL *pbHandled);  //定义一个回调函数 并添加到h中.
    #         int OnButtonCheck(HELE hEle,BOOL bCheck,BOOL *pbHandled);
    # public:
    # //构造函数  可以用于 强转 @dt<***>
    #     inline_ @sn<current_class>(vint hEle):@sn<current_class>()    {
    #         data().SetP(hEle);  
    #     }
    # <>     </include>
    #     int @dt<炫彩按钮>::OnBtnClick (HELE hEle, BOOL *pbHandled) {
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         set((vint)hEle);
    #         @<按钮_点击> ((INT_P)hEle, bHandle);
    #         *pbHandled = bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    #     int @dt<炫彩按钮>::OnButtonCheck (HELE hEle,BOOL bCheck,BOOL *pbHandled) {
    #         @dt<逻辑型类> bHandle;
    #         bHandle.@n<逻辑型类.值> = (*pbHandled);
    #         set((vint)hEle);
    #         @<按钮_选中> ((INT_P)hEle,(BOOL) bCheck,bHandle);
    #         *pbHandled = bHandle.@n<逻辑型类.值>;
    #         return 0;
    # }
    # @end

    方法 自动注册事件 <公开 注释 = "按需,无需手动调用,如不用设计器生成可调用" 折叠 @虚拟方法 = 可覆盖>
    {
        @ vint addr = (vint)this + sizeof( @sn<base_class>);
        @ UINT size = sizeof( CVolEventReceiver);
        @ VOID_FUNC fnReceiver;
        @ CVolEventObjectPointer* pEventReceiver;
        @ INT  nTagNumber;
        @ pEventReceiver = ((CVolEventReceiver*)addr)->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_BNCLICK, &@sn<current_class>::OnBtnClick);
        @     ((CVolEventReceiver*)addr)->sEndSendEvent (pEventReceiver); }
        @ pEventReceiver = ((CVolEventReceiver*)(addr + size))->BeginSendEvent(&fnReceiver, &nTagNumber );
        @ if ( pEventReceiver != NULL) {
        @     XEle_RegEventCPP1((HXCGUI)get(), XE_BUTTON_CHECK, &@sn<current_class>::OnButtonCheck);
        @     ((CVolEventReceiver*)(addr + size))->sEndSendEvent (pEventReceiver); }
        @ __super::@<自动注册事件>();

    }

    方法 注册事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.***">
    {
        如果 (事件类型 == 元素事件.按钮_点击)  // 按钮点击事件
        {
            // @ XCGUI_RegEventCPP_t((HXCGUI)get(), XE_BNCLICK, 0, TRUE, this, &@dt<炫彩按钮>::OnBtnClick, (char *)"OnBtnClick");
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_BNCLICK, &@dt<炫彩按钮>::OnBtnClick);
        }
        否则 (事件类型 == 元素事件.按钮_选中)  // 按钮点击事件
        {
            @ XEle_RegEventCPP1((HXCGUI)get(), XE_BUTTON_CHECK, &@dt<炫彩按钮>::OnButtonCheck);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    方法 按钮_点击 <公开 定义事件 类型 = 整数 折叠>
    参数 按钮句柄 <类型 = 变整数>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 按钮_选中 <公开 定义事件 类型 = 整数 折叠>
    参数 按钮句柄 <类型 = 变整数>
    参数 是否选中 <类型 = 逻辑型>
    参数 是否拦截 <类型 = 逻辑型类 注释 = "是否拦截.值=真">

    方法 移除事件 <公开 折叠 @虚拟方法 = 可覆盖>
    参数 事件类型 <类型 = 整数 注释 = "元素事件.***">
    {
        如果 (事件类型 == 元素事件.按钮_点击)  // 按钮点击事件
        {
            // @ XCGUI_RegEventCPP_t((HXCGUI)get(), XE_BNCLICK, 0, TRUE, this, &@dt<炫彩按钮>::OnBtnClick, (char *)"OnBtnClick");
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_BNCLICK, &@dt<炫彩按钮>::OnBtnClick);
        }
        否则 (事件类型 == 元素事件.按钮_选中)  // 按钮点击事件
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_BUTTON_CHECK, &@dt<炫彩按钮>::OnButtonCheck);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

    #

