    方法 取全部选择项 <公开 类型 = 整数 返回值注释 = "返回接收项数量." 折叠 @禁止流程检查 = 真>
    参数 项数组 <类型 = 整数数组类 注释 = "接收的数组">
    {
        @ int Count = XListBox_GetSelectCount((HELE)get());
        @ int *pArray = new int[Count];
        @ int hr = XListBox_GetSelectAll((HELE)get(), pArray, Count);
        @ @<项数组>.data ().InitCount (hr, FALSE);
        @ for (int i=0; i < hr; i++ ) {
        @ @<项数组>.data ().SetAt (i, pArray[i]);
        @ }
        @ delete [] pArray;
        @ return hr;
    }

