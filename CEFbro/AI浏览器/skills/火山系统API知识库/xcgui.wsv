        @ XPGrid_AddItemEle((HELE)@sn<this>.get(),(HELE)@<hElePanel>,@<nParentID>)
    }

    方法 删除全部 <公开 折叠 @嵌入式方法 = "">
    {
        @ XPGrid_DeleteAll((HELE)@sn<this>.get())
    }

    方法 取项元素 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 nParentID <类型 = 整数 注释 = "炫彩ID.**" @默认值 = 炫彩ID.根节点>
