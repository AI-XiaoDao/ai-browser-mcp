        否则 (事件类型 == 元素事件.列表头_项宽度改变)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LIST_HEADER_WIDTH_CHANGE, &@dt<炫彩列表>::OnListHeaderItemWidthChange);
        }
        否则 (事件类型 == 元素事件.列表头_项模板创建)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE, &@dt<炫彩列表>::OnListHeaderTemplateCreate);
        }
        否则 (事件类型 == 元素事件.列表头_项模板创建完成)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LIST_HEADER_TEMP_CREATE_END, &@dt<炫彩列表>::OnListHeaderTemplateCreateEnd);
        }
        否则 (事件类型 == 元素事件.列表头_项模板销毁)
        {
            @ XEle_RemoveEventCPP((HXCGUI)get(), XE_LIST_HEADER_TEMP_DESTROY, &@dt<炫彩列表>::OnListHeaderTemplateDestroy);
        }
        否则
        {
            @ __super::@<注册事件>(@<事件类型>);
        }

    }

