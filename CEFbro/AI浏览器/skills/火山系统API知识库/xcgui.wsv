    方法 取全部选择行 <公开 类型 = 整数 返回值注释 = "返回接收项数量." 折叠 @禁止流程检查 = 真>
    参数 行数组 <类型 = 整数数组类 注释 = "接收的数组">
    {
        @ int Count1 = XList_GetSelectItemCount((HELE)get());
        @ int *pArray = new int[Count1];
        @ int ret = XList_GetSelectAll((HELE)get(), pArray, Count1);
        @ @<行数组>.data ().InitCount (ret, FALSE);
        @ for(int i=0; i<ret; i++) {
        @ @<行数组>.data().SetAt (i, pArray[i]);
        // @ DebugTrace (FALSE, 0, 0, _T ("n"), pArray[i]);
        @ }
        @ delete [] pArray;
        @ return ret;
    }

