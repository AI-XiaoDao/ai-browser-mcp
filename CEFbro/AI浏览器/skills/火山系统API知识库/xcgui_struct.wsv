<火山程序 类型 = "通常" 版本 = 1 />

包 xc.gui <@文档 = "category = \"数据类型\"">

类 单精度小数坐标数组类 <公开 基础类 = 对象数组模板类 @模板实现类 = "单精度小数坐标_xc">

类 坐标数组 <公开 折叠 "">
{
    变量 字节集 <类型 = 字节集类>

    方法 加入坐标成员 <公开 折叠>
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    {
        字节集.添加值到字节集 (x)
        字节集.添加值到字节集 (y)
    }

    方法 取成员数 <公开 类型 = 整数 折叠>
    {
        返回 (字节集.取字节集长度 () / 8)
    }

    方法 取数组指针 <公开 类型 = 变整数 折叠>
    {
        返回 (字节集.取字节集指针 ())
    }

    方法 清空 <公开>
    {
        字节集.清空字节集 ()
    }

    #
}

