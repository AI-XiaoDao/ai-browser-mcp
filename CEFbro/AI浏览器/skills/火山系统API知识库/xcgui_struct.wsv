类 编辑框_数据_结构 <公开 基础类 = 结构基础类 注释 = "edit_data_copy_" 折叠>
{

    # @ @m<DECLARE_STRUCT_CLASS> (edit_data_copy_)

    方法 内容数量 <公开 属性读 类型 = 整数 注释 = " nCount" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->nCount
    }

    方法 内容数量 <公开 属性写 注释 = " nCount" 折叠>
    参数 数量 <类型 = 整数>
    {
        @ pdata ()->nCount = @<数量>;
    }

    方法 样式数量 <公开 属性读 类型 = 整数 注释 = "nStyleCount" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->nStyleCount
    }

    方法 样式数量 <公开 属性写 注释 = "nStyleCount" 折叠>
    参数 Count <类型 = 整数>
    {
        @ pdata ()->nStyleCount = @<Count>;
    }

    方法 样式数组 <公开 属性读 类型 = 编辑框_数据_样式数组 折叠 @禁止流程检查 = 真>
    {
        变量 数组 <类型 = 编辑框_数据_样式数组>
        @ for (int i = 0; i < pdata ()->nStyleCount; i++)  {
        // @ @<样式结构> = pdata ()->pStyle[i];
        @ @<数组>.Add ((@dt<编辑框_数据_样式结构>)pdata ()->pStyle[i],NULL);
        // @  pdata ()->pStyle[i].hFont_image_obj;
        // @ DebugTrace (FALSE, 0, 0, _T ("nnn"), pdata ()->pStyle[i].hFont_image_obj, pdata ()->pStyle[i].color, pdata ()->pStyle[i].bColor);
        @ }
        @ return @<数组>;
    }

    方法 样式数组 <公开 属性写 折叠>
    参数 样式结构 <类型 = 编辑框_数据_样式数组>
    {
        变量 style <类型 = 编辑框_数据_样式结构>
        @ int Count = @<样式结构>.GetCount();
        @ edit_data_copy_style_* data_style = new(edit_data_copy_style_[Count]);
        @ for (int i = 0; i < Count; i++)  {
        @ @<style> = @dt<编辑框_数据_样式结构>(&@<样式结构>.GetAt(i));
        @ data_style[i].hFont_image_obj = @<style>.pdata()->hFont_image_obj;
        @ data_style[i].color = @<style>.pdata()->color;
        @ data_style[i].bColor = @<style>.pdata()->bColor;
        @ }
        @ pdata ()->pStyle = data_style;
        @ delete []data_style;
        // @ @m<SET_STRUCT_MEMBER> (pStyle, data_style);
    }

    方法 内容数组 <公开 属性读 类型 = 整数 @嵌入式方法 = "">
    {
        // 1. 转火山字节集
        // CVolMem men = CVolMem (pData, sizeof(UINT) * nCount);
        // men.AddValue_SHORT((SHORT)*pdata ()->pData);
        // 2. 转整数数组类
        // @ @dt<变整数数组类> intArr;
        // @ for (INT i = 0; i < pdata ()->nCount; i++) {
        // // @        intArr.data().Add((INT_P)pdata ()->pData++);
        // // @ DebugTrace (FALSE, 0, 0, _T ("SSnS"),  _T("内容数组数据"),(const TCHAR*)pdata ()->pData++,i,(const TCHAR*)intArr.data ().GetAt (i));
        // @ }
        // @ DebugTrace (FALSE, 0, 0, _T ("SS"),  _T("内容数组数据"),(const TCHAR*)intArr.data ().GetAt (0));
        // 3.字节数组类
        // @ dt<字节数组类> men;
        // @ men.data().Append((S_BYET*)pdata ()->pData,2);
        @ (INT)@sn<this>.pdata ()->pData

    }

    方法 内容数组 <公开 属性写 注释 = "">
    参数 Data <类型 = 整数>
    {
        @ pdata ()->pData = (UINT *)@<Data>;
    }
}

