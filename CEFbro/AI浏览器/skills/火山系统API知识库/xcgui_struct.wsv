类 属性框_项结构 <公开 基础类 = 结构基础类 注释 = "propertyGrid_item_" 折叠>
{

    # @ @m<DECLARE_STRUCT_CLASS> (propertyGrid_item_)

    方法 类型 <公开 属性读 类型 = 整数 注释 = "属性网格项类型.**" 折叠 @嵌入式方法 = "">
    {
        @ (int)@sn<this>.pdata ()->nType
    }

    方法 类型 <公开 属性写 注释 = "属性网格项类型.**" 折叠>
    参数 值 <类型 = 整数>
    {
        @ pdata ()->nType = (propertyGrid_item_type_)@<值>;
    }

    方法 项ID <公开 属性读 类型 = 整数 注释 = "" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->nID
    }

    方法 项ID <公开 属性写 注释 = "" 折叠>
    参数 值 <类型 = 整数>
    {
        @ pdata ()->nID = @<值>;
    }

    方法 深度 <公开 属性读 类型 = 整数 注释 = "" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->nDepth
    }

    方法 深度 <公开 属性写 注释 = "" 折叠>
    参数 值 <类型 = 整数>
    {
        @ pdata ()->nDepth = @<值>;
    }

    方法 用户绑定数据 <公开 属性读 类型 = 变整数 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.pdata ()->nUserData
    }

    方法 用户绑定数据 <公开 属性写 注释 = "" 折叠>
    参数 数据 <类型 = 变整数>
    {
        @ pdata ()->nUserData = (vint)@<数据 >;
    }

    方法 名称列宽度 <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->nNameColWidth
    }

    方法 名称列宽度 <公开 属性写 折叠>
    参数 宽度 <类型 = 整数>
    {
        @ pdata ()->nNameColWidth = @<宽度>;
    }

    方法 项坐标 <公开 属性读 类型 = 矩形_xc 折叠 @禁止流程检查 = 真>
    {
        @ return pdata ()->rcItem;
    }

    方法 项坐标 <公开 属性写 折叠>
    参数 所欲设置坐标 <类型 = 矩形_xc 注释 = "矩形_xc">
    {
        @ @m<SET_STRUCT_MEMBER> (rcItem, @<所欲设置坐标>);
    }

    方法 展开坐标 <公开 属性读 类型 = 矩形_xc 折叠 @禁止流程检查 = 真>
    {
        @ return pdata ()->rcExpand;
    }

    方法 展开坐标 <公开 属性写 折叠>
    参数 所欲设置坐标 <类型 = 矩形_xc 注释 = "矩形_xc">
    {
        @ @m<SET_STRUCT_MEMBER> (rcExpand, @<所欲设置坐标>);
    }

    方法 是否展开 <公开 属性读 类型 = 逻辑型 注释 = "" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.pdata ()->bExpand
    }

    方法 是否展开 <公开 属性写 注释 = "" 折叠>
    参数 是否 <类型 = 逻辑型>
    {
        @ pdata ()->bExpand = @<是否>;
    }

    方法 是否可见 <公开 属性读 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)@sn<this>.pdata ()->bShow
    }

    方法 是否可见 <公开 属性写 折叠>
    参数 是否 <类型 = 逻辑型>
    {
        @ pdata ()->bShow = @<是否>;
    }
}

