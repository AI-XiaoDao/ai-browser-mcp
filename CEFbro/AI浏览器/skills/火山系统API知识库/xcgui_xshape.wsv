<火山程序 类型 = "通常" 版本 = 1 />

包 xc.gui <@文档 = "category = \"形状对象\"">

类 形状基类 <公开 基础类 = 炫彩窗口组件 折叠>
{
    方法 调整布局 <公开 折叠 @嵌入式方法 = "">
    {
        @ XShape_AdjustLayout((HXCGUI)@sn<this>.get())
    }

    方法 销毁 <公开 折叠 @嵌入式方法 = "">
    {
        @ XShape_Destroy((HXCGUI)@sn<this>.get())
    }

    方法 取内容大小 <公开 注释 = "仅计算有效内容, 填充父, 权重依赖父级所以无法计算" 折叠 @嵌入式方法 = "">
    参数 内容大小 <类型 = 尺寸_xc 注释 = "接收返回内容大小">
    {
        // @ SIZE sz;
        @ XShape_GetContentSize((HXCGUI)get(), @<内容大小>.pdata())
        // @ @<内容大小.宽>(sz.cx);
        // @ @<内容大小.高>(sz.cy);
    }

    方法 取左边 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        变量 矩形 <类型 = 矩形_xc>
        @ XShape_GetRect((HXCGUI)get(), @<矩形>.pdata());
        返回 (矩形.左边)
    }

    方法 取顶边 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        变量 矩形 <类型 = 矩形_xc>
        @ XShape_GetRect((HXCGUI)get(), @<矩形>.pdata());
        返回 (矩形.顶边)
    }

    方法 取高度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XShape_GetHeight((HXCGUI)@sn<this>.get())
    }

    方法 取矩形 <公开 折叠 @嵌入式方法 = "">
    参数 矩形坐标 <类型 = 矩形_xc 注释 = "接收返回坐标">
    {
        // @ RECT rc;
        @ XShape_GetRect((HXCGUI)@sn<this>.get(), @<矩形坐标>.pdata())
        // @ @<矩形坐标.左边>(rc.left);
        // @ @<矩形坐标.顶边>(rc.top);
        // @ @<矩形坐标.右边>(rc.right);
        // @ @<矩形坐标.底边>(rc.bottom);
    }

    方法 取宽度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XShape_GetWidth((HXCGUI)@sn<this>.get())
    }

    方法 取窗口客户区矩形 <公开 注释 = "基于窗口客户区坐标" 折叠 @嵌入式方法 = "">
    参数 矩形坐标 <类型 = 矩形_xc 注释 = "接收返回坐标">
    {
        // @ RECT rc;
        @ XShape_GetWndClientRect((HXCGUI)@sn<this>.get(), @<矩形坐标>.pdata())
        // @ @<矩形坐标.左边>(rc.left);
        // @ @<矩形坐标.顶边>(rc.top);
        // @ @<矩形坐标.右边>(rc.right);
        // @ @<矩形坐标.底边>(rc.bottom);
    }

    方法 取Z序 <公开 类型 = 整数 返回值注释 = "成功返回索引值,否则返回 XC_ID_ERROR" 折叠 @嵌入式方法 = "">
    {
        @ XShape_GetZOrder((HXCGUI)@sn<this>.get())
    }

    方法 透明度 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 透明 <类型 = 整数>
    {
        @ XShape_SetAlpha((HXCGUI)get(), (BYTE)@<透明>);
    }

    方法 透明度 <公开 属性读 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ (INT)XShape_GetSize ((HXCGUI)@sn<this>.GetP ())
    }

    方法 置大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ XShape_SetSize((HXCGUI)@sn<this>.get(), @<宽度>, @<高度>)
    }

    方法 取大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数 注释 = "返回">
    参数 高度 <类型 = 整数 注释 = "返回">
    {
        @ XShape_GetSize ((HXCGUI)@sn<this>.GetP (), (int *)&@<宽度>, (int *)&@<高度>)
    }

    方法 置位置 <公开 注释 = "移动" 折叠 @嵌入式方法 = "">
    参数 x坐标 <类型 = 整数>
    参数 y坐标 <类型 = 整数>
    {
        @ XShape_SetPosition((HXCGUI)@sn<this>.get(), @<x坐标>, @<y坐标>)
    }

    方法 取位置 <公开 折叠 @嵌入式方法 = "">
    参数 pX <类型 = 整数 注释 = "返回x轴偏移">
    参数 pY <类型 = 整数 注释 = "返回y轴偏移">
    {
        @ XShape_GetPosition ((HXCGUI)@sn<this>.get (), (int *)&@<pX>, (int *)&@<pY>)
    }

    方法 重绘 <公开 注释 = "重绘形状对象" 折叠 @嵌入式方法 = "">
    {
        @ XShape_Redraw((HXCGUI)@sn<this>.get())
    }

    方法 移除 <公开 注释 = "从父UI元素或窗口,和父布局对象中移除" 折叠 @嵌入式方法 = "">
    {
        @ XShape_RemoveShape((HXCGUI)@sn<this>.get())
    }

    方法 置矩形 <公开 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    {
        @ XShape_SetRect((HXCGUI)@sn<this>.get(), &RECT{@<左边>, @<顶边>,@<右边>,@<底边>})
    }

    方法 显示布局边界 <公开 折叠 @嵌入式方法 = "">
    参数 是否显示 <类型 = 逻辑型>
    {
        @ XShape_ShowLayout((HXCGUI)@sn<this>.get(), @<是否显示>)
    }

    方法 取矩形逻辑 <公开 注释 = "获取元素坐标,逻辑坐标,包含滚动视图偏移" 折叠 @嵌入式方法 = "">
    参数 矩形坐标 <类型 = 矩形_xc 注释 = "接收返回坐标">
    {
        // @ RECT pRect;
        @ XShape_GetRectLogic((HXCGUI)@sn<this>.get(), @<矩形坐标>.pdata())
        // @ @<矩形坐标.左边>(pRect.left);
        // @ @<矩形坐标.顶边>(pRect.top);
        // @ @<矩形坐标.右边>(pRect.right);
        // @ @<矩形坐标.底边>(pRect.bottom);
    }

    方法 置矩形逻辑 <公开 类型 = 逻辑型 注释 = "设置元素坐标,逻辑坐标,包含滚动视图偏移." 返回值注释 = "如果成功返回TRUE, 否则返回FALSE." 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 右边 <类型 = 整数>
    参数 底边 <类型 = 整数>
    参数 是否重绘 <类型 = 逻辑型>
    {
        @ XShape_SetRectLogic((HXCGUI)@sn<this>.get(), &RECT{@<左边>, @<顶边>,@<右边>,@<底边>},@<是否重绘>)
    }
}

类 形状文本 <公开 基础类 = 形状基类 注释 = "标签" 折叠>
{
    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 标题 <类型 = 文本型>
    参数 父句柄 <类型 = 变整数>
    {
        @ @sn<this>.set((vint)XShapeText_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, @<标题>, (HXCGUI)@<父句柄>))
    }

    方法 字体 <公开 属性写 折叠 @禁止流程检查 = 真>
    参数 字体句柄 <类型 = 变整数>
    {
        @ XShapeText_SetFont((HXCGUI)get(), (HFONTX)@<字体句柄>);
    }

    方法 字体 <公开 属性读 类型 = 变整数 返回值注释 = "返回字体句柄" 折叠 @嵌入式方法 = "">
    {
        @ (INT_P)XShapeText_GetFont((HXCGUI)@sn<this>.get())
    }

    方法 文本 <公开 属性写 @禁止流程检查 = 真>
    参数 标题 <类型 = 文本型>
    {
        @ XShapeText_SetText((HXCGUI)get(), @<标题>.GetText ());
    }

    方法 文本 <公开 属性读 类型 = 文本型 @嵌入式方法 = "">
    {
        @  @an<CVolString>(XShapeText_GetText((HXCGUI)@sn<this>.get()))
    }

    方法 取文本颜色 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ (int)XShapeText_GetTextColor((HXCGUI)@sn<this>.get())
    }

    方法 取文本长度 <公开 类型 = 整数 折叠 @嵌入式方法 = "">
    {
        @ XShapeText_GetTextLength((HXCGUI)@sn<this>.get())
    }

    方法 置偏移 <公开 折叠 @嵌入式方法 = "">
    参数 水平偏移 <类型 = 整数>
    参数 垂直偏移 <类型 = 整数>
    {
        @ XShapeText_SetOffset((HXCGUI)@sn<this>.get(), @<水平偏移>, @<垂直偏移>)
    }

    方法 置文本对齐 <公开 折叠 @嵌入式方法 = "">
    参数 对齐方式 <类型 = 整数 注释 = "文本标识.***">
    {
        @ XShapeText_SetTextAlign((HXCGUI)@sn<this>.get(), @<对齐方式>)
    }

    方法 置文本颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XShapeText_SetTextColor((HXCGUI)@sn<this>.get(), COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }
}

