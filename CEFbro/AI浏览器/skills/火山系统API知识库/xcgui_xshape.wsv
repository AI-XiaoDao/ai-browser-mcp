类 形状组框 <公开 基础类 = 形状基类 注释 = "分组框,不能当父" 折叠>
{
    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 标题 <类型 = 文本型>
    参数 父句柄 <类型 = 变整数>
    {
        @ @sn<this>.set((vint)XShapeGroupBox_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, @<标题>.GetText (), (HXCGUI)@<父句柄>))
    }

    方法 启用圆角 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XShapeGroupBox_EnableRoundAngle((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 取圆角大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数 注释 = "返回圆角宽度">
    参数 高度 <类型 = 整数 注释 = "返回圆角高度">
    {
        @ XShapeGroupBox_GetRoundAngle((HXCGUI)@sn<this>.get(), (INT*)&@<宽度>, (INT*)&@<高度>)
    }

    方法 取文本偏移 <公开 折叠 @嵌入式方法 = "">
    参数 水平偏移 <类型 = 整数 注释 = "接收的x偏移">
    参数 垂直偏移 <类型 = 整数 注释 = "接收的y偏移">
    {
        @ XShapeGroupBox_GetTextOffset((HXCGUI)@sn<this>.get(),  (INT*)&@<水平偏移>, (INT*)&@<垂直偏移>)
    }

    方法 置边框颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XShapeGroupBox_SetBorderColor((HXCGUI)@sn<this>.get(), COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 置字体 <公开 折叠 @嵌入式方法 = "">
    参数 字体句柄 <类型 = 变整数>
    {
        @ XShapeGroupBox_SetFontX((HXCGUI)@sn<this>.get(), (HFONTX)@<字体句柄>)
    }

    方法 置圆角大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ XShapeGroupBox_SetRoundAngle((HXCGUI)@sn<this>.get(), @<宽度>, @<高度>)
    }

    方法 置文本 <公开 折叠 @嵌入式方法 = "">
    参数 标题 <类型 = 文本型>
    {
        @ XShapeGroupBox_SetText((HXCGUI)@sn<this>.get(), @<标题>.GetText ())
    }

    方法 置文本颜色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XShapeGroupBox_SetTextColor((HXCGUI)@sn<this>.get(), COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 置文本偏移 <公开 折叠 @嵌入式方法 = "">
    参数 水平偏移 <类型 = 整数>
    参数 垂直偏移 <类型 = 整数>
    {
        @ XShapeGroupBox_SetTextOffset((HXCGUI)@sn<this>.get(), @<水平偏移>, @<垂直偏移>)
    }
}

类 形状直线 <公开 基础类 = 形状基类 折叠>
{
    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 起始x1 <类型 = 整数 注释 = "起始x">
    参数 起始y1 <类型 = 整数>
    参数 结束x2 <类型 = 整数>
    参数 结束y2 <类型 = 整数>
