类 形状矩形 <公开 基础类 = 形状基类 折叠>
{
    方法 创建 <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 父句柄 <类型 = 变整数>
    {
        @ @sn<this>.set((vint)XShapeRect_Create(@<左边>, @<顶边>, @<宽度>, @<高度>, (HXCGUI)@<父句柄>))
    }

    方法 启用边框 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XShapeRect_EnableBorder((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 启用填充 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XShapeRect_EnableFill((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 启用圆角 <公开 折叠 @嵌入式方法 = "">
    参数 是否启用 <类型 = 逻辑型>
    {
        @ XShapeRect_EnableRoundAngle((HXCGUI)@sn<this>.get(), @<是否启用>)
    }

    方法 取圆角大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数 注释 = "接收的宽度(整数)">
    参数 高度 <类型 = 整数 注释 = "接收的高度(整数)">
    {
        @ XShapeRect_GetRoundAngle((HXCGUI)@sn<this>.get(), (INT*)&@<宽度>, (INT*)&@<高度>)
        // @ WRITE_POINTER_NUMBER (@<宽度>, INT, w);
        // @ WRITE_POINTER_NUMBER (@<高度>, INT, h);
    }

    方法 置边框色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XShapeRect_SetBorderColor((HXCGUI)@sn<this>.get(), COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 置填充色 <公开 折叠 @嵌入式方法 = "">
    参数 颜色 <类型 = 整数>
    参数 透明度 <类型 = 短整数 @默认值 = 255>
    {
        @ XShapeRect_SetFillColor((HXCGUI)@sn<this>.get(), COLORREF_MAKE2(@<颜色>, (BYTE)@<透明度>))
    }

    方法 置圆角大小 <公开 折叠 @嵌入式方法 = "">
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    {
        @ XShapeRect_SetRoundAngle((HXCGUI)@sn<this>.get(), @<宽度>, @<高度>)
    }
}

