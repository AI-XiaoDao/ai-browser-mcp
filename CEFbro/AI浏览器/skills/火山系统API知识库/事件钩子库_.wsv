    #      }    
    #      return CallNextHookEx((HHOOK)@<鼠标钩子句柄>,nCode,wParam,lParam);
    # }
    # <> </include>
    # @end

    方法 获取按键状态 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 按键码 <类型 = 整数>
    {
        @ return GetKeyState(VK_CONTROL) & @<按键码>;
    }

    方法 鼠标按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 按下按键 <类型 = 整数 注释 = "1左键，2右键，3中建">

    方法 鼠标松开事件 <公开 定义事件 类型 = 整数 折叠>
    参数 放开按键 <类型 = 整数 注释 = "1左键，2右键，3中建">

    方法 键盘按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 按下按键 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 键盘松开事件 <公开 定义事件 类型 = 整数 折叠>
    参数 放开按键 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 鼠标滚轮事件 <公开 定义事件 类型 = 整数 折叠>
    参数 滚动距离 <类型 = 整数 注释 = "判断滚动方向，下滚：<0　上滚：>0">

    方法 组合键回调事件 <公开 定义事件 类型 = 整数 折叠>
    参数 按键码 <类型 = 整数 注释 = "例如：按键码.A键">
    参数 是否按下Ctrl <类型 = 逻辑型>
    参数 是否按下Alt <类型 = 逻辑型>
    参数 是否按下Shift <类型 = 逻辑型>
    参数 是否按下Win <类型 = 逻辑型>
    参数 按键状态 <类型 = 逻辑型 注释 = "真为按下，假为放开">

    方法 内部回调方法 <公开 折叠 @禁止流程检查 = 真>
    参数 按键码 <类型 = 整数>
    参数 消息值 <类型 = 整数>
    参数 scanCode <类型 = 整数>
    参数 flags <类型 = 整数>
    {
        变量 是否按下Ctrl <静态 类型 = 逻辑型>
        变量 是否按下Alt <静态 类型 = 逻辑型>
        变量 是否按下Shift <静态 类型 = 逻辑型>
        变量 是否按下Win <静态 类型 = 逻辑型>
        变量 放开还是按下 <静态 类型 = 逻辑型>
        如果 (消息值 > 512)
        {
            如果 (消息值 == 522)
            {
                如果 (flags >= 0)
                {
                    鼠标滚轮事件 (-1)
                }
                否则
                {
                    鼠标滚轮事件 (1)
                }
            }
            如果 (消息值 == 513)
            {
                // 鼠标左键按下
                鼠标按下事件 (1)
            }
            如果 (消息值 == 514)
            {
                // 鼠标左键放开
                鼠标松开事件 (1)
            }
            如果 (消息值 == 516)
            {
                // 鼠标右键按下
                鼠标按下事件 (2)
            }
            如果 (消息值 == 517)
            {
                // 鼠标右键放开
                鼠标松开事件 (2)
            }
            如果 (消息值 == 519)
            {
                // 鼠标中键按下
                鼠标按下事件 (3)
            }
            如果 (消息值 == 520)
            {
                // 鼠标中键放开
                鼠标松开事件 (3)
            }
        }
        如果 (消息值 == 256 || 消息值 == 260)
        {
            键盘按下事件 (按键码)
            放开还是按下 = 真
            如果 (按键码 == 160 || 按键码 == 161)
            {
                是否按下Shift = 真
            }
            如果 (按键码 == 162 || 按键码 == 163)
            {
                是否按下Ctrl = 真
            }
            如果 (按键码 == 164 || 按键码 == 165)
            {
                是否按下Alt = 真
            }
            如果 (按键码 == 91 || 按键码 == 92)
            {
                是否按下Win = 真
            }
        }
        如果 (消息值 == 257)
        {
            键盘松开事件 (按键码)
            放开还是按下 = 假
            如果 (按键码 == 160 || 按键码 == 161)
            {
                是否按下Shift = 假
            }
            如果 (按键码 == 162 || 按键码 == 163)
            {
                是否按下Ctrl = 假
            }
            如果 (按键码 == 164 || 按键码 == 165)
            {
                是否按下Alt = 假
            }
            如果 (按键码 == 91 || 按键码 == 92)
            {
                是否按下Win = 假
            }
        }
        如果 (消息值 == 256 || 消息值 == 260 || 消息值 == 257)
        {
            如果 (是否按下Alt == 真 || 是否按下Ctrl == 真 || 是否按下Shift == 真 || 是否按下Win == 真)
            {
                组合键回调事件 (按键码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下Win, 放开还是按下)
            }
        }
    }

    方法 类_清理 <折叠>
    {
        @ UnhookWindowsHookEx ((HHOOK)@<键盘钩子句柄>);
        @ UnhookWindowsHookEx ((HHOOK)@<鼠标钩子句柄>);
    }

    方法 类_初始化 <折叠>
    {
        @ ObjThis(this);
        @ @<鼠标钩子句柄>=(@dt<变整数>)SetWindowsHookEx(14,(HOOKPROC)(INT_P)&CodeMsg,GetModuleHandle(NULL),0);
        @ @<键盘钩子句柄>=(@dt<变整数>)SetWindowsHookEx(13,(HOOKPROC)(INT_P)&CodeMsg,GetModuleHandle(NULL),0);
        如果真 (是否为调试状态_ () == 真 && 进程_进程是否存在 ("voldev_f.exe") == 假)
        {
            调试输出 ("火山模块提醒你：当前程序正处于调试状态，并检测到使用了鼠键钩子类_，可能会导致火山断点调试时异常卡顿，请注意！！！", 64, "温馨提示！")
        }
    }
}

# //===模拟操作====

类 模拟操作类_ <公开 折叠 折叠2 @文档 = "category = \"事件钩子库.模拟鼠键操作\"" @全局类 = 真>
{
    方法 鼠标_限制鼠标移动范围 <公开 静态 注释 = "如果要让窗口一启动就执行限制，可以在窗口“首次激活”时调用本命令，" 注释 = "不要在“创建完毕”时调用　" 折叠 折叠2 @禁止流程检查 = 真>
    参数 限制左 <类型 = 整数 @默认值 = 0>
    参数 限制顶 <类型 = 整数 @默认值 = 0>
    参数 宽度范围 <类型 = 整数 @默认值 = 0>
    参数 高度范围 <类型 = 整数 @默认值 = 0>
    {
        变量 width <类型 = 整数>
        变量 height <类型 = 整数>
        @ RECT rc;
        @ rc.left = @<限制左>;
        @ rc.top = @<限制顶>;
        width = 取屏幕宽度 ()
        height = 取屏幕高度 ()
        @ if (!@<宽度范围>) rc.right = @<width> - @<限制左>;
        @ else rc.right = @<宽度范围> + @<限制左>;
        @ if (!@<高度范围>) rc.bottom = @<height> - @<限制顶>;
        @ else rc.bottom = @<高度范围> + @<限制顶>;
        @ ClipCursor(&rc);
    }

    方法 鼠标_解除鼠标移动范围 <公开 静态 折叠>
    {
        鼠标_限制鼠标移动范围 (0, 0, 取屏幕宽度 (), 取屏幕高度 ())
    }

    方法 键盘_模拟按键 <公开 静态 注释 = "可以单键也可以组合键" 折叠 @禁止流程检查 = 真>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.V键" "">
    参数 Ctrl <类型 = 逻辑型 @默认值 = 假>
    参数 Alt <类型 = 逻辑型 @默认值 = 假>
    参数 Shift <类型 = 逻辑型 @默认值 = 假>
    参数 Win <类型 = 逻辑型 @默认值 = 假>
    {
        如果 (键代码 == 76 && Win == 真)
        {
            运行 ("rundll32.exe user32.dll , LockWorkStation")
        }
        否则
        {
            @ if(@<Ctrl>==TRUE){keybd_event(VK_CONTROL, 0, 0, 0); }
            @ if(@<Shift>==TRUE){keybd_event(VK_SHIFT, 0, 0, 0); }
            @ if(@<Alt>==TRUE){keybd_event(VK_MENU, 0, 0, 0); }
            @ if(@<Win>==TRUE){keybd_event(VK_LWIN, 0, 0, 0); }
            @ keybd_event(@<键代码>, 0, 0, 0);
            @ if(@<Ctrl>==TRUE){keybd_event(VK_CONTROL, 0, KEYEVENTF_KEYUP, 0); }
            @ if(@<Shift>==TRUE){keybd_event(VK_SHIFT, 0, KEYEVENTF_KEYUP, 0); }
            @ if(@<Alt>==TRUE){keybd_event(VK_MENU, 0, KEYEVENTF_KEYUP, 0); }
            @ if(@<Win>==TRUE){keybd_event(VK_LWIN, 0, KEYEVENTF_KEYUP, 0); }
            @ keybd_event(@<键代码>, 0, KEYEVENTF_KEYUP, 0);
        }
    }

    方法 键盘_模拟按键2 <公开 静态 注释 = "向指定窗口句柄的窗口中发送按键消息" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">
    参数 Ctrl <类型 = 逻辑型 @默认值 = 假>
    参数 Alt <类型 = 逻辑型 @默认值 = 假>
    参数 Shift <类型 = 逻辑型 @默认值 = 假>
    参数 Win <类型 = 逻辑型 @默认值 = 假>
    参数 是否激活窗口 <类型 = 逻辑型 @默认值 = 真>
    参数 样式 <类型 = 窗口显示命令常量 注释 = "默认为显示窗口但不改变当前激活的窗口" @默认值 = 窗口显示命令常量.SW_SHOWNOACTIVATE>
    {
        @ if(@<是否激活窗口>==TRUE){
        @ PostMessage((HWND)@<窗口句柄>,7, 0, 0);
        @ ShowWindow((HWND)@<窗口句柄>, (INT)@<样式>);
        @ SetForegroundWindow((HWND)@<窗口句柄>);}
        @ PostMessage((HWND)@<窗口句柄>,7, 0, 0);
        @ if(@<Ctrl>==TRUE){keybd_event(VK_CONTROL, 0, 0, 0); }
        @ if(@<Shift>==TRUE){keybd_event(VK_SHIFT, 0, 0, 0); }
        @ if(@<Alt>==TRUE){keybd_event(VK_MENU, 0, 0, 0); }
        @ if(@<Win>==TRUE){keybd_event(VK_LWIN, 0, 0, 0); }
        @ PostMessage((HWND)@<窗口句柄>,7, 0, 0);
        @ PostMessage((HWND)@<窗口句柄>, WM_KEYDOWN, @<键代码>, 0);
        @ PostMessage((HWND)@<窗口句柄>, WM_KEYUP, @<键代码>, 0);
        @ keybd_event(@<键代码>, 0, 0, 0);
        @ keybd_event(@<键代码>, 0, KEYEVENTF_KEYUP, 0);
        @ if(@<Ctrl>==TRUE){keybd_event(VK_CONTROL, 0, KEYEVENTF_KEYUP, 0); }
        @ if(@<Shift>==TRUE){keybd_event(VK_SHIFT, 0, KEYEVENTF_KEYUP, 0); }
        @ if(@<Alt>==TRUE){keybd_event(VK_MENU, 0, KEYEVENTF_KEYUP, 0); }
        @ if(@<Win>==TRUE){keybd_event(VK_LWIN, 0, KEYEVENTF_KEYUP, 0); }
    }

    方法 键盘_模拟回车 <公开 静态 折叠 @嵌入式方法 = "">
    {
        @ keybd_event(VK_RETURN, 0, 0, 0);
        @ keybd_event(VK_RETURN, 0, 2, 0);
    }

    方法 鼠标_模拟鼠标移动 <公开 静态 折叠>
    参数 横坐标 <类型 = 整数>
    参数 纵坐标 <类型 = 整数>
    {
        模拟操作 (1, 横坐标, 纵坐标)
    }

    方法 鼠标_模拟鼠标左键单击 <公开 静态 折叠>
    参数 点击类型 <类型 = 整数 注释 = "0、按下松开 1、只按下 2、只松开" @默认值 = 0>
    {
