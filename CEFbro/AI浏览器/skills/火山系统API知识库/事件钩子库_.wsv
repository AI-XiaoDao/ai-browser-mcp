# //===挂接事件====

类 挂接事件类_ <公开 折叠 @文档 = "category = \"事件钩子库.鼠键事件监视\"">
{
    变量 独有1 <类型 = 文本独有数组类>
    变量 互斥1 <类型 = 许可锁类_>
    变量 键盘单次 <类型 = 逻辑型>

    方法 挂接事件_ <公开 注释 = "绑定组件，获取组件事件" 折叠>
    参数 组件句柄 <类型 = 变整数>
    {
        变量 指针数据 <类型 = 挂接指针信息>
        变量 lpfunc <类型 = 变整数>
        变量 This <类型 = 变整数>
        事件指针.置入新数据 (组件句柄, 真, 指针数据)
        @ @<lpfunc> = (@dt<变整数>)@<窗口消息监视>;
        @ @<指针数据.oldWndProc>=(@dt<变整数>)SetWindowLongPtrW((HWND)@<组件句柄>,GWLP_WNDPROC,@<lpfunc>);
        指针数据.lpfunc = lpfunc
        @ @<This>=(@dt<变整数>)this;
        指针数据.This = This
        事件指针.置入新数据 (组件句柄, 假, 指针数据)
    }

    方法 置按键触发方式_ <公开 注释 = "设置在一个按键事件内触发单次或多次" 折叠>
    参数 触发单次 <类型 = 逻辑型 @默认值 = 真>
    {
        键盘单次 = 触发单次
    }

    方法 鼠标按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 组件句柄 <类型 = 变整数 注释 = "光标处组件句柄">
    参数 横向位置 <类型 = 整数 注释 = "当前组件内的光标位，x轴，不含屏幕距离和其它组件">
    参数 纵向位置 <类型 = 整数 注释 = "当前组件内的光标位，y轴，不含屏幕距离和其它组件">
    参数 窗口左 <类型 = 整数 注释 = "当前窗口内，光标距离窗口左侧距离，不含屏幕距离">
    参数 窗口顶 <类型 = 整数 注释 = "当前窗口内，光标距离窗口顶侧距离，不含屏幕距离">
    参数 按键类型 <类型 = 整数 注释 = "1左键，2右键，3中建">

    方法 鼠标松开事件 <公开 定义事件 类型 = 整数 折叠>
    参数 组件句柄 <类型 = 变整数 注释 = "光标处组件句柄">
    参数 横向位置 <类型 = 整数 注释 = "当前组件内的光标位，x轴，不含屏幕距离和其它组件">
    参数 纵向位置 <类型 = 整数 注释 = "当前组件内的光标位，y轴，不含屏幕距离和其它组件">
    参数 窗口左 <类型 = 整数 注释 = "当前窗口内，光标距离窗口左侧距离，不含屏幕距离">
    参数 窗口顶 <类型 = 整数 注释 = "当前窗口内，光标距离窗口顶侧距离，不含屏幕距离">
    参数 按键类型 <类型 = 整数 注释 = "1左键，2右键，3中建">

    方法 键盘按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 键盘松开事件 <公开 定义事件 类型 = 整数 折叠>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 鼠标滚轮事件 <公开 定义事件 类型 = 整数 折叠>
    参数 滚动距离 <类型 = 整数 注释 = "判断滚动方向，下滚：<0　上滚：>0">

    方法 鼠标移动事件 <公开 定义事件 类型 = 整数 折叠>
    参数 顶级句柄 <类型 = 变整数 注释 = "主体窗口句柄">
    参数 组件句柄 <类型 = 变整数 注释 = "光标处组件句柄">
    参数 横向位置 <类型 = 整数 注释 = "当前组件内的光标位，x轴，不含屏幕距离和其它组件">
    参数 纵向位置 <类型 = 整数 注释 = "当前组件内的光标位，y轴，不含屏幕距离和其它组件">
    参数 组件左 <类型 = 整数 注释 = "光标处组件在窗口中的左侧距离">
    参数 组件顶 <类型 = 整数 注释 = "光标处组件在窗口中的顶侧距离">
    参数 组件宽 <类型 = 整数 注释 = "光标处组件宽度">
    参数 组件高 <类型 = 整数 注释 = "光标处组件高度">
    参数 窗口左 <类型 = 整数 注释 = "当前窗口内，光标距离窗口左侧距离，不含屏幕距离">
    参数 窗口顶 <类型 = 整数 注释 = "当前窗口内，光标距离窗口顶侧距离，不含屏幕距离">

    方法 回调事件集 <公开 定义事件 类型 = 整数 注释 = "内部" 折叠>
    参数 hwnd <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>

    方法 窗口消息监视 <静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 hwnd <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        变量 临时挂接指针信息对象 <类型 = 挂接指针信息>
        临时挂接指针信息对象 = 事件指针.获取指针数据 (hwnd)
        @ @sn<current_class> *pTimer=(@sn<current_class> *)(void *)@<临时挂接指针信息对象.This>;
        @ pTimer->@<回调事件集>(@<hwnd>,@<uMsg>,@<wParam>,@<lParam>);
        @ return CallWindowProcW((WNDPROC)@<临时挂接指针信息对象.oldWndProc>,(HWND)@<hwnd>,(UINT)@<uMsg>,(WPARAM)@<wParam>,(LPARAM)@<lParam>);
    }

    方法 挂接事件类__回调事件集 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 挂接事件类_>
    参数 标记值 <类型 = 整数>
    参数 hwnd <类型 = 变整数>
    参数 uMsg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        变量 顶级句柄 <类型 = 变整数>
        变量 组件句柄 <类型 = 变整数>
        变量 父句柄 <类型 = 变整数>
        变量 矩形 <类型 = 矩形_>
        变量 矩形2 <类型 = 矩形_>
        变量 组左 <类型 = 整数>
        变量 组顶 <类型 = 整数>
        变量 组宽 <类型 = 整数>
        变量 组高 <类型 = 整数>
        变量 坐标值 <类型 = 控件坐标值_>
        变量 坐标值2 <类型 = 控件坐标值_>
        顶级句柄 = hwnd
        组件句柄 = wParam
        父句柄 = 取父窗口句柄_ (组件句柄)
        如果 (父句柄 > 0)
        {
            矩形 = 窗口_取窗口组件矩形 (组件句柄)
            矩形2 = 窗口_取窗口组件矩形 (父句柄)
            组左 = 矩形.左边 - 矩形2.左边
            组顶 = 矩形.顶边 - 矩形2.顶边
            组宽 = 矩形.右边 - 矩形.左边
            组高 = 矩形.底边 - 矩形.顶边
        }
        否则
        {
            矩形 = 窗口_取窗口组件矩形 (组件句柄)
            组左 = 矩形.左边
            组顶 = 矩形.顶边
            组宽 = 矩形.右边 - 矩形.左边
            组高 = 矩形.底边 - 矩形.顶边
        }
        如果真 (组左 > 0 || 组顶 > 0 || 组宽 > 0 || 组高 > 0)
        {
            坐标值 = 窗口_取窗口组件坐标 (组件句柄)
            坐标值2 = 窗口_取窗口组件坐标 (顶级句柄)
            鼠标移动事件 (顶级句柄, 组件句柄, 取鼠标水平位置 () + 坐标值.横向位置 + 1, 取鼠标垂直位置 () + 坐标值.纵向位置 + 1, 组左, 组顶, 组宽, 组高, 取鼠标水平位置 () + 坐标值2.横向位置 + 1, 取鼠标垂直位置 () + 坐标值2.纵向位置 + 1)
        }

        如果 (uMsg > 512)
        {
            变量 句柄 <类型 = 变整数>
            变量 横位 <类型 = 整数>
            变量 纵位 <类型 = 整数>
            变量 水平位 <类型 = 整数>
            变量 垂直位 <类型 = 整数>
            句柄 = 窗口_取鼠标处窗口句柄 ()
            坐标值 = 窗口_取窗口组件坐标 (句柄)
            坐标值2 = 窗口_取窗口组件坐标 (取父窗口句柄_ (句柄))
            横位 = 取鼠标水平位置 () + 坐标值.横向位置 + 1
            纵位 = 取鼠标垂直位置 () + 坐标值.纵向位置 + 1
            水平位 = 取鼠标水平位置 () + 坐标值2.横向位置 + 1
            垂直位 = 取鼠标垂直位置 () + 坐标值2.纵向位置 + 1
            如果 (uMsg == 513)  // wParam == 513
            {
                // 鼠标左键按下
                鼠标按下事件 (句柄, 横位, 纵位, 水平位, 垂直位, 1)
            }
            如果 (uMsg == 514)
            {
                // 鼠标左键放开
                鼠标松开事件 (句柄, 横位, 纵位, 水平位, 垂直位, 1)
            }
            如果 (uMsg == 516)  // wParam == 516
            {
                // 鼠标右键按下
                鼠标按下事件 (窗口_取鼠标处窗口句柄 (), 横位, 纵位, 水平位, 垂直位, 2)
            }
            如果 (uMsg == 517)
            {
                // 鼠标右键放开
                鼠标松开事件 (句柄, 横位, 纵位, 水平位, 垂直位, 2)
            }
            如果 (uMsg == 519)
            {
                // 鼠标中键按下
                鼠标按下事件 (0, 横位, 纵位, 水平位, 垂直位, 3)
            }
            如果 (uMsg == 520)
            {
                // 鼠标中键放开
                鼠标松开事件 (0, 0, 0, 0, 0, 3)
            }
            如果 (uMsg == 522)
            {
                如果 (wParam == -7864320 || wParam == 4287102976)
                {
                    鼠标滚轮事件 (-1)
                }
                否则 (wParam == 7864320)
                {
                    鼠标滚轮事件 (1)
                }
            }
        }

        如果 (uMsg == 135 && wParam == 13)
        {
            如果 (键盘单次 == 真)
            {
                互斥1.加锁 ()
                如果真 (独有1.加入成员 (到文本 (wParam)) != -1)
                {
                    键盘按下事件 ((整数)wParam)
                }
                互斥1.解锁 ()
            }
            否则
            {
                键盘按下事件 ((整数)wParam)
            }
        }
        如果 (uMsg == 256)
        {
            如果 (键盘单次 == 真)
            {
                互斥1.加锁 ()
                如果真 (独有1.加入成员 (到文本 (wParam)) != -1)
                {
                    键盘按下事件 ((整数)wParam)
                }
                互斥1.解锁 ()
            }
            否则
            {
                键盘按下事件 ((整数)wParam)
            }
        }
        如果 (uMsg == 257)
        {
            互斥1.加锁 ()
            独有1.枚举循环 ()
            {
                如果真 (独有1.取枚举值 () == 到文本 (wParam))
                {
                    独有1.删除成员 (独有1.取枚举索引 (), )
                    跳出循环
                }
            }
            互斥1.解锁 ()
            键盘松开事件 ((整数)wParam)
        }
        返回 (0)
    }
}

类 事件指针 <公开 折叠 @文档 = "category = \"事件钩子库.鼠键事件监视.附加类\"">
{
    变量 指针数组 <静态 类型 = 对象数组类>
    变量 指针对应 <静态 类型 = JSON对象类_>

    方法 置入新数据 <公开 静态 折叠>
    参数 对应句柄 <类型 = 变整数>
    参数 是否新数据 <类型 = 逻辑型>
    参数 新数据对象 <类型 = 挂接指针信息>
    {
        变量 所处位置 <类型 = 整数>
        所处位置 = 指针对应.取整数值 (到文本 (对应句柄))
        如果 (是否新数据 == 真)
        {
            指针对应.置入整数值 (到文本 (对应句柄), 指针数组.加入成员 (新数据对象))
        }
        否则
        {
            指针数组.置成员值 (所处位置, 新数据对象)

        }

    }

    方法 获取指针数据 <公开 静态 类型 = 挂接指针信息 折叠>
    参数 对应句柄 <类型 = 变整数>
    {
        变量 所处位置 <类型 = 整数>
        所处位置 = 指针对应.取整数值 (到文本 (对应句柄))
        变量 挂接指针信息对象 <类型 = 挂接指针信息>
        挂接指针信息对象 = (挂接指针信息)指针数组.取成员 (所处位置)
        返回 (挂接指针信息对象)
    }
}

类 挂接指针信息 <公开 折叠 折叠2 @文档 = "category = \"事件钩子库.鼠键事件监视.附加类\"" @输出名 = "ThisClass">
{
    变量 lpfunc <公开 类型 = 变整数 @输出名 = "lpfunc">
    变量 oldWndProc <公开 类型 = 变整数 @输出名 = "oldWndProc">
    变量 This <公开 类型 = 变整数 @输出名 = "ThisClassOb">

    #
}
