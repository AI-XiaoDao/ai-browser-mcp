    方法 鼠标_模拟鼠标滚轮滚动 <公开 静态 注释 = "必须某个窗口先获得焦点" 折叠>
    参数 滚动方向 <类型 = 逻辑型 注释 = "真为向下滚，假为向上滚，1次为120" @默认值 = 真>
    {
        模拟操作 (2048, 0, 0, 选择 (滚动方向 == 真, -120, 120), 0)
    }

    方法 模拟操作 <静态 折叠 @嵌入式方法 = "">
    参数 模拟方式 <类型 = 整数>
    参数 x <类型 = 整数>
    参数 y <类型 = 整数>
    参数 滚轮数据 <类型 = 整数 @默认值 = 0>
    参数 附加信息 <类型 = 变整数 @默认值 = 0>
    {
        @  mouse_event (@<模拟方式>|MOUSEEVENTF_ABSOLUTE, @<x>*65535/GetSystemMetrics(SM_CXSCREEN), @<y>*65535/GetSystemMetrics(SM_CYSCREEN),@<滚轮数据>,@<附加信息>);
    }
}

# //===移入移出====

类 组件移入移出事件类_ <公开 折叠 @文档 = "category = \"事件钩子库.组件出入监视\"">
{
    变量 原横向位置 <类型 = 整数>
    变量 原纵向位置 <类型 = 整数>
    变量 原横向鼠标 <类型 = 整数>
    变量 原纵向鼠标 <类型 = 整数>
    变量 目标组件指针 <类型 = 变整数>
    变量 目标组件 <类型 = 窗口组件>
    变量 目标组件序号 <类型 = 整数>
    变量 时钟1 <类型 = 时钟类_>

    方法 监视组件_ <公开 注释 = "将本命令放置在某个组件的“鼠标位置被移动”事件里;" 注释 = "例如：“图片框_鼠标位置被移动”事件里，组件.监视组件_ (来源对象, 横向位置, 纵向位置)" 折叠 折叠2>
    参数 组件 <类型 = 窗口组件>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 组件序号 <类型 = 整数 注释 = "自定义该组件的序号，可以用于事件中作判断使用" @默认值 = 0>
    {
        目标组件 = 组件
        原横向位置 = 横向位置
        原纵向位置 = 纵向位置
        原横向鼠标 = 取鼠标水平位置 ()
        原纵向鼠标 = 取鼠标垂直位置 ()
        目标组件序号 = 组件序号
        时钟1.启动时钟_ (10)
        鼠标事件 (组件, 目标组件序号, 真)
    }

    方法 停止监视_ <公开 注释 = "立即临时停止，非永久停止" 折叠>
    {
        时钟1.停止时钟_ ()
    }

    方法 时钟类__周期事件_ <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 时钟类_>
    参数 标记值 <类型 = 整数>
    参数 时钟ID <类型 = 整数>
    {
        变量 横向位置 <类型 = 整数>
        变量 纵向位置 <类型 = 整数>
        横向位置 = 取鼠标水平位置 () - 原横向鼠标 + 原横向位置
        纵向位置 = 取鼠标垂直位置 () - 原纵向鼠标 + 原纵向位置
        如果真 (横向位置 < 0 || 横向位置 > 目标组件.取用户区宽度 () || 纵向位置 < 0 || 纵向位置 > 目标组件.取用户区高度 ())
        {
            时钟1.停止时钟_ ()
            鼠标事件 (目标组件, 目标组件序号, 真 == 假)
        }
        返回 (0)
    }

    方法 鼠标事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
}

类 组件移入移出事件类2_ <公开 折叠 @文档 = "category = \"事件钩子库.组件出入监视\"">
{
    变量 句柄组 <类型 = 文本独有数组类>
    变量 互斥1 <类型 = 许可锁类_>

    方法 监视组件_ <公开 注释 = "将本命令放置在某个组件的“XX_组件消息过滤”事件里;" 注释 = "例如：“图片框_组件消息过滤”事件里，组件.监视组件_ (来源对象, 消息值)" 折叠 折叠2>
    参数 来源对象 <类型 = 窗口组件>
    参数 消息值 <类型 = 整数>
    参数 组件序号 <类型 = 整数 注释 = "自定义该组件的序号，可以用于事件中作判断使用" @默认值 = 0>
    参数 悬停时间 <类型 = 整数 注释 = "单位：毫秒 1000毫秒=1秒  。当鼠标停留在该组件上，到达此时间时触发是否悬停提示" @默认值 = 2000>
    {
        变量 窗口句柄 <类型 = 变整数>
        窗口句柄 = 来源对象.取窗口句柄 ()
        分支判断 (消息值)
        {
            分支 (512)  // 鼠标进入
            {
                @  TRACKMOUSEEVENT tme;  
                @ tme.cbSize = sizeof(tme);  
                @ tme.hwndTrack = (HWND)@<窗口句柄>;  
                @ tme.dwFlags = 1|2;  
                @ tme.dwHoverTime =@<悬停时间>;  
                @ TrackMouseEvent(&tme);
                互斥1.加锁 ()
                如果真 (句柄组.加入成员 (到文本 (窗口句柄)) != -1)
                {
                    鼠标事件 (来源对象, 组件序号, 真, 假)
                }
                互斥1.解锁 ()
            }
            分支 (673)  // 鼠标悬停
            {
                鼠标事件 (来源对象, 组件序号, 真, 真)
            }
            分支 (675)  // 鼠标离开
            {
                互斥1.加锁 ()
                句柄组.枚举循环 ()
                {
                    如果真 (句柄组.取枚举值 () == 到文本 (窗口句柄))
                    {
                        句柄组.删除成员 (句柄组.取枚举索引 (), )
                        跳出循环
                    }
                }
                互斥1.解锁 ()
                鼠标事件 (来源对象, 组件序号, 假, 假)
            }
        }
    }

    方法 鼠标事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源组件 <类型 = 窗口组件>
    参数 组件序号 <类型 = 整数 注释 = "自定义序号">
    参数 是否移入 <类型 = 逻辑型 注释 = "真：鼠标移入　假：鼠标移出">
    参数 是否悬停 <类型 = 逻辑型 注释 = "鼠标是否停留在组件上，到达设置的时间时触发为真">
}

# //===事件过滤====

类 事件过滤类_ <公开 注释 = "触发鼠标键盘事件" 折叠 @文档 = "category = \"事件钩子库.鼠键事件监视\"">
{
    变量 横位 <类型 = 整数>
    变量 纵位 <类型 = 整数>

    方法 过滤 <公开 注释 = "将命令放入“窗口组件_组件消息过滤”下，参数对应“事件过滤类__综合事件”中的参数" 注释 = "例如：过滤类1.过滤 (来源对象, 标记值, 窗口句柄, 消息值, 消息参数1)" 折叠 折叠2>
    参数 来源对象 <类型 = 窗口组件>
    参数 标记值 <类型 = 整数>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    {
        计算坐标 (窗口句柄)
        @ if(@<消息值>==WM_KEYDOWN)//按下某键
        @ {
        键盘按下事件 (来源对象, 标记值, (整数)消息参数1)
        综合事件 (来源对象, 标记值, 1, 0, (整数)消息参数1, 0, 0, 0, 0)
        @ }

        @ if(@<消息值>==WM_KEYUP)//放开某键
        @ {
        键盘松开事件 (来源对象, 标记值, (整数)消息参数1)
        综合事件 (来源对象, 标记值, 2, 0, (整数)消息参数1, 0, 0, 0, 0)
        @ }

        @ if(@<消息值>==WM_LBUTTONDOWN)//鼠标左键被按下
        @ {
        鼠标按下事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 1)
        综合事件 (来源对象, 标记值, 3, 1, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_LBUTTONUP)//鼠标左键被放开
        @ {
        鼠标松开事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 1)
        综合事件 (来源对象, 标记值, 4, 1, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_LBUTTONDBLCLK)//被双击
        @ {
        鼠标按下事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 4)
        综合事件 (来源对象, 标记值, 3, 4, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_RBUTTONDOWN)//鼠标右键被按下
        @ {
        鼠标按下事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 2)
        综合事件 (来源对象, 标记值, 3, 2, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_RBUTTONUP)//鼠标右键被放开
        @ {
        鼠标松开事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 2)
        综合事件 (来源对象, 标记值, 4, 2, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_MBUTTONDOWN)//鼠标中键被按下
        @ {
        鼠标按下事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 3)
        综合事件 (来源对象, 标记值, 3, 3, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_MBUTTONUP)//鼠标中键被放开
        @ {
        鼠标松开事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位, 3)
        综合事件 (来源对象, 标记值, 4, 3, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_MOUSEMOVE)//鼠标位置被移动
        @ {
        鼠标移动事件 (来源对象, 标记值, 窗口句柄, 横位, 纵位)
        综合事件 (来源对象, 标记值, 5, 0, 0, 窗口句柄, 横位, 纵位, 0)
        @ }

        @ if(@<消息值>==WM_MOUSEWHEEL)//滚轮被滚动
        @ {
        如果 (消息参数1 == -7864320 || 消息参数1 == 4287102976)
        {
            鼠标滚轮事件 (来源对象, 标记值, 窗口句柄, -1)
            综合事件 (来源对象, 标记值, 6, 0, 0, 窗口句柄, 0, 0, -1)
        }
        否则 (消息参数1 == 7864320)
        {
            鼠标滚轮事件 (来源对象, 标记值, 窗口句柄, 1)
            综合事件 (来源对象, 标记值, 6, 0, 0, 窗口句柄, 0, 0, 1)
        }
        @ }

        @ if(@<消息值>==WM_SETFOCUS)//获得焦点
        @ {
        焦点事件 (来源对象, 标记值, 窗口句柄, 1)
        综合事件 (来源对象, 标记值, 7, 0, 0, 窗口句柄, 0, 0, 0)
        @ }

        @ if(@<消息值>==WM_KILLFOCUS)//失去焦点
        @ {
        焦点事件 (来源对象, 标记值, 窗口句柄, 2)
        综合事件 (来源对象, 标记值, 8, 0, 0, 窗口句柄, 0, 0, 0)
        @ }

        @ if(@<消息值>==WM_CHAR)//字符输入
        @ {
        字符输入事件 (来源对象, 标记值, 窗口句柄)
        综合事件 (来源对象, 标记值, 9, 0, 0, 窗口句柄, 0, 0, 0)
        @ }

    }

    方法 计算坐标 <折叠>
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 坐标值 <类型 = 控件坐标值_>
        变量 坐标值2 <类型 = 控件坐标值_>
        坐标值 = 窗口_取窗口组件坐标 (窗口句柄)
        坐标值2 = 窗口_取窗口组件坐标 (取父窗口句柄_ (窗口句柄))
        横位 = 取鼠标水平位置 () + 坐标值.横向位置 + 1
        纵位 = 取鼠标垂直位置 () + 坐标值.纵向位置 + 1
    }

    方法 综合事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源对象2 <类型 = 窗口组件>
    参数 标记值2 <类型 = 整数>
    参数 事件类型 <类型 = 整数 注释 = "1键盘按下，2键盘松开，3鼠标按下,4鼠标松开，5鼠标移动,6鼠标滚轮，7获得焦点，8失去焦点,9字符输入">
    参数 鼠标类型 <类型 = 整数 注释 = "1左键，2右键，3中建，4双击">
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">
    参数 组件句柄 <类型 = 变整数>
    参数 横向位置 <类型 = 整数 注释 = "当前组件内的光标位，x轴，不含屏幕距离和其它组件">
    参数 纵向位置 <类型 = 整数 注释 = "当前组件内的光标位，y轴，不含屏幕距离和其它组件">
    参数 滚动距离 <类型 = 整数 注释 = "判断滚动方向，下滚：<0　上滚：>0">

    方法 键盘按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源对象2 <类型 = 窗口组件>
    参数 标记值2 <类型 = 整数>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 键盘松开事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源对象2 <类型 = 窗口组件>
    参数 标记值2 <类型 = 整数>
    参数 键代码 <类型 = 整数 注释 = "例如：按键码.A键">

    方法 鼠标按下事件 <公开 定义事件 类型 = 整数 折叠>
    参数 来源对象2 <类型 = 窗口组件>
    参数 标记值2 <类型 = 整数>
