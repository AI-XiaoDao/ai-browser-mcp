<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"事件钩子库\"">

# //===热键====

类 热键监视类_ <公开 折叠 @文档 = "category = \"事件钩子库.热键\"">
{
    变量 指针 <静态 类型 = 变整数>

    # @begin
    # int m_iKeyId = 0;
    # LONG_PTR  m_lpOldWindowPtr = 0;
    # @dt<变整数数组类> m_lPCallBack;
    # LRESULT CALLBACK winHotKeyCallBak(HWND hWnd, UINT message, WPARAM wParam, LPARAM lParam)
    # {
    #     switch(message)
    #     {
    #     case WM_HOTKEY: 
    #         {
    #            return ::CallWindowProc((WNDPROC)m_lPCallBack.data().GetAt((int)wParam), hWnd, message, wParam, lParam);
    #         }
    #     default: return ::CallWindowProc((WNDPROC)m_lpOldWindowPtr, hWnd, message, wParam, lParam);
    #     }
    # }
    # @end

    方法 类_初始化 <折叠>
    {
        @ @<指针>=(@dt<变整数>)this;
    }

    方法 注册热键_ <公开 类型 = 整数 返回值注释 = "成功返回热键ID，失败返回-1" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 功能键 <类型 = 整数 注释 = "1、ALT  2、Ctrl  4、Shift  8、Win    ；组合功能键，直接数字相加即可" @默认值 = 0>
    参数 键代码 <类型 = 整数 注释 = "例如：键代码.V键">
    {
        @ if(!::RegisterHotKey((HWND)@<窗口句柄>,m_iKeyId,@<功能键>,@<键代码>)) return -1;
        @ m_iKeyId ++; 
        @ m_lPCallBack.data ().Add2 ((INT_P)&@<内部按键消息>);
        @ if (m_iKeyId > 1) return m_iKeyId-1;
        @ m_lpOldWindowPtr = ::SetWindowLongPtrW((HWND)@<窗口句柄>,GWLP_WNDPROC,(LONG_PTR)winHotKeyCallBak);
        @ return m_iKeyId-1;
    }

    方法 卸载热键_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 热键ID <类型 = 整数>
    {
        @ return ::UnregisterHotKey((HWND)@<窗口句柄>,@<热键ID>);
    }

    方法 内部按键消息 <静态 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    {
        读指针处对象 (指针, 热键监视类_).热键触发事件 ((整数)消息参数1)
    }

    方法 热键触发事件 <公开 定义事件 类型 = 整数 折叠>
    参数 热键ID <类型 = 整数>
}

# //===钩子====

类 钩子类_ <公开 折叠 @文档 = "category = \"事件钩子库.钩子\"">
{
    变量 键盘句柄 <静态 类型 = 变整数>
    变量 鼠标句柄 <静态 类型 = 变整数>
    变量 消息句柄 <静态 类型 = 变整数>
    变量 指针 <静态 类型 = 变整数>
    变量 独有1 <静态 类型 = 文本独有数组类>
    变量 互斥1 <静态 类型 = 许可锁类_>
    变量 键盘单次 <静态 类型 = 逻辑型>
    变量 全局屏蔽按键 <静态 类型 = 逻辑型>
    变量 全局屏蔽所有按键 <静态 类型 = 逻辑型>
    变量 全局屏蔽鼠标 <静态 类型 = 逻辑型>
    变量 全局屏蔽所有鼠标 <静态 类型 = 逻辑型>
    变量 全局键值组1 <静态 类型 = 整数数组类>
    变量 全局键值组2 <静态 类型 = "整数数组类 [2]">
    变量 全局键值组3 <静态 类型 = 整数数组类>
    变量 全局鼠标组 <静态 类型 = 整数数组类>
    变量 是否按下功能键 <静态 类型 = 逻辑型>
    变量 全局键盘 <静态 类型 = 逻辑型>
    变量 坐标 <静态 类型 = 控件坐标值_>
    变量 坐标2 <静态 类型 = 控件坐标值_>
    变量 互斥2 <类型 = 许可锁类_>
    变量 互斥3 <类型 = 许可锁类_>

    方法 注册键盘钩子_ <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否全局 <类型 = 逻辑型 @默认值 = 真>
    参数 开启屏蔽按键 <类型 = 逻辑型 注释 = "真：将拦截系统中的按键信息" @默认值 = 假>
    参数 屏蔽所有按键 <类型 = 逻辑型 注释 = "真：屏蔽整个键盘按键　；“开启屏蔽按键”设置为真时，本参数才会生效." 注释 = "无法拦截Ctrl+Alt+Del，可以配置“锁定任务管理器_”命令" @默认值 = 假>
    参数 触发单次 <类型 = 逻辑型 注释 = "真：按住某键时只触发一次" @默认值 = 真>
    {
        变量 临时句柄 <类型 = 变整数>
        变量 句柄标识 <类型 = 整数>
        钩子api.UnhookWindowsHookEx (键盘句柄)
        @ @<指针>=(@dt<变整数>)this;
        键盘单次 = 触发单次
        全局屏蔽按键 = 开启屏蔽按键
        如果真 (开启屏蔽按键 == 真)
        {
            是否全局 = 真
            全局屏蔽所有按键 = 屏蔽所有按键
        }
        如果 (是否全局)
        {
            @ @<临时句柄> = (@dt<变整数>)@<键盘处理1>;
            键盘句柄 = 钩子api.SetWindowsHookExW (13, 临时句柄, 0, 0)
        }
        否则
        {
            @ @<临时句柄> = (@dt<变整数>)@<键盘处理2>;
            句柄标识 = 钩子api.GetWindowThreadProcessId (窗口句柄, 0)
            键盘句柄 = 钩子api.SetWindowsHookExW (2, 临时句柄, 0, 句柄标识)
            @ @<消息句柄>=(@dt<变整数>)@<内部键盘消息处理>;
        }
        全局键盘 = 是否全局
        返回 (键盘句柄)
    }

    方法 注册鼠标钩子_ <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    参数 是否全局 <类型 = 逻辑型 @默认值 = 真>
    参数 开启屏蔽鼠标 <类型 = 逻辑型 注释 = "真：将拦截系统中的鼠标操作信息" @默认值 = 假>
    参数 屏蔽所有鼠标 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时句柄 <类型 = 变整数>
        变量 句柄标识 <类型 = 整数>
        钩子api.UnhookWindowsHookEx (鼠标句柄)
        @ @<指针>=(@dt<变整数>)this;
        全局屏蔽鼠标 = 开启屏蔽鼠标
        如果真 (开启屏蔽鼠标 == 真)
        {
            是否全局 = 真
            全局屏蔽所有鼠标 = 屏蔽所有鼠标
        }
        如果 (是否全局)
        {
            @ @<临时句柄> = (@dt<变整数>)@<鼠标处理>;
            鼠标句柄 = 钩子api.SetWindowsHookExW (14, 临时句柄, 0, 0)
        }
        否则
        {
            @ @<临时句柄> = (@dt<变整数>)@<鼠标处理>;
            句柄标识 = 钩子api.GetWindowThreadProcessId (窗口句柄, 0)
            鼠标句柄 = 钩子api.SetWindowsHookExW (7, 临时句柄, 0, 句柄标识)
        }
        返回 (鼠标句柄)
    }

    方法 加入屏蔽组合键输出_ <公开 注释 = "针对按下Shift+某键时，会输出某键的问题" 折叠>
    参数 键值 <类型 = 整数 注释 = "例如：按键码.F键">
    {
        变量 结果 <类型 = 逻辑型>
        互斥2.加锁 ()
        全局键值组3.枚举循环 ()
        {
            如果真 (全局键值组3.取枚举值 () == 键值)
            {
                结果 = 真
                跳出循环
            }
        }
        如果真 (结果 == 假)
        {
            全局键值组3.加入成员 (键值)
        }
        互斥2.解锁 ()
    }

    方法 删除屏蔽组合键输出_ <公开 折叠>
    参数 键值 <类型 = 整数>
    {
        互斥2.加锁 ()
        全局键值组3.枚举循环 ()
        {
            如果真 (全局键值组3.取枚举值 () == 键值)
            {
                全局键值组3.删除成员 (全局键值组3.取枚举索引 ())
                跳出循环
            }
        }
        互斥2.解锁 ()
    }

    方法 开启拦截按键_ <公开 折叠>
    参数 是否开启 <类型 = 逻辑型 注释 = "真：将拦截系统中的按键信息" @默认值 = 真>
    参数 屏蔽所有按键 <类型 = 逻辑型 注释 = "真：屏蔽整个键盘按键　；参数一“是否开启”设置为真时，本参数才会生效" @默认值 = 假>
    {
        全局屏蔽按键 = 是否开启
        处理事件_ ()
        如果 (是否开启 == 真)
        {
            全局屏蔽所有按键 = 屏蔽所有按键
        }
        否则
        {
            全局屏蔽所有按键 = 假
        }
    }

    方法 加入屏蔽键_ <公开 注释 = "不清楚键值的可以通过“键代码信息输出事件”查看." 注释 = "例：" 注释 = "Alt+Tab = 9 15" 注释 = "Alt+Tab = 32 57" 注释 = "Alt+F4 = 115 62"
            注释 = "Win = 91" 注释 = "Win = 92" 折叠 折叠2>
    参数 键值一 <类型 = 整数 注释 = "单填写参数一则屏蔽单键。例如：按键码.F键">
    参数 键值二 <类型 = 整数 注释 = "两个参数均填写则可屏蔽组合键." 注释 = "无法拦截Ctrl+Alt+Del，可以配置“锁定任务管理器_”命令" @默认值 = -1>
    参数 是否组合键 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 结果 <类型 = 逻辑型>
        互斥2.加锁 ()
        如果真 (键值一 > 0 && 键值二 < 1)
        {
            全局键值组1.枚举循环 ()
            {
                如果真 (全局键值组1.取枚举值 () == 键值一)
                {
                    结果 = 真
                    跳出循环
                }
            }
            如果真 (结果 == 假)
            {
                全局键值组1.加入成员 (键值一)
            }
        }
        如果真 (键值一 > 0 && 键值二 > 0)
        {
            全局键值组2 [0].枚举循环 ()
            {
                如果真 (全局键值组2 [0].取枚举值 () == 键值一 && 全局键值组2 [1].取枚举值 () == 键值二)
                {
                    结果 = 真
                    跳出循环
                }
            }
            如果真 (结果 == 假)
            {
                全局键值组2 [0].加入成员 (键值一)
                全局键值组2 [1].加入成员 (键值二)
            }
        }
        互斥2.解锁 ()
    }

    方法 删除屏蔽键_ <公开 折叠>
    参数 键值一 <类型 = 整数 注释 = "单填写参数一则删除单键">
    参数 键值二 <类型 = 整数 注释 = "两个参数均填写则可删除组合键" @默认值 = -1>
    {
        互斥2.加锁 ()
        如果真 (键值一 > 0 && 键值二 < 1)
        {
            全局键值组1.枚举循环 ()
            {
                如果真 (全局键值组1.取枚举值 () == 键值一)
                {
                    全局键值组1.删除成员 (全局键值组1.取枚举索引 ())
                    跳出循环
                }
            }
        }
        如果真 (键值一 > 0 && 键值二 > 0)
        {
            全局键值组2 [0].枚举循环 ()
            {
                如果真 (全局键值组2 [0].取枚举值 () == 键值一 && 全局键值组2 [1].取枚举值 () == 键值二)
                {
                    全局键值组2 [0].删除成员 (全局键值组2 [0].取枚举索引 ())
                    全局键值组2 [1].删除成员 (全局键值组2 [1].取枚举索引 ())
                    跳出循环
                }
            }
        }
        互斥2.解锁 ()
    }

    方法 开启拦截鼠标_ <公开 折叠>
    参数 是否开启 <类型 = 逻辑型 注释 = "真：将拦截系统中的鼠标操作信息" @默认值 = 真>
    参数 屏蔽所有鼠标 <类型 = 逻辑型 @默认值 = 假>
    {
        全局屏蔽鼠标 = 是否开启
        处理事件_ ()
        如果 (是否开启 == 真)
        {
            全局屏蔽所有鼠标 = 屏蔽所有鼠标
        }
        否则
        {
            全局屏蔽所有鼠标 = 假
        }
    }

    方法 加入屏蔽鼠标_ <公开 折叠>
    参数 鼠标操作类型 <类型 = 整数 注释 = "1、鼠标左键按下　2、鼠标左键放开　3、鼠标右键按下　4、鼠标右键放开." 注释 = "5、鼠标中键按下　6、鼠标中键放开　7、鼠标上滚　8、鼠标下滚">
    {
        互斥3.加锁 ()
        如果 (鼠标操作类型 == 1)
        {
            如果真 (是否已加入 (513) == 假)
            {
                全局鼠标组.加入成员 (513)
            }
        }
        否则 (鼠标操作类型 == 2)
        {
            如果真 (是否已加入 (514) == 假)
            {
                全局鼠标组.加入成员 (514)
            }
        }
        否则 (鼠标操作类型 == 3)
        {
            如果真 (是否已加入 (516) == 假)
            {
                全局鼠标组.加入成员 (516)
            }
        }
        否则 (鼠标操作类型 == 4)
        {
            如果真 (是否已加入 (517) == 假)
            {
                全局鼠标组.加入成员 (517)
            }
        }
        否则 (鼠标操作类型 == 5)
        {
            如果真 (是否已加入 (519) == 假)
            {
                全局鼠标组.加入成员 (519)
            }
        }
        否则 (鼠标操作类型 == 6)
        {
            如果真 (是否已加入 (520) == 假)
            {
                全局鼠标组.加入成员 (520)
            }
        }
        否则 (鼠标操作类型 == 7)
        {
            如果真 (是否已加入 (120) == 假)
            {
                全局鼠标组.加入成员 (120)
            }
        }
        否则 (鼠标操作类型 == 8)
        {
            如果真 (是否已加入 (-120) == 假)
            {
                全局鼠标组.加入成员 (-120)
            }
        }
        互斥3.解锁 ()
    }

    方法 删除屏蔽鼠标_ <公开 折叠>
    参数 鼠标操作类型 <类型 = 整数 注释 = "1、鼠标左键按下　2、鼠标左键放开　3、鼠标右键按下　4、鼠标右键放开." 注释 = "5、鼠标中键按下　6、鼠标中键放开　7、鼠标上滚　8、鼠标下滚">
    {
        变量 临时值 <类型 = 整数>
        互斥3.加锁 ()
        如果 (鼠标操作类型 == 1)
        {
            临时值 = 513
        }
        否则 (鼠标操作类型 == 2)
        {
            临时值 = 514
        }
        否则 (鼠标操作类型 == 3)
        {
            临时值 = 516
        }
        否则 (鼠标操作类型 == 4)
        {
            临时值 = 517
        }
        否则 (鼠标操作类型 == 5)
        {
            临时值 = 519
        }
        否则 (鼠标操作类型 == 6)
        {
            临时值 = 520
        }
        否则 (鼠标操作类型 == 7)
        {
            临时值 = 120
        }
        否则 (鼠标操作类型 == 8)
        {
            临时值 = -120
        }
        全局鼠标组.枚举循环 ()
        {
            如果真 (全局鼠标组.取枚举值 () == 临时值)
            {
                全局鼠标组.删除成员 (全局鼠标组.取枚举索引 ())
                跳出循环
            }
        }
        互斥3.解锁 ()
    }

    方法 卸载钩子_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 钩子句柄 <类型 = 变整数 注释 = "注册钩子时返回的句柄，留空将卸载所有钩子" @默认值 = 0>
    {
        变量 bRes <类型 = 逻辑型>
        全局键值组1.删除所有成员 ()
        全局键值组2 [0].删除所有成员 ()
        全局键值组2 [1].删除所有成员 ()
        连续赋值 (假, 全局屏蔽按键, 全局屏蔽所有按键, 全局屏蔽鼠标, 全局屏蔽所有鼠标)
        如果 (钩子句柄 <= 0)
        {
            如果真 (键盘句柄 > 0)
            {
                bRes = 钩子api.UnhookWindowsHookEx (键盘句柄)
                键盘句柄 = 0
            }
            如果真 (鼠标句柄 > 0)
            {
                bRes = 钩子api.UnhookWindowsHookEx (鼠标句柄)
                鼠标句柄 = 0
            }
        }
        否则
        {
            bRes = 钩子api.UnhookWindowsHookEx (钩子句柄)
        }
        返回 (bRes)
    }

    方法 是否已加入 <类型 = 逻辑型 折叠>
    参数 值 <类型 = 整数>
    {
        变量 结果 <类型 = 逻辑型>
        全局鼠标组.枚举循环 ()
        {
            如果真 (全局鼠标组.取枚举值 () == 值)
            {
                结果 = 真
                跳出循环
            }
        }
        返回 (结果)
    }

    方法 内部键盘消息处理 <静态 折叠 折叠2 @禁止流程检查 = 真 @视窗.前缀文本 = "@WINAPI">
    参数 按键类型 <类型 = 变整数>
    参数 键代码 <类型 = 整数>
    参数 其它 <类型 = 整数>
    {
        变量 是否按下Ctrl <静态 类型 = 逻辑型>
        变量 是否按下Alt <静态 类型 = 逻辑型>
        变量 是否按下Shift <静态 类型 = 逻辑型>
        变量 是否按下Win <静态 类型 = 逻辑型>
        变量 放开还是按下 <静态 类型 = 逻辑型>
        变量 是否功能键 <静态 类型 = 逻辑型>
        如果 (按键类型 == 256 || 按键类型 == 260)
        {
            放开还是按下 = 真
            如果 (全局键盘)
            {
                如果 (键代码 == 160 || 键代码 == 161)
                {
                    是否按下Shift = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 162 || 键代码 == 163)
                {
                    是否按下Ctrl = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 164 || 键代码 == 165)
                {
                    是否按下Alt = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 91 || 键代码 == 92)
                {
                    是否按下Win = 真
                    是否功能键 = 真
                }
            }
            否则
            {
                如果 (键代码 == 16)
                {
                    是否按下Shift = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 17)
                {
                    是否按下Ctrl = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 18)
                {
                    是否按下Alt = 真
                    是否功能键 = 真
                }
                如果 (键代码 == 91)
                {
                    是否按下Win = 真
                    是否功能键 = 真
                }
            }
            如果真 (是否按下Alt == 假 && 是否按下Ctrl == 假 && 是否按下Shift == 假 && 是否按下Win == 假)
            {
                是否功能键 = 假
            }
            如果 (键盘单次 == 真)
            {
                互斥1.加锁 ()
                如果真 (独有1.加入成员 (到文本 (键代码)) != -1)
                {
                    如果真 (是否按下Shift == 真)
                    {
                        是否按下功能键 = 真
                    }
                    如果 (是否按下Alt || 是否按下Ctrl || 是否按下Shift || 是否按下Win)
                    {
                        读指针处对象 (指针, 钩子类_).组合键回调事件 (键代码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下Win, 放开还是按下)
                    }
                    否则
                    {
                        读指针处对象 (指针, 钩子类_).键盘按下事件 (键代码)
                    }
                }
                互斥1.解锁 ()
            }
            否则
            {
                如果真 (是否按下Shift == 真)
                {
                    是否按下功能键 = 真
                }
                如果 (是否按下Alt || 是否按下Ctrl || 是否按下Shift || 是否按下Win)
                {
                    读指针处对象 (指针, 钩子类_).组合键回调事件 (键代码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下Win, 放开还是按下)
                }
                否则
                {
                    读指针处对象 (指针, 钩子类_).键盘按下事件 (键代码)
                }
            }
        }
        否则 (按键类型 == 257 || 按键类型 == 261)
        {
            放开还是按下 = 假
            如果 (全局键盘)
            {
                如果 (键代码 == 160 || 键代码 == 161)
                {
                    是否按下Shift = 假
                }
                如果 (键代码 == 162 || 键代码 == 163)
                {
                    是否按下Ctrl = 假
                }
                如果 (键代码 == 164 || 键代码 == 165)
                {
                    是否按下Alt = 假
                }
                如果 (键代码 == 91 || 键代码 == 92)
                {
                    是否按下Win = 假
                }
            }
            否则
            {
                如果 (键代码 == 16)
                {
                    是否按下Shift = 假
                }
                如果 (键代码 == 17)
                {
                    是否按下Ctrl = 假
                }
                如果 (键代码 == 18)
                {
                    是否按下Alt = 假
                }
                如果 (键代码 == 91)
                {
                    是否按下Win = 假
                }
            }
            互斥1.加锁 ()
            独有1.删除所有成员 ()
            互斥1.解锁 ()
            是否按下功能键 = 假
            如果 (是否按下Alt || 是否按下Ctrl || 是否按下Shift || 是否按下Win)
            {
                读指针处对象 (指针, 钩子类_).组合键回调事件 (键代码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下Win, 放开还是按下)
            }
            否则
            {
                如果 (是否功能键)
                {
                    读指针处对象 (指针, 钩子类_).组合键回调事件 (键代码, 是否按下Ctrl, 是否按下Alt, 是否按下Shift, 是否按下Win, 放开还是按下)
                }
                否则
                {
                    读指针处对象 (指针, 钩子类_).键盘松开事件 (键代码)
                }
                如果真 (是否按下Alt == 假 && 是否按下Ctrl == 假 && 是否按下Shift == 假 && 是否按下Win == 假)
                {
                    是否功能键 = 假
                }
            }
        }
    }

    方法 键盘处理1 <静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @视窗.前缀文本 = "@WINAPI">
    参数 nCode <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        变量 数据 <类型 = 字节集类>
        变量 虚拟码 <类型 = 整数>
        变量 扫描码 <类型 = 整数>
        数据 = 指针到字节集 (lParam, 32)
        虚拟码 = 任意进制转十进制_整数 (字节集到十六进制文本 (取字节集左边 (数据, 1)), 16)
        扫描码 = 任意进制转十进制_整数 (字节集到十六进制文本 (取字节集中间 (数据, 4, 1)), 16)
        @ typedef VOID(WINAPI* Func)(INT_PTR, INT, INT);
        如果真 (nCode == 0)
        {
            @ auto &info = *(const KBDLLHOOKSTRUCT*)@<lParam>;
            @ if (@<wParam> == WM_KEYDOWN || @<wParam> == WM_KEYUP || @<wParam> == WM_CHAR)
            @ {
            如果真 (消息句柄 > 0)
            {
                @ Func pfnFunc = (Func)@<消息句柄>;
                @ pfnFunc(@<wParam>, info.vkCode, 0);
            }
            @ }
            // 如果真 (虚拟码 == 164 || 虚拟码 == 165)
            // 如果真 (wParam == 256 || wParam == 260)
            如果真 (wParam == 256 || wParam == 257 || wParam == 260 || wParam == 261)
            {
                内部键盘消息处理 (wParam, 虚拟码, 0)
            }
            如果真 (全局屏蔽按键 == 真)
            {
                读指针处对象 (指针, 钩子类_).键代码信息输出事件 (虚拟码, 扫描码)
                如果真 (是否按下功能键 == 真)
                {
                    全局键值组3.枚举循环 ()
                    {
                        如果真 (全局键值组3.取枚举值 () == 虚拟码)
                        {
                            返回 (1)
                        }
                    }
                }
                如果 (全局屏蔽所有按键 == 真)
                {
                    返回 (1)
                }
                否则
                {
                    全局键值组1.枚举循环 ()
                    {
                        如果真 (全局键值组1.取枚举值 () == 虚拟码)
                        {
                            返回 (1)
                        }
                    }
                    全局键值组2 [0].枚举循环 ()
                    {
                        如果真 (全局键值组2 [0].取枚举值 () == 虚拟码 && 全局键值组2 [1].取枚举值 () == 扫描码)
                        {
                            返回 (1)
                        }
                    }
                }
            }
        }
        返回 (钩子api.CallNextHookEx (键盘句柄, nCode, wParam, lParam))
    }

    方法 键盘处理2 <静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @视窗.前缀文本 = "@WINAPI">
    参数 nCode <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        常量 WM_KEYDOWN <类型 = 整数 值 = 256>
        常量 WM_KEYUP <类型 = 整数 值 = 257>
        变量 KeyState <类型 = 整数>
        @ typedef VOID(WINAPI* Func)(INT_PTR, INT, INT);
        如果真 (nCode == 0)
        {
            KeyState = 选择 (位右移 (钩子api.GetAsyncKeyState ((整数)wParam), 16) == -1, WM_KEYDOWN, WM_KEYUP)
            如果真 (消息句柄 > 0)
            {
                @ Func pfnFunc = (Func)@<消息句柄>;
                @ pfnFunc(@<KeyState>, @<wParam>, 0);
            }
        }
        返回 (钩子api.CallNextHookEx (键盘句柄, nCode, wParam, lParam))
    }

    方法 鼠标处理 <静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @视窗.前缀文本 = "@WINAPI">
    参数 nCode <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        变量 scroll <类型 = 短整数>
        变量 uMsg <类型 = 整数>
        变量 临时句柄 <类型 = 变整数>
        变量 临时坐标 <类型 = 控件坐标值_>
        @ typedef VOID(WINAPI* Func)(INT, INT, INT);
        如果真 (nCode >= 0)
        {
            @ auto &info = *(const MOUSEHOOKSTRUCT*)@<lParam>;
            @ @<scroll> = GET_WHEEL_DELTA_WPARAM(info.hwnd);
            uMsg = LOWORD (wParam)
            如果真 (全局屏蔽鼠标 == 真)
            {
                如果 (全局屏蔽所有鼠标 == 真)
                {
                    返回 (1)
                }
                全局鼠标组.枚举循环 ()
                {
                    如果真 (全局鼠标组.取枚举值 () == scroll || 全局鼠标组.取枚举值 () == uMsg)
                    {
                        返回 (1)
                    }
                }
            }
            如果 (scroll == 120)
            {
                读指针处对象 (指针, 钩子类_).鼠标滚轮事件 (1)
            }
            如果 (scroll == -120)
            {
                读指针处对象 (指针, 钩子类_).鼠标滚轮事件 (-1)
            }
            如果 (uMsg == 513)  // 鼠标左键按下
            {
                读指针处对象 (指针, 钩子类_).鼠标按下事件 (1)
            }
            如果 (uMsg == 514)  // 鼠标左键放开
            {
                读指针处对象 (指针, 钩子类_).鼠标松开事件 (1)
            }
            如果 (uMsg == 516)  // 鼠标右键按下
            {
                读指针处对象 (指针, 钩子类_).鼠标按下事件 (2)
            }
            如果 (uMsg == 517)  // 鼠标右键放开
            {
                读指针处对象 (指针, 钩子类_).鼠标松开事件 (2)
            }
            如果 (uMsg == 519)  // 鼠标中键按下
            {
                读指针处对象 (指针, 钩子类_).鼠标按下事件 (3)
            }
            如果 (uMsg == 520)  // 鼠标中键放开
            {
                读指针处对象 (指针, 钩子类_).鼠标松开事件 (3)
            }
            鼠标_取鼠标位置 (坐标)
            临时句柄 = 窗口_取鼠标处窗口句柄 ()
            临时坐标 = 窗口_取窗口组件坐标 (临时句柄)
            如果真 (坐标.横向位置 != 坐标2.横向位置 || 坐标.纵向位置 != 坐标2.纵向位置)
            {
                读指针处对象 (指针, 钩子类_).鼠标移动事件 (临时句柄, 坐标.横向位置, 坐标.纵向位置, 坐标.横向位置 + 临时坐标.横向位置, 坐标.纵向位置 + 临时坐标.纵向位置)
            }
            坐标2 = 坐标
        }
        返回 (钩子api.CallNextHookEx (鼠标句柄, nCode, wParam, lParam))
    }

    方法 LOWORD <静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 l <类型 = 变整数>
    {
        @ return ((WORD)(((DWORD_PTR)(@<l>)) & 0xffff));
    }

