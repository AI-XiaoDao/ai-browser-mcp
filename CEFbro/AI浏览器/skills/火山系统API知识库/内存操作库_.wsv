    方法 内存_写内存文本 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 文本型>
    参数 Unicode编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 地址2 <类型 = 变整数>
        变量 进程句柄 <类型 = 变整数>
        变量 空白数据 <类型 = 字节集类>
        变量 地址 <类型 = 变整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        {
            如果真 (进程句柄 != 0)
            {
                如果 (Unicode编码 == 假)
                {
                    空白数据 = 转Unicode到Ascii_ (写入值)
                }
                否则
                {
                    空白数据 = 到字节集 (写入值)
                }
                地址2 = 内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (空白数据), 64)
                地址 = 内存api.WriteProcessMemory (进程句柄, 内存地址, 取字节集指针 (空白数据), 取字节集长度 (空白数据), 0)
                内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (空白数据), 地址2)
                进程_关闭进程 (进程句柄)
                返回 (地址 != 0)
            }
        }
        返回 (假)
    }

    方法 内存_读内存文本 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 内存长度 <类型 = 整数>
    参数 Unicode编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 进程句柄 <类型 = 变整数>
        变量 空白数据 <类型 = 字节集类 "">
        变量 地址 <类型 = 变整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        如果真 (进程句柄 != 0)
        {
            空白数据 = 取空白字节集 (内存长度)
            地址 = 内存api.ReadProcessMemory (进程句柄, 内存地址, 取字节集指针 (空白数据), 内存长度, 0)
            进程_关闭进程 (进程句柄)
        }
        如果 (Unicode编码 == 假)
        {
            返回 (转Ascii到Unicode_ (空白数据))
        }
        否则
        {
            返回 (字节集到文本 (空白数据))
        }
    }

    方法 内存_写内存文本2 <公开 静态 类型 = 逻辑型 注释 = "胖指针方式" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 文本型>
    参数 Unicode编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 地址2 <类型 = 变整数>
        变量 进程句柄 <类型 = 变整数>
        变量 空白数据 <类型 = 字节集类>
        变量 地址 <类型 = 变整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        如果真 (进程句柄 != 0)
        {
            如果 (Unicode编码 == 假)
            {
                空白数据 = 转Unicode到Ascii_ (写入值)
            }
            否则
            {
                空白数据 = 到字节集 (写入值)
            }
            内存_写内存整数 (进程ID, 内存地址, 空白数据.取字节集长度 ())
            地址2 = 内存_修改内存属性3 (进程句柄, 内存地址 + 4, 取字节集长度 (空白数据), 64)
            地址 = 内存api.WriteProcessMemory (进程句柄, 内存地址 + 4, 取字节集指针 (空白数据), 取字节集长度 (空白数据), 0)
            内存_修改内存属性3 (进程句柄, 内存地址 + 4, 取字节集长度 (空白数据), 地址2)
            进程_关闭进程 (进程句柄)
            返回 (地址 != 0)
        }
        返回 (假)
    }

    方法 内存_读内存文本2 <公开 静态 类型 = 文本型 注释 = "胖指针方式，不需要指定长度" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 Unicode编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 进程句柄 <类型 = 变整数>
        变量 空白数据 <类型 = 字节集类 "">
        变量 地址 <类型 = 变整数>
        变量 长度 <类型 = 整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        如果真 (进程句柄 != 0)
        {
            长度 = 内存_读内存整数 (进程ID, 内存地址)
            空白数据 = 取空白字节集 (长度)
            地址 = 内存api.ReadProcessMemory (进程句柄, 内存地址 + 4, 取字节集指针 (空白数据), 长度, 0)
            进程_关闭进程 (进程句柄)
        }
        如果 (Unicode编码 == 假)
        {
            返回 (转Ascii到Unicode_ (空白数据))
        }
        否则
        {
            返回 (字节集到文本 (空白数据))
        }
    }

    方法 内存_写内存文本3 <公开 静态 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数 "">
    参数 写入值 <类型 = 文本型>
    参数 长度 <类型 = 变整数>
    {
        @ memcpy((void*)@<内存地址>,(const void*)@<写入值>,@<长度>);
    }

    方法 内存_读内存文本3 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 长度 <类型 = 变整数>
    {
        变量 Buffer <类型 = 文本型>
        @ int Size = @<长度>;
        @ LPWSTR Buffer = new TCHAR[Size]();
        @ memcpy((void*)Buffer,(const void*)@<内存地址>,Size);
        @ @<Buffer> = Buffer;
        @ delete[] Buffer;
        @ return @<Buffer>.GetText();
    }

