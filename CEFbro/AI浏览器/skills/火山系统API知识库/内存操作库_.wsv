<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"内存操作库\"">

类 远程Call操作类_ <公开 折叠 折叠2 @文档 = "category = \"内存操作库.远程Call\"" @全局类 = 真>
{
    方法 内存_FastCall <公开 静态 类型 = 长整数 注释 = "非嵌入" 折叠 @禁止流程检查 = 真>
    参数 指向地址 <类型 = 变整数 注释 = "call地址">
    参数 RCX <类型 = 变整数 @默认值 = 0>
    参数 RDX <类型 = 变整数 @默认值 = 0>
    参数 R8 <类型 = 变整数 @默认值 = 0>
    参数 R9 <类型 = 变整数 @默认值 = 0>
    参数 R10 <类型 = 变整数 @默认值 = 0>
    参数 R11 <类型 = 变整数 @默认值 = 0>
    参数 R12 <类型 = 变整数 @默认值 = 0>
    参数 R13 <类型 = 变整数 @默认值 = 0>
    参数 R14 <类型 = 变整数 @默认值 = 0>
    参数 R15 <类型 = 变整数 @默认值 = 0>
    {
        @ typedef INT64(__fastcall* Tfunction)(INT64 @<RCX>,INT64 @<RDX>,INT64 @<R8>,INT64 @<R9>,INT64 @<R10>,INT64 @<R11>,INT64 @<R12>,INT64 @<R13>,INT64 @<R14>,INT64 @<R15>);
        @ Tfunction function = (Tfunction)@<指向地址>;
        @ return function(@<RCX>,@<RDX>,@<R8>,@<R9>,@<R10>,@<R11>,@<R12>,@<R13>,@<R14>,@<R15>);
    }

    方法 内存_远程Call <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 汇编字节集 <类型 = 字节集类>
    {
        变量 指针 <类型 = 变整数>
        变量 写入长度 <类型 = 整数>
        指针 = 汇编字节集.取字节集指针 ()
        写入长度 = 汇编字节集.取字节集长度 () + 1
        @ HANDLE  hProcess=OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
        @ LPVOID ptr= VirtualAllocEx(hProcess,0,@<写入长度>,4096,64);
        @ if( WriteProcessMemory(hProcess,ptr,(void*)@<指针>,@<写入长度>,0)==0){ VirtualFreeEx(hProcess,ptr,0,32768);return false;}
        @ HANDLE hThread = CreateRemoteThread(hProcess,0,0,(LPTHREAD_START_ROUTINE)ptr,0,4,NULL);
        @ if (hThread==NULL){return false ;}
        @ ResumeThread(hThread);
        @ WaitForSingleObject(hThread, -1);
        @ CloseHandle(hThread);
        @  VirtualFreeEx(hProcess,ptr,0,32768);
        @ return true;
    }

    方法 内存_远程Call2 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 指向地址 <类型 = 变整数 注释 = "Call地址">
    参数 附加参数 <类型 = 变整数>
    参数 p1 <类型 = 变整数 @默认值 = 0>
    参数 p2 <类型 = 变整数 @默认值 = 0>
    参数 p3 <类型 = 变整数 @默认值 = 0>
    参数 p4 <类型 = 变整数 @默认值 = 0>
    参数 p5 <类型 = 变整数 @默认值 = 0>
    参数 p6 <类型 = 变整数 @默认值 = 0>
    参数 p7 <类型 = 变整数 @默认值 = 0>
    参数 p8 <类型 = 变整数 @默认值 = 0>
    {
        如果 (附加参数 == 0)
        {
            @ HANDLE hRemoteThread = NULL;
            @ PTHREAD_START_ROUTINE CallWindows = NULL;
            @ HMODULE hModule = GetModuleHandleA("user32.dll");
            @ if (hModule != NULL) {
            @  CallWindows = (PTHREAD_START_ROUTINE)GetProcAddress(hModule, "CallWindowProcA");
            @  if (CallWindows != NULL) {
            @   hRemoteThread = CreateThread(NULL, 0, CallWindows, (LPVOID)@<指向地址>, 0, NULL);
            @   if (hRemoteThread != NULL) {
            @    WaitForSingleObject(hRemoteThread, INFINITE);
            @    CloseHandle(hRemoteThread);
            @    return *(__int64*)(@<指向地址>);
            @   }
            @  }
            @ }
            @ return 0;
        }
        否则
        {
            @ typedef INT64(_fastcall* Tfunction)(INT64,INT64,INT64,INT64,INT64,INT64,INT64,INT64,INT64);
            @ Tfunction function = (Tfunction)@<指向地址>;
            @ return function(@<附加参数>,@<p1>,@<p2>,@<p3>,@<p4>,@<p5>,@<p6>,@<p7>,@<p8>);
        }
    }
}

# //==========

类 内存释放类_ <公开 折叠 折叠2 @文档 = "category = \"内存操作库.内存释放\"" @全局类 = 真>
{
    方法 内存_释放程序内存 <公开 静态 类型 = 逻辑型 注释 = "释放指定程序进程的内存" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "psapi.h" @视窗.外部库 = "psapi.lib">
    参数 进程ID <类型 = 整数 注释 = "默认为自身进程ID" @默认值 = 0>
    参数 最小工作集 <类型 = 整数 注释 = "默认为1M ，单位：字节。进程在物理内存中当前实际存在的页面集合" @默认值 = 1048576>
    参数 最大工作集 <类型 = 整数 注释 = "默认为2M ，单位：字节。进程在物理内存中当前实际存在的页面集合" @默认值 = 2097152>
    {
        @ DWORD processId;
        @ if(@<进程ID>==0) {
        @     processId = GetCurrentProcessId();
        @ } else {
        @     processId = @<进程ID>;
        @ }
        @     HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, processId);
        @     if (hProcess == NULL) {
        @         return 0;
        @     }
        @     BOOL result = SetProcessWorkingSetSize(hProcess, @<最小工作集>, @<最大工作集>);
        @     if (!result) {
        @         CloseHandle(hProcess);
        @         return 0;
        @     }
        @     BOOL result2 = EmptyWorkingSet(hProcess);
        @     if (!result2) {
        @        CloseHandle(hProcess);
        @        return 0;
        @     } 
        @     CloseHandle(hProcess);
        @     return 1;
    }
}

