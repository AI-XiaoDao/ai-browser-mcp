类 共享内存类_ <公开 注释 = "本库改自于“山高人为峰”模块" 折叠 @文档 = "category = \"内存操作库.内存共享\"">
{
    变量 Hand_Arr <类型 = 变整数数组类>
    变量 共享内存 <类型 = 共享内存api>

    方法 类_清理 <折叠>
    {
        释放句柄_ ()
    }

    方法 释放句柄_ <公开 注释 = "所有" 折叠>
    {
        变量 总数 <类型 = 整数>
        变量 句柄 <类型 = 变整数>
        总数 = Hand_Arr.取成员数 ()
        计次循环 (总数)
        {
            句柄 = Hand_Arr.取成员 (取循环索引 ())
            如果真 (指针是否有效_ (句柄))
            {
                共享内存.CloseHandle (句柄)
            }
        }
    }

    方法 释放句柄2_ <公开 类型 = 逻辑型 注释 = "指定" 折叠>
    参数 句柄 <类型 = 变整数 注释 = "写“写共享数据_”所返回的句柄">
    {
        如果真 (指针是否有效_ (句柄))
        {
            返回 (共享内存.CloseHandle (句柄))
        }
        返回 (假)
    }

    方法 写共享数据_ <公开 类型 = 逻辑型 注释 = "共享数据的本类变量必须为非局部变量，或为静态变量" 返回值注释 = "成功返回真" 折叠>
    参数 共享标记名 <类型 = 文本型 注释 = "例如：共享标记 ;" 注释 = "为跨窗口、跨程序、跨进程间的通讯密钥，名称一致即可共享信息" 折叠2>
    参数 共享数据 <类型 = 字节集类 注释 = "支持写入：文本、整数、长整数、变整数、小数、字节集、变量、结构体等 ;" 注释 = "如果为结构体类型数据，请使用：XX对象.取对象数据() 进行写入 ;"
            注释 = "取出时，使用：XX对象.置对象数据() 取出类型数据 ;" 注释 = "例如：;" 注释 = "  1、共享内存.写共享数据_ (\"共享标记\", 文本到字节集 (\"我是内容\")) ;"
            注释 = "  2、共享内存.写共享数据_ (\"共享标记\", 到字节集 (123456789)) ;" 注释 = "  3、共享内存.写共享数据_ (\"共享标记\", 到字节集 (取文本指针 (\"我是内容\"))) ;"
            注释 = "  4、共享内存.写共享数据_ (\"共享标记\", 到字节集 (取变量地址 (结构))) ;" 注释 = "  5、共享内存.写共享数据_ (\"共享标记\", XX结构.取对象数据 ())">
    {
        变量 局_数据块 <类型 = 字节集类>
        变量 LPSTR <类型 = 变整数>
        变量 hMemFile <类型 = 变整数>
        局_数据块.添加值到字节集 (共享数据.取字节集长度 ())
        局_数据块.添加字节集 (共享数据)
        hMemFile = 共享内存.OpenFileMappingW (6, 假, 取文本指针 (共享标记名))
        如果 (hMemFile == 0)
        {
            hMemFile = 共享内存.CreateFileMappingW (-1, 0, 4, 0, 4, 取文本指针 (共享标记名))
            如果真 (hMemFile < 1)
            {
                返回 (假)
            }
            Hand_Arr.加入成员 (hMemFile)
            LPSTR = 共享内存.MapViewOfFile (hMemFile, 2, 0, 0, 0)
            如果真 (LPSTR < 1)
            {
                共享内存.CloseHandle (hMemFile)
                返回 (假)
            }
            内存复制 (LPSTR, 局_数据块.取字节集指针 (), 局_数据块.取字节集长度 ())
            返回 (共享内存.UnmapViewOfFile (LPSTR))
        }
        LPSTR = 共享内存.MapViewOfFile (hMemFile, 2, 0, 0, 0)
        如果真 (LPSTR < 1)
        {
            共享内存.CloseHandle (hMemFile)
            返回 (假)
        }
        内存复制 (LPSTR, 局_数据块.取字节集指针 (), 局_数据块.取字节集长度 ())
        返回 (共享内存.UnmapViewOfFile (LPSTR) && 共享内存.CloseHandle (hMemFile))
    }

    方法 写共享数据2_ <公开 类型 = 变整数 注释 = "共享数据的本类变量必须为非局部变量，或为静态变量" 返回值注释 = "成功返>0的句柄" 折叠>
    参数 共享标记名 <类型 = 文本型 注释 = "例如：共享标记 ;" 注释 = "为跨窗口、跨程序、跨进程间的通讯密钥，名称一致即可共享信息" 折叠2>
    参数 共享数据 <类型 = 字节集类 注释 = "支持写入：文本、整数、长整数、变整数、小数、字节集、变量、结构体等 ;" 注释 = "如果为结构体类型数据，请使用：XX对象.取对象数据() 进行写入 ;"
            注释 = "取出时，使用：XX对象.置对象数据() 取出类型数据 ;" 注释 = "例如：;" 注释 = "  1、共享内存.写共享数据_ (\"共享标记\", 文本到字节集 (\"我是内容\")) ;"
            注释 = "  2、共享内存.写共享数据_ (\"共享标记\", 到字节集 (123456789)) ;" 注释 = "  3、共享内存.写共享数据_ (\"共享标记\", 到字节集 (取文本指针 (\"我是内容\"))) ;"
            注释 = "  4、共享内存.写共享数据_ (\"共享标记\", 到字节集 (取变量地址 (结构))) ;" 注释 = "  5、共享内存.写共享数据_ (\"共享标记\", XX结构.取对象数据 ())">
    {
        变量 局_数据块 <类型 = 字节集类>
        变量 LPSTR <类型 = 变整数>
        变量 hMemFile <类型 = 变整数>
        局_数据块.添加值到字节集 (共享数据.取字节集长度 ())
        局_数据块.添加字节集 (共享数据)
        hMemFile = 共享内存.OpenFileMappingW (6, 假, 取文本指针 (共享标记名))
        如果 (hMemFile == 0)
        {
            hMemFile = 共享内存.CreateFileMappingW (-1, 0, 4, 0, 4, 取文本指针 (共享标记名))
            如果真 (hMemFile < 1)
            {
                返回 (-1)
            }
            Hand_Arr.加入成员 (hMemFile)
            LPSTR = 共享内存.MapViewOfFile (hMemFile, 2, 0, 0, 0)
            如果真 (LPSTR < 1)
            {
                共享内存.CloseHandle (hMemFile)
                返回 (-1)
            }
            内存复制 (LPSTR, 局_数据块.取字节集指针 (), 局_数据块.取字节集长度 ())
            如果真 (共享内存.UnmapViewOfFile (LPSTR))
            {
                返回 (hMemFile)
            }
            返回 (-1)
        }
        LPSTR = 共享内存.MapViewOfFile (hMemFile, 2, 0, 0, 0)
        如果真 (LPSTR < 1)
        {
            共享内存.CloseHandle (hMemFile)
            返回 (-1)
        }
        内存复制 (LPSTR, 局_数据块.取字节集指针 (), 局_数据块.取字节集长度 ())
        如果真 (共享内存.UnmapViewOfFile (LPSTR) && 共享内存.CloseHandle (hMemFile))
        {
            返回 (hMemFile)
        }
        返回 (-1)
    }

    方法 读共享数据_ <公开 类型 = 字节集类 注释 = "支持读取：文本、整数、长整数、变整数、小数、字节集、变量、结构体等 ;" 注释 = "例如：;" 注释 = "1、数据块 = 共享内存.读共享数据_ (\"共享标记\") ;"
            注释 = "   编辑框1.内容 = 字节集到文本 (数据块) ;" 注释 = "" 注释 = "2、数据块 = 共享内存.读共享数据_ (\"共享标记\") ;" 注释 = "   到文本 (取字节集数据 (数据块, 0, 变整数)) ;"
            注释 = "" 注释 = "3、数据块 = 共享内存.读共享数据_ (\"共享标记\") ;" 注释 = "   指针到文本 (取字节集数据 (数据块, , 变整数)) ;" 注释 = ""
            注释 = "4、数据块 = 共享内存.读共享数据_ (\"共享标记\") ;" 注释 = "   指针 = 到文本 (取字节集数据 (数据块, 0, 变整数)) ;"
            注释 = "   结构2 = 读指针处对象 ((变整数)文本到长整数 (指针), 结构类) ;" 注释 = "" 注释 = "5、数据块 = 共享内存.读共享数据_ (\"共享标记\") ;"
            注释 = "   XX结构.置对象数据 (数据块)" 返回值注释 = "成功返回字节集数据，失败返回空字节集;" 返回值注释 = "如果为结构体类型数据，请使用：XX对象.置对象数据() 将本方法所读取的数据转换成对应类型" 折叠 折叠2>
    参数 共享标记名 <类型 = 文本型 注释 = "例如：共享标记 ;" 注释 = "为跨窗口、跨程序、跨进程间的通讯密钥，名称一致即可共享信息" 折叠2>
    {
        变量 临时字节集 <类型 = 字节集类>
        变量 hMemFile <类型 = 变整数>
        hMemFile = 共享内存.OpenFileMappingW (4, 假, 取文本指针 (共享标记名))
        如果真 (hMemFile < 1)
        {
            返回 (临时字节集)
        }
        变量 LPSTR <类型 = 变整数>
        LPSTR = 共享内存.MapViewOfFile (hMemFile, 4, 0, 0, 0)
        如果真 (LPSTR < 1)
        {
            共享内存.CloseHandle (hMemFile)
            返回 (临时字节集)
        }
        临时字节集 = 指针到字节集 (LPSTR, 4)
        变量 长度 <类型 = 整数>
        长度 = 取字节集数据 (临时字节集, 0, 整数)
        临时字节集 = 指针到字节集 (LPSTR, 长度 + 4)
        临时字节集 = 取字节集右边 (临时字节集, 长度)
        共享内存.UnmapViewOfFile (LPSTR)
        共享内存.CloseHandle (hMemFile)
        返回 (临时字节集)
    }
}

类 共享内存api <折叠 @文档 = "category = \"内存操作库.内存共享.附加类\"">
{
    方法 CreateFileMappingW <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 文件映射句柄 <类型 = 变整数>
    参数 安全对象 <类型 = 变整数>
    参数 打开映射方式 <类型 = 整数>
    参数 文件映射最大长度 <类型 = 整数>
    参数 文件映射的最小长度 <类型 = 整数>
    参数 映射对象名 <类型 = 变整数>
    {
        @ (__int64)CreateFileMappingW((HANDLE)@<文件映射句柄>,@<安全对象>,@<打开映射方式>,@<文件映射最大长度>,@<文件映射的最小长度>,(LPCWSTR)@<映射对象名>)
    }

    方法 MapViewOfFile <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 hFileMappingObject <类型 = 变整数>
    参数 dwDesiredAccess <类型 = 整数>
    参数 dwFileOffsetHigh <类型 = 整数>
    参数 dwFileOffsetLow <类型 = 整数>
    参数 dwNumberOfBytesToMap <类型 = 整数>
    {
        @ (__int64)MapViewOfFile((HANDLE)@<hFileMappingObject>,@<dwDesiredAccess>,@<dwFileOffsetHigh>,@<dwFileOffsetLow>,@<dwNumberOfBytesToMap>)
    }

    方法 UnmapViewOfFile <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 lpBaseAddress <类型 = 变整数>
    {
        @ (bool)UnmapViewOfFile((LPCVOID)@<lpBaseAddress>)
    }

    方法 OpenFileMappingW <公开 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 dwDesiredAccess <类型 = 整数 @默认值 = 6>
    参数 bInheritHandle <类型 = 逻辑型 @默认值 = 真>
    参数 lpName <类型 = 变整数>
    {
        @ (__int64)OpenFileMappingW(@<dwDesiredAccess>,@<bInheritHandle>,(LPCWSTR)@<lpName>)
    }

    方法 CloseHandle <公开 类型 = 逻辑型 折叠 @嵌入式方法 = "">
    参数 句柄 <类型 = 变整数>
    {
        @ (bool)::CloseHandle((HANDLE)@<句柄>)
    }
}
