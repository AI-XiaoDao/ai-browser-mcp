    方法 内存_申请内存整数地址 <公开 静态 类型 = 变整数 注释 = "在自身进程申请自身整数内存" 返回值注释 = "返回内存地址" 折叠 @禁止流程检查 = 真>
    参数 初始值 <类型 = 整数 @默认值 = 0>
    {
        @ byte* tmp = 0;
        @ tmp = new byte[4];
        @ memcpy ((LPVOID)tmp, &@<初始值>, 4);
        @ return (INT64)tmp;
    }

    方法 内存_写内存短整数 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 短整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ if (hProcess == NULL){ return false; }
        @ bool ret = ::WriteProcessMemory(hProcess,(LPVOID)@<内存地址>,&(LPCVOID)@<写入值>,2,NULL);
        @ ::CloseHandle(hProcess);
        @ return ret;
    }

    方法 内存_读内存短整数 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ if (hProcess == NULL){ return -1; }
        @ short value;
        @ bool ret = ::ReadProcessMemory(hProcess,(LPVOID)@<内存地址>,&value,2,NULL);
        @ ::CloseHandle(hProcess);
        @ if (ret == false) { return -1; }
        @ return value;
    }

    方法 内存_写内存整数 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
