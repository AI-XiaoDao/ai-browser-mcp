    方法 写文本_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 文本型>
    参数 Unicode编码 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 地址2 <类型 = 变整数>
        变量 空白数据 <类型 = 字节集类>
        变量 地址 <类型 = 变整数>
        如果 (Unicode编码 == 假)
        {
            空白数据 = 转Unicode到Ascii_ (写入值)
        }
        否则
        {
            空白数据 = 到字节集 (写入值)
        }
        地址2 = 内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (空白数据), 64)
        地址 = 内存api.WriteProcessMemory (进程句柄, 内存地址, 取字节集指针 (空白数据), 取字节集长度 (空白数据), 0)
        内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (空白数据), 地址2)
        返回 (地址 != 0)
    }

