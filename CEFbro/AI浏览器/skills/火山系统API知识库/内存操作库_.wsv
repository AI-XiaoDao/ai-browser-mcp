    }

    方法 内存_写内存长整数 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 长整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ if (hProcess == NULL){ return false; }
        @ bool ret = ::WriteProcessMemory(hProcess,(LPVOID)@<内存地址>,&(LPCVOID)@<写入值>,8,NULL);
        @ ::CloseHandle(hProcess);
        @ return ret;
    }

