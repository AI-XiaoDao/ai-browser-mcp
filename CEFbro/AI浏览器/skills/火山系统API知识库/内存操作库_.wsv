        长度 = 读整数_ (内存地址)
        空白数据 = 取空白字节集 (长度)
        地址 = 内存api.ReadProcessMemory (进程句柄, 内存地址 + 4, 取字节集指针 (空白数据), 长度, 0)
        如果 (Unicode编码 == 假)
        {
            返回 (转Ascii到Unicode_ (空白数据))
        }
        否则
        {
            返回 (字节集到文本 (空白数据))
        }
    }

    方法 写字节集_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 字节集类>
    {
        变量 地址2 <类型 = 变整数>
        变量 地址 <类型 = 变整数>
        地址2 = 内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (写入值), 64)
        地址 = 内存api.WriteProcessMemory (进程句柄, 内存地址, 取字节集指针 (写入值), 取字节集长度 (写入值), 0)
        内存_修改内存属性3 (进程句柄, 内存地址, 取字节集长度 (写入值), 地址2)
        返回 (地址 != 0)
    }

    方法 写字节集2_ <公开 类型 = 逻辑型 注释 = "胖指针方式" 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
