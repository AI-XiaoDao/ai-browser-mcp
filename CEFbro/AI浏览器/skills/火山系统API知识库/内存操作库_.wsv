    方法 内存_读内存整数 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ if (hProcess == NULL){ return -1; }
        @ int value;
        @ bool ret = ::ReadProcessMemory(hProcess,(LPVOID)@<内存地址>,&value,4,NULL);
        @ ::CloseHandle(hProcess);
