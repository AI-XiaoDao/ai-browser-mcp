类 内存操作类_ <公开 折叠 折叠2 @文档 = "category = \"内存操作库.内存读写\"" @全局类 = 真 @视窗.外部头文件 = "<TlHelp32.h>">
{
    方法 内存特征码搜索_ <公开 静态 类型 = 整数 注释 = "搜索指定进程中的特征码，支持通配符 ?" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 特征码 <类型 = 文本型 注释 = "十六进制文本，如“BA ?? 00 B4 09 ?? 21”， 首尾无空格,中间空格不可省略">
    参数 返回的特征码地址 <类型 = 长整数数组类 注释 = "返回 十进制地址 数组">
    参数 搜寻起始地址 <类型 = 长整数 注释 = "0x401000" @默认值 = 0x401000>
    参数 搜寻结束地址 <类型 = 长整数 注释 = "0xFFFFFFFFFFFF" @默认值 = 0xFFFFFFFFFFFF>
    {
        变量 地址 <类型 = 长整数>
        @ int dwNum = WideCharToMultiByte(CP_ACP,NULL,@<特征码>,-1,NULL,NULL,0,NULL);
        @ char *Tzm = new char[dwNum];
        @ WideCharToMultiByte(CP_ACP,NULL,@<特征码>,-1,Tzm,dwNum,0,NULL);
        @ unsigned __int64 StartAddress=@<搜寻起始地址>;
        @ unsigned __int64 EndAddress=@<搜寻结束地址>;
        @ HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, false, @<进程ID>); 
        @ #define BLOCKMAXSIZE 409600
        @ unsigned char* MemoryData = new BYTE[BLOCKMAXSIZE];
        @ unsigned long BlockSize;
        @ MEMORY_BASIC_INFORMATION mbi;
        @ WORD TzmLength = (WORD)(strlen(Tzm) / 3 + 1);
        @ WORD* TzmArray = new WORD[TzmLength];
        @ int len = 0;
        @ for (int i = 0; i < strlen(Tzm); )
        @ {
        @  char num[2];
        @  num[0] = Tzm[i++];
        @  num[1] = Tzm[i++];
        @  i++;
        @  if (num[0] != '?' && num[1] != '?')
        @  {
        @   int sum = 0;
        @   WORD a[2];
        @   for (int i = 0; i < 2; i++)
        @   {
        @    if (num[i] >= '0' && num[i] <= '9')
        @    {
        @     a[i] = num[i] - '0';
        @    }
        @    else if (num[i] >= 'a' && num[i] <= 'z')
        @    {
        @     a[i] = num[i] - 87;
        @    }
        @    else if (num[i] >= 'A' && num[i] <= 'Z')
        @    {
        @     a[i] = num[i] - 55;
        @    }
        @   }
        @   sum = a[0] * 16 + a[1];
        @   TzmArray[len++] = sum;
        @  }
        @  else
        @  {
        @   TzmArray[len++] = 256;
        @  }
        @ }
        @ short Next[260]; 
        @ for (int i = 0; i < 260; i++)
        @  Next[i] = -1;
        @ for (int i = 0; i < TzmLength; i++)
        @  Next[TzmArray[i]] = i;
        返回的特征码地址.删除所有成员 ()
        @ while (VirtualQueryEx(hProcess, (LPCVOID)StartAddress, &mbi, sizeof(mbi)) != 0)
        @ {
        @      int i = 0;
        @   BlockSize = (unsigned long)mbi.RegionSize;
        @   while (BlockSize >= BLOCKMAXSIZE)
        @   {
        @    if (ReadProcessMemory(hProcess, (LPCVOID)(StartAddress + (BLOCKMAXSIZE * i)), MemoryData, BLOCKMAXSIZE, NULL))
        @    {
        @     for (int m = 0, j, k; m < BLOCKMAXSIZE;)
        @     {
        @      j = m; k = 0;
        @      for (; k < TzmLength && j < BLOCKMAXSIZE && (TzmArray[k] == MemoryData[j] || TzmArray[k] == 256); k++, j++);
        @      if (k == TzmLength)
        @      {
        @  @<地址>=StartAddress + (BLOCKMAXSIZE * i) + m;
        返回的特征码地址.加入成员 (地址)
        @      }
        @      if ((m + TzmLength) >= BLOCKMAXSIZE)
        @      {
        @       break;
        @      }
        @      int num = Next[MemoryData[m + TzmLength]];
        @      if (num == -1)
        @       m += (TzmLength - Next[256]);
        @      else
        @       m += (TzmLength - num);
        @     }
        @    }
        @    BlockSize -= BLOCKMAXSIZE; i++;
        @   }
        @   if (ReadProcessMemory(hProcess, (LPCVOID)(StartAddress + (BLOCKMAXSIZE * i)), MemoryData, BlockSize, NULL))
        @   {
        @    for (int m = 0, j, k; m < BlockSize;)
        @    {
        @     j = m; k = 0;
        @     for (; k < TzmLength && j < BlockSize && (TzmArray[k] == MemoryData[j] || TzmArray[k] == 256); k++, j++);
        @     if (k == TzmLength)
        @     {
        @  @<地址>=StartAddress + (BLOCKMAXSIZE * i) + m;
        返回的特征码地址.加入成员 (地址)
        @     }
        @     if ((m + TzmLength) >= BlockSize)
        @     {
        @      break;
        @     }
        @     int num = Next[MemoryData[m + TzmLength]];
        @     if (num == -1)
        @      m += (TzmLength - Next[256]);
        @     else
        @      m += (TzmLength - num);
        @    }
        @   }
        @  StartAddress += mbi.RegionSize;
        @  if (EndAddress != 0 && StartAddress > EndAddress){ break; }
        @ }
        @ delete[]TzmArray;
        @ delete[]MemoryData;
        @ CloseHandle(hProcess);
        返回 (返回的特征码地址.取成员数 ())
    }

    方法 内存特征码修改_ <公开 静态 类型 = 逻辑型 注释 = "修改指定进程中，特征码地址处的数据" 折叠>
    参数 进程ID <类型 = 整数>
    参数 特征码地址 <类型 = 长整数>
    参数 欲写入的数据 <类型 = 文本型 注释 = "十六进制文本，如“0F 84 91 02 00 00”，首尾无空格,中间空格可有可无">
    {
        变量 临时数据 <类型 = 字节集类>
        临时数据 = 十六进制文本到字节集 (删全部空_ (欲写入的数据))
        返回 (内存_写内存字节集 (进程ID, (变整数)特征码地址, 临时数据))
    }

    方法 申请内存_ <公开 静态 类型 = 变整数 注释 = "申请当前进程中的内存" 返回值注释 = "返回内存地址" 折叠 @禁止流程检查 = 真>
    参数 内存长度 <类型 = 变整数>
    参数 清零内存 <类型 = 逻辑型 @默认值 = 真>
    {
        @ byte* tmp = 0;
        @ tmp = new byte[@<内存长度>];
        如果真 (清零内存)
        {
            @ memset (tmp, 0, @<内存长度>);
        }
        @ return (INT64)tmp;
    }

    方法 内存_申请内存 <公开 静态 类型 = 变整数 注释 = "申请当前进程中的内存" 返回值注释 = "返回内存地址" 折叠>
    参数 内存长度 <类型 = 变整数>
    参数 清零内存 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (申请内存_ (内存长度, 清零内存))
    }

    方法 申请内存2_ <公开 静态 类型 = 变整数 返回值注释 = "返回内存地址" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 内存长度 <类型 = 整数 注释 = "要申请的内存长度,尽量填4096的倍数吧,因为不足4096时系统自动以此倍数值来分配的">
    参数 保护属性 <类型 = 整数 注释 = "2=只读，4=可读写，64=可读写运行，默认=64( PAGE_READWRITE)" @默认值 = 64>
    {
        @ return (INT_P)VirtualAllocEx((HANDLE)@<进程句柄>,(LPVOID)NULL,@<内存长度>,MEM_COMMIT,(DWORD)@<保护属性>);
    }

    方法 内存_申请内存2 <公开 静态 类型 = 变整数 返回值注释 = "返回内存地址" 折叠>
    参数 进程句柄 <类型 = 变整数 注释 = "进程句柄">
    参数 内存长度 <类型 = 整数 注释 = "要申请的内存长度,尽量填4096的倍数吧,因为不足4096时系统自动以此倍数值来分配的">
    参数 保护属性 <类型 = 整数 注释 = "2=只读，4=可读写，64=可读写运行，默认=64( PAGE_READWRITE)" @默认值 = 64>
    {
        返回 (申请内存2_ (进程句柄, 内存长度, 保护属性))
    }

    方法 申请内存3_ <公开 静态 类型 = 变整数 返回值注释 = "返回内存地址" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存长度 <类型 = 整数 注释 = "要申请的内存长度,尽量填4096的倍数吧,因为不足4096时系统自动以此倍数值来分配的">
    参数 保护属性 <类型 = 整数 注释 = "2=只读，4=可读写，64=可读写运行，默认=64( PAGE_READWRITE)" @默认值 = 64>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ if (hProcess == NULL){ return false; }
        @ INT_P ret =  (INT_P)VirtualAllocEx((HANDLE)hProcess,(LPVOID)NULL,@<内存长度>,MEM_COMMIT,(DWORD)@<保护属性>);
        @ ::CloseHandle(hProcess);
        @ return ret;
    }

    方法 内存_申请内存3 <公开 静态 类型 = 变整数 返回值注释 = "返回内存地址" 折叠>
