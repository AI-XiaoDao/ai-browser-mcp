        @ return ret;
    }

    方法 读整数_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    {
        @ int value;
        @ bool ret = ::ReadProcessMemory((HANDLE)@<进程句柄>,(LPVOID)@<内存地址>,&value,4,NULL);
        @ if (ret == false) { return -1; }
        @ return value;
    }

    方法 写长整数_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
