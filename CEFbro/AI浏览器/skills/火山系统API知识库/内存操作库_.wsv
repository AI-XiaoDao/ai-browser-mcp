    方法 内存_修改内存属性 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 内存地址 <类型 = 变整数>
    参数 内存长度 <类型 = 变整数>
    参数 新属性 <类型 = 变整数 注释 = "1   = PAGE_NOACCESS（任何访问该区域的操作将被拒绝）；" 注释 = "2   = PAGE_READONLY（区域为只读。如果应用程序试图访问区域中的页的时候，将会被拒绝访问）；"
            注释 = "4   = PAGE_READWRITE（区域可被应用程序读写）；" 注释 = "16  = PAGE_EXECUTE（区域包含可被系统执行的代码。试图读写该区域的操作将被拒绝）；"
            注释 = "32  = PAGE_EXECUTE_READ（区域包含可执行代码，应用程序可以读该区域）；" 注释 = "64  = PAGE_EXECUTE_READWRITE（区域包含可执行代码，应用程序可以读写该区域）；"
            注释 = "256 = PAGE_GUARD（区域第一次被访问时进入一个STATUS_GUARD_PAGE异常，这个标志要和其他保护标志合并使用，表明区域被第一次访问的权限）；"
            注释 = "512 = PAGE_NOCACHE（RAM中的页映射到该区域时将不会被微处理器缓存（cached)）" 折叠2 @默认值 = 64>
    {
        变量 进程句柄 <类型 = 变整数>
        变量 地址 <类型 = 变整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        如果真 (进程句柄 == 0)
        {
            返回 (-1)
        }
        @ DWORD 地址2;
        @ @<地址> = VirtualProtectEx((HANDLE*)@<进程句柄>, (void*)@<内存地址>, @<内存长度>,@<新属性>,&地址2);
        进程_关闭进程 (进程句柄)
        如果 (地址 == 1)
        {
            @ return 地址2;
        }
        否则
        {
            @ return -1;
        }
        返回 (-1)
    }

    方法 内存_修改内存属性2 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 内存长度 <类型 = 变整数>
    参数 新属性 <类型 = 变整数 注释 = "1   = PAGE_NOACCESS（任何访问该区域的操作将被拒绝）；" 注释 = "2   = PAGE_READONLY（区域为只读。如果应用程序试图访问区域中的页的时候，将会被拒绝访问）；"
            注释 = "4   = PAGE_READWRITE（区域可被应用程序读写）；" 注释 = "16  = PAGE_EXECUTE（区域包含可被系统执行的代码。试图读写该区域的操作将被拒绝）；"
            注释 = "32  = PAGE_EXECUTE_READ（区域包含可执行代码，应用程序可以读该区域）；" 注释 = "64  = PAGE_EXECUTE_READWRITE（区域包含可执行代码，应用程序可以读写该区域）；"
            注释 = "256 = PAGE_GUARD（区域第一次被访问时进入一个STATUS_GUARD_PAGE异常，这个标志要和其他保护标志合并使用，表明区域被第一次访问的权限）；"
            注释 = "512 = PAGE_NOCACHE（RAM中的页映射到该区域时将不会被微处理器缓存（cached)）" 折叠2 @默认值 = 64>
    {
        变量 地址 <类型 = 变整数>
        @ DWORD 地址2;
        @ @<地址> = VirtualProtect((void*)@<内存地址>, @<内存长度>,@<新属性>,&地址2);
        如果 (地址 == 1)
        {
            @ return 地址2;
        }
        否则
        {
            @ return -1;
        }
        返回 (-1)
    }

    方法 内存_修改内存属性3 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数>
    参数 内存地址 <类型 = 变整数>
    参数 内存长度 <类型 = 变整数>
    参数 新属性 <类型 = 变整数 注释 = "1   = PAGE_NOACCESS（任何访问该区域的操作将被拒绝）；" 注释 = "2   = PAGE_READONLY（区域为只读。如果应用程序试图访问区域中的页的时候，将会被拒绝访问）；"
            注释 = "4   = PAGE_READWRITE（区域可被应用程序读写）；" 注释 = "16  = PAGE_EXECUTE（区域包含可被系统执行的代码。试图读写该区域的操作将被拒绝）；"
            注释 = "32  = PAGE_EXECUTE_READ（区域包含可执行代码，应用程序可以读该区域）；" 注释 = "64  = PAGE_EXECUTE_READWRITE（区域包含可执行代码，应用程序可以读写该区域）；"
            注释 = "256 = PAGE_GUARD（区域第一次被访问时进入一个STATUS_GUARD_PAGE异常，这个标志要和其他保护标志合并使用，表明区域被第一次访问的权限）；"
            注释 = "512 = PAGE_NOCACHE（RAM中的页映射到该区域时将不会被微处理器缓存（cached)）" 折叠2 @默认值 = 64>
    {
        变量 地址 <类型 = 变整数>
        @ DWORD 地址2;
        @ @<地址> = VirtualProtectEx((HANDLE*)@<进程句柄>, (void*)@<内存地址>, @<内存长度>,@<新属性>,&地址2);
        如果 (地址 == 1)
        {
            @ return 地址2;
        }
        否则
        {
            @ return -1;
        }
        返回 (-1)
    }
}

类 内存操作类2_ <公开 折叠 折叠2 @文档 = "category = \"内存操作库.内存读写\"" @全局类 = 真 @视窗.外部头文件 = "<TlHelp32.h>">
{
    变量 进程句柄 <类型 = 变整数>

    方法 申请内存_ <公开 类型 = 变整数 注释 = "申请当前进程中的内存" 返回值注释 = "返回内存地址" 折叠 @禁止流程检查 = 真>
    参数 内存长度 <类型 = 变整数>
    参数 清零内存 <类型 = 逻辑型 @默认值 = 真>
    {
        @ byte* tmp = 0;
        @ tmp = new byte[@<内存长度>];
        如果真 (清零内存)
        {
            @ memset (tmp, 0, @<内存长度>);
        }
        @ return (INT64)tmp;
    }

    方法 释放内存_ <公开 折叠 @嵌入式方法 = "">
    参数 内存地址 <类型 = 变整数>
    {
        @ delete [] (BYTE*)@<内存地址>
    }

    方法 打开进程_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ @<进程句柄>=(INT_P)hProcess;
        @ return @<进程句柄>>0;
    }

    方法 进程_关闭进程 <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    {
        @ return CloseHandle((HANDLE)@<进程句柄>);
    }

    方法 写短整数_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 写入值 <类型 = 短整数>
    {
        @ bool ret = ::WriteProcessMemory((HANDLE)@<进程句柄>,(LPVOID)@<内存地址>,&(LPCVOID)@<写入值>,2,NULL);
        @ return ret;
    }

    方法 读短整数_ <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    {
