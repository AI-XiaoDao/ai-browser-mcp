        地址2 = 内存_修改内存属性3 (进程句柄, 内存地址 + 4, 取字节集长度 (写入值), 64)
        地址 = 内存api.WriteProcessMemory (进程句柄, 内存地址 + 4, 取字节集指针 (写入值), 取字节集长度 (写入值), 0)
        内存_修改内存属性3 (进程句柄, 内存地址 + 4, 取字节集长度 (写入值), 地址2)
        返回 (地址 != 0)
    }

    方法 读字节集_ <公开 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    参数 内存长度 <类型 = 整数>
    {
        变量 空白数据 <类型 = 字节集类 "">
        变量 地址 <类型 = 变整数>
        空白数据 = 取空白字节集 (内存长度)
        地址 = 内存api.ReadProcessMemory (进程句柄, 内存地址, 取字节集指针 (空白数据), 内存长度, 0)
        返回 (空白数据)
    }

    方法 读字节集2_ <公开 类型 = 字节集类 注释 = "胖指针方式，不需要指定长度" 折叠 @禁止流程检查 = 真>
    参数 内存地址 <类型 = 变整数>
    {
        变量 空白数据 <类型 = 字节集类 "">
        变量 地址 <类型 = 变整数>
        变量 长度 <类型 = 整数>
        长度 = 读整数_ (内存地址)
        空白数据 = 取空白字节集 (长度)
        地址 = 内存api.ReadProcessMemory (进程句柄, 内存地址 + 4, 取字节集指针 (空白数据), 长度, 0)
        返回 (空白数据)
    }

    方法 表达式取地址_ <公开 类型 = 变整数 注释 = "支持+或-的地址表达式，例如：50339C+254-1C0" 折叠 @禁止流程检查 = 真>
    参数 基址地址 <类型 = 文本型 注释 = "基址文本表达式，例如：50339C+254+1c0">
    {
        变量 结果组 <类型 = 文本数组类>
        变量 正则 <类型 = 正则类_>
        变量 临时数量 <类型 = 整数>
        变量 临时指针 <类型 = 整数>
        变量 临时地址 <类型 = 变整数>
        变量 公式 <类型 = 文本型 值 = "[-|\\+]">
        变量 i <类型 = 整数>
        分割文本 (基址地址, "+-", 结果组)
        临时数量 = 结果组.取成员数 ()
        如果真 (临时数量 <= 1)
        {
            返回 (文本到整数 (基址地址))
        }
        正则.创建 (公式, 基址地址, , , )
        循环 (0, 临时数量, i)
        {
            如果真 (i == 临时数量 - 1)
            {
                跳出循环
            }
            如果 (正则.取匹配文本 (i, ) == "-")
            {
                临时地址 = 临时指针 - 十六进制转十进制2_ (结果组.取成员 (i))
                @ bool ret = ::ReadProcessMemory((HANDLE)@<进程句柄>,(LPVOID)@<临时地址>,&@<临时指针>,4,NULL);
            }
            否则
            {
                临时地址 = 临时指针 + 十六进制转十进制2_ (结果组.取成员 (i))
                @ bool ret = ::ReadProcessMemory((HANDLE)@<进程句柄>,(LPVOID)@<临时地址>,&@<临时指针>,4,NULL);
            }
        }
        如果 (正则.取匹配文本 (临时数量 - 1, ) == "-")
        {
            临时地址 = 临时指针 - 十六进制转十进制2_ (结果组.取成员 (临时数量 - 1))
        }
        否则
        {
            临时地址 = 临时指针 + 十六进制转十进制2_ (结果组.取成员 (临时数量 - 1))
        }
        返回 (临时地址)
    }
}

