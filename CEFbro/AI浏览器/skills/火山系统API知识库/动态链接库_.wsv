<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"动态链接库\"">

类 动态内存加载类_ <公开 注释 = "支持动态加载DLL及内存加载DLL;" 注释 = "内存加载DLL，不支持加载MFC的DLL;" 注释 = "注：调试状态可能无效，可以编译后测试" 折叠 折叠2
        @文档 = "category = \"动态链接库.动态内存\"" @视窗.外部头文件 = "ncjz\\peloader.h">
{
    变量 句柄组 <类型 = 变整数数组类>
    变量 互斥 <类型 = 许可锁类_>

    方法 类_清理 <折叠>
    {
        句柄组.删除所有成员 ()
    }

    方法 加载内存DLL_ <公开 类型 = 变整数 注释 = "例如：新建个“DLL变量”字节集类，属性名设置“@视窗.值文件”，属性值中加载非MFC的DLL即可" 折叠 @嵌入式方法 = "">
    参数 DLL数据指针 <类型 = 变整数 注释 = "例如：DLL变量.取字节集指针 ()">
    参数 DLL数据长度 <类型 = 整数 注释 = "例如：DLL变量.取字节集长度 ()">
    {
        @ (INT_P)PeLoader_LoadLibrary((unsigned char*)@<DLL数据指针>,(DWORD)@<DLL数据长度>, 0, NULL, NULL)
    }

    方法 取内存函数地址_ <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 DLL句柄 <类型 = 变整数 注释 = "“加载内存DLL_”的返回值">
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const CHAR* ps = GetMbsText (@<DLL函数输出名>.GetText (), memBuf, &npResultTextLength);
        @ return (INT_P) PeLoader_GetProcAddress((HMODULE)@<DLL句柄>,ps) ;
    }

    方法 取内存函数地址2_ <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 DLL句柄 <类型 = 变整数 注释 = "“加载内存DLL_”的返回值">
    参数 函数索引 <类型 = 整数>
    {
        @ return (INT_P) PeLoader_GetProcAddress((HMODULE)@<DLL句柄>,reinterpret_cast<CHAR*>(@<函数索引>)) ;
    }

    方法 释放内存DLL_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 DLL句柄 <类型 = 变整数 注释 = "“加载内存DLL_”的返回值">
    {
        @ return PeLoader_FreeLibrary ((HMODULE)@<DLL句柄>);
    }

    方法 执行函数_有返回值 <公开 注释 = "如果本命令在x86下不可用，可使用“执行函数_”" 折叠 @嵌入式方法 = "">
    参数 函数地址 <类型 = 变整数 注释 = "例如“取内存函数地址_”的返回值">
    参数 返回值类型 <@匹配类型 = 通用非文本基本型 @需求类型 = 数据类型 @返回值类型 = 0>
    参数 参数 <注释 = "" 注释 = "" @匹配类型 = 所有类型 @可扩展 = "">
    {
        @ ((@<返回值类型>(FAR WINAPI *)(...)) @<函数地址>)(@<参数>)
    }

    方法 执行函数_无返回值 <公开 注释 = "如果本命令在x86下不可用，可使用“执行函数_”" 折叠 @嵌入式方法 = "">
    参数 函数地址 <类型 = 变整数 注释 = "例如“取内存函数地址_”的返回值">
    参数 参数 <@匹配类型 = 所有类型 @可扩展 = "">
    {
        @ ((void(__stdcall*)(...))@<函数地址>) (@<参数>)
    }

    方法 执行函数_无参数 <公开 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 函数地址 <类型 = 变整数 注释 = "例如“取内存函数地址_”的返回值">
    {
        @ typedef  INT_P (__stdcall *DLLFUN)();
        @ return ((DLLFUN)@<函数地址>)();
    }

    方法 执行函数_无参数2 <公开 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 函数地址 <类型 = 变整数 注释 = "例如“取内存函数地址_”的返回值">
    {
        @ typedef  INT_P (__stdcall *DLLFUN)();
        @ return ((DLLFUN)@<函数地址>)();
    }

    方法 执行函数_ <公开 类型 = 变整数 注释 = "如果x86下“执行函数_有返回值”或无返回值，不可用，可调用本命令" 返回值注释 = "有返回值就填写类型 没有就留空" 折叠>
    参数 函数地址 <类型 = 变整数 注释 = "例如“取内存函数地址_”的返回值">
    参数 DLL参数数量 <类型 = 整数 @默认值 = 2>
    参数 返回结果 <类型 = 变整数 注释 = "指定一个可写入的变量指针，存放返回数据值(DLL方法返回值)，无返回值可填0" @默认值 = 0>
    参数 参数一 <类型 = 变整数 @默认值 = -1>
    参数 参数二 <类型 = 变整数 @默认值 = -1>
    参数 参数三 <类型 = 变整数 @默认值 = -1>
    参数 参数四 <类型 = 变整数 @默认值 = -1>
    参数 参数五 <类型 = 变整数 @默认值 = -1>
    参数 参数六 <类型 = 变整数 @默认值 = -1>
    参数 参数七 <类型 = 变整数 @默认值 = -1>
    参数 参数八 <类型 = 变整数 @默认值 = -1>
    参数 参数九 <类型 = 变整数 @默认值 = -1>
    参数 参数十 <类型 = 变整数 @默认值 = -1>
    参数 参数十一 <类型 = 变整数 @默认值 = -1>
    参数 参数十二 <类型 = 变整数 @默认值 = -1>
    {
        变量 结果 <类型 = 变整数>
        如果真 (指针是否有效_ (函数地址) == 真)
        {
            如果 (返回结果 == 0)
            {
                如果 (DLL参数数量 == 0)
                {
                    返回 (执行函数_无参数 (函数地址))
                }
                否则 (DLL参数数量 == 1)
                {
                    返回 (执行A_ (函数地址, 参数一))
                }
                否则 (DLL参数数量 == 2)
                {
                    返回 (执行B_ (函数地址, 参数一, 参数二))
                }
                否则 (DLL参数数量 == 3)
                {
                    返回 (执行C_ (函数地址, 参数一, 参数二, 参数三))
                }
                否则 (DLL参数数量 == 4)
                {
                    返回 (执行D_ (函数地址, 参数一, 参数二, 参数三, 参数四))
                }
                否则 (DLL参数数量 == 5)
                {
                    返回 (执行E_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五))
                }
                否则 (DLL参数数量 == 6)
                {
                    返回 (执行F_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六))
                }
                否则 (DLL参数数量 == 7)
                {
                    返回 (执行G_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七))
                }
                否则 (DLL参数数量 == 8)
                {
                    返回 (执行H_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八))
                }
                否则 (DLL参数数量 == 9)
                {
                    返回 (执行I_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九))
                }
                否则 (DLL参数数量 == 10)
                {
                    返回 (执行J_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十))
                }
                否则 (DLL参数数量 == 11)
                {
                    返回 (执行K_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一))
                }
                否则
                {
                    返回 (执行L_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一, 参数十二))
                }
            }
            否则
            {
                如果真 (指针是否有效_ (返回结果) == 真)
                {
                    如果 (DLL参数数量 == 0)
                    {
                        结果 = 执行函数_无参数 (函数地址)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 1)
                    {
                        结果 = 执行A_ (函数地址, 参数一)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 2)
                    {
                        结果 = 执行B_ (函数地址, 参数一, 参数二)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 3)
                    {
                        结果 = 执行C_ (函数地址, 参数一, 参数二, 参数三)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 4)
                    {
                        结果 = 执行D_ (函数地址, 参数一, 参数二, 参数三, 参数四)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 5)
                    {
                        结果 = 执行E_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 6)
                    {
                        结果 = 执行F_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 7)
                    {
                        结果 = 执行G_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 8)
                    {
                        结果 = 执行H_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 9)
                    {
                        结果 = 执行I_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 10)
                    {
                        结果 = 执行J_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十)
                        写指针处值 (返回结果, 结果)
                    }
                    否则 (DLL参数数量 == 11)
                    {
                        结果 = 执行K_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一)
                        写指针处值 (返回结果, 结果)
                    }
                    否则
                    {
                        结果 = 执行L_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一, 参数十二)
                        写指针处值 (返回结果, 结果)
                    }
                }
            }
        }
        返回 (结果)
    }

    方法 执行函数2_ <公开 类型 = 变整数 注释 = "如果x86下“执行函数_有返回值”或无返回值，不可用，可调用本命令" 返回值注释 = "有返回值就填写类型 没有就留空" 折叠>
