# //====

类 动态链接库类_ <公开 折叠 @文档 = "category = \"动态链接库.动态链接\"">
{
    变量 集DLL路径 <类型 = 文本型>
    变量 集DLL句柄 <类型 = 变整数>
    变量 句柄组 <类型 = 变整数数组类>
    变量 互斥 <类型 = 许可锁类_>

    方法 类_清理 <折叠>
    {
        句柄组.删除所有成员 ()
    }

    方法 动态加载窗口_ <公开 类型 = 变整数 注释 = "加载DLL窗口，已高度封装的命令;" 注释 = "正常步骤：;动态加载DLL_、取函数地址_、执行函数_" 返回值注释 = "返回DLL句柄" 折叠 折叠2>
    参数 DLL文件路径 <类型 = 文本型>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    参数 DLL参数数量 <类型 = 整数 注释 = "0、无参数 1、一个参数 2、两个参数" @默认值 = 1>
    参数 主窗口对象 <类型 = 对象类 注释 = "可以用“本对象”，或“取程序().主窗口对象”">
    参数 附加指针 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第二个参数接收此指针" @默认值 = 0>
    参数 附加指针2 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第三个参数接收此指针" @默认值 = 0>
    参数 返回的DLL句柄 <类型 = 变整数类 注释 = "成功则返回动态加载的DLL句柄" @默认值 = 空对象>
    参数 返回的DLL窗口句柄 <类型 = 变整数类 注释 = "成功返回DLL里窗口句柄" @默认值 = 空对象>
    {
        变量 DLL句柄 <类型 = 变整数>
        变量 DLL窗口句柄 <类型 = 变整数>
        变量 地址句柄 <类型 = 变整数>
        DLL句柄 = 动态加载DLL_ (DLL文件路径)
        如果真 (DLL句柄 > 0)
        {
            返回的DLL句柄.值 = DLL句柄
            地址句柄 = 取函数地址_ (DLL句柄, DLL函数输出名)
            如果真 (地址句柄 > 0)
            {
                DLL窗口句柄 = 执行函数_ (地址句柄, DLL参数数量, , 取变量地址 (主窗口对象), 附加指针, 附加指针2)
                返回的DLL窗口句柄.值 = DLL窗口句柄
                返回 (DLL句柄)
            }
            返回 (DLL句柄)
        }
        返回的DLL句柄.值 = 0
        返回的DLL窗口句柄.值 = 0
        返回 (DLL句柄)
    }

    方法 动态加载窗口2_ <公开 类型 = 变整数 注释 = "加载DLL窗口，已高度封装的命令;" 注释 = "正常步骤：;动态加载DLL_、取函数地址_、执行函数_" 返回值注释 = "返回DLL句柄" 折叠 折叠2>
    参数 DLL文件路径 <类型 = 文本型>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    参数 DLL参数数量 <类型 = 整数 注释 = "0、无参数 1、一个参数 2、两个参数" @默认值 = 0>
    参数 附加参数1 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第一个参数接收此指针" @默认值 = 0>
    参数 附加参数2 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第二个参数接收此指针" @默认值 = 0>
    参数 返回的DLL句柄 <类型 = 变整数类 注释 = "成功则返回动态加载的DLL句柄" @默认值 = 空对象>
    参数 返回的DLL窗口句柄 <类型 = 变整数类 注释 = "成功返回DLL里窗口句柄" @默认值 = 空对象>
    {
        变量 DLL句柄 <类型 = 变整数>
        变量 DLL窗口句柄 <类型 = 变整数>
        变量 地址句柄 <类型 = 变整数>
        DLL句柄 = 动态加载DLL_ (DLL文件路径)
        如果真 (DLL句柄 > 0)
        {
            返回的DLL句柄.值 = DLL句柄
            地址句柄 = 取函数地址_ (DLL句柄, DLL函数输出名)
            如果真 (地址句柄 > 0)
            {
                DLL窗口句柄 = 执行函数_ (地址句柄, DLL参数数量, , 附加参数1, 附加参数2)
                返回的DLL窗口句柄.值 = DLL窗口句柄
                返回 (DLL句柄)
            }
            返回 (DLL句柄)
        }
        返回的DLL句柄.值 = 0
        返回的DLL窗口句柄.值 = 0
        返回 (DLL句柄)
    }

    方法 动态加载DLL_ <公开 类型 = 变整数 注释 = "返回DLL句柄" 折叠>
    参数 DLL文件路径 <类型 = 文本型>
    {
        变量 局部句柄 <类型 = 变整数>
        互斥.加锁 ()
        集DLL路径 = DLL文件路径
        局部句柄 = 取模块句柄_ (DLL文件路径)
        集DLL句柄 = 局部句柄
        句柄组.加入成员 (局部句柄)
        互斥.解锁 ()
        返回 (局部句柄)
    }

    方法 动态释放DLL_ <公开 类型 = 逻辑型 折叠>
    参数 DLL句柄 <类型 = 变整数>
    {
        变量 结果 <类型 = 逻辑型>
        互斥.加锁 ()
        结果 = 动态DLLapi.FreeLibrary (DLL句柄)
        句柄组.枚举循环 ()
        {
            如果真 (句柄组.取枚举值 () == DLL句柄)
            {
                句柄组.删除成员 (句柄组.取枚举索引 ())
                跳出循环
            }
        }
        互斥.解锁 ()
        返回 (结果)
    }

    方法 动态释放所有DLL_ <公开 类型 = 逻辑型 折叠>
    {
        变量 结果 <类型 = 逻辑型>
        互斥.加锁 ()
        句柄组.枚举循环 ()
        {
            结果 = 动态DLLapi.FreeLibrary (句柄组.取枚举值 ())
        }
        句柄组.删除所有成员 ()
        互斥.解锁 ()
        返回 (结果)
    }

    方法 动态重载DLL_ <公开 类型 = 变整数 注释 = "重新加载上一个DLL;" 注释 = "即使用过\"动态加载DLL_()\",并且\"动态释放DLL_\"过的，可直接再次加载" 折叠 折叠2>
    {
        如果真 (指针是否有效_ (集DLL句柄) == 真)
        {
            返回 (0)
        }
        返回 (取模块句柄_ (集DLL路径))
    }

    方法 取函数地址_ <公开 类型 = 变整数 注释 = "返回公开函数的地址" 折叠>
    参数 DLL句柄 <类型 = 变整数>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    {
        变量 局部地址 <类型 = 字节集类>
        局部地址 = 文本到多字节 (DLL函数输出名)
        返回 (动态DLLapi.GetProcAddress (DLL句柄, 取字节集指针 (局部地址)))
    }

    方法 取函数数量_ <公开 类型 = 整数 注释 = "返回DLL函数数量" 折叠 @禁止流程检查 = 真>
    参数 DLL文件路径 <类型 = 文本型>
    {
        变量 模块句柄 <类型 = 变整数 编辑时信息 = "0, 4BFFB, 0, 0">
        变量 函数地址 <类型 = 变整数 编辑时信息 = "0, 4BFFB, 0, 0">
        变量 数量 <类型 = 整数 值 = 0>
        变量 i <类型 = 整数 值 = 0 编辑时信息 = "0, 4BFFB, 0, 0">
        模块句柄 = 动态DLLapi.GetModuleHandleW (取文本指针 (DLL文件路径))
        判断循环 (模块句柄 != 0)
        {
            i = i + 1
            函数地址 = 动态DLLapi.GetProcAddress (模块句柄, i)
            如果真 (函数地址 != 0)
            {
                数量 = 数量 + 1
            }
            如果真 (i > 3000)
            {
                跳出循环
            }
        }
        返回 (数量)
    }

    方法 执行函数_ <公开 类型 = 变整数 折叠>
    参数 函数地址 <类型 = 变整数>
    参数 DLL参数数量 <类型 = 整数 注释 = "0、无参数 1、一个参数 2、两个参数。。。" @默认值 = 0>
    参数 返回结果 <类型 = 变整数 注释 = "指定一个可写入的变量指针，存放返回数据值(DLL方法返回值)，无返回值可填0" @默认值 = 0>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    参数 参数3 <类型 = 变整数 @默认值 = 0>
    参数 参数4 <类型 = 变整数 @默认值 = 0>
    参数 参数5 <类型 = 变整数 @默认值 = 0>
    参数 参数6 <类型 = 变整数 @默认值 = 0>
