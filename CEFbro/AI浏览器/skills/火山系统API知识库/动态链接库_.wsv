                }
                否则 (DLL参数数量 == 3)
                {
                    返回 (执行C2_ (函数地址, 参数一, 参数二, 参数三))
                }
                否则 (DLL参数数量 == 4)
                {
                    返回 (执行D2_ (函数地址, 参数一, 参数二, 参数三, 参数四))
                }
                否则 (DLL参数数量 == 5)
                {
                    返回 (执行E2_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五))
                }
                否则 (DLL参数数量 == 6)
                {
                    返回 (执行F2_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六))
                }
                否则 (DLL参数数量 == 7)
                {
                    返回 (执行G2_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七))
                }
                否则 (DLL参数数量 == 8)
                {
                    返回 (执行H2_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八))
                }
                否则 (DLL参数数量 == 9)
                {
                    返回 (执行I2_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九))
                }
