                        结果 = 执行K_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一)
                        写指针处值 (返回结果, 结果)
                    }
                    否则
                    {
                        结果 = 执行L_ (函数地址, 参数一, 参数二, 参数三, 参数四, 参数五, 参数六, 参数七, 参数八, 参数九, 参数十, 参数十一, 参数十二)
                        写指针处值 (返回结果, 结果)
                    }
                }
            }
        }
        返回 (结果)
    }

    方法 动态加载窗口_ <公开 注释 = "加载DLL窗口，已高度封装的命令;" 注释 = "正常步骤：;动态加载DLL_、取函数地址_、执行函数_" 折叠 折叠2>
    参数 DLL文件路径 <类型 = 文本型>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    参数 主窗口对象 <类型 = 对象类 注释 = "可以用“本对象”，或“取程序().主窗口对象”">
    参数 附加指针 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第二个参数接收此指针" @默认值 = 0>
    参数 附加指针2 <类型 = 变整数 注释 = "用于传递其它对象指针等，DLL中第三个参数接收此指针" @默认值 = 0>
    参数 返回的DLL句柄 <类型 = 变整数类 注释 = "成功则返回动态加载的DLL句柄" @默认值 = 空对象>
    参数 返回的DLL窗口句柄 <类型 = 变整数类 注释 = "成功返回DLL里窗口句柄" @默认值 = 空对象>
    {
        变量 DLL句柄 <类型 = 变整数>
        变量 DLL窗口句柄 <类型 = 变整数>
        变量 地址句柄 <类型 = 变整数>
        DLL句柄 = 动态加载DLL_ (DLL文件路径)
        如果真 (DLL句柄 > 0)
        {
            返回的DLL句柄.值 = DLL句柄
            地址句柄 = 取函数地址_ (DLL句柄, DLL函数输出名)
            如果真 (地址句柄 > 0)
            {
                DLL窗口句柄 = 执行函数_ (地址句柄, 3, , 取变量地址 (主窗口对象), 附加指针, 附加指针2)
                返回的DLL窗口句柄.值 = DLL窗口句柄
                返回
            }
            返回
        }
        返回的DLL句柄.值 = 0
        返回的DLL窗口句柄.值 = 0
    }

    方法 动态加载DLL_ <公开 类型 = 变整数 注释 = "返回DLL句柄" 折叠 @禁止流程检查 = 真>
    参数 DLL文件路径 <类型 = 文本型>
    {
        变量 句柄 <类型 = 变整数>
        互斥.加锁 ()
        @ INT_P jb=(INT_P)LoadLibraryW(@<DLL文件路径>.GetText());
        @ @<句柄>=(@dt<变整数>)jb;
        句柄组.加入成员 (句柄)
        互斥.解锁 ()
        @ return jb;
    }

    方法 动态释放DLL_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 DLL句柄 <类型 = 变整数>
    {
        互斥.加锁 ()
        @ BOOL jg =FreeLibrary((HMODULE)@<DLL句柄>);
        句柄组.枚举循环 ()
        {
            如果真 (句柄组.取枚举值 () == DLL句柄)
            {
                句柄组.删除成员 (句柄组.取枚举索引 ())
                跳出循环
            }
        }
        互斥.解锁 ()
        @ return jg;
    }

    方法 动态释放所有DLL_ <公开 类型 = 逻辑型 折叠>
    {
        变量 结果 <类型 = 逻辑型>
        句柄组.枚举循环 ()
        {
            结果 = 动态释放DLL_ (句柄组.取枚举值 ())
        }
        互斥.加锁 ()
        句柄组.删除所有成员 ()
        互斥.解锁 ()
        返回 (结果)
    }

    方法 取函数地址_ <公开 类型 = 变整数 注释 = "返回公开函数的地址" 折叠 @禁止流程检查 = 真>
    参数 DLL句柄 <类型 = 变整数 注释 = "加载dll 返回值">
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    {
        @ @an<CVolMem> memBuf;
        @ INT_P npResultTextLength;
        @ const char* ps = GetMbsText (@<DLL函数输出名>.GetText (), memBuf, &npResultTextLength);
        @ return (INT_P)GetProcAddress((HMODULE)@<DLL句柄>,ps); 
    }

    方法 指针是否有效_ <公开 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 指针 <类型 = 变整数>
    {
        @ return IsBadCodePtr((FARPROC)@<指针>)== 0;
    }

