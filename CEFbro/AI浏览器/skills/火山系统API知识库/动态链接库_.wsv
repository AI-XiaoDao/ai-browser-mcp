    参数 参数10 <类型 = 变整数 @默认值 = 0>
    参数 参数11 <类型 = 变整数 @默认值 = 0>
    参数 参数12 <类型 = 变整数 @默认值 = 0>
    {
        变量 结果 <类型 = 变整数>
        如果真 (指针是否有效_ (函数地址) == 真)
        {
            如果 (返回结果 == 0)
            {
                如果真 (指针是否有效_ (函数地址) == 真)
                {
                    如果 (DLL参数数量 == 0)
                    {
                        返回 (配对参数0 (函数地址))
                    }
                    否则 (DLL参数数量 == 1)
                    {
                        返回 (配对参数1 (函数地址, 参数1))
                    }
                    否则 (DLL参数数量 == 2)
