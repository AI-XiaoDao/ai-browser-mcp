                    否则 (DLL参数数量 == 12)
                    {
                        结果 = 配对参数12 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10, 参数11, 参数12)
                        写指针处值 (返回结果, 结果)
                    }
                }
            }
        }
        返回 (结果)
    }

    方法 执行函数2_ <公开 类型 = 逻辑型 注释 = "该函数会自动加载DLL(无需先“动态加载DLL_”等),使用完后会立即释放DLL，成功调用返回真" 折叠>
    参数 DLL文件路径 <类型 = 文本型>
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    参数 DLL参数数量 <类型 = 整数 注释 = "0、无参数 1、一个参数 2、两个参数。。。" @默认值 = 0>
    参数 返回结果 <类型 = 变整数 注释 = "指定一个可写入的变量指针，存放返回数据值(DLL方法返回值)，无返回值可填0" @默认值 = 0>
    参数 参数1 <类型 = 变整数 @默认值 = 0>
    参数 参数2 <类型 = 变整数 @默认值 = 0>
    参数 参数3 <类型 = 变整数 @默认值 = 0>
    参数 参数4 <类型 = 变整数 @默认值 = 0>
    参数 参数5 <类型 = 变整数 @默认值 = 0>
    参数 参数6 <类型 = 变整数 @默认值 = 0>
    参数 参数7 <类型 = 变整数 @默认值 = 0>
    参数 参数8 <类型 = 变整数 @默认值 = 0>
    参数 参数9 <类型 = 变整数 @默认值 = 0>
    参数 参数10 <类型 = 变整数 @默认值 = 0>
    参数 参数11 <类型 = 变整数 @默认值 = 0>
    参数 参数12 <类型 = 变整数 @默认值 = 0>
    {
        变量 DLL句柄 <类型 = 变整数>
        变量 函数地址 <类型 = 变整数>
        变量 逻辑返回 <类型 = 逻辑型>
        DLL句柄 = 取模块句柄_ (DLL文件路径)
        函数地址 = 取函数地址_ (DLL句柄, DLL函数输出名)
        如果 (指针是否有效_ (函数地址) == 真)
        {
            如果 (返回结果 == 0)
            {
                如果 (DLL参数数量 == 0)
                {
                    配对参数0 (函数地址)
                }
                否则 (DLL参数数量 == 1)
                {
                    配对参数1 (函数地址, 参数1)
                }
                否则 (DLL参数数量 == 2)
                {
                    配对参数2 (函数地址, 参数1, 参数2)
                }
                否则 (DLL参数数量 == 3)
                {
                    配对参数3 (函数地址, 参数1, 参数2, 参数3)
                }
                否则 (DLL参数数量 == 4)
                {
                    配对参数4 (函数地址, 参数1, 参数2, 参数3, 参数4)
                }
                否则 (DLL参数数量 == 5)
                {
                    配对参数5 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5)
                }
                否则 (DLL参数数量 == 6)
                {
                    配对参数6 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6)
                }
                否则 (DLL参数数量 == 7)
                {
                    配对参数7 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7)
                }
                否则 (DLL参数数量 == 8)
                {
                    配对参数8 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8)
                }
                否则 (DLL参数数量 == 9)
                {
                    配对参数9 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9)
                }
                否则 (DLL参数数量 == 10)
                {
                    配对参数10 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10)
                }
                否则 (DLL参数数量 == 11)
                {
                    配对参数11 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10, 参数11)
                }
                否则 (DLL参数数量 == 12)
                {
                    配对参数12 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10, 参数11, 参数12)
                }
                逻辑返回 = 真
            }
            否则 (指针是否有效_ (返回结果) == 真)
            {
                如果 (DLL参数数量 == 0)
                {
                    写指针处值 (返回结果, 配对参数0 (函数地址))
                }
                否则 (DLL参数数量 == 1)
                {
                    写指针处值 (返回结果, 配对参数1 (函数地址, 参数1))
                }
                否则 (DLL参数数量 == 2)
                {
                    写指针处值 (返回结果, 配对参数2 (函数地址, 参数1, 参数2))
                }
                否则 (DLL参数数量 == 3)
                {
                    写指针处值 (返回结果, 配对参数3 (函数地址, 参数1, 参数2, 参数3))
                }
                否则 (DLL参数数量 == 4)
                {
                    写指针处值 (返回结果, 配对参数4 (函数地址, 参数1, 参数2, 参数3, 参数4))
                }
                否则 (DLL参数数量 == 5)
                {
                    写指针处值 (返回结果, 配对参数5 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5))
                }
                否则 (DLL参数数量 == 6)
                {
                    写指针处值 (返回结果, 配对参数6 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6))
                }
                否则 (DLL参数数量 == 7)
                {
                    写指针处值 (返回结果, 配对参数7 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7))
                }
                否则 (DLL参数数量 == 8)
                {
                    写指针处值 (返回结果, 配对参数8 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8))
                }
                否则 (DLL参数数量 == 9)
                {
                    写指针处值 (返回结果, 配对参数9 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9))
                }
                否则 (DLL参数数量 == 10)
                {
                    写指针处值 (返回结果, 配对参数10 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10))
                }
                否则 (DLL参数数量 == 11)
                {
                    写指针处值 (返回结果, 配对参数11 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10, 参数11))
                }
                否则 (DLL参数数量 == 12)
                {
                    写指针处值 (返回结果, 配对参数12 (函数地址, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6, 参数7, 参数8, 参数9, 参数10, 参数11, 参数12))
                }
                逻辑返回 = 真
            }
            动态DLLapi.FreeLibrary (DLL句柄)
        }
        否则
        {
            逻辑返回 = 假
        }
        返回 (逻辑返回)
    }

