类 动态DLLapi <折叠 @文档 = "category = \"动态链接库.动态链接.附加类\"">
{
    方法 GetModuleHandleW <公开 静态 类型 = 变整数 注释 = "返回动态链接库的模块句柄" 折叠 折叠2 @输出名 = "GetModuleHandleW" @视窗.输入 = "kernel32.dll">
    参数 lpModuleName <类型 = 变整数>

    方法 IsBadCodePtr <公开 静态 类型 = 整数 注释 = "指针是否无效,0为有效,1为无效" 折叠 折叠2 @输出名 = "IsBadCodePtr" @视窗.输入 = "kernel32.dll">
    参数 指针 <类型 = 变整数>

    方法 LoadLibraryW <公开 静态 类型 = 变整数 注释 = "成功则返回DLL模块的句柄，0表示失败。" 折叠 折叠2 @输出名 = "LoadLibraryW" @视窗.输入 = "kernel32.dll">
    参数 DLL文件指针 <类型 = 变整数 注释 = "字符串指针">

    方法 FreeLibrary <公开 静态 类型 = 逻辑型 注释 = "释放指定的DLL" 折叠2 @输出名 = "FreeLibrary" @视窗.输入 = "kernel32.dll">
    参数 DLL模块的句柄 <类型 = 变整数 注释 = "取模块句柄_ 的返回值">

    方法 GetProcAddress <公开 静态 类型 = 变整数 注释 = "返回公开函数的地址" 折叠 折叠2 @输出名 = "GetProcAddress" @视窗.输入 = "kernel32.dll">
    参数 DLL模块的句柄 <类型 = 变整数 注释 = "取模块句柄_ 的返回值">
    参数 公开函数名指针 <类型 = 变整数 注释 = "字符串指针" "">
}

# //====

类 函数地址类_ <公开 折叠 折叠2 @文档 = "category = \"动态链接库.函数地址\"" @全局类 = 真>
{
    方法 取执行文件名_DLL <公开 静态 类型 = 文本型 返回值注释 = "返回首个DLL，未找到返回空" 折叠>
    参数 返回的所有DLL <类型 = 文本数组类 注释 = "如果有多个DLL，则返回所有" @默认值 = 空对象>
    参数 是否返回路径 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 临时名称 <类型 = 文本数组类>
        变量 临时路径 <类型 = 文本数组类>
        变量 当前路径 <类型 = 文本型>
        变量 结果组 <类型 = 文本数组类>
        变量 结果名 <类型 = 文本型>
        变量 结果 <类型 = 文本型>
        进程_进程提权 ()
        进程_枚举进程模块 (进程_取自身进程ID (), , , , 临时名称, 临时路径)
        当前路径 = 取运行目录 ()
        临时路径.枚举循环 ()
        {
            结果名 = 临时路径.取枚举值 ()
            如果 (寻找文本 (结果名, 当前路径, , 真) != -1 && 到小写 (文件_取扩展名 (结果名)) == ".dll")
            {
                如果 (是否返回路径)
                {
                    结果组.加入成员 (结果名)
                }
                否则
                {
                    结果组.加入成员 (临时名称.取成员 (临时路径.取枚举索引 ()))
                }
            }
        }
        如果 (结果组.取成员数 () > 0)
        {
            结果 = 结果组.取成员 (0)
            返回的所有DLL = 结果组
        }
        返回 (结果)
    }

    方法 取系统API地址_ <公开 静态 类型 = 变整数 折叠>
    参数 API名 <类型 = 文本型>
    参数 库名称 <类型 = 文本型 注释 = "用于接收当前API所在的库文件" @默认值 = 空对象>
    {
        常量 动态链接库 <类型 = 文本型
                值 = "kernel32.dll, user32.dll, winmm.dll, ws2_32.dll, WinINet.dll, gdi32.dll, GLU32.DLL, aclui.dll, acsmib.dll, activeds.dll, AcXtrnal.dll, adimage.dll, adptif.dll, ADVAPI32.DLL, advpack.dll, atl.dll, authz.dll, avicap32.dll, avifil32.dll, browseui.dll, CABINET.DLL, clusapi.dll, comctl32.dll, comdlg32.dll, comsvcs.dll, crtdll.dll, crypt32.dll, cryptnet.dll, D3DRM.DLL, dbghelp.dll, ddraw.dll, DHCPCSVC.DLL, digest.dll, DINPUT.DLL, dplay.dll, dplayx.dll, dsound.dll, dsprop.dll, dsuiext.dll, ftsrch.dll, gpedit.dll, hhctrl.ocx, hlink.dll, iasperf.dll, icm32.dll, ICMP.DLL, icmui.dll, idq.dll, iedkcs32.dll, iissuba.dll, IMAGEHLP.DLL, imm32.dll, inetcpl.cpl, IPHLPAPI.DLL, iprop.dll, KSUSER.DLL, loadperf.dll, lz32.dll, mapi32.dll, mgmtapi.dll, MOBSYNC.DLL, mpg4dmod.dll, mpr.dll, mprapi.dll, mqrt.dll, msacm32.dll, msafd.dll, mscms.dll, mscpxl32.dLL, msgina.dll, MSHTML.DLL, MSI.DLL, msimg32.dll, msorcl32.dll, MSPATCHA.DLL, msrating.dll, mstlsapi.dll, msvbvm50.dll, msvfw32.dll, MSWSOCK.DLL, MTXDM.DLL, MTXOCI.DLL, NDDEAPI.DLL, ndisnpp.dll, netapi32.dll, npptools.dll, ntdll.dll, ntdsapi.dll, ntdsbcli.dll, ntmsapi.dll, nwprovau.dll, odbc32.dll, ODBCBCP.DLL, odbccp32.dll, ODBCTRAC.DLL, ole32.dll, OLEACC.DLL, oleaut32.dll, olecli32.dll, oledlg.dll, olesvr32.dll, opengl32.dll, password.cpl, pdh.dll, Powrprof.dll, psapi.dll, qosname.dll, query.dll, rasapi32.dll, raschap.dll, rasdlg.dll, rasman.dll, rassapi.dll, rastls.dll, resutils.dll, RICHED20.DLL, rpcns4.dll, rpcrt4.dll, RSRC32.dll, rtm.dll, rtutils.dll, scarddlg.dll, secur32.dll, SENSAPI.DLL, setupapi.dll, SFC.DLL, shdocvw.dll, shell32.dll, shlwapi.dll, snmpapi.dll, softpub.dll, spoolss.dll, SVRAPI.DLL, tapi32.dll, TLBINF32.dll, traffic.dll, url.dll, URLMON.DLL, userenv.dll, USP10.DLL, uxtheme.dll, VB5STKIT.DLL, vba6.dll, VDMDBG.DLL, version.dll, winfax.dll, wininet.dll, winscard.dll, winspool.dll, winspool.drv, wintrust.dll, wldap32.dll, WOW32.DLL, wsnmp32.dll, wtsapi32.dll, xolehlp.dll,msvcrt.dll,realloc.dll,memory.dll">
        变量 成员数量 <类型 = 整数>
        变量 分割的文本 <类型 = 文本数组类>
        变量 函数地址 <类型 = 变整数>
        成员数量 = 分割文本 (动态链接库, ", ", 分割的文本, 真, 真)
        计次循环 (成员数量)
        {
            函数地址 = 取API函数入口 (分割的文本.取成员 (取循环索引 ()), API名)
            如果真 (函数地址 > 0)
            {
                库名称 = 分割的文本.取成员 (取循环索引 ())
                跳出循环
            }
        }
        如果真 (函数地址 == -1)
        {
            库名称 = "未找到API所在的库文件，请确认是否输入错误！"
        }
        返回 (函数地址)
    }

    方法 取API函数入口 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 动态链接库 <类型 = 文本型 @输出名 = "Dynamiclinklibrary">
    参数 欲截获的函数名 <类型 = 文本型 @输出名 = "Functionname">
    {
        // GetProcAddress没有Unicode,因为该函数的执行方式是在 PE 文件的头部用字符串匹配所要找的函数名
        // 而函数名在可执行模块的PE文件头里是以ANSI方式存储的。但是可以自己写一个 Unicode 版本的相应函数
        @ HMODULE Handle = LoadLibraryEx(Dynamiclinklibrary.GetText (),nullptr,true);
        @ if (Handle != NULL)
        @ {
        @    FARPROC address = GetProcAddress(Handle, (LPCSTR) CU8String(Functionname).GetText());
        @    if (address != NULL)
        @      {
        @         return (@dt<变整数>)address;
        @      }
        @      FreeLibrary(Handle);
        @ }
        @ return -1;
    }
}
