<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"数据匹配库\"">

类 正则类_ <公开 折叠 @文档 = "category = \"数据匹配库.正则\"">
{
    变量 正则 <类型 = COM对象类>
    变量 集_过度对象 <类型 = COM对象类>
    变量 集_被搜索的文本 <类型 = COM变体型>

    方法 类_清理 <折叠>
    {
        正则.清除 ()
        集_过度对象.清除 ()
        集_被搜索的文本.清空 ()
        COM初始化类.清理COM ()
    }

    方法 类_初始化 <折叠>
    {
        COM初始化类.初始化COM ()
    }

    方法 创建 <公开 类型 = 逻辑型 折叠>
    参数 正则表达式文本 <类型 = 文本型>
    参数 要匹配的内容 <类型 = 文本型>
    参数 是否区分大小写 <类型 = 逻辑型 注释 = "可以留空,默认为假,不区分大小写; 真为区分大小写;" 注释 = "本参数指定这个正则表达式在创建成功后进行匹配、搜索、替换时，是否区分大小写;" 折叠2 @默认值 = 假>
    参数 是否匹配多行 <类型 = 逻辑型 注释 = "可以留空,默认为真,允许匹配多行; 如果本成员值为真，字符“^”不仅匹配目标文本的开头;"
            注释 = "而且匹配目标文本中换行符（字符(10)，字符(13)或 #换行符）的后面；字符“$”不仅匹配目标文本的结尾，而且匹配目标文本中换行符的前面;" 注释 = "否则字符“^”仅仅匹配目标文本的开头，“$”也仅仅匹配目标文本的结尾"
            折叠2 @默认值 = 真>
    参数 是否全局匹配 <类型 = 逻辑型 注释 = "可以留空，默认为真，全局匹配" @默认值 = 真>
    {
        变量 局_正则文本 <类型 = 文本型>
        正则.清除 ()
        集_过度对象.清除 ()
        正则.创建 ("VBScript.RegExp", )
        正则.写属性 ("IgnoreCase", 取反 (是否区分大小写))  // 匹配时不区分大小写
        正则.写属性 ("Multiline", 是否匹配多行)  // 是否匹配多行
        正则.写属性 ("Singleline", 真)  // Singleline(单行模式)
        正则.写属性 ("Global", 是否全局匹配)  // 是否全局匹配
        局_正则文本 = 正则表达式文本
        正则.写属性 ("Pattern", 局_正则文本)
        集_被搜索的文本.赋值 (要匹配的内容, )
        集_过度对象 = 正则.对象型方法 ("Execute", COM对象类, 集_被搜索的文本)
        返回 (集_过度对象.是否为空 () == 假)
    }

    方法 取正则文本 <公开 类型 = 文本型 注释 = "返回以文本形式表示的正则表达式.如果该对象尚未创建,则返回空文本" 折叠>
    {
        返回 (选择 (正则.是否为空 (), "", 正则.读无参数属性 ("Pattern", 文本型)))
    }

    方法 替换 <公开 类型 = 文本型 注释 = "替换在正则表达式查找中找到的文本" 折叠>
    参数 用作替换的文本 <类型 = 文本型 注释 = "用作替换的文本">
    {
        变量 用作替换的文本_变体型 <类型 = COM变体型>
        用作替换的文本_变体型.赋值 (用作替换的文本, )
        返回 (正则.方法 ("Replace", 文本型, 集_被搜索的文本, 用作替换的文本_变体型))
    }

    方法 取匹配数量 <公开 类型 = 整数 注释 = "取出该正则匹配到的数量" 折叠>
    {
        返回 (集_过度对象.读无参数属性 ("Count", 整数))
    }

    方法 取匹配文本 <公开 类型 = 文本型 注释 = "取出该正则匹配到的文本" 折叠>
    参数 匹配索引 <类型 = 整数 注释 = "从0开始">
    参数 起始位置 <类型 = 变整数 注释 = "传址 返回取得的子文本在整个被搜索文本中的起始位置" @默认值 = 0>
    {
        变量 Match <类型 = COM对象类>
        变量 Value <类型 = 文本型>
        Match = 集_过度对象.读对象型属性 ("Item", COM对象类, 匹配索引)
        Value = Match.读无参数属性 ("Value", 文本型)
        如果真 (起始位置 != 0)
        {
            写指针处值 (起始位置, 寻找文本 (集_被搜索的文本.取值 (文本型), Value, Match.读无参数属性 ("FirstIndex", 整数), 选择 (正则.读无参数属性 ("IgnoreCase", 文本型) == "0", 真, 假)) - 1)
        }
        返回 (Value)
    }

    方法 取子匹配文本 <公开 类型 = 文本型 注释 = "取出该正则的子表达式匹配到的文本" 折叠 @禁止流程检查 = 真>
    参数 匹配索引 <类型 = 整数 注释 = "从0开始">
    参数 子表达式索引 <类型 = 整数 注释 = "欲取其值的子表达式,该参数对应与正则表达式中的一个子表达式以圆括号\"( )\"为标记,索引从0开始">
    参数 起始位置 <类型 = 变整数 注释 = "传址 返回取得的子文本在整个被搜索文本中的起始位置" @默认值 = 0>
    {
        变量 Match <类型 = COM对象类>
        变量 SubMatches <类型 = COM对象类>
        变量 value <类型 = 文本型>
        Match = 集_过度对象.读对象型属性 ("Item", COM对象类, 匹配索引)
        SubMatches = Match.读无参数对象型属性 ("SubMatches", COM对象类)
        value = SubMatches.读属性 ("Item", 文本型, 子表达式索引)
        如果真 (起始位置 != 0)
        {
            写指针处值 (起始位置, 寻找文本 (集_被搜索的文本.取值 (文本型), value, Match.读无参数属性 ("FirstIndex", 整数), 选择 (正则.读无参数属性 ("IgnoreCase", 文本型) == "0", 真, 假)) - 1)
        }
        返回 (value)
    }

    方法 取子匹配数量 <公开 类型 = 整数 注释 = "取出该正则的子表达式匹配到的数量" 折叠 @禁止流程检查 = 真>
    {
        返回 (集_过度对象.读对象型属性 ("Item", COM对象类, 0).读无参数对象型属性 ("SubMatches", COM对象类).读无参数属性 ("Count", 整数))

    }
}

# //=======

类 数据匹配类_正则 <公开 折叠 折叠2 @文档 = "category = \"数据匹配库.数据匹配\"" @全局类 = 真>
{
    方法 是否为整数或小数_ <公开 静态 类型 = 逻辑型 注释 = "正则方式" 折叠>
    参数 待查内容 <类型 = 文本型>
    参数 小数位最小位数要求 <类型 = 整数 @默认值 = 1>
    参数 小数位最大位数要求 <类型 = 整数 @默认值 = 9>
    {
        常量 公式前 <类型 = 文本型 值 = "^-?[0-9]+(\\.[0-9]">
        常量 公式后 <类型 = 文本型 值 = ")?$|^[0-9]+$">
        变量 正则 <类型 = 正则类_>
        正则.创建 (公式前 + "{" + 到文本 (小数位最小位数要求) + "," + 到文本 (小数位最大位数要求) + "}" + 公式后, 待查内容)
        如果真 (正则.取匹配数量 () > 0)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 匹配所有小数_ <公开 静态 类型 = 文本数组类 注释 = "正则方式" 折叠>
    参数 待查内容 <类型 = 文本型>
    {
        常量 公式 <类型 = 文本型 值 = "[+-]?\\d+(\\.\\d+)">
        变量 正则 <类型 = 正则类_>
        变量 结果 <类型 = 文本数组类>
        正则.创建 (公式, 待查内容)
        计次循环 (正则.取匹配数量 ())
        {
            结果.加入成员 (正则.取匹配文本 (取循环索引 ()))
        }
        返回 (结果)
    }

    方法 匹配所有小数整数_ <公开 静态 类型 = 文本数组类 注释 = "正则方式" 折叠>
    参数 待查内容 <类型 = 文本型>
    {
        常量 公式 <类型 = 文本型 值 = "[+-]?\\d+(\\.\\d+)?">
        变量 正则 <类型 = 正则类_>
        变量 结果 <类型 = 文本数组类>
        正则.创建 (公式, 待查内容)
        计次循环 (正则.取匹配数量 ())
        {
            结果.加入成员 (正则.取匹配文本 (取循环索引 ()))
        }
        返回 (结果)
    }

    方法 是否为小数_ <公开 静态 类型 = 逻辑型 注释 = "正则方式" 折叠>
