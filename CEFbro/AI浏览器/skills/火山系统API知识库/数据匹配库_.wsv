    参数 待查内容 <类型 = 文本型>
    {
        计次循环 (取文本长度 (待查内容))
        {
            如果真 (取代码_ (待查内容, 取循环索引 ()) > 19967 && 取代码_ (待查内容, 取循环索引 ()) < 40870)
            {
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 匹配所有非中文_ <公开 静态 类型 = 文本型 注释 = "非正则方式" 折叠 @禁止流程检查 = 真>
    参数 待查内容 <类型 = 文本型>
    {
        变量 szBuffer <类型 = 文本型>
        @ if (TCHAR* szBuffer = (TCHAR*)calloc(@<待查内容>.GetLength() + 1, sizeof(TCHAR)))
        @ {
        @     DWORD i = 0, n = 0;
        @     TCHAR bit = 0;
        @     for (; i < @<待查内容>.GetLength(); i++)
        @     {
        @         bit = *((TCHAR*)@<待查内容>.GetText() + i);
        @         if (L'\u4e00' > bit && bit < L'\u9fa5')
        @         {
        @             *((TCHAR*)szBuffer + n) = bit;
        @             n++;
        @         }
        @     }
        @     @<szBuffer>.SetValueText(szBuffer);
        @     free(szBuffer);
        @ }
        返回 (szBuffer)
    }

