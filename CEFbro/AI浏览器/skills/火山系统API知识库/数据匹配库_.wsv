            值 = {"jpg、jpeg","png","bmp","gif","ico","tif、tiff","psd","webp、wav","tga","raw","wmf","ai、pdf","dwg","wav","aiff","mpg、mpeg","mpg","mpg","mp3","mp3","mp4","mid、midi","wma、wmv","avi","mov","ra、ram","rm、rmvb","flv","swf","swf","rtf","docx、xlsx、pptx、ppsx","doc、xls、ppt、pps","rar","zip、xlsx","zip","7z","xml","html","accdb","mdb","mdb","v","vcip","exe、dll、ocx","e","ec","txt","wpd","chm","cur","mdf、ldf"}
