    {
        常量 公式 <类型 = 文本型 值 = "^([0-9]{1,}[.][0-9]*)$">
        变量 正则 <类型 = 正则类_>
        正则.创建 (公式, 待查内容)
        如果 (正则.取匹配数量 () > 0)
        {
            返回 (真)
        }
        返回 (假)
    }

