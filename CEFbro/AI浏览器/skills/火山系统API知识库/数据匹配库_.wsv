    {
        变量 szBuffer <类型 = 文本型>
        @ if (TCHAR* szBuffer = (TCHAR*)calloc(@<待查内容>.GetLength() + 1, sizeof(TCHAR)))
        @ {
        @     DWORD i = 0, n = 0;
        @     TCHAR bit = 0;
        @     for (; i < @<待查内容>.GetLength(); i++)
        @     {
        @         bit = *((TCHAR*)@<待查内容>.GetText() + i);
        @         if (@<获取类型> == 1)
        @         {
        @             if (L'a' <= bit && bit <= L'z')
        @             {
        @                 *((TCHAR*)szBuffer + n) = bit;
        @                 n++;
        @             }
        @         }
        @         else if (@<获取类型> == 2)
        @         {
        @             if (L'A' <= bit && bit <= L'Z')
        @             {
        @                 *((TCHAR*)szBuffer + n) = bit;
        @                 n++;
        @             }
        @         }
        @         else
        @         {
        @             if (L'a' <= bit && bit <= L'z' || L'A' <= bit && bit <= L'Z')
        @             {
        @                 *((TCHAR*)szBuffer + n) = bit;
        @                 n++;
        @             }
        @         }
        @     }
        @     @<szBuffer>.SetValueText(szBuffer);
        @     free(szBuffer);
        @ }
        返回 (szBuffer)
    }

