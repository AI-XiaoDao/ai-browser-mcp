    方法 文件类型识别_ <公开 类型 = 整数 注释 = "可以识别52种常见文件类型，让被更改过扩展名的文件无处遁形" 返回值注释 = "识别成功返回大于0，否则为识别失败。" 折叠>
    参数 文件来源 <类型 = 文本型>
    参数 返回真实扩展名 <类型 = 文本型 @默认值 = 空对象>
    参数 返回文件描述 <类型 = 文本型 @默认值 = 空对象>
    {
        变量 头数据 <类型 = 文本型>
        变量 头数据2 <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        头数据 = 取文件头_ (文件来源, )
        循环 (, 52, i)
        {
            头数据2 = 取文本左边 (头数据, 取文本长度 (文件头组 [i]))
            如果真 (头数据2 == 文件头组 [i])
            {
                如果 (i == 8)
                {
                    如果真 (取文件头_ (文件来源, 8) == "0000020001002020")
                    {
                        返回真实扩展名 = "cur"
                        返回文件描述 = "光标文件"
                        i2 = 1
                    }
                }
                否则
                {
                    返回真实扩展名 = 扩展名组 [i]
                    返回文件描述 = 描述组 [i]
                    i2 = 1
                }
                跳出循环
            }
        }
        返回 (i2)
    }

