类 数据匹配类_非正则 <公开 折叠 折叠2 @文档 = "category = \"数据匹配库.数据匹配\"" @全局类 = 真>
{
    方法 格式化手机号_ <公开 静态 类型 = 文本型 注释 = "例如“18812345678”转换后为“188 1234 5678”" 折叠>
    参数 号码 <类型 = 文本型>
    {
        如果真 (取文本长度 (号码) != 11)
        {
            返回 ("")
        }
        返回 (取文本左边 (号码, 3) + " " + 取文本中间 (号码, 3, 4) + " " + 取文本右边 (号码, 4))
    }

    方法 格式化金额_ <公开 静态 类型 = 文本型 注释 = "例如“12345678.67”转换后为“12,345,678.67”" 折叠>
    参数 金额 <类型 = 小数>
    {
        变量 金额2 <类型 = 文本型>
        变量 金额左 <类型 = 文本型>
        变量 金额右 <类型 = 文本型>
        变量 结果 <类型 = 文本型>
        变量 倍数 <类型 = 整数>
        变量 差位 <类型 = 整数>
        变量 i <类型 = 整数>
        金额2 = 到文本 (金额)
        金额左 = 取文本左边_ (金额2, ".", , 真)
        金额右 = 取文本右边2_ (金额2, ".")
        倍数 = 取文本长度 (金额左) / 3
        差位 = 取文本长度 (金额左) - 倍数 * 3
        如果真 (取文本长度 (金额左) % 3 != 0)
        {
            加入文本 (结果, 取文本左边 (金额2, 差位) + ",")
        }
        循环 (, 倍数, i)
        {
            加入文本 (结果, 取文本中间 (金额左, 差位 + i * 3, 3) + ",")
        }
        结果 = 取文本左边 (结果, 取文本长度 (结果) - 1)
        如果真 (金额右 != "")
        {
            加入文本 (结果, "." + 金额右)
        }
        返回 (结果)
    }

