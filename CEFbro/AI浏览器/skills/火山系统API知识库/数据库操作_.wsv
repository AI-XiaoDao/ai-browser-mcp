    方法 查找指定记录 <公开 类型 = 逻辑型 注释 = "根据指定的条件以及选项查找并跳转至满足条件的记录位置." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 条件语句 <类型 = 文本型 注释 = "指定搜索的语句,该语句指定要在搜索中使用的列名称,比较运算符和值.">
    参数 起始搜索位置 <类型 = 整数 注释 = "本次搜索起始的偏移,默认情况下将会从当前所处位置开始搜索." @默认值 = 0>
    参数 正向搜索 <类型 = 逻辑型 注释 = "指定搜索是否从记录集的开头搜索至末尾位置,提供假则反向搜索,即从末尾至开头." @默认值 = 真>
    参数 起始搜索书签 <类型 = COM变体型 注释 = "作为搜索的起始位置的书签对象." @默认值 = 空对象>
    {
        变量 搜索方向 <类型 = 整数>
        如果 (正向搜索)
        {
            搜索方向 = 1
        }
        否则
        {
            搜索方向 = -1
        }
        如果 (是否为空对象 (起始搜索书签))
        {
            返回 (记录集对象.无返回值方法 ("Find", 条件语句, 起始搜索位置, 搜索方向))
        }
        否则
        {
            返回 (记录集对象.无返回值方法 ("Find", 条件语句, 起始搜索位置, 搜索方向, 起始搜索书签))
        }
    }

