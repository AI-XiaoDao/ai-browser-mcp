    参数 数据源 <类型 = COM变体型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称)." @默认值 = 空对象>
    参数 活动连接 <类型 = COM变体型 注释 = "是否提供一个已有的活动连接对象(数据库类),也可提供连接串文本,与连接数据库同理." @默认值 = 空对象>
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型_\"所提供的常量." @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型_\"所提供的常量." @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型_\"以及\"数据库命令执行选项_\"所定义常量的单个或多个组合值." @默认值 = -1>
    {
        如果 (是否客户端)
        {
            游标服务位置 = 数据库游标服务位置_.客户端游标
        }
        返回 (无返回值方法 ("Open", 数据源, 活动连接, 游标类型, 编辑锁, 选项))
    }

    方法 执行 <公开 类型 = 逻辑型 注释 = "从一个已经创建并成功连接的\"数据库类_\"对象打开执行当前记录集对象." 注释 = "Excel表名字段之类需要这样表示：[表1$]" 返回值注释 = "执行成功返回真,否则返回假." 折叠
            折叠2>
    参数 数据源 <类型 = 文本型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称).">
    参数 连接对象 <类型 = 数据库类_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型_\"所提供的常量." @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型_\"所提供的常量." @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型_\"以及\"数据库命令执行选项_\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    {
        变量 连接 <类型 = COM变体型>
        变量 源 <类型 = COM变体型>
        变量 结果 <类型 = 逻辑型>
        源.赋值 (数据源)
        连接.置COM对象 (连接对象.连接对象)
        结果 = 打开 (源, 连接, 是否客户端, 游标类型, 编辑锁, 选项)
        错误描述 = 连接对象.语句错误描述信息
        语句错误描述信息 = 连接对象.语句错误描述信息
        返回 (结果)
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 注释 = "Excel表名字段之类需要这样表示：[表1$]" 返回值注释 = "如是执行查询，并不会返回真假，需要改用执行SQL语句2\"" 折叠 @禁止流程检查 = 真>
    参数 SQL语句 <类型 = 文本型 注释 = "提供所欲执行的SQL语句,例如:SELECT * FROM VOLDP">
    参数 连接对象 <类型 = 数据库类_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 选项 <类型 = 整数 注释 = "提供本次执行的可选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 受影响行数 <类型 = 整数类 注释 = "提供一个整数类变量以获取本次命令执行后,影响到表中的记录数量，如是执行查询操作是不会返回受影响行数" @默认值 = 空对象>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    {
        变量 影响数 <类型 = 整数类>
        变量 结果 <类型 = 逻辑型>
        变量 临时记录集 <类型 = 记录集类_>
        临时记录集 = 执行SQL语句2 (SQL语句, 连接对象, 选项, 影响数)
        受影响行数 = 影响数
        如果真 (影响数.值 > 0 || 临时记录集.是否成功 () == 真)
        {
            结果 = 真
        }
        错误描述 = 连接对象.语句错误描述信息
        语句错误描述信息 = 连接对象.语句错误描述信息
        返回 (结果)
    }

    方法 执行SQL语句2 <公开 类型 = 记录集类_ 注释 = "Excel表名字段之类需要这样表示：[表1$]" 折叠 @禁止流程检查 = 真>
    参数 SQL语句 <类型 = 文本型 注释 = "提供所欲执行的SQL语句,例如:SELECT * FROM VOLDP">
    参数 连接对象 <类型 = 数据库类_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 选项 <类型 = 整数 注释 = "提供本次执行的可选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 受影响行数 <类型 = 整数类 注释 = "提供一个整数类变量以获取本次命令执行后,影响到表中的记录数量，如是执行查询操作是不会返回受影响行数" @默认值 = 空对象>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    {
        变量 连接 <类型 = COM对象类>
        变量 临时记录 <类型 = COM对象类>
        连接.置COM对象 (连接对象.连接对象)
        临时记录 = 连接.方法 ("Execute", COM对象类, SQL语句, 受影响行数, 选项)
        错误描述 = 连接对象.语句错误描述信息
        语句错误描述信息 = 连接对象.语句错误描述信息
        @ return @dt<记录集类_> (@<临时记录>);
    }

