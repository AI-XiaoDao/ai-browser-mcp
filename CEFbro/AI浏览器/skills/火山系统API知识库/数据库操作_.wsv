    方法 取字段列表 <公开 类型 = 文本数组类 注释 = "获取该记录集当前位置所包含的所有字段(列)列表." 注释 = "在该表执行\"执行SQL语句2\"后，再取字段，才能取出字段列表" 返回值注释 = "直接返回字段列数组" 折叠 折叠2>
    参数 记录集 <类型 = 记录集类_>
    {
        变量 数据库字段 <类型 = 数据库字段集合类_>
        变量 当前字段 <类型 = 数据库字段类_>
        变量 字段组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        数据库字段 = 记录集.取字段列表 ()
        循环 (, 数据库字段.成员数, i)
        {
            当前字段 = 数据库字段.取成员 (i)
            字段组.加入成员 (当前字段.名称)
        }
        返回 (字段组)
    }

    方法 取结构信息 <公开 类型 = 记录集类_ 注释 = "获取当前所连接数据库的结构信息." 返回值注释 = "返回包含该数据库的结构信息记录集." 折叠 @禁止流程检查 = 真>
    参数 查询类型 <类型 = 整数 注释 = "提供所欲查询的类型,请参考\"数据库结构信息类型_\"所提供的常量值.">
    {
        变量 返回记录 <类型 = COM对象类>
        返回记录 = 连接对象.方法 ("OpenSchema", COM对象类, 查询类型)
        @ return @dt<记录集类_>(@<返回记录>);
    }

    方法 类_初始化 <折叠>
    {
        如果 (连接对象.创建 ("ADODB.Connection"))
        {
            连接事件对象.挂接 (连接对象, "{00000400-0000-0010-8000-00AA006D2EA4}")
        }
    }

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发." 折叠>
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        如果 (来源对象 == 连接事件对象)  // 分发连接对象的事件
        {
            如果 (事件方法ID == 0x00000006)  // WillConnect
            {
                事件返回值.赋值 (即将开始连接 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (文本型), 事件参数.取成员 (2).取值 (文本型), 事件参数.取成员 (4).取值 (整数)))
            }
            否则 (事件方法ID == 0)  // InfoMessage
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (警告信息反馈 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000001)  // BeginTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (1).取COM对象 (错误返回)
                事件返回值.赋值 (开始事务完成 (事件参数.取成员 (0).取值 (整数), 错误返回, 事件参数.取成员 (2).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000003)  // CommitTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (提交事务完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000002)  // RollbackTransComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (回滚事务完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000004)  // WillExecute
            {
                事件返回值.赋值 (即将开始执行 (事件参数.取成员 (0).取值 (文本型), 事件参数.取成员 (1).取值 (整数), 事件参数.取成员 (2).取值 (整数), 事件参数.取成员 (3).取值 (整数), 事件参数.取成员 (4).取值 (整数)))
            }
            否则 (事件方法ID == 0x00000005)  // ExecuteComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (1).取COM对象 (错误返回)
                变量 返回记录 <类型 = 记录集类_>
                事件参数.取成员 (4).取COM对象 (返回记录)
                事件返回值.赋值 (命令执行完成 (事件参数.取成员 (0).取值 (整数), 返回记录, 错误返回, 事件参数.取成员 (2).取值 (整数)))
                语句错误描述信息 = 错误返回.错误描述
            }
            否则 (事件方法ID == 0x00000007)  // ConnectComplete
            {
                变量 错误返回 <类型 = 数据库错误信息类_>
                事件参数.取成员 (0).取COM对象 (错误返回)
                事件返回值.赋值 (连接完成 (错误返回, 事件参数.取成员 (1).取值 (整数)))
                连接错误描述 = 错误返回.错误描述
            }
            否则 (事件方法ID == 0x00000008)  // Disconnect
            {
                事件返回值.赋值 (断开连接 (事件参数.取成员 (0).取值 (整数)))
            }
        }
        返回 (0)
    }

    方法 即将开始连接 <公开 定义事件 类型 = 整数 注释 = "即将发起数据库连接时,本事件将被调用." 折叠>
    参数 连接文本 <类型 = 文本型 注释 = "本次发起连接所使用的连接文本内容.">
    参数 用户名 <类型 = 文本型 注释 = "本次发起连接所使用的用户名.">
    参数 密码 <类型 = 文本型 注释 = "本次发起连接所使用的密码.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 即将开始执行 <公开 定义事件 类型 = 整数 注释 = "即将执行SQL命令时,本事件将被调用." 折叠>
    参数 命令内容 <类型 = 文本型 注释 = "即将执行的命令内容文本.">
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型_\"所提供的常量值.">
    参数 编辑锁类型 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型_\"所提供的常量值.">
    参数 选项值 <类型 = 整数 注释 = "执行命令或打开记录集所使用的选项值.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 警告信息反馈 <公开 定义事件 类型 = 整数 注释 = "在操作过程中如果出现警告信息,本事件将被调用." 折叠>
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 开始事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用." 折叠>
    参数 事务等级 <类型 = 整数 注释 = "本次事务的等级.">
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 提交事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用." 折叠>
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 回滚事务完成 <公开 定义事件 类型 = 整数 注释 = "当调用\"开始事务\"后,如果开始成功本事件将被调用." 折叠>
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">
    参数 操作状态 <类型 = 整数 注释 = "请参考\"数据库事件执行状态_\"所提供的常量值.">

    方法 命令执行完成 <公开 定义事件 类型 = 整数 注释 = "在执行SQL命令后,执行完毕本事件将被调用." 折叠>
    参数 影响行数 <类型 = 整数 注释 = "执行该命令后被影响的记录数量.">
    参数 记录集 <类型 = 记录集类_ 注释 = "执行该命令后所获取到的记录集对象.">
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">
