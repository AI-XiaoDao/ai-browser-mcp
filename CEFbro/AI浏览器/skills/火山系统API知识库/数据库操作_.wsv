                    {
                        名称 = mysql组32.取枚举值 ()
                        跳出循环
                    }
                }
            }
            加入文本 (说明文, "已安装: " + 名称 + " 　详细版本：" + 版本 + "\r\n")
            加入文本 (说明文, "已安装: " + "MySQL ODBC 8.0 Unicode Driver" + " 　详细版本：" + 版本 + "\r\n")
        }
        返回 (说明文)
    }

