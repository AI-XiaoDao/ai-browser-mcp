        变量 名称组 <类型 = 文本数组类>
        变量 临时记录集 <类型 = 记录集类_>
        如果真 (数据库类型 < 1 || 数据库类型 > 3)
        {
            数据库类型 = 1
        }
        如果 (数据库类型 == 1)
        {
            临时记录集 = 执行SQL语句2 ("select name from syscolumns where id=Object_Id('" + 数据表名 + "')")
        }
        否则 (数据库类型 == 2)
        {
            临时记录集 = 执行SQL语句2 ("select COLUMN_NAME from information_schema.COLUMNS where table_name='" + 数据表名 + "'")
