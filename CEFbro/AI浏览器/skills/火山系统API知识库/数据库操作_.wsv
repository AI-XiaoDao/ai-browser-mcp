    方法 取新建表SQL <公开 类型 = 文本型 注释 = "create table" 注释 = "例如："
            注释 = "链式：sql.表名 (\"商品表\").主键 (\"ID\").文本字段2 (\"品名\", 200).货币字段 (\"单价\").日期时间字段 (\"入库时间\").取新建表SQL () ;"
            注释 = "相当于SQL语句：create table 商品表(ID int identity primary key,品名 varchar(200),单价 money,入库时间 datetime)" 折叠 折叠2>
    {
        变量 sql <类型 = 文本型>
        变量 tmp <类型 = 文本型>
        sql = "create table " + 命令集.取值 (SQL类型.表名) + "("
        如果 (主键类型 == 1)
        {
            tmp = 命令集.取值 (SQL类型.主键)
        }
        否则 (主键类型 == 2)
        {
