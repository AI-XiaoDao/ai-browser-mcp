<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"ADO数据库\"">

# 数据库1 ---

类 数据库类_ <公开 折叠 @文档 = "category = \"ADO数据库.ADO数据库1\"">
{

    # @begin
    # @ @def_macro DECLARE_ADO_COMOBJ(vol_class_name)    \
    # <>         <include>    \
    #         inline_ @dt<vol_class_name> (@dt<COM对象类>& obj) : @dt<vol_class_name> () { SetUnknownObject (obj.m_pUnknownObject); }    \
    #         inline_ void @an<_OnCleanupExtra> () { ReleaseUnknownObject(); }    \
    # <>         </include>
    #
    # @ @def_macro DECLARE_ADO_COMOBJ_EXTRA_INIT(vol_class_name, init_method_name)    \
    # <>         <include>    \
    #         inline_ @dt<vol_class_name> (@dt<COM对象类>& obj) : @dt<vol_class_name> ()   \
    #         {    \
    #             SetUnknownObject (obj.m_pUnknownObject);    \
    #             @n<init_method_name>(obj);    \
    #         }    \
    #         inline_ void @an<_OnCleanupExtra> () { ReleaseUnknownObject(); }    \
    # <>         </include>
    #
    # @end

    变量 连接对象 <公开 类型 = COM对象类>
    变量 连接事件对象 <类型 = COM对象事件类>
    变量 连接文本内容 <类型 = 文本型>
    变量 连接文本内容2 <类型 = 文本型>
    变量 语句错误描述信息 <公开 类型 = 文本型 值 = "还未连接数据库">
    变量 连接错误描述 <公开 类型 = 文本型 值 = "还未连接数据库">

    方法 执行超时 <公开 属性写 注释 = "设置该数据库对象等待命令执行所欲等待的时间." 折叠>
    参数 超时 <类型 = 整数 注释 = "单位:秒,提供0表示无超时一直等待.">
    {
        连接对象.写属性 ("CommandTimeout", 超时)
    }

    方法 执行超时 <公开 属性读 类型 = 整数 注释 = "获取该数据库对象等待命令执行所欲等待的时间." 折叠>
    {
        返回 (连接对象.读无参数属性 ("CommandTimeout", 整数))
    }

    方法 连接文本 <公开 属性写 注释 = "设置\"连接\"方法所欲使用的连接文本." 折叠 折叠2 编辑时信息 = "7954D, 0, 0, 0" @值细节类型 = 自定义
            @附加文本 = "..\\mfc_ui_base\\designer\\mfc_designer_x64.dll\r\n..\\mfc_ui_base\\designer\\mfc_designer_win32.dll\r\nGetODBCConnectStr\r\n0">
    参数 值 <类型 = 文本型 编辑时信息 = "7954D, 0, 0, 0">
    {
        连接文本内容 = 值
    }

    方法 连接文本 <公开 属性读 类型 = 文本型 注释 = "获取已设置的连接文本属性内容." 折叠>
    {
        返回 (连接文本内容)
    }

    方法 连接文本2 <公开 属性读 类型 = 文本型 注释 = "锐浪专用连接，获取已设置的连接文本属性内容." 折叠>
    {
