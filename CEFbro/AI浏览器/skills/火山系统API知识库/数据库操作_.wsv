# 链式SQL ---

类 链式SQL类_ <公开 注释 = "查询：" 注释 = "链式：sql.表名 (\"商品表\").字段 (\"*\").条件 (\"品名=\'新品\'\").且 (\"规格=\'12g\'\").取查询SQL () ;"
        注释 = "相当于SQL语句：select  from 商品表 where 品名=\'新品\' and 规格=\'12g\' ;"
        注释 = "链式：sql.表名 (\"商品表\").条件2 (\"品名\", \"新品\").或2 (\"品名\", \"新货\").取查询SQL ()"
        注释 = "相当于SQL语句：select  from 商品表 where 品名 like \'%新品%\' or 品名 like \'%新货%\'" 注释 = "" 注释 = "新增："
        注释 = "链式：sql.表名 (\"商品表\").插入数据 (\"品名,规格,单位,金额\", \"\'新品\',\'12g\',\'盒\',100\").取新增SQL () ;"
        注释 = "相当于SQL语句：insert into 商品表(品名 , 规格 , 单位 , 金额) values (\'新品\' , \'12g\' , \'盒\' , 100)  ;" 注释 = "" 注释 = "修改："
        注释 = "链式：sql.表名 (\"商品表\").赋值 (\"品名\", \"\'新品名\'\").赋值 (\"规格\", \"\'18g\'\").条件 (\"id=2\").取修改SQL () ;"
        注释 = "相当于SQL语句：update 商品表 set 品名=\'新品名\' , 规格=\'18g\' where id=2 ;" 注释 = "" 注释 = "删除："
        注释 = "链式：sql.表名 (\"商品表\").条件 (\"品名=\'新品\'\").且 (\"规格=\'12g\'\").取删除SQL () ;"
        注释 = "相当于SQL语句：delete from 商品表 where 品名=\'新品\' and 规格=\'12g\'" 注释 = "" 注释 = "创建库：" 注释 = "链式：sql.表名 (\"cs\").取新建库SQL () ;"
        注释 = "相当于SQL语句：create database cs" 注释 = "" 注释 = "删除库：" 注释 = "链式：sql.表名 (\"商品表\").取删除库SQL ()"
        注释 = "相当于SQL语句：drop database 商品表" 注释 = "" 注释 = "创建表："
        注释 = "链式：sql.表名 (\"商品表\").主键 (\"ID\").文本字段2 (\"品名\", 200).货币字段 (\"单价\").日期时间字段 (\"入库时间\").取新建表SQL () ;"
        注释 = "相当于SQL语句：create table 商品表(ID int identity primary key,品名 varchar(200),单价 money,入库时间 datetime)" 注释 = "" 注释 = "删除表："
        注释 = "链式：sql.表名 (\"商品表\").取删除表SQL ()" 注释 = "相当于SQL语句：drop table 商品表" 折叠 折叠2 @文档 = "category = \"ADO数据库.链式SQL\"">
{
    变量 命令集 <静态 类型 = SQL命令集>
    变量 主键类型 <类型 = 整数>

    方法 字段 <公开 类型 = 链式SQL类_ 注释 = "field" 折叠 @视窗.返回参考 = 真>
    参数 字段名 <类型 = 文本型>
    参数 唯一性 <类型 = 逻辑型 注释 = "DISTINCT" @默认值 = 假>
    {
        命令集.插入 (SQL类型.字段, 选择 (唯一性 == 真, "distinct " + 字段名, 字段名))
        返回 (本对象)
    }

    方法 表名 <公开 类型 = 链式SQL类_ 注释 = "field;" 注释 = "表名后对接，例如：;" 注释 = "查询：条件 (\"品名=\'新品\'\").且 (\"规格=\'12g\'\").取查询SQL () ;"
            注释 = "查询：条件2 (\"品名\", \"新品\").且2 (\"品名\", \"新货\").取查询SQL ()"
            注释 = "相当于SQL语句：select  from 商品表 where 品名 like \'%新品%\' or 品名 like \'%新货%\'"
            注释 = "新增：插入数据 (\"品名,规格\", \"\'新品\',\'12g\').取新增SQL () ;"
            注释 = "修改：赋值 (\"品名\", \"\'新品名\'\").赋值 (\"规格\", \"\'18g\'\").取修改SQL () ;"
            注释 = "删除：条件 (\"品名=\'新品\'\").且 (\"规格=\'12g\'\").取删除SQL ()" 折叠 折叠2 @视窗.返回参考 = 真>
    参数 表名 <类型 = 文本型>
    参数 别名 <类型 = 文本型 @默认值 = "">
    {
        命令集.插入 (SQL类型.表名, 表名 + 选择 (别名 == "", "", " as " + 别名))
        返回 (本对象)
    }

    方法 条件 <公开 类型 = 链式SQL类_ 注释 = "where" 折叠 @视窗.返回参考 = 真>
    参数 命令语句 <类型 = 文本型 注释 = "例如：\"品名=\'新品\'\"">
    {
        命令集.插入 (SQL类型.条件, 命令语句)
        返回 (本对象)
    }

    方法 条件2 <公开 类型 = 链式SQL类_ 注释 = "where" 折叠 @视窗.返回参考 = 真>
    参数 条件前语句 <类型 = 文本型 注释 = "例如：\"品名\"">
    参数 条件后语句 <类型 = 文本型 注释 = "例如：模糊条件：\"新品\"　；精确条件：\'新品\'">
    参数 类型 <类型 = 逻辑型 注释 = "真：模糊(like)　假：精确" @默认值 = 真>
    {
        如果 (类型 == 真)
        {
            命令集.插入 (SQL类型.条件, 条件前语句 + " like '%" + 条件后语句 + "%'")
        }
        否则
        {
            命令集.插入 (SQL类型.条件, 条件前语句 + 条件后语句)
        }
        返回 (本对象)
    }

    方法 排序 <公开 类型 = 链式SQL类_ 注释 = "order" 折叠 @视窗.返回参考 = 真>
    参数 命令语句 <类型 = 文本型>
    参数 排序类型 <类型 = 整数 注释 = "0 升序 1 降序" @默认值 = 0>
    {
        命令集.插入 (SQL类型.排序, 命令语句 + " " + 选择 (排序类型 == 0, "asc", "desc"))
        返回 (本对象)
    }

    方法 分组 <公开 类型 = 链式SQL类_ 注释 = "group" 折叠 @视窗.返回参考 = 真>
    参数 命令语句 <类型 = 文本型>
    {
        命令集.插入 (SQL类型.分组, 命令语句)
        返回 (本对象)
    }

    方法 关联 <公开 类型 = 链式SQL类_ 注释 = "join" 折叠 @视窗.返回参考 = 真>
    参数 命令语句 <类型 = 文本型>
    {
        命令集.插入 (SQL类型.关联, 命令语句)
        返回 (本对象)
    }

    方法 且 <公开 类型 = 链式SQL类_ 注释 = "and　精确条件不带like" 折叠 @视窗.返回参考 = 真>
    参数 命令语句 <类型 = 文本型>
    {
        命令集.插入 (SQL类型.且, 命令语句)
        返回 (本对象)
    }

    方法 且2 <公开 类型 = 链式SQL类_ 注释 = "and　精确条件带有like" 注释 = "例如" 折叠 折叠2 @视窗.返回参考 = 真>
    参数 条件前语句 <类型 = 文本型 注释 = "例如：1.模糊：\"品名\"　； 2.精确：\"品名=\"">
    参数 条件后语句 <类型 = 文本型 注释 = "例如：1.模糊：\"新品\"　； 2.精确：\"\'新品\'\"">
