    方法 取查询SQL <公开 类型 = 文本型 注释 = "select" 注释 = "例如："
            注释 = "链式：sql.表名 (\"商品表\").条件 (\"品名=\'新品\'\").且 (\"规格=\'12g\'\").取查询SQL () ;"
            注释 = "相当于SQL语句：select  from 商品表 where 品名=\'新品\' and 规格=\'12g\'"
            注释 = "链式：sql.表名 (\"商品表\").条件2 (\"品名\", \"新品\").或2 (\"品名\", \"新货\").取查询SQL ()"
            注释 = "相当于SQL语句：select  from 商品表 where 品名 like \'%新品%\' or 品名 like \'%新货%\'" 折叠 折叠2>
    参数 用完就释放 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 sql <类型 = 文本型>
        变量 tmp <类型 = 文本型>
        变量 exists <类型 = 文本型>
        tmp = 命令集.取值 (SQL类型.字段)
        sql = "select " + tmp + " from "
        tmp = 命令集.取值 (SQL类型.表名)
        sql = sql + tmp
        tmp = 命令集.取值 (SQL类型.条件)
        如果真 (tmp != "")
        {
            exists = 命令集.取值 (SQL类型.是否存在)
            sql = sql + 选择 (tmp == "", "", " where " + 选择 (exists == "", "", exists + "(") + 选择 (exists == "", tmp, tmp + ")"))
        }
        tmp = 命令集.取值 (SQL类型.为空)
        sql = sql + tmp
        tmp = 命令集.取值 (SQL类型.非空)
        sql = sql + tmp
        tmp = 命令集.取值 (SQL类型.且)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.或)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.介于)
        sql = sql + tmp
        tmp = 命令集.取值 (SQL类型.包含)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", "in ( " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.关联)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.关联条件)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", "on " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.分组)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " group by " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.合计函数)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " having " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.排序)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " order by " + tmp)
        }
        tmp = 命令集.取值 (SQL类型.限制返回数量)
        如果真 (tmp != "")
        {
            sql = sql + 选择 (tmp == "", "", " limit " + tmp)
        }
        如果真 (用完就释放 == 真)
        {
            命令集.清空 ()
        }
        子文本替换 (sql, "  ", " ")
        返回 (sql)
    }

