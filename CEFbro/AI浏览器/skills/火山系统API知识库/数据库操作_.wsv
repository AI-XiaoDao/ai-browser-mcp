类 SQL命令集 <公开 折叠 @文档 = "category = \"ADO数据库.链式SQL.附加类\"">
{
    变量 命令集 <类型 = SQL命令数组>

    方法 取值 <公开 类型 = 文本型 折叠>
    参数 键 <类型 = 文本型>
    {
        变量 临时成员 <类型 = SQL命令>
        变量 临时值数组 <类型 = 文本数组类 注释 = "存放返回的值列表">
        变量 命令语句 <类型 = 文本型>
        变量 处理后列数组 <类型 = 文本数组类>
        变量 处理后值数组 <类型 = 文本数组类>
        // 获取全部的值===
        计次循环 (命令集.取成员数 ())
        {
            临时成员 = 命令集.取成员 (取循环索引 ())
            如果真 (临时成员.键 == 键 && 临时成员.值 != "")
            {
                临时值数组.加入成员 (临时成员.值)
            }
        }
        // 重新组合一下,根据不同的类型,组合成不同的结果===
        计次循环 (临时值数组.取成员数 ())
        {
            // 处理字段===
            如果真 (键 == SQL类型.字段)  // 字段
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
                }
            }
            // 读取TABLE===
            如果真 (键 == SQL类型.表名)  // 读取TABLE
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
                }
            }
            // 读取WHERE===
            如果真 (键 == SQL类型.条件)  // 读取WHERE
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
            }
            // 读取NULL===
            如果真 (键 == SQL类型.为空)  // 读取NULL
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
            }
            // 读取NOT NULL===
            如果真 (键 == SQL类型.非空)  // 读取NOT NULL
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
            }
            // 读取AND===
            如果真 (键 == SQL类型.且)
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    如果 (取循环索引 () == 0)
                    {
                        加入文本 (命令语句, "and " + 临时值数组.取成员 (取循环索引 ()))
                    }
                    否则
                    {
                        加入文本 (命令语句, " and " + 临时值数组.取成员 (取循环索引 ()))
                    }
                }
                否则
                {
                    加入文本 (命令语句, " and " + 临时值数组.取成员 (取循环索引 ()))
                }
            }
            // 读取OR===
            如果真 (键 == SQL类型.或)
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    如果 (取循环索引 () == 0)
                    {
                        加入文本 (命令语句, "or " + 临时值数组.取成员 (取循环索引 ()))
                    }
                    否则
                    {
                        加入文本 (命令语句, " or " + 临时值数组.取成员 (取循环索引 ()))
                    }
                }
                否则
                {
                    加入文本 (命令语句, " or " + 临时值数组.取成员 (取循环索引 ()))
                }
            }
            // 处理读取BETWEEN===
            如果真 (键 == SQL类型.介于)
            {
                加入文本 (命令语句, " between " + 临时值数组.取成员 (取循环索引 ()))
            }
            // 读取IN===
            如果真 (键 == SQL类型.包含)  // 读取IN
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ")")
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + " , ")
                }
            }
            // 处理读取JOIN===
            如果真 (键 == SQL类型.关联)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
            }
            // 处理读取ON===
            如果真 (键 == SQL类型.关联条件)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
            }
            // 读取GROUP===
            如果真 (键 == SQL类型.分组)
            {
                命令语句 = 临时值数组.取成员 (取循环索引 ())
            }
            // 读取HAVING===
            如果真 (键 == SQL类型.合计函数)
            {
                命令语句 = 临时值数组.取成员 (取循环索引 ())
            }
            // 读取ORDER===
            如果真 (键 == SQL类型.排序)
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
                }
            }
            // 读取LIMIT===
            如果真 (键 == SQL类型.限制返回数量)
            {
                命令语句 = 临时值数组.取成员 (取循环索引 ())
            }
            // 读取INSTER条件===
            如果真 (键 == SQL类型.值)
            {
                变量 值数组 <类型 = 文本数组类>
                分割文本 (临时值数组.取成员 (取循环索引 ()), SQL类型.分割符, 值数组)
                如果真 (值数组.取成员数 () == 2)
                {
                    如果 (寻找文本 (值数组.取成员 (0), ",") != -1)  // 防止是aaa,bbb,ccc这样的格式
                    {
                        变量 临时 <类型 = 文本数组类>
                        分割文本 (值数组.取成员 (0), ",", 临时)
                        计次循环 (临时.取成员数 ())
                        {
                            处理后列数组.加入成员 (临时.取成员 (取循环索引 ()))
                        }
                    }
                    否则
                    {
                        处理后列数组.加入成员 (值数组.取成员 (0))
                    }
                    // ===
                    如果 (寻找文本 (值数组.取成员 (1), ",") != -1)  // 防止是aaa,bbb,ccc这样的格式
                    {
                        变量 临时 <类型 = 文本数组类>
                        分割文本 (值数组.取成员 (1), ",", 临时)
                        计次循环 (临时.取成员数 ())
                        {
                            处理后值数组.加入成员 (临时.取成员 (取循环索引 ()))
                        }
                    }
                    否则
                    {
                        处理后值数组.加入成员 (值数组.取成员 (1))
                    }
                }
            }
            // ===读取UPDATE和DELETE条件===
            如果真 (键 == SQL类型.数据)
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + " , ")
                }
            }
            // 读取UNION===
            如果真 (键 == SQL类型.合并)
            {
                如果 (取循环索引 () == 临时值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()))
                }
                否则
                {
                    加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + " union ")
                }
            }
            // 创建表处理===
            如果真 (键 == SQL类型.主键)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.主键2)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.主键3)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.文本字段1)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.文本字段2)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.文本字段3)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.文本字段4)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.整数字段1)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.整数字段2)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.整数字段3)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.单精度字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.双精度字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.货币字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.日期字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.日期时间字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
            如果真 (键 == SQL类型.逻辑字段)
            {
                加入文本 (命令语句, 临时值数组.取成员 (取循环索引 ()) + ",")
            }
        }
        // ===
        // 单独处理一下INSERT相关语句,不能在循环内部处理否则会出错===
        如果真 (键 == SQL类型.值)
        {
            // 处理后列数组===
            计次循环 (处理后列数组.取成员数 ())
            {
                如果 (取循环索引 () == 处理后列数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 处理后列数组.取成员 (取循环索引 ()) + ") values (")
                }
                否则
                {
                    加入文本 (命令语句, 处理后列数组.取成员 (取循环索引 ()) + " , ")
                }
            }
            // 处理后值数组===
            计次循环 (处理后值数组.取成员数 ())
            {
                如果 (取循环索引 () == 处理后值数组.取成员数 () - 1)
                {
                    加入文本 (命令语句, 处理后值数组.取成员 (取循环索引 ()) + ") ")
                }
                否则
                {
                    加入文本 (命令语句, 处理后值数组.取成员 (取循环索引 ()) + " , ")
                }
            }
        }
        返回 (命令语句)
    }

    方法 插入 <公开 折叠>
    参数 键 <类型 = 文本型>
    参数 值 <类型 = 文本型>
    {
        变量 新成员 <类型 = SQL命令>
        新成员.键 = 键
        新成员.值 = 值
        命令集.加入成员 (新成员)
    }

    方法 清空 <公开 折叠>
    {
        命令集.删除所有成员 ()
    }

    方法 取成员数 <公开 类型 = 变整数 折叠>
    {
        返回 (命令集.取成员数 ())
    }
}

