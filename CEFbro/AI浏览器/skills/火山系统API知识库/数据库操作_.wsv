类 ADO记录集辅助类_ <公开 注释 = "将记录集转成的json数据包进行解析" 折叠 @文档 = "category = \"ADO数据库.ADO转JSON\"">
{
    变量 解析对象 <类型 = JSON解析对象类_yy>
    变量 迭代对象 <类型 = JSON解析对象类迭代器_yy>
    变量 迭代数组 <类型 = JSON解析数组类迭代器_yy>
    变量 解析数组 <类型 = JSON解析数组类_yy>
    变量 字段组 <类型 = 文本数组类>
    变量 键名称 <类型 = 文本型>

    方法 记录集转JSON <公开 类型 = 文本型 注释 = "将记录集转成可读的文本数据，转换完成将自动关闭该记录集;" 注释 = "数据包可通过“ADO记录集辅助类_”来处理解析" 折叠 折叠2>
    参数 记录集 <类型 = 记录集类_>
    参数 格式类型 <类型 = 整数 注释 = "1、按列转　2、按行转" @默认值 = 1>
    参数 关闭记录集 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 字段列表 <类型 = 数据库字段集合类_>
        变量 当前字段 <类型 = 数据库字段类_>
        变量 JSON对象1 <类型 = JSON构造对象类_yy>
        变量 JSON对象2 <类型 = JSON构造对象类_yy>
        变量 JSON对象3 <类型 = "JSON构造对象类_yy [150]">
        变量 JSON数组1 <类型 = JSON构造数组类_yy>
        变量 JSON数组2 <类型 = "JSON构造数组类_yy [150]">
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        记录集.到首记录 ()
        字段列表 = 记录集.取字段列表 ()
        JSON对象2.初始化空对象 ()
        如果真 (字段列表.成员数 > 150)
        {
            调试输出 ("最多支持150列，当前已经超出。")
            返回 ("")
        }
        如果 (格式类型 == 1)
        {
            计次循环 (字段列表.成员数)
            {
                JSON对象3 [取循环索引 ()].初始化空数组 ()
                JSON数组2 [取循环索引 ()] = JSON对象3 [取循环索引 ()].置空数组 ()
            }
            循环 (, 记录集.记录数量, i)
            {
                循环 (, 字段列表.成员数, i2)
                {
                    JSON数组2 [i2].添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                }
                记录集.到下一行 ()
            }
            循环 (, 字段列表.成员数, i)
            {
                当前字段 = 字段列表.取成员 (i)
                JSON对象2.添加对象节点 (当前字段.名称, 假).置JSON文本 (JSON数组2 [i].到可读文本 ())
            }
        }
        否则
        {
            JSON对象1.初始化空数组 ()
            循环 (, 记录集.记录数量, i)
            {
                JSON数组1 = JSON对象1.置空数组 ()
                循环 (, 字段列表.成员数, i2)
                {
                    JSON数组1.添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                }
                JSON对象2.添加对象节点 (到文本 (i), 假).置JSON文本 (JSON数组1.到可读文本 ())
                记录集.到下一行 ()
            }
        }
        如果真 (关闭记录集 == 真)
        {
            记录集.关闭 ()
        }
        返回 (JSON对象2.到可读文本 ())
    }

    方法 记录集转JSON2 <公开 类型 = 字节集类 注释 = "将记录集转成字节集数据，转换完成将自动关闭该记录集;" 注释 = "数据包可通过“ADO记录集辅助类_”来处理解析" 折叠 折叠2>
    参数 记录集 <类型 = 记录集类_>
    参数 格式类型 <类型 = 整数 注释 = "1、按列转　2、按行转" @默认值 = 1>
    参数 关闭记录集 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 字段列表 <类型 = 数据库字段集合类_>
        变量 当前字段 <类型 = 数据库字段类_>
        变量 JSON对象1 <类型 = JSON构造对象类_yy>
        变量 JSON对象2 <类型 = JSON构造对象类_yy>
        变量 JSON对象3 <类型 = "JSON构造对象类_yy [150]">
        变量 JSON数组1 <类型 = JSON构造数组类_yy>
        变量 JSON数组2 <类型 = "JSON构造数组类_yy [150]">
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        记录集.到首记录 ()
        字段列表 = 记录集.取字段列表 ()
        如果 (字段列表.成员数 > 150)
        {
            调试输出 ("最多支持150列，当前已经超出。")
        }
        否则
        {
            JSON对象2.初始化空对象 ()
            如果 (格式类型 == 1)
            {
                计次循环 (字段列表.成员数)
                {
                    JSON对象3 [取循环索引 ()].初始化空数组 ()
                    JSON数组2 [取循环索引 ()] = JSON对象3 [取循环索引 ()].置空数组 ()
                }
                循环 (, 记录集.记录数量, i)
                {
                    循环 (, 字段列表.成员数, i2)
                    {
                        JSON数组2 [i2].添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                    }
                    记录集.到下一行 ()
                }
                循环 (, 字段列表.成员数, i)
                {
                    当前字段 = 字段列表.取成员 (i)
                    JSON对象2.添加对象节点 (当前字段.名称, 假).置JSON文本 (JSON数组2 [i].到可读文本 ())
                }
            }
            否则
            {
                JSON对象1.初始化空数组 ()
                循环 (, 记录集.记录数量, i)
                {
                    JSON数组1 = JSON对象1.置空数组 ()
                    循环 (, 字段列表.成员数, i2)
                    {
                        JSON数组1.添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                    }
                    JSON对象2.添加对象节点 (到文本 (i), 假).置JSON文本 (JSON数组1.到可读文本 ())
                    记录集.到下一行 ()
                }
            }
        }
        如果真 (关闭记录集 == 真)
        {
            记录集.关闭 ()
        }
        返回 (JSON对象2.到字节集 ())
    }

    方法 JSON数据包_取字段名 <公开 类型 = 整数 注释 = "解析按列转的json数据包，如果是提供按行转的数据包，则会解析出行序号" 返回值注释 = "返回字段数量" 折叠>
    参数 JSON数据包 <类型 = 文本型>
    参数 返回的字段组 <类型 = 文本数组类 注释 = "返回字段名称" @默认值 = 空对象>
    {
        字段组.重置为空对象 ()
        字段组.预分配尺寸 = 4096
        解析对象.创建自文本 (JSON数据包)
        迭代对象.初始化 (解析对象)
        判断循环 (迭代对象.迭代键名节点 (键名称, 空对象))
        {
            字段组.加入成员 (键名称)
        }
        返回的字段组 = 字段组
        返回 (字段组.取成员数 ())
    }

    方法 JSON数据包_取字段名2 <公开 类型 = 整数 注释 = "解析按列转的json数据包，如果是提供按行转的数据包，则会解析出行序号" 返回值注释 = "返回字段数量" 折叠>
    参数 JSON数据包 <类型 = 字节集类 注释 = "需要UTF8编码">
    参数 返回的字段组 <类型 = 文本数组类 注释 = "返回字段名称" @默认值 = 空对象>
    {
        字段组.重置为空对象 ()
        字段组.预分配尺寸 = 4096
        解析对象.创建自字节集 (JSON数据包)
        迭代对象.初始化 (解析对象)
        判断循环 (迭代对象.迭代键名节点 (键名称, 空对象))
        {
            字段组.加入成员 (键名称)
        }
        返回的字段组 = 字段组
        返回 (字段组.取成员数 ())
    }

    方法 JSON数据包_取列数据 <公开 类型 = 整数 注释 = "取记录集指定列数据;" 注释 = "调用本方法前，需要先执行“JSON数据包_取字段名”或“JSON数据包_取字段名2”" 返回值注释 = "返回该列的行数" 折叠 折叠2>
    参数 列号 <类型 = 整数 注释 = "0就代表第一列数据" @默认值 = 0>
    参数 返回的列数据组 <类型 = 文本数组类 注释 = "返回的JSON数组类，用 JSON数组.取文本值()，取得详细列数据" @默认值 = 空对象>
    {
        变量 列数据组 <类型 = 文本数组类>
        如果真 (列号 < 0)
        {
            列号 = 0
        }
        如果真 (列号 < 字段组.取成员数 ())
        {
            列数据组.预分配尺寸 = 4096
            迭代数组.初始化 (解析对象.取成员节点 (列号))
            判断循环 (迭代数组.迭代节点 (解析数组))
            {
                列数据组.加入成员 (解析数组.可读文本)
            }
            返回的列数据组 = 列数据组
        }
        返回 (列数据组.取成员数 ())
    }

    方法 JSON数据包_取行数据 <公开 类型 = 整数 注释 = "解析按列转的json数据;" 注释 = "取记录集指定行数据;" 注释 = "调用本方法前，需要先执行“JSON数据包_取字段名”或“JSON数据包_取字段名2”"
            返回值注释 = "返回该行的列数" 折叠 折叠2>
    参数 行号 <类型 = 整数 注释 = "0就代表第一行数据" @默认值 = 0>
    参数 返回的行数据组 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 行数据组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        如果真 (行号 < 0)
        {
            行号 = 0
        }
        行数据组.预分配尺寸 = 4096
        循环 (, 字段组.取成员数 (), i)
        {
            迭代数组.初始化 (解析对象.取成员节点 (i), 行号, 1)
            迭代数组.迭代节点 (解析数组)
            行数据组.加入成员 (解析数组.可读文本)
        }
        返回的行数据组 = 行数据组
        返回 (字段组.取成员数 ())
    }

