    方法 添加空记录 <公开 类型 = 逻辑型 注释 = "如果当前记录集可写,该方法将添加一个新的空记录至当前记录集." 返回值注释 = "添加成功返回真,否则返回假." 折叠>
    {
        返回 (无参数及返回值方法 ("AddNew"))
    }

    方法 添加新记录 <公开 类型 = 逻辑型 注释 = "如果当前记录集可写,该方法将添加新的记录至当前记录集." 返回值注释 = "添加成功返回真,否则返回假." 折叠>
    参数 字段列表 <类型 = COM变体型数组类 注释 = "提供本次置入新记录的字段名称列表(或者可提供字段的整数索引列表),请置入字段名称的文本型数组或字段索引的整数数组."
            注释 = "注意:如果该参数提供空对象,将会按所提供的值列表成员依次对应字段索引置入其记录值." @默认值 = 空对象>
    参数 值列表 <类型 = COM变体型数组类 注释 = "提供本次置入新记录的值列表,对应\"字段列表\"参数.">
    {
        如果 (是否为空对象 (字段列表) && 是否为空对象 (值列表))
        {
            返回 (无参数及返回值方法 ("AddNew"))
        }
        否则 (是否为空对象 (值列表))  // 值列表为空,无意义.
        {
            返回 (假)
        }
        否则
        {
            变量 局_字段列表 <类型 = COM变体型>
            变量 局_值列表 <类型 = COM变体型>
            变量 字段数量 <类型 = 整数>
            如果 (是否为空对象 (字段列表))
            {
                字段数量 = 值列表.取成员数 ()
                @ INT* fieldList = new INT[@<字段数量>];
                @ for (INT i = 0; i < @<字段数量>; i++)
                @     fieldList[i] = i;
                @ @<局_字段列表>.CreateArray_INT(fieldList, @<字段数量>, 0, -1);
                @ delete[] fieldList;
            }
            否则
            {
                字段数量 = 字段列表.取成员数 ()
                @ CVolComVariant* fieldList = new CVolComVariant[@<字段数量>];
                @ for (INT i = 0; i < @<字段数量>; i++)
                @     fieldList[i] = (CVolComVariant&)@<字段列表>.GetAt (i);
                @ @<局_字段列表>.CreateArray_Variant(fieldList, @<字段数量>, 0, -1);
                @ delete[] fieldList;
            }
            变量 值数量 <类型 = 整数>
            值数量 = 值列表.取成员数 ()
            @ CVolComVariant* valueList = new CVolComVariant[@<值数量>];
            @ for (INT i = 0; i < @<值数量>; i++)
            @     valueList[i] = (CVolComVariant&)@<值列表>.GetAt (i);
            @ @<局_值列表>.CreateArray_Variant(valueList, @<值数量>, 0, -1);
            @ delete[] valueList;
            返回 (无返回值方法 ("AddNew", 局_字段列表, 局_值列表))
        }
    }

    方法 取消执行 <公开 类型 = 逻辑型 注释 = "取消执行挂起的异步方法调用." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
