类 数据库字段类_ <公开 基础类 = COM对象类 注释 = "表示表中的一个字段(列)." 折叠 @文档 = "category = \"ADO数据库.ADO数据库1.附加类\"">
{
    方法 取属性信息 <公开 类型 = 数据库属性集合类_ 注释 = "获取当前字段的属性集合." 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<数据库属性集合类_>(Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Properties"), 0, _T ("")));
    }

    方法 名称 <公开 属性读 类型 = 文本型 注释 = "获取该字段的名称." 折叠>
    {
        返回 (读无参数属性 ("Name", 文本型))
    }

    方法 名称 <公开 属性写 注释 = "设置该字段的名称." 折叠>
    参数 值 <类型 = 文本型>
    {
        写属性 ("Name", 值)
    }

    方法 实际尺寸 <公开 属性读 类型 = 长整数 注释 = "获取字段值的实际所占用的长度(字节单位)." 折叠>
    {
        返回 (读无参数属性 ("ActualSize", 长整数))
    }

    方法 定义尺寸 <公开 属性读 类型 = 长整数 注释 = "获取字段值定义的尺寸(字节单位)." 折叠>
    {
        返回 (读无参数属性 ("DefinedSize", 长整数))
    }

    方法 小数位数 <公开 属性读 类型 = 整数 注释 = "获取字段中数值的小数位数." 折叠>
    {
        返回 (读无参数属性 ("NumericScale", 整数))
    }

    方法 小数位数 <公开 属性写 注释 = "数值字段中数值的小数位数." 折叠>
    参数 值 <类型 = 整数>
    {
        写属性 ("NumericScale", 值)
    }

    方法 原始值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段在有任何更改之前的原始值." 折叠>
    {
        返回 (读无参数属性 ("OriginalValue", COM变体型))
    }

    方法 最大位数 <公开 属性读 类型 = 整数 注释 = "获取字段中值的最大位数(精度)." 折叠>
    {
        返回 (读无参数属性 ("Precision", 整数))
    }

    方法 最大位数 <公开 属性写 注释 = "数值字段中值的最大位数(精度)." 折叠>
    参数 值 <类型 = 整数>
    {
        写属性 ("Precision", 值)
    }

    方法 状态 <公开 属性读 类型 = 长整数 注释 = "获取该字段当前状态." 返回值注释 = "返回值请参考\"数据库字段状态类型_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("Status", 长整数))
    }

    方法 类型 <公开 属性读 类型 = 整数 注释 = "获取该字段定义的数据类型." 返回值注释 = "返回值请参考\"数据库字段数据类型_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("Type", 整数))
    }

    方法 当前值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段当前的值." 折叠>
    {
        返回 (读无参数属性 ("UnderlyingValue", COM变体型))
    }

    方法 值 <公开 属性读 类型 = COM变体型 注释 = "获取该字段的值." 折叠>
    {
        返回 (读无参数属性 ("Value", COM变体型))
    }

    方法 值 <公开 属性写 注释 = "设置该字段的值." 返回值注释 = "返回值请参考\"数据库字段数据类型_\"所提供的常量." 折叠>
    参数 欲置入值 <类型 = COM变体型>
    {
        写属性 ("Value", 欲置入值)
    }
}

类 数据库字段集合类_ <公开 基础类 = 数据库集合类_ 注释 = "本类表示一个数据集中所有的字段数据." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.附加类\""
        @模板实现类 = "数据库字段类_,数据库字段集合类_">
{
    方法 加入 <公开 类型 = 逻辑型 注释 = "将指定字段追加至该集合的尾部." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 名称 <类型 = 文本型 注释 = "所欲加入新字段的名称,不能与集合中的任何其他字段同名.">
    参数 字段对象 <类型 = 数据库字段类_ 注释 = "提供所欲加入该集合的字段对象.">
    参数 数据类型 <类型 = 整数 注释 = "所欲加入新字段的数据类型,请参考\"数据库字段数据类型_\"所提供的常量." @默认值 = 数据库字段数据类型_.空值>
    参数 定义尺寸 <类型 = 长整数 注释 = "表示所加入新字段定义的大小(字节)." @默认值 = 0>
    参数 字段属性 <类型 = 长整数 注释 = "提供该字段的属性选项,请参考\"数据库字段属性类型_\"所提供的常量,支持其单个或多个组合值." @默认值 = 数据库字段属性类型_.无>
    {
        返回 (无返回值方法 ("Append", 名称, 数据类型, 定义尺寸, 字段属性, 字段对象))
    }

    方法 删除索引 <公开 类型 = 逻辑型 注释 = "删除指定索引处的字段对象." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 索引 <类型 = 整数 注释 = "所欲删除字段在本集合内所处的索引位置.">
    {
        返回 (无返回值方法 ("Delete", 索引))
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "以字段名称删除指定字段对象." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 名称 <类型 = 文本型 注释 = "所欲删除字段的名称.">
    {
        返回 (无返回值方法 ("Delete", 名称))
    }

    方法 取消更新 <公开 类型 = 逻辑型 注释 = "在调用\"更新\"方法之前,取消对当前字段对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (无参数及返回值方法 ("CancelUpdate"))
    }

    方法 重新同步 <公开 类型 = 逻辑型 注释 = "通过重新执行对象所基于的查询来更新字段集合对象中的字段数据." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 是否覆盖 <类型 = 逻辑型 注释 = "是否覆盖原有数据,挂起的更新动作将被直接取消,提供假将不会覆盖数据,也不会取消挂起的更新动作." @默认值 = 真>
    {
        如果 (是否覆盖)
        {
            返回 (无返回值方法 ("Resync", 3, 2))
        }
        否则
        {
            返回 (无返回值方法 ("Resync", 3, 1))
        }
    }

    方法 更新 <公开 类型 = 逻辑型 注释 = "保存对字段集合对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 字段 <类型 = COM变体型 注释 = "指定所欲修改的一个或多个字段名称,如果有多个字段请置入字段数组,可以为名称也可以是字段索引." @默认值 = 空对象>
    参数 值 <类型 = COM变体型 注释 = "指定字段所对应的值,如果有多个字段,必须提供对等数量的值,否则将无法正常执行更新." @默认值 = 空对象>
    {
        返回 (无返回值方法 ("Update", 字段, 值))
    }
}

类 记录集编辑状态_ <公开 注释 = "指定记录的编辑状态." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.常量类\"" @禁止创建对象 = 真>
{
    常量 无 <公开 类型 = 整数 值 = 0 注释 = "指示没有正在进行的编辑操作">
    常量 正在编辑 <公开 类型 = 整数 值 = 1 注释 = "指示当前记录中的数据已修改但尚未保存,可能处于编辑状态.">
    常量 已加入 <公开 类型 = 整数 值 = 2 注释 = "已提交保存到缓冲区,但尚未保存至数据库中.">
    常量 已删除 <公开 类型 = 整数 值 = 4 注释 = "指示当前记录已被删除">
}

类 数据库字段数据类型_ <公开 注释 = "指定字段,参数或属性的数据类型." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.常量类\"" @禁止创建对象 = 真>
{
    常量 数组型 <公开 类型 = 整数 值 = 0x2000 注释 = "指示一个数据类型的数组型,该常量需要与本类其他常量值组合使用.">
    常量 "//---//"
    常量 空值 <公开 类型 = 整数 值 = 0 注释 = "DBTYPE_EMPTY,空值.">
    常量 小整数值 <公开 类型 = 整数 值 = 2 注释 = "(DBTYPE_I2)两个字节的有符号整数.">
    常量 整数值 <公开 类型 = 整数 值 = 3 注释 = "(DBTYPE_I4)4字节有符号整数.">
    常量 单精度浮点值 <公开 类型 = 整数 值 = 4 注释 = "(DBTYPE_R4)单精度浮点值.">
    常量 双精度浮点值 <公开 类型 = 整数 值 = 5 注释 = "(DBTYPE_R8)双精度浮点值.">
    常量 货币值 <公开 类型 = 整数 值 = 6 注释 = "(DBTYPE_CY)小数点右侧具有四位数的固定点数字的货币值.">
    常量 小数日期值 <公开 类型 = 整数 值 = 7 注释 = "(DBTYPE_DATE)日期型.">
    常量 文本值 <公开 类型 = 整数 值 = 8 注释 = "(DBTYPE_BSTR)以null结尾的字符串值(Unicode).">
    常量 错误值 <公开 类型 = 整数 值 = 10 注释 = "(DBTYPE_ERROR)32位的错误代码值.">
    常量 逻辑值 <公开 类型 = 整数 值 = 11 注释 = "(DBTYPE_BOOL)布尔值.">
    常量 精确数值 <公开 类型 = 整数 值 = 14 注释 = "(DBTYPE_DECIMAL)具有固定精度和小数位数的精确数值.">
    常量 单字节整数值 <公开 类型 = 整数 值 = 16 注释 = "(DBTYPE_I1)单字节有符号整数.">
    常量 无符单字节整数值 <公开 类型 = 整数 值 = 17 注释 = "(DBTYPE_UI1)单字节无符号整数.">
    常量 无符小整数值 <公开 类型 = 整数 值 = 18 注释 = "(DBTYPE_UI2)两字节无符号整数.">
    常量 无符整数值 <公开 类型 = 整数 值 = 19 注释 = "(DBTYPE_UI4)四字节无符号整数.">
    常量 大整数值 <公开 类型 = 整数 值 = 20 注释 = "(DBTYPE_I8)的8字节有符号整数.">
    常量 无符大整数值 <公开 类型 = 整数 值 = 21 注释 = "(DBTYPE_UI8)8字节无符号整数.">
    常量 文件时间值 <公开 类型 = 整数 值 = 64 注释 = "(DBTYPE_FILETIME)64位表示文件时间的值.">
    常量 唯一标识符值 <公开 类型 = 整数 值 = 72 注释 = "(DBTYPE_GUID)全局唯一标识符值.">
    常量 二进制值 <公开 类型 = 整数 值 = 128 注释 = "(DBTYPE_BYTES)二进制值.">
    常量 字符串值 <公开 类型 = 整数 值 = 129 注释 = "(DBTYPE_STR)字符串值.">
    常量 文本值_WChar <公开 类型 = 整数 值 = 130 注释 = "(DBTYPE_WSTR)指示一个以null结尾的字符串(Unicode).">
    常量 精确数值_NUMERIC <公开 类型 = 整数 值 = 131 注释 = "(DBTYPE_NUMERIC)具有固定精度和小数位数的精确数值.">
    常量 用户变量值 <公开 类型 = 整数 值 = 132 注释 = "(DBTYPE_UDT)用户定义变量.">
    常量 日期值 <公开 类型 = 整数 值 = 133 注释 = "(DBTYPE_DBDATE)以yyyymmdd表示的日期值.">
    常量 时间值 <公开 类型 = 整数 值 = 134 注释 = "(DBTYPE_DBTIME)以hhmmss表示的时间值.">
    常量 时间戳值 <公开 类型 = 整数 值 = 135 注释 = "(DBTYPE_DBTIMESTAMP)日期/时间戳值.">
    常量 子集值 <公开 类型 = 整数 值 = 136 注释 = "(DBTYPE_HCHAPTER)用于标识子行集中的行的4字节的子集值.">
    常量 可变类型值 <公开 类型 = 整数 值 = 138 注释 = "可自动变化类型的值.">
    常量 数字值 <公开 类型 = 整数 值 = 139 注释 = "数字值">
    常量 字符串值_VarChar <公开 类型 = 整数 值 = 200 注释 = "字符串值">
    常量 大字符串值 <公开 类型 = 整数 值 = 201 注释 = "长字符串值.">
    常量 文本值_VarWChar <公开 类型 = 整数 值 = 202 注释 = "指示一个以null结尾的字符串(Unicode).">
    常量 大文本值 <公开 类型 = 整数 值 = 203 注释 = "以null结尾的长字符串值(Unicode).">
    常量 二进制值_VarBinary <公开 类型 = 整数 值 = 204 注释 = "二进制值">
    常量 大二进制值 <公开 类型 = 整数 值 = 205 注释 = "长二进制值.">
}

类 数据库字段状态类型_ <公开 注释 = "表示一个字段的状态." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.常量类\"" @禁止创建对象 = 真>
{
    常量 已存在 <公开 类型 = 长整数 值 = 26 注释 = "表示指定字段已存在.">
    常量 状态无效 <公开 类型 = 长整数 值 = 12 注释 = "表示从ADO发送到OLEDB提供程序的状态值无效.">
    常量 无法完成 <公开 类型 = 长整数 值 = 20 注释 = "由源指定的URL服务器无法完成操作.">
    常量 源无法删除 <公开 类型 = 长整数 值 = 23 注释 = "在移动操作过程中,树或子树已移动到新位置,但无法删除该源.">
    常量 无法检索字段 <公开 类型 = 长整数 值 = 2 注释 = "无法检索或存储字段,不会丢失数据.">
    常量 无法创建 <公开 类型 = 长整数 值 = 7 注释 = "未能添加字段,因为提供程序超出了允许的字段数.">
    常量 数据溢出 <公开 类型 = 长整数 值 = 6 注释 = "从提供程序返回的数据溢出了字段的数据类型.">
    常量 默认值 <公开 类型 = 长整数 值 = 13 注释 = "在设置数据时使用了字段的默认值.">
    常量 不存在 <公开 类型 = 长整数 值 = 16 注释 = "表示指定字段不存在.">
    常量 忽略置值 <公开 类型 = 长整数 值 = 15 注释 = "在设置数据时跳过了该字段.">
    常量 派生实体 <公开 类型 = 长整数 值 = 10 注释 = "无法修改字段,因为它是计算实体或派生实体.">
    常量 无效字符 <公开 类型 = 长整数 值 = 17 注释 = "数据源URL包含无效字符.">
    常量 空值 <公开 类型 = 长整数 值 = 3 注释 = "提供程序返回VT_NULL类型的变量值.">
    常量 成功 <公开 类型 = 长整数 值 = 0 注释 = "已成功添加或删除字段.">
    常量 内存不足 <公开 类型 = 长整数 值 = 22 注释 = "提供程序无法获得足够的存储空间来完成移动或复制操作.">
    常量 即将修改 <公开 类型 = 长整数 值 = 0x40000 注释 = "字段的值或者数据类型在调用更新后会被修改.">
    常量 即将删除 <公开 类型 = 长整数 值 = 0x20000 注释 = "字段在调用更新后会被删除.">
    常量 即将插入 <公开 类型 = 长整数 值 = 0x10000 注释 = "在字段集合中新增的字段,调用更新后会被加入.">
    常量 未知预操作 <公开 类型 = 长整数 值 = 0x80000 注释 = "无法确定字段即将会有何状态.">
    常量 未知操作删除 <公开 类型 = 长整数 值 = 0x100000 注释 = "无法确定何种操作导致字段即将被删除,更新后字段会被删除.">
    常量 权限不足 <公开 类型 = 长整数 值 = 9 注释 = "权限不足无法修改字段,可能当前字段权限为只读.">
    常量 只读 <公开 类型 = 长整数 值 = 24 注释 = "表示字段被定义为只读状态.">
    常量 资源已存在 <公开 类型 = 长整数 值 = 19 注释 = "提供程序无法执行该操作,因为目标URL中已存在一个对象,且该对象不能被覆盖.">
    常量 资源已锁定 <公开 类型 = 长整数 值 = 18 注释 = "提供程序无法执行该操作,因为数据源被一个或多个其他应用程序或进程锁定.">
    常量 超出记录范围 <公开 类型 = 长整数 值 = 25 注释 = "指示源或目标URL超出了当前记录的范围.">
    常量 违反架构约束 <公开 类型 = 长整数 值 = 11 注释 = "提供的值违反了字段的数据源架构约束.">
    常量 签名不匹配 <公开 类型 = 长整数 值 = 5 注释 = "提供程序返回的数据值已签名,但ADO字段值的数据类型未签名.">
    常量 数据被截断 <公开 类型 = 长整数 值 = 4 注释 = "在从数据源读取时,长度可变的数据被截断.">
    常量 值不可用 <公开 类型 = 长整数 值 = 8 注释 = "在从数据源读取时,提供程序无法确定该值.">
    常量 找不到储存卷 <公开 类型 = 长整数 值 = 21 注释 = "提供程序找不到URL所指示的存储卷.">
}

类 记录操作状态类型_ <公开 注释 = "指定有关批更新和其他批量操作的记录的状态." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.常量类\"" @禁止创建对象 = 真>
{
    常量 已取消 <公开 类型 = 整数 值 = 0x100 注释 = "指示未修改记录,因为该操作已取消.">
    常量 无法释放 <公开 类型 = 整数 值 = 0x400 注释 = "指示未修改新记录,因为现有记录已锁定.">
    常量 并发冲突 <公开 类型 = 整数 值 = 0x800 注释 = "指示由于使用乐观并发而未修改记录.">
    常量 数据源已删除 <公开 类型 = 整数 值 = 0x40000 注释 = "指示已从数据源中删除记录.">
    常量 已删除 <公开 类型 = 整数 值 = 0x4 注释 = "指示记录已被删除.">
    常量 非完整数据 <公开 类型 = 整数 值 = 0x1000 注释 = "指示由于违法了数据完整约束而未修改记录.">
    常量 书签无效 <公开 类型 = 整数 值 = 0x10 注释 = "指示未修改记录,因为其书签无效.">
    常量 挂起太多 <公开 类型 = 整数 值 = 0x2000 注释 = "指示未修改记录,因为挂起的更改操作太多.">
    常量 已修改 <公开 类型 = 整数 值 = 0x2 注释 = "已修改记录.">
    常量 影响多个 <公开 类型 = 整数 值 = 0x40 注释 = "指示未修改记录,因为它会影响多个记录.">
    常量 新记录 <公开 类型 = 整数 值 = 0x1 注释 = "指示记录是新记录.">
    常量 储存对象冲突 <公开 类型 = 整数 值 = 0x4000 注释 = "指示由于与打开的存储对象冲突而未修改记录.">
    常量 成功 <公开 类型 = 整数 值 = 0 注释 = "指示已成功更新记录.">
    常量 内存不足 <公开 类型 = 整数 值 = 0x8000 注释 = "由于计算机内存不足而未修改记录.">
