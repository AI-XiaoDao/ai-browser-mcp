    参数 模式 <类型 = 整数>
    {
        连接对象.写属性 ("Mode", 模式)
    }

    方法 权限模式 <公开 属性读 类型 = 整数 注释 = "获取数据库中数据的可用权限." 返回值注释 = "请参考\"数据库权限模式_\"所提供的常量." 折叠>
    {
        返回 (连接对象.读无参数属性 ("Mode", 整数))
    }

    方法 取错误信息 <公开 类型 = 数据库错误集合类_ 注释 = "获取当前的错误集合." 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<数据库错误集合类_>(@<连接对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Errors"), 0, _T ("")));
    }

    方法 取属性信息 <公开 类型 = 数据库属性集合类_ 注释 = "获取当前的属性集合." 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<数据库属性集合类_>(@<连接对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Properties"), 0, _T ("")));
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "关闭当前已连接的数据库,并释放所关联的任何系统资源." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (连接对象.无参数及返回值方法 ("Close"))
    }

    方法 取消执行 <公开 类型 = 逻辑型 注释 = "取消执行挂起的异步方法调用." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (连接对象.无参数及返回值方法 ("Cancel"))
    }

    方法 开始事务 <公开 类型 = 整数 注释 = "开始一个新的事务." 返回值注释 = "返回事务的嵌套级别." 折叠>
    {
        返回 (连接对象.无参数方法 ("BeginTrans", 整数))
    }

    方法 保存事务 <公开 类型 = 逻辑型 注释 = "保存所有更改并结束当前事务." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (连接对象.无参数及返回值方法 ("CommitTrans"))
    }

    方法 回滚事务 <公开 类型 = 逻辑型 注释 = "取消在当前事务中所做的任何更改并结束事务." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (连接对象.无参数及返回值方法 ("RollbackTrans"))
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 注释 = "Excel表名字段之类需要这样表示：[表1$]" 返回值注释 = "如是执行查询，并不会返回真假，需要改用\"执行SQL语句2\"" 折叠 @禁止流程检查 = 真>
    参数 SQL语句 <类型 = 文本型 注释 = "提供所欲执行的SQL语句,例如:SELECT * FROM VOLDP">
    参数 选项 <类型 = 整数 注释 = "提供本次执行的可选项,提供\"数据库命令类型__\"以及\"数据库命令执行选项__\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 受影响行数 <类型 = 整数类 注释 = "提供一个整数变量以获取本次命令执行后,影响到表中的记录数量，如是执行查询操作是不会返回受影响行数" @默认值 = 空对象>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    {
        变量 影响数 <类型 = 整数类>
        变量 结果 <类型 = 逻辑型>
        变量 临时记录集 <类型 = 记录集类_>
        临时记录集 = 执行SQL语句2 (SQL语句, 选项, 影响数)
        受影响行数 = 影响数
        如果真 (影响数.值 > 0 || 临时记录集.是否成功 () == 真)
        {
            结果 = 真
        }
        错误描述 = 语句错误描述信息
        返回 (结果)
    }

    方法 执行SQL语句2 <公开 类型 = 记录集类_ 注释 = "Excel表名字段之类需要这样表示：[表1$]" 折叠 @禁止流程检查 = 真>
    参数 SQL语句 <类型 = 文本型 注释 = "提供所欲执行的SQL语句,例如:SELECT * FROM VOLDP">
    参数 选项 <类型 = 整数 注释 = "提供本次执行的可选项,提供\"数据库命令类型__\"以及\"数据库命令执行选项__\"所定义常量的单个或多个组合值." @默认值 = -1>
    参数 受影响行数 <类型 = 整数类 注释 = "提供一个整数变量以获取本次命令执行后,影响到表中的记录数量，如是执行查询操作是不会返回受影响行数" @默认值 = 空对象>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    {
        变量 临时记录 <类型 = COM对象类>
        临时记录 = 连接对象.方法 ("Execute", COM对象类, SQL语句, 受影响行数, 选项)
        错误描述 = 语句错误描述信息
        @ return @dt<记录集类_> (@<临时记录>);
    }

    方法 取语句错误描述 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (语句错误描述信息)
    }

    方法 取连接错误描述 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (连接错误描述)
    }

    方法 连接Excel <公开 类型 = 逻辑型 注释 = "驱动下载：https://xf3v74qido.feishu.cn/file/BGkebUI9vodkGVxt0AocHlwVnvd" 折叠>
    参数 文件路径 <类型 = 文本型 @默认值 = "">
    参数 是否新版 <类型 = 逻辑型 注释 = "本参数指定Access版本，为假则使用2003以下连接方式，为真则使用2007版本连接方式" @默认值 = 真>
    参数 是否提示驱动 <类型 = 逻辑型 @默认值 = 真>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        变量 版本内容 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果真 (是否提示驱动 == 真)
        {
            如果 (取驱动信息Access_ (版本内容) == 假)
            {
                错误描述 = "还未安装Access Database Engine驱动"
                连接错误描述 = 错误描述
                调试输出 (错误描述)
            }
            否则
            {
                调试输出 (版本内容)
            }
            如果真 (文件是否存在 (文件路径) == 假)
            {
                错误描述 = "数据库文件不存在"
                连接错误描述 = 错误描述
                调试输出 (错误描述)
                返回 (假)
            }
        }
        如果 (是否新版)
        {
            连接文本内容2 = "Provider=Microsoft.ACE.OLEDB.12.0; Data Source=" + 文件路径 + "; Extended Properties=Excel 12.0;"
            结果 = 连接 (连接文本内容2)
            错误描述 = 连接错误描述
            如果真 (文本是否为空 (错误描述) == 假)
            {
                调试输出 (错误描述)
            }
            返回 (结果)
        }
        否则
        {
            连接文本内容2 = "Provider=Microsoft.Jet.OLEDB.4.0; Data Source=" + 文件路径 + "; Extended Properties=Excel 8.0;"
            结果 = 连接 (连接文本内容2)
            错误描述 = 连接错误描述
            如果真 (文本是否为空 (错误描述) == 假)
            {
                调试输出 (错误描述)
            }
            返回 (结果)
        }
    }

    方法 连接Access <公开 类型 = 逻辑型 注释 = "驱动下载：https://xf3v74qido.feishu.cn/file/BGkebUI9vodkGVxt0AocHlwVnvd" 返回值注释 = "执行成功返回真,否则返回假."
            折叠>
    参数 文件路径 <类型 = 文本型 注释 = "提供数据库文件完整路径.">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的用户密码." @默认值 = "">
    参数 是否新版 <类型 = 逻辑型 注释 = "本参数指定Access版本,为假则使用2003以下连接方式,为真则使用2007版本连接方式." @默认值 = 真>
    参数 是否提示驱动 <类型 = 逻辑型 @默认值 = 真>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        变量 版本内容 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果 (取驱动信息Access_ (版本内容) == 假)
        {
            错误描述 = "还未安装Access Database Engine驱动"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
        }
        否则
        {
            如果真 (是否提示驱动 == 真)
            {
                调试输出 (版本内容)
            }
        }
        如果真 (文件是否存在 (文件路径) == 假)
        {
            错误描述 = "数据库文件不存在"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
        如果 (是否新版)
        {
            连接文本内容2 = "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码
            结果 = 连接 (连接文本内容2)
        }
        否则
        {
            连接文本内容2 = "Provider=Microsoft.Jet.OLEDB.4.0; Data Source=" + 文件路径 + ";Jet OLEDB:Database Password=" + 密码
            结果 = 连接 (连接文本内容2)
        }
        错误描述 = 连接错误描述
        如果真 (文本是否为空 (错误描述) == 假)
        {
            调试输出 (错误描述)
        }
        返回 (结果)
    }

    方法 连接Sqlite <公开 类型 = 逻辑型 注释 = "驱动下载：https://xf3v74qido.feishu.cn/file/DvhWbSp1Coelqdxzi8xctysPndf" 折叠>
    参数 文件路径 <类型 = 文本型 注释 = "提供数据库文件完整路径">
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        变量 Sqlite <类型 = 文本型 值 = "Provider=MSDASQL.1;Extended Properties=Driver={SQLite3 ODBC Driver};Password=\'\';Database=文件路径;"
                编辑时信息 = "0, 17553E, 0, 0">
        变量 结果 <类型 = 逻辑型>
        如果真 (文件是否存在 (文件路径) == 假)
        {
            错误描述 = "数据库文件不存在"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
        子文本替换 (Sqlite, "文件路径", 文件路径)
        结果 = 连接 (Sqlite)
        错误描述 = 连接错误描述
        如果真 (文本是否为空 (错误描述) == 假)
        {
            调试输出 (错误描述)
        }
        返回 (结果)
    }

    方法 连接Mysql <公开 类型 = 逻辑型 注释 = "8.0驱动下载：https://xf3v74qido.feishu.cn/file/Aq1Obnk9QoGEWMx8HwBc7OhbnVc"
            注释 = "3.5驱动下载：https://xf3v74qido.feishu.cn/file/VRY7blTQWoY24SxqgjEcepwfnPf" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址." @默认值 = "localhost">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称." @默认值 = "">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名." @默认值 = "root">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码." @默认值 = "">
    参数 端口号 <类型 = 整数 注释 = "通过该数据库的连接端口." @默认值 = 3306>
    参数 驱动版本 <类型 = 文本型 注释 = "例如：3.51、5.1、5.2、5.3、8.0　，默认：3.51" @默认值 = "8.0">
    参数 版本8类型 <类型 = 整数 注释 = "如果驱动版本是8系列的，可以选择：1、ANSI Driver　2、Unicode Driver" @默认值 = 2>
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    参数 是否提示驱动 <类型 = 逻辑型 @默认值 = 真>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        变量 版本内容 <类型 = 文本型>
        变量 驱动名 <类型 = 文本型>
        变量 结果 <类型 = 逻辑型>
        如果 (取驱动信息ODBC_ (版本内容) == 假)
        {
            错误描述 = "还未安装ODBC驱动"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
        否则
        {
            如果真 (是否提示驱动 == 真)
            {
                调试输出 (版本内容)
            }
            驱动名 = 取指定驱动名_ (驱动版本, 版本8类型)
            如果真 (驱动名 == "")
            {
                错误描述 = "未找到该版本的驱动"
                连接错误描述 = 错误描述
                调试输出 (错误描述)
                返回 (假)
            }
        }
        连接文本内容2 = "MYSQL;Database=" + 数据库名 + ";Password=" + 密码 + ";Port=" + 到文本 (端口号) + ";Server=" + 地址 + ";User=" + 用户名 + ";"
        结果 = 连接 ("Provider=MSDASQL; DRIVER=" + 驱动名 + "; SERVER=" + 地址 + "; PORT=" + 到文本 (端口号) + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接)
        错误描述 = 连接错误描述
        如果真 (文本是否为空 (错误描述) == 假)
        {
            调试输出 (错误描述)
        }
        返回 (结果)
    }

