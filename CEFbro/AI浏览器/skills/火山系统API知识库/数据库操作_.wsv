    方法 取ODBC数据源_ <公开 静态 折叠>
    参数 返回64位信息 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回32位信息 <类型 = 文本数组类 @默认值 = 空对象>
    {
        mysql组64.删除所有成员 ()
        mysql组32.删除所有成员 ()
        Pg组64.删除所有成员 ()
        Pg组32.删除所有成员 ()
        Sqlite组64.删除所有成员 ()
        Sqlite组32.删除所有成员 ()
        注册表枚举键名_ (3, "SOFTWARE\\ODBC\\ODBCINST.INI", 返回64位信息, 真)
        注册表枚举键名_ (3, "SOFTWARE\\ODBC\\ODBCINST.INI", 返回32位信息, 假)
        返回64位信息.枚举循环 ()
        {
            如果 (取文本左边 (返回64位信息.取枚举值 (), 10) == "MySQL ODBC")
            {
                mysql组64.加入成员 (返回64位信息.取枚举值 ())
            }
            否则 (取文本左边 (返回64位信息.取枚举值 (), 10) == "PostgreSQL")
            {
                Pg组64.加入成员 (返回64位信息.取枚举值 ())
            }
            否则 (取文本左边 (返回64位信息.取枚举值 (), 6) == "SQLite")
            {
                Sqlite组64.加入成员 (返回64位信息.取枚举值 ())
            }
        }
        返回32位信息.枚举循环 ()
        {
            如果 (取文本左边 (返回32位信息.取枚举值 (), 10) == "MySQL ODBC")
            {
                mysql组32.加入成员 (返回32位信息.取枚举值 ())
            }
            否则 (取文本左边 (返回32位信息.取枚举值 (), 10) == "PostgreSQL")
            {
                Pg组32.加入成员 (返回32位信息.取枚举值 ())
            }
            否则 (取文本左边 (返回32位信息.取枚举值 (), 6) == "SQLite")
            {
                Sqlite组32.加入成员 (返回32位信息.取枚举值 ())
            }
        }
    }

    方法 取指定驱动名_ <公开 静态 类型 = 文本型 注释 = "获取MySql ODBC驱动名" 返回值注释 = "未找到将返回空" 折叠>
    参数 版本号 <类型 = 文本型 注释 = "例如：3.51、5.1、5.2、5.3、8.0　" @默认值 = "3.51">
    参数 版本8类型 <类型 = 整数 注释 = "1、ANSI Driver　2、Unicode Driver" @默认值 = 1>
    {
        变量 名称 <类型 = 文本型>
        如果真 (mysql组64.取成员数 () == 0 && mysql组32.取成员数 () == 0)
        {
            取ODBC数据源_ ()
        }
        mysql组64.枚举循环 ()
        {
            如果真 (寻找文本 (mysql组64.取枚举值 (), 版本号) != -1)
            {
                如果 (版本号 == "8.0")
                {
                    如果 (版本8类型 == 1)
                    {
                        名称 = "MySQL ODBC 8.0 ANSI Driver"
                    }
                    否则
                    {
                        名称 = "MySQL ODBC 8.0 Unicode Driver"
                    }
                }
                否则
                {
                    名称 = mysql组64.取枚举值 ()
                }
                跳出循环
            }
        }
        如果真 (名称 == "")
        {
            mysql组32.枚举循环 ()
            {
                如果真 (寻找文本 (mysql组32.取枚举值 (), 版本号) != -1)
                {
                    如果 (版本号 == "8.0")
                    {
                        如果 (版本8类型 == 1)
                        {
                            名称 = "MySQL ODBC 8.0 ANSI Driver"
                        }
                        否则
                        {
                            名称 = "MySQL ODBC 8.0 Unicode Driver"
                        }
                    }
                    否则
                    {
                        名称 = mysql组32.取枚举值 ()
                    }
                    跳出循环
                }
            }
        }
        返回 (名称)
    }

