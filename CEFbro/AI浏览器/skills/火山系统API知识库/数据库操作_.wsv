    方法 值 <公开 属性写 注释 = "设置该字段的值." 返回值注释 = "返回值请参考\"数据库字段数据类型2_\"所提供的常量." 折叠>
    参数 欲置入值 <类型 = COM变体型>
    {
        写属性 ("Value", 欲置入值)
    }
}

类 数据库字段集合类2_ <公开 基础类 = 数据库集合类2_ 注释 = "本类表示一个数据集中所有的字段数据." 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库2.附加类\""
        @模板实现类 = "数据库字段类2_,数据库字段集合类2_">
{
    方法 加入 <公开 类型 = 逻辑型 注释 = "将指定字段追加至该集合的尾部." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 名称 <类型 = 文本型 注释 = "所欲加入新字段的名称,不能与集合中的任何其他字段同名.">
    参数 字段对象 <类型 = 数据库字段类2_ 注释 = "提供所欲加入该集合的字段对象.">
    参数 数据类型 <类型 = 整数 注释 = "所欲加入新字段的数据类型,请参考\"数据库字段数据类型2_\"所提供的常量." @默认值 = 数据库字段数据类型2_.空值>
    参数 定义尺寸 <类型 = 长整数 注释 = "表示所加入新字段定义的大小(字节)." @默认值 = 0>
    参数 字段属性 <类型 = 长整数 注释 = "-1 未指定字段属性." 注释 = "0x1000 程序将会缓存字段值,后续的读取是从缓存中完成的." 注释 = "0x10 字段包含固定长度数据." 注释 = "0x2000 字段包含子集值."
            注释 = "0x40000 字段是由记录表示其他资源的集合." 注释 = "0x8000 字段是主键列的全部或部分." 注释 = "0x20000 字段包含由记录表示的资源的默认流." 注释 = "0x20 字段接受NULL值."
            注释 = "0x10000 字段包含从记录表示的数据存储区中对资源进行命名的URL." 注释 = "0x80 该字段是长二进制字段." 注释 = "0x40 可能会从该字段中读到NULL值."
            注释 = "0x2 字段值不是从数据源中检索整个记录,而只是在显式访问字段值时进行检索." 注释 = "0x4000 字段值支持反比例列的数值."
            注释 = "0x100 字段包含不能写入的持久性行标识符,并且除标识行(如记录号,唯一标识符)等之外没有有意义的值." 注释 = "0x200 字段包含用于标识更新的时间戳或日期值." 注释 = "0x8 提供程序无法确定是否可以写入字段."
            注释 = "0x4 表示该字段支持写入." 折叠2 @默认值 = -1>
    {
        返回 (无返回值方法 ("Append", 名称, 数据类型, 定义尺寸, 字段属性, 字段对象))
    }

    方法 删除索引 <公开 类型 = 逻辑型 注释 = "删除指定索引处的字段对象." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 索引 <类型 = 整数 注释 = "所欲删除字段在本集合内所处的索引位置.">
    {
        返回 (无返回值方法 ("Delete", 索引))
    }

    方法 删除 <公开 类型 = 逻辑型 注释 = "以字段名称删除指定字段对象." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 名称 <类型 = 文本型 注释 = "所欲删除字段的名称.">
    {
        返回 (无返回值方法 ("Delete", 名称))
    }

    方法 取消更新 <公开 类型 = 逻辑型 注释 = "在调用\"更新\"方法之前,取消对当前字段对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        返回 (无参数及返回值方法 ("CancelUpdate"))
    }

    方法 重新同步 <公开 类型 = 逻辑型 注释 = "通过重新执行对象所基于的查询来更新字段集合对象中的字段数据." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 是否覆盖 <类型 = 逻辑型 注释 = "是否覆盖原有数据,挂起的更新动作将被直接取消,提供假将不会覆盖数据,也不会取消挂起的更新动作." @默认值 = 真>
    {
        如果 (是否覆盖)
        {
            返回 (无返回值方法 ("Resync", 3, 2))
        }
        否则
        {
            返回 (无返回值方法 ("Resync", 3, 1))
        }
    }

    方法 更新 <公开 类型 = 逻辑型 注释 = "保存对字段集合对象所做的任何更改." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 字段 <类型 = COM变体型 注释 = "指定所欲修改的一个或多个字段名称,如果有多个字段请置入字段数组,可以为名称也可以是字段索引." @默认值 = 空对象>
    参数 值 <类型 = COM变体型 注释 = "指定字段所对应的值,如果有多个字段,必须提供对等数量的值,否则将无法正常执行更新." @默认值 = 空对象>
    {
        返回 (无返回值方法 ("Update", 字段, 值))
    }
}

