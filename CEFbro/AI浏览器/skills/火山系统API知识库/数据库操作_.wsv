    方法 取所有库名 <公开 类型 = 整数 注释 = "获取当前连接中所有数据库名称" 返回值注释 = "返回库名数量" 折叠>
    参数 返回的库名数据 <类型 = 文本数组类 @默认值 = 空对象>
    参数 连接对象 <类型 = 数据库类_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 数据库类型 <类型 = 整数 注释 = "1、MsSql  2、MySql  3、Postgresql" @默认值 = 1>
    {
        变量 记录数 <类型 = 整数>
        变量 名称组 <类型 = 文本数组类>
        如果真 (数据库类型 < 1 || 数据库类型 > 3)
        {
            数据库类型 = 1
        }
        如果 (数据库类型 == 1)
        {
            执行 ("SELECT NAME FROM MASTER.DBO.SYSDATABASES ORDER BY NAME", 连接对象)
        }
        否则 (数据库类型 == 2)
        {
            执行 ("show databases", 连接对象)
        }
        否则 (数据库类型 == 3)
        {
            执行 ("select datname from pg_database where datistemplate=false", 连接对象)
        }
        到首记录 ()
        记录数 = 记录数量
        计次循环 (记录数)
        {
            名称组.加入成员 (读索引文本数据 (0))
            到下一行 ()
        }
        返回的库名数据 = 名称组
        关闭 ()
        返回 (记录数)
    }

    方法 取所有表名 <公开 类型 = 整数 注释 = "获取当前数据库中所有表名称." 注释 = "Access需要先设置MsysObjects权限;" 注释 = "①旧版：菜单-工具-选项-视图-勾选\"系统对象\";"
            注释 = "菜单-工具-安全-用户与组权限-选择\"管理员\"-选择\"MsysObjects\"-勾选\"读取数据\"，最后再取消勾选\"系统对象\"" 注释 = ""
            注释 = "②新版：左侧表列表-右键\"导航选项\"-勾选\"显示系统对象\";" 注释 = "文件-用户和权限-用户与组权限-选择\"MsysObjects\"，勾选\"读取数据\"，最后再取消勾选\"显示系统对象\""
            返回值注释 = "返回表名数量" 折叠 折叠2>
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称，当前为Mysql数据库时则需要提供本名称，Excel的需要提供文件来源，其它数据库则不需要填写" @默认值 = "">
    参数 返回的表名数据 <类型 = 文本数组类 @默认值 = 空对象>
    参数 连接对象 <类型 = 数据库类_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." @默认值 = 空对象>
    参数 数据库类型 <类型 = 整数 注释 = "1、MsSql  2、MySql  3、Access  4、Sqlite  5、Postgresql  6、Excel" @默认值 = 1>
    {
        变量 记录数 <类型 = 整数>
        变量 名称组 <类型 = 文本数组类>
        如果真 (数据库类型 < 1 || 数据库类型 > 6)
        {
            数据库类型 = 1
        }
        如果 (数据库类型 == 1)
        {
            执行 ("SELECT NAME FROM SYSOBJECTS WHERE XTYPE='U' ORDER BY NAME", 连接对象)
        }
        否则 (数据库类型 == 2)
        {
            执行 ("select table_name from information_schema.tables where table_schema='" + 数据库名 + "'", 连接对象)
        }
        否则 (数据库类型 == 3)
        {
            执行 ("select Name from MsysObjects where type=1 and Flags=0", 连接对象)
        }
        否则 (数据库类型 == 4)
        {
            执行 ("SELECT name FROM sqlite_master where type='table' order by name", 连接对象)
        }
        否则 (数据库类型 == 5)
        {
            执行SQL语句 ("SELECT table_name FROM information_schema.tables WHERE table_schema = 'public' ORDER BY table_name", 连接对象)
        }
        否则 (数据库类型 == 6)
        {
            变量 对象1 <类型 = COM对象类>
            变量 对象2 <类型 = COM对象类>
            变量 临时表名 <类型 = 文本型>
            变量 i <类型 = 整数>
            对象1.创建 ("ADODB.Connection", )
            对象1.写属性 ("CursorLocation", 3)
            对象2.创建 ("ADODB.RecordSet", )
            对象1.方法 ("open", 文本型, "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + 数据库名 + ";Extended Properties=" + "\"" + "Excel 12.0;" + "\"")
            对象2 = 对象1.对象型方法 ("OpenSchema", COM对象类, 20)
            记录数 = 对象2.读无参数属性 ("RecordCount", 整数)
            循环 (, 记录数, i)
            {
                临时表名 = 对象2.无参数对象型方法 ("Fields", COM对象类).读对象型属性 ("Item", COM对象类, "TABLE_NAME").读无参数属性 ("Value", 文本型)
                子文本替换 (临时表名, "'", "", , , )
                如果真 (取文本右边 (临时表名, 1) == "$")
                {
                    子文本替换 (临时表名, "$", "", , , )
                    名称组.加入成员 (临时表名)
                }
                对象2.无参数方法 ("MoveNext", COM对象类)
            }
            对象2.无参数方法 ("Close", COM对象类)
            对象1.无参数方法 ("Close", COM对象类)
            返回的表名数据 = 名称组
            返回 (记录数)
        }
        到首记录 ()
        记录数 = 记录数量
        计次循环 (记录数)
        {
            名称组.加入成员 (读索引文本数据 (0))
            到下一行 ()
        }
        返回的表名数据 = 名称组
        关闭 ()
        返回 (记录数)
    }

    方法 取所有字段名 <公开 类型 = 文本数组类 注释 = "获取当前数据表中所有字段名称" 折叠>
    参数 记录集 <类型 = 记录集类_>
    {
        变量 数据库字段 <类型 = 数据库字段集合类_>
