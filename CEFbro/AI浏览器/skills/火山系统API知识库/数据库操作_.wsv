    方法 取所有字段信息 <公开 类型 = 整数 注释 = "获取当前数据表中所有字段名称和字段类型" 返回值注释 = "返回字段总数" 折叠>
    参数 记录集 <类型 = 记录集类2_>
    参数 返回的字段名称组 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的字段类型名 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的字段类型组 <类型 = 整数数组类 注释 = "返回值请参考“数据库字段数据类型_”所提供的常量" @默认值 = 空对象>
    {
        变量 数据库字段 <类型 = 数据库字段集合类2_>
        变量 当前字段 <类型 = 数据库字段类2_>
        变量 i <类型 = 整数>
        数据库字段 = 记录集.取字段列表 ()
        循环 (, 数据库字段.成员数, i)
        {
            当前字段 = 数据库字段.取成员 (i)
            返回的字段名称组.加入成员 (当前字段.名称)
            返回的字段类型组.加入成员 (当前字段.类型)
            返回的字段类型名.加入成员 (匹配类型 (当前字段.类型))
        }
        返回 (返回的字段名称组.取成员数 ())
    }

    方法 匹配类型 <类型 = 文本型 折叠>
    参数 字段值 <类型 = 整数>
    {
        变量 整数组 <类型 = "整数 [11]" 值 = {2,3,6,14,16,17,18,19,20,21,139}>
        变量 小数组 <类型 = "整数 [3]" 值 = {4,5,131}>
        变量 文本组 <类型 = "整数 [7]" 值 = {8,129,130,200,201,202,203}>
        变量 日期组 <类型 = "整数 [4]" 值 = {7,133,134,135}>
        变量 字节组 <类型 = "整数 [3]" 值 = {204,205,128}>
        变量 逻辑组 <类型 = 整数 值 = 11>
        变量 结果 <类型 = 文本型>
        计次循环 (取数组成员数 (文本组))
        {
            如果真 (文本组 [取循环索引 ()] == 字段值)
            {
                结果 = "文本型"
                跳出循环
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (整数组))
            {
                如果真 (整数组 [取循环索引 ()] == 字段值)
                {
                    结果 = "整数型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (小数组))
            {
                如果真 (小数组 [取循环索引 ()] == 字段值)
                {
                    结果 = "小数型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (日期组))
            {
                如果真 (日期组 [取循环索引 ()] == 字段值)
                {
                    结果 = "日期型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            如果真 (字段值 == 逻辑组)
            {
                结果 = "逻辑型"
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (字节组))
            {
                如果真 (字节组 [取循环索引 ()] == 字段值)
                {
                    结果 = "字节型"
                    跳出循环
                }
            }
        }
        返回 (结果)
    }

    方法 导出记录集 <公开 类型 = 字节集类 注释 = "将记录集转成字节集数据" 折叠>
    {
        变量 Stream <类型 = COM对象类>
        变量 var <类型 = COM变体型>
        变量 bins <类型 = 字节集类>
        Stream.创建 ("ADODB.Stream")
        var.置COM对象 (Stream)
        记录集对象.无返回值方法 ("Save", var, 0)
        <> var = Stream.无参数方法 ("Read", COM变体型)
        var.取字节集 (bins)
        Stream.清除 ()
        var.清空 ()
        返回 (bins)
    }

    方法 导入记录集 <公开 类型 = 逻辑型 注释 = "将字节集形式的记录集数据，转回记录集" 折叠>
    参数 欲转换数据 <类型 = 字节集类>
    {
        变量 Stream <类型 = COM对象类>
        变量 var <类型 = COM变体型>
        变量 obj <类型 = COM对象类>
        变量 objvar <类型 = COM变体型>
        COM初始化类.初始化COM ()
        var.置字节集 (欲转换数据)
        Stream.创建 ("ADODB.Stream")
        Stream.无参数及返回值方法 ("Open")
        Stream.写属性 ("Type", 1)
        Stream.无返回值方法 ("Write", var)
        Stream.写属性 ("Position", 0)
        var.清空 ()
        objvar.置COM对象 (Stream)
        obj.创建 ("ADODB.RecordSet")
        obj.无返回值方法 ("Open", objvar)
        Stream.无参数及返回值方法 ("Close")
        Stream.清除 ()
        记录集对象 = obj
        COM初始化类.清理COM ()
        返回 (obj.取错误 () == COM方法调用结果.成功)
    }

    方法 记录集转JSON <公开 类型 = 文本型 注释 = "将记录集转成可读的文本数据，转换完成将自动关闭该记录集;" 注释 = "数据包可通过“ADO记录集辅助类_”来处理解析" 折叠 折叠2>
    参数 记录集 <类型 = 记录集类2_>
    参数 格式类型 <类型 = 整数 注释 = "1、按列转　2、按行转" @默认值 = 1>
    参数 关闭记录集 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 字段列表 <类型 = 数据库字段集合类2_>
        变量 当前字段 <类型 = 数据库字段类2_>
        变量 JSON对象1 <类型 = JSON构造对象类_yy>
        变量 JSON对象2 <类型 = JSON构造对象类_yy>
        变量 JSON对象3 <类型 = "JSON构造对象类_yy [150]">
        变量 JSON数组1 <类型 = JSON构造数组类_yy>
        变量 JSON数组2 <类型 = "JSON构造数组类_yy [150]">
        变量 字段组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        记录集.到首记录 ()
        字段列表 = 记录集.取字段列表 ()
        JSON对象2.初始化空对象 ()
        如果真 (字段列表.成员数 > 150)
        {
            调试输出 ("最多支持150列，当前已经超出。")
            返回 ("")
        }
        如果 (格式类型 == 1)
        {
            计次循环 (字段列表.成员数)
            {
                JSON对象3 [取循环索引 ()].初始化空数组 ()
                JSON数组2 [取循环索引 ()] = JSON对象3 [取循环索引 ()].置空数组 ()
            }
            循环 (, 记录集.记录数量, i)
            {
                循环 (, 字段列表.成员数, i2)
                {
                    JSON数组2 [i2].添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                }
                记录集.到下一行 ()
            }
            循环 (, 字段列表.成员数, i)
            {
                当前字段 = 字段列表.取成员 (i)
                JSON对象2.添加对象节点 (当前字段.名称, 假).置JSON文本 (JSON数组2 [i].到可读文本 ())
            }
        }
        否则
        {
            JSON对象1.初始化空数组 ()
            循环 (, 记录集.记录数量, i)
            {
                JSON数组1 = JSON对象1.置空数组 ()
                循环 (, 字段列表.成员数, i2)
                {
                    JSON数组1.添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                }
                JSON对象2.添加对象节点 (到文本 (i), 假).置JSON文本 (JSON数组1.到可读文本 ())
                记录集.到下一行 ()
            }
        }
        如果真 (关闭记录集 == 真)
        {
            记录集.关闭 ()
        }
        返回 (JSON对象2.到可读文本 ())
    }

    方法 记录集转JSON2 <公开 类型 = 字节集类 注释 = "将记录集转成字节集数据，转换完成将自动关闭该记录集;" 注释 = "数据包可通过“ADO记录集辅助类_”来处理解析" 折叠 折叠2>
    参数 记录集 <类型 = 记录集类2_>
    参数 格式类型 <类型 = 整数 注释 = "1、按列转　2、按行转" @默认值 = 1>
    参数 关闭记录集 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 字段列表 <类型 = 数据库字段集合类2_>
        变量 当前字段 <类型 = 数据库字段类2_>
        变量 JSON对象1 <类型 = JSON构造对象类_yy>
        变量 JSON对象2 <类型 = JSON构造对象类_yy>
        变量 JSON对象3 <类型 = "JSON构造对象类_yy [150]">
        变量 JSON数组1 <类型 = JSON构造数组类_yy>
        变量 JSON数组2 <类型 = "JSON构造数组类_yy [150]">
        变量 字段组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        变量 i2 <类型 = 整数>
        记录集.到首记录 ()
        字段列表 = 记录集.取字段列表 ()
        如果 (字段列表.成员数 > 150)
        {
            调试输出 ("最多支持150列，当前已经超出。")
        }
        否则
        {
            JSON对象2.初始化空对象 ()
            如果 (格式类型 == 1)
            {
                计次循环 (字段列表.成员数)
                {
                    JSON对象3 [取循环索引 ()].初始化空数组 ()
                    JSON数组2 [取循环索引 ()] = JSON对象3 [取循环索引 ()].置空数组 ()
                }
                循环 (, 记录集.记录数量, i)
                {
                    循环 (, 字段列表.成员数, i2)
                    {
                        JSON数组2 [i2].添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                    }
                    记录集.到下一行 ()
                }
                循环 (, 字段列表.成员数, i)
                {
                    当前字段 = 字段列表.取成员 (i)
                    JSON对象2.添加对象节点 (当前字段.名称, 假).置JSON文本 (JSON数组2 [i].到可读文本 ())
                }
            }
            否则
            {
                JSON对象1.初始化空数组 ()
                循环 (, 记录集.记录数量, i)
                {
                    JSON数组1 = JSON对象1.置空数组 ()
                    循环 (, 字段列表.成员数, i2)
                    {
                        JSON数组1.添加数组节点 ().文本值 = 记录集.读索引文本数据 (i2)
                    }
                    JSON对象2.添加对象节点 (到文本 (i), 假).置JSON文本 (JSON数组1.到可读文本 ())
                    记录集.到下一行 ()
                }
            }
        }
        如果真 (关闭记录集 == 真)
        {
            记录集.关闭 ()
        }
        返回 (JSON对象2.到字节集 ())
    }

