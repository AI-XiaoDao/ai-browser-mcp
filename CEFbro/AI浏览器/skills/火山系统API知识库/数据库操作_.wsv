    方法 匹配类型 <类型 = 文本型 折叠>
    参数 字段值 <类型 = 整数>
    {
        变量 整数组 <类型 = "整数 [11]" 值 = {2,3,6,14,16,17,18,19,20,21,139}>
        变量 小数组 <类型 = "整数 [3]" 值 = {4,5,131}>
        变量 文本组 <类型 = "整数 [7]" 值 = {8,129,130,200,201,202,203}>
        变量 日期组 <类型 = "整数 [4]" 值 = {7,133,134,135}>
        变量 字节组 <类型 = "整数 [3]" 值 = {204,205,128}>
        变量 逻辑组 <类型 = 整数 值 = 11>
        变量 结果 <类型 = 文本型>
        计次循环 (取数组成员数 (文本组))
        {
            如果真 (文本组 [取循环索引 ()] == 字段值)
            {
                结果 = "文本型"
                跳出循环
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (整数组))
            {
                如果真 (整数组 [取循环索引 ()] == 字段值)
                {
                    结果 = "整数型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (小数组))
            {
                如果真 (小数组 [取循环索引 ()] == 字段值)
                {
                    结果 = "小数型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (日期组))
            {
                如果真 (日期组 [取循环索引 ()] == 字段值)
                {
                    结果 = "日期型"
                    跳出循环
                }
            }
        }
        如果真 (文本是否为空 (结果))
        {
            如果真 (字段值 == 逻辑组)
            {
                结果 = "逻辑型"
            }
        }
        如果真 (文本是否为空 (结果))
        {
            计次循环 (取数组成员数 (字节组))
            {
                如果真 (字节组 [取循环索引 ()] == 字段值)
                {
                    结果 = "字节型"
                    跳出循环
                }
            }
        }
        返回 (结果)
    }

    方法 刷新记录 <公开 类型 = 逻辑型 注释 = "通过重新执行对象所基于的查询来更新记录集对象中的数据." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型_\"以及\"数据库命令执行选项_\"所定义常量的单个或多个组合值." @默认值 = -1>
    {
        返回 (无返回值方法 ("Requery", 选项))
    }

    方法 重新同步 <公开 类型 = 逻辑型 注释 = "通过重新执行对象所基于的查询来更新记录集对象中的数据." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 范围选项 <类型 = 整数 注释 = "指定该删除操作会影响到的记录,请参考\"数据库影响记录选项_\"." @默认值 = 数据库影响记录选项_.所有>
    参数 是否覆盖 <类型 = 逻辑型 注释 = "是否覆盖原有数据,挂起的更新动作将被直接取消,提供假将不会覆盖数据,也不会取消挂起的更新动作." @默认值 = 真>
    {
        如果 (是否覆盖)
        {
            返回 (无返回值方法 ("Resync", 范围选项, 2))
        }
        否则
        {
            返回 (无返回值方法 ("Resync", 范围选项, 1))
        }
    }

    方法 导出记录集 <公开 类型 = 字节集类 注释 = "将记录集转成字节集数据" 折叠>
    {
        变量 Stream <类型 = COM对象类>
        变量 value <类型 = COM变体型>
        Stream.创建 ("ADODB.Stream")
        value.置COM对象 (Stream)
        无返回值方法 ("Save", value, 0)
        变量 ret <类型 = COM变体型>
        ret = Stream.无参数方法 ("Read", COM变体型)
        变量 返回字节集 <类型 = 字节集类>
        ret.取字节集 (返回字节集)
        Stream.清除 ()
        value.清空 ()
        返回 (返回字节集)
    }

    方法 导入记录集 <公开 类型 = 逻辑型 注释 = "将字节集形式的记录集数据，转回记录集" 折叠>
    参数 记录集数据 <类型 = 字节集类>
    {
        变量 Stream <类型 = COM对象类>
        变量 value <类型 = COM变体型>
        value.置字节集 (记录集数据)
        Stream.创建 ("ADODB.Stream")
        Stream.无参数及返回值方法 ("Open")
        Stream.写属性 ("Type", 1)
        Stream.无返回值方法 ("Write", value)
        Stream.写属性 ("Position", 0)
        value.清空 ()
        value.置COM对象 (Stream)
        创建 ("ADODB.RecordSet")
        变量 临时 <类型 = COM变体型>
        无返回值方法 ("Open", value, 临时, 0, 1, 256)
        Stream.无参数及返回值方法 ("Close")
        Stream.清除 ()
        返回 (取错误 () == COM方法调用结果.成功)
    }

