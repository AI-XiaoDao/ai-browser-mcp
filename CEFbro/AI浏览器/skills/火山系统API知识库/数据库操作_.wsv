        如果 (内部_数据库COM.创建 ("ADODB.Connection"))
        {
            结果 = 连接 ("DRIVER=" + 驱动程序 + "; SERVER=" + 地址, 用户名, 密码, , 异步连接)
            错误描述 = 连接错误描述
            如果真 (文本是否为空 (错误描述) == 假)
            {
                调试输出 (错误描述)
            }
            返回 (结果)
        }
        否则
        {
            错误描述 = "创建对象失败"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
    }

    方法 连接Oracle_64 <公开 类型 = 逻辑型 注释 = "驱动下载：https://xf3v74qido.feishu.cn/file/N5tebFPeYoBV44xX5BbcQCDHnuc"
            返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 地址 <类型 = 文本型>
    参数 用户名 <类型 = 文本型>
    参数 密码 <类型 = 文本型>
    参数 端口 <类型 = 整数 @默认值 = 1521>
    参数 实例名 <类型 = 文本型 @默认值 = "ORCL">
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        变量 结果 <类型 = 逻辑型>
        如果 (内部_数据库COM.创建 ("ADODB.Connection"))
        {
            结果 = 连接 ("Provider=OraOLEDB.Oracle.1; Password=" + 密码 + "; Persist Security Info=True;User ID=" + 用户名 + "; \Data Source=\"(DESCRIPTION = (ADDRESS = (PROTOCOL = TCP)(HOST = " + 地址 + ")(PORT = " + 到文本 (端口) + ")) (CONNECT_DATA = (SERVER = DEDICATED) (SERVICE_NAME = " + 实例名 + ")))\"", , , , 假)
            错误描述 = 连接错误描述
            如果真 (文本是否为空 (错误描述) == 假)
            {
                调试输出 (错误描述)
            }
            返回 (结果)
        }
        否则
        {
            错误描述 = "创建对象失败"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
    }

    方法 连接Postgresql <公开 类型 = 逻辑型 注释 = "驱动下载：https://xf3v74qido.feishu.cn/file/FcOAbXJzOoiHWRxTntXcrXfJnWh"
            返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 地址 <类型 = 文本型 注释 = "提供数据库连接地址." @默认值 = "localhost">
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称." @默认值 = "">
    参数 用户名 <类型 = 文本型 注释 = "提供连接该数据库所需的用户名." @默认值 = "postgres">
    参数 密码 <类型 = 文本型 注释 = "提供连接该数据库所需的密码." @默认值 = "">
    参数 端口号 <类型 = 整数 注释 = "通过该数据库的连接端口." @默认值 = 5432>
    参数 驱动程序 <类型 = 文本型 注释 = "指定是否使用ODBC驱动方式连接(例如:PostgreSQL UNICODE),提供空文本将会使用OLEDB方式连接,如果使用驱动方式连接,务必保证系统中已安装该驱动."
            @默认值 = "PostgreSQL Unicode">
    参数 异步连接 <类型 = 逻辑型 注释 = "是否以异步方式进行连接,提供假则会堵塞直到连接完成,提供真将会以事件方式(连接完成)通知连接结果." @默认值 = 假>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取连接错误描述”获取" @默认值 = "">
    {
        关闭 ()
        变量 结果 <类型 = 逻辑型>
        如果 (内部_数据库COM.创建 ("ADODB.Connection") == 假)
        {
            错误描述 = "创建对象失败"
            连接错误描述 = 错误描述
            调试输出 (错误描述)
            返回 (假)
        }
        如果 (文本是否为空 (驱动程序))
        {
            结果 = 连接 ("Provider=PostgreSQL OLE DB; Data Source=" + 地址 + "; location=" + 数据库名 + ";", 用户名, 密码, , 异步连接)
        }
        否则
        {
            结果 = 连接 ("Provider=MSDASQL; DRIVER=" + 驱动程序 + "; SERVER=" + 地址 + "; PORT=" + 到文本 (端口号) + "; DATABASE=" + 数据库名 + ";", 用户名, 密码, , 异步连接)
        }
        错误描述 = 连接错误描述
        如果真 (文本是否为空 (错误描述) == 假)
        {
            调试输出 (错误描述)
        }
        返回 (结果)
    }

    方法 取连接错误描述 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (连接错误描述)
    }

    方法 关闭 <公开 类型 = 逻辑型 注释 = "关闭当前已连接的数据库,并释放所关联的任何系统资源." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    {
        内部_数据库COM.无参数及返回值方法 ("Close")
        返回 (真)
    }

    方法 最后错误 <公开 类型 = 文本型 注释 = "数据库最后错误描述" 折叠>
    {
        变量 Errors <类型 = COM对象类>
        变量 Item <类型 = COM对象类>
        变量 Description <类型 = 文本型>
        变量 临时对象2 <类型 = COM对象类>
        Errors = 内部_数据库COM.读无参数属性 ("Errors", COM对象类)
        如果 (Errors.读无参数属性 ("Count", 整数) > 0)
        {
            临时对象2 = 内部_数据库COM.读无参数属性 ("Errors", COM对象类)
            Item = 临时对象2.读无参数属性 ("Item", COM对象类)
            Description = Item.读无参数属性 ("Description", 文本型)
            如果 (Description != "")
            {
                返回 (Description)
            }
        }
        返回 ("")
    }

    方法 开始事务 <公开 类型 = 整数 注释 = "开始一个新的事务." 返回值注释 = "返回事务的嵌套级别." 折叠>
    {
        返回 (内部_数据库COM.无参数方法 ("BeginTrans", 整数))
    }

    方法 保存事务 <公开 类型 = 逻辑型 注释 = "保存所有更改并结束当前事务." 注释 = "注意：开始事务请直接在执行SQL语句方法中的参数设置" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    {
        返回 (内部_数据库COM.无参数及返回值方法 ("CommitTrans"))
    }

    方法 回滚事务 <公开 类型 = 逻辑型 注释 = "取消在当前事务中所做的任何更改并结束事务." 注释 = "注意：开始事务请直接在执行SQL语句方法中的参数设置" 返回值注释 = "执行成功返回真,否则返回假." 折叠 折叠2>
    {
        返回 (内部_数据库COM.无参数及返回值方法 ("RollbackTrans"))
    }

