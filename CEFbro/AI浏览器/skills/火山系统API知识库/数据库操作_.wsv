}

类 记录集类2_ <公开 基础类 = COM对象类 注释 = "表示数据表中的整个记录集或执行的命令的结果,可使用本类实例获取具体数据." 折叠 @文档 = "category = \"ADO数据库.ADO数据库2\"">
{
    变量 数据库COM <类型 = COM对象类>
    变量 记录集对象 <类型 = COM对象类>
    变量 被影响行数 <类型 = 整数>
    变量 语句错误描述信息 <类型 = 文本型 值 = "还未连接数据库">

    方法 类_初始化 <折叠>
    {
        记录集对象.创建 ("ADODB.recordset")
    }

    # //原始命令===

    方法 COM对象事件类_接收到事件 <接收事件 类型 = 整数 注释 = "当接收到所挂接COM事件时,本事件被触发." 折叠>
    参数 来源对象 <类型 = COM对象事件类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 来源COM对象 <类型 = COM对象类 注释 = "提供挂接事件时所提供的来源COM对象">
    参数 事件方法ID <类型 = 整数 注释 = "提供所触发的具体事件的对应COM方法ID值">
    参数 事件参数 <类型 = COM变体型数组类 注释 = "提供事件的所有参数数据">
    参数 事件返回值 <类型 = COM变体型 注释 = "仅用作输出. 事件处理完毕后如果需要返回数据,请将所欲返回数据值填入到此参数变量中.">
    {
        如果 (事件方法ID == 0x00000005)  // ExecuteComplete
        {
            变量 错误返回 <类型 = 数据库错误信息类_>
            事件参数.取成员 (1).取COM对象 (错误返回)
            事件返回值.赋值 (命令执行完成 (事件参数.取成员 (0).取值 (整数, ), 错误返回), )
            被影响行数 = 事件参数.取成员 (0).取值 (整数, )
            语句错误描述信息 = 错误返回.错误描述
        }
        返回 (0)
    }

    方法 命令执行完成 <公开 定义事件 类型 = 整数 注释 = "在执行SQL命令后,执行完毕本事件将被调用." 折叠>
    参数 受影响行数 <类型 = 整数 注释 = "执行该命令后被影响的记录数量.">
    参数 错误对象 <类型 = 数据库错误信息类_ 注释 = "返回错误对象,其包含错误代码以及描述内容.">

    方法 打开2 <类型 = 逻辑型 注释 = "根据指定数据源以及连接串文本打开记录集." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 数据源 <类型 = COM变体型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称)." @默认值 = 空对象>
    参数 活动连接 <类型 = COM变体型 注释 = "是否提供一个已有的活动连接对象(数据库类),也可提供连接串文本,与连接数据库同理." @默认值 = 空对象>
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 游标类型 <类型 = 整数 注释 = "请参考\"记录集游标类型\"所提供的常量." @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型\"所提供的常量." @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    {
        如果 (是否客户端)
        {
            游标服务位置 = 3
        }
        变量 是否成功 <类型 = 逻辑型>
        是否成功 = 记录集对象.无返回值方法 ("Open", 数据源, 活动连接, 游标类型, 编辑锁, 选项)
        返回 (是否成功)
    }

    方法 打开 <公开 类型 = 逻辑型 注释 = "根据指定数据源以及连接串文本打开记录集." 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 数据源 <类型 = 文本型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称).">
    参数 数据库 <类型 = 数据库类2_ 注释 = "是否提供一个已有的活动连接对象(数据库类),也可提供连接串文本,与连接数据库同理.">
    参数 是否客户端 <类型 = 逻辑型 注释 = "指定是否将游标服务位置指向客户端,默认为真." @默认值 = 真>
    参数 游标类型 <类型 = 整数 注释 = "-1无　0默认　1键集游标　2动态游标　3静态游标" @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "-1无　1只读锁定　2悲观锁定　3开放式锁定　4批处理更新" @默认值 = -1>
    参数 选项 <类型 = 整数 注释 = "提供本次执行的性能选项,提供\"数据库命令类型\"以及\"数据库命令执行选项\"所定义常量的单个或多个组合值." @默认值 = -1>
    {
        如果 (是否客户端)
        {
            游标服务位置 = 3
        }
        数据库COM = 数据库.内部_数据库COM
        变量 源 <类型 = COM变体型>
        变量 连接 <类型 = COM变体型>
        源.赋值 (数据源)
        连接.置COM对象 (数据库COM)
        变量 事件对象 <类型 = COM对象事件类>
        事件对象.挂接 (数据库COM, "{00000400-0000-0010-8000-00AA006D2EA4}")
        挂接事件 (事件对象, )
        变量 是否成功 <类型 = 逻辑型>
        是否成功 = 记录集对象.无返回值方法 ("Open", 源, 连接, 游标类型, 编辑锁, 选项)
        返回 (是否成功)
    }

    方法 执行SQL语句 <公开 类型 = 逻辑型 返回值注释 = "执行成功返回真,否则返回假." 折叠>
    参数 Sql语句 <类型 = 文本型 注释 = "数据来源,可以是一个SQL语句(表名,储存过程,URL,本地记录集文件,流对象名称).">
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 受影响行数 <类型 = 整数类 注释 = "提供一个整数类变量以获取本次命令执行后,影响到表中的记录数量，如是执行查询操作是不会返回受影响行数" @默认值 = 空对象>
    参数 错误描述 <类型 = 文本型 注释 = "也可通过“取语句错误描述”获取" @默认值 = "">
    参数 选项 <类型 = 整数 注释 = "一般提供-1即可" @默认值 = -1>
    参数 编辑锁 <类型 = 整数 注释 = "-1无　0默认　1键集游标　2动态游标　3静态游标" @默认值 = -1>
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型 0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." 折叠2 @默认值 = -1>
    {
        变量 是否客户端 <类型 = 逻辑型 值 = 真 注释 = "指定是否将游标服务位置指向客户端,默认为真.">
        变量 源 <类型 = COM变体型>
        变量 连接 <类型 = COM变体型>
        变量 是否成功_ <类型 = 是否成功>
        数据库COM = 数据库.内部_数据库COM
        源.赋值 (Sql语句)
        连接.置COM对象 (数据库COM)
        变量 是否成功 <类型 = 逻辑型>
        变量 事件对象 <类型 = COM对象事件类>
        事件对象.挂接 (数据库COM, "{00000400-0000-0010-8000-00AA006D2EA4}")
        挂接事件 (事件对象, )
        是否成功 = 打开2 (源, 连接, 是否客户端, 游标类型, 编辑锁, 选项)
        受影响行数.值 = 被影响行数
        错误描述 = 语句错误描述信息
        返回 (是否成功)
    }

    方法 取语句错误描述 <公开 属性读 类型 = 文本型 折叠>
    {
        返回 (语句错误描述信息)
    }

    方法 创建数据库 <公开 类型 = 逻辑型 注释 = "适用于mssql、mysql" 折叠>
    参数 欲创建的数据库名称 <类型 = 文本型>
    参数 Mysql字符集 <类型 = 文本型 注释 = "Mysql数据库专用，例如：utf8mb4" @默认值 = "">
    参数 Mysql排序规则 <类型 = 文本型 注释 = "Mysql数据库专用，例如：utf8mb4_general_ci" @默认值 = "">
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 错误描述 <类型 = 文本型 @默认值 = "">
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." 折叠2 @默认值 = -1>
    {
        变量 语句 <类型 = 文本型>
        如果 (Mysql字符集 == "" && Mysql排序规则 == "")
        {
            语句 = "create database " + 欲创建的数据库名称
        }
        否则
        {
            语句 = "create database IF NOT EXISTS " + 欲创建的数据库名称 + " DEFAULT CHARACTER SET " + Mysql字符集 + " DEFAULT COLLATE " + Mysql排序规则
        }
        返回 (执行SQL语句 (语句, 数据库, , 错误描述, , , 游标类型))
    }

    方法 删除数据库 <公开 类型 = 逻辑型 注释 = "适用于mssql、mysql" 折叠>
    参数 欲删除的数据库名称 <类型 = 文本型>
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 错误描述 <类型 = 文本型 @默认值 = "">
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." @默认值 = -1>
    {
        返回 (执行SQL语句 ("drop database " + 欲删除的数据库名称, 数据库, , 错误描述, , , 游标类型))
    }

    方法 创建数据库表 <公开 类型 = 逻辑型 折叠>
    参数 Sql语句 <类型 = 文本型 注释 = "可以用链式生成语句"
            注释 = "链式：sql.表名 (\"商品表\").主键 (\"ID\").文本字段2 (\"品名\", 200).货币字段 (\"单价\").日期时间字段 (\"入库时间\").取新建表SQL () ;"
            注释 = "相当于SQL语句：create table 商品表(ID int identity primary key,品名 varchar(200),单价 money,入库时间 datetime)" 折叠2>
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 错误描述 <类型 = 文本型 @默认值 = "">
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." 折叠2 @默认值 = -1>
    {
        返回 (执行SQL语句 (Sql语句, 数据库, , 错误描述, , , 游标类型))
    }

    方法 删除数据库表 <公开 类型 = 逻辑型 折叠>
    参数 欲删除的表名称 <类型 = 文本型>
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 错误描述 <类型 = 文本型 @默认值 = "">
    参数 游标类型 <类型 = 整数 注释 = "-1不指定游标的类型" 注释 = "0只进游标,只能向前滚动记录." 注释 = "1使用键集游标,与动态游标类似,但看不到其他用户添加的记录,其他用户删除的记录无法从记录集中访问,数据更改仍然可用."
            注释 = "2使用动态游标,其他用户的添加,更改和删除是可用的,并且允许所有类型的移动." 注释 = "3使用静态游标,该游标是一组记录的静态副本,可用于查找数据或生成报表,其他用户的添加,更改或删除不可用." 折叠2 @默认值 = -1>
    {
        返回 (执行SQL语句 ("drop table " + 欲删除的表名称, 数据库, , 错误描述, , , 游标类型))
    }

    方法 取所有库名 <公开 类型 = 整数 注释 = "获取当前连接中所有数据库名称" 返回值注释 = "返回库名数量" 折叠>
    参数 返回的库名数据 <类型 = 文本数组类 @默认值 = 空对象>
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 数据库类型 <类型 = 整数 注释 = "1、MsSql  2、MySql  3、Postgresql" @默认值 = 1>
    {
        变量 记录数 <类型 = 整数>
        变量 名称组 <类型 = 文本数组类>
        如果真 (数据库类型 < 1 || 数据库类型 > 3)
        {
            数据库类型 = 1
        }
        如果 (数据库类型 == 1)
        {
            执行SQL语句 ("SELECT NAME FROM MASTER.DBO.SYSDATABASES ORDER BY NAME", 数据库)
        }
        否则 (数据库类型 == 2)
        {
            执行SQL语句 ("show databases", 数据库)
        }
        否则 (数据库类型 == 3)
        {
            执行SQL语句 ("select datname from pg_database where datistemplate=false", 数据库)
        }
        到首记录 ()
        记录数 = 记录数量
        计次循环 (记录数)
        {
            名称组.加入成员 (读索引文本数据 (0))
            到下一行 ()
        }
        返回的库名数据 = 名称组
        关闭 ()
        返回 (记录数)
    }

    方法 取所有表名 <公开 类型 = 整数 注释 = "获取当前数据库中所有表名称." 注释 = "Access需要先设置MsysObjects权限;" 注释 = "①旧版：菜单-工具-选项-视图-勾选\"系统对象\";"
            注释 = "菜单-工具-安全-用户与组权限-选择\"管理员\"-选择\"MsysObjects\"-勾选\"读取数据\"，最后再取消勾选\"系统对象\"" 注释 = ""
            注释 = "②新版：左侧表列表-右键\"导航选项\"-勾选\"显示系统对象\";" 注释 = "文件-用户和权限-用户与组权限-选择\"MsysObjects\"，勾选\"读取数据\"，最后再取消勾选\"显示系统对象\""
            返回值注释 = "返回表名数量" 折叠 折叠2>
    参数 数据库名 <类型 = 文本型 注释 = "提供所欲打开的数据库名称，当前为Mysql数据库时则需要提供本名称，Excel的需要提供文件来源，其它数据库则不需要填写" @默认值 = "">
    参数 返回的表名数据 <类型 = 文本数组类 @默认值 = 空对象>
    参数 数据库 <类型 = 数据库类2_ 注释 = "提供已创建以及连接成功的数据库对象,将会基于该对象打开记录集." "">
    参数 数据库类型 <类型 = 整数 注释 = "1、MsSql  2、MySql  3、Access  4、Sqlite  5、Postgresql  6、Excel" @默认值 = 1>
    {
        变量 记录数 <类型 = 整数>
        变量 名称组 <类型 = 文本数组类>
        如果真 (数据库类型 < 1 || 数据库类型 > 6)
        {
            数据库类型 = 1
        }
        如果 (数据库类型 == 1)
        {
            执行SQL语句 ("SELECT NAME FROM SYSOBJECTS WHERE XTYPE='U' ORDER BY NAME", 数据库)
        }
        否则 (数据库类型 == 2)
        {
            执行SQL语句 ("select table_name from information_schema.tables where table_schema='" + 数据库名 + "'", 数据库)
        }
        否则 (数据库类型 == 3)
        {
            执行SQL语句 ("select Name from MsysObjects where type=1 and Flags=0", 数据库)
        }
        否则 (数据库类型 == 4)
        {
            执行SQL语句 ("SELECT name FROM sqlite_master where type='table' order by name", 数据库)
        }
        否则 (数据库类型 == 5)
        {
            执行SQL语句 ("SELECT table_name FROM information_schema.tables WHERE table_schema = 'public' ORDER BY table_name", 数据库)
        }
        否则 (数据库类型 == 6)
        {
            变量 对象1 <类型 = COM对象类>
            变量 对象2 <类型 = COM对象类>
            变量 临时表名 <类型 = 文本型>
            变量 i <类型 = 整数>
            对象1.创建 ("ADODB.Connection", )
            对象1.写属性 ("CursorLocation", 3)
            对象2.创建 ("ADODB.RecordSet", )
            对象1.方法 ("open", 文本型, "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + 数据库名 + ";Extended Properties=" + "\"" + "Excel 12.0;" + "\"")
            对象2 = 对象1.对象型方法 ("OpenSchema", COM对象类, 20)
            记录数 = 对象2.读无参数属性 ("RecordCount", 整数)
            循环 (, 记录数, i)
            {
                临时表名 = 对象2.无参数对象型方法 ("Fields", COM对象类).读对象型属性 ("Item", COM对象类, "TABLE_NAME").读无参数属性 ("Value", 文本型)
                子文本替换 (临时表名, "'", "", , , )
                如果真 (取文本右边 (临时表名, 1) == "$")
                {
                    子文本替换 (临时表名, "$", "", , , )
                    名称组.加入成员 (临时表名)
                }
                对象2.无参数方法 ("MoveNext", COM对象类)
            }
            对象2.无参数方法 ("Close", COM对象类)
            对象1.无参数方法 ("Close", COM对象类)
            返回的表名数据 = 名称组
            返回 (记录数)
        }
        到首记录 ()
        记录数 = 记录数量
        计次循环 (记录数)
        {
            名称组.加入成员 (读索引文本数据 (0))
            到下一行 ()
        }
        返回的表名数据 = 名称组
        关闭 ()
        返回 (记录数)
    }

    方法 取字段列表 <公开 类型 = 数据库字段集合类2_ 注释 = "获取该记录集当前位置所包含的所有字段(列)列表." 折叠 @禁止流程检查 = 真>
    {
        @ return @dt<数据库字段集合类2_>(@<记录集对象>.Invoke_CVolComObject(CVolComObject::IMT_GET_PROPERTY, _T("Fields"), 0, _T ("")));
    }

    方法 取所有字段名 <公开 类型 = 文本数组类 注释 = "获取当前数据表中所有字段名称" 折叠>
    参数 记录集 <类型 = 记录集类2_>
    {
        变量 数据库字段 <类型 = 数据库字段集合类2_>
        变量 当前字段 <类型 = 数据库字段类2_>
        变量 字段组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        数据库字段 = 记录集.取字段列表 ()
        循环 (, 数据库字段.成员数, i)
        {
            当前字段 = 数据库字段.取成员 (i)
            字段组.加入成员 (当前字段.名称)
        }
        返回 (字段组)
    }

