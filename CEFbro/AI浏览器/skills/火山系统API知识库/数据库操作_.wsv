}

类 记录集类_ <公开 基础类 = COM对象类 注释 = "表示数据表中的整个记录集或执行的命令的结果,可使用本类实例获取具体数据." 折叠 @文档 = "category = \"ADO数据库.ADO数据库1\"">
{

    # @ @m<数据库类_.DECLARE_ADO_COMOBJ_EXTRA_INIT>(记录集类_, 初始化事件挂接)

    变量 事件对象 <类型 = COM对象事件类>
    变量 语句错误描述信息 <类型 = 文本型 值 = "还未连接数据库">

    方法 当前页 <公开 属性读 类型 = 整数 注释 = "获取当前所处的页索引." 折叠>
    {
        返回 (读无参数属性 ("AbsolutePage", 整数))
    }

    方法 当前页 <公开 属性写 注释 = "设置当前所处的页索引." 折叠>
    参数 索引 <类型 = 整数>
    {
        写属性 ("AbsolutePage", 索引)
    }

    方法 当前位置 <公开 属性读 类型 = 变整数 注释 = "获取当前记录集所处的序号位置." 折叠>
    {
        返回 (读无参数属性 ("AbsolutePosition", 变整数))
    }

    方法 当前位置 <公开 属性写 注释 = "设置当前记录集所处的序号位置." 折叠>
    参数 位置 <类型 = 变整数>
    {
        写属性 ("AbsolutePosition", 位置)
    }

    方法 首记录前 <公开 属性读 类型 = 逻辑型 注释 = "判断当前记录位置是否处于首记录之前,通常用于判断该记录集是否存在数据." 折叠>
    {
        返回 (读无参数属性 ("BOF", 逻辑型))
    }

    方法 尾记录后 <公开 属性读 类型 = 逻辑型 注释 = "判断当前记录位置是否处于尾记录之后,通常用于判断当前位置后是否还存在更多记录." 折叠>
    {
        返回 (读无参数属性 ("EOF", 逻辑型))
    }

    方法 缓存数量 <公开 属性读 类型 = 整数 注释 = "获取当前记录集对象缓存到内存中的记录数量." 折叠>
    {
        返回 (读无参数属性 ("CacheSize", 整数))
    }

    方法 缓存数量 <公开 属性写 注释 = "设置当前记录集对象缓存到内存中的记录数量." 折叠>
    参数 数量 <类型 = 整数 注释 = "必须大于等于1.">
    {
        写属性 ("CacheSize", 数量)
    }

    方法 游标服务位置 <公开 属性写 注释 = "指定游标服务位置,请参考\"数据库游标服务位置_\"所提供的常量." 折叠>
    参数 位置 <类型 = 整数>
    {
        写属性 ("CursorLocation", 位置)
    }

    方法 游标服务位置 <公开 属性读 类型 = 整数 注释 = "获取游标服务位置." 返回值注释 = "请参考\"数据库游标服务位置_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("CursorLocation", 整数))
    }

    方法 游标类型 <公开 属性写 注释 = "指定所欲使用游标的类型,请参考\"记录集游标类型_\"所提供的常量." 折叠>
    参数 类型 <类型 = 整数>
    {
        写属性 ("CursorType", 类型)
    }

    方法 游标类型 <公开 属性读 类型 = 整数 注释 = "获取所使用游标的类型." 返回值注释 = "请参考\"记录集游标类型_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("CursorType", 整数))
    }

    方法 编辑状态 <公开 属性读 类型 = 整数 注释 = "获取当前记录集的编辑状态." 返回值注释 = "请参考\"记录集编辑状态_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("EditMode", 整数))
    }

    方法 书签 <公开 属性写 注释 = "在记录集的当前位置设置一个书签,即一个自定义标识符,后续移动不同的位置后,可通过该书签快速返回到标记书签的位置." 折叠>
    参数 值 <类型 = COM变体型 注释 = "提供一个自定义标记.">
    {
        写属性 ("Bookmark", 值)
    }

    方法 书签 <公开 属性读 类型 = COM变体型 注释 = "获取当前位置所设置的书签." 折叠>
    {
        返回 (读无参数属性 ("Bookmark", COM变体型))
    }

    方法 过滤 <公开 属性写 注释 = "为当前记录集过滤出满足条件的新记录" 折叠>
    参数 过滤条件 <类型 = 文本型 注释 = "条件语句内容：由一个或单独子语句组成，例如由and或or运算符相连接">
    {
        变量 条件值 <类型 = COM变体型>
        条件值.赋值 (过滤条件)
        写属性 ("Filter", 条件值)
    }

    方法 筛选器 <公开 属性写 注释 = "为当前记录集设置一个数据筛选器." 折叠>
    参数 筛选条件 <类型 = COM变体型 注释 = "本参数可包含以下项之一:" 注释 = "  条件语句内容:由一个或单独子语句组成,例如由AND或or运算符相连接." 注释 = "  书签数组:获取所有打上书签位置的数据."
            注释 = "  筛选组:请参考\"记录集筛选组类型_\"所提供的常量.">
    {
        写属性 ("Filter", 筛选条件)
    }

    方法 筛选器 <公开 属性读 类型 = COM变体型 注释 = "获取当前记录集的筛选器." 折叠>
    {
        返回 (读无参数属性 ("Filter", COM变体型))
    }

    方法 索引名称 <公开 属性读 类型 = 文本型 注释 = "获取当前记录集对象索引名称." 折叠>
    {
        返回 (读无参数属性 ("Index", 文本型))
    }

    方法 索引名称 <公开 属性写 注释 = "设置当前记录集对象索引名称." 折叠>
    参数 名称 <类型 = 文本型>
    {
        写属性 ("Index", 名称)
    }

    方法 编辑锁类型 <公开 属性读 类型 = 整数 注释 = "获取当前记录集对象的编辑锁类型." 返回值注释 = "请参考\"记录集编辑锁类型_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("LockType", 整数))
    }

    方法 编辑锁类型 <公开 属性写 注释 = "设置当前记录集对象的编辑锁类型." 折叠>
    参数 类型 <类型 = 整数 注释 = "请参考\"记录集编辑锁类型_\"所提供的常量.">
    {
        写属性 ("LockType", 类型)
    }

    方法 数据封送选项 <公开 属性读 类型 = 整数 注释 = "获取当前记录集所设置的数据封送选项." 返回值注释 = "请参考\"记录集数据封送选项_\"所提供的常量." 折叠>
    {
        返回 (读无参数属性 ("MarshalOptions", 整数))
    }

    方法 数据封送选项 <公开 属性写 注释 = "设置当前记录集所设置的数据封送(跨线程或进程边界打包和发送接口方法参数的过程)选项." 折叠>
    参数 选项 <类型 = 整数 注释 = "请参考\"记录集数据封送选项_\"所提供的常量.">
    {
        写属性 ("MarshalOptions", 选项)
    }

    方法 最大记录数 <公开 属性读 类型 = 长整数 注释 = "获取该记录集所设置的最大记录数量限制." 折叠>
    {
        返回 (读无参数属性 ("MaxRecords", 长整数))
    }

    方法 最大记录数 <公开 属性写 注释 = "限定一个获取数据量的最大值,从数据源获取数据时将会受该属性限制." 折叠>
    参数 最大数量 <类型 = 长整数 注释 = "默认为0,表示无限制,将会返回所有记录.">
    {
        写属性 ("MaxRecords", 最大数量)
    }

    方法 页数 <公开 属性读 类型 = 整数 注释 = "获取当前记录集所包含的页数." 折叠>
    {
        返回 (读无参数属性 ("PageCount", 整数))
    }

    方法 单页记录数 <公开 属性读 类型 = 整数 注释 = "获取当前记录集一个页所包含的记录数量,即页数据尺寸." 折叠>
    {
        返回 (读无参数属性 ("PageSize", 整数))
    }

    方法 单页记录数 <公开 属性写 注释 = "设置当前记录集一个页所包含的记录数量." 折叠>
    参数 尺寸 <类型 = 整数 注释 = "默认为10.">
    {
        写属性 ("PageSize", 尺寸)
    }

    方法 记录数量 <公开 属性读 类型 = 整数 注释 = "获取该记录集所包含的记录数量(即数据行)." 折叠>
    {
        返回 (读无参数属性 ("RecordCount", 整数))
    }

    方法 排序规则 <公开 属性读 类型 = 文本型 注释 = "获取当前记录集对象所设置的排序规则." 折叠>
    {
        返回 (读无参数属性 ("Sort", 文本型))
    }

    方法 排序规则 <公开 属性写 注释 = "设置当前记录集对象的排序规则." 注释 = "注意:该属性将会优先于SQL语句的order by." 折叠 折叠2>
    参数 规则 <类型 = 文本型 注释 = "例如记录集中包含有三个字段:\"firstName\",\"middle\",\"lastName\","
            注释 = "该参数内容为\"lastName DESC, firstName ASC\",此时该记录集将会按照lastName降序,firstName升序来排列,中间的middle被忽略.">
