类 数据库集合类_ <公开 基础类 = COM对象类 注释 = "模板类型1为集合中的成员类型." 注释 = "模板类型2为实现类自身" 折叠 折叠2 @文档 = "category = \"ADO数据库.ADO数据库1.附加类\""
        @模板基础类 = 真>
{

    # @ @m<数据库类_.DECLARE_ADO_COMOBJ>(模板类型2)

    方法 成员数 <公开 属性读 类型 = 整数 注释 = "获取该集合中所包含的成员数量." 折叠>
    {
        返回 (读无参数属性 ("Count", 整数))
    }

    方法 刷新 <公开 类型 = 逻辑型 注释 = "刷新该集合." 返回值注释 = "返回调用结果." 折叠>
    {
        返回 (无参数及返回值方法 ("Refresh"))
    }

    方法 取成员 <公开 类型 = 模板类型1 注释 = "获取该集合中所包含的指定成员." 折叠>
    参数 索引 <类型 = 整数>
    {
        返回 ((模板类型1)读属性 ("Item", COM对象类, 索引))
    }

    方法 取成员2 <公开 类型 = 模板类型1 注释 = "以指定的成员名称获取该成员对象." 折叠>
    参数 成员名 <类型 = 文本型>
    {
        返回 ((模板类型1)读属性 ("Item", COM对象类, 成员名))
    }
}

