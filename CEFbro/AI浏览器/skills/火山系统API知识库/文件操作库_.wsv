    方法 开始监视 <公开 折叠>
    参数 监视目录 <类型 = 文本型 注释 = "例如：“C:\\\\目录A”" @默认值 = "">
    参数 预计文件数量 <类型 = 整数 注释 = "预设瞬间文件变动缓存数" @默认值 = 5000>
    {
        集监视目录 = 监视目录
        集预设数量 = 预计文件数量
        处理事件_ ()
        是否停止 = 真
        线程.启动 ()
    }

    方法 开始监视2 <折叠>
    参数 监视目录 <类型 = 文本型 注释 = "例如：“C:\\\\目录A”" @默认值 = "">
    参数 预计文件数量 <类型 = 整数 注释 = "预设瞬间文件变动缓存数" @默认值 = 5000>
    {
        变量 临时名 <类型 = 文本型>
        变量 临时名2 <类型 = 文本型>
        变量 临时路径 <类型 = 文本型>
        @ DirectoryWatcher watcher(@<监视目录>.GetText(), @<预计文件数量>);
        @ watcher.start();
        @ while (@<是否停止>) {
        @ auto changes = watcher.getChanges();
        @ for (const auto& change : changes) {
        @ switch (change.type) {
        @ case DirectoryWatcher::ChangeType::Added:
        @ @<临时名>=change.filename.c_str();
        @ @<临时路径>=change.fullPath.c_str();
        文件变动事件 (0, 临时名, 临时名, 临时路径)
        @ break;
        @ case DirectoryWatcher::ChangeType::Removed:
        @ @<临时名>=change.filename.c_str();
        @ @<临时路径>=change.fullPath.c_str();
        文件变动事件 (1, 临时名, 临时名, 临时路径)
        @ break;
        @ case DirectoryWatcher::ChangeType::Modified:
        @ @<临时名>=change.filename.c_str();
        @ @<临时路径>=change.fullPath.c_str();
        文件变动事件 (2, 临时名, 临时名, 临时路径)
        @ break;
        @ case DirectoryWatcher::ChangeType::RenamedOld:
        @ break;
        @ case DirectoryWatcher::ChangeType::RenamedNew:
        @ @<临时名>=change.oldFilename.c_str();
        @ @<临时名2>=change.filename.c_str();
        @ @<临时路径>=change.fullPath.c_str();
        文件变动事件 (3, 临时名, 临时名2, 临时路径)
        @ break;
        @ }
        @ }
        @ }
    }

    方法 停止监视 <公开 折叠>
    {
        是否停止 = 假
    }

    方法 线程类_线程运行 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程类>
    参数 标记值 <类型 = 整数>
    {
        开始监视2 (集监视目录, 集预设数量)
        返回 (0)
    }

    方法 文件变动事件 <公开 定义事件 类型 = 整数 折叠>
    参数 变动类型 <类型 = 整数 注释 = "0、新建文件　1、删除文件　2、修改内容　3、重命名文件">
    参数 原文件名 <类型 = 文本型>
    参数 新文件名 <类型 = 文本型>
    参数 完整路径 <类型 = 文本型>
}

# //====浏览目录文件操作====

类 文件定位类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件浏览\"" @全局类 = 真>
{
    方法 文件_定位打开文件 <公开 静态 类型 = 逻辑型 注释 = "打开文件所在目录并选中文件" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<shlwapi.h>" @视窗.外部库 = "shlwapi.lib" "">
    参数 文件路径 <类型 = 文本型>
    参数 编辑模式 <类型 = 逻辑型 @默认值 = 假>
    {
        @ #define OFASI_EDIT          0x0001
        @ if (!PathFileExistsW(@<文件路径>.GetText())) return false;
        @ LPITEMIDLIST pidl = ILCreateFromPathW(@<文件路径>.GetText());
        @ if (!pidl) return false;
        @ DWORD dwFlags = 0;
        @ if (@<编辑模式>) dwFlags = OFASI_EDIT;
        @ HRESULT hr = SHOpenFolderAndSelectItems(pidl, 0, NULL, dwFlags);
        @ ILFree(pidl);
        @ return (hr == S_OK);
    }

    方法 文件_定位打开文件_多文件 <公开 静态 类型 = 逻辑型 注释 = "打开文件所在目录并选中文件" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<shlwapi.h>" @视窗.外部库 = "shlwapi.lib">
    参数 文件路径 <类型 = 文本数组类 注释 = "需提供文件或文件夹的绝对路径">
    {
        变量 文件所在目录 <类型 = 文本型>
        变量 szFile <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 n <类型 = 整数>
        n = 文件路径.取成员数 ()
        如果 (n > 0)
        {
            文件所在目录 = 取文本左边2_ (文件路径.取成员 (0), "\\")
            @ if (!PathIsDirectoryW(@<文件所在目录>.GetText())) return false;
            @ ITEMIDLIST* pidl = ILCreateFromPathW(@<文件所在目录>.GetText());
            @ if (!pidl) return false;
            @ LPITEMIDLIST* items = new LPITEMIDLIST[@<n>];
            循环 (0, n, i, 1)
            {
                szFile = 文件路径.取成员 (i)
                @ items[@<i>] = ILCreateFromPathW(@<szFile>.GetText());
            }
            @ CoInitialize(NULL);
            @ HRESULT hr = SHOpenFolderAndSelectItems(pidl, @<n>, (LPCITEMIDLIST*)items, 0);
            @ CoUninitialize();
            @ for (size_t i = 0; i < @<n>; i++)
            @     ILFree(items[i]);
            @ delete[] items;
            @ ILFree(pidl);
            @ return hr == S_OK;
        }
        否则
        {
            返回 (假)
        }
    }
}

类 文件浏览类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件浏览\"" @全局类 = 真>
{
    方法 浏览选择文件_ <公开 静态 类型 = 文本型 返回值注释 = "成功返回选中的文件名，失败或未选择则返回空文本" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "父窗口的句柄，0表示无父窗口" @默认值 = 0>
    参数 对话框标题 <类型 = 文本型 @默认值 = 空对象>
    参数 默认文件名 <类型 = 文本型 注释 = "用作初始化对话框中的文件名" @默认值 = "">
    参数 过滤器 <类型 = 文本型 注释 = "例如 \"MP4文件(*.mp4;*.m4a)|*.mp4;*.m4a|所有文件(*.*)|*.*\"" @默认值 = "所有文件(*.*)|*.*">
    参数 初始过滤器 <类型 = 整数 注释 = "指定初始过滤器在\"过滤器\"属性中的索引位置(从1开始)," 注释 = "0为不指定初始过滤器,以第一个过滤器为初始项." @默认值 = 0>
    参数 初始目录 <类型 = 文本型 注释 = "指定打开对话框时自动跳转到的目录" @默认值 = 空对象>
    参数 默认文件后缀 <类型 = 文本型 注释 = "当用户没有输入文件的后缀名称时,自动使用这里的文件后缀名称." @默认值 = 空对象>
    参数 创建时提示 <类型 = 逻辑型 注释 = "如果输入的文件不存在,提示是否创建文件" @默认值 = 假>
    参数 禁止解析快捷方式 <类型 = 逻辑型 注释 = "选择快捷方式时默认解析为它指向的目标文件,设置为真时返回快捷方式文件本身." @默认值 = 假>
    参数 不改变目录 <类型 = 逻辑型 注释 = "是否在对话框关闭后,将\"当前目录\"还原为打开对话框之前的目录." @默认值 = 假>
    参数 启用对话框 <类型 = 逻辑型 注释 = "指定一个自定义对话框模板" @默认值 = 假>
    {
        @ OPENFILENAMEW ofn { 0 };
        @ ofn.lStructSize = sizeof (OPENFILENAMEW);
        @ ofn.hwndOwner = @<父窗口句柄> ? (HWND)@<父窗口句柄> : NULL;
        @ @an<CVolMem> szFilter;
        @ if (@<过滤器>.IsEmpty ()) {
        @     ofn.lpstrFilter = NULL;
        @ } else {
        @     szFilter.AddTextValue (@<过滤器>, TRUE);
        @     szFilter.ReplaceBin (CVolMem (_CT ("|")), CVolMem ().AddManyBytes (2, 0, 0), 0, 0);
        @     szFilter.AddWord (0);
        @     ofn.lpstrFilter = reinterpret_cast<const WCHAR*>(szFilter.GetPtr ());
        @ }
        @ ofn.lpstrInitialDir = @<初始目录>.IsEmpty () ? NULL : @<初始目录>.GetText ();
        @ WCHAR szBuffer[MAX_PATH * 4];
        @ if (@<默认文件名>.IsEmpty ())
        @     szBuffer[0] = '\0';
        @ else
        @     wcscpy_s (szBuffer, MAX_PATH * 4, @<默认文件名>.GetText ());
        @ ofn.lpstrFile = szBuffer;
        @ ofn.lpstrTitle = @<对话框标题>.IsEmpty () ? NULL : @<对话框标题>.GetText ();
        @ ofn.nMaxFile = sizeof (szBuffer);
        @ ofn.nFilterIndex = static_cast<DWORD>(@<初始过滤器>);
        @ ofn.lpstrDefExt = @<默认文件后缀>.IsEmpty () ? NULL : @<默认文件后缀>.GetText ();
        @ ofn.Flags = OFN_EXPLORER | OFN_HIDEREADONLY | OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST;
        @ if (@<创建时提示>) ofn.Flags |= OFN_CREATEPROMPT;
        @ if (@<禁止解析快捷方式>) ofn.Flags |= OFN_NODEREFERENCELINKS;
        @ if (@<不改变目录>) ofn.Flags |= OFN_NOCHANGEDIR;
        @ if (@<启用对话框>) ofn.Flags |= OFN_ENABLETEMPLATE;
        @ if (::GetOpenFileNameW (&ofn)) {
        @     @<默认文件名>.SetText (ofn.lpstrFile);
        @     return ofn.lpstrFile;
        @ }
        @ @<默认文件名>.Empty ();
        @ return _T("");
    }

    方法 文件_浏览选择文件 <公开 类型 = 文本型 折叠>
    {
        返回 (浏览选择文件_ ())
    }

    方法 浏览选择多文件_ <公开 静态 类型 = 文本数组类 返回值注释 = "成功返回文件列表数组" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "父窗口的句柄,0表示无父窗口" @默认值 = 0>
    参数 对话框标题 <类型 = 文本型 @默认值 = 空对象>
    参数 过滤器 <类型 = 文本型 注释 = "例如 \"MP4文件(*.mp4;*.m4a)|*.mp4;*.m4a|所有文件(*.*)|*.*\"" @默认值 = "所有文件(*.*)|*.*">
    参数 初始过滤器 <类型 = 整数 注释 = "指定初始过滤器在\"过滤器\"属性中的索引位置(从1开始)," 注释 = "0为不指定初始过滤器,以第一个过滤器为初始项." @默认值 = 0>
    参数 初始目录 <类型 = 文本型 注释 = "指定打开对话框时自动跳转到的目录" @默认值 = 空对象>
    参数 不改变目录 <类型 = 逻辑型 注释 = "是否在对话框关闭后,将\"当前目录\"还原为打开对话框之前的目录." @默认值 = 假>
    参数 启用对话框 <类型 = 逻辑型 注释 = "指定一个自定义对话框模板" @默认值 = 假>
    {
        变量 文件名列表 <类型 = 文本数组类>
        @ @<文件名列表>.data ().RemoveAll ();
        @ OPENFILENAMEW ofn { 0 };
        @ ofn.lStructSize = sizeof (OPENFILENAMEW);
        @ ofn.hwndOwner = @<父窗口句柄> ? (HWND)@<父窗口句柄> : NULL;
        @ @an<CVolMem> szFilter;
        @ if (@<过滤器>.IsEmpty ()) {
        @     ofn.lpstrFilter = NULL;
        @ } else {
        @     szFilter.AddTextValue (@<过滤器>, TRUE);
        @     szFilter.ReplaceBin (CVolMem (_CT ("|")), CVolMem ().AddManyBytes (2, 0, 0), 0, 0);
        @     szFilter.AddWord (0);
        @     ofn.lpstrFilter = reinterpret_cast<const WCHAR*>(szFilter.GetPtr ());
        @ }
        @ ofn.lpstrInitialDir = @<初始目录>.IsEmpty () ? NULL : @<初始目录>.GetText ();
        @ WCHAR szBuffer[MAX_PATH * 512] { 0 }; // 缓冲区大小决定文件数量
        @ ofn.lpstrFile = szBuffer;
        @ ofn.lpstrTitle = @<对话框标题>.IsEmpty () ? NULL : @<对话框标题>.GetText ();
        @ ofn.nMaxFile = sizeof (szBuffer);
        @ ofn.nFilterIndex = static_cast<DWORD>(@<初始过滤器>);
        @ ofn.Flags = OFN_EXPLORER | OFN_HIDEREADONLY | OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST | OFN_ALLOWMULTISELECT | OFN_NODEREFERENCELINKS;
        @ if (@<不改变目录>) ofn.Flags |= OFN_NOCHANGEDIR;
        @ if (@<启用对话框>) ofn.Flags |= OFN_ENABLETEMPLATE;
        @ if (::GetOpenFileNameW (&ofn)) {
        @     @an<CVolString> szPath {szBuffer, ofn.nFileOffset};
        @     szPath.CheckAddPathChar ();
        @     WCHAR* p = szBuffer + ofn.nFileOffset;
        @     while (*p) {
        @         @an<CVolString> szFileName;
        @         szFileName.AddText (szPath);
        @         szFileName.AddText (p);
        @         @<文件名列表>.data ().Add (szFileName);
        @         p += wcslen (p) + 1;
        @     }
        @     return @<文件名列表>;
        @ }
        @ return @<文件名列表>;
    }

    方法 文件_浏览选择多文件 <公开 类型 = 文本数组类 折叠>
    {
        返回 (浏览选择多文件_ ())
    }

    方法 浏览选择文件夹_ <公开 静态 类型 = 文本型 注释 = "只限于MFC中使用" 折叠 @禁止流程检查 = 真>
    参数 初始目录 <类型 = 文本型 @默认值 = "">
    {
        @  CWString workingDirectory;
        @ if(@<初始目录>!=_T("")){workingDirectory=@<初始目录>;}
        @  CWString m_strFolderPath;
        @  CFolderPickerDialog dlg(workingDirectory, 0, NULL, 0); 
        @  if (dlg.DoModal()==IDOK) 
        @  {
        @     m_strFolderPath = dlg.GetPathName() ;
        @     return m_strFolderPath;
        @  }
        @     return _T("");
    }

    方法 文件_浏览选择文件夹 <公开 类型 = 文本型 折叠>
    {
        返回 (浏览选择文件夹_ ())
    }

    方法 浏览选择文件夹2_ <公开 静态 类型 = 文本型 注释 = "支持文件和文件夹，支持非MFC使用" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "父窗口的句柄，0表示无父窗口" @默认值 = 0>
    参数 标题 <类型 = 文本型 @默认值 = "请选择一个文件或文件夹">
    参数 文件是否可选 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 结果变量 <类型 = 文本型>
        @ BROWSEINFO inf; 
        @ ZERO_MEM (&inf, sizeof (inf)); 
        @ inf.hwndOwner = @<父窗口句柄> ? (HWND)@<父窗口句柄> : NULL; 
        @ TCHAR path [MAX_PATH]; 
        @ path [0] = '\0'; 
        @ inf.pszDisplayName = path; 
        @ inf.lpszTitle = @<标题>.GetText ();
        @ inf.ulFlags = BIF_EDITBOX | BIF_NEWDIALOGSTYLE;
        @ if (@<文件是否可选>)
        @ inf.ulFlags |= BIF_BROWSEINCLUDEFILES; LPITEMIDLIST pItem = SHBrowseForFolder (&inf); 
        @ if (pItem != NULL)
        @  {
        @ path [0] = '\0';
        @ if (SHGetPathFromIDList (pItem, path))
        @ @<结果变量>.SetText (path);
        @ IMalloc* pMalloc;
        @ if (SUCCEEDED (SHGetMalloc (&pMalloc)))
        @ {
        @ pMalloc->Free (pItem);
        @ pMalloc->Release ();
        @ }
        @  } 
        返回 (结果变量)
    }

    方法 文件_浏览选择文件夹2 <公开 类型 = 文本型 折叠>
    {
        返回 (浏览选择文件夹2_ ())
    }

    方法 浏览选择保存文件_ <公开 静态 类型 = 文本型 返回值注释 = "成功返回保存路径名" 折叠 @禁止流程检查 = 真>
    参数 父窗口句柄 <类型 = 变整数 注释 = "父窗口的句柄，0：表示无父窗口" @默认值 = 0>
    参数 对话框标题 <类型 = 文本型 注释 = "文件对话框的标题，默认为\"保存\"" @默认值 = 空对象>
