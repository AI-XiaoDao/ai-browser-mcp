    }

    方法 删除文件2_ <公开 静态 类型 = 逻辑型 注释 = "支持删除文件和目录" 折叠>
    参数 文件名 <类型 = 文本型>
    {
        如果真 (文件是否存在 (文件名))
        {
            变量 结果 <类型 = 文本型>
            变量 结果2 <类型 = 文本型>
            如果 (位与 (取文件属性 (文件名), 文件属性.子目录) != 0)
            {
                运行控制台程序 ("cmd /c rd /s /q " + "\"" + 文件名 + "\"", , 结果)
            }
            否则
            {
                运行控制台程序 ("cmd /c del /f /q " + "\"" + 文件名 + "\"", , 结果2)
            }
            如果 (文本是否为空 (结果) == 假 || 文本是否为空 (结果2) == 假)
            {
                返回 (假)
            }
            否则
            {
                返回 (真)
            }
        }
        返回 (假)
    }

    方法 删除文件_强制 <公开 静态 类型 = 逻辑型 折叠>
    参数 文件名 <类型 = 文本型>
    {
        变量 目录 <类型 = 文本型>
        变量 目录2 <类型 = 文本型>
        变量 目录3 <类型 = 文本型>
        变量 目录4 <类型 = 文本型>
        目录 = 取特定目录 (特定目录类型.临时文件目录) + 到文本 (取时间戳 (取现行时间 ()))
        @  CreateDirectoryW((LPCWSTR)@<目录>.GetText(),NULL);
        目录2 = 目录 + "\\....\\"
        @ CreateDirectoryW((LPCWSTR)@<目录2>.GetText(),NULL);
        目录3 = 目录2 + "TemporaryFile"
        @  MoveFileW((LPCWSTR)@<文件名>.GetText(),(LPCWSTR)@<目录3>.GetText());
        目录4 = 目录 + "\\TemporaryFile"
        @  MoveFileW((LPCWSTR)@<目录2>.GetText(),(LPCWSTR)@<目录4>.GetText());
        删除目录 (目录, 目录删除模式.全部删除, )
        返回 (取反 (文件是否存在 (文件名)))
    }
}

# //====枚举目录文件====

类 文件枚举类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件枚举\"" @全局类 = 真>
{
    方法 枚举文件_ <公开 静态 类型 = 整数 注释 = "支持枚举文件和文件夹" 折叠 @禁止流程检查 = 真>
    参数 欲枚举的目录 <类型 = 文本型>
    参数 欲查找的文件名 <类型 = 文本型 注释 = "* 为枚举所有文件;" 注释 = "支持：1、*　2、*.*　3、aa.*　4、*.jpg　5、aa.jpg" 折叠2 @默认值 = "*">
    参数 返回的枚举文件 <类型 = 文本数组类 注释 = "需要带路径，请将“是否返回路径”设置为真" @默认值 = 空对象>
    参数 返回的枚举目录 <类型 = 文本数组类 @默认值 = 空对象>
    参数 是否返回路径 <类型 = 逻辑型 注释 = "为真时，“返回枚举文件”里则会带上路径" @默认值 = 假>
    参数 是否枚举子目录 <类型 = 逻辑型 @默认值 = 假>
    参数 是否枚举隐藏文件 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时文件 <类型 = 文本数组类>
        变量 临时目录 <类型 = 文本数组类>
        变量 临时目录2 <类型 = 文本数组类>
        变量 数量 <类型 = 整数>
        变量 i <类型 = 整数>
        变量 结果1 <类型 = 整数>
        变量 结果2 <类型 = 整数>
        变量 选择类型 <类型 = 整数>
        结果1 = 寻找文本 (欲查找的文件名, ".*")
        结果2 = 寻找文本 (欲查找的文件名, "*.")
        如果真 (是否枚举子目录 == 真 && 欲查找的文件名 != "*" && 欲查找的文件名 != "*.*")
        {
            如果真 (结果1 > 0 || 结果2 > 0 || 结果1 == -1 || 结果2 == -1)
            {
                选择类型 = 1
            }
        }
        如果 (选择类型 == 1)
        {
            enumeration (欲枚举的目录, 欲查找的文件名, 临时文件, 临时目录, 是否返回路径, , 是否枚举隐藏文件)
            返回的枚举文件.添加数组 (临时文件)
            返回的枚举目录.添加数组 (临时目录2)
            临时文件.删除所有成员 ()
            临时目录2.删除所有成员 ()
            如果真 (是否枚举子目录 == 真)
            {
                enumeration (欲枚举的目录, , , 临时目录, 真, 真, 是否枚举隐藏文件)
                循环 (, 临时目录.取成员数 (), i)
                {
                    enumeration (临时目录.取成员 (i), 欲查找的文件名, 临时文件, 临时目录2, 是否返回路径, , 是否枚举隐藏文件)
                    返回的枚举文件.添加数组 (临时文件)
                    返回的枚举目录.添加数组 (临时目录2)
                    临时文件.删除所有成员 ()
                    临时目录2.删除所有成员 ()
                }
            }
            数量 = 返回的枚举文件.取成员数 ()
        }
        否则
        {
            数量 = enumeration (欲枚举的目录, 欲查找的文件名, 返回的枚举文件, 返回的枚举目录, 是否返回路径, 是否枚举子目录, 是否枚举隐藏文件)
        }
        返回 (数量)
    }

    方法 文件_枚举文件 <公开 静态 类型 = 整数 注释 = "支持枚举文件和文件夹" 折叠 @禁止流程检查 = 真>
    参数 欲枚举的目录 <类型 = 文本型>
    参数 欲查找的文件名 <类型 = 文本型 注释 = "* 为枚举所有文件;" 注释 = "支持：1、*　2、*.*　3、aa.*　4、*.jpg　5、aa.jpg" 折叠2 @默认值 = "*">
    参数 返回的枚举文件 <类型 = 文本数组类 注释 = "需要带路径，请将“是否返回路径”设置为真" @默认值 = 空对象>
    参数 返回的枚举目录 <类型 = 文本数组类 @默认值 = 空对象>
    参数 是否返回路径 <类型 = 逻辑型 注释 = "为真时，“返回枚举文件”里则会带上路径" @默认值 = 假>
    参数 是否枚举子目录 <类型 = 逻辑型 @默认值 = 假>
    参数 是否枚举隐藏文件 <类型 = 逻辑型 @默认值 = 假>
    {
        返回 (枚举文件_ (欲枚举的目录, 欲查找的文件名, 返回的枚举文件, 返回的枚举目录, 是否返回路径, 是否枚举子目录, 是否枚举隐藏文件))
    }

    方法 文件_删除空文件夹 <公开 静态 类型 = 整数 注释 = "删除指定目录中所有空文件夹" 返回值注释 = "返回删除的总数量" 折叠>
    参数 欲操作的目录 <类型 = 文本型 注释 = "例如：“C:\\\\测试目录”">
    {
        变量 目录组 <类型 = 文本数组类>
        变量 数量 <类型 = 整数>
        枚举文件_ (欲操作的目录, , , 目录组, 真, 真, 真)
        目录组.枚举循环 ()
        {
            如果真 (RemoveDirectoryW (目录组.取枚举值 ()))
            {
                数量 = 数量 + 1
            }
        }
        返回 (数量)
    }

    方法 RemoveDirectoryW <静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    {
        @ return RemoveDirectoryW(@<路径>);
    }

    方法 enumeration <静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 欲枚举的目录 <类型 = 文本型>
    参数 欲查找的文件名 <类型 = 文本型 注释 = "* 为枚举所有文件" @默认值 = "*">
    参数 返回枚举文件 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回枚举目录 <类型 = 文本数组类 @默认值 = 空对象>
    参数 是否返回路径 <类型 = 逻辑型 @默认值 = 假>
    参数 是否枚举子目录 <类型 = 逻辑型 @默认值 = 假>
    参数 是否枚举隐藏文件 <类型 = 逻辑型 @默认值 = 假>
    {
        常量 INVALID_HANDLE_VALUE <类型 = 变整数 值 = -1>
        常量 MAX_PATH <类型 = 整数 值 = 260>
        常量 存档文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_ARCHIVE>
        常量 子目录 <类型 = 整数 值 = @FILE_ATTRIBUTE_DIRECTORY>
        常量 隐藏文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_HIDDEN>
        常量 通常文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_NORMAL>
        常量 只读文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_READONLY>
        常量 系统文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_SYSTEM>
        常量 临时文件 <类型 = 整数 值 = @FILE_ATTRIBUTE_TEMPORARY>
        变量 文件路径 <类型 = 文本型>
        变量 hFind <类型 = 变整数>
        变量 文件结构体 <类型 = WIN32_FIND_DATAW_>
        变量 文件名称 <类型 = 文本型>
        变量 bRes <类型 = 逻辑型>
        如果 (取文本右边 (欲枚举的目录, 1) != "\\")
        {
            文件路径 = 欲枚举的目录 + "\\"
        }
        否则
        {
            文件路径 = 欲枚举的目录
        }
        如果真 (是否枚举子目录 == 假)
        {
            返回枚举文件.删除所有成员 ()
        }
        hFind = FindFirstFileW_ (文件路径 + 欲查找的文件名, 文件结构体)
        如果真 (hFind == INVALID_HANDLE_VALUE)
        {
            返回 (0)
        }
        循环判断首 ()
        {
            文件名称 = 字符数组到文本 (文件结构体.文件名称, MAX_PATH)
            如果真 (文件名称 != "." && 文件名称 != "..")
            {
                如果真 (是否枚举子目录 && 位与 (文件结构体.文件属性, 子目录) != 0)
                {
                    enumeration (文件路径 + 文件名称 + "\\", 欲查找的文件名, 返回枚举文件, 返回枚举目录, 是否返回路径, 是否枚举子目录)
                }
                如果 (位与 (文件结构体.文件属性, 子目录) != 0)
                {
                    如果 (是否枚举隐藏文件 == 假)
                    {
                        如果真 (位与 (文件结构体.文件属性, 隐藏文件) == 0)
                        {
                            如果 (是否返回路径)
                            {
                                返回枚举目录.加入成员 (文件路径 + 文件名称)
                            }
                            否则
                            {
                                返回枚举目录.加入成员 (文件名称)
                            }
                        }
                    }
                    否则
                    {
                        如果 (是否返回路径)
                        {
                            返回枚举目录.加入成员 (文件路径 + 文件名称)
                        }
                        否则
                        {
                            返回枚举目录.加入成员 (文件名称)
                        }
                    }
                }
                否则
                {
                    如果 (是否枚举隐藏文件 == 假)
                    {
                        如果真 (位与 (文件结构体.文件属性, 隐藏文件) == 0)
                        {
                            如果 (是否返回路径)
                            {
                                返回枚举文件.加入成员 (文件路径 + 文件名称)
                            }
                            否则
                            {
                                返回枚举文件.加入成员 (文件名称)
                            }
                        }
                    }
                    否则
                    {
                        如果 (是否返回路径)
                        {
                            返回枚举文件.加入成员 (文件路径 + 文件名称)
                        }
                        否则
                        {
                            返回枚举文件.加入成员 (文件名称)
                        }
                    }
                }
            }
            bRes = FindNextFileW_ (hFind, 文件结构体)
        }
        循环判断尾 (bRes)
        FindClose_ (hFind)
        返回 (返回枚举文件.取成员数 ())
    }

    方法 FindClose_ <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "FindClose" @视窗.输入 = "Kernel32.dll">
    参数 hFindFile <类型 = 变整数 "">

    方法 FindNextFileW_ <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "FindNextFileW" @视窗.输入 = "Kernel32.dll">
    参数 hFindFile <类型 = 变整数>
    参数 lpFindFileData <类型 = WIN32_FIND_DATAW_ @视窗.输出参数 = 真>

    方法 FindFirstFileW_ <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "FindFirstFileW" @视窗.输入 = "Kernel32.dll">
    参数 lpFileName <类型 = 文本型>
    参数 lpFindFileData <类型 = WIN32_FIND_DATAW_ @视窗.输出参数 = 真>
}

类 WIN32_FIND_DATAW_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件枚举.附加类\"" @视窗.结构类 = 0>
{
    变量 文件属性 <公开 类型 = 整数>
    变量 ftCreationTime <公开 类型 = FILETIME_>
    变量 ftLastAccessTime <公开 类型 = FILETIME_>
    变量 ftLastWriteTime <公开 类型 = FILETIME_>
    变量 nFileSizeHigh <公开 类型 = 整数>
    变量 nFileSizeLow <公开 类型 = 整数>
    变量 dwReserved0 <公开 类型 = 整数>
    变量 dwReserved1 <公开 类型 = 整数>
    变量 文件名称 <公开 类型 = "字符 [260]">
    变量 cAlternateFileName <公开 类型 = "字符 [14]">
}

类 FILETIME_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件枚举.附加类\"" @视窗.结构类 = 0>
{
    变量 dwLowDateTime <公开 类型 = 整数>
    变量 dwHighDateTime <公开 类型 = 整数>
}

# //====窗口文件拖放操作====

类 文件拖放类_ <公开 折叠 @文档 = "category = \"文件操作类.文件拖放\"">
{
    变量 m_hWnd <类型 = 变整数>
    变量 m_WndFunc <类型 = 变整数>
    变量 m_dwNewLong <类型 = 变整数>
    变量 是否开启 <类型 = 逻辑型>

    常量 GWLP_WNDPROC <类型 = 整数 值 = -4 折叠>
    常量 WM_COPYDATA <类型 = 整数 值 = 74>
    常量 WM_DROPFILES <类型 = 整数 值 = 563>
    常量 MSGFLT_ADD <类型 = 整数 值 = 1>

    方法 启用拖放_ <公开 折叠>
    参数 绑定组件句柄 <类型 = 变整数>
    {
        如果真 (是否开启 == 假)
        {
            m_hWnd = 绑定组件句柄
            m_WndFunc = 取对象自身指针 ()
            拖放api.DragAcceptFiles (m_hWnd, 真)
            m_dwNewLong = 拖放api.SetWindowLongW64_32 (m_hWnd, GWLP_WNDPROC, 取静态方法地址 (拖放对象回调))
            拖放api.SetPropW (m_hWnd, "lpWndFunc", m_WndFunc)
            拖放api.SetPropW (m_hWnd, "lpdwNewLong", m_dwNewLong)
            拖放api.ChangeWindowMessageFilter (WM_DROPFILES, MSGFLT_ADD)
            拖放api.ChangeWindowMessageFilter (WM_COPYDATA, MSGFLT_ADD)
            拖放api.ChangeWindowMessageFilter (73, MSGFLT_ADD)
        }
        是否开启 = 真
    }

    方法 撤销拖放_ <公开 折叠>
    参数 所绑定的组件句柄 <类型 = 变整数>
    {
        如果真 (是否开启)
        {
            拖放api.DragAcceptFiles (所绑定的组件句柄, 假)
            拖放api.SetWindowLongW64_32 (所绑定的组件句柄, GWLP_WNDPROC, m_dwNewLong)
            拖放api.RemovePropW (所绑定的组件句柄, "lpWndFunc")
            拖放api.RemovePropW (所绑定的组件句柄, "lpdwNewLong")
        }
        是否开启 = 假
    }

    方法 回调过程 <折叠>
    参数 文件名 <类型 = 文本数组类>
    {
        拖放事件 (文件名)
    }

    方法 拖放事件 <公开 定义事件 类型 = 整数 折叠>
    参数 接收到的文件 <类型 = 文本数组类>

    方法 拖放对象回调 <静态 类型 = 变整数 折叠 折叠2 @禁止流程检查 = 真 @视窗.前缀文本 = "@WINAPI">
    参数 hWnd <类型 = 变整数>
    参数 Msg <类型 = 整数>
    参数 wParam <类型 = 变整数>
    参数 lParam <类型 = 变整数>
    {
        变量 动态DLL <类型 = 动态链接库类_>
        变量 WndFunc <类型 = 变整数>
        变量 dwNewLong <类型 = 变整数>
        变量 szFile <类型 = 文本型>
        变量 nFilesCount <类型 = 整数>
        变量 文件组 <类型 = 文本数组类>
        变量 i <类型 = 整数>
        WndFunc = 拖放api.GetPropW (hWnd, "lpWndFunc")
        dwNewLong = 拖放api.GetPropW (hWnd, "lpdwNewLong")
        如果真 (Msg == WM_DROPFILES)
        {
            szFile = 取空白文本 (1024)
            nFilesCount = 拖放api.DragQueryFileW (wParam, -1, szFile, 1024)
            循环 (, nFilesCount, i)
            {
                拖放api.DragQueryFileW (wParam, i, szFile, 1024)
                文件组.加入成员 (szFile)
            }
            拖放api.DragFinish (wParam)
            读指针处对象 (WndFunc, 文件拖放类_).回调过程 (文件组)
        }
        返回 (动态DLL.执行函数_ (dwNewLong, 4, , hWnd, Msg, wParam, lParam))
    }
}

类 拖放api <折叠 @文档 = "category = \"文件操作类.文件拖放.附加类\"">
{
    方法 ChangeWindowMessageFilter <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "ChangeWindowMessageFilter" @视窗.输入 = "User32.dll">
    参数 message <类型 = 整数>
    参数 dwFlag <类型 = 整数>

    方法 SetPropW <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "SetPropW" @视窗.输入 = "User32.dll">
    参数 hWnd <类型 = 变整数>
    参数 lpString <类型 = 文本型>
    参数 hData <类型 = 变整数>

    方法 DragAcceptFiles <公开 静态 折叠 折叠2 @输出名 = "DragAcceptFiles" @视窗.输入 = "shell32.dll">
    参数 hWnd <类型 = 变整数>
    参数 fAccept <类型 = 逻辑型>

    方法 GetPropW <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "GetPropW" @视窗.输入 = "User32.dll">
    参数 hWnd <类型 = 变整数>
    参数 lpString <类型 = 文本型>

    方法 DragQueryFileW <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "DragQueryFileW" @视窗.输入 = "shell32.dll">
    参数 hDrop <类型 = 变整数>
    参数 iFile <类型 = 整数>
    参数 lpszFile <类型 = 文本型>
    参数 cch <类型 = 整数>

    方法 DragFinish <公开 静态 折叠 折叠2 @输出名 = "DragFinish" @视窗.输入 = "shell32.dll">
    参数 hDrop <类型 = 变整数>

    方法 RemovePropW <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "RemovePropW" @视窗.输入 = "User32.dll">
    参数 hWnd <类型 = 变整数>
    参数 lpString <类型 = 文本型>

    方法 SetWindowLongW64_32 <公开 静态 类型 = 变整数 折叠>
    参数 hWnd <类型 = 变整数>
    参数 nIndex <类型 = 变整数>
    参数 dwNewLong <类型 = 变整数>
    {
        变量 动态DLL <类型 = 动态链接库类_>
        变量 句柄 <类型 = 变整数>
        变量 句柄2 <类型 = 变整数>
        变量 句柄3 <类型 = 变整数>
        句柄 = 动态DLL.动态加载DLL_ ("User32.dll")  // 动态加载DLL_
        如果 (为64位程序 ())
        {
            句柄3 = 动态DLL.取函数地址_ (句柄, "SetWindowLongPtrW")  // 取函数地址_
            句柄2 = 动态DLL.执行函数_ (句柄3, 3, , hWnd, nIndex, dwNewLong)
        }
        否则
        {
            句柄3 = 动态DLL.取函数地址_ (句柄, "SetWindowLongW")
            句柄2 = 动态DLL.执行函数_ (句柄3, 3, , hWnd, nIndex, dwNewLong)
        }
        动态DLL.动态释放DLL_ (句柄)  // 动态释放DLL_
        返回 (句柄2)



    }

    #
}

# //====模拟拖放====

类 模拟拖放投递类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件拖放\"" @全局类 = 真>
{
    方法 拖放_发送文件拖放消息 <公开 静态 注释 = "模拟文件拖放功能，将文件信息投递到软件里，完成模拟拖放文件" 折叠>
    参数 窗口句柄 <类型 = 变整数>
    参数 文件名 <类型 = 文本型 注释 = "例如：“C:\\\\aa.txt”；此参数与下个参数只需设置一些即可" @默认值 = "">
    参数 文件名组 <类型 = 文本数组类 注释 = "提供多个文件。此参数与上个参数只需设置一些即可" @默认值 = 空对象>
    {
        变量 句柄 <类型 = 变整数>
        变量 地址 <类型 = 变整数>
        变量 待发数据 <类型 = 字节集类>
        待发数据.添加字节集 (到字节集 (20))
        待发数据.添加字节集 (取空白字节集 (16))
        如果 (文本是否为空 (文件名) == 假)
        {
            待发数据.添加字节集 (文本到多字节 (文件名, ))
        }
        否则
        {
            计次循环 (文件名组.取成员数 ())
            {
                待发数据.添加字节集 (文本到多字节 (文件名组.取成员 (取循环索引 ()), ))
            }
        }
        句柄 = 进程_打开进程_句柄 (窗口句柄)
        地址 = 内存_申请内存2 (句柄, 取数据尺寸 (待发数据), )
        内存_写内存字节集3 (句柄, 地址, 待发数据)
        发送消息_ (窗口句柄, 563, 地址, 0)
        内存_释放内存2 (句柄, 地址)
        进程_关闭进程 (句柄)
    }
}
