    方法 文件_文件是否被占用 <公开 静态 类型 = 逻辑型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<shlwapi.h>" @视窗.外部库 = "Shlwapi.lib">
    参数 文件路径 <类型 = 文本型>
    {
        @ if (!PathFileExistsW(@<文件路径>.GetText())) return false;
        @ HANDLE hFile = CreateFileW(@<文件路径>.GetText(), GENERIC_WRITE, 0, 0, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, 0);
        @ if (hFile == INVALID_HANDLE_VALUE) return true;
        @ CloseHandle(hFile);
        @ return false;
    }

