    方法 线程类_线程运行 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程类>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 线程1)
        {
            生成行数索引 ()
        }
        否则 (来源对象 == 线程2)
        {
            生成段行数索引 ()
        }
        否则 (来源对象 == 线程3)
        {
            生成分段索引 ()
        }
        返回 (0)
    }

    方法 生成分段索引 <注释 = "执行总分段" 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 累计位 <类型 = 整数>
        变量 寻找位 <类型 = 整数>
        段落组.删除所有成员 ()
        临时数据.置字节集预分配尺寸 (5242880)
        文件读写_移动读写位置 (句柄, 0, 文件常量.文件首)
        判断循环 (真)
        {
            临时数据 = 文件读写_读入字节集 (句柄, 5242880)
            寻找位 = 倒找字节集 (临时数据, 记号, )
            累计位 = 累计位 + 寻找位
            如果 (寻找位 != -1 && 寻找位 > 2)
            {
                段落组.加入成员 (累计位 + 2)
            }
            否则
            {
                跳出循环
            }
            文件读写_移动读写位置 (句柄, 累计位, 文件常量.文件首)
        }
        临时数据.清空字节集 ()
        总段数 = 段落组.取成员数 ()
        处理事件_ ()
    }

    方法 生成段行数索引 <注释 = "内部调用" 折叠>
    {
        变量 寻找位 <类型 = 整数>
        变量 累计位 <类型 = 整数>
        变量 临时数据 <类型 = 字节集类>
        变量 结果 <类型 = 逻辑型>
        索引组.删除所有成员 ()
        缓存数据.清空字节集 ()
        缓存数据.置字节集预分配尺寸 (读取长度)
        文件读写_移动读写位置 (句柄, 指定距离, 文件常量.文件首)
        缓存数据 = 文件读写_读入字节集 (句柄, 读取长度)
        判断循环 (真)
        {
            寻找位 = 寻找字节集 (缓存数据, 记号, 累计位)
            如果 (寻找位 != -1)
            {
                索引组.加入成员 (寻找位)
            }
            否则
            {
                如果 (缓存数据.取字节集右边 (2) != 记号)
                {
                    索引组.加入成员 (读取长度)
                }
                否则
                {
                    索引组.加入成员 (读取长度 - 2)
                }
                结果 = 真
                跳出循环
            }
            累计位 = 寻找位 + 2
        }
        如果真 (缓存数据.取字节集右边 (2) == 记号)
        {
            索引组.删除成员 (索引组.取成员数 () - 1)
        }
        总行数 = 索引组.取成员数 ()
        处理事件_ ()
    }

    方法 生成行数索引 <注释 = "内部调用" 折叠>
    {
        变量 寻找位 <类型 = 整数>
        变量 寻找位2 <类型 = 整数>
        变量 寻找位3 <类型 = 整数>
        变量 累计位 <类型 = 整数>
        变量 临时数据 <类型 = 字节集类>
        变量 结果 <类型 = 逻辑型>
        索引组.删除所有成员 ()
        临时数据.置字节集预分配尺寸 (5242880)
        文件读写_移动读写位置 (句柄, 0, 文件常量.文件首)
        判断循环 (真)
        {
            临时数据 = 文件读写_读入字节集 (句柄, 5242880)
            累计位 = 0
            判断循环 (真)
            {
                寻找位 = 寻找字节集 (临时数据, 记号, 累计位)
                如果 (寻找位 != -1)
                {
                    寻找位2 = 寻找位
                    索引组.加入成员 (寻找位3 + 寻找位2)
                }
                否则
                {
                    如果真 (文件读写_取当前读写位置 (句柄) >= 总尺寸)
                    {
                        如果 (临时数据.取字节集右边 (2) != 记号)
                        {
                            索引组.加入成员 ((整数)总尺寸)
                            有无尾部 = 假
                        }
                        否则
                        {
                            有无尾部 = 真
                        }
                        结果 = 真
                    }
                    跳出循环
                }
                累计位 = 寻找位 + 2
            }
            寻找位3 = 寻找位3 + 寻找位2 + 2
            如果 (结果 == 真)
            {
                跳出循环
            }
            否则
            {
                文件读写_移动读写位置 (句柄, 寻找位3, 文件常量.文件首)
            }
        }
        临时数据.清空字节集 ()
        总行数 = 索引组.取成员数 ()
        处理事件_ ()
    }
}

# //====INI配置读写====

类 配置项类_ <公开 注释 = "功能同官方命令“读配置项”、“写配置项”；优点是除了支持ANSI，还支持UTF8编码，速度快等." 注释 = "执行顺序：" 注释 = "1、打开配置文件." 注释 = "2、读配置项_　或　写配置项_."
        注释 = "3、保存配置" 折叠 折叠2 @文档 = "category = \"文件操作类.INI配置读写\"">
{
    变量 配置 <类型 = INI配置文件操作类_>
    变量 已打开 <类型 = 逻辑型>

    方法 打开配置文件 <公开 类型 = 逻辑型 折叠>
    参数 配置文件名 <类型 = 文本型 注释 = "指定配置文件的名称,通常以\"ini\"作为文件名后缀.">
    参数 文件编码 <类型 = 文本编码类型 @默认值 = 文本编码类型.多字节>
    参数 是否添加空格 <类型 = 逻辑型 @默认值 = 真>
    {
        创建目录 (文件_取文件路径 (配置文件名))
        已打开 = 选择 (配置.打开文件 (配置文件名, 文件编码, 假) >= 0, 真, 假)
        配置.是否添加空格 = 是否添加空格
        返回 (已打开)
    }

    方法 读配置项 <公开 类型 = 文本型 注释 = "请先执行“打开配置文件”." 注释 = "读取并返回所指定配置文件中指定项目的文本内容." 注释 = "支持ANSI、UTF8等编码" 折叠 折叠2>
    参数 节名 <类型 = 文本型 注释 = "指定欲读入配置项所处节的名称">
    参数 键名 <类型 = 文本型 注释 = "指定欲读入配置项在其节中的名称">
    参数 默认值 <类型 = 文本型 注释 = "如果所指定配置项不存在,将返回此默认值文本." @默认值 = "">
    参数 启用注释 <类型 = 逻辑型 注释 = "为真时将过滤注释内容" @默认值 = 假>
    参数 注释符号 <类型 = 文本型 @默认值 = "//">
    {
        变量 临时值 <类型 = 文本型>
        如果真 (已打开 == 假)
        {
            信息框_ ("请先执行打开配置文件", 16, "提示！")
            返回 ("")
        }
        临时值 = 配置.取键值 (节名, 键名, 默认值)
        如果真 (启用注释)
        {
            临时值 = 取文本左边2_ (临时值, 注释符号, 真)
        }
        返回 (删首尾空 (临时值))
    }

    方法 写配置项 <公开 类型 = 逻辑型 注释 = "请先执行“打开配置文件”，可以执行多项写入，最后执行一次“保存配置”即可." 注释 = "将指定文本内容写入指定配置项中或者删除指定的配置项或节,"
            注释 = "如果指定配置文件不存在,将会自动创建." 注释 = "支持ANSI、UTF8等编码" 返回值注释 = "返回是否成功" 折叠 折叠2 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "指定欲写入配置项所处节的名称">
    参数 键名 <类型 = 文本型>
    参数 欲写入值 <类型 = 文本型 @默认值 = "">
    参数 注释 <类型 = 文本型 注释 = "注释说明文本" @默认值 = "">
    参数 注释位置 <类型 = 整数 注释 = "0、节名下方　1、键值后面 (注：设置1是非通用型的ini文件)" @默认值 = 1>
    参数 注释符号 <类型 = 文本型 @默认值 = "//">
    {
        变量 临时值 <类型 = 文本型>
        变量 结果 <类型 = 整数>
        如果真 (已打开 == 假)
        {
            信息框_ ("请先执行打开配置文件", 16, "提示！")
            返回 (假)
        }
        如果 (注释位置 == 0)
        {
            结果 = 配置.置键值 (节名, 键名, 欲写入值, 注释)
        }
        否则
        {
            如果 (文本是否为空 (注释) == 真)
            {
                临时值 = 配置.取键值 (节名, 键名)
                临时值 = 取文本右边2_ (临时值, ";")
            }
            否则
            {
                临时值 = 注释
            }
            结果 = 配置.置键值 (节名, 键名, 选择 (临时值 == "", 欲写入值, 欲写入值 + " " + 注释符号 + 临时值))
        }
        如果真 (结果 < 0)
        {
            返回 (假)
        }
        返回 (真)
    }

    方法 删除配置项 <公开 类型 = 逻辑型 注释 = "请先执行“打开配置文件”，可以执行多项删除，最后执行一次“保存配置”即可" 折叠>
    参数 节名 <类型 = 文本型 注释 = "所欲删除配置的节,如果如果键名为空,则表示删除整个节.">
    参数 键名 <类型 = 文本型 注释 = "所欲删除的键,如果键名为空,则表示删除整个节." @默认值 = 空对象>
    {
        返回 (配置.删除配置 (节名, 键名))
    }

    方法 取配置节名 <公开 类型 = 文本数组类 注释 = "请先执行“打开配置文件”." 注释 = "返回指定配置文件中所有已有节名的文本数组." 注释 = "支持ANSI、UTF8等编码" 折叠 折叠2>
    {
        变量 返回组 <类型 = 文本数组类>
        如果真 (已打开 == 假)
        {
            信息框_ ("请先执行打开配置文件", 16, "提示！")
        }
        配置.取所有节名 (返回组)
        返回 (返回组)
    }

    方法 取配置键名 <公开 类型 = 文本数组类 注释 = "请先执行“打开配置文件”." 注释 = "返回指定配置文件中所有键名的文本数组." 注释 = "支持ANSI、UTF8等编码" 折叠 折叠2>
    参数 节名 <类型 = 文本型 注释 = "所欲取所有键名的节">
    {
        变量 返回组 <类型 = 文本数组类>
        如果真 (已打开 == 假)
        {
            信息框_ ("请先执行打开配置文件", 16, "提示！")
        }
        配置.取所有键名 (节名, 返回组)
        返回 (返回组)
    }

    方法 保存配置 <公开 类型 = 逻辑型 注释 = "在执行“写配置项”后再执行本命令" 折叠>
    {
        返回 (配置.保存 () >= 0)
    }
}

类 INI配置文件操作类_ <公开 注释 = "提供了简易的ini配置文件修改操作" 折叠 折叠2 @文档 = "category = \"文件操作类.INI配置读写\""
        @视窗.外部头文件 = "piv\\encoding.hpp\npiv\\SimpleIni.h">
{
    方法 类_初始化 <折叠>
    {
        @ data ().SetUnicode (true); // 默认使用UTF-8
    }

    方法 类_清理 <折叠>
    {
        @ if (m_szIniFile.IsEmpty () == FALSE && m_bAutoSave == true)
        @     this->@<保存> ();
    }

    方法 清空 <公开 注释 = "释放本配置对象的所有内存数据" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Reset ()
    }

    方法 创建自文本 <公开 类型 = 整数 注释 = "从文本型数据中读入ini配置数据,本方法会覆盖本类之前的数据." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 @禁止流程检查 = 真>
    参数 配置内容 <类型 = 文本型>
    {
        @ data ().Reset ();
        @ data ().SetUnicode (true);
        @ return data ().LoadData (*PivW2U(@<配置内容>.GetText()));
    }

    方法 创建自字节集 <公开 类型 = 整数 注释 = "从字节集数据中读入ini配置数据,本方法会覆盖本类之前的数据." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 @禁止流程检查 = 真>
    参数 配置内容 <类型 = 字节集类>
    参数 文本编码 <类型 = 文本编码类型 注释 = "指定字节集文本编码,文本编码必须对应,否则可能会乱码;" 注释 = "其中\"未知\"等同多字节." @默认值 = 文本编码类型.UTF8>
    {
        @ data ().Reset ();
        @ if (@<文本编码> == VSET_UTF_8) {
        @     data ().SetUnicode (true);
        @     return data ().LoadData (reinterpret_cast<const char*>(@<配置内容>.GetPtr()), @<配置内容>.GetSize());
        @ } else if (@<文本编码> == VSET_UTF_16) {
        @     data ().SetUnicode (true);
        @     return data ().LoadData (*PivW2U (reinterpret_cast<const wchar_t*>(@<配置内容>.GetPtr()), @<配置内容>.GetSize() / 2));
        @ } else {
        @     data ().SetUnicode (false);
        @     return data ().LoadData (reinterpret_cast<const char*>(@<配置内容>.GetPtr()), @<配置内容>.GetSize());
        @ }
    }

    方法 创建自文件 <公开 类型 = 整数 注释 = "  从指定的文件中读入ini配置数据,本方法会覆盖本类之前的数据." 注释 = "  注意: 读入配置后就会关闭文件,所以之后修改的配置并不会反映到"
            注释 = "ini文件中,必须调用\"保存/保存文件\"才会将结果保存到文件." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 折叠2 @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型 注释 = "所欲打开的ini配置文件,文件不存在时会自动创建.">
    参数 文本编码 <类型 = 文本编码类型 注释 = "指定所打开ini文件的文本编码;" 注释 = "首先会根据文件的BOM签名自动识别编码;" 注释 = "若不存在签名,则以此参数指定的编码打开,\"未知\"等同多字节;"
            注释 = "文本编码必须选择正确,否则可能会乱码." @默认值 = 文本编码类型.未知>
    参数 自动保存 <类型 = 逻辑型 注释 = "是否在对象被释放之前自动保存更改到文件中;" 注释 = "为假时必须手动调用\"保存\",否则可能丢失未保存的编辑内容;"
            注释 = "为真时,即使已经通过\"保存文件\"将配置数据保存到新文件中," 注释 = "仍会将更改保存到原文件." @默认值 = 真>
    {
        @ m_szIniFile.Empty (); m_bAutoSave = false;
        @ data ().Reset ();
        @ INT nRet = 0;
        @ FILE* fp = _wfopen (@<文件名>.GetText (), L"ab+");
        @ if (!fp) return -3;
        @ fseek (fp, 0, SEEK_END);
        @ int nSize = ftell (fp);
        @ if (nSize == 0) {
        @     fclose (fp); m_nType = @<文本编码>;
        @     if (m_nType == VSET_UTF_8 || m_nType == VSET_UTF_16)
        @         data ().SetUnicode (true);
        @     else
        @         data ().SetUnicode (false);
        @     m_szIniFile = @<文件名>;
        @     m_bAutoSave = (bool)@<自动保存>;
        @     return 0;
        @ }
        @ fseek (fp, 0, SEEK_SET);
        @ char* szData = new char [nSize] { 0 };
        @ if (!szData) { fclose (fp); return -2; }
        @ fread (szData, sizeof(char), nSize, fp);
        @ fclose (fp);
        @ m_nType = VSET_UNKNOWN;
        @ bool hasBom = false;
        @ if (memcmp (szData, SI_UTF16_SIGNATURE, 2) == 0) {
        @     m_nType = VSET_UTF_16; hasBom = true;
        @ } else if (memcmp (szData, SI_UTF8_SIGNATURE, 3) == 0) {
        @     m_nType = VSET_UTF_8;
        @ }
        @ if (m_nType == VSET_UTF_16 || (m_nType == VSET_UNKNOWN && @<文本编码> == VSET_UTF_16)) {
        @     data ().SetUnicode (true);
        @     nRet = static_cast<INT>(data ().LoadData (*PivW2U (reinterpret_cast<const WCHAR*>(szData + (hasBom ? 2 : 0)), (hasBom ? (nSize - 2) : nSize) / 2)));
        @ } else if (m_nType == VSET_UTF_8 || (m_nType == VSET_UNKNOWN && @<文本编码> == VSET_UTF_8)) {
        @     data ().SetUnicode (true);
        @     nRet = static_cast<INT>(data ().LoadData (reinterpret_cast<const char*>(szData), nSize));
        @ } else {
        @     m_nType = VSET_MBCS;
        @     data ().SetUnicode (false);
        @     nRet = static_cast<INT>(data ().LoadData (reinterpret_cast<const char*>(szData), nSize));
        @ }
        @ delete [] szData;
        @ if (nRet >= 0) {
        @     m_szIniFile = @<文件名>;
        @     m_bAutoSave = (bool)@<自动保存>;
        @ }
        @ return nRet;
    }

    方法 是否添加空格 <公开 属性写 注释 = "设置是否在键值对的等号两边添加空格." 注释 = " 真: \"key = value\";" 注释 = " 假: \"key=value\"." 折叠 折叠2>
    参数 是否添加 <类型 = 逻辑型 注释 = "默认为假">
    {
        @ data ().SetSpaces (@<是否添加>);
    }

    方法 是否添加空格 <公开 属性读 类型 = 逻辑型 注释 = "返回是否在等号两边添加空格" 折叠 @嵌入式方法 = "">
    {
        @ @sn<this>.data ().UsingSpaces ()
    }

    方法 打开文件 <公开 类型 = 整数 注释 = "  本方法跟\"创建自文件\"一样,只是为了兼容以前的代码才保留." 注释 = "  从指定的文件中获取ini配置数据,本方法会覆盖本类之前的数据."
            注释 = "  注意: 读入配置后就会关闭文件,所以之后修改的配置并不会反映到" 注释 = "ini文件中,必须调用\"保存/保存文件\"才会将结果保存到文件." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 折叠2
            @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型 注释 = "所欲打开的ini配置文件,文件不存在时会自动创建.">
    参数 文本编码 <类型 = 文本编码类型 注释 = "指定所打开ini文件的文本编码;" 注释 = "首先会根据文件的BOM签名自动识别编码;" 注释 = "若不存在签名,则以此参数指定的编码打开,\"未知\"等同多字节;"
            注释 = "文本编码必须选择正确,否则可能会乱码." @默认值 = 文本编码类型.未知>
    参数 自动保存 <类型 = 逻辑型 注释 = "是否在对象被释放之前自动保存更改到文件中;" 注释 = "为假时必须手动调用\"保存\",否则可能丢失未保存的编辑内容;"
            注释 = "为真时,即使已经通过\"保存文件\"将配置数据保存到新文件中," 注释 = "仍会将更改保存到原文件中." @默认值 = 真>
    {
        返回 (创建自文件 (文件名, 文本编码, 自动保存))
    }

    方法 保存 <公开 类型 = 整数 注释 = "覆盖保存所打开的ini文件." 注释 = "如果未执行过\"创建自文件/打开文件\",应当使用\"保存文件\"." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 折叠2
            @禁止流程检查 = 真>
    {
        @ if (m_szIniFile.IsEmpty ())
        @     return -3;
        @ else
        @     return this->@<保存文件> (m_szIniFile, m_nType);
    }

    方法 保存文件 <公开 类型 = 整数 注释 = "将当前编辑的内容保存到指定的ini文件中" 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 @禁止流程检查 = 真>
    参数 文件名 <类型 = 文本型 注释 = "所欲保存内容的ini配置文件,如果文件不存在将自动创建.">
    参数 文本编码 <类型 = 文本编码类型 注释 = "指定保存文件的文本编码,UTF8和UTF16会添加自动BOM签名,其中\"未知\"等同多字节." @默认值 = 文本编码类型.UTF8>
    {
        @ if (@<文本编码> == @<文本编码类型.UTF8>) {
        @     if (data ().IsUnicode ()) {
        @         return data ().SaveFile (@<文件名>.GetText (), true);
        @     } else {
        @         CVolMem memUtf8;
        @         std::string szBuffer;
        @         data ().Save (szBuffer, false);
        @         PivA2U utf8str {szBuffer};
        @         utf8str.to_volmem (memUtf8, false);
        @         memUtf8.InsertValue_S_BYTE (0, (S_BYTE)0xBF); memUtf8.InsertValue_S_BYTE (0, (S_BYTE)0xBB); memUtf8.InsertValue_S_BYTE (0, (S_BYTE)0xEF);
        @         return memUtf8.WriteIntoFile (@<文件名>, -1) ? 0 : -3;
        @     }
        @ } else if (@<文本编码> == @<文本编码类型.UTF16>) {
        @     CVolMem memWStr; std::string szBuffer;
        @     data ().Save (szBuffer, false);
        @     if (data ().IsUnicode ()) {
        @         PivU2W utf16str {szBuffer};
        @         utf16str.to_volmem (memWStr, false);
        @     } else {
        @         PivA2W utf16str {szBuffer};
        @         utf16str.to_volmem (memWStr, false);
        @     }
        @     memWStr.InsertValue_SHORT (0, (SHORT)0xFEFF);
        @     return memWStr.WriteIntoFile (@<文件名>, -1) ? 0 : -3;
        @ } else {
        @     if (data ().IsUnicode ()) {
        @         CVolMem memMBS;
        @         std::string szBuffer;
        @         data ().Save (szBuffer, false);
        @         PivU2A mbstr {szBuffer};
        @         mbstr.to_volmem (memMBS, false);
        @         return memMBS.WriteIntoFile (@<文件名>, -1) ? 0 : -3;
        @     } else {
        @         return static_cast<INT>(data ().SaveFile (@<文件名>.GetText (), false));
        @     }
        @ }
    }

    方法 取文件编码 <公开 类型 = 文本编码类型 注释 = "返回已打开ini配置文件的文本编码." 注释 = "若未成功执行过\"打开文件\",则返回\"文本编码类型.未知\"." 折叠 折叠2 @嵌入式方法 = "">
    {
        @ @sn<this>.m_nType
    }

    方法 到文本 <公开 类型 = 文本型 注释 = "将内存中的配置数据输出到文本" 折叠 @禁止流程检查 = 真>
    {
        @ std::string szBuffer;
        @ data ().Save (szBuffer, false);
        @ if (data ().IsUnicode ())
        @     return *PivU2Ws {szBuffer};
        @ else
        @     return *PivA2Ws {szBuffer};
    }

    方法 到字节集 <公开 类型 = 字节集类 注释 = "将内存中的配置数据输出到字节集类." 注释 = "本方法不做编码转换,直接返回类的内部数据,内部只使用多字节和UTF8两种编码." 折叠 折叠2 @禁止流程检查 = 真>
    参数 添加签名 <类型 = 逻辑型 注释 = "是否对UTF-8数据添加BOM签名(多字节无签名)" @默认值 = 假>
    参数 是否UTF8编码 <类型 = 逻辑型类 注释 = "返回字节集的数据是否为UTF8编码,返回假则说明是多字节编码." @默认值 = 空对象>
    {
        @ std::string szBuffer;
        @ data ().Save (szBuffer, @<添加签名>);
        @ @<是否UTF8编码.值> = data ().IsUnicode ();
        @ return @an<CVolMem> (szBuffer.c_str(), szBuffer.size());
    }

    方法 取键值 <公开 类型 = 文本型 注释 = "获取指定键的文本型键值" 折叠 @嵌入式方法 = "">
    参数 节名 <类型 = 文本型 注释 = "所欲获取键值的节名称">
    参数 键名 <类型 = 文本型 注释 = "所欲获取键值的键名称">
    参数 默认值 <类型 = 文本型 注释 = "如果所指定键名不存在,将返回此默认值." @默认值 = "">
    参数 是否有多个值 <类型 = 逻辑型类 注释 = "返回当前键是否有多个值,为真时可以用\"取所有键值\"获取." @默认值 = 空对象>
    {
        @ @an<CVolString> (@sn<this>.data ().GetValue (@<节名>.GetText (), @<键名>.GetText (), @<默认值>.GetText (), (bool*)&@<是否有多个值.值>))
    }

    方法 置键值 <公开 类型 = 整数 注释 = "添加或更新一个节或文本型键值." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "所欲添加或更新的节">
    参数 键名 <类型 = 文本型 注释 = "所欲添加或更新的键,留空表示创建一个空节." @默认值 = 空对象>
    参数 键值 <类型 = 文本型 注释 = "所欲设置的键值,留空表示创建一个空节." @默认值 = 空对象>
    参数 注释 <类型 = 文本型 注释 = "仅在第一次创建新的节或键名时才会写入注释." @默认值 = 空对象>
    参数 强制替换 <类型 = 逻辑型 注释 = "  \"是否允许重复键名\"为真时,是否强制将同一个键名的" 注释 = "所有键值都替换成新值." @默认值 = 假>
    {
        变量 临时注释 <类型 = 文本型>
        临时注释 = 注释
        如果真 (注释 != "")
        {
            子文本替换 (临时注释, "//", ";")
            如果真 (取文本左边 (临时注释, 1) != ";" || 取文本左边 (临时注释, 1) != "#")
            {
                临时注释 = ";" + 临时注释
            }
        }
        @ return (INT)data ().SetValue (@<节名>.GetText (), @<键名>.IsEmpty () ? NULL : @<键名>.GetText (),
        @     @<键值>.IsEmpty () ? NULL : @<键值>.GetText (), @<临时注释>.IsEmpty () ? NULL : @<临时注释>.GetText (), (bool)@<强制替换>);
    }

    方法 取所有节名 <公开 注释 = "获取配置数据中所有节的名称" 折叠>
    参数 返回节名数组 <类型 = 文本数组类 注释 = "成功返回节名的数组">
    {
        @ @<返回节名数组>.data ().RemoveAll ();
        @ CSimpleIniW::TNamesDepend sections;
        @ data ().GetAllSections (sections);
        @ for (auto it = sections.begin(); it != sections.end(); it++) {
        @     @<返回节名数组>.data ().Add ((*it).pItem);
        @ }
    }

    方法 取所有键名 <公开 类型 = 逻辑型 注释 = "获取指定节中的所有唯一键名" 折叠 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "所欲取所有键名的节">
    参数 返回键名数组 <类型 = 文本数组类 注释 = "成功返回键名的数组">
    {
        @ @<返回键名数组>.data ().RemoveAll ();
        @ CSimpleIniW::TNamesDepend keys;
        @ BOOL bRet = data ().GetAllKeys (@<节名>.GetText (), keys);
        @ if (!bRet) return FALSE;
        @ for (auto it = keys.begin(); it != keys.end(); it++) {
        @     @<返回键名数组>.data ().Add ((*it).pItem);
        @ }
        @ return bRet;
    }

    方法 取所有键值 <公开 类型 = 逻辑型 注释 = "获取指定节指定键的所有键值" 折叠 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "所欲取键值的节名">
    参数 键名 <类型 = 文本型 注释 = "所欲取键值的键名">
    参数 返回值数组 <类型 = 文本数组类 注释 = "成功返回键值数组">
    {
        @ @<返回值数组>.data ().RemoveAll ();
        @ CSimpleIniW::TNamesDepend values;
        @ BOOL bRet = data ().GetAllValues (@<节名>.GetText (), @<键名>.GetText (), values);
        @ if (!bRet) return FALSE;
        @ for (auto it = values.begin(); it != values.end(); it++) {
        @     @<返回值数组>.data ().Add ((*it).pItem);
        @ }
        @ return bRet;
    }

    方法 取节成员数 <公开 类型 = 整数 注释 = "获取指定节的键数量" 折叠 @嵌入式方法 = "">
    参数 节名 <类型 = 文本型 注释 = "所欲取键数量的节名">
    {
        @ @sn<this>.data ().GetSectionSize (@<节名>.GetText ())
    }

    方法 节名是否存在 <公开 类型 = 逻辑型 注释 = "检查指定的节是否存在" 折叠 @嵌入式方法 = "">
    参数 节名 <类型 = 文本型 注释 = "所欲检查的节名">
    {
        @ @sn<this>.data ().SectionExists (@<节名>.GetText ())
    }

    方法 键名是否存在 <公开 类型 = 逻辑型 注释 = "检查指定的键名是否存在" 折叠 @嵌入式方法 = "">
    参数 节名 <类型 = 文本型 注释 = "所欲检查键名的节名">
    参数 键名 <类型 = 文本型 注释 = "所欲检查的键名">
    {
        @ @sn<this>.data ().KeyExists (@<节名>.GetText (), @<键名>.GetText ())
    }

    方法 删除配置 <公开 类型 = 逻辑型 注释 = "  删除整个节,或节中的某个键." 注释 = "  当\"是否允许重复键名\"为真时,将删除所有同名的键," 注释 = "如果要单独删除某个键值对,请用\"删除键值\"."
            返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 折叠2 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "所欲删除配置的节,如果如果键名为空,则表示删除整个节.">
    参数 键名 <类型 = 文本型 注释 = "所欲删除的键,如果键名为空,则表示删除整个节." @默认值 = 空对象>
    参数 删除空节 <类型 = 逻辑型 注释 = "如果删除指定键后,节已经没有其他内容,是否把这个空节也删除掉?" @默认值 = 假>
    {
        @ return data ().Delete (@<节名>.GetText (), @<键名>.IsEmpty () ? NULL : @<键名>.GetText (), (bool)@<删除空节>);
    }

    方法 删除键值 <公开 类型 = 逻辑型 注释 = "删除整个节,或节中的某个键.如果提供了键值,则只删除对应的键." 返回值注释 = "返回值大于等于0表示成功,小于0表示失败." 折叠 @禁止流程检查 = 真>
    参数 节名 <类型 = 文本型 注释 = "所欲删除配置的节,如果如果键名为空,则表示删除整个节.">
    参数 键名 <类型 = 文本型 注释 = "所欲删除的键,如果键名为空,则表示删除整个节." @默认值 = 空对象>
    参数 键值 <类型 = 文本型 注释 = "所欲删除的指定键值,如果留空则表示删除所有同名的键." @默认值 = 空对象>
    参数 删除空节 <类型 = 逻辑型 注释 = "如果删除指定键后,节已经没有其他内存,是否把这个空节也删除掉." @默认值 = 假>
    {
        @ return data ().DeleteValue (@<节名>.GetText (), @<键名>.IsEmpty () ? NULL : @<键名>.GetText (),
        @        @<键值>.IsEmpty () ? NULL : @<键值>.GetText (), (bool)@<删除空节>);
    }

    # @begin
    # @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CSimpleIniW)
    # <> <include>
    # #define SI_UTF16_SIGNATURE     "\xFF\xFE"
    # CVolString m_szIniFile;
    # bool m_bAutoSave;
    # INT m_nType = VSET_UNKNOWN;
    # <> </include>
    # @end
}

# //====文件资源打包====

类 资源包类_ <公开 基础类 = 对象数组类 注释 = "将图标等N多文件打包成一个资源文件，支持读取修操作" 折叠 @文档 = "category = \"文件操作类.资源文件打包\"">
{
    变量 加解密 <类型 = 加解密类_>

    方法 类_初始化 <折叠>
    {
        置随机数种子 ()
    }

    方法 加载资源包_ <公开 类型 = 逻辑型 折叠>
    参数 欲导入的包数据 <类型 = 字节集类>
    {
        变量 流对象 <类型 = 内存输入流>
        如果真 (欲导入的包数据.取字节集长度 () < 1)
        {
            返回 (假)
        }
        流对象.打开 (欲导入的包数据)
        变量 标志 <类型 = 整数>
        如果 (流对象.读 (标志).是否出错 ())
        {
            返回 (假)
        }
        如果 (标志 != 999)
        {
            流对象.错误码 = 流错误码.无效数据
        }
        判断循环 (真)
        {
            变量 消息 <类型 = 资源模版类_>
            流对象.读对象 (消息)
            如果 (流对象.是否出错 ())
            {
                跳出循环
            }
            加入成员 (消息)
        }
        返回 (真)
    }

    方法 加载资源包_路径 <公开 类型 = 逻辑型 折叠>
    参数 欲导入的包文件 <类型 = 文本型 注释 = "文件路径＋名称">
    {
        返回 (加载资源包_ (读入文件 (欲导入的包文件)))
    }

    方法 加载资源包_资源 <公开 类型 = 逻辑型 折叠>
    参数 欲导入的包数据 <类型 = 视窗文件资源>
    {
        变量 资源内容 <类型 = 字节集类>
        文件资源到字节集 (欲导入的包数据, 资源内容)
        返回 (加载资源包_ (资源内容))
    }

    方法 导出资源包_ <公开 类型 = 字节集类 折叠>
    {
        变量 流对象 <类型 = 内存输出流>
        如果真 (取资源数量_ () == 0)
        {
            返回 (流对象.取数据 ())
        }
        流对象.写 (999)
        枚举循环 ()
        {
            流对象.写对象 (取枚举值 ())
        }
        返回 (流对象.取数据 ())
    }

    方法 保存资源包_ <公开 类型 = 逻辑型 折叠>
    参数 保存路径 <类型 = 文本型 注释 = "提供路径和名称。例如：“C:\\\\资源.db”">
    {
        变量 临时数据 <类型 = 字节集类>
        临时数据 = 导出资源包_ ()
        如果 (取字节集长度 (临时数据) == 0)
        {
            返回 (假)
        }
        返回 (写到文件 (保存路径, 临时数据))
    }

    方法 添加_字节集 <公开 类型 = 逻辑型 注释 = "添加字节集文件到资源包中" 折叠>
    参数 文件名 <类型 = 文本型>
    参数 资源数据 <类型 = 字节集类>
    参数 密钥 <类型 = 文本型 @默认值 = "">
    {
        变量 资源 <类型 = 资源模版类_>
        变量 随机位 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 右数据 <类型 = 字节集类>
        如果真 (资源数据.取字节集长度 () > 0)
        {
            资源.文件名 = 文件名
            如果 (文本是否为空 (密钥) == 假)
            {
                资源.资源数据 = 压缩数据_ (资源数据, 9)
                长度 = 资源.资源数据.取字节集长度 ()
                随机位 = 取随机数 (长度 / 3, 长度)
                资源.资源数据.插入字节集 (随机位, 加解密.加密文本2_ (密钥, 密钥))
                如果 (资源.资源数据.取字节集长度 () > 12)
                {
                    右数据 = 加解密.加密字节集_ (资源.资源数据.取字节集右边 (12), 密钥)
                }
                否则
                {
                    右数据 = 加解密.加密字节集_ (资源.资源数据, 密钥)
                }
                资源.加密长度 = 右数据.取字节集长度 ()
                如果 (资源.资源数据.取字节集长度 () > 12)
                {
                    资源.资源数据.字节集删除 (资源.资源数据.取字节集长度 () - 12, 12)
                }
                否则
                {
                    资源.资源数据.清空字节集 ()
                }
                资源.资源数据.添加字节集 (右数据)
            }
            否则
            {
                资源.资源数据 = 资源数据
            }
            加入成员 (资源)
            返回 (真)
        }
        返回 (假)
    }

    方法 添加_路径 <公开 类型 = 逻辑型 注释 = "添加路径文件到资源包中" 折叠>
    参数 文件名 <类型 = 文本型 注释 = "默认为文件名" @默认值 = "">
    参数 资源路径 <类型 = 文本型>
    参数 密钥 <类型 = 文本型 @默认值 = "">
    {
        变量 资源 <类型 = 资源模版类_>
        变量 资源数据 <类型 = 字节集类>
        如果真 (文件是否存在 (资源路径) == 真)
        {
            资源数据 = 读入文件 (资源路径)
            如果 (文件名 == "")
            {
                文件名 = 文件_取文件名 (资源路径)
            }
            返回 (添加_字节集 (文件名, 资源数据, 密钥))
        }
        返回 (假)
    }

    方法 读取_ <公开 类型 = 字节集类 注释 = "读取资源包中的文件信息" 折叠>
    参数 文件名 <类型 = 文本型>
    参数 密钥 <类型 = 文本型 @默认值 = "">
    {
        变量 资源 <类型 = 字节集类>
        变量 密钥值 <类型 = 字节集类>
        变量 位置 <类型 = 整数>
        变量 右数据 <类型 = 字节集类>
        变量 加密长度 <类型 = 整数>
        枚举循环 ()
        {
            如果真 (取指定类型枚举值 (资源模版类_).文件名 == 文件名)
            {
                资源 = 取指定类型枚举值 (资源模版类_).资源数据
                如果 (文本是否为空 (密钥) == 假)
                {
                    加密长度 = 取指定类型枚举值 (资源模版类_).加密长度
                    右数据 = 资源.取字节集右边 (加密长度)
                    右数据 = 加解密.解密字节集_ (右数据, 密钥)
                    密钥值 = 加解密.加密文本2_ (密钥, 密钥)
                    资源.字节集删除 (资源.取字节集长度 () - 加密长度, 加密长度)
                    资源.添加字节集 (右数据)
                    位置 = 资源.寻找字节集 (密钥值)
                    如果真 (位置 > 0)
                    {
                        资源.字节集删除 (位置, 密钥值.取字节集长度 ())
                    }
                    资源 = 解压数据_ (资源)
                }
            }
        }
        返回 (资源)
    }

    方法 删除_ <公开 注释 = "删除资源包中的文件信息" 折叠>
    参数 文件名 <类型 = 文本型>
    {
        枚举循环 ()
        {
            如果真 (取指定类型枚举值 (资源模版类_).文件名 == 文件名)
            {
                删除成员 (取枚举索引 ())
            }
        }
    }

    方法 修改_ <公开 注释 = "修改资源包中的文件信息" 折叠>
    参数 文件名 <类型 = 文本型>
    参数 新文件名 <类型 = 文本型 @默认值 = 空对象>
    参数 新资源数据 <类型 = 字节集类 @默认值 = 空对象>
    参数 新密钥 <类型 = 文本型 注释 = "不支持单独修改密钥" @默认值 = "">
    {
        变量 资源 <类型 = 字节集类>
        变量 随机位 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 右数据 <类型 = 字节集类>
        枚举循环 ()
        {
            如果真 (取指定类型枚举值 (资源模版类_).文件名 == 文件名)
            {
                如果真 (文本是否为空 (新文件名) == 假)
                {
                    取指定类型枚举值 (资源模版类_).文件名 = 新文件名
                }
                如果 (文本是否为空 (新密钥) == 假)
                {
                    资源 = 压缩数据_ (新资源数据, 9)
                    长度 = 新资源数据.取字节集长度 ()
                    随机位 = 取随机数 (长度 / 3, 长度)
                    资源.插入字节集 (随机位, 加解密.加密文本2_ (新密钥, 新密钥))
                    如果 (资源.取字节集长度 () > 12)
                    {
                        右数据 = 加解密.加密字节集_ (资源.取字节集右边 (12), 新密钥)
                    }
                    否则
                    {
                        右数据 = 加解密.加密字节集_ (资源, 新密钥)
                    }
                    取指定类型枚举值 (资源模版类_).加密长度 = 右数据.取字节集长度 ()
                    如果 (资源.取字节集长度 () > 12)
                    {
                        资源 = 资源.取字节集左边 (资源.取字节集长度 () - 12)
                    }
                    否则
                    {
                        资源.清空字节集 ()
                    }
                    资源.添加字节集 (右数据)
                    如果真 (字节集是否为空 (新资源数据) == 假)
                    {
                        取指定类型枚举值 (资源模版类_).资源数据 = 资源
                    }
                }
                否则
                {
                    如果真 (字节集是否为空 (新资源数据) == 假)
                    {
                        取指定类型枚举值 (资源模版类_).资源数据 = 新资源数据
                    }
                }
                跳出循环
            }
        }
    }

    方法 修改_路径 <公开 注释 = "修改资源包中的文件信息" 折叠>
    参数 文件名 <类型 = 文本型>
    参数 新文件名 <类型 = 文本型 @默认值 = 空对象>
    参数 新资源路径 <类型 = 文本型 @默认值 = 空对象>
    参数 新密钥 <类型 = 文本型 注释 = "不支持单独修改密钥" @默认值 = "">
    {
        修改_ (文件名, 新文件名, 读入文件 (新资源路径), 新密钥)
    }

    方法 清空_ <公开 注释 = "初始化为空资源包" 折叠>
    {
        重置数组 (资源模版类_, 0)
        删除所有成员 ()
    }

    方法 取资源尺寸_ <公开 类型 = 整数 注释 = "取资源包整体大小" 折叠>
    {
        返回 (取字节集长度 (导出资源包_ ()))
    }

    方法 取资源数量_ <公开 类型 = 整数 注释 = "取资源包中资源总数" 折叠>
    {
        返回 (取成员数 ())
    }

    方法 取资源名称_ <公开 类型 = 文本数组类 注释 = "取资源包中所有资源名称" 折叠>
    {
        变量 临时名 <类型 = 文本数组类>
        临时名.预分配尺寸 = 取成员数 ()
        枚举循环 ()
        {
            临时名.加入成员 (((资源模版类_)取枚举值 ()).文件名)
        }
        返回 (临时名)
    }
}

类 资源模版类_ <折叠 @文档 = "category = \"文件操作类.资源文件打包.附加类\"">
{
    变量 文件名 <公开 类型 = 文本型>
    变量 资源数据 <公开 类型 = 字节集类>
    变量 加密长度 <公开 类型 = 整数>
}

类 资源文件类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件资源读写\"" @全局类 = 真>
{
    方法 写出资源文件_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 欲写到的文件路径名称 <类型 = 文本型>
    参数 欲写出的资源文件名称 <类型 = 视窗文件资源>
    {
        写到文件 (欲写到的文件路径名称, 取出资源文件_ (欲写出的资源文件名称))
        延迟_ (10)
        返回 (文件是否存在 (欲写到的文件路径名称))
    }

    方法 读资源文件内容_ <公开 静态 类型 = 文本型 注释 = "只能取文本资源内容" 折叠 @禁止流程检查 = 真>
    参数 资源文件 <类型 = 视窗文件资源>
    {
        返回 (多字节到文本 (取出资源文件_ (资源文件)))
    }

    方法 取出资源文件_ <公开 静态 类型 = 字节集类 折叠 @禁止流程检查 = 真>
    参数 资源文件 <类型 = 视窗文件资源>
    {
        变量 资源内容 <类型 = 字节集类>
        文件资源到字节集 (资源文件, 资源内容)
        返回 (资源内容)

    }
}

# //====文件读写操作====

类 文件读写类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写\"" @全局类 = 真>
{
    方法 文件读写_打开文件 <公开 静态 类型 = 变整数 注释 = "成功返回大于0，返回文件句柄" 折叠 @嵌入式方法 = "">
    参数 文件路径 <类型 = 文本型>
    参数 打开方式 <类型 = 打开方式 注释 = "默认是打开或创建" @默认值 = 打开方式.打开或创建>
    参数 共享模式 <类型 = 共享方式 注释 = "默认是共享读写" @默认值 = 共享方式.共享读写>
    参数 访问方式 <类型 = 访问方式 注释 = "默认是读写" @默认值 = 访问方式.读写>
    {
        @ (@dt<变整数>) ::CreateFile(@<文件路径>,@<访问方式>,@<共享模式>,NULL,(DWORD)@<打开方式>,FILE_ATTRIBUTE_NORMAL,NULL)
    }

    方法 文件读写_关闭文件 <公开 静态 折叠 @嵌入式方法 = "">
    参数 文件句柄 <类型 = 变整数>
    {
        @ ::CloseHandle((HANDLE)@<文件句柄>)
    }

    方法 文件读写_读入字节集 <公开 静态 类型 = 字节集类 注释 = "先执行“文件读写_打开文件”." 注释 = "读入该文件中的数据" 折叠 折叠2>
    参数 文件句柄 <类型 = 变整数>
    参数 读入长度 <类型 = 整数 注释 = "默认读取整个文件" @默认值 = -1>
    {
        变量 空字节集 <类型 = 字节集类>
        变量 临时读取长度 <类型 = 整数>
        变量 ""
        变量 实际读取长度 <类型 = 整数>
        如果 (读入长度 == 0)
        {
            返回 (空字节集)
        }
        如果 (读入长度 == -1)
        {
            临时读取长度 = (整数)文件操作取文件大小_ (文件句柄)
        }
        否则
        {
            临时读取长度 = 读入长度
        }
        空字节集.分配字节集 (临时读取长度)
        实际读取长度 = 文件操作读到内存_ (文件句柄, 空字节集.取字节集指针 (), 临时读取长度)
        如果 (实际读取长度 < 0)
        {
            空字节集.清空字节集 ()
        }
        否则 (实际读取长度 < 临时读取长度)
        {
            空字节集.重分配字节集 (实际读取长度)
        }
        返回 (空字节集)
    }

    方法 文件读写_写出字节集 <公开 静态 类型 = 整数 注释 = "先执行“文件读写_打开文件”." 注释 = "将数据写入到文件中" 返回值注释 = "成功返回读取的长度" 折叠 折叠2>
    参数 文件句柄 <类型 = 变整数>
    参数 欲写出的字节集 <类型 = 字节集类>
    {
        返回 (文件操作写内存数据_ (文件句柄, 欲写出的字节集.取字节集指针 (), 欲写出的字节集.取字节集长度 ()))
    }

    方法 文件读写_取文件尺寸 <公开 静态 类型 = 长整数 注释 = "先执行“文件读写_打开文件”" 折叠 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    {
        @   LARGE_INTEGER li;
        @   li.LowPart = ::GetFileSize((HANDLE)@<文件句柄>,(LPDWORD)&li.HighPart);
        @   return li.QuadPart;
    }

    方法 文件读写_移动读写位置 <公开 静态 类型 = 长整数 注释 = "移动该文件的读写位置" 返回值注释 = "成功返回移动距离" 折叠 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    参数 移动距离 <类型 = 长整数>
    参数 移动方式 <类型 = 文件常量 注释 = "默认是当前位置" @默认值 = 文件常量.当前位置>
    {
        @    LARGE_INTEGER li;
        @    li.QuadPart = @<移动距离>;
        @    li.LowPart = ::SetFilePointer ((HANDLE)@<文件句柄>, li.LowPart, &li.HighPart, (DWORD)@<移动方式>);
        @    if (li.LowPart == INVALID_SET_FILE_POINTER && GetLastError() != NO_ERROR)
        @    {
        @       li.QuadPart = -1;
        @    }
        @    return li.QuadPart;
    }

    方法 文件读写_移动读写位置到文件尾 <公开 静态 类型 = 长整数 注释 = "先执行“文件读写_打开文件”" 返回值注释 = "成功返回移动距离" 折叠>
    参数 文件句柄 <类型 = 变整数>
    参数 移动方式 <类型 = 文件常量 注释 = "默认是当前位置" @默认值 = 文件常量.当前位置>
    {
        返回 (文件读写_移动读写位置 (文件句柄, 文件读写_取文件尺寸 (文件句柄), 移动方式))
    }

    方法 文件读写_取当前读写位置 <公开 静态 类型 = 长整数 注释 = "先执行“文件读写_打开文件”." 注释 = "取出该文件的当前读写位置" 折叠 折叠2 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    {
        @    LARGE_INTEGER li;
        @   li.HighPart = 0;
        @   li.LowPart = SetFilePointer((HANDLE)@<文件句柄>, 0, &li.HighPart, FILE_CURRENT);
        @  return li.QuadPart;
    }

    方法 文件读写_置文件大小 <公开 静态 类型 = 逻辑型 注释 = "预创建指定大小的文件" 折叠 @禁止流程检查 = 真>
    参数 文件名称 <类型 = 文本型>
    参数 文件大小 <类型 = 长整数>
    {
        变量 句柄 <类型 = 变整数>
        句柄 = 文件读写_打开文件 (文件名称, 打开方式.新建或覆盖, 共享方式.共享读写, 访问方式.读写)
        文件读写_移动读写位置 (句柄, 文件大小, 文件常量.文件尾)  // SetFilePointer GetLastError
        文件读写_移动位置 (句柄)  // SetEndOfFile
        如果 (文件读写_取文件尺寸 (句柄) == 文件大小)
        {
            文件读写_关闭文件 (句柄)
            返回 (真)
        }
        文件读写_关闭文件 (句柄)
        返回 (假)
    }

    方法 文件读写_移动位置 <静态 折叠 @嵌入式方法 = "">
    参数 文件句柄 <类型 = 变整数>
    {
        @ ::SetEndOfFile((HANDLE)@<文件句柄>)
    }

    方法 文件操作取文件大小_ <静态 类型 = 长整数 折叠 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    {
        @   LARGE_INTEGER li;
        @   li.LowPart = ::GetFileSize((HANDLE)@<文件句柄>,(LPDWORD)&li.HighPart);
        @   return li.QuadPart;
    }

    方法 文件操作读到内存_ <静态 类型 = 整数 注释 = "先执行“文件读写_打开文件”" 返回值注释 = "返回实际夺取了多少个字节" 折叠 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    参数 缓冲区指针 <类型 = 变整数 注释 = "这个参数使用前，必须申请一段空的内存，来存放读到的数据">
    参数 缓冲区大小 <类型 = 整数 注释 = "分配的内存大小">
    {
        @   DWORD dwNumberOfBytesRead = 0;
        @   BOOL bOk = ::ReadFile((HANDLE)@<文件句柄>,(LPVOID)@<缓冲区指针>,(DWORD)@<缓冲区大小>,&dwNumberOfBytesRead,NULL);
        @   return (INT)dwNumberOfBytesRead;
    }

    方法 文件操作写内存数据_ <静态 类型 = 整数 注释 = "先执行“文件读写_打开文件”" 返回值注释 = "返回写了多少个字节" 折叠 @禁止流程检查 = 真>
    参数 文件句柄 <类型 = 变整数>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        @   DWORD nBytesWrites = 0;
        @   BOOL bOk = ::WriteFile( (HANDLE)@<文件句柄>,(LPCVOID)@<数据指针>,@<数据大小>,&nBytesWrites,NULL);
        @   return (INT)nBytesWrites;
    }

    方法 文件读写_写出文本行 <公开 静态 注释 = "先执行“文件读写_打开文件”，再执行本命令，最后执行“文件读写_关闭文件”." 注释 = "将新内容写到文件尾部" 折叠 折叠2>
    参数 文件句柄 <类型 = 变整数>
    参数 内容 <类型 = 文本型 注释 = "写入的内容">
    参数 是否换行 <类型 = 逻辑型 注释 = "连续写入的内容是否自动换行" @默认值 = 真>
    参数 是否为ANSI <类型 = 逻辑型 注释 = "真：ANSI(多字节集)　假：UTF8　" @默认值 = 真>
    {
        变量 文件 <类型 = 文件读写类>
        如果真 (文件读写_移动读写位置到文件尾 (文件句柄, 文件常量.文件首) < 1)
        {
            文件读写_移动读写位置到文件尾 (文件句柄, 文件常量.文件首)
        }
        如果 (是否为ANSI == 真)
        {
            文件读写_写出字节集 (文件句柄, 文本到多字节 (内容 + 选择 (是否换行 == 假, "", "\r\n"), 假))
        }
        否则
        {
            文件读写_写出字节集 (文件句柄, 文本到UTF8 (内容 + 选择 (是否换行 == 假, "", "\r\n"), 假))
        }
    }
}

类 文件共享类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写.附加类\"" @全局类 = 真>
{
    方法 文件共享_开启共享 <公开 静态 类型 = 逻辑型 折叠>
    参数 待处理的文件夹 <类型 = 文本型>
    参数 共享名称 <类型 = 文本型 注释 = "默认为该文件夹名" @默认值 = "">
    {
        变量 结果 <类型 = 文本型>
        如果真 (共享名称 == "")
        {
            共享名称 = 文件_取文件名 (待处理的文件夹)
        }
        运行控制台程序 ("net share " + 共享名称 + "=" + 待处理的文件夹, 结果, , , , , , )
        返回 (寻找文本 (结果, "共享成功") != -1)
    }

    方法 文件共享_关闭共享 <公开 静态 类型 = 逻辑型 折叠>
    参数 待处理的文件夹 <类型 = 文本型>
    {
        变量 结果 <类型 = 文本型>
        运行控制台程序 ("net share " + 待处理的文件夹 + " /y /del", 结果, , , , , , )
        返回 (寻找文本 (结果, "已经删除") != -1)
    }

    方法 文件共享_设置权限 <公开 静态 类型 = 逻辑型 折叠>
    参数 待处理的文件夹 <类型 = 文本型>
    参数 权限类型 <类型 = 整数 注释 = "1、完全控制　2、拒绝访问" @默认值 = 1>
    {
        变量 结果 <类型 = 文本型>
        变量 权限 <类型 = 文本型>
        如果 (权限类型 == 2)
        {
            权限 = "n"
        }
        否则
        {
            权限 = "f"
        }
        运行控制台程序 ("cacls " + 待处理的文件夹 + " /e /t /p everyone:" + 权限, 结果, , , , , , )
        返回 (寻找文本 (结果, "处理的目录") != -1 || 寻找文本 (结果, "处理的文件") != -1)
    }
}

类 打开方式 <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写.附加类\"" @常量类 = 整数>
{
    常量 新建 <公开 值 = @CREATE_NEW 注释 = "创建一个新文件,如果文件已经存在则返回失败">
    常量 新建或覆盖 <公开 值 = @CREATE_ALWAYS 注释 = "创建一个新文件,如果文件存在，则覆盖这个文件,并且清除其属性">
    常量 打开 <公开 值 = @OPEN_EXISTING 注释 = "打开文件,如果文件不存在则打开失败">
    常量 打开或创建 <公开 值 = @OPEN_ALWAYS 注释 = "如果文件则打开文件，如果不存在则会创建文件,此时和CREATE_NEW功能一样">
    常量 清空 <公开 值 = @TRUNCATE_EXISTING 注释 = "打开文件。 打开后，文件将被截断，因此其大小为零字节。"
            注释 = "调用过程必须打开至少具有GENERIC_WRITE访问权限的文件。 如果文件不存在，该功能将失败。">

    #
}

类 共享方式 <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写.附加类\"" @常量类 = 整数>
{
    常量 不共享 <公开 值 = 0 注释 = "不共享， 如果当前软件打开设备后，其他设备就不能打开操作了">
    常量 共享读 <公开 值 = @FILE_SHARE_READ 注释 = "例如两个软件同时操作 a.txt 如果指定这个标志，表示两个软件都可以对a.txt读  否则只有第一个打开a.txt 的可以操作，其他的不能">
    常量 共享写 <公开 值 = @FILE_SHARE_WRITE 注释 = "例如两个软件同时操作 a.txt 如果指定这个标志，表示两个软件都可以对a.txt写  否则只有第一个打开a.txt 的可以操作，其他的不能">
    常量 共享读写 <公开 值 = @"@FILE_SHARE_WRITE|FILE_SHARE_READ">
    常量 共享删除 <公开 值 = @FILE_SHARE_DELETE 注释 = "原理同上">

    #
}

类 文件常量 <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写.附加类\"" @常量类 = 整数>
{
    常量 文件首 <公开 值 = @FILE_BEGIN 注释 = "文件指针起始位置为文件起始位置，当调用SetFilePointerEx成功后，" 注释 = "文件指针将指向liDistanceToMove指向的位置。"
            注释 = "FILE_BEGIN The starting point is zero or the beginning of the file.">
    常量 当前位置 <公开 值 = @FILE_CURRENT 注释 = "文件指针起始位置为当前文件指针指向的位置"
            注释 = "FILE_CURRENT The starting point is the current value of the file pointer.">
    常量 文件尾 <公开 值 = @FILE_END 注释 = "文件指针起始位置为文件末尾" 注释 = "FILE_END The starting point is the current end-of-file position.">

    #
}

类 访问方式 <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件读写.附加类\"" @常量类 = 整数>
{
    常量 读 <公开 值 = @GENERIC_READ>
    常量 写 <公开 值 = @GENERIC_WRITE>
    常量 读写 <公开 值 = @"@GENERIC_READ|GENERIC_WRITE">

    #
}

# //====文件访问权限====

类 文件访问权限类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.访问权限\"" @全局类 = 真>
{
    方法 修改文件权限_ <公开 静态 类型 = 逻辑型 注释 = "控制文件的访问权限，包括读取、写入、执行等操作">
    参数 目标文件 <类型 = 文本型>
    参数 类型 <类型 = 整数 注释 = "-1、全部拒绝 -2、拒绝修改 -3、拒绝读取和执行 -4、拒绝读取 -5、拒绝写入." 注释 = "1、全部允许  2、允许修改 3、允许读取和执行 4、允许读取 5、允许写入" @默认值 = -1>
    {
        变量 结果 <类型 = 文本型>
        如果 (类型 == -1)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /deny everyone:F", 结果)
        }
        否则 (类型 == -2)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /deny everyone:M", 结果)
        }
        否则 (类型 == -3)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /deny everyone:RX", 结果)
        }
        否则 (类型 == -4)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /deny everyone:R", 结果)
        }
        否则 (类型 == -5)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /deny everyone:W", 结果)
        }
        否则 (类型 == 1)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /grant everyone:F", 结果)
        }
        否则 (类型 == 2)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /grant everyone:M", 结果)
        }
        否则 (类型 == 3)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /grant everyone:RX", 结果)
        }
        否则 (类型 == 4)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /grant everyone:R", 结果)
        }
        否则 (类型 == 5)
        {
            运行控制台程序 ("cmd /c icacls " + 目标文件 + " /grant everyone:W", 结果)
        }
        如果真 (寻找文本 (结果, "0 个文件时失败", , 真) != -1)
        {
            返回 (真)
        }
        返回 (假)
    }
}

# //====文件监视操作====

类 文件监视类_ <公开 注释 = "监视文件信息变动情况，例如：文件的新建、删除、修改、重命名，都将触发变动提示" 折叠 @文档 = "category = \"文件操作类.文件监视\"">
{
    变量 句柄组 <类型 = 变整数数组类>
    变量 线程 <类型 = 线程池类2_>
    变量 是否停止 <类型 = 逻辑型>
    变量 已监视 <类型 = 逻辑型>
    变量 队列1 <类型 = 超级队列类_>

    方法 开始监视_ <公开 类型 = 逻辑型 注释 = "参数1、参数2、参数3只需给一个即可，或全给。退出程序前请执行“停止监视_”，否则无法结束进程" 折叠>
    参数 监视目录 <类型 = 文本型 注释 = "例如：“C:\\\\目录A”" @默认值 = "">
    参数 监视目录组 <类型 = 文本数组类 注释 = "与参数1一样，给的是数组形式，可加入多个目录" @默认值 = 空对象>
    参数 监视分区组 <类型 = 文本数组类 注释 = "给磁盘分区符号，监视某分区，可加入多个分区。如：“C:\\\\”" @默认值 = 空对象>
    {
        变量 目录 <类型 = 目录信息类>
        变量 临时 <类型 = 文本型>
        如果真 (已监视)
        {
            调试输出 ("已经开启")
            返回 (假)
        }
        如果真 (文本是否为空 (监视目录) && 监视目录组.取成员数 () == 0 && 监视分区组.取成员数 () == 0)
        {
            调试输出 ("还未设置目录信息")
            返回 (假)
        }
        如果真 (文本是否为空 (监视目录) == 假)
        {
            监视目录组.加入成员 (监视目录)
        }
        监视分区组.枚举循环 ()
        {
            临时 = 监视分区组.取枚举值 ()
            如果真 (取文本右边 (临时, 1) != "\\")
            {
                临时 = 临时 + "\\"
            }
            如果真 (取文本中间 (临时, 1, 1) == ":")
            {
                监视目录组.加入成员 ("\\??\\" + 临时)
            }
        }
        如果真 (监视目录组.取成员数 () > 0)
        {
            已监视 = 真
            处理事件_ ()
        }
        是否停止 = 假
        队列1.启用消息等待_ ()
        线程.创建_ (监视目录组.取成员数 (), , )
        监视目录组.枚举循环 ()
        {
            目录.目录名 = 监视目录组.取枚举值 ()
            线程.投递对象_ (, 目录, )
        }
        返回 (监视目录组.取成员数 () > 0)
    }

    方法 停止监视_ <公开 注释 = "退出程序前请执行停止，否则无法结束进程" 折叠>
    {
        是否停止 = 真
        已监视 = 假
        队列1.停止消息等待_ ()
        句柄组.枚举循环 ()
        {
            关闭文件 (句柄组.取枚举值 ())
        }
        句柄组.删除所有成员 ()
    }

    方法 线程池类2__线程池事件_对象 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类2_>
    参数 标记值 <类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户对象 <类型 = 对象类>
    参数 用户数据 <类型 = 变整数>
    {
        变量 目录 <类型 = 目录信息类>
        目录 = (目录信息类)用户对象
        监视文件 (目录.目录名)
        返回 (0)
    }

    方法 监视文件 <折叠 @禁止流程检查 = 真>
    参数 路径 <类型 = 文本型>
    {
        变量 名称变量 <类型 = 文本型>
        变量 临时句柄 <类型 = 变整数>
        @ HANDLE hDirectory=CreateFile(@<路径>,GENERIC_READ|GENERIC_WRITE|FILE_LIST_DIRECTORY,FILE_SHARE_READ|FILE_SHARE_WRITE|FILE_SHARE_DELETE,NULL,OPEN_EXISTING,FILE_FLAG_BACKUP_SEMANTICS|FILE_FLAG_OVERLAPPED,NULL);
        @
        @   if(hDirectory==INVALID_HANDLE_VALUE)
        @   {
        @     DWORD dwErr=GetLastError();
        投递变动信息 (-1, 路径, 名称变量, "打开监视目录失败")
        @     return;
        @   }
        @ @<临时句柄>=(@dt<变整数>)hDirectory;
        句柄组.加入成员 (临时句柄)
        @
        @ char notify[65536]; 
        @  BOOL watch_state;
        @  memset(notify, 0, sizeof(notify)); 
        @  FILE_NOTIFY_INFORMATION *pNotification=(FILE_NOTIFY_INFORMATION *)notify; 
        @  DWORD BytesReturned=0; 
        @
        @  while (TRUE)
        @ {
        @
        @ if (@<是否停止>==true)
        @ {
        @    break;
        @ }
        @
        @   ZeroMemory(pNotification, sizeof(notify));
        @   watch_state=ReadDirectoryChangesW(hDirectory,&notify,sizeof(notify),TRUE,FILE_NOTIFY_CHANGE_FILE_NAME|FILE_NOTIFY_CHANGE_DIR_NAME|FILE_NOTIFY_CHANGE_ATTRIBUTES|FILE_NOTIFY_CHANGE_SIZE|FILE_NOTIFY_CHANGE_LAST_WRITE|FILE_NOTIFY_CHANGE_LAST_ACCESS|FILE_NOTIFY_CHANGE_CREATION|FILE_NOTIFY_CHANGE_SECURITY,(LPDWORD)&BytesReturned,NULL,NULL);
        @
        @   if (GetLastError()==ERROR_INVALID_FUNCTION)
        @   {
        投递变动信息 (-1, 路径, 名称变量, "不支持该系统")
        @    break;
        @   }
        @
        @   else if(watch_state == FALSE)
        @   {
        @    DWORD dwErr = GetLastError();
        投递变动信息 (-1, 路径, 名称变量, "监视目录失败")
        @    break;
        @   }
        @
        @   else if (GetLastError()==ERROR_NOTIFY_ENUM_DIR)
        @   {
        投递变动信息 (-1, 路径, 名称变量, "缓冲区溢出")
        @    continue;
        @   }
        @
        @   else
        @   {
        @    CString szFileName(pNotification->FileName, pNotification->FileNameLength / sizeof(wchar_t));
        @    
        @    if (pNotification->Action==FILE_ACTION_ADDED)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (0, 路径, 名称变量, "")
        @    }
        @
        @    else if (pNotification->Action==FILE_ACTION_REMOVED)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (1, 路径, 名称变量, "")
        @    }
        @
        @    else if (pNotification->Action==FILE_ACTION_MODIFIED)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (2, 路径, 名称变量, "")
        @    }
        @
        @    else if (pNotification->Action==FILE_ACTION_RENAMED_OLD_NAME)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (3, 路径, 名称变量, "")
        @    }
        @
        @    else if (pNotification->Action==FILE_ACTION_RENAMED_NEW_NAME)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (3, 路径, 名称变量, "")
        @    }
        @
        @    else if (@<是否停止>!=true)
        @    {
        @ @<名称变量>=(@dt<文本型>)szFileName;
        投递变动信息 (4, 路径, 名称变量, "")
        @    }
        @   }
        @ }
    }

