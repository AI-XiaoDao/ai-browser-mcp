<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"文件操作库\"">

# //====文件属性====

类 文件属性类_ <公开 折叠 @全局类 = 真>
{
    方法 取文件属性_ <公开 静态 类型 = 整数 返回值注释 = "1、只读文件 2、隐藏文件 4、系统文件 16、子目录 32、存档文件 128、通常文件 256、临时文件" 折叠 @禁止流程检查 = 真>
    参数 目标文件 <类型 = 文本型>
    {
        @ return ::GetFileAttributesW(@<目标文件>);
    }

    方法 置文件属性_ <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 目标文件 <类型 = 文本型>
    参数 属性值 <类型 = 整数 注释 = "0、取消所有 1、只读文件 2、隐藏文件 4、系统文件 16、子目录 32、存档文件 128、通常文件 256、临时文件" 注释 = "通过值相加可以设置多个属性">
    {
        @ return ::SetFileAttributesW(@<目标文件>,@<属性值>);
    }
}

# //====文本数据读写====

类 文本数据读取类_ <公开 注释 = "用于快速便捷操作文本变量，快速取出指定行数据." 注释 = "操作流程如下:" 注释 = "1、加载变量" 注释 = "2、读入文本行、读入文本行2、删除文本行、修改文本行、插入文本行"
        注释 = "3、取出修改数据、取出修改数据2" 折叠 折叠2 @文档 = "category = \"文件操作类.文本读写\"">
{
    变量 全局是否为ANSI <类型 = 逻辑型>
    变量 数据组 <类型 = 字节集数组类>
    变量 是否加载文本 <类型 = 逻辑型>

    方法 加载变量 <公开 类型 = 整数 返回值注释 = "返回文本总行数，错误返回-1" 折叠>
    参数 文本变量 <类型 = 文本型 注释 = "参数一和二，只需要提供一个即可" @默认值 = "">
    参数 字节集变量 <类型 = 字节集类 注释 = "参数一和二，只需要提供一个即可" @默认值 = 空对象>
    参数 限制获取数量 <类型 = 整数 注释 = "限制获取文本行的最大行数，为0表示返回全部行" @默认值 = 0>
    参数 是否为ANSI <类型 = 逻辑型 注释 = "真：ANSI(多字节集)　假：UTF8　，本参数针对“字节集变量”参数起作用" @默认值 = 真>
    {
        如果真 (文本是否为空 (文本变量) && 字节集变量.取字节集长度 () == 0)
        {
            返回 (-1)
        }
        如果 (文本是否为空 (文本变量))
        {
            是否加载文本 = 假
        }
        否则
        {
            是否加载文本 = 真
        }
        全局是否为ANSI = 是否为ANSI
        返回 (分割文本字节集_ (文本变量, 字节集变量, "\r\n", , 数据组, 限制获取数量))
    }

    方法 取文本行数 <公开 类型 = 整数 注释 = "先执行“加载变量”命令，再执行本命令" 折叠>
    {
        返回 (数据组.取成员数 ())
    }

    方法 读入文本行 <公开 类型 = 文本型 注释 = "先执行“加载变量”命令" 折叠>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    {
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 数据组.取成员数 () - 1)
        {
            指定行 = 数据组.取成员数 () - 1
        }
        如果真 (是否加载文本)
        {
            返回 (字节集到文本 (数据组.取成员 (指定行)))
        }
        返回 (选择 (全局是否为ANSI, 多字节到文本_ (数据组.取成员 (指定行)), UTF8到文本_ (数据组.取成员 (指定行))))
    }

    方法 读入文本行2 <公开 类型 = 字节集类 注释 = "先执行“加载变量”命令" 返回值注释 = "如果加载的是文本变量，返回值用“字节集到文本 ()”转换" 折叠>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    {
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 数据组.取成员数 () - 1)
        {
            指定行 = 数据组.取成员数 () - 1
        }
        返回 (数据组.取成员 (指定行))
    }

    方法 删除文本行 <公开 注释 = "先执行“加载变量”命令" 折叠>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    {
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 数据组.取成员数 () - 1)
        {
            指定行 = 数据组.取成员数 () - 1
        }
        数据组.删除成员 (指定行)
    }

    方法 修改文本行 <公开 注释 = "先执行“加载变量”命令" 折叠>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    参数 新内容 <类型 = 文本型>
    {
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 数据组.取成员数 () - 1)
        {
            指定行 = 数据组.取成员数 () - 1
        }
        如果 (是否加载文本)
        {
            数据组.置成员值 (指定行, 文本到字节集 (新内容))
        }
        否则
        {
            数据组.置成员值 (指定行, 选择 (全局是否为ANSI, 文本到多字节_ (新内容), 文本到UTF8_ (新内容)))
        }
    }

    方法 插入文本行 <公开 注释 = "先执行“加载变量”命令" 折叠>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    参数 新内容 <类型 = 文本型>
    {
        变量 是否超尾行 <类型 = 逻辑型>
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 数据组.取成员数 () - 1)
        {
            是否超尾行 = 真
        }
        如果 (是否加载文本)
        {
            如果 (是否超尾行)
            {
                数据组.加入成员 (文本到字节集 (新内容))
            }
            否则
            {
                数据组.插入成员 (指定行, 文本到字节集 (新内容))
            }
        }
        否则
        {
            如果 (是否超尾行)
            {
                数据组.加入成员 (选择 (全局是否为ANSI, 文本到多字节_ (新内容), 文本到UTF8_ (新内容)))
            }
            否则
            {
                数据组.插入成员 (指定行, 选择 (全局是否为ANSI, 文本到多字节_ (新内容), 文本到UTF8_ (新内容)))
            }
        }
    }

    方法 取出修改数据 <公开 类型 = 文本型 注释 = "先执行“加载变量”命令" 折叠>
    {
        变量 临时数据 <类型 = 文本型>
        置文本预分配字符数 (临时数据, 取数据尺寸 (数据组))
        如果 (是否加载文本)
        {
            数据组.枚举循环 ()
            {
                加入文本 (临时数据, 字节集到文本 (数据组.取枚举值 ()) + "\r\n")
            }
        }
        否则
        {
            数据组.枚举循环 ()
            {
                加入文本 (临时数据, 选择 (全局是否为ANSI, 多字节到文本_ (数据组.取枚举值 ()), UTF8到文本_ (数据组.取枚举值 ())) + "\r\n")
            }
        }
        返回 (取文本左边 (临时数据, 取文本长度 (临时数据) - 2))
    }

    方法 取出修改数据2 <公开 类型 = 字节集类 注释 = "先执行“加载变量”命令" 返回值注释 = "如果加载的是文本变量，返回值用“字节集到文本 ()”转换" 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 换行 <类型 = 字节集类>
        临时数据.置字节集预分配尺寸 (取数据尺寸 (数据组))
        换行 = 文本到UTF8_ ("\r\n")
        数据组.枚举循环 ()
        {
            临时数据.添加字节集 (数据组.取枚举值 ())
            临时数据.添加字节集 (换行)
        }
        返回 (临时数据.取字节集左边 (临时数据.取字节集长度 () - 2))
    }

    方法 取出修改数据3 <公开 类型 = 字节集数组类 注释 = "先执行“加载变量”命令" 返回值注释 = "返回数组形式数据。如果加载的是文本变量，返回值用“字节集到文本 ()”转换" 折叠>
    {
        返回 (数据组)
    }

    方法 关闭变量 <公开 注释 = "清空“加载变量”所加载的数据" 折叠>
    {
        数据组.删除所有成员 ()
    }
}

# //====大文档读写====

类 文档读取类_ <公开 注释 = "用于快速读取超大文档，快速取出指定行数据." 注释 = "一、整文档读取操作流程：(一次性分析，文档越大时间越久)" 注释 = "1、打开文件 2、取文本行数 3、读入文本行 4、关闭文件." 注释 = ""
        注释 = "二、文档分段读取操作流程：(按段分析，文档再大也可瞬间完成)" 注释 = "1、加载文档_ 2、读取文档段落_ 3、读入文本行_段落 ." 注释 = "" 注释 = "三、可编辑文档操作流程：(不适合太大的文档，否则影响速度)"
        注释 = "1、打开文件 2、生成可编辑文档 3、删除文本行 4、修改文本行 5、插入文本行 6、保存文档." 折叠 折叠2 @文档 = "category = \"文件操作类.文本读写\"">
{
    变量 记号 <类型 = 字节集类 折叠>
    变量 句柄 <类型 = 变整数>
    变量 总尺寸 <类型 = 长整数>
    变量 索引组 <类型 = 整数数组类>
    变量 段落组 <类型 = 整数数组类>
    变量 总行数 <类型 = 长整数 值 = -1>
    变量 总段数 <类型 = 长整数>
    变量 指定距离 <类型 = 整数 值 = 0>
    变量 读取长度 <类型 = 整数 值 = 5242880>
    变量 全局是否为ANSI <类型 = 逻辑型>
    变量 线程1 <类型 = 线程类>
    变量 线程2 <类型 = 线程类>
    变量 线程3 <类型 = 线程类>
    变量 缓存数据 <类型 = 字节集类>
    变量 有无尾部 <类型 = 逻辑型>
    变量 可编辑 <类型 = 逻辑型>
    变量 全局文件路径 <类型 = 文本型>
    变量 已启动 <类型 = 逻辑型>
    变量 是否尾行 <类型 = 逻辑型>

    方法 类_清理 <折叠>
    {
        关闭文件 ()
    }

    方法 打开文件 <公开 类型 = 逻辑型 折叠>
    参数 文件路径 <类型 = 文本型>
    参数 打开方式 <类型 = 打开方式 注释 = "默认是打开或创建" @默认值 = 打开方式.打开或创建>
    参数 共享模式 <类型 = 共享方式 注释 = "默认是共享读写" @默认值 = 共享方式.共享读写>
    参数 访问方式 <类型 = 访问方式 注释 = "默认是读写" @默认值 = 访问方式.读写>
    参数 是否为ANSI <类型 = 逻辑型 注释 = "真：ANSI(多字节集)　假：UTF8　" @默认值 = 真>
    {
        如果真 (文件是否存在 (文件路径) == 假)
        {
            返回 (假)
        }
        全局是否为ANSI = 是否为ANSI
        记号 = 选择 (是否为ANSI == 真, 文本到多字节 ("\r\n", 假), 文本到UTF8 ("\r\n", 假))
        索引组.删除所有成员 ()
        索引组.预分配尺寸 = 40960
        指定距离 = 0
        读取长度 = 5242880
        句柄 = 文件读写_打开文件 (文件路径, 打开方式, 共享模式, 访问方式)
        总尺寸 = 文件读写_取文件尺寸 (句柄)
        全局文件路径 = 文件路径
        返回 (选择 (句柄 > 0, 真, 假))
    }

    方法 关闭文件 <公开 注释 = "其它所有操作完成后，最后执行本命令" 折叠>
    {
        索引组.删除所有成员 ()
        缓存数据.重置为空对象 ()
        如果真 (句柄 > 0)
        {
            文件读写_关闭文件 (句柄)
        }
        句柄 = 0
        连续赋值 (假, 可编辑, 有无尾部, 已启动)
        连续赋值 (-1, 总行数, 总段数)
    }

    方法 取文本行数 <公开 类型 = 长整数 注释 = "先执行“打开文件”，操作完毕后执行“关闭文件”." 注释 = "取出该文档共有多少行数据，顺便建立索引(一次性分析整个文档)." 返回值注释 = "错误返回－1，成功返回文档行数" 折叠
            折叠2>
    {
        如果真 (已启动 == 真)
        {
            调试输出 ("已经在执行")
            返回 (-1)
        }
        已启动 = 真
        处理事件_ ()
        如果真 (句柄 < 1)
        {
            调试输出 ("请先执行打开文件")
            返回 (-1)
        }
        线程1.启动 ()
        总行数 = -1
        判断循环 (总行数 == -1)
        {
            延迟2_ (1)
        }
        已启动 = 假
        返回 (总行数)
    }

    方法 读入文本行 <公开 类型 = 文本型 注释 = "先执行“打开文件”，首次会建立索引所以时间消耗会多些(一次性分析整个文档)." 注释 = "读取文档中指定行的数据，首次会慢些" 折叠 折叠2>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    {
        变量 前位置 <类型 = 整数类>
        变量 长度 <类型 = 整数类>
        变量 数据 <类型 = 字节集类>
        如果真 (句柄 < 1)
        {
            返回 ("请先执行打开文件")
        }
        如果真 (索引组.取成员数 () == 0)
        {
            取文本行数 ()
        }
        如果真 (索引组.取成员数 () == 0)
        {
            返回 ("无信息")
        }
        定位行索引 (指定行, 前位置, 长度)
        文件读写_移动读写位置 (句柄, 前位置.值, 文件常量.文件首)
        数据 = 文件读写_读入字节集 (句柄, 长度.值)
        如果真 (数据.取字节集右边 (2) == 记号)
        {
            数据 = 数据.取字节集左边 (数据.取字节集长度 () - 2)
        }
        如果 (全局是否为ANSI == 真)
        {
            返回 (多字节到文本 (数据))
        }
        否则 (全局是否为ANSI == 假)
        {
            返回 (UTF8到文本_ (数据))
        }
        返回 ("")
    }

    方法 生成可编辑文档 <公开 类型 = 长整数 注释 = "先执行“打开文件”，再执行本命令，最后可可执行“删除文本行、修改文本行、插入文本行”等." 注释 = "执行本命令后，可对该文档进行增删修操作。不推荐操作很大的文档"
            返回值注释 = "错误返回－1，成功返回文档行数" 折叠 折叠2>
    {
        变量 临时数据 <类型 = 字节集类>
        如果真 (句柄 < 1)
        {
            调试输出 ("请先执行打开文件")
            返回 (-1)
        }
        如果真 (索引组.取成员数 () == 0)
        {
            取文本行数 ()
        }
        如果真 (索引组.取成员数 () == 0)
        {
            调试输出 ("无信息")
            返回 (-1)
        }
        缓存数据.置字节集预分配尺寸 ((整数)总尺寸)
        文件读写_移动读写位置 (句柄, 0, 文件常量.文件首)
        缓存数据 = 文件读写_读入字节集 (句柄)
        如果真 (缓存数据.取字节集长度 () != 总尺寸)
        {
            返回 (-1)
        }
        可编辑 = 真
        是否尾行 = 假
        返回 (总行数)
    }

    方法 删除文本行 <公开 类型 = 逻辑型 注释 = "先执行“打开文件”，再执行“生成可编辑文档”，最后执行本命令." 注释 = "删除文档中指定行数据，删除一行后，原行数序号会变动，整体会进行减位缩进，所以删除一行后需要重新给予新的指定行"
            折叠 折叠2>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    {
        变量 前位置 <类型 = 整数类>
        变量 长度 <类型 = 整数类>
        变量 临时数据 <类型 = 字节集类>
        变量 长度组 <类型 = 整数数组类>
        变量 删除长度 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (句柄 < 1)
        {
            调试输出 ("请先执行打开文件")
            返回 (假)
        }
        如果真 (索引组.取成员数 () == 0)
        {
            取文本行数 ()
        }
        如果真 (索引组.取成员数 () == 0)
        {
            调试输出 ("无信息")
            返回 (假)
        }
        如果真 (可编辑 == 假)
        {
            调试输出 ("请先执行生成可编辑文档")
            返回 (假)
        }
        如果真 (指定行 < 0)
        {
            指定行 = 0
        }
        如果真 (指定行 > 索引组.取成员数 () - 1)
        {
            指定行 = 索引组.取成员数 () - 1
        }
        如果真 (索引组.取成员数 () == 0)
        {
            返回 (假)
        }
        定位行索引 (指定行, 前位置, 长度)
        删除长度 = 定位行索引 (i) + 2
        循环 (指定行, 索引组.取成员数 (), i)
        {
            索引组.置成员值 (i, 索引组.取成员 (i) - 删除长度)
        }
        索引组.删除成员 (指定行)
        如果 (指定行 <= 索引组.取成员数 () - 1)
        {
            如果 (指定行 == 0)
            {
                缓存数据.字节集删除 (前位置.值, 长度.值 + 2)
            }
            否则
            {
                缓存数据.字节集删除 (前位置.值, 长度.值)
            }
        }
        否则
        {
            如果 (索引组.取成员数 () == 1)
            {
                缓存数据.字节集删除 (前位置.值 - 2, 长度.值)
            }
            否则
            {
                如果 (有无尾部)
                {
                    缓存数据.字节集删除 (前位置.值, 长度.值 + 2)
                }
                否则
                {
                    如果 (索引组.取成员数 () == 0)
                    {
                        缓存数据.清空字节集 ()
                        索引组.删除所有成员 ()
                    }
                    否则
                    {
                        缓存数据.字节集删除 (前位置.值 - 2, 长度.值 + 2)
                    }
                }
            }
        }
        返回 (真)
    }

    方法 修改文本行 <公开 类型 = 逻辑型 注释 = "先执行“打开文件”，再执行“生成可编辑文档”，最后执行本命令." 注释 = "修改文档中指定行数据" 折叠 折叠2>
    参数 指定行 <类型 = 整数 注释 = "从0开始，0就是第一行">
    参数 新内容 <类型 = 文本型>
    {
        如果 (指定行 >= 索引组.取成员数 () - 1)
        {
            是否尾行 = 真
        }
        否则
        {
            是否尾行 = 假
        }
        如果真 (删除文本行 (指定行) == 真)
        {
            返回 (插入文本行2 (指定行, 新内容))
        }
        返回 (假)
    }

