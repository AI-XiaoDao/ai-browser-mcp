        @ ofn.hwndOwner = @<父窗口句柄> ? (HWND)@<父窗口句柄> : NULL;
        @ @an<CVolMem> szFilter;
        @ if (@<过滤器>.IsEmpty ()) {
        @     ofn.lpstrFilter = NULL;
        @ } else {
        @     szFilter.AddTextValue (@<过滤器>, TRUE);
        @     szFilter.ReplaceBin (CVolMem (_CT ("|")), CVolMem ().AddManyBytes (2, 0, 0), 0, 0);
        @     szFilter.AddWord (0);
        @     ofn.lpstrFilter = reinterpret_cast<const WCHAR*>(szFilter.GetPtr ());
        @ }
        @ ofn.lpstrInitialDir = @<初始目录>.IsEmpty () ? NULL : @<初始目录>.GetText ();
        @ WCHAR szBuffer[MAX_PATH * 4];
        @ if (@<默认文件名>.IsEmpty ())
        @     szBuffer[0] = '\0';
        @ else
        @     wcscpy_s (szBuffer, MAX_PATH * 4, @<默认文件名>.GetText ());
        @ ofn.lpstrFile = szBuffer;
        @ ofn.lpstrTitle = @<对话框标题>.IsEmpty () ? NULL : @<对话框标题>.GetText ();
        @ ofn.nMaxFile = sizeof (szBuffer);
        @ ofn.nFilterIndex = static_cast<DWORD>(@<初始过滤器>);
        @ ofn.lpstrDefExt = @<默认文件后缀>.IsEmpty () ? NULL : @<默认文件后缀>.GetText ();
        @ ofn.Flags = OFN_EXPLORER | OFN_HIDEREADONLY | OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST;
        @ if (@<文件覆盖提示>) ofn.Flags |= OFN_OVERWRITEPROMPT;
        @ if (@<不改变目录>) ofn.Flags |= OFN_NOCHANGEDIR;
        @ if (@<启用对话框>) ofn.Flags |= OFN_ENABLETEMPLATE;
        @ if (::GetSaveFileNameW (&ofn)) {
        @     @<默认文件名>.SetText (ofn.lpstrFile);
        @     return ofn.lpstrFile;
        @ }
        @ @<默认文件名>.Empty ();
        @ return _T("");
    }

    方法 文件_浏览选择保存文件 <公开 类型 = 文本型 折叠>
    {
        返回 (浏览选择保存文件_ ())
    }
}

# //====文件尺寸====

类 文件尺寸类_ <公开 折叠 折叠2 @文档 = "category = \"文件操作类.文件尺寸\"" @全局类 = 真>
{
    方法 取文件夹尺寸_ <公开 静态 类型 = 长整数 注释 = "取出整个文件夹总大小" 返回值注释 = "单位为字节, 失败返回-1" 折叠 @禁止流程检查 = 真>
    参数 文件夹路径 <类型 = 文本型>
    {
        变量 FSO <类型 = COM对象类>
        变量 GetFolder <类型 = COM对象类>
        变量 Size <类型 = 长整数 值 = -1>
        初始化COM库_ ()
        如果真 (FSO.创建 ("Scripting.FileSystemObject"))
        {
            GetFolder = FSO.方法 ("GetFolder", COM对象类, 文件夹路径)
            Size = GetFolder.读无参数属性 ("Size", 长整数)
        }
        关闭COM库_ ()
        返回 (Size)
    }

    方法 文件_取文件夹尺寸 <公开 类型 = 长整数 注释 = "取出整个文件夹总大小" 折叠>
    参数 文件夹路径 <类型 = 文本型>
    {
        返回 (取文件夹尺寸_ (文件夹路径))
    }

    方法 取文件目录尺寸_ <公开 静态 类型 = 长整数 注释 = "支持文件和文件夹" 返回值注释 = "执行成功返回文件尺寸(单位字节)，返回-1表示错误" 折叠>
    参数 文件名 <类型 = 文本型>
    {
        变量 临时大小 <类型 = 长整数>
        如果 (文件_是否为文件 (文件名) == 真)
        {
            临时大小 = 取文件尺寸 (文件名)
            如果真 (临时大小 == -1)
            {
                返回 (-1)
            }
        }
        否则 (文件_是否为文件夹 (文件名) == 真)
        {
            变量 文件组 <类型 = 文本数组类>
            变量 临时大小2 <类型 = 长整数>
            枚举文件_ (文件名, , 文件组, , 真, 真, 真)
            文件组.枚举循环 ()
            {
                临时大小2 = 取文件尺寸 (文件组.取枚举值 ())
                如果 (临时大小 == -1)
                {
                    返回 (-1)
                }
                否则
                {
                    临时大小 = 临时大小 + 临时大小2
                }
            }
        }
        返回 (临时大小)
    }

    方法 文件_取文件目录尺寸 <公开 类型 = 长整数 注释 = "支持文件和文件夹" 折叠>
    参数 文件名 <类型 = 文本型>
    {
        返回 (取文件目录尺寸_ (文件名))
    }
}

