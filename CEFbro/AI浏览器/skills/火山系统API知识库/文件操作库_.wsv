    方法 定位行索引 <类型 = 整数 注释 = "内部调用" 折叠>
    参数 指定行 <类型 = 整数>
    参数 返回前位置 <类型 = 整数类 @默认值 = 空对象>
    参数 返回长度 <类型 = 整数类 @默认值 = 空对象>
    {
        变量 前位置 <类型 = 整数>
        变量 长度 <类型 = 整数>
        如果真 (指定行 < 0)
        {
            指定行 = 0
            长度 = 索引组.取成员 (0)
        }
        如果 (指定行 + 1 > 索引组.取成员数 ())
        {
            指定行 = 索引组.取成员数 () - 1
        }
        如果 (指定行 == 0)
        {
            前位置 = 0
            长度 = 索引组.取成员 (0)
        }
        否则
        {
            前位置 = 索引组.取成员 (指定行 - 1) + 2
            长度 = 索引组.取成员 (指定行) - 索引组.取成员 (指定行 - 1)
        }
        返回前位置.值 = 前位置
        返回长度.值 = 长度
        返回 (长度)
    }

