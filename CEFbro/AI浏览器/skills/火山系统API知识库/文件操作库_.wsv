    方法 文件_文件大小转单位 <公开 静态 类型 = 文本型 折叠>
    参数 文件大小 <类型 = 长整数>
    {
        如果 (文件大小 < 1024)
        {
            返回 (到文本 (四舍五入 ((小数)文件大小, 1)) + "B")
        }
        否则 (文件大小 < 1048576 && 文件大小 > 1023)
        {
            返回 (到文本 (四舍五入 ((小数)文件大小 / 1024, 1)) + "KB")
        }
        否则 (文件大小 < 1073741824 && 文件大小 > 1048575)
        {
            返回 (到文本 (四舍五入 ((小数)文件大小 / 1024 / 1024, 1)) + "MB")
        }
        否则 (文件大小 < 1099511627776 && 文件大小 > 1073741823)
        {
            返回 (到文本 (四舍五入 ((小数)文件大小 / 1024 / 1024 / 1024, 1)) + "GB")
        }
        否则
        {
            返回 (到文本 (四舍五入 ((小数)文件大小 / 1024 / 1024 / 1024 / 1024, 1)) + "TB")
        }
    }

    方法 文件_文件大小转单位2 <公开 静态 类型 = 文本型 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "shlwapi.h">
    参数 文件大小 <类型 = 变整数>
    {
        @ wchar_t szResult[100] = { 0 };
        @ if (StrFormatByteSizeW(@<文件大小>, szResult, ARRAYSIZE(szResult))) {
        @ }
        @ else {
        @ return -1;
        @ }
        @ return szResult;
    }

    方法 文件_取文件路径 <公开 静态 类型 = 文本型 注释 = "取文件路径中除名称外的部分" 折叠 @禁止流程检查 = 真>
