    参数 GMT时间 <类型 = 文本型 注释 = "例如：Sun, 29 Jan 2023 19:14:57 GMT">
    {
        变量 pvtime <类型 = 小数>
        @ typedef BOOL(WINAPI* InternetTimeToSystemTimeW)(LPCWSTR lpszTime, SYSTEMTIME* pst, DWORD dwReserved);
        @ HMODULE hModule = LoadLibraryW(L"Wininet.dll");
        @ if (!hModule) return 0;
        @ InternetTimeToSystemTimeW pfnInternetTimeToSystemTimeW = (InternetTimeToSystemTimeW)GetProcAddress(hModule, "InternetTimeToSystemTimeW");
        @ if (pfnInternetTimeToSystemTimeW != NULL)
        @ {
        @     SYSTEMTIME pst;
        @     pfnInternetTimeToSystemTimeW(@<GMT时间>.GetText(), &pst, 0);
        @     SystemTimeToVariantTime(&pst, &@<pvtime>);
        @ }
        @ FreeLibrary(hModule);
        pvtime = 增减时间 (pvtime, 时间字段类型.小时, 8)
        返回 (pvtime)
    }

