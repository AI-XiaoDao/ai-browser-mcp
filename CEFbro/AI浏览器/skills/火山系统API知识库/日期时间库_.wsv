    方法 时间_取指定时间戳3 <公开 静态 类型 = 长整数 返回值注释 = "-1：日期格式无效   -2：日期格式无效   -3：时间格式无效   -4：时间转换失败" 折叠 折叠2
            @视窗.外部头文件 = "iostream\r\nstring\r\nctime\r\nchrono\r\niomanip\r\nsstream\r\nvector\r\nalgorithm\r\ncctype\r\ncstring"
            @禁止流程检查 = 真>
    参数 时间 <类型 = 文本型 注释 = "例如：2021-05-05 16:20:25、2021年05月05日16时26分25秒、2021/05/05 16:26:25、2021-05-05 16:20">
    参数 是否十位 <类型 = 逻辑型 注释 = "真：10位时间戳  假：13位时间戳" @默认值 = 真>
    参数 是否实时填充 <类型 = 逻辑型 注释 = "取13位时，本参数生效。真：当前毫秒时间填充  假：000填充" @默认值 = 真>
    {
        @ std::string processed = CU8String (@<时间>).GetText ();
        @ bool millisecond = @<是否十位>;
        @ bool useCurrentMilliseconds = @<是否实时填充>;
        @ static const std::pair<const char*, const char*> replacements[] = {
        @ {"年", "-"}, {"月", "-"}, {"日", " "},
        @ {"时", ":"}, {"分", ":"}, {"秒", ""},
        @ {"/", "-"}
        @ };
        @ for (const auto& rep : replacements) {
        @ const size_t from_len = std::strlen(rep.first);
        @ const size_t to_len = std::strlen(rep.second);
        @ if (from_len == 1 && to_len == 1) {
        @ std::replace(processed.begin(), processed.end(), rep.first[0], rep.second[0]);
        @ }
        @ else {
        @ size_t start_pos = 0;
        @ while ((start_pos = processed.find(rep.first, start_pos)) != std::string::npos) {
        @ processed.replace(start_pos, from_len, rep.second);
        @ start_pos += to_len;
        @ }
        @ }
        @ }
        @ for (size_t pos = processed.find("  "); pos != std::string::npos; pos = processed.find("  ")) {
        @ processed.replace(pos, 2, " ");
        @ }
        @ const size_t space_pos = processed.find(' ');
        @ if (space_pos == std::string::npos) {
        @ return -1;
        @ }
        @ const std::string date_str = processed.substr(0, space_pos);
        @ std::vector<int> date_parts;
        @ size_t start = 0, end;
        @ while ((end = date_str.find('-', start)) != std::string::npos) {
        @ date_parts.push_back(std::stoi(date_str.substr(start, end - start)));
        @ start = end + 1;
        @ }
        @ date_parts.push_back(std::stoi(date_str.substr(start)));
        @ if (date_parts.size() != 3) {
        @ return -2;
        @ }
        @ const std::string time_str = processed.substr(space_pos + 1);
        @ std::vector<int> time_parts;
        @ start = 0;
        @ while ((end = time_str.find(':', start)) != std::string::npos) {
        @ time_parts.push_back(std::stoi(time_str.substr(start, end - start)));
        @ start = end + 1;
        @ }
        @ time_parts.push_back(std::stoi(time_str.substr(start)));
        @ if (time_parts.size() < 2 || time_parts.size() > 3) {
        @ return -3;
        @ }
        @ struct tm tm = { 0 };
        @ tm.tm_year = date_parts[0] - 1900;
        @ tm.tm_mon = date_parts[1] - 1;
        @ tm.tm_mday = date_parts[2];
        @ tm.tm_hour = time_parts[0];
        @ tm.tm_min = time_parts[1];
        @ tm.tm_sec = time_parts.size() > 2 ? time_parts[2] : 0;
        @ tm.tm_isdst = -1;
        @ const std::time_t timestamp = std::mktime(&tm);
        @ if (timestamp == -1) {
        @ return -4;
        @ }
        @ if (millisecond) {
        @ if (useCurrentMilliseconds) {
        @ const auto now = std::chrono::system_clock::now();
        @ const auto ms = std::chrono::duration_cast<std::chrono::milliseconds>(
        @ now.time_since_epoch()) % 1000;
        @ return timestamp * 1000 + ms.count();
        @ }
        @ else {
        @ return timestamp * 1000;
        @ }
        @ }
        @ return timestamp;
    }

    方法 时间_时间戳到时间 <公开 静态 类型 = 文本型 注释 = "只支持10位时间戳" 折叠 @禁止流程检查 = 真>
    参数 时间戳 <类型 = 整数>
    参数 类型 <类型 = 整数 注释 = "1、年-月-日　2、年-月-日 时:分:秒　默认为1" @默认值 = 1>
    {
        变量 格式 <类型 = 文本型>
        如果 (类型 == 1)
        {
            格式 = "%Y-%m-%d"
        }
        否则
        {
            格式 = "%Y-%m-%d %H:%M:%S"
        }

        @ const TCHAR* lpFormat = (const TCHAR*)@<格式>;
        @ time_t t = @<时间戳>;
        @  TCHAR str_time[100];
        @  struct tm* local_time = localtime(&t);
        @  _tcsftime(str_time, sizeof(str_time), lpFormat, local_time);
        @ return str_time;
    }

