    # @ struct NTPPacket
    # @ {
    # @     union
    # @     {
    # @         struct _ControlWord
    # @         {
    # @             unsigned int uLI : 2;
    # @             unsigned int uVersion : 3;
    # @             unsigned int uMode : 3;
    # @             unsigned int uStratum : 8;
    # @             int nPoll : 8;
    # @             int nPrecision : 8;
    # @         };
    # @         int nControlWord;
    # @     };
    # @     int nRootDelay;
    # @     int nRootDispersion;
    # @     int nReferenceIdentifier;
    # @     __int64 n64ReferenceTimestamp;
    # @     __int64 n64OriginateTimestamp;
    # @     __int64 n64ReceiveTimestamp;
    # @     int nTransmitTimestampSeconds;
    # @     int nTransmitTimestampFractions;
    # @ };

    方法 时间_取现行时间戳_NTP <公开 静态 类型 = 长整数 注释 = "通过NTP服务器获取网络时间，返回10位时间戳，失败返回-1" 折叠 @禁止流程检查 = 真>
    参数 NTP服务器 <类型 = 文本型 @默认值 = "time.windows.com">
    {
        变量 NtpName <类型 = 字节集类>
        NtpName = 文本到多字节 (NTP服务器)
        @ ULONGLONG nlTime = (ULONGLONG)INVALID_SOCKET;
        @ WSADATA wsaData;
        @ if (WSAStartup(MAKEWORD(2, 2), &wsaData) == NO_ERROR)
        @ {
        @     addrinfo hints = { 0 }, * ai_list = NULL;
        @     hints.ai_family = AF_UNSPEC;
        @     hints.ai_socktype = SOCK_DGRAM;
        @     hints.ai_protocol = IPPROTO_UDP;
        @     if (getaddrinfo((const char*)@<NtpName>.GetPtr(), "123", &hints, &ai_list) == NO_ERROR)
        @     {
        @         SOCKET sock;
        @         sock = socket(ai_list->ai_family, ai_list->ai_socktype, ai_list->ai_protocol);
        @         if (sock != INVALID_SOCKET)
        @         {
        @             NTPPacket ntpBuf = { 0 };
        @             ntpBuf.nControlWord = 0x1B;
        @             DWORD dwBufLen = sizeof(ntpBuf);
        @             int iRes = sendto(sock, (const char*)&ntpBuf, dwBufLen, 0, ai_list->ai_addr, (int)ai_list->ai_addrlen);
        @             if (iRes == dwBufLen)
        @             {
        @                 fd_set readfds = { 0 };
        @                 FD_SET(sock, &readfds);
        @                 timeval timeout = { 3,0 };
        @                 if (select((int)sock + 1, &readfds, NULL, NULL, &timeout) > 0)
        @                 {
        @                     FD_ZERO(&ntpBuf);
        @                     iRes = recvfrom(sock, (char*)&ntpBuf, dwBufLen, 0, ai_list->ai_addr, (int*)&ai_list->ai_addrlen);
        @                     if (iRes == dwBufLen)
        @                     {
        @                         nlTime = (ntohl(ntpBuf.nTransmitTimestampSeconds) - 0x83aa7e80);
        @                     }
        @                 }
        @             }
        @         }
        @         freeaddrinfo(ai_list);
        @         closesocket(sock);
        @     }
        @     WSACleanup();
        @ }
        @ return nlTime;
    }

