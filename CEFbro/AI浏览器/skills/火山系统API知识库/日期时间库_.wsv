类 UTC时间类_ <公开 折叠 折叠2 @文档 = "category = \"日期时间库.UTC时间\"" @视窗.外部头文件 = "ctime\r\nsstream\r\niomanip" @全局类 = 真>
{
    方法 时间_取现行UTC时间_ <公开 静态 类型 = 文本型 注释 = "UTC时间 比 北京时间慢8小时" 折叠 @禁止流程检查 = 真>
    {
        @     std::time_t now = std::time(nullptr);
        @     std::tm utc_time;
        @     gmtime_s(&utc_time, &now);
        @     std::stringstream time_stream;
        @     time_stream << std::setfill('0') 
        @                << 1900 + utc_time.tm_year << "-"
        @                << std::setw(2) << 1 + utc_time.tm_mon << "-"
        @                << std::setw(2) << utc_time.tm_mday << " "
        @                << std::setw(2) << utc_time.tm_hour << ":"
        @                << std::setw(2) << utc_time.tm_min << ":"
        @                << std::setw(2) << utc_time.tm_sec;
        @     std::string utc_time_str = time_stream.str();
        @     return utc_time_str.c_str();
    }

    方法 时间_取现行UTC时间戳_ <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ std::time_t timestamp = std::time(nullptr);
        @ return timestamp ;
    }

    方法 时间_取指定UTC时间戳_ <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 时间值 <类型 = 文本型>
    {
        @     std::string time_str = std::string (CU8String (@<时间值>).GetText ());
        @     std::tm tm = {0};
        @     std::istringstream ss(time_str);
        @     ss >> std::get_time(&tm, "%Y-%m-%d %H:%M:%S");
        @     tm.tm_isdst = -1; 
        @     std::time_t timestamp = _mkgmtime(&tm);
        @ return timestamp;
    }
}

