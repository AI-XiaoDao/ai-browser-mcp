    方法 时间_取某日周次 <公开 静态 类型 = 整数 折叠>
    参数 年份 <类型 = 整数 注释 = "默认为当前年份" @默认值 = -1>
    参数 月份 <类型 = 整数 注释 = "默认为当前月份" @默认值 = -1>
    参数 日 <类型 = 整数 注释 = "默认为当前日" @默认值 = -1>
    参数 基准周 <类型 = 整数 注释 = "以此为界限来划分周次。1-7 之间的整数，依次为：周日、周一、周二、周三、周四、周五、周六" @默认值 = 1>
    {
        变量 天数 <类型 = 整数>
        变量 当时 <类型 = 小数>
        变量 结果 <类型 = 整数 值 = -1>
        变量 周次组 <类型 = 整数数组类>
        变量 i <类型 = 整数>
        如果真 (年份 == -1)
        {
            年份 = 取年份 (取现行时间 ())
        }
        如果真 (月份 == -1)
        {
            月份 = 取月份 (取现行时间 ())
        }
        如果真 (日 == -1)
        {
            日 = 取日 (取现行时间 ())
        }
        天数 = 时间_取某月天数 (年份, 月份)
        当时 = 到时间 (到文本 (年份) + "-" + 到文本 (月份) + "-1 00:00:00")
        循环 (, 天数, i)
        {
            如果真 (i > 0)
            {
                当时 = 增减时间 (当时, 时间字段类型.日, 1)
            }
            如果真 (取星期几 (当时) == 基准周)
            {
                周次组.加入成员 (取日 (当时))
            }
        }
        周次组.枚举循环 ()
        {
            如果 (周次组.取枚举值 () >= 日)
            {
                结果 = 周次组.取枚举索引 () + 1
                跳出循环
            }
        }
        返回 (结果)
    }

    方法 时间_取某月周数 <公开 静态 类型 = 整数 折叠>
    参数 年份 <类型 = 整数 注释 = "默认为当前年份" @默认值 = -1>
    参数 月份 <类型 = 整数 注释 = "默认为当前月份" @默认值 = -1>
    参数 基准周 <类型 = 整数 注释 = "以此为界限来划分周数。1-7 之间的整数，依次为：周日、周一、周二、周三、周四、周五、周六" @默认值 = 1>
    {
        变量 天数 <类型 = 整数>
        变量 当时 <类型 = 小数>
        变量 结果 <类型 = 整数>
        变量 i <类型 = 整数>
        如果真 (年份 == -1)
        {
            年份 = 取年份 (取现行时间 ())
        }
        如果真 (月份 == -1)
        {
            月份 = 取月份 (取现行时间 ())
        }
        天数 = 时间_取某月天数 (年份, 月份)
        当时 = 到时间 (到文本 (年份) + "-" + 到文本 (月份) + "-1 00:00:00")
        循环 (, 天数, i)
        {
            如果真 (i > 0)
            {
                当时 = 增减时间 (当时, 时间字段类型.日, 1)
            }
            如果真 (取星期几 (当时) == 基准周)
            {
                结果 = 结果 + 1
            }
        }
        返回 (结果)
    }

