类 格林时间类_ <公开 折叠 折叠2 @文档 = "category = \"日期时间库.格林时间转换\"" @全局类 = 真 @视窗.外部头文件 = "<time.h>\r\n<winhttp.h>\r\n<sys/timeb.h>"
        @视窗.外部库 = "winhttp.lib">
{
    方法 时间_北京时间转GMT时间_小数 <公开 静态 类型 = 文本型 注释 = "转格林威治时间。例如转成：Sun, 29 Jan 2023 19:14:57 GMT" 折叠 @禁止流程检查 = 真>
    参数 北京时间 <类型 = 小数 注释 = "例如：44955.8020486111　，也通过命令获取“取现行时间 ()”">
    {
        变量 北京时间2 <类型 = 小数>
        北京时间2 = 增减时间 (北京时间, 时间字段类型.小时, -8)
        @ typedef BOOL(WINAPI* InternetTimeFromSystemTimeW)(const SYSTEMTIME* pst, DWORD dwRFC, LPWSTR lpszTime, DWORD cbTime);
        @ HMODULE hModule = LoadLibraryW(L"Wininet.dll");
        @ if (!hModule) return "";
        @ InternetTimeFromSystemTimeW pfnInternetTimeFromSystemTimeW = (InternetTimeFromSystemTimeW)GetProcAddress(hModule, "InternetTimeFromSystemTimeW");
        @ TCHAR szTime[WINHTTP_TIME_FORMAT_BUFSIZE] = { 0 };
        @ if (pfnInternetTimeFromSystemTimeW)
        @ {
        @ SYSTEMTIME SystemTime;
        @ VariantTimeToSystemTime(@<北京时间2>, &SystemTime);
        @ pfnInternetTimeFromSystemTimeW(&SystemTime, 0, szTime, WINHTTP_TIME_FORMAT_BUFSIZE);
        @ }
        @ FreeLibrary(hModule);
        @ return szTime;
    }

