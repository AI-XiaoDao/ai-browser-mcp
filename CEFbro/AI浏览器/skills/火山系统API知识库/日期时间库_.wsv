类 NTP网络时间类_ <折叠 折叠2 @视窗.外部头文件 = "iostream\r\ncstring\r\nctime\r\nwinsock2.h\r\nws2tcpip.h\r\nwindows.h"
        @视窗.外部库 = "ws2_32.lib" @全局类 = 真>
{
    方法 时间_取网络时间2 <公开 静态 类型 = 文本型 注释 = "从NTP获取" 折叠>
    参数 NTP服务器 <类型 = 文本型 注释 = "默认为阿里云" @默认值 = "ntp.aliyun.com">
    参数 超时等待时长 <类型 = 整数 注释 = "单位毫秒  1000毫秒=1秒" @默认值 = 15000>
    参数 返回的原始时间 <类型 = 文本型 注释 = "世界时间" @默认值 = "">
    {
        返回 (时间_取NTP时间 (NTP服务器, 超时等待时长, 返回的原始时间))
    }

    方法 时间_取NTP时间 <公开 静态 类型 = 文本型 注释 = "更新NTP服务信息自行查询." 注释 = "阿里云：ntp.aliyun.com ;" 注释 = "中国：cn.pool.ntp.org ;"
            注释 = "国家授时中心：ntp.ntsc.ac.cn ;" 注释 = "中国移动：ntp.neu6.edu.cn ;" 注释 = "全球：pool.ntp.org ;" 注释 = "微软：time.windows.com ;"
            注释 = "苹果：time.apple.com ;" 注释 = "谷歌：time.google.com" 折叠 折叠2 @禁止流程检查 = 真>
    参数 NTP服务器 <类型 = 文本型 注释 = "默认为阿里云" @默认值 = "ntp.aliyun.com">
    参数 超时等待时长 <类型 = 整数 注释 = "单位毫秒  1000毫秒=1秒" @默认值 = 15000>
    参数 返回的原始时间 <类型 = 文本型 注释 = "世界时间" 编辑时信息 = "83184, 0, 0, 0" @默认值 = "">
    {
        @ struct NTPPacket {
        @ uint8_t li_vn_mode;
        @ uint8_t stratum;
        @ uint8_t poll;
        @ uint8_t precision;
        @ uint32_t rootDelay;
        @ uint32_t rootDispersion;
        @ uint32_t referenceId;
        @ uint32_t referenceTm_s;
        @ uint32_t referenceTm_f;
        @ uint32_t originateTm_s;
        @ uint32_t originateTm_f;
        @ uint32_t receiveTm_s;
        @ uint32_t receiveTm_f;
        @ uint32_t transmitTm_s;
        @ uint32_t transmitTm_f;
        @ };
        @ WSADATA wsaData;
        @ if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        调试输出 ("WSAStartup初始化失败")
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ std::string ntpServer = CU8String (@<NTP服务器>).GetText ();
        @ SOCKET sockfd = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        @ if (sockfd == INVALID_SOCKET) {
        调试输出 ("创建Socket失败")
        @ WSACleanup();
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ sockaddr_in serverAddr{};
        @ serverAddr.sin_family = AF_INET;
        @ serverAddr.sin_port = htons(123);
        @ addrinfo hints{};
        @ hints.ai_family = AF_INET;
        @ hints.ai_socktype = SOCK_DGRAM;
        @ addrinfo* result;
        @ if (getaddrinfo(ntpServer.c_str(), "123", &hints, &result) != 0) {
        调试输出 ("解析服务器地址失败")
        @ closesocket(sockfd);
        @ WSACleanup();
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ memcpy(&serverAddr, result->ai_addr, sizeof(serverAddr));
        @ freeaddrinfo(result);
        @ NTPPacket packet = { 0 };
        @ packet.li_vn_mode = 0x1B;
        @ DWORD timeout = @<超时等待时长>;
        @ if (setsockopt(sockfd, SOL_SOCKET, SO_RCVTIMEO,
        @ (char*)&timeout, sizeof(timeout)) == SOCKET_ERROR) {
        调试输出 ("设置Socket超时失败")
        @ closesocket(sockfd);
        @ WSACleanup();
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ int bytesSent = sendto(sockfd, (char*)&packet, sizeof(packet), 0,
        @ (sockaddr*)&serverAddr, sizeof(serverAddr));
        @ if (bytesSent == SOCKET_ERROR) {
        调试输出 ("发送NTP请求失败")
        @ closesocket(sockfd);
        @ WSACleanup();
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ sockaddr_in fromAddr{};
        @ int fromAddrLen = sizeof(fromAddr);
        @ int bytesRecv = recvfrom(sockfd, (char*)&packet, sizeof(packet), 0,
        @ (sockaddr*)&fromAddr, &fromAddrLen);
        @ if (bytesRecv == SOCKET_ERROR) {
        调试输出 ("接收NTP响应失败")
        @ closesocket(sockfd);
        @ WSACleanup();
        @ return @an<CVolString>(WSAGetLastError());
        @ }
        @ closesocket(sockfd);
        @ WSACleanup();
        @ const uint32_t ntpEpochOffset = 2208988800UL;
        @ time_t ntpTime = ntohl(packet.transmitTm_s) - ntpEpochOffset;
        @ auto formatTime = [](const tm* timeinfo) {
        @ char buffer[80];
        @ strftime(buffer, sizeof(buffer), "%Y-%m-%d %H:%M:%S", timeinfo);
        @ return std::string(buffer);
        @ };
        @ tm utcTime;
        @ gmtime_s(&utcTime, &ntpTime);
        @ @<返回的原始时间>=formatTime(&utcTime).c_str();
        @ tm localTime;
        @ localtime_s(&localTime, &ntpTime);
        @ return formatTime(&localTime).c_str();
    }
}
