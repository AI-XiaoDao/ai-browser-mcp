    {
        @ FILETIME LocalTime;
        @ FileTimeToLocalFileTime((LPFILETIME)@<FileTime>, &LocalTime);
        @ SYSTEMTIME SystemTime;
        @ FileTimeToSystemTime(&LocalTime, &SystemTime);
        @ DOUBLE vTime;
        @ SystemTimeToVariantTime(&SystemTime, &vTime);
        @ return vTime;
    }
}

