类 界面延时处理类_ <公开 折叠 折叠2 @文档 = "category = \"日期时间库.延时处理\"" @全局类 = 真>
{
    方法 处理事件_ <公开 静态 折叠 @禁止流程检查 = 真>
    {
        @ MSG msg;
        @ while ( ::PeekMessage( &msg, NULL, 0, 0, PM_REMOVE ) != 0) 
        @ {
        @     DispatchMessage(&msg);
        @     TranslateMessage(&msg);
        @ }
    }

    方法 延迟_ <公开 静态 注释 = "不卡UI，不占CPU，不影响执行其它代码" 折叠>
    参数 时长 <类型 = 整数 注释 = "单位毫秒；1000毫秒＝1秒  1000微秒=1毫秒">
    参数 是否微秒 <类型 = 逻辑型 注释 = "为真时将以微秒为等待单位，否则以毫秒为单位" @默认值 = 假>
    {
        @ const HANDLE hTimer = ::CreateWaitableTimer (NULL, FALSE, NULL);
        @ if (hTimer == NULL)  return;
        @ LARGE_INTEGER liDueTime;
        @    if (@<是否微秒>) {
        @       liDueTime.QuadPart = (LONGLONG)-10 * (LONGLONG)MAX (1, @<时长>);
        @    } else {
        @       liDueTime.QuadPart = (LONGLONG)-10000 * (LONGLONG)MAX (1, @<时长>);
        @    }
        @ if (::SetWaitableTimer (hTimer, &liDueTime, 0, NULL, NULL, FALSE))
        @ {
        @     while (TRUE)
        @     {
        @         const DWORD dwResult = ::MsgWaitForMultipleObjects (1, &hTimer, FALSE, INFINITE, QS_ALLEVENTS);
        @         if (dwResult == WAIT_FAILED || dwResult == WAIT_OBJECT_0)
        @             break;
        @         @<处理事件_> ();
        @     }
        @ }
        @ ::CloseHandle (hTimer);
    }

    方法 延迟2_ <公开 静态 注释 = "不卡UI，不占CPU，不影响执行其它代码" 折叠>
    参数 时长 <类型 = 整数 注释 = "单位毫秒；1000毫秒＝1秒  1000微秒＝1毫秒">
    参数 是否微秒 <类型 = 逻辑型 注释 = "为真时将以微秒为等待单位，否则以毫秒为单位" @默认值 = 假>
    {
        @     HANDLE hEvent = ::CreateWaitableTimer(NULL,FALSE,NULL);
        @     LARGE_INTEGER ltm;
        @    if (@<是否微秒>) {
        @       ltm.QuadPart =-10*@<时长>;
        @    } else {
        @       ltm.QuadPart =-10*@<时长> * 1000;
        @    }
        @     ::SetWaitableTimer(hEvent,&ltm,0,NULL,NULL,FALSE);
        @     while(MsgWaitForMultipleObjects(1, &hEvent, FALSE, INFINITE,QS_ALLEVENTS ) != WAIT_OBJECT_0)
        @     {
        @         MSG msg;
        @         while ( ::PeekMessage( &msg, NULL, 0, 0, PM_REMOVE ) != 0 ) 
        @         {
        @              DispatchMessage(&msg);
        @              TranslateMessage(&msg);
        @         }
        @     }
        @     CloseHandle(hEvent);
    }
}

