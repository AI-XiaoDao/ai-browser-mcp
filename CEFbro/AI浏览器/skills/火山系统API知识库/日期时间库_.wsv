类 时间类_ <公开 折叠 折叠2 @文档 = "category = \"日期时间库.日期时间操作\"" @全局类 = 真 @视窗.外部头文件 = "<time.h>\r\n<sys/timeb.h>">
{
    方法 时间_取随机时间 <公开 静态 类型 = 文本型 折叠>
    参数 是否格式化 <类型 = 逻辑型 @默认值 = 假>
    参数 时间样式 <类型 = 文本型 注释 = "日期格式文本：yy,yyyy(年)； M,MM(月)； d,dd(日) ；ddd(周几)； dddd(星期几)；"
            注释 = "时间格式文本：h,hh(12小时制)； H,HH(24小时制)； m,mm(分钟)； s,ss(秒)；" 注释 = "其它格式文本：tt(上午或下午)；"
            注释 = "例如：yyyy年MM月dd日 dddd、h:m；yyyy/MM/dd dddd HH:mm:ss等。" @默认值 = "yyyy-MM-dd HH:mm:ss">
    {
        变量 数值 <类型 = 整数>
        变量 时值 <类型 = 小数>
        变量 结果 <类型 = 文本型>
        数值 = 取随机数 (-300, 300)
        如果真 (数值 == 0)
        {
            数值 = 取随机数 (1, 300)
        }
        如果 (数值 > 0)
        {
            时值 = -数值
        }
        时值 = 增减时间 (取现行时间 (), 时间字段类型.秒, 数值)
        结果 = 时间到文本 (时值)
        如果真 (是否格式化 == 真)
        {
            结果 = 时间_格式化时间 (结果, 时间样式)
        }
        返回 (结果)
    }

    方法 时间_取随机时间戳 <公开 静态 类型 = 文本型 折叠>
    参数 是否13位 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 数值 <类型 = 整数>
        变量 结果 <类型 = 文本型>
        数值 = 取随机数 (100, 999)
        结果 = 到文本 (时间_取指定时间戳 (时间_取随机时间 ()))
        如果真 (是否13位 == 真)
        {
            结果 = 结果 + 到文本 (数值)
        }
        返回 (结果)
    }

    方法 时间_格式化时间 <公开 静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 日期时间值 <类型 = 文本型 注释 = "可以为时间小数：44370.5168287037 ;" 注释 = "可以为时间文本：2021-6-23 12:25:1 ;" 注释 = "可以为时间戳：1667094877">
    参数 时间样式 <类型 = 文本型 注释 = "日期格式文本：yy,yyyy(年)； M,MM(月)； d,dd(日) ；ddd(周几)； dddd(星期几)；"
            注释 = "时间格式文本：h,hh(12小时制)； H,HH(24小时制)； m,mm(分钟)； s,ss(秒)；" 注释 = "其它格式文本：tt(上午或下午)；"
            注释 = "例如：M/d；yy/M/d；yyyy/MM/dd；yyyy年MM月dd日；yyyy年MM月dd日 ddd；yyyy年MM月dd日 dddd；yyyy/MM/dd dddd HH:mm:ss等。"
            @默认值 = "yyyy-MM-dd HH:mm:ss">
    参数 是否为中文格式 <类型 = 逻辑型 注释 = "中文格式(年月日排列顺序为年月日),例如:" 注释 = "  1. 1973-11-15-12-30-25  2. 1973-11-15-12:30:25 ;"
            注释 = "  3. 1973/11/15 12:30:25  4. 1973/11/15/12/30/25 ;" 注释 = "  5. 1973/11/15/12:30:25  6. 1973.11.15 12:30:25 ;"
            注释 = "  7. 19731115123025       8. 1973年11月15日12时30分25秒 ;" 注释 = "非中文格式(年月日排列顺序为月日年),例如:"
            注释 = "  1. 11/15/1973 12:30:25  2. 11/15/1973/12/30/25" 注释 = "  4. 11/15/1973/12:30:25  5. 11-15-1973-12-30-25"
            注释 = "  6. 11-15-1973-12:30:25  7. 11.15.1973 12:30:25" @默认值 = 真>
    {
        变量 国家语言代码 <类型 = 整数 值 = 0x0804 注释 = "zh_CN">
        变量 TimeStr <类型 = 文本型>
        变量 日期时间值2 <类型 = 小数>
        如果 (寻找文本 (日期时间值, ".") == -1)
        {
            如果 (是否为全数字_ (日期时间值) && 取文本长度 (日期时间值) > 8)
            {
                日期时间值2 = 时间戳到时间 (文本到整数 (日期时间值))
            }
            否则
            {
                日期时间值2 = 到时间 (日期时间值, 是否为中文格式)
            }
        }
        否则
        {
            日期时间值2 = 文本到小数 (日期时间值)
        }
        @ LPWSTR TimeStr = new TCHAR[256]();
        @ SYSTEMTIME SystemTime;
        @ int iRes = VariantTimeToSystemTime (@<日期时间值2>, &SystemTime);
        @ if (!iRes) return "";
        @ GetDateFormatW (@<国家语言代码>, 0, &SystemTime, @<时间样式>.GetText(), TimeStr, 50);
        @ GetTimeFormatW (@<国家语言代码>, 0, &SystemTime, TimeStr, TimeStr, 50);
        @ @<TimeStr> = TimeStr;
        @ delete[] TimeStr;
        @ return @<TimeStr>.GetText();
    }

    方法 时间_取网络时间 <公开 静态 类型 = 文本型 返回值注释 = "返回明文时间" 折叠>
    参数 返回的时间戳 <类型 = 文本型 @默认值 = "">
    {
        变量 网络 <类型 = 网络访问类_>
        变量 数据包 <类型 = 文本型>
        变量 json数据 <类型 = JSON对象类_>
        变量 结果 <类型 = 文本型>
        网络.网页访问_B ("www.baidu.com", , , , , , , , 数据包)
        结果 = 取文本中间_ (数据包, "Date: ", " GMT")
        如果 (文本是否为空 (结果) == 假)
        {
            结果 = 时间_GMT时间转北京时间_文本 (结果)
            返回的时间戳 = 到文本 (取时间戳 (到时间 (结果)))
        }
        否则
        {
            计次循环 (3)
            {
                数据包 = 网络.网页访问_T ("http://api.k780.com:88/?app=life.time&appkey=10003&sign=b59bc3ef6191eb9f747dd4e83c99f2a4&format=json")
                如果 (取文本长度 (数据包) > 12)
                {
                    如果真 (json数据.创建自文本 (数据包))
                    {
                        结果 = json数据.取文本值 ("/result/datetime_1")
                        返回的时间戳 = json数据.取文本值 ("/result/timestamp")
                    }
                    跳出循环
                }
            }
        }
        返回 (结果)
    }

    方法 取启动时间_ <公开 静态 类型 = 长整数 注释 = "高精度计时" 折叠 @禁止流程检查 = 真>
    参数 是否微秒 <类型 = 逻辑型 注释 = "真：微秒  假：毫秒" @默认值 = 真>
    {
        @ LARGE_INTEGER freq, counter;
        @ QueryPerformanceFrequency(&freq);
        @ QueryPerformanceCounter(&counter);
        @ const ULONGLONG multiplier = @<是否微秒> ? 1000000 : 1000;
        @ return (counter.QuadPart * multiplier) / freq.QuadPart;
    }

    方法 取现行时间_ <公开 静态 类型 = 文本型 注释 = "获取“2024-01-24 09:12:01”、“2024-01-24”此类格式时间" 折叠>
    参数 类型 <类型 = 整数 注释 = "1、年-月-日　2、年-月-日 时:分:秒　3、时:分:秒　默认为1" @默认值 = 1>
    参数 单数补零 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 临时时间 <类型 = 文本型>
        如果 (单数补零 == 假)
        {
            临时时间 = 取时间值 (类型)
        }
        否则
        {
            如果 (类型 == 1)
            {
                临时时间 = 时间_格式化时间 (取时间值 (类型), "yyyy-MM-dd")
            }
            否则 (类型 == 2)
            {
                临时时间 = 时间_格式化时间 (取时间值 (类型), "yyyy-MM-dd HH:mm:ss")
            }
            否则
            {
                临时时间 = 时间_格式化时间 (取时间值 (2), "HH:mm:ss")
            }
        }
        返回 (临时时间)
    }

    方法 时间_取现行时间 <公开 静态 类型 = 文本型 注释 = "获取“2024-01-24 09:12:01”、“2024-01-24”此类格式时间" 折叠>
    参数 类型 <类型 = 整数 注释 = "1、年-月-日　2、年-月-日 时:分:秒　3、时:分:秒　默认为1" @默认值 = 1>
    参数 单数补零 <类型 = 逻辑型 @默认值 = 假>
    {
        返回 (取现行时间_ (类型, 单数补零))
    }

    方法 时间_取现行时间_ISO <公开 静态 类型 = 文本型 注释 = "获取“2024-01-28 T08:23:50Z”此类格式时间" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "iostream\r\nchrono\r\niomanip\r\nsstream">
    参数 是否带空格 <类型 = 逻辑型 @默认值 = 真>
    参数 是否东八时区 <类型 = 逻辑型 @默认值 = 真>
    {
        @ auto now = @<是否东八时区> ?std::chrono::system_clock::now(): std::chrono::system_clock::now() - std::chrono::hours(8);
        @ auto now_time_t = std::chrono::system_clock::to_time_t(now);  
        @ std::tm now_tm = *std::localtime(&now_time_t);  
        @ std::stringstream ss;  
        @ if(@<是否带空格>==1)ss << std::put_time(&now_tm, "%Y-%m-%d T%H:%M:%SZ");  
        @ if(@<是否带空格>==0)ss << std::put_time(&now_tm, "%Y-%m-%dT%H:%M:%SZ"); 
        @ std::string iso_time = ss.str();  
        @ ATL::CA2T atlStr(iso_time.c_str());
        @ return atlStr;
    }

    方法 时间_秒数转时间格式 <公开 静态 类型 = 文本型 注释 = "例如将90转成：“00:01:30”、“00时01分30秒”、“0天 00:01:30”样式" 折叠>
    参数 秒长 <类型 = 整数>
    参数 时区是否文字间隔 <类型 = 逻辑型 注释 = "按时分秒或按:符号间隔" @默认值 = 假>
    参数 是否含天 <类型 = 逻辑型 @默认值 = 假>
    参数 天间隔符 <类型 = 文本型 @默认值 = " ">
    {
        变量 分长 <类型 = 整数>
        变量 时长 <类型 = 整数>
        分长 = 秒长 / 60
        如果 (是否含天)
        {
            时长 = 分长 / 60
            如果真 (时区是否文字间隔)
            {
                返回 (取格式文本 ("%d天" + 天间隔符 + "%02d时%02d分%02d秒", 时长 / 24, 时长 % 24, 分长 % 60, 秒长 % 60))
            }
            返回 (取格式文本 ("%d天" + 天间隔符 + "%02d:%02d:%02d", 时长 / 24, 时长 % 24, 分长 % 60, 秒长 % 60))
        }
        如果真 (时区是否文字间隔)
        {
            返回 (取格式文本 ("%02d时%02d分%02d秒", 分长 / 60, 分长 % 60, 秒长 % 60))
        }
        返回 (取格式文本 ("%02d:%02d:%02d", 分长 / 60, 分长 % 60, 秒长 % 60))
    }

    方法 取时间值 <静态 类型 = 文本型 折叠 @禁止流程检查 = 真>
    参数 类型 <类型 = 整数 注释 = "1、年-月-日　2、年-月-日 时:分:秒　3、时:分:秒　默认为1" @默认值 = 1>
    {
        变量 格式 <类型 = 文本型>
        如果 (类型 == 1)
        {
            格式 = "%u-%u-%u"
        }
        否则 (类型 == 2)
        {
            格式 = "%u-%u-%u %u:%u:%u"
        }
        否则
        {
            格式 = "%u:%u:%u"
        }

        @ LONG lx = @<类型>;
        @  TCHAR szBuffer[256];
        @  SYSTEMTIME st;
        @  ::GetLocalTime(&st);
        @ if (lx <3)
        @ {
        @  ::wsprintf(szBuffer, @<格式>,st.wYear, st.wMonth, st.wDay,st.wHour, st.wMinute, st.wSecond);
        @ }
        @ else
        @ {
        @  ::wsprintf(szBuffer, @<格式>, st.wHour, st.wMinute, st.wSecond);
        @ }
        @ return szBuffer;
    }

    方法 时间_置现行时间 <公开 静态 类型 = 逻辑型 折叠>
    参数 年 <类型 = 整数 注释 = "默认为当前 年" @默认值 = 0>
    参数 月 <类型 = 整数 注释 = "默认为当前 月" @默认值 = 0>
    参数 日 <类型 = 整数 注释 = "默认为当前 日" @默认值 = 0>
    参数 时 <类型 = 整数 注释 = "默认为当前 时" @默认值 = 0>
    参数 分 <类型 = 整数 注释 = "默认为当前 分" @默认值 = 0>
    参数 秒 <类型 = 整数 注释 = "默认为当前 秒" @默认值 = 0>
    {
        变量 时间类 <类型 = 时间类型_>
        时间类.年 = (短整数)年
        如果真 (年 == 0)
        {
            时间类.年 = (短整数)取年份 (取现行时间 ())
        }
        时间类.月 = (短整数)月
        如果真 (月 == 0)
        {
            时间类.月 = (短整数)取月份 (取现行时间 ())
        }
        时间类.日 = (短整数)日
        如果真 (日 == 0)
        {
            时间类.日 = (短整数)取日 (取现行时间 ())
        }
        时间类.时 = (短整数)时
        如果真 (时 == 0)
        {
            时间类.时 = (短整数)取小时 (取现行时间 ())
        }
        时间类.分 = (短整数)分
        如果真 (分 == 0)
        {
            时间类.分 = (短整数)取分钟 (取现行时间 ())
        }
        时间类.秒 = (短整数)秒
        如果真 (秒 == 0)
        {
            时间类.秒 = (短整数)取秒 (取现行时间 ())
        }
        返回 (SetLocalTime (时间类))
    }

