<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"日期时间库\"">

类 毫秒时间类_ <公开 注释 = "精确到毫秒的全格式时间" 折叠 折叠2 @文档 = "category = \"日期时间库.毫秒时间\"" @全局类 = 真>
{
    方法 取现行时间2_ <公开 静态 类型 = 文本型 注释 = "获取“2024-01-24 09:12:01.299”此类格式时间" 折叠 @禁止流程检查 = 真>
    参数 是否为点 <类型 = 逻辑型 注释 = "真为\".\"   假为\":\"" @默认值 = 真>
    {
        @ union {
        @     FILETIME ft;
        @     INT64 ftt;
        @ };
        @ ::GetSystemTimeAsFileTime(&ft);
        @ INT64 currentTimeStamp = ftt / 10000 - 11644473600000;
        @ time_t rawtime = (time_t)(currentTimeStamp / 1000);
        @ struct tm timeinfo{0};
        @ ::localtime_s(&timeinfo, &rawtime);
        @ WCHAR szTime[32]{0};
        @ size_t len = ::wcsftime(szTime, sizeof(szTime), L"%F %T", &timeinfo);
        @ ::swprintf(szTime + len, @<是否为点> ? L".%03d":L":%03d", currentTimeStamp - (INT64)rawtime * 1000);
        @ return @an<CVolString>(szTime);
    }

    方法 取现行时间3_ <公开 静态 类型 = 文本型 注释 = "获取“2024-01-24 09:12:01”此类格式时间" 折叠 @禁止流程检查 = 真>
    {
        @ union {
        @     FILETIME ft;
        @     INT64 ftt;
        @ };
        @ ::GetSystemTimeAsFileTime(&ft);
        @ INT64 currentTimeStamp = ftt / 10000 - 11644473600000;
        @ time_t rawtime = (time_t)(currentTimeStamp / 1000);
        @ struct tm timeinfo{0};
        @ ::localtime_s(&timeinfo, &rawtime);
        @ WCHAR szTime[32]{0};
        @ size_t len = ::wcsftime(szTime, sizeof(szTime), L"%F %T", &timeinfo);
        @ return @an<CVolString>(szTime);
    }

    方法 取现行时间戳_毫秒 <公开 静态 类型 = 长整数 注释 = "13位" 折叠 @禁止流程检查 = 真>
    {
        @ FILETIME ft;
        @ ::GetSystemTimeAsFileTime(&ft);
        @ return ((INT64)ft.dwLowDateTime | (INT64)ft.dwHighDateTime << 32) / 10000 - 11644473600000;
    }

    方法 取现行时间戳_微秒 <公开 静态 类型 = 长整数 注释 = "16位" 折叠 @禁止流程检查 = 真>
    {
        @ FILETIME ft;
        @ ::GetSystemTimeAsFileTime(&ft);
        @ return ((INT64)ft.dwLowDateTime | (INT64)ft.dwHighDateTime << 32) / 10 - 11644473600000000;
    }
}

