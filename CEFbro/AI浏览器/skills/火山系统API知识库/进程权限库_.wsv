类 进程模块信息类_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.进程模块\"" @全局类 = 真>
{
    方法 进程_取所有进程模块 <公开 静态 类型 = 整数 注释 = "本命令有耗时操作，所以需要将本命令放在线程中执行，以免卡界面" 折叠 折叠2 @禁止流程检查 = 真
            @视窗.外部头文件 = "windows.h\r\ntlhelp32.h\r\npsapi.h\r\niostream\r\niomanip\r\nmap" @视窗.外部库 = "psapi.lib">
    参数 返回的信息组 <类型 = 进程信息组>
    {
        变量 临时DLL名称 <类型 = 文本型>
        变量 临时DLL路径 <类型 = 文本型>
        变量 信息类 <类型 = 进程信息类>
        @         HANDLE hToken;
        @         if (OpenProcessToken(GetCurrentProcess(), TOKEN_ADJUST_PRIVILEGES | TOKEN_QUERY, &hToken)) {
        @             TOKEN_PRIVILEGES tkp;
        @             if (LookupPrivilegeValue(NULL, SE_DEBUG_NAME, &tkp.Privileges[0].Luid)) {
        @                 tkp.PrivilegeCount = 1;
        @                 tkp.Privileges[0].Attributes = SE_PRIVILEGE_ENABLED;
        @                 AdjustTokenPrivileges(hToken, FALSE, &tkp, 0, NULL, 0);
        @             }
        @             CloseHandle(hToken);
        @         }
        @     std::map<DWORD, std::wstring> processes;
        @     {
        @         PROCESSENTRY32W pe32;
        @         pe32.dwSize = sizeof(PROCESSENTRY32W);
        @         HANDLE hProcessSnap = CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
        @         if (hProcessSnap != INVALID_HANDLE_VALUE) {
        @             if (Process32FirstW(hProcessSnap, &pe32)) {
        @                 do {
        @                     processes[pe32.th32ProcessID] = pe32.szExeFile;
        @                 } while (Process32NextW(hProcessSnap, &pe32));
        @             }
        @             CloseHandle(hProcessSnap);
        @         }
        @     }
        @     for (const auto& proc : processes) {
        信息类.重置为空对象 ()
        @         DWORD pid = proc.first;
        @         std::wstring exeName = proc.second;
        @         HANDLE hProcess = NULL;
        @         hProcess = OpenProcess(PROCESS_QUERY_INFORMATION | PROCESS_VM_READ, FALSE, pid);
        @         if (!hProcess) {
        @             hProcess = OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, FALSE, pid);
        @             if (!hProcess) continue;
        @         }
        @         WCHAR exePath[MAX_PATH] = { 0 };
        @         if (!GetModuleFileNameExW(hProcess, NULL, exePath, MAX_PATH)) {
        @             CloseHandle(hProcess);
        @             continue;
        @         }
        @ @<信息类.进程ID>=pid;
        @ @<信息类.进程名>=exeName.c_str();
        @ @<信息类.进程路径>=exePath;
        @         std::map<std::wstring, std::wstring> dependencies;
        @         {
        @             HMODULE hMods[1024];
        @             DWORD cbNeeded;
        @             if (EnumProcessModules(hProcess, hMods, sizeof(hMods), &cbNeeded)) {
        @                 WCHAR mainModulePath[MAX_PATH] = { 0 };
        @                 GetModuleFileNameExW(hProcess, hMods[0], mainModulePath, MAX_PATH);
        @                 for (DWORD i = 0; i < (cbNeeded / sizeof(HMODULE)); i++) {
        @                     WCHAR modName[MAX_PATH] = { 0 };
        @                     WCHAR modPath[MAX_PATH] = { 0 };
        @                     if (GetModuleBaseNameW(hProcess, hMods[i], modName, MAX_PATH) &&
        @                         GetModuleFileNameExW(hProcess, hMods[i], modPath, MAX_PATH)) {
        @                         if (wcscmp(modPath, mainModulePath) != 0) {
        @                             dependencies[modName] = modPath;
        @                         }
        @                     }
        @                 }
        @             }
        @         }
        @         for (const auto& dll : dependencies) {
        @ @<临时DLL名称>=dll.first.c_str();
        信息类.DLL名称.加入成员 (临时DLL名称)
        @ @<临时DLL路径>=dll.second.c_str();
        信息类.DLL路径.加入成员 (临时DLL路径)
        @         }
        @         std::wcout << L"\n";
        @         CloseHandle(hProcess);
        返回的信息组.加入成员 (信息类)
        @     }
        @     return processes.size();
    }
}

类 进程信息组 <公开 基础类 = 对象数组模板类 折叠2 @输出到部件 = 假 @模板实现类 = "进程信息类">

类 进程信息类 <公开 折叠>
{
    变量 进程ID <公开 类型 = 整数>
    变量 进程名 <公开 类型 = 文本型>
    变量 进程路径 <公开 类型 = 文本型>
    变量 DLL名称 <公开 类型 = 文本数组类>
