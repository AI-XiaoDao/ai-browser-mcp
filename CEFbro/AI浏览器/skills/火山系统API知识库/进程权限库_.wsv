    方法 进程_取指定进程句柄 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ return (INT_P)hProcess;
    }

    方法 进程_取自身进程ID <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    {
        @ return GetCurrentProcessId();
    }

    方法 进程_取指定进程名称 <公开 静态 类型 = 文本型 注释 = "进程ID取进程名" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 @输出名 = "nProcessID">
    {
        @ HANDLE hProcessSnap = ::CreateToolhelp32Snapshot (TH32CS_SNAPPROCESS, 0);
        @ if (hProcessSnap == INVALID_HANDLE_VALUE) return 0;
        @ PROCESSENTRY32W pe32 { sizeof (PROCESSENTRY32W) };
        @ if (::Process32FirstW (hProcessSnap, &pe32) == FALSE) return 0;
        @ do {
        @     if (pe32.th32ProcessID == nProcessID) {
        @         ::CloseHandle (hProcessSnap);
        @         return @an<CVolString> (pe32.szExeFile);
        @     }
        @ } while (::Process32NextW (hProcessSnap, &pe32));
        @ ::CloseHandle (hProcessSnap);
        @ return _CT ("");
    }

    方法 进程_取指定进程ID <公开 静态 类型 = 整数 注释 = "进程名取进行ID" 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        @ HANDLE hProcessSnap = ::CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS,NULL);
        @ PROCESSENTRY32 pe32;CWString ProcessName = @<进程名>,sProcessName;
        @ ProcessName.MakeLower ();
        @ if (hProcessSnap == INVALID_HANDLE_VALUE)
        @ { return -1; }
        @ pe32.dwSize = sizeof(pe32);
        @ BOOL bRet = ::Process32First(hProcessSnap,&pe32);
        @ while(bRet)
        @ {
        @ sProcessName=pe32.szExeFile;
        @ sProcessName.MakeLower();
        @ if (sProcessName == ProcessName)
        @ { ::CloseHandle(hProcessSnap); return pe32.th32ProcessID; }
        @ bRet = ::Process32Next(hProcessSnap,&pe32);
        @ }
        @ ::CloseHandle(hProcessSnap);
        @ return 0;
    }

    方法 进程_取指定进程ID_批量 <公开 静态 类型 = 整数 注释 = "取相同名称进程" 折叠 折叠2 @视窗.外部头文件 = "<TlHelp32.h>\r\n<iphlpapi.h>" @视窗.外部库 = "Iphlpapi.lib"
            @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    参数 返回的ID组 <类型 = 整数数组类 "">
    {
        变量 szPath <类型 = 文本型>
        变量 dwProcessId <类型 = 整数>
        变量 result <类型 = 整数>
        返回的ID组.删除所有成员 ()
        @ PROCESSENTRY32W pe;
        @ memset(&pe, 0, sizeof(PROCESSENTRY32W));
        @ pe.dwSize = sizeof(PROCESSENTRY32W);
        @ HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPALL, 0);
        @ if (hSnapshot == INVALID_HANDLE_VALUE) return -1;
        @ BOOL hRes = Process32FirstW(hSnapshot, &pe);
        @ while (hRes)
        @ {
        @ @<szPath> =  pe.szExeFile;
        result = 文本比较 (到小写 (进程名), 到小写 (szPath), 假)
        @ if (!@<result>)
        @ {
        @ @<dwProcessId> = pe.th32ProcessID;
        返回的ID组.加入成员 (dwProcessId)
        @ }
        @ hRes = Process32NextW(hSnapshot, &pe);
        @ }
        @ CloseHandle(hSnapshot);
        返回 (返回的ID组.取成员数 ())
    }

    方法 进程_端口取进程ID <公开 静态 类型 = 整数 注释 = "通过端口取出进程PID" 折叠 折叠2 @视窗.外部头文件 = "<iphlpapi.h>" @视窗.外部库 = "Iphlpapi.lib" @禁止流程检查 = 真>
    参数 端口 <类型 = 整数>
    {
        @ DWORD dwSize = 0;
        @ GetExtendedTcpTable(NULL, &dwSize, TRUE, AF_INET, TCP_TABLE_OWNER_PID_ALL, 0);
        @ if (!dwSize) return 0;
        @ PMIB_TCPTABLE_OWNER_PID pTcpTable = (PMIB_TCPTABLE_OWNER_PID)malloc(dwSize);
        @ DWORD dwRet = NO_ERROR, dwOwningPid = 0;
        @ dwRet = GetExtendedTcpTable(pTcpTable, &dwSize, TRUE, AF_INET, TCP_TABLE_OWNER_PID_ALL, 0);
        @ if (dwRet == NO_ERROR && pTcpTable && pTcpTable->dwNumEntries)
        @ {
        @     for (int i = 0; i < pTcpTable->dwNumEntries; i++)
        @     {
        @         if (ntohs((u_short)pTcpTable->table[i].dwLocalPort) == @<端口>)
        @         {
        @             dwOwningPid = pTcpTable->table[i].dwOwningPid;
        @             break;
        @         }
        @     }
        @ }
        @ else if (dwRet == ERROR_INSUFFICIENT_BUFFER)
        @     dwOwningPid = 0;
        @ else if (dwRet == ERROR_INVALID_PARAMETER)
        @     dwOwningPid = 0;
        @ free(pTcpTable);
        @ return dwOwningPid;
    }

    方法 进程_进程ID取端口 <公开 静态 类型 = 整数 注释 = "通过进程PID取出端口" 折叠 折叠2 @视窗.外部头文件 = "<iphlpapi.h>" @视窗.外部库 = "Iphlpapi.lib" @禁止流程检查 = 真>
    参数 PID <类型 = 整数>
    {
        @ DWORD dwSize = 0;
        @ GetExtendedTcpTable(NULL, &dwSize, TRUE, AF_INET, TCP_TABLE_OWNER_PID_ALL, 0);
        @ if (!dwSize) return 0;
        @ PMIB_TCPTABLE_OWNER_PID pTcpTable = (PMIB_TCPTABLE_OWNER_PID)malloc(dwSize);
        @ DWORD dwRet = NO_ERROR, dwLocalPort = 0;
        @ dwRet = GetExtendedTcpTable(pTcpTable, &dwSize, TRUE, AF_INET, TCP_TABLE_OWNER_PID_ALL, 0);
        @ if (dwRet == NO_ERROR && pTcpTable && pTcpTable->dwNumEntries)
        @ {
        @     for (int i = 0; i < pTcpTable->dwNumEntries; i++)
        @     {
        @         if (pTcpTable->table[i].dwOwningPid == @<PID>)
        @         {
        @             dwLocalPort = ntohs((u_short)(pTcpTable->table[i].dwLocalPort));
        @             break;
        @         }
        @     }
        @ }
        @ else if (dwRet == ERROR_INSUFFICIENT_BUFFER) //为表分配的空间不足
        @     dwLocalPort = 0;
        @ else if (dwRet == ERROR_INVALID_PARAMETER) //传递给函数的参数无效
        @     dwLocalPort = 0;
        @ free(pTcpTable);
        @ return dwLocalPort;
    }

    方法 进程_窗口句柄取进程路径 <公开 静态 类型 = 文本型 注释 = "通过窗口句柄取程序路径" 折叠 折叠2 @禁止流程检查 = 真 @视窗.外部头文件 = "<Psapi.h>" @视窗.外部库 = "Psapi.lib">
    参数 窗口句柄 <类型 = 变整数>
    {
        变量 szFileName <类型 = 文本型>
        @ HWND hWnd = (HWND)@<窗口句柄>;
        @ DWORD dwProcessId;
        @ if (GetWindowThreadProcessId(hWnd, &dwProcessId) > 0)
        @ {
        @ HANDLE hProcess = OpenProcess(PROCESS_QUERY_INFORMATION | PROCESS_VM_READ, FALSE, dwProcessId);
        @ if (hProcess > 0)
        @ {
        @ HMODULE hModule[1];
        @ DWORD cbNeeded;
        @ if (EnumProcessModulesEx(hProcess, hModule, sizeof(hModule), &cbNeeded, LIST_MODULES_ALL))
        @ {
        @ WCHAR szFileName[MAX_PATH] = { 0 };
        @ if (GetModuleFileNameExW(hProcess, hModule[0], szFileName, MAX_PATH))
        @ {
        @ @<szFileName>.SetValueText(szFileName);
        子文本替换 (szFileName, "\\??\\", "")
        @ }
        @ }
        @ CloseHandle(hProcess);
        @ }
        @ }
        @ return @<szFileName>.GetText();
    }

    方法 进程_取指定进程窗口句柄_进程名 <公开 静态 类型 = 变整数 注释 = "通过进程名取窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    参数 窗口标题 <类型 = 文本型 @默认值 = "">
    参数 是否模糊 <类型 = 逻辑型 注释 = "配合参数二使用" @默认值 = 假>
    参数 是否获取首句柄 <类型 = 逻辑型 注释 = "当参数二“窗口标题”为空时，本参数设置生效。不保证是主窗口句柄。真：获取首  假：获取尾" @默认值 = 真>
    参数 返回的窗口句柄组 <类型 = 变整数数组类 注释 = "所有获取到的窗口句柄都保存在此数组中，并返回找到的第一个窗口句柄" @默认值 = 空对象>
    {
        变量 pid <类型 = 整数>
        变量 句柄组 <类型 = 变整数数组类>
        变量 临时句柄 <类型 = 变整数>
        变量 句柄组2 <类型 = 整数数组类>
        变量 结果 <类型 = 逻辑型>
        进程_取指定进程ID_批量 (进程名, 句柄组2)
        句柄组2.枚举循环 ()
        {
            pid = 句柄组2.取枚举值 ()
            进程_取指定进程窗口句柄3_进程ID (pid, 句柄组)
            如果真 (句柄组.取成员数 () > 0)
            {
                如果 (文本是否为空 (窗口标题))
                {
                    如果 (是否获取首句柄)
                    {
                        临时句柄 = 句柄组.取成员 (0)
                    }
                    否则
                    {
                        临时句柄 = 句柄组.取成员 (句柄组.取成员数 () - 1)
                    }
                    结果 = 真
                }
                否则
                {
                    句柄组.枚举循环 ()
                    {
                        临时句柄 = 句柄组.取枚举值 ()
                        如果 (是否模糊)
                        {
                            如果真 (寻找文本 (窗口_取窗口组件标题 (临时句柄), 窗口标题, , 真) != -1)
                            {
                                结果 = 真
                                跳出循环
                            }
                        }
                        否则
                        {
                            如果真 (窗口_取窗口组件标题 (临时句柄) == 窗口标题)
                            {
                                结果 = 真
                                跳出循环
                            }
                        }
                    }
                }
                返回的窗口句柄组 = 句柄组
                如果 (结果)
                {
                    跳出循环
                }
                否则
                {
                    临时句柄 = 0
                }
            }
        }
        返回 (临时句柄)
    }

    方法 进程_取指定进程窗口句柄_进程ID <公开 静态 类型 = 变整数 注释 = "通过进程ID取窗口句柄" 返回值注释 = "成功返回找到的第一个窗口句柄，不能保证是主窗口句柄，失败返回0" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "0为当前进程" @默认值 = 0>
    {
        @ HWND hWnd = ::GetTopWindow(NULL);
        @ DWORD dwFindPID = @<进程ID> ? static_cast<DWORD>(@<进程ID>) : ::GetCurrentProcessId();
        @ while (hWnd) {
        @     DWORD dwPID = 0;
        @     DWORD dwTheardId = ::GetWindowThreadProcessId(hWnd, &dwPID);
        @     if (dwTheardId) {
        @         if (dwPID == dwFindPID)
        @             return (INT_P)hWnd;
        @     }
        @     hWnd = ::GetNextWindow(hWnd, GW_HWNDNEXT);
        @ }
        @ return 0;
    }

    方法 进程_取指定进程窗口句柄2_进程名 <公开 静态 类型 = 变整数 注释 = "通过进程名取窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        变量 pid <类型 = 整数>
