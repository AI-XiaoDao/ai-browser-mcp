                        }
                    }
                }
                内存_释放内存2 (进程句柄, 局_param.pFunc)
            }
        }
        返回 (0)
    }

    方法 关闭对象 <类型 = 逻辑型 返回值注释 = "关闭成功返回真；失败返回假；" 折叠 @禁止流程检查 = 真>
    参数 参_对象句柄 <类型 = 变整数>
    {
        @ return ::CloseHandle((HANDLE)@<参_对象句柄>);
    }

    方法 MyNtCreateThreadEx <静态 类型 = 整数 返回值注释 = "成功返回线程ID，失败返回0；" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数>
    参数 函数地址 <类型 = 变整数>
    参数 附加参数 <类型 = 变整数>
    {
        @ #ifdef _AMD64_
        @ typedef DWORD(WINAPI* PfnZwCreateThreadEx)(
        @     PHANDLE ThreadHandle,
        @     ACCESS_MASK DesiredAccess,
        @     LPVOID ObjectAttributes,
        @     HANDLE ProcessHandle,
        @     LPTHREAD_START_ROUTINE lpStartAddress,
        @     LPVOID lpParameter,
        @     ULONG CreateThreadFlags,
        @     SIZE_T ZeroBits,
        @     SIZE_T StackSize,
        @     SIZE_T MaximunStackSize,
        @     LPVOID pUnkown);
        @ #else
        @ typedef DWORD(WINAPI *PfnZwCreateThreadEx)(
        @     PHANDLE ThreadHandle,
        @     ACCESS_MASK DesiredAccess,
        @     LPVOID ObjectAttributes,
        @     HANDLE ProcessHandle,
        @     LPTHREAD_START_ROUTINE lpStartAddress,
        @     LPVOID lpParameter,
        @     BOOL CreateThreadFlags,
        @     DWORD  ZeroBits,
        @     DWORD  StackSize,
        @     DWORD  MaximumStackSize,
        @     LPVOID pUnkown);
        @ #endif

        @ if(@<进程句柄> != NULL)
        @ {
        @     HMODULE ntdll = NULL;
        @     ntdll = LoadLibrary(TEXT("ntdll.dll"));
        @     HANDLE hThreadHandle = NULL;
        @     PfnZwCreateThreadEx m_ZwCreateThreadEx;
        @     m_ZwCreateThreadEx = reinterpret_cast<PfnZwCreateThreadEx>(GetProcAddress(ntdll, "NtCreateThreadEx"));
        @     m_ZwCreateThreadEx(&hThreadHandle, PROCESS_ALL_ACCESS, NULL,(HANDLE) @<进程句柄>, (LPTHREAD_START_ROUTINE)@<函数地址>, (LPVOID)@<附加参数>, NULL, NULL, NULL, NULL, NULL);
        @     if(hThreadHandle != NULL)
        @     {
        @         return (int)hThreadHandle;
        @     }
        @ }
        @ return 0;
    }

    方法 等待线程结束 <静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 线程句柄 <类型 = 整数>
    参数 等待时长 <类型 = 整数 注释 = "单位：毫秒；默认为-1表示无限等待直到线程返回；" @默认值 = -1>
    {
        @ return ::WaitForSingleObject((HANDLE)@<线程句柄>,@<等待时长>);
    }

    方法 取进程函数地址 <静态 类型 = 变整数 返回值注释 = "成功返回函数地址；失败返回0；" 折叠 @禁止流程检查 = 真>
    参数 模块名称 <类型 = 文本型 注释 = "如：USER32.dll">
    参数 函数名称 <类型 = 文本型 注释 = "如：MessageBoxA">
    {
        变量 局_函数 <类型 = 字节集类>
        变量 局_模块句柄 <类型 = 变整数>
        局_函数 = 文本到多字节 (函数名称)
        局_模块句柄 = 取模块句柄 (模块名称)
        @ return (INT_P)::GetProcAddress ((HMODULE)@<局_模块句柄>,(LPCSTR)@<局_函数>.GetPtr());
    }

    方法 取模块句柄 <静态 类型 = 变整数 折叠 @嵌入式方法 = "">
    参数 模块名称 <类型 = 文本型 注释 = "dll的名称">
    {
        @ (INT_P)::GetModuleHandleW (@<模块名称>)
    }

    方法 GetExitCodeThread <公开 静态 类型 = 整数 注释 = "获取一个已中止线程的退出代码；非零表示成功，零表示失败" 折叠 折叠2 @输出名 = "GetExitCodeThread"
            @视窗.输入 = "kernel32.dll">
    参数 参_线程句柄 <类型 = 整数>
    参数 参_退出代码 <类型 = 变整数 注释 = "请使用：取变量地址(long) 传递进来；long为长整型变量；">
    {

    }
}

类 模块信息类_ <折叠 @文档 = "category = \"进程权限库.进程注入.附加类\"">
{
    变量 模块ID <公开 类型 = 整数>
    变量 进程ID <公开 类型 = 整数>
    变量 全局使用计数 <公开 类型 = 整数>
    变量 模块使用计数 <公开 类型 = 整数>
    变量 模块基址 <公开 类型 = 变整数>
    变量 模块大小 <公开 类型 = 整数>
    变量 模块句柄 <公开 类型 = 变整数>
    变量 模块文件名 <公开 类型 = 文本型 "">
    变量 模块完整路径 <公开 类型 = 文本型>
}

类 param <公开 折叠 折叠2 @文档 = "category = \"进程权限库.进程注入.附加类\"" "">
{
    变量 pFunc <公开 类型 = 变整数>
    变量 Size <公开 类型 = 变整数>
    变量 LdrGetProcedureAddress <公开 类型 = 变整数>
    变量 NtAllocateVirtualMemory <公开 类型 = 变整数>
    变量 LdrLoadDll <公开 类型 = 变整数>
    变量 RtlInitAnsiString <公开 类型 = 变整数>
    变量 RtlAnsiStringToUnicodeString <公开 类型 = 变整数>
    变量 RtlFreeUnicodeString <公开 类型 = 变整数>
    变量 LdrUnloadDll <公开 类型 = 变整数>
    变量 NtFreeVirtualMemory <公开 类型 = 变整数>
}

# //====

类 进程通讯类_ <公开 注释 = "支持跨程序、跨窗口、跨进程通讯" 折叠 折叠2 @文档 = "category = \"进程权限库.进程通讯\"" "">
{
    变量 共享内存 <类型 = 共享内存类_>
    变量 线程 <类型 = 线程池类2_>
    变量 状态 <类型 = 逻辑型>
    变量 等待 <类型 = 逻辑型>
    变量 当前标记 <类型 = 逻辑型>
    变量 同步返回 <类型 = 逻辑型>
    变量 本端名 <类型 = 文本型>
    变量 同步中 <类型 = 逻辑型>

    方法 开启消息等待_ <公开 注释 = "只需开启一次，后台将循环等待新消息，通过“通讯事件”回调取出" 折叠>
    {
        如果真 (等待 == 真)
        {
            返回
        }
        等待 = 真
        处理事件_ ()
        状态 = 假
        线程.创建_ (1)
        线程.投递任务_ ()
    }

    方法 关闭消息等待_ <公开 折叠>
    {
        等待 = 假
        状态 = 真
        线程.销毁_ ()
    }

    方法 释放句柄_ <公开 折叠>
    {
        状态 = 真
        共享内存.释放句柄_ ()
    }

    方法 置本端名称_ <公开 注释 = "给本端设置一个名称，可用于接收指定通讯内容" 折叠>
    参数 名称 <类型 = 文本型 注释 = "例如：程序A">
    {
        本端名 = 名称
    }

    方法 发送信息_ <公开 类型 = 逻辑型 注释 = "发送端不会接收到信息，发送端如要取信息内容，请按以下命令操作;" 注释 = "请用：取地址内容_()，取文本内容_()，取标记内容_()" 折叠 折叠2>
    参数 地址内容 <类型 = 变整数 注释 = "提供该消息数据或对象的指针(此参数不支持跨程序间传指针);" 注释 = "1、直接赋整数值;" 注释 = "2、取文本指针、写指针处值、取变量地、取对象数据" 折叠2 @默认值 = 0>
    参数 文本内容 <类型 = 文本型 @默认值 = "">
    参数 字节集内容 <类型 = 字节集类 注释 = "可使用“取对象数据”命令填入本参数　；取出后使用“置对象数据”命令" @默认值 = 空对象>
    参数 通讯标记 <类型 = 整数 @默认值 = 0>
    参数 接收对象 <类型 = 文本型 注释 = "通过“置本端名称_”设置，指定名称端才能接收到，例如：命名“程序A”" @默认值 = "">
    {
        变量 临时数据 <类型 = 字节集类>
        变量 状态值 <类型 = 整数>
        变量 结果组 <类型 = "逻辑型 [6]">
        变量 i <类型 = 整数>
        如果真 (地址内容 == 0 || 字节集内容.取字节集长度 () == 0)
        {
            如果真 (文本内容 == "" && 通讯标记 == 0)
            {
                信息框_ ("内容不能为全空", 64)
                返回 (假)
            }
        }
        临时数据 = 共享内存.读共享数据_ ("yw状态")
        状态值 = 取字节集数据 (临时数据, 0, 整数)
        判断循环 (状态值 == 1)
        {
            状态值 = 取字节集数据 (临时数据, 0, 整数)
            i = i + 1
            如果真 (i > 500)
            {
                跳出循环
            }
            延迟2_ (1)
        }
        结果组 [0] = 共享内存.写共享数据_ ("yw对象", 文本到字节集 (接收对象))
        结果组 [1] = 共享内存.写共享数据_ ("yw地内", 到字节集 (地址内容))
        结果组 [2] = 共享内存.写共享数据_ ("yw字内", 字节集内容)
        结果组 [3] = 共享内存.写共享数据_ ("yw文内", 文本到字节集 (文本内容))
        结果组 [4] = 共享内存.写共享数据_ ("yw标记", 到字节集 (通讯标记))
        结果组 [5] = 共享内存.写共享数据_ ("yw状态", 到字节集 (1))
        当前标记 = 真
        处理事件_ ()
        如果真 (结果组 [0] == 真 && 结果组 [1] == 真 && 结果组 [2] == 真 && 结果组 [3] == 真 && 结果组 [4] == 真 && 结果组 [5] == 真)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 发送信息_同步 <公开 类型 = 逻辑型 注释 = "发送端不会接收到信息，发送端如要取信息内容，请按以下命令操作;" 注释 = "请用：取通讯地址内容_()，取通讯文本内容_()，取通讯标记内容_();"
            注释 = "同步发送后，另一端直接执行发送信息即可，此命令处可直接取得返回的信息，不需要经过事件取得" 返回值注释 = "如果超时，会在“返回的标记内容”中返回“超时”" 折叠 折叠2>
    参数 地址内容 <类型 = 变整数 注释 = "提供该消息数据或对象的指针(此参数不支持跨程序间传指针);" 注释 = "1、直接赋整数值;" 注释 = "2、取文本指针、写指针处值、取变量地、取对象数据" 折叠2 @默认值 = 0>
    参数 文本内容 <类型 = 文本型 注释 = "本项适合用来标记数据类型，或也可以当文本内容项发送" @默认值 = "">
    参数 字节集内容 <类型 = 字节集类 注释 = "可使用“取对象数据”命令填入本参数　；取出后使用“置对象数据”命令" @默认值 = 空对象>
    参数 通讯标记 <类型 = 整数 @默认值 = 0>
    参数 接收对象 <类型 = 文本型 注释 = "通过“置本端名称_”设置，指定名称端才能接收到，例如：命名“程序A”" @默认值 = "">
    参数 返回的地址内容 <类型 = 变整数 @默认值 = 0>
    参数 返回的文本内容 <类型 = 文本型 @默认值 = "">
    参数 返回的字节集内容 <类型 = 字节集类 @默认值 = 空对象>
    参数 返回的通讯标记 <类型 = 整数 @默认值 = 0>
    参数 等待时间 <类型 = 整数 注释 = "单位：毫秒 ；1000毫秒＝1秒" @默认值 = 2000>
    {
        变量 发送结果 <类型 = 逻辑型>
        变量 i <类型 = 整数>
        如果 (同步中 == 假)
        {
            同步中 = 真
            处理事件_ ()
            发送结果 = 发送信息_ (地址内容, 文本内容, 字节集内容, 通讯标记, 接收对象)
            同步返回 = 假
            判断循环 (同步返回 == 假)
            {
                i = i + 1
                如果真 (i > 等待时间)
                {
                    返回的文本内容 = "超时"
                    跳出循环
                }
                延迟2_ (1)
            }
            返回的地址内容 = 取通讯地址内容_ ()
            返回的文本内容 = 取通讯文本内容_ ()
            返回的字节集内容 = 取通讯字节集内容_ ()
            返回的通讯标记 = 取通讯标记内容_ ()
            同步中 = 假
            处理事件_ ()
        }
        否则
        {
            返回的文本内容 = "当前还有任务未完成"
            返回 (假)
        }
        返回 (发送结果)
    }

    方法 取通讯地址内容_ <公开 类型 = 变整数 注释 = "返回的地址数据可使用：指针到文本、读指针处对象、读指针处值等命令还原数据" 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 对象名 <类型 = 文本型>
        临时数据 = 共享内存.读共享数据_ ("yw对象")
        对象名 = 字节集到文本 (临时数据)
        如果 (对象名 == 本端名)
        {
            临时数据 = 共享内存.读共享数据_ ("yw地内")
        }
        否则
        {
            返回 (0)
        }
        返回 (取字节集数据 (临时数据, 0, 变整数))
    }

    方法 取通讯字节集内容_ <公开 类型 = 字节集类 注释 = "返回的地址数据可使用：置对象数据等命令还原数据" 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 对象名 <类型 = 文本型>
        临时数据 = 共享内存.读共享数据_ ("yw对象")
        对象名 = 字节集到文本 (临时数据)
        如果 (对象名 == 本端名)
        {
            临时数据 = 共享内存.读共享数据_ ("yw字内")
        }
        否则
        {
            临时数据 = 字节集类.取空白字节集 (0)
        }
        返回 (临时数据)
    }

    方法 取通讯文本内容_ <公开 类型 = 文本型 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 对象名 <类型 = 文本型>
        临时数据 = 共享内存.读共享数据_ ("yw对象")
        对象名 = 字节集到文本 (临时数据)
        如果 (对象名 == 本端名)
        {
            临时数据 = 共享内存.读共享数据_ ("yw文内")
        }
        否则
        {
            返回 ("")
        }
        返回 (字节集到文本 (临时数据))
    }

    方法 取通讯标记内容_ <公开 类型 = 整数 折叠>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 对象名 <类型 = 文本型>
        临时数据 = 共享内存.读共享数据_ ("yw对象")
        对象名 = 字节集到文本 (临时数据)
        如果 (对象名 == 本端名)
        {
            临时数据 = 共享内存.读共享数据_ ("yw标记")
        }
        否则
        {
            返回 (0)
        }
        返回 (取字节集数据 (临时数据, 0, 整数))
    }

    方法 通讯事件 <公开 定义事件 类型 = 整数 注释 = "需要开启“开启消息等待_”才有事件触发" 折叠>
    参数 地址内容 <类型 = 变整数 注释 = "根据数据或对象的指针，取数据内容；指针到文本、读指针处对象、读指针处值、置对象数据等">
    参数 文本内容 <类型 = 文本型>
    参数 字节集内容 <类型 = 字节集类 注释 = "可使用“置对象数据”命令">
    参数 通讯标记 <类型 = 整数>

    方法 类_清理 <折叠>
    {
        释放句柄_ ()
    }

    方法 线程池类2__线程池事件 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类2_>
    参数 标记值 <类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户参数 <类型 = 长整数>
    参数 用户数据 <类型 = 变整数>
    {
        变量 临时数据 <类型 = 字节集类>
        变量 对象名 <类型 = 文本型>
        变量 状态值 <类型 = 整数>
        判断循环 (状态 == 假)
        {
            临时数据 = 共享内存.读共享数据_ ("yw状态")
            状态值 = 取字节集数据 (临时数据, 0, 整数)
            如果真 (状态值 == 1 && 当前标记 == 假)
            {
                同步返回 = 真
                处理事件_ ()
                临时数据 = 共享内存.读共享数据_ ("yw对象")
                对象名 = 字节集到文本 (临时数据)
                共享内存.写共享数据_ ("yw状态", 到字节集 (2))
                处理事件_ ()
                如果 (对象名 == 本端名)
                {
                    通讯事件 (取通讯地址内容_ (), 取通讯文本内容_ (), 取通讯字节集内容_ (), 取通讯标记内容_ ())
                }
            }
            如果真 (当前标记 == 真)
            {
                当前标记 = 假
            }
            延迟2_ (1)
        }
        返回 (0)
    }
}

