类 进程注入类_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.进程注入\"" @视窗.外部头文件 = "<TlHelp32.h>">
{
    方法 注入1_ <公开 类型 = 逻辑型 注释 = "支持32位、64位。调用本命令的程序位数必须与DLL一致" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 strtmp <类型 = 字节集类>
        变量 strpoint <类型 = 变整数>
        strtmp = 文本到多字节 (DLL文件名, )
        strpoint = 取字节集指针 (strtmp)
        @    LPCSTR DllPath = (LPCSTR)@<strpoint>;
        @    DWORD hDllModule = 0;
        @    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
        @    if (hProcess)
        @    {
        @        SIZE_T dwSize = strlen(DllPath)+1;
        @        LPVOID pMem = VirtualAllocEx(hProcess, NULL, dwSize, MEM_COMMIT, PAGE_EXECUTE_READWRITE);
        @        if (pMem)
        @        {
        @            WriteProcessMemory(hProcess, pMem, (LPVOID)DllPath, dwSize, NULL);
        @            HANDLE hThread = CreateRemoteThread(hProcess,NULL,0,(LPTHREAD_START_ROUTINE)LoadLibraryA,pMem,0,NULL);
        @            if (hThread)
        @            {
        @                WaitForSingleObject(hThread, INFINITE);
        @                GetExitCodeThread(hThread, &hDllModule);    //GetExitCodeThread无法取回64位类型的返回码,只能取4位
        @                CloseHandle(hThread);
        @            }
        @            VirtualFreeEx(hProcess, pMem, 0, MEM_RELEASE);
        @        }
        @        CloseHandle(hProcess);
        @    }
        @    return hDllModule != NULL;
    }

    方法 注入2_ <公开 类型 = 逻辑型 注释 = "支持32位、64位。调用本命令的程序位数必须与DLL一致" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 szDllPath <类型 = 字节集类>
        szDllPath = 到字节集 (DLL文件名)
        @ DWORD hDllModule = 0;
        @    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
        @    if (hProcess)
        @    {
        @        DWORD dwSize = (INT)@<szDllPath>.GetSize();
        @        LPVOID pMem = VirtualAllocEx(hProcess, NULL, dwSize, MEM_COMMIT, PAGE_READWRITE);
        @        if (pMem)
        @        {
        @            WriteProcessMemory(hProcess, pMem, @<szDllPath>.GetPtr(), dwSize, NULL);
        @            LPVOID pFunc = LoadLibraryW;
        @            HANDLE hThread = CreateRemoteThread(hProcess, NULL, 0, (LPTHREAD_START_ROUTINE)pFunc, pMem, 0, NULL);
        @            if (hThread)
        @            {
        @                WaitForSingleObject(hThread, INFINITE);
        @                GetExitCodeThread(hThread, &hDllModule);    //GetExitCodeThread无法取回64位类型的返回码,只能取4位
        @                CloseHandle(hThread);
        @            }
        @            VirtualFreeEx(hProcess, pMem, 0, MEM_RELEASE);
        @        }
        @        CloseHandle(hProcess);
        @    }
        @    return hDllModule != NULL;
    }

    方法 注入3_ <公开 类型 = 逻辑型 注释 = "支持32位、64位。调用本命令的程序位数必须与DLL一致" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 szDllPath <类型 = 字节集类>
        szDllPath = 到字节集 (DLL文件名)
        @ DWORD hDllModule = 0;
        @    HANDLE ProcessHandle = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
        @    if (ProcessHandle)
        @    {
        @        DWORD dwSize = (INT)@<szDllPath>.GetSize();
        @        LPVOID pMem = VirtualAllocEx(ProcessHandle, NULL, dwSize, MEM_COMMIT, PAGE_READWRITE);
        @        if (pMem)
        @        {
        @            WriteProcessMemory(ProcessHandle, pMem, @<szDllPath>.GetPtr(), dwSize, NULL);
        @            PTHREAD_START_ROUTINE threatStartRoutineAddress = (PTHREAD_START_ROUTINE)GetProcAddress(GetModuleHandle(TEXT("Kernel32")), "LoadLibraryW");
        @            HANDLE hThread = CreateRemoteThread(ProcessHandle, NULL, 0, threatStartRoutineAddress, pMem, 0, NULL);
        @            if (hThread)
        @            {
        @                WaitForSingleObject(hThread, INFINITE);
        @                GetExitCodeThread(hThread, &hDllModule);
        @                CloseHandle(hThread);
        @            }
        @        VirtualFreeEx(ProcessHandle, pMem, 0, MEM_RELEASE);
        @        }
        @        CloseHandle(ProcessHandle);
        @    }
        @    return hDllModule != NULL;
    }

    方法 卸载注入1_ <公开 类型 = 逻辑型 注释 = "FreeLibrary" 注释 = "支持32位、64位。调用本命令的程序位数必须与DLL一致" 折叠 折叠2 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 DLL句柄 <类型 = 变整数>
        DLL句柄 = 进程_取远程模块句柄 (进程ID, DLL文件名)
        如果真 (DLL句柄 > 0)
        {
            @    DWORD dwExitCode = 0;
            @    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
            @    if (hProcess)
            @    {
            @        HANDLE hThread = CreateRemoteThread(hProcess,NULL,0,(LPTHREAD_START_ROUTINE)FreeLibrary,(LPVOID)@<DLL句柄>,0,NULL);
            @        if (hThread)
            @        {
            @            WaitForSingleObject(hThread, INFINITE);
            @            GetExitCodeThread(hThread, &dwExitCode);    //GetExitCodeThread无法取回64位类型的返回码,只能取4位
            @            CloseHandle(hThread);
            @        }
            @        CloseHandle(hProcess);
            @        return dwExitCode == TRUE;
            @    }

        }
        返回 (假)
    }

    方法 卸载注入2_ <公开 类型 = 逻辑型 注释 = "FreeLibraryAndExitThread" 注释 = "支持32位、64位。调用本命令的程序位数必须与DLL一致" 折叠 折叠2 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 DLL句柄 <类型 = 变整数>
        DLL句柄 = 进程_取远程模块句柄 (进程ID, DLL文件名)
        如果真 (DLL句柄 > 0)
        {
            @    DWORD dwExitCode = 0;
            @    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
            @    if (hProcess)
            @    {
            @        HANDLE hThread = CreateRemoteThread(hProcess,NULL,0,(LPTHREAD_START_ROUTINE)FreeLibraryAndExitThread,(LPVOID)@<DLL句柄>,0,NULL);
            @        if (hThread)
            @        {
            @            WaitForSingleObject(hThread, INFINITE);
            @            GetExitCodeThread(hThread, &dwExitCode);    //GetExitCodeThread无法取回64位类型的返回码,只能取4位
            @            CloseHandle(hThread);
            @        }
            @        CloseHandle(hProcess);
            @        return dwExitCode != NULL;
            @    }

        }
        返回 (假)
    }
}

类 进程注入类2_ <公开 注释 = "不落地注入" 折叠 @文档 = "category = \"进程权限库.进程注入\"">
{
    方法 注入_ <公开 类型 = 变整数 注释 = "64位专用，不落地注入" 返回值注释 = "返回非0表示成功" 折叠>
    参数 进程ID <类型 = 整数>
    参数 DLL数据 <类型 = 字节集类 注释 = "读入文件() 或 视窗文件资源　来加载DLL文件数据">
    {
        变量 局_param <类型 = param>
        变量 进程句柄 <类型 = 变整数>
        进程句柄 = 进程_打开进程_ID (进程ID)
        局_param.Size = DLL数据.取字节集长度 ()
        如果真 (局_param.Size > 0)
        {
            局_param.pFunc = 内存_申请内存2 (进程句柄, (整数)局_param.Size + 1280)  // 1280是给分配的Shellcode[参_数据集]注入的空间
            如果真 (局_param.pFunc != 0)
            {
                局_param.LdrGetProcedureAddress = 取进程函数地址 ("ntdll.dll", "LdrGetProcedureAddress")
                如果真 (局_param.LdrGetProcedureAddress != 0)
                {
                    局_param.NtAllocateVirtualMemory = 取进程函数地址 ("ntdll.dll", "NtAllocateVirtualMemory")
                    如果真 (局_param.NtAllocateVirtualMemory != 0)
                    {
                        局_param.LdrLoadDll = 取进程函数地址 ("ntdll.dll", "LdrLoadDll")
                        如果真 (局_param.LdrLoadDll != 0)
                        {
                            局_param.RtlInitAnsiString = 取进程函数地址 ("ntdll.dll", "RtlInitAnsiString")
                            如果真 (局_param.RtlInitAnsiString != 0)
                            {
                                局_param.RtlAnsiStringToUnicodeString = 取进程函数地址 ("ntdll.dll", "RtlAnsiStringToUnicodeString")
                                如果真 (局_param.RtlAnsiStringToUnicodeString != 0)
                                {
                                    局_param.RtlFreeUnicodeString = 取进程函数地址 ("ntdll.dll", "RtlFreeUnicodeString")
                                    如果真 (局_param.RtlFreeUnicodeString != 0)
                                    {
                                        局_param.LdrUnloadDll = 取进程函数地址 ("ntdll.dll", "LdrUnloadDll")
                                        如果真 (局_param.LdrUnloadDll != 0)
                                        {
                                            局_param.NtFreeVirtualMemory = 取进程函数地址 ("ntdll.dll", "NtFreeVirtualMemory")
                                            如果真 (局_param.NtFreeVirtualMemory != 0)
                                            {
                                                变量 ShellCode <类型 = 字节集类>
