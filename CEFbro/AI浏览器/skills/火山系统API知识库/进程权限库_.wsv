        如果 (pid != 0)
        {
            返回 (进程_取指定进程窗口句柄2_进程ID (pid, 5000))
        }
        返回 (0)
    }

    方法 进程_取指定进程窗口句柄2_进程ID <公开 静态 类型 = 变整数 注释 = "通过进程ID窗口句柄" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 等待时限 <类型 = 整数 @默认值 = 5000>
    {
        变量 启动时间 <类型 = 长整数>
        变量 句柄 <静态 类型 = 变整数>
        变量 pid <类型 = 整数>
        启动时间 = 取启动时间 ()
        判断循环 (取启动时间 () - 启动时间 < 等待时限)
        {
            句柄 = 窗口_取窗口组件句柄 (, , 0, 句柄)
            如果 (窗口_窗口是否可见 (句柄) == 假)
            {
                到循环尾
            }
            pid = 进程_窗口句柄取进程ID (句柄)
            如果 (pid == 进程ID)
            {
                跳出循环
            }
        }
        返回 (句柄)
    }

    方法 进程_取指定进程窗口句柄3_进程ID <公开 静态 类型 = 变整数 注释 = "通过进程ID取窗口句柄" 返回值注释 = "成功返回找到的第一个窗口句柄，不能保证是主窗口句柄，失败返回0" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "0为当前进程" @默认值 = 0>
    参数 返回的窗口句柄组 <类型 = 变整数数组类 注释 = "所有获取到的窗口句柄都保存在此数组中，并返回找到的第一个窗口句柄" @默认值 = 空对象>
    {
        返回的窗口句柄组.删除所有成员 ()
        @ HWND hWnd = ::GetTopWindow(NULL);
        @ DWORD dwFindPID = @<进程ID> ? static_cast<DWORD>(@<进程ID>) : ::GetCurrentProcessId();
        @ while (hWnd) {
        @     DWORD dwPID = 0;
        @     DWORD dwTheardId = ::GetWindowThreadProcessId(hWnd, &dwPID);
        @     if (dwTheardId) {
        @         if (dwPID == dwFindPID)
        @             @<返回的窗口句柄组>.data().Add((INT_P)hWnd);
        @     }
        @     hWnd = ::GetNextWindow(hWnd, GW_HWNDNEXT);
        @ }
        返回 (选择 (返回的窗口句柄组.取成员数 () > 0, 返回的窗口句柄组.取成员 (0), (变整数)0))
    }

    方法 进程_窗口句柄取进程ID <公开 静态 类型 = 整数 注释 = "取出指定窗口句柄的进程ID" 折叠 @禁止流程检查 = 真>
