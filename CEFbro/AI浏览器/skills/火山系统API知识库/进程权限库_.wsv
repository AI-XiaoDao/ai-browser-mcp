    方法 进程_取远程函数地址 <公开 静态 类型 = 变整数 返回值注释 = "返回进程中指定DLL函数基址" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    参数 DLL函数输出名 <类型 = 文本型 注释 = "即DLL中，@输出名">
    {
        变量 函数地址 <类型 = 变整数>
        变量 strtmp <类型 = 字节集类>
        变量 strpoint <类型 = 变整数>
        strtmp = 文本到多字节 (DLL文件名, )
        strpoint = 取字节集指针 (strtmp)
        @    LPCSTR DllFileName = (LPCSTR)@<strpoint>;
        @    @an<CVolMem> memBuf;
        @    INT_P npResultTextLength;
        @    const char * DllFuncName = GetMbsText (@<DLL函数输出名>.GetText (), memBuf, &npResultTextLength);
        @    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
        @    if (hProcess)
        @    {
        @        LPVOID pAddress = GetProcAddress(GetModuleHandleA(DllFileName), DllFuncName);
        @        @<函数地址> = (@dt<变整数>)pAddress;
        @        CloseHandle(hProcess);
        如果真 (函数地址 > 0)
        {
            返回 (函数地址)
        }
        @    }
        返回 (0)
    }

    方法 进程_取远程模块句柄 <公开 静态 类型 = 变整数 返回值注释 = "返回进程中DLL模块句柄" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    参数 DLL文件名 <类型 = 文本型 注释 = "完整来源路径">
    {
        变量 DLL信息 <类型 = 模块信息类_>
        @ HANDLE hSnapshort = CreateToolhelp32Snapshot(TH32CS_SNAPMODULE, @<进程ID>);
        @ if (!hSnapshort) return 0;
        @ MODULEENTRY32W me = { sizeof(MODULEENTRY32W) };
        @ BOOL bRet = Module32FirstW(hSnapshort, &me);
        @ while (bRet)
        @ {
        @     @<DLL信息.模块ID> = me.th32ModuleID;
        @     @<DLL信息.进程ID> = me.th32ProcessID;
        @     @<DLL信息.全局使用计数> = me.GlblcntUsage;
        @     @<DLL信息.模块使用计数> = me.ProccntUsage;
        @     @<DLL信息.模块基址> = (@dt<变整数>)me.modBaseAddr;
        @     @<DLL信息.模块大小> = me.modBaseSize;
        @     @<DLL信息.模块句柄> = (@dt<变整数>)me.hModule;
        @     @<DLL信息.模块文件名>.SetValueText(me.szModule);
        @     @<DLL信息.模块完整路径>.SetValueText(me.szExePath);
        @     bRet = Module32NextW(hSnapshort, &me);
        如果真 (到小写 (DLL信息.模块文件名) == 到小写 (DLL文件名) || 到小写 (DLL信息.模块完整路径) == 到小写 (DLL文件名))
        {
            返回 (DLL信息.模块句柄)
        }
        @ }
        @ CloseHandle(hSnapshort);
        返回 (0)
    }

    方法 进程_取进程模块基址 <公开 静态 类型 = 变整数 折叠 @视窗.外部头文件 = "TlHelp32.h">
    参数 进程ID <类型 = 整数>
    参数 模块名 <类型 = 文本型>
    {
        @ HANDLE hModuleSnap = INVALID_HANDLE_VALUE;  
        @ MODULEENTRY32 me32;  
        @ hModuleSnap = CreateToolhelp32Snapshot(TH32CS_SNAPMODULE, @<进程ID>);  
        @ if (hModuleSnap == INVALID_HANDLE_VALUE) {  
        @    return(FALSE);  
        @ }  
        @ me32.dwSize = sizeof(MODULEENTRY32);   
        @ if (!Module32First(hModuleSnap, &me32)) {  
        @     CloseHandle(hModuleSnap);  
        @     return 0;  
        @ }  
        @ do {  
        @ if (wcscmp(me32.szModule, @<模块名>) == 0) {  
        @ return ((@dt<变整数>)me32.modBaseAddr);  
        @     }  
        @ } while (Module32Next(hModuleSnap, &me32));  
        @ CloseHandle(hModuleSnap);
        @ return 0;
        返回 (0)
    }
}

# //====

类 系统级权限类_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.系统权限\"" @视窗.外部头文件 = "<TlHelp32.h>" @全局类 = 真>
{
    方法 进程_以系统级权限运行程序 <公开 静态 类型 = 逻辑型 注释 = "将程序进程权限提升至SYSTEM级" 折叠>
    参数 程序路径 <类型 = 文本型 注释 = "默认提权自身" @默认值 = "">
    参数 隐藏窗口运行 <类型 = 逻辑型 注释 = "默认不隐藏窗口" @默认值 = 假>
    {
        变量 SystemProcessHandle <类型 = 变整数>
        变量 SystemTokenHandle <类型 = 变整数>
        变量 phNewToken <类型 = 变整数>
        变量 自身获取权限 <类型 = 逻辑型>
        如果真 (进程_进程提权 () == 假)
        {
            返回 (假)
        }
        如果真 (文本是否为空 (程序路径))
        {
            程序路径 = 取运行目录 () + 取执行文件名 ()
            自身获取权限 = 真
            如果真 (进程_取程序运行权限级别 () == 3)
            {
                返回 (真)
            }
        }
        SystemProcessHandle = 进程提权API.OpenProcess (1024, 假, 内部取进程ID ("lsass.exe"))
        如果真 (SystemProcessHandle == 0)
        {
            SystemProcessHandle = 进程提权API.OpenProcess (1024, 假, 内部取进程ID ("winlogon.exe"))
        }
        如果真 (SystemProcessHandle == 0)
        {
            返回 (假)
        }
        如果真 (进程提权API.OpenProcessToken (SystemProcessHandle, 2, 取变量地址 (SystemTokenHandle)))  // 取系统令牌
        {
            进程提权API.DuplicateTokenExW (SystemTokenHandle, 33554432, 0, 2, 1, 取变量地址 (phNewToken))  // 复制令牌
        }
        进程提权API.CloseHandle (SystemTokenHandle)
        如果 (phNewToken == 0)
        {
            返回 (假)
        }
        变量 P1 <类型 = STARTUPINFO类_>
        变量 P2 <类型 = PROCESS_INFORMATION类_>
        变量 lpCommandLine <类型 = 文本型 值 = "winsta0\\default">
        变量 提升权限是否成功 <类型 = 逻辑型>
        P1.cb = 68
        P1.lpDesktop = 取文本指针 (lpCommandLine)
        如果真 (隐藏窗口运行)
        {
            P1.wShowWindow = 系统级权限常量.SW_HIDE
            P1.dwFlags = 系统级权限常量.STARTF_USESHOWWINDOW
        }
        提升权限是否成功 = 进程提权API.CreateProcessWithTokenW (phNewToken, 系统级权限常量.LOGON_NETCREDENTIALS_ONLY, 0, 取文本指针 (程序路径), 系统级权限常量.NORMAL_PRIORITY_CLASS, 0, 0, P1, P2.取对象自身指针 ())
        进程提权API.CloseHandle (phNewToken)
        如果 (提升权限是否成功)
        {
            如果 (自身获取权限 == 真)
            {
                结束 ()
            }
            否则
            {
                返回 (提升权限是否成功)
            }
        }
        否则
        {
            如果 (自身获取权限 == 真)
            {
                如果 (全局信息框 ("自身进程获取权限失败！是否重新获取？", 信息框按钮.询问图标 + 信息框按钮.是否钮, "错误：", 0) == 返回按钮类型.否钮)
                {
                    结束 ()
                }
                否则
                {
                    进程_以系统级权限运行程序 ()
                }
            }
            否则
            {
                返回 (提升权限是否成功)
            }
        }
        返回 (提升权限是否成功)
    }

    方法 进程_取程序运行权限级别 <公开 静态 类型 = 整数 注释 = "获取进程当前UAC的执行权限级别。0、低级 1、中级 2、高级 3、系统级 -1、未知" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 @默认值 = 0>
    {
        @ HANDLE hProcess = GetCurrentProcess();
        @ if (@<进程ID> > 0)
        @     hProcess = OpenProcess(PROCESS_QUERY_INFORMATION, FALSE, @<进程ID>);
        @ if (!hProcess) return -1;
        @ HANDLE hToken;
        @ DWORD dwIntegrityLevel = -1;
        @ if (OpenProcessToken(hProcess, TOKEN_QUERY | TOKEN_QUERY_SOURCE, &hToken))
        @ {
        @     DWORD dwByteLen = 0;
        @     GetTokenInformation(hToken, TokenIntegrityLevel, NULL, 0, &dwByteLen);
        @     TOKEN_MANDATORY_LABEL* pTIL = (TOKEN_MANDATORY_LABEL*)malloc(dwByteLen);
        @     if (GetTokenInformation(hToken, TokenIntegrityLevel, pTIL, dwByteLen, &dwByteLen))
        @     {
        @         dwIntegrityLevel = *GetSidSubAuthority(pTIL->Label.Sid, (DWORD)(UCHAR)(*GetSidSubAuthorityCount(pTIL->Label.Sid) - 1));
        @     }
        @     free(pTIL);
        @     CloseHandle(hToken);
        @ }
        @ CloseHandle(hProcess);
        @ if (dwIntegrityLevel == SECURITY_MANDATORY_LOW_RID)
        @     return 0;
        @ else if (dwIntegrityLevel >= SECURITY_MANDATORY_MEDIUM_RID && dwIntegrityLevel < SECURITY_MANDATORY_HIGH_RID)
        @     return 1;
        @ else if (dwIntegrityLevel >= SECURITY_MANDATORY_HIGH_RID && dwIntegrityLevel < SECURITY_MANDATORY_SYSTEM_RID)
        @     return 2;
        @ else if (dwIntegrityLevel >= SECURITY_MANDATORY_SYSTEM_RID)
        @     return 3;
        @ else
        @     return -1;
    }

    方法 内部取进程ID <静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        @ HANDLE hProcessSnap = ::CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS,NULL);
        @ PROCESSENTRY32 pe32;CWString ProcessName = @<进程名>,sProcessName;
        @ ProcessName.MakeLower ();
        @ if (hProcessSnap == INVALID_HANDLE_VALUE)
        @ { return -1; }
        @ pe32.dwSize = sizeof(pe32);
        @ BOOL bRet = ::Process32First(hProcessSnap,&pe32);
        @ while(bRet)
        @ {
        @ sProcessName=pe32.szExeFile;
        @ sProcessName.MakeLower();
        @ if (sProcessName == ProcessName)
        @ { ::CloseHandle(hProcessSnap); return pe32.th32ProcessID; }
        @ bRet = ::Process32Next(hProcessSnap,&pe32);
        @ }
        @ ::CloseHandle(hProcessSnap);
        @ return 0;
    }
}

