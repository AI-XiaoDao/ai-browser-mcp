<火山程序 类型 = "通常" 版本 = 1 />

包 火山.仰望 <@文档 = "category = \"进程权限库\"">

类 互斥体类_ <公开 折叠 @文档 = "category = \"进程权限库.互斥体\"">
{
    变量 线程 <类型 = 线程池类2_>
    变量 互斥 <类型 = 许可锁类_>
    变量 标记组 <类型 = 整数数组类>

    方法 类_初始化 <折叠>
    {
        线程.创建_ ()
    }

    方法 关闭互斥体_路径 <公开 类型 = 逻辑型 注释 = "同时会运行该程序" 折叠>
    参数 程序路径 <类型 = 文本型>
    参数 互斥体名称 <类型 = 文本数组类>
    {
        变量 信息 <类型 = 互斥体信息类_>
        变量 id <类型 = 整数>
        变量 序号 <类型 = 整数>
        变量 开始时间 <类型 = 长整数>
        互斥.加锁 ()
        序号 = 标记组.取成员数 ()
        标记组.加入成员 (-1)
        id = 进程_创建进程 (程序路径, , , 5)
        信息.进程ID = id
        信息.互斥体名称 = 互斥体名称
        线程.投递对象_ (序号, 信息)
        互斥.解锁 ()
        开始时间 = 取启动时间 ()
        判断循环 (标记组.取成员 (序号) == -1)
        {
            如果真 (取启动时间 () - 开始时间 > 2000)
            {
                跳出循环
            }
            处理事件_ ()
        }
        返回 (标记组.取成员 (序号) != -1)
    }

    方法 关闭互斥体_ID <公开 类型 = 逻辑型 注释 = "需要手动运行程序后再执行本命令" 折叠>
    参数 进程ID <类型 = 整数>
    参数 互斥体名称 <类型 = 文本数组类>
    {
        变量 信息 <类型 = 互斥体信息类_>
        变量 序号 <类型 = 整数>
        变量 开始时间 <类型 = 长整数>
        互斥.加锁 ()
        序号 = 标记组.取成员数 ()
        标记组.加入成员 (-1)
        信息.进程ID = 进程ID
        信息.互斥体名称 = 互斥体名称
        线程.投递对象_ (序号, 信息)
        互斥.解锁 ()
        开始时间 = 取启动时间 ()
        判断循环 (标记组.取成员 (序号) == -1)
        {
            如果真 (取启动时间 () - 开始时间 > 2000)
            {
                跳出循环
            }
            处理事件_ ()
        }
        返回 (标记组.取成员 (序号) != -1)
    }

    方法 线程池类2__线程池事件_对象 <接收事件 类型 = 整数 折叠>
    参数 来源对象 <类型 = 线程池类2_>
    参数 标记值 <类型 = 整数>
    参数 用户标记 <类型 = 整数>
    参数 用户对象 <类型 = 对象类>
    参数 用户数据 <类型 = 变整数>
    {
        如果 (互斥体api.关闭互斥 (((互斥体信息类_)用户对象).进程ID, ((互斥体信息类_)用户对象).互斥体名称))
        {
            标记组.置成员值 (用户标记, 1)
        }
        否则
        {
            标记组.置成员值 (用户标记, 0)
        }
        返回 (0)
    }
}

类 互斥体类2_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.互斥体2\"" @全局类 = 真>
{
    方法 互斥_关闭互斥体运行程序 <公开 静态 类型 = 逻辑型 折叠 折叠2 @视窗.外部头文件 = "iostream" @禁止流程检查 = 真>
    参数 程序路径 <类型 = 文本型>
    参数 互斥体名称 <类型 = 文本型>
    参数 运行数量 <类型 = 整数 @默认值 = 2>
    {
        @ const TCHAR* mutexName = @<互斥体名称>;
        @ HANDLE hMutex = OpenMutex(MUTEX_ALL_ACCESS, FALSE, mutexName);
        @ if (hMutex != NULL) {
        @     CloseHandle(hMutex); //关闭互斥体
        @ }
        @ const TCHAR* programPath = @<程序路径>;
        @ for (int i = 0; i < @<运行数量>; ++i) {
        @     STARTUPINFO si = { sizeof(STARTUPINFO) };
        @     PROCESS_INFORMATION pi;
        @     if (CreateProcess(programPath, NULL, NULL, NULL, FALSE, 0, NULL, NULL, &si, &pi)) {
        @     CloseHandle(pi.hProcess);
        @     CloseHandle(pi.hThread);
        @     } else {
        @     return false;
        @     }
        @ }
        @ return true;
    }
}

类 互斥体api <折叠 @文档 = "category = \"进程权限库.互斥体.附加类\"">
{
    方法 关闭互斥 <公开 静态 类型 = 逻辑型 折叠>
    参数 进程ID <类型 = 整数>
    参数 互斥体名称 <类型 = 文本数组类>
    {
        变量 局_进程句柄 <类型 = 变整数>
        变量 HandleCount <类型 = 整数>
        变量 sHandle <类型 = 整数>
        变量 tHandle <类型 = 变整数>
        变量 buf <类型 = 字节集类>
        变量 len <类型 = 整数>
        变量 name <类型 = 文本型>
        变量 i <类型 = 整数>
        变量 n <类型 = 整数>
        变量 临时句柄 <类型 = 变整数>
        变量 结果 <类型 = 逻辑型>
        局_进程句柄 = 互斥体api.OpenProcess (2035711, 假, 进程ID)
        n = 互斥体名称.取成员数 ()
        i = 0
        如果真 (互斥体api.GetProcessHandleCount (局_进程句柄, 取变量地址 (HandleCount)))
        {
            判断循环 (HandleCount > i && sHandle < 65536)
            {
                sHandle = sHandle + 4
                如果真 (互斥体api.DuplicateHandle (局_进程句柄, sHandle, 互斥体api.GetCurrentProcess (), 取变量地址 (tHandle), 0, 假, 2))
                {
                    i = i + 1
                    buf = 取空白字节集 (8192)
                    如果 (互斥体api.ZwQueryObject (tHandle, 1, buf.取字节集指针 (), 8192, 0) == 0)
                    {
                        len = buf.取字节集数据 (0, 短整数)
                        如果真 (len > 0)
                        {
                            name = 字节集到文本 (buf.取字节集中间 (16, len))
                            临时句柄 = 0
                            计次循环 (n)
                            {
                                如果真 (寻找文本 (name, 互斥体名称.取成员 (取循环索引 ()), , ) != -1)
                                {
                                    如果真 (互斥体api.DuplicateHandle (局_进程句柄, sHandle, 互斥体api.GetCurrentProcess (), 取变量地址 (临时句柄), 0, 假, 1))
                                    {
                                        互斥体api.CloseHandle (临时句柄)
                                        互斥体名称.删除成员 (取循环索引 (), 1)
                                        n = 互斥体名称.取成员数 ()
                                        结果 = 真
                                    }
                                    跳出循环
                                }
                            }
                        }
                    }
                    互斥体api.CloseHandle (tHandle)
                    如果真 (n <= 0)
                    {
                        跳出循环
                    }
                }
            }
        }
        返回 (结果)
    }

    方法 OpenProcess <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "OpenProcess" @视窗.输入 = "Kernel32.dll">
    参数 dwDesiredAccess <类型 = 变整数>
    参数 bInheritHandle <类型 = 逻辑型>
    参数 dwProcessId <类型 = 变整数>

    方法 CloseHandle <公开 静态 类型 = 变整数 折叠 折叠2 @输出名 = "CloseHandle" @视窗.输入 = "Kernel32.dll">
    参数 hObject <类型 = 变整数>

    方法 GetProcessHandleCount <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "GetProcessHandleCount" @视窗.输入 = "Kernel32.dll">
    参数 hProcess <类型 = 变整数>
    参数 pdwHandleCount <类型 = 变整数>

    方法 DuplicateHandle <公开 静态 类型 = 逻辑型 折叠 折叠2 @输出名 = "DuplicateHandle" @视窗.输入 = "kernel32.dll">
    参数 hSourceProcessHandle <类型 = 变整数>
    参数 hSourceHandle <类型 = 变整数>
    参数 hTargetProcessHandle <类型 = 变整数>
    参数 lpTargetHandle <类型 = 变整数>
    参数 dwDesiredAccess <类型 = 整数>
    参数 bInheritHandle <类型 = 逻辑型>
    参数 dwOptions <类型 = 整数>

    方法 GetCurrentProcess <公开 静态 类型 = 变整数 折叠2 @输出名 = "GetCurrentProcess" @视窗.输入 = "kernel32.dll">

    方法 ZwQueryObject <公开 静态 类型 = 整数 折叠 折叠2 @输出名 = "ZwQueryObject" @视窗.输入 = "ntdll.dll">
    参数 ObjectHandle <类型 = 变整数>
    参数 ObjectInformationClass <类型 = 整数>
    参数 ObjectInformation <类型 = 变整数>
    参数 ObjectInformationLength <类型 = 整数>
    参数 ReturnLength <类型 = 变整数>
    {

    }
}

