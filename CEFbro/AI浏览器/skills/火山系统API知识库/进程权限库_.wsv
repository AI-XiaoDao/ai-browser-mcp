类 进程类_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.进程操作\"" @全局类 = 真 @视窗.外部头文件 = "<iostream>\r\n<TlHelp32.h>"
        @视窗.外部头文件 = "cmd\\Processes.h" @视窗.外部源文件 = "cmd\\Processes.cpp">
{
    方法 进程_创建进程 <公开 静态 类型 = 整数 返回值注释 = "返回进程ID" 折叠 @禁止流程检查 = 真>
    参数 程序路径 <类型 = 文本型 "">
    参数 命令行 <类型 = 文本型 @默认值 = 空对象>
    参数 是否等待 <类型 = 逻辑型 @默认值 = 假>
    参数 显示方式 <类型 = 整数 注释 = "2、隐藏　5、显示" @默认值 = 2>
    参数 运行目录 <类型 = 文本型 @默认值 = 空对象>
    {
        @ std::wstring strDir = @<运行目录>.GetText();
        @ if (@<运行目录>.IsEmpty())
        @ {
        @     strDir = @<程序路径>.GetText();
        @     int index = strDir.rfind(L"\\");
        @     if (index > -1)
        @         strDir = strDir.substr(0, index + 1);
        @ }
        @ STARTUPINFOW si = { sizeof(STARTUPINFOW) };
        @ switch (@<显示方式>)
        @ {
        @     case 1:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_HIDE;
        @         break;
        @     case 3:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_SHOWMINIMIZED;
        @         break;
        @     case 4:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_SHOWMAXIMIZED;
        @         break;
        @     case 5:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_SHOWNOACTIVATE;
        @         break;
        @     case 6:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_MINIMIZE;
        @         break;
        @     default:
        @         si.dwFlags = STARTF_USESHOWWINDOW;
        @         si.wShowWindow = SW_HIDE;
        @         break;
        @ }
        @ PROCESS_INFORMATION pi = { 0 };
        @ if (CreateProcessW(@<程序路径>.GetText(), (wchar_t*)@<命令行>.GetText(), NULL, NULL, FALSE, 0, NULL, strDir.c_str(), &si, &pi))
        @ {
        @     if (@<是否等待>)
        @         WaitForSingleObject(pi.hProcess, INFINITE);
        @     else
        @         WaitForSingleObject(pi.hProcess, 1000);
        @     CloseHandle(pi.hProcess);
        @     CloseHandle(pi.hThread);
        @ }
        @ return pi.dwProcessId;
    }

    方法 进程_创建进程_管理员 <公开 静态 类型 = 逻辑型 注释 = "在Vista/Win7及更高系统上,以管理员模式创建进程;" 注释 = "注意：请勿放在“窗口创建完毕”及“首次被激活”死循环中" 折叠 折叠2 @禁止流程检查 = 真>
    参数 进程路径 <类型 = 文本型 注释 = "留空默认启动自身进程" @默认值 = "">
    参数 运行参数 <类型 = 文本型 注释 = "命令行参数" @默认值 = "">
    {
        变量 lpFile <类型 = 文本型>
        @ SHELLEXECUTEINFOW ExecInfo;
        @ memset(&ExecInfo, 0, sizeof(SHELLEXECUTEINFOW));
        @ ExecInfo.cbSize = sizeof(SHELLEXECUTEINFOW);
        @ if (@<进程路径>.IsEmpty())
        @ {
        lpFile = 取运行目录 () + 取执行文件名 ()
        @ ExecInfo.lpFile = @<lpFile>.GetText();
        @ }
        @ else
        @ {
        @ ExecInfo.lpFile = @<进程路径>.GetText();
        @ }
        @ ExecInfo.lpParameters = @<运行参数>.GetText();
        @ ExecInfo.lpVerb = L"runas";
        @ ExecInfo.nShow = SW_SHOWDEFAULT;
        @ ExecInfo.fMask = SEE_MASK_FLAG_DDEWAIT;
        @ return ShellExecuteExW(&ExecInfo);
    }

    方法 进程_枚举进程 <公开 静态 类型 = 整数 返回值注释 = "返回进程数量" 折叠 折叠2 @视窗.外部头文件 = "<AclAPI.h>\r\n<TlHelp32.h>\r\n<Psapi.h>"
            @视窗.外部库 = "AdvAPI32.Lib\r\nPsapi.lib" @禁止流程检查 = 真>
    参数 返回的进程名称 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的进程ID <类型 = 整数数组类 @默认值 = 空对象>
    参数 是否获取程序路径 <类型 = 逻辑型 @默认值 = 假>
    参数 返回的程序路径 <类型 = 文本数组类 @默认值 = 空对象>
    参数 指定进程名 <类型 = 文本型 注释 = "指定枚举某进程，不区分大小写" @默认值 = "">
    {
        变量 szPath <类型 = 文本型>
        变量 dwProcessId <类型 = 整数>
        返回的进程名称.删除所有成员 ()
        返回的进程ID.删除所有成员 ()
        返回的程序路径.删除所有成员 ()
        @ GetPrivileges();
        @ PROCESSENTRY32W pe;
        @ memset(&pe, 0, sizeof(PROCESSENTRY32W));
        @ pe.dwSize = sizeof(PROCESSENTRY32W);
        @ HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPALL, 0);
        @ if (hSnapshot == INVALID_HANDLE_VALUE) return 0;
        @ BOOL hRes = Process32FirstW(hSnapshot, &pe);
        @ while (hRes)
        @ {
        @ @<szPath> =  pe.szExeFile;
        @ @<dwProcessId> = pe.th32ProcessID;
        如果 (指定进程名 == "")
        {
            返回的进程名称.加入成员 (szPath)
            返回的进程ID.加入成员 (dwProcessId)
            如果真 (是否获取程序路径 == 真)
            {
                返回的程序路径.加入成员 (进程_取进程路径_ID (dwProcessId))
            }
        }
        否则 (到小写 (指定进程名) == 到小写 (szPath))
        {
            返回的进程名称.加入成员 (szPath)
            返回的进程ID.加入成员 (dwProcessId)
            如果真 (是否获取程序路径 == 真)
            {
                返回的程序路径.加入成员 (进程_取进程路径_ID (dwProcessId))
            }
        }
        @ hRes = Process32NextW(hSnapshot, &pe);
        @ }
        @ CloseHandle(hSnapshot);
        返回 (返回的进程名称.取成员数 ())
    }

    方法 进程_枚举进程模块 <公开 静态 类型 = 整数 注释 = "先执行“进程提权_”，否则一些系统进程无法获取" 注释 = "获取某个进程所有模块的基本信息" 返回值注释 = "成功返回进程的模块数量" 折叠 折叠2
            @视窗.外部头文件 = "tlhelp32.h
" @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "所欲取模块信息的进程ID,0为当前进程" @输出名 = "nPID">
    参数 返回的模块基址 <类型 = 变整数数组类 @默认值 = 空对象>
    参数 返回的模块大小 <类型 = 整数数组类 @默认值 = 空对象>
    参数 返回的模块句柄 <类型 = 变整数数组类 @默认值 = 空对象>
    参数 返回的模块名称 <类型 = 文本数组类 @默认值 = 空对象>
    参数 返回的模块路径 <类型 = 文本数组类 @默认值 = 空对象>
    {
        变量 模块基址 <类型 = 变整数>
        变量 模块大小 <类型 = 整数>
        变量 模块句柄 <类型 = 变整数>
        变量 模块名称 <类型 = 文本型>
        变量 模块路径 <类型 = 文本型>
        @ HANDLE hModuleSnap = ::CreateToolhelp32Snapshot (TH32CS_SNAPMODULE, (DWORD)nPID);
        @ if (hModuleSnap == INVALID_HANDLE_VALUE) return 0;
        @ MODULEENTRY32W me32;
        @ memset (&me32, 0, sizeof (MODULEENTRY32W));
        @ me32.dwSize = sizeof (me32);
        @ if (::Module32FirstW (hModuleSnap, &me32) == FALSE) return 0;
        @ do
        @ {
        @     @<模块基址> = (INT_P)me32.modBaseAddr;
        @     @<模块大小> = (INT)me32.modBaseSize;
        @     @<模块句柄> = (INT_P)me32.hModule;
        @     @<模块名称>.SetText (me32.szModule);
        @     @<模块路径>.SetText (me32.szExePath);
        返回的模块基址.加入成员 (模块基址)
        返回的模块大小.加入成员 (模块大小)
        返回的模块句柄.加入成员 (模块句柄)
        返回的模块名称.加入成员 (模块名称)
        返回的模块路径.加入成员 (模块路径)
        @ } while (::Module32NextW (hModuleSnap, &me32));
        @ ::CloseHandle (hModuleSnap);
        返回 (返回的模块基址.取成员数 ())
    }

    方法 进程_结束进程_名称 <公开 静态 类型 = 逻辑型 注释 = "结束单个进程" 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        变量 进程ID <类型 = 整数>
        变量 结果 <类型 = 逻辑型>
        进程ID = 进程_取指定进程ID (进程名)
        如果真 (进程ID > 0)
        {
            结果 = 进程_结束进程_ID (进程ID)
        }
        返回 (结果)
    }

    方法 进程_结束进程_ID <公开 静态 类型 = 逻辑型 注释 = "结束单个进程" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    {
        @ DWORD dwProcessId;
        @ if (!@<进程ID>) dwProcessId = GetCurrentProcessId();
        @ else dwProcessId = @<进程ID>;
        @ HANDLE hProcess;
        @ hProcess = OpenProcess(PROCESS_TERMINATE, false, dwProcessId);
        @ bool bRes = TerminateProcess(hProcess, 0);
        @ CloseHandle(hProcess);
        @ return bRes;
    }

    方法 进程_结束进程_批量 <公开 静态 注释 = "结束多个同名进程" 折叠 @禁止流程检查 = 真>
    参数 进程名 <类型 = 文本型>
    {
        变量 开始时间 <类型 = 长整数>
        开始时间 = 取启动时间 ()
        判断循环 (真)
        {
            如果真 (取启动时间 () - 开始时间 > 4000)
            {
                跳出循环
            }
            如果 (进程_进程是否存在 (进程名) == 真)
            {
                进程_结束进程_名称 (进程名)
            }
            否则
            {
                跳出循环
            }
        }
    }

    方法 进程_关闭进程 <公开 静态 类型 = 逻辑型 注释 = "关闭进程句柄" 折叠 @禁止流程检查 = 真>
    参数 进程句柄 <类型 = 变整数>
    {
        @ return CloseHandle((HANDLE)@<进程句柄>);
    }

    方法 进程_取进程路径_名称 <公开 静态 类型 = 文本型 注释 = "返回指定进程路径" 折叠 "">
    参数 进程名 <类型 = 文本型>
    {
        变量 id <类型 = 整数>
        id = 进程_取指定进程ID (进程名)
        如果真 (id == 0)
        {
            返回 ("")
        }
        返回 (进程_取进程路径_ID (id))
    }

    方法 进程_取进程路径_ID <公开 静态 类型 = 文本型 注释 = "返回指定进程路径" 折叠 折叠2 @视窗.外部头文件 = "<Psapi.h>" @视窗.外部库 = "Psapi.lib" @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 @默认值 = 0>
    {
        变量 szFileName <类型 = 文本型>
        @ HANDLE hProcess = !@<进程ID> ? GetCurrentProcess() : OpenProcess(PROCESS_QUERY_INFORMATION, FALSE, @<进程ID>);
        @ if (!hProcess) return @<szFileName>.GetText();
        @ DWORD dwSize = 0;
        @ wchar_t szFileName[MAX_PATH] = { 0 };
        @ dwSize = GetProcessImageFileNameW(hProcess, szFileName, MAX_PATH);
        @ CloseHandle(hProcess);
        @ if (dwSize == 0) return @<szFileName>.GetText();
        @ wchar_t szDeviceName[MAX_PATH] = L" :";
        @ wchar_t szTargetPath[MAX_PATH] = { 0 };
        @ for (int i = 0; i < 26; i++)
        @ {
        @     szDeviceName[0] = L'A' + i;
        @     QueryDosDeviceW(szDeviceName, szTargetPath, MAX_PATH);
        @     DWORD dwSize = wcslen(szTargetPath);
        @     if (dwSize > 0 && wcsnicmp(szFileName, szTargetPath, dwSize) == 0)
        @     {
        @         wcscat(szDeviceName, szFileName + dwSize);
        @         @<szFileName>.SetValueText(szDeviceName);
        @         break;
        @     }
        @ }
        @ return @<szFileName>.GetText();
    }

    方法 进程_取进程线程数 <公开 静态 类型 = 整数 返回值注释 = "成功返回进程的线程数量." 折叠 折叠2 @视窗.外部头文件 = "tlhelp32.h
" @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "所欲取线程数量的进程ID" @输出名 = "nProcessID">
    {
        @ HANDLE hProcessSnap = ::CreateToolhelp32Snapshot (TH32CS_SNAPPROCESS, 0);
        @ if (hProcessSnap == INVALID_HANDLE_VALUE) return 0;
        @ PROCESSENTRY32W pe32;
        @ memset (&pe32, 0, sizeof (PROCESSENTRY32W));
        @ pe32.dwSize = sizeof (PROCESSENTRY32W);
        @ if (::Process32FirstW (hProcessSnap, &pe32) == FALSE) return 0;
        @ do
        @ {
        @     if (pe32.th32ProcessID == nProcessID)
        @     {
        @         ::CloseHandle (hProcessSnap);
        @         return (INT)pe32.cntThreads;
        @     }
        @ } while (::Process32NextW (hProcessSnap, &pe32));
        @ ::CloseHandle (hProcessSnap);
        @ return 0;
    }

    方法 进程_打开进程_ID <公开 静态 类型 = 变整数 注释 = "返回进程句柄" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    {
        @ return (INT_PTR)OpenProcess(PROCESS_ALL_ACCESS, FALSE, @<进程ID>);
    }

    方法 进程_打开进程_句柄 <公开 静态 类型 = 变整数 注释 = "返回进程句柄" 折叠 @禁止流程检查 = 真>
    参数 窗口句柄 <类型 = 变整数>
    {
        @ if (!IsWindow((HWND)@<窗口句柄>)) return 0;
        @ DWORD dwProcessId;
        @ GetWindowThreadProcessId((HWND)@<窗口句柄>, &dwProcessId);
        @ return (INT_PTR)OpenProcess(PROCESS_ALL_ACCESS, FALSE, dwProcessId);
    }

    方法 进程_取进程句柄数 <公开 静态 类型 = 整数 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数>
    {
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,@<进程ID>);
        @ DWORD handleCount = 0;  
        @ GetProcessHandleCount(hProcess,&handleCount);
        @ ::CloseHandle(hProcess);
        @ return handleCount;
    }

    方法 进程_取自身进程句柄 <公开 静态 类型 = 变整数 折叠 @禁止流程检查 = 真>
    {
        @ int id = GetCurrentProcessId();
        @ HANDLE hProcess = ::OpenProcess (PROCESS_ALL_ACCESS,NULL,id);
