                                                                    变量 i <类型 = 整数>
                                                                    变量 ss <类型 = 算术运算类>
                                                                    i = GetExitCodeThread (局_线程ID, 取变量地址 (dExecCode))
                                                                    关闭对象 (局_线程ID)
                                                                    如果真 (dExecCode < 0)
                                                                    {
                                                                        返回 (dExecCode)
                                                                    }
                                                                    dExecCode = dExecCode + 位左移 (位右移 (局_param.pFunc, 32), 32)
