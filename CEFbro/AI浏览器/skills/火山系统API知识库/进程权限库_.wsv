类 进程优先级类_ <公开 折叠 折叠2 @文档 = "category = \"进程权限库.进程优先级\"" @全局类 = 真>
{
    方法 进程_取进程优先级 <公开 静态 类型 = 整数 返回值注释 = "0、最高 1、高于标准 2、实时 3、标准 4、低于标准 5、低 -1、表示无权限访问进程" 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "默认0则取自身进程" @默认值 = 0>
    {
        @ HANDLE hProcess;
        @ if (!@<进程ID>) hProcess = GetCurrentProcess();
        @ else hProcess = OpenProcess(PROCESS_QUERY_INFORMATION, FALSE, @<进程ID>);
        @ if (!hProcess) return -1;
        @ DWORD Class = GetPriorityClass(hProcess);
        @ CloseHandle(hProcess);
        @ int Type = 0;
        @ if (Class == REALTIME_PRIORITY_CLASS) Type = 2;
        @ else if (Class == HIGH_PRIORITY_CLASS) Type = 0;
        @ else if (Class == ABOVE_NORMAL_PRIORITY_CLASS) Type = 1;
        @ else if (Class == NORMAL_PRIORITY_CLASS) Type = 3;
        @ else if (Class == BELOW_NORMAL_PRIORITY_CLASS) Type = 4;
        @ else if (Class == IDLE_PRIORITY_CLASS) Type = 5;
        @ return Type;
    }

    方法 进程_置进程优先级 <公开 静态 类型 = 逻辑型 折叠 @禁止流程检查 = 真>
    参数 进程ID <类型 = 整数 注释 = "默认0则取自身进程" @默认值 = 0>
    参数 进程级别 <类型 = 整数 注释 = "0、最高 1、高于标准 2、实时 3、标准 4、低于标准 5、低" @默认值 = 0>
    {
        @ DWORD Type = HIGH_PRIORITY_CLASS;
        @ if (@<进程级别> == 0) Type = HIGH_PRIORITY_CLASS;
        @ else if (@<进程级别> == 1) Type = ABOVE_NORMAL_PRIORITY_CLASS;
        @ else if (@<进程级别> == 2) Type = REALTIME_PRIORITY_CLASS;
        @ else if (@<进程级别> == 3) Type = NORMAL_PRIORITY_CLASS;
        @ else if (@<进程级别> == 4) Type = BELOW_NORMAL_PRIORITY_CLASS;
        @ else if (@<进程级别> == 5) Type = IDLE_PRIORITY_CLASS;
        @ HANDLE hProcess;
        @ if (!@<进程ID>) hProcess = GetCurrentProcess();
        @ else hProcess = OpenProcess(PROCESS_SET_INFORMATION, FALSE, @<进程ID>);
        @ if (!hProcess) return FALSE;
        @ BOOL bRet = SetPriorityClass(hProcess, Type);
        @ CloseHandle(hProcess);
        @ return bRet;
    }
}

