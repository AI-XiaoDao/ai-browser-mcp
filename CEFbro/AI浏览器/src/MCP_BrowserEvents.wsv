    方法 浏览器_载入错误 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 错误码 <类型 = 整数>
    参数 错误文本 <类型 = 文本型>
    参数 失败地址 <类型 = 文本型>
    {
        如果 (框架.是否为主框架 ())
        {
            如果 (浏览器容器.欢迎页导航已发起)
            {
                变量 欢迎地址 <类型 = 文本型>
                欢迎地址 = 浏览器容器.取欢迎页地址 ()
                如果 (失败地址 == 欢迎地址 || 失败地址 == 欢迎地址 + "/" || 取文本左边 (失败地址, 取文本长度 (欢迎地址)) == 欢迎地址)
                {
                    浏览器容器.重置欢迎页导航状态 ()
                    调试输出 ("[MCP] 欢迎页载入失败, 已重置导航状态:", 失败地址)
                }
            }
        }
        如果 (MCP命令服务器.是否监控载入事件 && 框架.是否为主框架 ())
        {
            变量 数据 <类型 = YYJSON对象类>
            数据.创建自文本 ("{}")
            数据.加入整数成员 ("error_code", 错误码)
            数据.加入文本成员 ("error_text", 错误文本)
            数据.加入文本成员 ("failed_url", 失败地址)
            MCP命令服务器.记录浏览器事件 ("load_error", 浏览器.取ID (), 数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
