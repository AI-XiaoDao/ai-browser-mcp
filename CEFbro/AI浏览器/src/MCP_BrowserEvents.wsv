    方法 浏览器_获取音频参数 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 参数 <类型 = FBrowser_音频参数>
    {
        如果 (MCP命令服务器.是否Hook音频 == 假 || MCP命令服务器.音频指纹配置 == "")
        {
            返回 (假)
        }
        变量 配置解析 <类型 = YYJSON只读对象类>
        如果 (配置解析.创建自文本 (MCP命令服务器.音频指纹配置) == 假)
        {
            返回 (假)
        }
        变量 sampleRate <类型 = 整数>
        sampleRate = MCP命令服务器.yyjson取整数 (配置解析, "sample_rate")
        如果 (sampleRate > 0)
        {
            参数.采样频率 = sampleRate
        }
        变量 channels <类型 = 整数>
        channels = MCP命令服务器.yyjson取整数 (配置解析, "channels")
        如果 (channels > 0)
        {
            参数.通道布局 = channels
        }
        变量 framesPerBuffer <类型 = 整数>
        framesPerBuffer = MCP命令服务器.yyjson取整数 (配置解析, "frames_per_buffer")
        如果 (framesPerBuffer > 0)
        {
            参数.帧缓冲 = framesPerBuffer
        }
        调试输出 ("[MCP] 音频参数Hook已应用: rate=", 参数.采样频率, " layout=", 参数.通道布局)
        返回 (真)
    }
    # --- JS 对话框 ---
    方法 浏览器_JS即将打开对话框 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 源地址 <类型 = 文本型>
    参数 对话框类型 <类型 = 整数>
    参数 消息文本 <类型 = 文本型>
    参数 默认提示文本 <类型 = 文本型>
    参数 回调 <类型 = 类_FBrowser_JS对话框回调>
    参数 禁止消息可设 <类型 = 逻辑型类>
    {
        如果 (MCP命令服务器.是否监控对话框)
        {
            变量 类型名 <类型 = 文本型>
            如果 (对话框类型 == 0)
            {
                类型名 = "alert"
            }
            否则 (对话框类型 == 1)
            {
                类型名 = "confirm"
            }
            否则 (对话框类型 == 2)
            {
                类型名 = "prompt"
            }
            否则
            {
                类型名 = "unknown"
            }
            // yyjson安全构建, 防止对话框消息含双引号/反斜杠破坏JSON
            变量 对话框数据 <类型 = YYJSON对象类>
            对话框数据.创建自文本 ("{}")
            对话框数据.加入文本成员 ("type", 类型名)
            对话框数据.加入文本成员 ("message", 消息文本)
            对话框数据.加入文本成员 ("url", 源地址)
            MCP命令服务器.记录浏览器事件 ("js_dialog", 浏览器.取ID (), 对话框数据.到可读文本 (YYJSON格式化选项.压缩))
        }
        如果 (MCP命令服务器.是否自动关闭JS对话框 && 回调.是否为空 () == 假)
        {
            回调.继续 (真, 默认提示文本)
            返回 (真)
        }
        返回 (假)
    }
