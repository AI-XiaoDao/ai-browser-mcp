<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# ================================================================
# MCP浏览器事件 — 网络监控 + 应用事件 + V8注入 + Console收集
# 被 MCP_Server.wsv 引用
# ================================================================
类 类_MCP_浏览器事件 <公开 基础类 = 类_FBrowser_浏览器事件>
{
    # 统一写入 browser_event 日志 (供 browser_event 工具查询)
    方法 记录监控事件 <类型 = 逻辑型>
    参数 开关 <类型 = 逻辑型>
    参数 事件类型 <类型 = 文本型>
    参数 浏览器ID <类型 = 整数>
    参数 数据JSON <类型 = 文本型 @默认值 = "">
    {
        如果 (开关)
        {
            MCP命令服务器.记录浏览器事件 (事件类型, 浏览器ID, 数据JSON)
        }
        返回 (开关)
    }
    方法 是否为里程碑进度 <公开 静态 类型 = 逻辑型 注释 = "进度事件仅记录 0/25/50/75/100 里程碑, 减少高频写入">
    参数 进度 <类型 = 整数>
    {
        返回 (进度 == 0 || 进度 == 25 || 进度 == 50 || 进度 == 75 || 进度 == 100)
    }
    方法 浏览器_创建完毕 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 额外信息 <类型 = 类_FBrowser_字典值>
    {
        MCP命令服务器.浏览器数组锁.加锁 ()
        浏览器容器.浏览器数组.加入成员 (浏览器)
        MCP命令服务器.浏览器数组锁.解锁 ()
        调试输出 ("[MCP] 浏览器创建完毕 [ID:", 浏览器.取ID (), "]")
        // 应用全局持久配置 (代理/缩放/静音)
        MCP命令服务器.应用持久配置到浏览器 (浏览器)
        // 自动注册CDP DevTools观察者(确保browser_cdp_call可用)
        MCP命令服务器.确保CDP观察者已注册 ()
        // ======== 预加载Hook注入 (浏览器加载前生效) ========
        // 所有Hook通过事件方法预注册, 开关在浏览器_创建完毕时检查一次,
        // 后续每个事件触发时再检查开关 (支持运行时动态切换)
        如果 (MCP命令服务器.是否Hook导航 && MCP命令服务器.导航拦截规则 != "")
        {
            调试输出 ("[MCP] 导航拦截Hook已预加载, 规则:", MCP命令服务器.导航拦截规则)
        }
        如果 (MCP命令服务器.是否Hook资源 && MCP命令服务器.资源替换规则 != "")
        {
            调试输出 ("[MCP] 资源拦截Hook已预加载, 规则:", MCP命令服务器.资源替换规则)
        }
        如果 (MCP命令服务器.是否Hook音频 && MCP命令服务器.音频指纹配置 != "")
        {
            调试输出 ("[MCP] 音频指纹Hook已预加载:", MCP命令服务器.音频指纹配置)
        }
        如果 (MCP命令服务器.是否记录网络)
        {
            调试输出 ("[MCP] 网络日志Hook已预加载")
        }
        如果 (MCP命令服务器.是否记录控制台)
        {
            调试输出 ("[MCP] 控制台日志Hook已预加载")
        }
        如果 (MCP命令服务器.是否缓存响应)
        {
            调试输出 ("[MCP] 响应缓存Hook已预加载 → SQLite:response_cache表")
        }
        // 如果有V8扩展待注入, 在渲染进程创建V8环境时注入 (最关键的预加载Hook)
        变量 待注入V8列表 <类型 = 文本数组类>
        待注入V8列表 = MCP命令服务器.持久V8扩展列表
        如果 (待注入V8列表.取成员数 () > 0)
        {
            调试输出 ("[MCP] V8预注入Hook:", 待注入V8列表.取成员数 (), "个")
        }
        变量 创建数据 <类型 = YYJSON对象类>
        创建数据.创建自文本 ("{}")
        创建数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        记录监控事件 (MCP命令服务器.是否监控生命周期, "browser_created", 浏览器.取ID (), 创建数据.到可读文本 (YYJSON格式化选项.压缩))
        浏览器容器.尝试导航欢迎页 ()
    }
    # V8 持久扩展已移至 类_MCP_初始化事件 (应用事件/渲染进程)
    # Console消息收集 — browser_collect console_enable 的核心实现
    方法 浏览器_控制台消息 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 日志级别 <类型 = 整数>
    参数 消息 <类型 = 文本型>
    参数 内容 <类型 = 文本型>
    参数 行 <类型 = 整数>
    {
        如果 (MCP命令服务器.是否记录控制台)
        {
            MCP命令服务器.记录控制台消息 (日志级别, 消息, 内容, 行)
        }
        返回 (假)
    }
    方法 浏览器_即将关闭 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        调试输出 ("[MCP] 浏览器即将关闭 [ID:", 浏览器.取ID (), "]")
        变量 关闭数据 <类型 = YYJSON对象类>
        关闭数据.创建自文本 ("{}")
        记录监控事件 (MCP命令服务器.是否监控生命周期, "browser_closing", 浏览器.取ID (), 关闭数据.到可读文本 (YYJSON格式化选项.压缩))
        MCP命令服务器.浏览器数组锁.加锁 ()
        变量 count <类型 = 整数>
        count = 浏览器容器.浏览器数组.取成员数 ()
        计次循环 (count)
        {
            变量 idx <类型 = 整数>
            idx = 取循环索引 ()
            变量 temp <类型 = 类_FBrowser_浏览器>
            temp = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, idx, 类_FBrowser_浏览器)
            如果 (temp.取ID () == 浏览器.取ID ())
            {
                浏览器容器.浏览器数组.删除成员 (idx)
                跳出循环
            }
        }
        变量 剩余数量 <类型 = 整数>
        剩余数量 = 浏览器容器.浏览器数组.取成员数 ()
        MCP命令服务器.浏览器数组锁.解锁 ()
        // CDP 观察者附着于 browser_id=CDP附着浏览器ID; 仅关闭该浏览器时注销, 避免弹窗关闭误伤主窗口
        如果 (MCP命令服务器.CDP观察者已注册 && 浏览器.取ID () == MCP命令服务器.CDP附着浏览器ID)
        {
            变量 closeVip <类型 = 类_FBrowserVIP_控制器>
            closeVip = 浏览器.取VIP控制器 ()
            如果 (closeVip.是否为空 () == 假)
            {
                closeVip.开发者消息_关闭监管者事件 ()
            }
            MCP命令服务器.CDP观察者已注册 = 假
            MCP命令服务器.CDP附着浏览器ID = 0
            调试输出 ("[MCP] CDP DevTools观察者因浏览器关闭而注销 [ID:", 浏览器.取ID (), "]")
        }
        如果 (剩余数量 == 0)
        {
            浏览器容器.重置欢迎页导航状态 ()
            浏览器容器.标记需要重建浏览器 ()
        }
    }
    方法 浏览器_获取资源处理器 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 请求 <类型 = 类_FBrowser_请求>
    参数 设置资源处理器 <类型 = 类_FBrowser_设置资源处理器>
    {
        如果 (MCP命令服务器.是否记录网络)
        {
            如果 (MCP命令服务器.是否详细记录网络)
            {
                MCP命令服务器.记录网络请求_详细 (请求)
            }
            否则
            {
                MCP命令服务器.记录网络请求 (请求.取类型 (), 请求.取地址 ())
            }
        }
        // 资源拦截Hook: 规则匹配日志 (实际拦截由VIP控制器处理)
        如果 (MCP命令服务器.是否Hook资源 && MCP命令服务器.资源替换规则 != "")
        {
            调试输出 ("[MCP] 资源Hook已激活, 规则:", MCP命令服务器.资源替换规则)
        }
    }
    方法 浏览器_获取资源过滤器 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 请求 <类型 = 类_FBrowser_请求>
    参数 响应 <类型 = 类_FBrowser_响应>
    参数 设置资源过滤器 <类型 = 类_FBrowser_设置资源过滤器>
    {
        如果 (MCP命令服务器.是否缓存响应)
        {
            变量 地址 <类型 = 文本型>
            地址 = 请求.取地址 ()
            如果 (地址 != "")
            {
                变量 缓存过滤器 <类型 = 类_FBrowser_事件智能指针>
                缓存过滤器.创建 (类_MCP_缓存过滤器)
                缓存过滤器.取执行类 (类_MCP_缓存过滤器).资源地址 = 地址
                缓存过滤器.取执行类 (类_MCP_缓存过滤器).资源MIME = 响应.取MIME类型 ()
                设置资源过滤器.设置 (缓存过滤器)
            }
        }
    }
    方法 浏览器_资源加载完毕 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 请求 <类型 = 类_FBrowser_请求>
    参数 响应 <类型 = 类_FBrowser_响应>
    参数 加载状态 <类型 = 整数>
    参数 内容长度 <类型 = 长整数>
    {
        如果 (MCP命令服务器.是否记录网络)
        {
            如果 (MCP命令服务器.是否详细记录网络)
            {
                MCP命令服务器.记录网络响应_详细 (请求, 响应, 内容长度)
            }
            否则
            {
                MCP命令服务器.记录网络响应 (请求.取地址 (), 响应.取状态 (), 响应.取MIME类型 (), 假)
            }
        }
    }
    # - 下载 (使用官方事件, 与主浏览器一致) ---
    方法 浏览器_即将下载 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 下载 <类型 = 类_FBrowser_下载>
    参数 推荐名 <类型 = 文本型>
    参数 下载回调 <类型 = 类_FBrowser_即将下载回调>
    {
        如果 (下载.是否为空 () == 假 && 下载回调.是否为空 () == 假)
        {
            调试输出 ("[MCP] 即将下载:", 下载.取推荐文件名 (), " 大小:", 下载.取总长度 ())
            变量 下载数据 <类型 = YYJSON对象类>
            下载数据.创建自文本 ("{}")
            下载数据.加入文本成员 ("filename", 下载.取推荐文件名 ())
            下载数据.加入长整数成员 ("total_bytes", 下载.取总长度 ())
            如果 (MCP命令服务器.是否自动保存下载)
            {
                变量 下载目录 <类型 = 文本型>
                下载目录 = 取运行目录 () + "\\Downloads"
                如果 (目录是否存在 (下载目录) == 假)
                {
                    创建目录 (下载目录)
                }
                变量 保存路径 <类型 = 文本型>
                保存路径 = 下载目录 + "\\" + 下载.取推荐文件名 ()
                下载数据.加入文本成员 ("save_path", 保存路径)
                下载数据.加入逻辑值成员 ("auto_save", 真)
                记录监控事件 (MCP命令服务器.是否监控下载事件, "download_start", 浏览器.取ID (), 下载数据.到可读文本 (YYJSON格式化选项.压缩))
                下载回调.继续 (保存路径, 假)
            }
            否则
            {
                下载数据.加入逻辑值成员 ("auto_save", 假)
                记录监控事件 (MCP命令服务器.是否监控下载事件, "download_start", 浏览器.取ID (), 下载数据.到可读文本 (YYJSON格式化选项.压缩))
            }
        }
        返回 (真)
    }
    方法 浏览器_正在下载 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 下载 <类型 = 类_FBrowser_下载>
    参数 下载回调 <类型 = 类_FBrowser_正在下载回调>
    {
        变量 进度 <类型 = 整数>
        进度 = 下载.取下载百分比 ()
        调试输出 ("[MCP] 下载中:", 下载.取推荐文件名 (), " 进度:", 进度, "%")
        如果 (MCP命令服务器.是否监控下载事件 && 是否为里程碑进度 (进度))
        {
            变量 进度数据 <类型 = YYJSON对象类>
            进度数据.创建自文本 ("{}")
            进度数据.加入文本成员 ("filename", 下载.取推荐文件名 ())
            进度数据.加入整数成员 ("percent", 进度)
            进度数据.加入长整数成员 ("received_bytes", 下载.取已下载长度 ())
            进度数据.加入长整数成员 ("total_bytes", 下载.取总长度 ())
            记录监控事件 (真, "download_progress", 浏览器.取ID (), 进度数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    # 页面加载完成 — 记录事件 + 通知主窗口更新地址栏
    方法 浏览器_载入结束 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 状态码 <类型 = 整数>
    {
        如果 (框架.是否为主框架 ())
        {
            如果 (MCP命令服务器.是否监控载入事件)
            {
                MCP命令服务器.记录加载事件 ("load_end", 浏览器.取ID (), 状态码)
            }
            浏览器容器.最新地址 = 框架.取地址 ()
            变量 当前URL <类型 = 文本型>
            当前URL = 框架.取地址 ()
            如果 (当前URL == 浏览器容器.取欢迎页地址 ())
            {
                浏览器容器.欢迎页已导航 = 真
                浏览器容器.欢迎页导航已发起 = 假
                浏览器容器.欢迎页导航发起毫秒 = 0
            }
        }
    }
    # URL变化 — 地址栏实时同步
    方法 浏览器_地址被改变 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 新地址 <类型 = 文本型>
    {
        如果 (框架.是否为主框架 () && 新地址 != "" && 新地址 != "about:blank" && 新地址 != "data:")
        {
            浏览器容器.最新地址 = 新地址
            变量 地址数据 <类型 = YYJSON对象类>
            地址数据.创建自文本 ("{}")
            地址数据.加入文本成员 ("url", 新地址)
            记录监控事件 (MCP命令服务器.是否监控生命周期, "url_changed", 浏览器.取ID (), 地址数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    # 渲染进程崩溃 — 通知客户端
    方法 浏览器_渲染意外终止 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 状态 <类型 = 整数>
    参数 错误码 <类型 = 整数>
    参数 错误文本 <类型 = 文本型>
    {
        调试输出 ("[MCP] 渲染进程崩溃! 浏览器ID:", 浏览器.取ID (), " 状态:", 状态, " 错误:", 错误文本)
        MCP命令服务器.记录加载事件 ("crash", 浏览器.取ID (), 错误码)
        MCP命令服务器.浏览器数组锁.加锁 ()
        变量 count <类型 = 整数>
        count = 浏览器容器.浏览器数组.取成员数 ()
        计次循环 (count)
        {
            变量 idx <类型 = 整数>
            idx = 取循环索引 ()
            变量 temp <类型 = 类_FBrowser_浏览器>
            temp = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, idx, 类_FBrowser_浏览器)
            如果 (temp.取ID () == 浏览器.取ID ())
            {
                浏览器容器.浏览器数组.删除成员 (idx)
                跳出循环
            }
        }
        MCP命令服务器.浏览器数组锁.解锁 ()
    }
    # URL导航拦截 — 可用于安全过滤, 通过 browser_intercept/action=navigate_block 动态启用
    # 参照 browser_event21.wsv: 浏览器_即将导航 中可调用 请求环境.置首选项
    方法 浏览器_即将导航 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 请求 <类型 = 类_FBrowser_请求>
    参数 用户动作 <类型 = 逻辑型>
    参数 是否重定向 <类型 = 逻辑型>
    {
        变量 目标地址 <类型 = 文本型>
        目标地址 = 请求.取地址 ()
        如果 (MCP命令服务器.是否监控载入事件 && 目标地址 != "")
        {
            变量 导航数据 <类型 = YYJSON对象类>
            导航数据.创建自文本 ("{}")
            导航数据.加入文本成员 ("url", 目标地址)
            导航数据.加入逻辑值成员 ("user_gesture", 用户动作)
            导航数据.加入逻辑值成员 ("is_redirect", 是否重定向)
            记录监控事件 (真, "navigate", 浏览器.取ID (), 导航数据.到可读文本 (YYJSON格式化选项.压缩))
        }
        // 防止重定向链: 已经是重定向的导航不再拦截, 避免 A→B→C→A 死循环
        如果 (是否重定向 == 假 && MCP命令服务器.是否Hook导航 && MCP命令服务器.导航拦截规则 != "")
        {
            如果 (目标地址 != "")
            {
                // 规则格式: action|url[|target] 每行一条
                变量 规则文本 <类型 = 文本数组类>
                分割文本 (MCP命令服务器.导航拦截规则, "\n", 规则文本, 真, 假)
                计次循环 (规则文本.取成员数 ())
                {
                    变量 行文本 <类型 = 文本型>
                    行文本 = 规则文本.取成员 (取循环索引 ())
                    如果 (行文本 == "")
                    {
                        到循环尾
                    }
                    变量 parts <类型 = 文本数组类>
                    分割文本 (行文本, "|", parts, 真, 假)
                    如果 (parts.取成员数 () >= 2)
                    {
                        变量 规则动作 <类型 = 文本型>
                        规则动作 = parts.取成员 (0)
                        变量 规则URL <类型 = 文本型>
                        规则URL = parts.取成员 (1)
                        变量 匹配位置 <类型 = 整数>
                        匹配位置 = 寻找文本 (目标地址, 规则URL, 0, 假)
                        如果 (匹配位置 != -1)
                        {
                            如果 (规则动作 == "block")
                            {
                                调试输出 ("[MCP] 导航拦截:", 目标地址)
                                返回 (真)
                            }
                            否则 (规则动作 == "redirect" && parts.取成员数 () >= 3)
                            {
                                变量 重定向目标 <类型 = 文本型>
                                重定向目标 = parts.取成员 (2)
                                调试输出 ("[MCP] 导航重定向:", 目标地址, "→", 重定向目标)
                                框架.载入地址 (重定向目标)
                                返回 (真)
                            }
                        }
                    }
                }
            }
        }
        返回 (假)  // 默认不拦截
    }
    # 弹窗自定义 — 参照 browser_event21.wsv: 浏览器_即将打开新窗口
    方法 浏览器_即将打开新窗口 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 弹窗ID <类型 = 整数>
    参数 地址 <类型 = 文本型>
    参数 目标框架名称 <类型 = 文本型>
    参数 目标类型 <类型 = 整数>
    参数 用户手势 <类型 = 逻辑型>
    参数 弹出功能 <类型 = FBrowser_弹出功能>
    参数 窗口信息 <类型 = FBrowser_窗口信息>
    参数 浏览器设置 <类型 = FBrowser_浏览器配置>
    参数 无JS访问 <类型 = 逻辑型类>
    参数 用户额外配置 <类型 = 类_FBrowser_用户额外配置>
    {
        变量 当前浏览器数 <类型 = 整数>
        当前浏览器数 = FBrowser_浏览器_取数量 ()
        如果 (当前浏览器数 >= MCP命令服务器.浏览器实例最大数量)
        {
            调试输出 ("[MCP] 弹窗已拒绝: 浏览器实例数=", 当前浏览器数, " 上限=", MCP命令服务器.浏览器实例最大数量, " url=", 地址)
            返回 (真)
        }
        如果 (MCP命令服务器.是否Hook弹窗 && MCP命令服务器.弹窗配置 != "")
        {
            变量 弹窗JSON <类型 = YYJSON只读对象类>
            如果 (弹窗JSON.创建自文本 (MCP命令服务器.弹窗配置))
            {
                变量 弹窗宽度 <类型 = 整数>
                弹窗宽度 = 弹窗JSON.取整数 ("width")
                变量 弹窗高度 <类型 = 整数>
                弹窗高度 = 弹窗JSON.取整数 ("height")
                如果 (弹窗宽度 > 0)
                {
                    窗口信息.宽度 = 弹窗宽度
                }
                如果 (弹窗高度 > 0)
                {
                    窗口信息.高度 = 弹窗高度
                }
                变量 弹窗X <类型 = 整数>
                弹窗X = 弹窗JSON.取整数 ("x")
                变量 弹窗Y <类型 = 整数>
                弹窗Y = 弹窗JSON.取整数 ("y")
                如果 (弹窗X != 0 || 弹窗Y != 0)
                {
                    窗口信息.横坐标 = 弹窗X
                    窗口信息.纵坐标 = 弹窗Y
                }
                调试输出 ("[MCP] 弹窗自定义:", 弹窗宽度, "x", 弹窗高度)
            }
        }
        如果 (MCP命令服务器.是否监控载入事件)
        {
            变量 弹窗数据 <类型 = YYJSON对象类>
            弹窗数据.创建自文本 ("{}")
            弹窗数据.加入文本成员 ("url", 地址)
            弹窗数据.加入整数成员 ("popup_id", 弹窗ID)
            弹窗数据.加入整数成员 ("width", 窗口信息.宽度)
            弹窗数据.加入整数成员 ("height", 窗口信息.高度)
            记录监控事件 (真, "popup", 浏览器.取ID (), 弹窗数据.到可读文本 (YYJSON格式化选项.压缩))
        }
        返回 (假)  // 不阻止弹窗
    }
