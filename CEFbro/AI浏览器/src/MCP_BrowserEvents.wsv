    方法 浏览器_查找返馈 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 ID <类型 = 整数>
    参数 数量 <类型 = 整数>
    参数 选择位置 <类型 = FBrowser_矩形位置>
    参数 顺序 <类型 = 整数>
    参数 最后更新 <类型 = 逻辑型>
    {
        如果 (MCP命令服务器.是否监控查找)
        {
            变量 查找数据 <类型 = YYJSON对象类>
            查找数据.创建自文本 ("{}")
            查找数据.加入整数成员 ("find_id", ID)
            查找数据.加入整数成员 ("match_count", 数量)
            查找数据.加入整数成员 ("active_match", 顺序)
            查找数据.加入逻辑值成员 ("final_update", 最后更新)
            记录监控事件 (真, "find_result", 浏览器.取ID (), 查找数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    # --- 框架生命周期 ---
    方法 浏览器_即将创建框架 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    {
        如果 (MCP命令服务器.是否监控框架)
        {
            变量 fc数据 <类型 = YYJSON对象类>
            fc数据.创建自文本 ("{}")
            fc数据.加入文本成员 ("name", 框架.取框架名 ())
            fc数据.加入文本成员 ("url", 框架.取地址 ())
            MCP命令服务器.记录浏览器事件 ("frame_created", 浏览器.取ID (), fc数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    方法 浏览器_即将拆离框架 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    {
        如果 (MCP命令服务器.是否监控框架)
        {
            变量 fd数据 <类型 = YYJSON对象类>
            fd数据.创建自文本 ("{}")
            fd数据.加入文本成员 ("name", 框架.取框架名 ())
            MCP命令服务器.记录浏览器事件 ("frame_detached", 浏览器.取ID (), fd数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    方法 浏览器_即将改变主框架 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 旧框架 <类型 = 类_FBrowser_框架>
    参数 新框架 <类型 = 类_FBrowser_框架>
    {
        如果 (MCP命令服务器.是否监控框架)
        {
            变量 mfc数据 <类型 = YYJSON对象类>
            mfc数据.创建自文本 ("{}")
            mfc数据.加入文本成员 ("old_url", 旧框架.取地址 ())
            mfc数据.加入文本成员 ("new_url", 新框架.取地址 ())
            MCP命令服务器.记录浏览器事件 ("main_frame_changed", 浏览器.取ID (), mfc数据.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    # --- 下载事件 ---
    方法 浏览器_可下载 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 地址 <类型 = 文本型>
    参数 请求方法 <类型 = 文本型>
    {
        如果 (MCP命令服务器.是否监控下载事件)
        {
            变量 dl数据 <类型 = YYJSON对象类>
            dl数据.创建自文本 ("{}")
            dl数据.加入文本成员 ("url", 地址)
            dl数据.加入文本成员 ("method", 请求方法)
            MCP命令服务器.记录浏览器事件 ("download_request", 浏览器.取ID (), dl数据.到可读文本 (YYJSON格式化选项.压缩))
        }
        返回 (假)  // 不阻止下载
    }
    # --- 键盘/焦点 ---
    方法 浏览器_按下某键 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 按键事件 <类型 = FBrowser_按键事件>
    参数 系统事件 <类型 = FBrowser_系统事件>
    参数 是否快捷键 <类型 = 逻辑型>
    {
        如果 (MCP命令服务器.是否监控键盘焦点)
        {
            变量 按键数据 <类型 = YYJSON对象类>
            按键数据.创建自文本 ("{}")
            按键数据.加入整数成员 ("key", 按键事件.系统按键)
            按键数据.加入逻辑值成员 ("shortcut", 是否快捷键)
            记录监控事件 (真, "key_press", 浏览器.取ID (), 按键数据.到可读文本 (YYJSON格式化选项.压缩))
        }
        返回 (假)
    }
    方法 浏览器_即将失去焦点 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 下一个 <类型 = 逻辑型>
    {
        如果 (MCP命令服务器.是否监控键盘焦点)
        {
            MCP命令服务器.记录浏览器事件 ("focus_lost", 浏览器.取ID (), "{}")
        }
    }
    方法 浏览器_收到焦点 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        如果 (MCP命令服务器.是否监控键盘焦点)
        {
            MCP命令服务器.记录浏览器事件 ("focus_gained", 浏览器.取ID (), "{}")
        }
    }
    方法 浏览器_加载进度被改变 <公开 注释 = "英文名：OnLoadingProgressChange 说明：在浏览器主进程中调用" @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 进度 <类型 = 整数>
    {
        如果 (MCP命令服务器.是否监控加载进度)
        {
            // 仅记录0/25/50/75/100里程碑事件, 减少缓存压力
            如果 (是否为里程碑进度 (进度))
            {
                变量 进度数据 <类型 = YYJSON对象类>
                进度数据.创建自文本 ("{}")
                进度数据.加入整数成员 ("progress", 进度)
                记录监控事件 (真, "load_progress", 浏览器.取ID (), 进度数据.到可读文本 (YYJSON格式化选项.压缩))
            }
        }
    }
    方法 浏览器_执行关闭 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        记录监控事件 (MCP命令服务器.是否监控生命周期, "do_close", 浏览器.取ID (), "{}")
        返回 (假)
    }
}
