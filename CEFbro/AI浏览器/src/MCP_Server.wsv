        判断循环 (浏览器容器.浏览器数组.取成员数 () > 0)
        {
            浏览器容器.浏览器数组.删除成员 (0)
        }
        浏览器数组锁.解锁 ()
        导航拦截规则 = ""
        资源替换规则 = ""
        是否Hook导航 = 假
        是否Hook资源 = 假
        是否Hook音频 = 假
        是否Hook弹窗 = 假
        音频指纹配置 = ""
        弹窗配置 = ""
        IP速率限制字典.创建 ()
        应用事件节流字典.创建 ()
        异步缓存锁.加锁 ()
        活动URL请求数 = 0
        最后URL请求槽释放时间 = 0
        URL请求槽满起始毫秒 = 0
        异步缓存锁.解锁 ()
        如果 (MCP服务器实例.是否为空 () == 假)
        {
            MCP服务器实例.关闭 ()
            MCP服务器实例.置空 ()
        }
        关闭缓存数据库 ()
        调试输出 ("[MCP] AI浏览器 MCP 服务器已关闭")
    }
    # ======== 空文本数组辅助 ==========
    方法 取空文本数组 <公开 静态 类型 = 文本数组类>
    {
        变量 arr <类型 = 文本数组类>
        返回 (arr)
    }
    # ======== CORS 跨域辅助 ==========
    变量 CORS响应头 <公开 静态 类型 = FBrowser_双文本数组>
    方法 初始化CORS响应头 <公开 静态>
    {
        如果 (CORS响应头.是否为空 () == 假)
        {
            返回
        }
        CORS响应头.创建 ()
        变量 h_Origin <类型 = FBrowser_双文本>
        变量 h_Methods <类型 = FBrowser_双文本>
        变量 h_Headers <类型 = FBrowser_双文本>
        h_Origin.name = "Access-Control-Allow-Origin"
        h_Origin.value = "*"
        h_Methods.name = "Access-Control-Allow-Methods"
        h_Methods.value = "GET, POST, OPTIONS"
        h_Headers.name = "Access-Control-Allow-Headers"
        h_Headers.value = "Content-Type, Authorization, Mcp-Session-Id"
        CORS响应头.加入成员 (h_Origin)
        CORS响应头.加入成员 (h_Methods)
        CORS响应头.加入成员 (h_Headers)
    }
    方法 发送CORS响应 <公开 静态>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    参数 状态码 <类型 = 整数>
    参数 内容类型 <类型 = 文本型>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        如果 (CORS响应头.是否为空 ())
        {
            初始化CORS响应头 ()
        }
        服务器.发送HttpResponse (连接ID, 状态码, 内容类型, 数据大小, CORS响应头)
        如果 (数据指针 != 0 && 数据大小 > 0)
        {
            服务器.发送原始数据 (连接ID, 数据指针, 数据大小)
        }
    }
    # 便捷封装 — 保持现有调用无需改参数
    方法 发送CORS200响应 <公开 静态>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    参数 内容类型 <类型 = 文本型>
    参数 数据指针 <类型 = 变整数>
    参数 数据大小 <类型 = 整数>
    {
        发送CORS响应 (服务器, 连接ID, 200, 内容类型, 数据指针, 数据大小)
    }
    方法 发送CORS404响应 <公开 静态>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    {
        发送CORS响应 (服务器, 连接ID, 404, HTTP_JSON内容类型, 0, 0)
    }
    方法 发送CORS404HTML响应 <公开 静态>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    参数 提示 <类型 = 文本型 @默认值 = "404 Not Found">
    {
        变量 body <类型 = 字节集类>
        body = 文本到UTF8 ("<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>404</title></head><body><h1>404</h1><p>" + 提示 + "</p></body></html>", 假)
        发送CORS响应 (服务器, 连接ID, 404, "text/html; charset=utf-8", 取字节集指针 (body), 取字节集长度 (body))
    }
    方法 发送CORS500响应 <公开 静态>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    参数 错误消息 <类型 = 文本型>
    {
        变量 errObj <类型 = YYJSON对象类>
        errObj.创建自文本 ("{}")
        errObj.加入文本成员 ("error", 错误消息)
        变量 errBody <类型 = 字节集类>
        errBody = 文本到UTF8 (errObj.到可读文本 (YYJSON格式化选项.压缩), 假)
        发送CORS响应 (服务器, 连接ID, 500, HTTP_JSON内容类型, 取字节集指针 (errBody), 取字节集长度 (errBody))
    }
    # ======== JSON 响应构建（yyjson值序列化 + 文本拼接外层） ==========
    # 注: yyjson 的 加入成员() 嵌套对象在此版本存在访问违例 (0xC0000005)
    # 故改用: yyjson构建扁平内层对象→序列化→火山文本拼接外包装
    方法 构建JSONRPC响应 <公开 静态 类型 = 文本型>
    参数 请求ID <类型 = 文本型>
    参数 结果JSON文本 <类型 = 文本型 @默认值 = "">
    参数 错误码 <类型 = 整数 @默认值 = 0>
    参数 错误消息 <类型 = 文本型 @默认值 = "">
    {
        变量 前缀 <类型 = 文本型>
        前缀 = 构建JSONRPC头部前缀 (请求ID)
        如果 (错误码 == 0)
        {
            // === 成功: 用yyjson注入_req_id, 然后文本级嵌入result ===
            变量 结果JSON <类型 = 文本型>
            如果 (结果JSON文本 != "")
            {
                变量 结果对象 <类型 = YYJSON对象类>
                如果 (结果对象.创建自文本 (结果JSON文本))
                {
                    如果 (紧凑响应模式 == 假 && 当前请求追踪ID != "")
                    {
                        结果对象.加入文本成员 ("_req_id", 当前请求追踪ID)
                    }
                    结果JSON = 结果对象.到可读文本 (YYJSON格式化选项.压缩)
                }
                否则
                {
                    变量 原始包装 <类型 = YYJSON对象类>
                    原始包装.创建自文本 ("{}")
                    原始包装.加入文本成员 ("_raw", 结果JSON文本)
                    结果JSON = 原始包装.到可读文本 (YYJSON格式化选项.压缩)
                }
            }
            否则
            {
                结果JSON = "{}"
            }
            返回 (前缀 + ",\"result\":" + 结果JSON + "}")
        }
        // === 错误: yyjson构建错误对象→序列化→文本拼接 ===
        变量 错误对象 <类型 = YYJSON对象类>
        错误对象.创建自文本 ("{}")
        错误对象.加入整数成员 ("code", 错误码)
        错误对象.加入文本成员 ("message", 错误消息)
        如果 (紧凑响应模式 == 假 && 当前请求追踪ID != "")
        {
            错误对象.加入文本成员 ("_req_id", 当前请求追踪ID)
        }
        返回 (前缀 + ",\"error\":" + 错误对象.到可读文本 (YYJSON格式化选项.压缩) + "}")
    }
    方法 构建简单JSON <公开 静态 类型 = 文本型>
    参数 键名 <类型 = 文本型>
    参数 键值 <类型 = 文本型>
    {
        // network_logs 值为 JSON 数组文本时嵌入为数组, 避免 "network_logs":"[]" 双重编码
        如果 (键名 == "network_logs" && 是否以 (键值, "["))
        {
            变量 头对象 <类型 = YYJSON对象类>
            头对象.创建自文本 ("{}")
            头对象.加入逻辑值成员 ("success", 真)
            变量 头JSON <类型 = 文本型>
            头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
            返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"network_logs\":" + 键值 + "}")
        }
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 (键名, 键值)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建双键JSON <公开 静态 类型 = 文本型>
    参数 键名1 <类型 = 文本型>
    参数 键值1 <类型 = 文本型>
    参数 键名2 <类型 = 文本型>
    参数 键值2 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 (键名1, 键值1)
        对象.加入文本成员 (键名2, 键值2)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== MCP JSON-RPC 入口处理 ==========
    方法 处理MCP请求 <公开 静态 类型 = 文本型>
    参数 请求体JSON <类型 = 文本型>
    参数 客户端地址 <类型 = 文本型 @默认值 = "">
    {
        如果 (MCP正在关闭 || 是否启用 == 假)
        {
            返回 (构建JSONRPC响应 ("", "", -32000, "MCP 服务正在关闭"))
        }
        紧凑响应模式 = 假  // 每个请求默认重置
        // === 速率限制检查 (按IP优先, 回退全局) ===
        如果 (检查IP速率限制 (客户端地址) == 假)
        {
            调试输出 ("[MCP] 速率限制触发, IP:", 客户端地址)
            返回 (构建JSONRPC响应 ("", "", -32029, "请求过于频繁, 速率限制:" + 到文本 (速率限制_每分钟) + "/min"))
        }
        请求计数器 = 请求计数器 + 1
        当前请求追踪ID = 到文本 (服务器启动时间戳) + "_" + 到文本 (请求计数器)
        变量 解析结果 <类型 = YYJSON只读对象类>
        如果 (解析结果.创建自文本 (请求体JSON) == 假)
        {
            变量 错误摘要 <类型 = 文本型>
            变量 体长度 <类型 = 整数>
            体长度 = 取文本长度 (请求体JSON)
            如果 (体长度 > 600)
            {
                // 显示前后各300字上下文,帮助定位JSON中的转义/语法错误
                错误摘要 = "JSON解析失败, 体长度=" + 到文本 (体长度) + ", 前300字: " + 取文本左边 (请求体JSON, 300) + " ... 末300字: " + 取文本右边 (请求体JSON, 300)
            }
            否则 (体长度 > 0)
            {
                错误摘要 = "JSON解析失败, 体长度=" + 到文本 (体长度) + ", 完整体: " + 请求体JSON
            }
            否则
            {
                错误摘要 = "JSON解析失败, 请求体为空"
            }
            调试输出 ("[MCP] " + 错误摘要 + " | _req_id=" + 当前请求追踪ID)
            返回 (构建JSONRPC响应 ("", "", -32700, 错误摘要))
        }
        如果 (解析结果.是否为空 ())
        {
            返回 (构建JSONRPC响应 ("", "", -32600, "无效请求"))
        }
        // 验证jsonrpc字段,拒绝非JSON-RPC 2.0消息
        变量 jsonrpc版本 <类型 = 文本型>
        jsonrpc版本 = yyjson取文本 (解析结果, "jsonrpc")
        如果 (jsonrpc版本 != "2.0")
        {
            返回 (构建JSONRPC响应 ("", "", -32600, "仅支持JSON-RPC 2.0"))
        }
        变量 方法名 <类型 = 文本型>
        方法名 = yyjson取文本 (解析结果, "method")
        变量 请求ID <类型 = 文本型>
        请求ID = yyjson取文本 (解析结果, "id")
        // === API密钥认证 ===
        变量 参数对象_认证 <类型 = YYJSON只读对象类>
        参数对象_认证 = 解析结果.取对象 ("params")
        如果 (是否启用认证 && 验证API密钥 (参数对象_认证) == 假)
        {
            调试输出 ("[MCP] API密钥认证失败")
            返回 (构建JSONRPC响应 (请求ID, "", -32001, "认证失败: API密钥无效, 请在params中提供_api_key"))
        }
        // 紧凑响应模式 — 减少token消耗, 跳过jsonrpc/_req_id/双层包裹
        变量 参数对象 <类型 = YYJSON只读对象类>
        参数对象 = 解析结果.取对象 ("params")
        如果 (参数对象.是否为空 () == 假)
        {
            紧凑响应模式 = 参数对象.取逻辑值 ("_compact")
        }
        否则
        {
            紧凑响应模式 = 假
        }
        // 用客户端ID信息优化追踪ID的可读性
        如果 (请求ID != "")
        {
            当前请求追踪ID = 到文本 (服务器启动时间戳) + "_" + 到文本 (请求计数器) + "_" + 请求ID
        }
        // JSON-RPC 2.0: 通知(无id字段)不返回响应
        变量 是通知 <类型 = 逻辑型>
        是通知 = 请求ID == ""
        如果 (方法名 == "")
        {
            如果 (是通知)
            {
                返回 ("")  // 通知不响应
            }
            返回 (构建JSONRPC响应 (请求ID, "", -32600, "缺少method"))
        }
        调试输出 ("[MCP] RPC方法:", 方法名)
        // --- MCP 协议方法 ---
        如果 (方法名 == "initialize")
        {
            返回 (处理_初始化 (请求ID, 解析结果))
        }
        否则 (方法名 == "notifications/initialized")
        {
            返回 ("")
        }
        否则 (方法名 == "tools/list")
        {
            返回 (处理_工具列表 (请求ID))
        }
        否则 (方法名 == "tools/call")
        {
            返回 (处理_工具调用 (请求ID, 解析结果))
        }
        // 直接的浏览器命令(方法名包含 browser || mcp)
        如果 (寻找文本 (方法名, "browser", , ) != -1 || 寻找文本 (方法名, "mcp", , ) != -1)
        {
            变量 直接参数 <类型 = YYJSON只读对象类>
            直接参数 = 解析结果.取对象 ("params")
            调试输出 ("[MCP] 直接命令:", 方法名)
            返回 (执行浏览器命令 (请求ID, 方法名, 直接参数))
        }
        返回 (构建JSONRPC响应 (请求ID, "", -32601, "未知方法: " + 方法名))
    }
    # ======== MCP initialize ==========
    方法 处理_初始化 <公开 静态 类型 = 文本型>
    参数 请求ID <类型 = 文本型>
    参数 请求JSON <类型 = YYJSON只读对象类>
    {
        变量 客户端名 <类型 = 文本型>
        变量 客户端版本 <类型 = 文本型>
        // clientInfo 在 params 内部 (符合 MCP 规范)
        变量 参数JSON <类型 = YYJSON只读对象类>
        参数JSON = 请求JSON.取对象 ("params")
        变量 客户端信息 <类型 = YYJSON只读对象类>
        如果 (参数JSON.是否为空 () == 假)
        {
            客户端信息 = 参数JSON.取对象 ("clientInfo")
            如果 (客户端信息.是否为空 () == 假)
            {
                客户端名 = 客户端信息.取文本 ("name")
                客户端版本 = 客户端信息.取文本 ("version")
            }
        }
        调试输出 ("[MCP] 初始化 — 客户端:", 客户端名)
        // 构建 capabilities
        变量 能力对象 <类型 = YYJSON对象类>
        能力对象.创建自文本 ("{}")
        变量 工具能力 <类型 = YYJSON对象类>
        工具能力.创建自文本 ("{}")
        能力对象.加入成员 ("tools", 工具能力)
        // 构建 serverInfo
        变量 服务器信息 <类型 = YYJSON对象类>
        服务器信息.创建自文本 ("{}")
        服务器信息.加入文本成员 ("name", MCP_服务器名)
        服务器信息.加入文本成员 ("version", MCP_版本号)
        // 构建 result
        变量 结果对象 <类型 = YYJSON对象类>
        结果对象.创建自文本 ("{}")
        结果对象.加入文本成员 ("protocolVersion", MCP_协议版本)
        结果对象.加入成员 ("capabilities", 能力对象)
        结果对象.加入成员 ("serverInfo", 服务器信息)
        返回 (构建JSONRPC响应 (请求ID, 结果对象.到可读文本 (YYJSON格式化选项.压缩)))
    }
    # ======== MCP tools/list ==========
    方法 处理_工具列表 <公开 静态 类型 = 文本型>
    参数 请求ID <类型 = 文本型>
    {
        // 使用缓存避免每次重建(工具列表不变)
        如果 (工具列表缓存 != "")
        {
            返回 (构建JSONRPC响应 (请求ID, 工具列表缓存))
        }
        开始构建工具列表 ()
        填充工具列表 ()
        变量 结果JSON <类型 = 文本型>
        结果JSON = "{\"tools\":" + 完成构建工具列表 () + "}"
        // 缓存结果JSON
        工具列表缓存 = 结果JSON
        调试输出 ("[MCP] tools/list 已缓存, 长度=", 取文本长度 (结果JSON))
        返回 (构建JSONRPC响应 (请求ID, 结果JSON))
    }
    # ======== 填充工具列表到数组 ==========
    方法 填充工具列表 <公开 静态>
    {
        // === 核心 API (精简版 — 每个能力唯一) ===
        添加工具JSON ("browser_navigate", "导航到指定URL", 单参数Schema文本 ("url", "text", "URL地址"))
        添加工具JSON ("browser_get_url", "获取当前页面URL")
        添加工具JSON ("browser_get_title", "获取页面标题(默认同步返回, async_only:true改异步)")
        添加工具JSON ("browser_back", "后退")
        添加工具JSON ("browser_forward", "前进")
        添加工具JSON ("browser_reload", "刷新页面", 单参数Schema文本 ("ignore_cache", "boolean", "忽略缓存", 假))
        添加工具JSON ("browser_stop", "停止加载")
        添加工具JSON ("browser_execute_js", "执行JS(无返回值)", 单参数Schema文本 ("code", "text", "JS代码"))
        添加工具JSON ("browser_evaluate", "执行JS并返回结果(默认同步, async_only:true改异步)", 单参数Schema文本 ("code", "text", "JS代码"))
        添加工具JSON ("browser_get_source", "获取HTML源码(默认异步, sync_wait:true可同步)", 单参数Schema文本 ("max_chars", "integer", "最大字符数(默认256KB=262144)", 假))
        添加工具JSON ("browser_get_text", "获取页面文本(selector非空时默认同步)", 单参数Schema文本 ("max_chars", "integer", "最大字符数(默认256KB)", 假))
        添加工具JSON ("browser_open_devtools", "打开开发者工具")
        添加工具JSON ("browser_close_devtools", "关闭开发者工具")
        添加工具JSON ("browser_create", "创建浏览器窗口 [已禁用: GUI自动管理]", 单参数Schema文本 ("url", "text", "URL", 假))
        添加工具JSON ("browser_create_background", "创建后台浏览器 [已禁用: GUI自动管理]", 单参数Schema文本 ("url", "text", "URL", 假))
        添加工具JSON ("browser_close", "关闭浏览器 [已禁用: GUI自动管理]", 单参数Schema文本 ("force", "boolean", "强制关闭", 假))
        添加工具JSON ("browser_close_try", "[已废弃] 远程关闭浏览器已禁用, 生命周期由GUI管理")
        添加工具JSON ("browser_list", "列出所有浏览器实例")
        添加工具JSON ("browser_set_zoom", "设置缩放", 单参数Schema文本 ("level", "text", "如1.0,1.5,0.8"))
        添加工具JSON ("browser_get_zoom", "获取缩放级别")
        添加工具JSON ("browser_find", "页面查找", 单参数Schema文本 ("text", "text", "查找内容"))
        添加工具JSON ("browser_stop_find", "停止查找")
