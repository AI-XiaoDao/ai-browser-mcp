    # ======== 事件日志 (SQLite) — v2.4 参数化 ==========
    方法 记录事件日志 <公开 静态>
    参数 日志类型 <类型 = 文本型>
    参数 事件名 <类型 = 文本型 @默认值 = "">
    参数 浏览器ID <类型 = 整数 @默认值 = 0>
    参数 数据JSON <类型 = 文本型>
    {
        如果 (缓存数据库可用 () == 假)
        {
            返回
        }
        变量 存储JSON <类型 = 文本型>
        存储JSON = 数据JSON
        如果 (取文本长度 (存储JSON) > 网络日志最大字节)
        {
            存储JSON = 取文本左边 (存储JSON, 网络日志最大字节) + "...[truncated]"
        }
        异步缓存锁.加锁 ()
        变量 stmt <类型 = SQLite记录集类>
        stmt = 缓存数据库.取记录集 ("INSERT INTO event_log (log_type, event_name, browser_id, data_json, created_at) VALUES (?, ?, ?, ?, ?)", )
        stmt.置文本参数数据 (1, 日志类型)
        stmt.置文本参数数据 (2, 事件名)
        stmt.置整数参数数据 (3, 浏览器ID)
        stmt.置文本参数数据 (4, 存储JSON)
        stmt.置长整数参数数据 (5, 取启动时间 ())
        stmt.执行语句 ()
        stmt.释放 ()
        修剪事件日志表_已持锁 ()
        异步缓存锁.解锁 ()
        // 每1000条清理一次
        变量 清理计数 <静态 类型 = 整数 值 = 0>
        清理计数 = 清理计数 + 1
        如果 (清理计数 >= 日志清理间隔)
        {
            清理计数 = 0
            清理过期缓存 ()
        }
    }
    # v2.4 参数化查询 — 动态WHERE条件通过条件构建+编号绑定, 彻底消除SQL注入风险
    方法 查询事件日志 <公开 静态 类型 = 文本型>
    参数 日志类型 <类型 = 文本型 @默认值 = "">
    参数 事件名 <类型 = 文本型 @默认值 = "">
    参数 浏览器ID <类型 = 整数 @默认值 = 0>
    参数 限制条数 <类型 = 整数 @默认值 = 100>
    {
        变量 result <类型 = 文本型>
        result = "["
        异步缓存锁.加锁 ()
        // 动态构建 WHERE 条件, 用 ? 占位, 计数绑定
        变量 条件SQL <类型 = 文本型>
        条件SQL = ""
        变量 paramIdx <类型 = 整数 值 = 0>
        变量 hasType <类型 = 逻辑型 值 = 假>
        变量 hasEvent <类型 = 逻辑型 值 = 假>
        变量 hasBID <类型 = 逻辑型 值 = 假>
        如果 (日志类型 != "")
        {
            paramIdx = paramIdx + 1
            条件SQL = 条件SQL + " AND log_type=?  "
            hasType = 真
        }
        如果 (事件名 != "")
        {
            paramIdx = paramIdx + 1
            条件SQL = 条件SQL + " AND event_name=?  "
            hasEvent = 真
        }
        如果 (浏览器ID > 0)
        {
            paramIdx = paramIdx + 1
            条件SQL = 条件SQL + " AND browser_id=?  "
            hasBID = 真
        }
        变量 sql <类型 = 文本型>
        sql = "SELECT data_json FROM event_log WHERE 1=1" + 条件SQL + "ORDER BY created_at DESC LIMIT ?  "
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 (sql, )
        paramIdx = 0
        如果 (hasType)
        {
            paramIdx = paramIdx + 1
            记录集.置文本参数数据 (paramIdx, 日志类型)
        }
        如果 (hasEvent)
        {
            paramIdx = paramIdx + 1
            记录集.置文本参数数据 (paramIdx, 事件名)
        }
        如果 (hasBID)
        {
            paramIdx = paramIdx + 1
            记录集.置整数参数数据 (paramIdx, 浏览器ID)
        }
        记录集.置整数参数数据 (paramIdx + 1, 限制条数)
        变量 first <类型 = 逻辑型 值 = 真>
        循环判断首 ()
        {
            变量 rc <类型 = 整数>
            rc = 记录集.执行语句 ()
            如果 (rc != 100)  // 非 SQLITE_ROW
            {
                跳出循环
            }
            如果 (first)
            {
                first = 假
            }
            否则
            {
                result = result + ","
            }
            result = result + 记录集.读文本数据 (0)
        }
        循环判断尾 (真)
        记录集.释放 ()
        异步缓存锁.解锁 ()
        result = result + "]"
        返回 (result)
    }
    方法 查询网络日志 <公开 静态 类型 = 文本型>
    参数 限制条数 <类型 = 整数 @默认值 = 500>
    {
        变量 result <类型 = 文本型>
        result = "["
        异步缓存锁.加锁 ()
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT data_json FROM event_log WHERE log_type IN ('network','network_detail') ORDER BY created_at DESC LIMIT ?  ", )
        记录集.置整数参数数据 (1, 限制条数)
        变量 first <类型 = 逻辑型 值 = 真>
        循环判断首 ()
        {
            变量 rc <类型 = 整数>
            rc = 记录集.执行语句 ()
            如果 (rc != 100)
            {
                跳出循环
            }
            如果 (first)
            {
                first = 假
            }
            否则
            {
                result = result + ","
            }
            result = result + 记录集.读文本数据 (0)
        }
        循环判断尾 (真)
        记录集.释放 ()
        异步缓存锁.解锁 ()
        result = result + "]"
        返回 (result)
    }
    方法 统计网络日志条数 <公开 静态 类型 = 整数>
    {
        如果 (缓存数据库可用 () == 假)
        {
            返回 (0)
        }
        变量 总数 <类型 = 整数 值 = 0>
        异步缓存锁.加锁 ()
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT COUNT(*) FROM event_log WHERE log_type IN ('network','network_detail')", )
        如果 (记录集.执行语句 () == 100)
        {
            总数 = 记录集.读整数数据 (0)
        }
        记录集.释放 ()
        异步缓存锁.解锁 ()
        返回 (总数)
    }
    方法 构建网络日志数据JSON <公开 静态 类型 = 文本型>
    参数 限制条数 <类型 = 整数 @默认值 = 500>
    {
        变量 日志数组 <类型 = 文本型>
        日志数组 = 查询网络日志 (限制条数)
        变量 条数 <类型 = 整数>
        条数 = 统计网络日志条数 ()
        变量 头对象 <类型 = YYJSON对象类>
        头对象.创建自文本 ("{}")
        头对象.加入逻辑值成员 ("network_enabled", 是否记录网络)
        头对象.加入逻辑值成员 ("network_detail", 是否详细记录网络)
        头对象.加入整数成员 ("count", 条数)
        如果 (条数 == 0)
        {
            如果 (是否记录网络 == 假)
            {
                头对象.加入文本成员 ("hint", "网络日志未启用; 请 action=enable 或 config enable_network_log=true, navigate 后再 list")
            }
            否则
            {
                头对象.加入文本成员 ("hint", "尚无记录; 仅记录 enable 之后的新请求, 磁盘缓存命中可能无 req/res")
            }
        }
        变量 头JSON <类型 = 文本型>
        头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
        返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"network_logs\":" + 日志数组 + "}")
    }
    方法 分派网络日志命令 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 action <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        如果 (action == "enable" || action == "network_enable")
        {
            是否记录网络 = 真
            是否详细记录网络 = 假
            返回 (命令成功 (命令ID, "网络日志已启用(基础模式)"))
        }
        如果 (action == "detail_enable" || action == "network_detail_enable")
        {
            是否记录网络 = 真
            是否详细记录网络 = 真
            返回 (命令成功 (命令ID, "网络日志已启用(详细模式)"))
        }
        如果 (action == "disable" || action == "network_disable")
        {
            是否记录网络 = 假
            是否详细记录网络 = 假
            返回 (命令成功 (命令ID, "网络日志已禁用"))
        }
        如果 (action == "clear" || action == "network_clear")
        {
            执行SQL ("DELETE FROM event_log WHERE log_type='network' OR log_type='network_detail'")
            返回 (命令成功 (命令ID, "已清空"))
        }
        如果 (action == "list" || action == "get" || action == "network_get")
        {
            如果 (是否记录网络 == 假 && yyjson取逻辑 (参数JSON, "auto_enable") != 假)
            {
                是否记录网络 = 真
            }
            变量 限制 <类型 = 整数>
            限制 = yyjson取整数 (参数JSON, "limit")
            如果 (限制 <= 0)
            {
                限制 = 500
            }
            返回 (命令成功_原始JSON (命令ID, 构建网络日志数据JSON (限制)))
        }
        返回 (命令失败 (命令ID, "未知action: " + action + " | 支持: list/get/enable/disable/clear/detail_enable (别名 network_*)"))
    }
    # ======== 缓存清理 — v2.4 参数化 ==========
    方法 清理滞留等待任务_已持锁 <公开 静态 注释 = "调用方须已持有 异步缓存锁">
    {
        变量 等待截止 <类型 = 长整数>
        等待截止 = 取启动时间 () - 等待任务最大滞留毫秒
        缓存数据库.执行SQL语句 ("DELETE FROM async_results WHERE is_waiting=1 AND created_at<" + 到文本 (等待截止), )
    }
    方法 修剪异步结果表_已持锁 <公开 静态 注释 = "调用方须已持有 异步缓存锁">
    {
        清理滞留等待任务_已持锁 ()
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT COUNT(*) FROM async_results", )
        如果 (记录集.执行语句 () == 100)
        {
            变量 总数 <类型 = 整数>
            总数 = 记录集.读整数数据 (0)
            如果 (总数 > 缓存最大条目)
            {
                变量 删除数 <类型 = 整数>
                删除数 = 总数 - 缓存最大条目 + 缓存清理_保留缓冲
                缓存数据库.执行SQL语句 ("DELETE FROM async_results WHERE task_id IN (SELECT task_id FROM async_results WHERE is_waiting=0 ORDER BY created_at ASC LIMIT " + 到文本 (删除数) + ")", )
                变量 仍超限 <类型 = 整数>
                仍超限 = 总数 - 删除数
                如果 (仍超限 > 缓存最大条目)
                {
                    变量 强制删除数 <类型 = 整数>
                    强制删除数 = 仍超限 - 缓存最大条目 + 缓存清理_保留缓冲
                    缓存数据库.执行SQL语句 ("DELETE FROM async_results WHERE task_id IN (SELECT task_id FROM async_results ORDER BY created_at ASC LIMIT " + 到文本 (强制删除数) + ")", )
                }
            }
        }
        记录集.释放 ()
    }
    方法 修剪事件日志表_已持锁 <公开 静态 注释 = "调用方须已持有 异步缓存锁">
    {
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT COUNT(*) FROM event_log", )
        如果 (记录集.执行语句 () == 100)
        {
            变量 总数 <类型 = 整数>
            总数 = 记录集.读整数数据 (0)
            如果 (总数 > 事件日志最大条目)
            {
                变量 删除数 <类型 = 整数>
                删除数 = 总数 - 事件日志最大条目 + 缓存清理_保留缓冲
                缓存数据库.执行SQL语句 ("DELETE FROM event_log WHERE id IN (SELECT id FROM event_log ORDER BY created_at ASC LIMIT " + 到文本 (删除数) + ")", )
            }
        }
        记录集.释放 ()
    }
    方法 修剪响应缓存表_已持锁 <公开 静态 注释 = "调用方须已持有 异步缓存锁">
    {
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT COUNT(*) FROM response_cache", )
        如果 (记录集.执行语句 () == 100)
        {
            变量 总数 <类型 = 整数>
            总数 = 记录集.读整数数据 (0)
            如果 (总数 > 响应缓存最大条目)
            {
                变量 删除数 <类型 = 整数>
                删除数 = 总数 - 响应缓存最大条目 + 缓存清理_保留缓冲
                缓存数据库.执行SQL语句 ("DELETE FROM response_cache WHERE url IN (SELECT url FROM response_cache ORDER BY created_at ASC LIMIT " + 到文本 (删除数) + ")", )
            }
        }
        记录集.释放 ()
    }
    方法 清理过期缓存 <公开 静态>
    {
        变量 过期时间 <类型 = 长整数>
        过期时间 = 取启动时间 () - 缓存保留天数 * 毫秒_每天
        异步缓存锁.加锁 ()
        执行参数化DELETE ("DELETE FROM async_results WHERE is_waiting=0 AND created_at<?", 到文本 (过期时间))
        变量 短TTL截止 <类型 = 长整数>
        短TTL截止 = 取启动时间 () - 异步结果非等待保留毫秒
        缓存数据库.执行SQL语句 ("DELETE FROM async_results WHERE is_waiting=0 AND created_at<" + 到文本 (短TTL截止), )
        清理滞留等待任务_已持锁 ()
        修剪异步结果表_已持锁 ()
        执行参数化DELETE ("DELETE FROM event_log WHERE created_at<?", 到文本 (过期时间))
        修剪事件日志表_已持锁 ()
        执行参数化DELETE ("DELETE FROM response_cache WHERE created_at<?", 到文本 (过期时间))
        修剪响应缓存表_已持锁 ()
        异步缓存锁.解锁 ()
    }
    # ======== SQL 辅助 (v2.4: 全部用户数据写入已改为参数化查询) ==========
    # 保留: 仅用于无参数的DDL/CREATE/PRAGMA
    # 所有含用户数据的SQL请使用 执行参数化INSERT / 取记录集+置参数 模式
    方法 执行SQL <公开 静态>
    参数 sql <类型 = 文本型>
    {
        异步缓存锁.加锁 ()
        缓存数据库.执行SQL语句 (sql, )
        异步缓存锁.解锁 ()
    }
    # ======== 响应缓存 (SQLite) — v2.4 修复 ?, 参数化+hex编码body ==========
    方法 存储响应缓存 <公开 静态>
    参数 url <类型 = 文本型>
    参数 mime <类型 = 文本型>
    参数 body <类型 = 字节集类>
    参数 size <类型 = 整数>
    {
        如果 (缓存数据库可用 () == 假)
        {
            返回
        }
        如果 (size <= 0 || size > 响应缓存单条最大字节)
        {
            返回
        }
        异步缓存锁.加锁 ()
        变量 当前时间 <类型 = 长整数>
        当前时间 = 取启动时间 ()
        // body转hex, 避免blob绑定API限制; hex仅含[0-9a-fA-F], 校验后再拼接
        变量 hexBody <类型 = 文本型>
        hexBody = 字节集到十六进制文本 (body)
        // 安全校验: hexBody仅允许[0-9a-fA-F], 非hex字符视为数据异常, 拒绝写入
        变量 hexValid <类型 = 逻辑型 值 = 真>
        变量 hexLen <类型 = 整数>
        hexLen = 取文本长度 (hexBody)
        如果 (hexLen == 0 || (hexLen % 2) != 0)
        {
            hexValid = 假
        }
        否则
        {
            变量 hexAlphabet <类型 = 文本型 值 = "0123456789ABCDEFabcdef">
            变量 hi <类型 = 整数>
            计次循环 (hexLen)
            {
                hi = 取循环索引 ()
                变量 hc <类型 = 文本型>
                hc = 取文本中间 (hexBody, hi + 1, 1)
                如果 (寻找文本 (hexAlphabet, hc, 0, 假) == -1)
                {
                    hexValid = 假
                    跳出循环
                }
            }
        }
        如果 (hexValid == 假)
        {
            调试输出 ("[MCP] 警告: response_cache body hex校验失败, 拒绝写入 url=", url, " hexLen=", hexLen)
            异步缓存锁.解锁 ()
            返回
        }
        变量 stmt <类型 = SQLite记录集类>
        stmt = 缓存数据库.取记录集 ("INSERT OR REPLACE INTO response_cache (url, mime_type, body, size, created_at) VALUES (?, ?, x'" + hexBody + "', ?, ?)", )
        stmt.置文本参数数据 (1, url)
        stmt.置文本参数数据 (2, mime)
        stmt.置整数参数数据 (3, size)
        stmt.置长整数参数数据 (4, 当前时间)
        stmt.执行语句 ()
        stmt.释放 ()
        修剪响应缓存表_已持锁 ()
        异步缓存锁.解锁 ()
    }
    # ======== 异步JS执行 (非阻塞) ==========
    方法 异步执行JS <公开 静态 类型 = 文本型>
    参数 browser <类型 = 类_FBrowser_浏览器>
    参数 code <类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    {
        变量 安全框架 <类型 = 类_FBrowser_框架>
        安全框架 = 取安全主框架 (browser)
        如果 (安全框架.是否为空 () || 安全框架.是否有效 () == 假)
        {
            存储异步结果 (任务ID, 构建标准失败JSON (错误_主框架无效))
            返回 (任务ID)
        }
        // 直接传入JS代码, FBrowser V8 引擎原生执行, 无需 eval() 包装
        变量 JS回调 <类型 = 类_FBrowser_事件智能指针>
        JS回调.创建 (类_MCP_JS异步回调)
        JS回调.取执行类 (类_MCP_JS异步回调).任务ID = 任务ID
        安全框架.执行JS代码_带返回值 (code, , , JS回调)
        返回 (任务ID)
    }
