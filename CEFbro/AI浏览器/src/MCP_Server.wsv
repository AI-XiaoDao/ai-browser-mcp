    }
    # ======== Schema 构建辅助 (纯文本拼接 — 规避 yyjson 嵌套崩溃, 见 L6) ==========
    # L6: YYJSON对象类.加入成员/加入数组成员 嵌套多层会触发 0xC0000005,
    #      工具列表/MCP响应一律用 文本拼接 + 构建任务查询结果JSON 等 helper.
    # 所有函数返回 JSON 文本片段, 由 填充工具列表() 组装为最终数组
    变量 工具列表构建缓冲区 <公开 静态 类型 = 文本型 值 = "">
    方法 开始构建工具列表 <公开 静态>
    {
        工具列表构建缓冲区 = "["
    }
    方法 添加工具JSON <公开 静态>
    参数 名称 <类型 = 文本型>
    参数 描述 <类型 = 文本型>
    参数 schemaJSON <类型 = 文本型 @默认值 = "\"inputSchema\":{\"type\":\"object\"}">
    {
        如果 (工具列表构建缓冲区 != "[")
        {
            工具列表构建缓冲区 = 工具列表构建缓冲区 + ","
        }
        工具列表构建缓冲区 = 工具列表构建缓冲区 + "{\"name\":\"" + 名称 + "\",\"description\":\"" + 描述 + "\"," + schemaJSON + "}"
    }
    方法 完成构建工具列表 <公开 静态 类型 = 文本型>
    {
        工具列表构建缓冲区 = 工具列表构建缓冲区 + "]"
        返回 (工具列表构建缓冲区)
    }
    方法 空Schema文本 <公开 静态 类型 = 文本型>
    {
        返回 ("\"inputSchema\":{\"type\":\"object\"}")
    }
    方法 单参数Schema文本 <公开 静态 类型 = 文本型>
    参数 名 <类型 = 文本型>
    参数 类型 <类型 = 文本型>
    参数 描述 <类型 = 文本型>
    参数 必须 <类型 = 逻辑型 @默认值 = 真>
    {
        变量 s <类型 = 文本型>
        s = "\"inputSchema\":{\"type\":\"object\",\"properties\":{\"" + 名 + "\":{\"type\":\"" + 类型 + "\",\"description\":\"" + 描述 + "\"}}"
        如果 (必须)
        {
            s = s + ",\"required\":[\"" + 名 + "\"]"
        }
        s = s + "}"
        返回 (s)
    }
    方法 双XY_Schema文本 <公开 静态 类型 = 文本型>
    参数 名1 <类型 = 文本型>
    参数 名2 <类型 = 文本型>
    参数 描述1 <类型 = 文本型>
    参数 描述2 <类型 = 文本型>
    {
        返回 ("\"inputSchema\":{\"type\":\"object\",\"properties\":{\"" + 名1 + "\":{\"type\":\"integer\",\"description\":\"" + 描述1 + "\"},\"" + 名2 + "\":{\"type\":\"integer\",\"description\":\"" + 描述2 + "\"}},\"required\":[\"" + 名1 + "\",\"" + 名2 + "\"]}")
    }
    方法 多属性Schema文本 <公开 静态 类型 = 文本型>
    参数 属性列表文本 <类型 = 文本型>
    参数 必需列表文本 <类型 = 文本型 @默认值 = "">
    {
        变量 s <类型 = 文本型>
        s = "\"inputSchema\":{\"type\":\"object\",\"properties\":{" + 属性列表文本 + "}"
        如果 (必需列表文本 != "")
        {
            s = s + ",\"required\":[" + 必需列表文本 + "]"
        }
        s = s + "}"
        返回 (s)
    }
    方法 属性项JSON <公开 静态 类型 = 文本型>
    参数 名 <类型 = 文本型>
    参数 类型 <类型 = 文本型>
    参数 描述 <类型 = 文本型>
    {
        返回 ("\"" + 名 + "\":{\"type\":\"" + 类型 + "\",\"description\":\"" + 描述 + "\"}")
    }
    # ======== MCP tools/call ==========
    方法 处理_工具调用 <公开 静态 类型 = 文本型>
    参数 请求ID <类型 = 文本型>
    参数 请求JSON <类型 = YYJSON只读对象类>
    {
        变量 参数对象 <类型 = YYJSON只读对象类>
        参数对象 = 请求JSON.取对象 ("params")
        变量 工具名 <类型 = 文本型>
        工具名 = ""
        如果 (参数对象.是否为空 () == 假)
        {
            工具名 = 参数对象.取文本 ("name")
        }
        调试输出 ("[MCP] 调用工具:", 工具名)
        // 提取 arguments (兼容 JSON 字符串 — 字符串优先于空 object)
        变量 工具参数字典 <类型 = YYJSON只读对象类>
        如果 (参数对象.是否为空 () == 假)
        {
            变量 参数字符串 <类型 = 文本型>
            参数字符串 = yyjson取JSON文本 (参数对象, "arguments")
            如果 (参数字符串 == "")
            {
                参数字符串 = yyjson取文本 (参数对象, "arguments")
            }
            如果 (参数字符串 != "" && (是否以 (参数字符串, "{") || 是否以 (参数字符串, "[")))
            {
                工具参数字典.创建自文本 (参数字符串)
            }
            否则
            {
                工具参数字典 = 参数对象.取对象 ("arguments")
            }
        }
        // 执行命令
        变量 命令结果JSON <类型 = 文本型>
        命令结果JSON = 执行浏览器命令 (请求ID, 工具名, 工具参数字典)
        命令结果JSON = 尝试同步跟随异步响应 (请求ID, 命令结果JSON, 工具名, 工具参数字典, 假)
        // 存储结果供异步查询
        存储任务结果 (请求ID, 命令结果JSON)
        // 解析命令结果,提取 content
        变量 结果解析 <类型 = YYJSON只读对象类>
        如果 (结果解析.创建自文本 (命令结果JSON) == 假)
        {
            返回 (构建JSONRPC响应 (请求ID, "", -32603, "结果解析失败"))
        }
        变量 是否成功 <类型 = 逻辑型>
        是否成功 = 结果解析.取逻辑值 ("success")
        // 异步结果: 将 _req_id 映射为 task_id, 确保客户端可用 _req_id 轮询 mcp_result
        变量 是否异步 <类型 = 逻辑型>
        是否异步 = 结果解析.取逻辑值 ("_async")
        变量 异步任务ID <类型 = 文本型>
        异步任务ID = ""
        如果 (是否异步)
        {
            异步任务ID = yyjson取文本 (结果解析, "task_id")
            如果 (异步任务ID != "")
            {
                当前请求追踪ID = 异步任务ID
            }
        }
        变量 内容文本 <类型 = 文本型>
        如果 (是否成功 == 假)
        {
            内容文本 = yyjson取文本 (结果解析, "error")
            如果 (内容文本 == "")
            {
                变量 failDataObj <类型 = YYJSON只读对象类>
                failDataObj = 结果解析.取对象 ("data")
                如果 (failDataObj.是否为空 () == 假)
                {
                    内容文本 = failDataObj.到可读文本 (YYJSON格式化选项.压缩)
                }
            }
            如果 (内容文本 == "")
            {
                内容文本 = "未知错误"
            }
        }
        否则
        {
            内容文本 = yyjson取文本 (结果解析, "message")
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "url")
            }
            如果 (内容文本 == "")
            {
                // 优先取文本型result,若是对象/数组/数字则取JSON原文
                内容文本 = yyjson取文本 (结果解析, "result")
                如果 (内容文本 == "")
                {
                    // result字段可能是原始JSON对象(如console_eval),转为可读文本
                    变量 resultObj <类型 = YYJSON只读对象类>
                    resultObj = 结果解析.取对象 ("result")
                    如果 (resultObj.是否为空 () == 假)
                    {
                        内容文本 = resultObj.到可读文本 (YYJSON格式化选项.压缩)
                    }
                }
                如果 (内容文本 == "")
                {
                    变量 resultArr <类型 = YYJSON只读数组类>
                    resultArr = 结果解析.取数组 ("result")
                    如果 (resultArr.是否为空对象 () == 假)
                    {
                        内容文本 = resultArr.到可读文本 (YYJSON格式化选项.压缩)
                    }
                }
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "data")
                // data是对象/数组时无法取文本, 转为完整JSON字符串
                如果 (内容文本 == "")
                {
                    变量 dataObj <类型 = YYJSON只读对象类>
                    dataObj = 结果解析.取对象 ("data")
                    如果 (dataObj.是否为空 () == 假)
                    {
                        内容文本 = dataObj.到可读文本 (YYJSON格式化选项.压缩)
                    }
                }
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "title")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "source")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "text")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "cookies")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "browsers")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "html")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "frames")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "names")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "exists")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "value")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "help")
            }
            如果 (内容文本 == "")
            {
                变量 netLogsText <类型 = 文本型>
                netLogsText = yyjson取文本 (结果解析, "network_logs")
                如果 (netLogsText != "" && 是否以 (netLogsText, "["))
                {
                    内容文本 = 命令结果JSON
                }
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "network_logs")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "console_logs")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "fbro_version")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "zoom_level")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "hwnd")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "loading")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "muted")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "id")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "count")
            }
            如果 (内容文本 == "")
            {
                内容文本 = yyjson取文本 (结果解析, "can_go_back")
            }
            如果 (内容文本 == "")
            {
                // 所有文本字段均未命中: 直接将完整命令结果序列化为 content, 避免数据丢失
                内容文本 = 命令结果JSON
            }
        }
        // 异步工具: 在内容文本中附带task_id, 方便MCP客户端用mcp_result查询
        如果 (是否异步 && 异步任务ID != "")
        {
            内容文本 = 内容文本 + "\n\n[task_id: " + 异步任务ID + "]"
        }
        // 构建 MCP content response
        变量 内容数组 <类型 = YYJSON数组类>
        内容数组.创建自文本数据 (取空文本数组 ())
        变量 内容项 <类型 = YYJSON对象类>
        内容项.创建自文本 ("{}")
        内容项.加入文本成员 ("type", "text")
        内容项.加入文本成员 ("text", 内容文本)
        内容数组.加入成员 (内容项)
        变量 结果对象 <类型 = YYJSON对象类>
        结果对象.创建自文本 ("{}")
        结果对象.加入数组成员 ("content", 内容数组)
        如果 (是否成功 == 假)
        {
            结果对象.加入逻辑值成员 ("isError", 真)
        }
        返回 (构建JSONRPC响应 (请求ID, 结果对象.到可读文本 (YYJSON格式化选项.压缩)))
    }
    # ======== 命令执行核心 ==========
    方法 执行浏览器命令 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        MCP执行锁.加锁 ()
        当前命令方法名 = 方法名
        当前命令参数JSON = 参数JSON
        调试输出 ("[MCP] 执行:", 方法名)
        变量 请求浏览器ID <类型 = 整数>
        变量 保存浏览器ID <类型 = 整数>
        请求浏览器ID = yyjson取整数 (参数JSON, "browser_id")
        保存浏览器ID = 目标浏览器ID
        目标浏览器ID = 请求浏览器ID
        // === 五段分类分派: 核心 → 填表 → VIP → 系统 → 编排 ===
        变量 result <类型 = 文本型>
        result = MCP_核心分派.分类分派_核心操作 (命令ID, 方法名, 参数JSON)
        如果 (result != "")
        {
            目标浏览器ID = 保存浏览器ID
            MCP执行锁.解锁 ()
            返回 (result)
        }
        result = MCP_填表分派.分类分派_填表操作 (命令ID, 方法名, 参数JSON)
        如果 (result != "")
        {
            目标浏览器ID = 保存浏览器ID
            MCP执行锁.解锁 ()
            返回 (result)
        }
        result = MCP_VIP分派.分类分派_VIP操作 (命令ID, 方法名, 参数JSON)
        如果 (result != "")
        {
            目标浏览器ID = 保存浏览器ID
            MCP执行锁.解锁 ()
            返回 (result)
        }
        result = MCP_系统分派.分类分派_系统操作 (命令ID, 方法名, 参数JSON)
        如果 (result != "")
        {
            目标浏览器ID = 保存浏览器ID
            MCP执行锁.解锁 ()
            返回 (result)
        }
        result = MCP_编排分派.分类分派_编排操作 (命令ID, 方法名, 参数JSON)
        如果 (result != "")
        {
            目标浏览器ID = 保存浏览器ID
            MCP执行锁.解锁 ()
            返回 (result)
        }
        // 快捷别名回退 (不递归, 避免 MCP执行锁 重入)
        如果 (是否以 (方法名, "browser_") == 假)
        {
            变量 短名映射 <类型 = 文本型>
            短名映射 = 取短名映射 (方法名)
            如果 (短名映射 != "" && 短名映射 != 方法名)
            {
                调试输出 ("[MCP] 别名映射: " + 方法名 + " → " + 短名映射)
                result = MCP_核心分派.分类分派_核心操作 (命令ID, 短名映射, 参数JSON)
                如果 (result == "")
                {
                    result = MCP_填表分派.分类分派_填表操作 (命令ID, 短名映射, 参数JSON)
                }
                如果 (result == "")
                {
                    result = MCP_VIP分派.分类分派_VIP操作 (命令ID, 短名映射, 参数JSON)
                }
                如果 (result == "")
                {
                    result = MCP_系统分派.分类分派_系统操作 (命令ID, 短名映射, 参数JSON)
                }
                如果 (result == "")
                {
                    result = MCP_编排分派.分类分派_编排操作 (命令ID, 短名映射, 参数JSON)
                }
                目标浏览器ID = 保存浏览器ID
                MCP执行锁.解锁 ()
                返回 (result)
            }
        }
        目标浏览器ID = 保存浏览器ID
        MCP执行锁.解锁 ()
        返回 (命令失败 (命令ID, "未知命令: " + 方法名 + " | 用 mcp_help 查看可用命令"))
    }
    # ======== 命令响应辅助（yyjson构建） ==========
    方法 命令成功 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 命令失败 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 假)
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== 异步任务结果提取 ==========
    # 提交异步JS任务/取源码/取文本 返回 {"_async":true,"task_id":"xxx"}
    # 本方法检测此格式并返回 命令成功_异步()
    方法 包装异步提交结果 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 异步返回值 <类型 = 文本型>
    参数 键名 <类型 = 文本型 @默认值 = "result">
    参数 成功消息 <类型 = 文本型 @默认值 = "已提交, 通过mcp_result查询结果">
    {
        // 检测提交错误 (如 frame_invalid), 直接返回失败不包装
        如果 (是否以 (异步返回值, "{\"error\":"))
        {
            变量 错误解析 <类型 = YYJSON只读对象类>
            如果 (错误解析.创建自文本 (异步返回值))
            {
                变量 错误文本 <类型 = 文本型>
                错误文本 = 错误解析.取文本 ("error")
                返回 (命令失败 (命令ID, 错误文本))
            }
            返回 (命令失败 (命令ID, 异步返回值))
        }
        // 检测自动异步切换标记
        如果 (是否以 (异步返回值, "{\"_async\":"))
        {
            变量 异步解析 <类型 = YYJSON只读对象类>
            如果 (异步解析.创建自文本 (异步返回值))
            {
                变量 taskID <类型 = 文本型>
                taskID = 异步解析.取文本 ("task_id")
                如果 (taskID != "")
                {
                    返回 (命令成功_异步 (命令ID, taskID, 成功消息))
                }
            }
        }
        // 正常结果 (非异步标记)
        返回 (构建简单JSON (键名, 异步返回值))
    }
    # ======== 短名别名映射表 ==========
    方法 取短名映射 <公开 静态 类型 = 文本型>
    参数 短名 <类型 = 文本型>
    {
        // 已带 browser_ 前缀的完整名不需要映射
        如果 (是否以 (短名, "browser_"))
        {
            返回 ("")
        }
        // 无前缀命令 (ping/batch/aliases/mcp_*) 直接返回原短名
        如果 (短名 == "ping" || 短名 == "batch" || 短名 == "aliases" || 是否以 (短名, "mcp_"))
        {
            返回 (短名)
        }
        // 优先用命令注册表查找 (O(1) 字典)
        变量 注册ID <类型 = 整数>
        注册ID = 查找命令ID (短名)
        如果 (注册ID != 0)
        {
            返回 ("browser_" + 短名)
        }
        返回 ("")
    }
    # ======== HTTP 路径与 API 元信息 ==========
    方法 提取HTTP路径 <公开 静态 类型 = 文本型>
    参数 请求地址 <类型 = 文本型>
    {
        变量 URL路径 <类型 = 文本型>
        变量 协议位置 <类型 = 整数>
        协议位置 = 寻找文本 (请求地址, "://", , 假)
        如果 (协议位置 > 0)
        {
            变量 协议后起始 <类型 = 整数>
            协议后起始 = 协议位置 + 3
            变量 主机后文本 <类型 = 文本型>
            主机后文本 = 取文本中间 (请求地址, 协议后起始, 取文本长度 (请求地址) - 协议后起始 + 1)
            变量 路径起始 <类型 = 整数>
            路径起始 = 寻找文本 (主机后文本, "/", , 假)
            如果 (路径起始 > 0)
            {
                URL路径 = 取文本中间 (主机后文本, 路径起始 + 1, 取文本长度 (主机后文本) - 路径起始)
                URL路径 = "/" + URL路径
            }
            否则
            {
                URL路径 = "/"
            }
        }
        否则
        {
            URL路径 = 请求地址
            如果 (URL路径 == "")
            {
                URL路径 = "/"
            }
            如果 (取文本左边 (URL路径, 1) != "/")
            {
                URL路径 = "/" + URL路径
            }
        }
        变量 queryPos <类型 = 整数>
        queryPos = 寻找文本 (URL路径, "?", , 假)
        如果 (queryPos > 0)
        {
            URL路径 = 取文本左边 (URL路径, queryPos - 1)
        }
        变量 hashPos <类型 = 整数>
        hashPos = 寻找文本 (URL路径, "#", , 假)
        如果 (hashPos > 0)
        {
            URL路径 = 取文本左边 (URL路径, hashPos - 1)
        }
        返回 (URL路径)
    }
    方法 构建API元信息JSON <公开 静态 类型 = 文本型>
    {
        变量 信息JSON <类型 = YYJSON对象类>
        信息JSON.创建自文本 ("{}")
        信息JSON.加入文本成员 ("server", MCP_服务器名)
        信息JSON.加入文本成员 ("version", MCP_版本号)
        信息JSON.加入整数成员 ("browsers", FBrowser_浏览器_取数量 ())
        信息JSON.加入文本成员 ("protocol", "JSON-RPC 2.0")
        信息JSON.加入文本成员 ("mcp_ws", 取MCP_WS地址 ())
        信息JSON.加入文本成员 ("mcp_http_post", 取MCP_HTTP地址 () + "/mcp")
        信息JSON.加入文本成员 ("mcp_http_post_alt", 取MCP_HTTP地址 () + "/")
        信息JSON.加入文本成员 ("health", "/health")
        信息JSON.加入文本成员 ("tools", "/tools/list")
        信息JSON.加入文本成员 ("json_list", "/json/list")
        信息JSON.加入文本成员 ("json_version", "/json/version")
        信息JSON.加入文本成员 ("welcome", "/")
        信息JSON.加入文本成员 ("docs", "/docs/")
        信息JSON.加入文本成员 ("cdp_note", "CDP 请使用 MCP 工具 browser_cdp_call / browser_cdp_event, 非独立 WebSocket 代理")
        信息JSON.加入文本成员 ("bridge_script", "mcp_bridge.js")
        信息JSON.加入文本成员 ("check_command", "node mcp_bridge.js --check")
        信息JSON.加入文本成员 ("usage_step1", "启动 AI浏览器.exe")
        信息JSON.加入文本成员 ("usage_step2", "Cursor 配置 node mcp_bridge.js (见欢迎页快速接入)")
        信息JSON.加入文本成员 ("usage_step3", "tools/call 调用 browser_navigate 等工具")
        返回 (信息JSON.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 JSON转义文本 <公开 静态 类型 = 文本型 注释 = "转义文本以便安全嵌入JSON双引号字符串(\"...\")">
    参数 源文本 <类型 = 文本型>
    {
        // == 转义映射表 (JSON双引号字符串上下文) ==
        常量 JESC_BSLASH <类型 = 文本型 值 = "\\">
        常量 JESC_DQUOTE <类型 = 文本型 值 = "\"">
        常量 JESC_NEWLINE <类型 = 文本型 值 = "\n">
        常量 JESC_CR <类型 = 文本型 值 = "\r">
        // 转义目标值
        常量 JREP_BSLASH <类型 = 文本型 值 = "\\\\">
        常量 JREP_DQUOTE <类型 = 文本型 值 = "\\\"">
        常量 JREP_NEWLINE <类型 = 文本型 值 = "\\n">
        常量 JREP_CR <类型 = 文本型 值 = "\\r">
        变量 结果 <类型 = 文本型>
        结果 = 源文本
        子文本替换 (结果, JESC_BSLASH, JREP_BSLASH, , , 假)
        子文本替换 (结果, JESC_DQUOTE, JREP_DQUOTE, , , 假)
        子文本替换 (结果, JESC_NEWLINE, JREP_NEWLINE, , , 假)
        子文本替换 (结果, JESC_CR, JREP_CR, , , 假)
        返回 (结果)
    }
    # mcp_result 响应: data 字段嵌入 JSON 对象(非字符串), 避免双重编码
    方法 构建任务查询结果JSON <公开 静态 类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 消息 <类型 = 文本型>
    参数 原始数据JSON <类型 = 文本型>
    参数 任务ID <类型 = 文本型 @默认值 = "">
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 是否成功)
        如果 (任务ID != "")
        {
            对象.加入文本成员 ("task_id", 任务ID)
        }
        如果 (是否成功)
        {
            对象.加入文本成员 ("message", 消息)
            变量 头JSON <类型 = 文本型>
            头JSON = 对象.到可读文本 (YYJSON格式化选项.压缩)
            如果 (原始数据JSON != "" && 是否为合法JSON文档 (原始数据JSON))
            {
                返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"data\":" + 原始数据JSON + "}")
            }
            如果 (原始数据JSON != "")
            {
                对象.加入文本成员 ("data", 原始数据JSON)
            }
            返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
        }
        对象.加入文本成员 ("error", 消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建JSON版本响应 <公开 静态 类型 = 文本型>
    {
        变量 版本JSON <类型 = YYJSON对象类>
        版本JSON.创建自文本 ("{}")
        版本JSON.加入文本成员 ("Browser", "AI浏览器 MCP/" + MCP_版本号)
        版本JSON.加入文本成员 ("Protocol-Version", "1.3")
        版本JSON.加入文本成员 ("User-Agent", MCP_服务器名)
        版本JSON.加入文本成员 ("V8-Version", "CEF")
        版本JSON.加入文本成员 ("WebKit-Version", "FBrowser CEF")
        版本JSON.加入文本成员 ("webSocketDebuggerUrl", 取MCP_WS地址 ())
        返回 (版本JSON.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建JSON列表响应 <公开 静态 类型 = 文本型>
    {
        变量 ID清单 <类型 = 类_FBrowser_列表值>
        ID清单 = FBrowser_浏览器_取ID清单 ()
        变量 json文本 <类型 = 文本型>
        json文本 = "["
        变量 first <类型 = 逻辑型 值 = 真>
        计次循环 (ID清单.取大小 ())
        {
            变量 bid <类型 = 整数>
            bid = ID清单.取整数值 (取循环索引 ())
            变量 bb <类型 = 类_FBrowser_浏览器>
            bb = FBrowser_浏览器_通过ID取浏览器 (bid)
            如果 (bb.是否为空 () == 假 && bb.是否已关闭 () == 假)
            {
                如果 (first)
                {
                    first = 假
                }
                否则
                {
                    json文本 = json文本 + ","
                }
                变量 url文本 <类型 = 文本型>
                变量 title文本 <类型 = 文本型>
                变量 jsonUrlFrame <类型 = 类_FBrowser_框架>
                jsonUrlFrame = 取安全主框架 (bb)
                如果 (jsonUrlFrame.是否为空 () == 假 && jsonUrlFrame.是否有效 ())
                {
                    url文本 = jsonUrlFrame.取地址 ()
                }
                否则
                {
                    url文本 = "about:blank"
                }
                变量 窗口句柄 <类型 = 变整数>
                窗口句柄 = bb.取窗口句柄 ()
                如果 (窗口句柄 != 0)
                {
                    title文本 = bb.取窗口标题 ()
                }
                否则
                {
                    title文本 = "FBrowser #" + 到文本 (bid)
                }
                变量 页面对象 <类型 = YYJSON对象类>
                页面对象.创建自文本 ("{}")
                页面对象.加入文本成员 ("id", 到文本 (bid))
                页面对象.加入文本成员 ("type", "page")
                页面对象.加入文本成员 ("title", title文本)
                页面对象.加入文本成员 ("url", url文本)
                页面对象.加入文本成员 ("description", "MCP browser_id=" + 到文本 (bid) + ", CDP via browser_cdp_call")
                页面对象.加入整数成员 ("mcp_browser_id", bid)
                json文本 = json文本 + 页面对象.到可读文本 (YYJSON格式化选项.压缩)
            }
        }
        json文本 = json文本 + "]"
        返回 (json文本)
    }
    方法 读取HTTP_POST体 <公开 静态 类型 = 文本型>
    参数 请求 <类型 = 类_FBrowser_请求>
    {
        变量 POST数据体 <类型 = 类_FBrowser_POST数据>
        POST数据体 = 请求.取POST数据 ()
        如果 (POST数据体.是否为空 () || POST数据体.取元素个数 () <= 0)
        {
            返回 ("")
        }
        变量 元素数组 <类型 = 类_FBrowser_POST元素数组>
        元素数组 = POST数据体.取元素 ()
        如果 (元素数组.是否为空 ())
        {
            返回 ("")
        }
        变量 元素个数 <类型 = 整数>
        元素个数 = 元素数组.取个数 ()
        变量 全部字节数据 <类型 = 字节集类>
        变量 总字节数 <类型 = 整数>
        总字节数 = 0
        元素数组.到数组首 ()
        计次循环 (元素个数)
        {
            变量 当前元素 <类型 = 类_FBrowser_POST元素>
            当前元素 = 元素数组.取当前位置数据 ()
            如果 (当前元素.是否为空 () == 假)
            {
                变量 数据大小 <类型 = 整数>
                数据大小 = 当前元素.取数据大小 ()
                如果 (数据大小 > 0)
                {
                    变量 字节数据 <类型 = 字节集类>
                    字节数据 = 当前元素.取字节集数据 (数据大小)
                    如果 (字节数据.字节集是否为空 () == 假)
                    {
                        全部字节数据.添加字节集 (字节数据)
                        总字节数 = 总字节数 + 数据大小
                    }
                }
            }
            元素数组.到下一个 ()
        }
        如果 (总字节数 > 0)
        {
            返回 (UTF8到文本 (全部字节数据))
        }
        返回 ("")
    }
    # ======== 静态文档 /docs ========
    方法 取文档根目录 <公开 静态 类型 = 文本型>
    {
        如果 (文档根目录缓存 != "")
        {
            返回 (文档根目录缓存)
        }
        文档根目录缓存 = 取运行目录 () + "\\docs"
        返回 (文档根目录缓存)
    }
    方法 取文档扩展名 <公开 静态 类型 = 文本型>
    参数 文件路径 <类型 = 文本型>
    {
        变量 文件名 <类型 = 文本型>
        变量 末斜杠 <类型 = 整数>
        末斜杠 = 倒找文本 (文件路径, "\\", , 假)
        如果 (末斜杠 == -1)
        {
            末斜杠 = 倒找文本 (文件路径, "/", , 假)
        }
        如果 (末斜杠 != -1)
        {
            文件名 = 取文本中间 (文件路径, 末斜杠 + 1, 取文本长度 (文件路径) - 末斜杠 - 1)
        }
        否则
        {
            文件名 = 文件路径
        }
        变量 点位置 <类型 = 整数>
        点位置 = 倒找文本 (文件名, ".", , 假)
        如果 (点位置 < 0)
        {
            返回 ("")
        }
        返回 (到小写 (取文本中间 (文件名, 点位置 + 1, 取文本长度 (文件名) - 点位置 - 1)))
    }
    方法 文档相对路径是否安全 <公开 静态 类型 = 逻辑型>
    参数 相对路径 <类型 = 文本型>
    {
        如果 (相对路径 == "")
        {
            返回 (假)
        }
        // URL 解码: 防止 %2e%2e%2f 等编码绕过路径穿越检查
        变量 解码路径 <类型 = 文本型>
        解码路径 = FBrowser_Parser_URI解码 (相对路径, 真, 真)
        如果 (寻找文本 (解码路径, "..", , 假) != -1)
        {
            返回 (假)
        }
        如果 (寻找文本 (解码路径, ":", , 假) != -1)
        {
            返回 (假)
        }
        如果 (寻找文本 (相对路径, "\\", , 假) != -1 && 寻找文本 (相对路径, "/", , 假) != -1)
        {
            返回 (假)
        }
        返回 (真)
    }
    方法 取文档MIME类型 <公开 静态 类型 = 文本型>
    参数 文件路径 <类型 = 文本型>
    {
        变量 扩展名 <类型 = 文本型>
        扩展名 = 取文档扩展名 (文件路径)
        如果 (扩展名 == "html" || 扩展名 == "htm")
        {
            返回 ("text/html; charset=utf-8")
        }
        如果 (扩展名 == "css")
        {
            返回 ("text/css; charset=utf-8")
        }
        如果 (扩展名 == "js" || 扩展名 == "mjs")
        {
            返回 ("application/javascript; charset=utf-8")
        }
        如果 (扩展名 == "json")
        {
            返回 ("application/json; charset=utf-8")
        }
        如果 (扩展名 == "svg")
        {
            返回 ("image/svg+xml")
        }
        如果 (扩展名 == "png")
        {
            返回 ("image/png")
        }
        如果 (扩展名 == "jpg" || 扩展名 == "jpeg")
        {
            返回 ("image/jpeg")
        }
        如果 (扩展名 == "gif")
        {
            返回 ("image/gif")
        }
        如果 (扩展名 == "webp")
        {
            返回 ("image/webp")
        }
        如果 (扩展名 == "ico")
        {
            返回 ("image/x-icon")
        }
        如果 (扩展名 == "woff")
        {
            返回 ("font/woff")
        }
        如果 (扩展名 == "woff2")
        {
            返回 ("font/woff2")
        }
        如果 (扩展名 == "md" || 扩展名 == "txt")
        {
            返回 ("text/plain; charset=utf-8")
        }
        返回 ("application/octet-stream")
    }
    方法 尝试发送静态文档 <公开 静态 类型 = 逻辑型>
    参数 服务器 <类型 = 类_FBrowser_服务器>
    参数 连接ID <类型 = 整数>
    参数 URL路径 <类型 = 文本型>
    {
        变量 相对路径 <类型 = 文本型>
        相对路径 = URL路径
        如果 (相对路径 == "/docs" || 相对路径 == "/docs/")
        {
            相对路径 = "index.html"
        }
        否则 (是否以 (相对路径, "/docs/"))
        {
            变量 前缀长度 <类型 = 整数>
            前缀长度 = 取文本长度 ("/docs/")
            相对路径 = 取文本中间 (相对路径, 前缀长度, 取文本长度 (相对路径) - 前缀长度)
        }
        否则
        {
            返回 (假)
        }
        子文本替换 (相对路径, "/", "\\", , , 假)
        如果 (文档相对路径是否安全 (相对路径) == 假)
        {
            返回 (假)
        }
        变量 文件路径 <类型 = 文本型>
        文件路径 = 取文档根目录 () + "\\" + 相对路径
        如果 (文件是否存在 (文件路径) == 假)
        {
            返回 (假)
        }
        变量 文件字节 <类型 = 字节集类>
        文件字节 = 读入文件 (文件路径)
        如果 (取字节集长度 (文件字节) == 0)
        {
            返回 (假)
        }
        变量 MIME <类型 = 文本型>
        MIME = 取文档MIME类型 (相对路径)
        发送CORS200响应 (服务器, 连接ID, MIME, 取字节集指针 (文件字节), 取字节集长度 (文件字节))
        返回 (真)
    }
    #
}
