        命令注册表.置整数值 ("browser_evaluate", 9)
        命令注册表.置整数值 ("browser.get_source", 10)
        命令注册表.置整数值 ("browser_get_source", 10)
        命令注册表.置整数值 ("browser.get_text", 11)
        命令注册表.置整数值 ("browser_get_text", 11)
        // ID 200-399: DOM/DevTools
