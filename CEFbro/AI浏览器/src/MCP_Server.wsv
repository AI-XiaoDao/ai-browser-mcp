    # 取 object 型成员 (batch arguments / tools/call params 等)
    方法 yyjson取对象成员 <公开 静态 类型 = YYJSON只读对象类>
    参数 JSON对象 <类型 = YYJSON只读对象类>
    参数 键名 <类型 = 文本型>
    {
        变量 默认JSON对象 <类型 = YYJSON只读对象类>
        如果 (JSON对象.是否为空 () == 假)
        {
            返回 (JSON对象.取对象 (键名))
        }
        返回 (默认JSON对象)
    }
    # 字符串优先; 否则序列化 object/array 为 JSON 文本 (兼容 MCP 客户端传 object 参数)
    方法 yyjson取JSON文本 <公开 静态 类型 = 文本型>
    参数 JSON对象 <类型 = YYJSON只读对象类>
    参数 键名 <类型 = 文本型>
    {
        如果 (JSON对象.是否为空 ())
        {
            返回 ("")
        }
        变量 文本值 <类型 = 文本型>
        文本值 = JSON对象.取文本 (键名)
        如果 (文本值 != "")
        {
            返回 (文本值)
        }
        变量 子对象 <类型 = YYJSON只读对象类>
        子对象 = JSON对象.取对象 (键名)
        如果 (子对象.是否为空 () == 假 && 子对象.取成员数 () > 0)
        {
            返回 (子对象.到可读文本 (YYJSON格式化选项.压缩))
        }
        变量 子数组 <类型 = YYJSON只读数组类>
        子数组 = JSON对象.取数组 (键名)
        如果 (子数组.是否为空对象 () == 假 && 子数组.取成员数 () > 0)
        {
            返回 (子数组.到可读文本 (YYJSON格式化选项.压缩))
        }
        返回 ("")
    }
    # ======== 文本辅助 ==========
    方法 简单转义JS <公开 静态 类型 = 文本型 注释 = "转义文本以便安全嵌入单引号JS字符串('...')。双引号上下文请用 JSON转义文本。">
    参数 原始文本 <类型 = 文本型>
    {
        如果 (原始文本 == "")
        {
            返回 ("")
        }
        // == 转义映射表 (单引号JS字符串上下文) ==
        // 注意: 转义顺序至关重要! 反斜杠 必须先替换, 否则后续替换引入的反斜杠会被二次转义
        常量 JS_ESC_NULL <类型 = 文本型 值 = "\0">
        常量 JS_ESC_BSLASH <类型 = 文本型 值 = "\\">
        常量 JS_ESC_SQUOTE <类型 = 文本型 值 = "'">
        常量 JS_ESC_BTICK <类型 = 文本型 值 = "`">
        常量 JS_ESC_NEWLINE <类型 = 文本型 值 = "\n">
        常量 JS_ESC_CR <类型 = 文本型 值 = "\r">
        常量 JS_ESC_TAB <类型 = 文本型 值 = "\t">
        常量 JS_ESC_FF <类型 = 文本型 值 = "\f">
        常量 JS_ESC_VTAB <类型 = 文本型 值 = "\v">
        常量 JS_ESC_SCRIPT <类型 = 文本型 值 = "</script>">
        // 转义目标值
        常量 JS_REP_NULL <类型 = 文本型 值 = "">
        常量 JS_REP_BSLASH <类型 = 文本型 值 = "\\\\">
        常量 JS_REP_SQUOTE <类型 = 文本型 值 = "\\'">
        常量 JS_REP_BTICK <类型 = 文本型 值 = "\\`">
        常量 JS_REP_NEWLINE <类型 = 文本型 值 = "\\n">
        常量 JS_REP_CR <类型 = 文本型 值 = "\\r">
        常量 JS_REP_TAB <类型 = 文本型 值 = "\\t">
        常量 JS_REP_FF <类型 = 文本型 值 = "\\f">
        常量 JS_REP_VTAB <类型 = 文本型 值 = "\\v">
        常量 JS_REP_SCRIPT <类型 = 文本型 值 = "<\\/script>">
        变量 结果 <类型 = 文本型>
        结果 = 原始文本
        // 1. 安全: 去除null字节(可截断C字符串)
        子文本替换 (结果, JS_ESC_NULL, JS_REP_NULL, , , 假)
        // 2. 反斜杠 — 必须最先替换!
        子文本替换 (结果, JS_ESC_BSLASH, JS_REP_BSLASH)
        // 3. 单引号 — 在 '...' 字面量中破坏字符串
        子文本替换 (结果, JS_ESC_SQUOTE, JS_REP_SQUOTE)
        // 4. 反引号 — 防止模板字符串注入
        子文本替换 (结果, JS_ESC_BTICK, JS_REP_BTICK)
        // 5. 控制字符 — 保持JS字面量合法
        子文本替换 (结果, JS_ESC_NEWLINE, JS_REP_NEWLINE)
        子文本替换 (结果, JS_ESC_CR, JS_REP_CR)
        子文本替换 (结果, JS_ESC_TAB, JS_REP_TAB)
        子文本替换 (结果, JS_ESC_FF, JS_REP_FF)
        子文本替换 (结果, JS_ESC_VTAB, JS_REP_VTAB)
        // 6. HTML注入防护
        子文本替换 (结果, JS_ESC_SCRIPT, JS_REP_SCRIPT)
        // 注: " 不转义 (单引号JS字面量中无需), $ 不转义 (避免破坏jQuery等)
        返回 (结果)
    }
    # ======== 拦截辅助 ==========
    方法 解析匹配模式 <公开 静态 类型 = 整数>
    参数 模式名 <类型 = 文本型>
    {
        如果 (模式名 == "exact")
        {
            返回 (VIP过滤器地址.完全匹配)
        }
        否则 (模式名 == "fuzzy")
        {
            返回 (VIP过滤器地址.模糊匹配)
        }
        否则 (模式名 == "head")
        {
            返回 (VIP过滤器地址.模糊头匹配)
        }
        否则 (模式名 == "regex")
        {
            返回 (VIP过滤器地址.正则匹配)
        }
        返回 (VIP过滤器地址.模糊尾匹配)
    }
    # 添加资源替换规则到全局文本存储 (配合 browser_intercept 事件Hook通道)
    方法 裁剪规则文本到最大行数 <公开 静态 类型 = 文本型>
    参数 规则文本 <类型 = 文本型>
    参数 最大行数 <类型 = 整数>
    {
        如果 (规则文本 == "" || 最大行数 <= 0)
        {
            返回 (规则文本)
        }
        变量 行数组 <类型 = 文本数组类>
        分割文本 (规则文本, "\n", 行数组, 真, 假)
        变量 行数 <类型 = 整数>
        行数 = 行数组.取成员数 ()
        如果 (行数 <= 最大行数)
        {
            返回 (规则文本)
        }
        变量 结果 <类型 = 文本型>
        结果 = ""
        变量 起始 <类型 = 整数>
        起始 = 行数 - 最大行数
        计次循环 (最大行数)
        {
            变量 idx <类型 = 整数>
            idx = 起始 + 取循环索引 ()
            如果 (结果 == "")
            {
                结果 = 行数组.取成员 (idx)
            }
            否则
            {
                结果 = 结果 + "\n" + 行数组.取成员 (idx)
            }
        }
        返回 (结果)
    }
    方法 追加导航拦截规则 <公开 静态>
    参数 新行 <类型 = 文本型>
    {
        如果 (新行 == "")
        {
            返回
        }
        如果 (导航拦截规则 == "")
        {
            导航拦截规则 = 新行
        }
        否则
        {
            导航拦截规则 = 导航拦截规则 + "\n" + 新行
        }
        导航拦截规则 = 裁剪规则文本到最大行数 (导航拦截规则, 拦截规则最大行数)
    }
    方法 添加资源替换规则 <公开 静态>
    参数 动作 <类型 = 文本型>
    参数 规则URL <类型 = 文本型>
    参数 搜索文本 <类型 = 文本型>
    参数 替换文本 <类型 = 文本型>
    参数 文件路径 <类型 = 文本型>
    参数 MIME类型 <类型 = 文本型>
    {
        // 使用紧凑文本格式: action|url|search_text|replace_text|file_path|mime_type
        变量 新行 <类型 = 文本型>
        新行 = 动作 + "|" + 规则URL
        如果 (搜索文本 != "")
        {
            新行 = 新行 + "|" + 搜索文本 + "|" + 替换文本
        }
        如果 (文件路径 != "")
        {
            新行 = 新行 + "|file:" + 文件路径
        }
        如果 (资源替换规则 == "")
        {
            资源替换规则 = 新行
        }
        否则
        {
            资源替换规则 = 资源替换规则 + "\n" + 新行
        }
        资源替换规则 = 裁剪规则文本到最大行数 (资源替换规则, 拦截规则最大行数)
    }
    # ======== 网络日志 ==========
    方法 记录网络请求 <公开 静态>
    参数 请求方法 <类型 = 文本型>
    参数 请求URL <类型 = 文本型>
    {
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", "req")
        日志项.加入文本成员 ("method", 请求方法)
        日志项.加入文本成员 ("url", 请求URL)
        记录事件日志 ("network", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 记录网络响应 <公开 静态>
    参数 响应URL <类型 = 文本型>
    参数 状态码 <类型 = 整数>
    参数 MIME类型 <类型 = 文本型>
    参数 是否缓存 <类型 = 逻辑型>
    {
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", "res")
        日志项.加入文本成员 ("url", 响应URL)
        日志项.加入整数成员 ("status", 状态码)
        日志项.加入文本成员 ("mime", MIME类型)
        日志项.加入逻辑值成员 ("cached", 是否缓存)
        记录事件日志 ("network", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 记录网络日志项 <公开 静态>
    参数 类型_文本 <类型 = 文本型>
    参数 URL_文本 <类型 = 文本型>
    参数 消息_文本 <类型 = 文本型>
    参数 大小_整数 <类型 = 整数 @默认值 = 0>
    {
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", 类型_文本)
        日志项.加入文本成员 ("url", URL_文本)
        日志项.加入文本成员 ("path", 消息_文本)
        如果 (大小_整数 > 0)
        {
            日志项.加入整数成员 ("size", 大小_整数)
        }
        记录事件日志 ("network", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 记录网络请求_详细 <公开 静态>
    参数 请求 <类型 = 类_FBrowser_请求>
    {
        变量 请求URL <类型 = 文本型>
        请求URL = 请求.取地址 ()
        变量 请求方法 <类型 = 文本型>
        请求方法 = 请求.取类型 ()
        // 用yyjson构建主体, 避免URL中的双引号/反斜杠破坏JSON
        // 注: header子对象避免用加入成员嵌套(已知崩溃), 改为先序列化再嵌入文本
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", "req")
        日志项.加入文本成员 ("method", 请求方法)
        日志项.加入文本成员 ("url", 请求URL)
        变量 头数组 <类型 = FBrowser_双文本数组>
        头数组 = 请求.取协议头数据 ()
        如果 (头数组.取个数 () > 0)
        {
            变量 头对象 <类型 = YYJSON对象类>
            头对象.创建自文本 ("{}")
            头数组.到数组首 ()
            变量 继续 <类型 = 逻辑型 值 = 真>
            循环判断首 ()
            {
                变量 当前头 <类型 = FBrowser_双文本>
                当前头 = 头数组.取当前位置数据 ()
                如果 (当前头.name != "" && 当前头.name != "cookie")
                {
                    头对象.加入文本成员 (当前头.name, 当前头.value)
                }
                继续 = 头数组.到下一个 ()
            }
            循环判断尾 (继续)
            // 先序列化头对象, 再作为文本成员嵌入 (规避加入成员嵌套崩溃)
            日志项.加入文本成员 ("headers_json", 头对象.到可读文本 (YYJSON格式化选项.压缩))
        }
        记录事件日志 ("network_detail", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 记录网络响应_详细 <公开 静态>
    参数 请求 <类型 = 类_FBrowser_请求>
    参数 响应 <类型 = 类_FBrowser_响应>
    参数 内容长度 <类型 = 长整数>
    {
        变量 响应URL <类型 = 文本型>
        响应URL = 请求.取地址 ()
        变量 MIME类型 <类型 = 文本型>
        MIME类型 = 响应.取协议头_名称 ("Content-Type")
        // 用yyjson构建, 避免URL/MIME/Header中的特殊字符破坏JSON
        // 注: header子对象避免用加入成员嵌套(已知崩溃), 改为先序列化再嵌入文本
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", "res")
        日志项.加入文本成员 ("url", 响应URL)
        日志项.加入长整数成员 ("content_length", 内容长度)
        日志项.加入文本成员 ("mime", MIME类型)
        变量 头数组 <类型 = FBrowser_双文本数组>
        头数组 = 响应.取协议头数据 ()
        如果 (头数组.取个数 () > 0)
        {
            变量 头对象 <类型 = YYJSON对象类>
            头对象.创建自文本 ("{}")
            头数组.到数组首 ()
            变量 继续 <类型 = 逻辑型 值 = 真>
            循环判断首 ()
            {
                变量 当前头 <类型 = FBrowser_双文本>
                当前头 = 头数组.取当前位置数据 ()
                如果 (当前头.name != "" && 当前头.name != "set-cookie")
                {
                    头对象.加入文本成员 (当前头.name, 当前头.value)
                }
                继续 = 头数组.到下一个 ()
            }
            循环判断尾 (继续)
            日志项.加入文本成员 ("response_headers_json", 头对象.到可读文本 (YYJSON格式化选项.压缩))
        }
        记录事件日志 ("network_detail", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== 浏览器加载事件记录 ========
    方法 记录加载事件 <公开 静态>
    参数 事件类型 <类型 = 文本型>
    参数 浏览器ID <类型 = 整数>
    参数 附加数据 <类型 = 整数 @默认值 = 0>
    {
        变量 事件键名 <类型 = 文本型>
        事件键名 = "browser_event:" + 事件类型 + ":" + 到文本 (浏览器ID)
        变量 事件包装 <类型 = YYJSON对象类>
        事件包装.创建自文本 ("{}")
        事件包装.加入文本成员 ("event", 事件类型)
        事件包装.加入整数成员 ("browser_id", 浏览器ID)
        事件包装.加入文本成员 ("timestamp", 到文本 (取启动时间 ()))
        如果 (事件类型 == "load_end")
        {
            事件包装.加入整数成员 ("status_code", 附加数据)
        }
        否则 (事件类型 == "crash")
        {
            事件包装.加入整数成员 ("error_code", 附加数据)
        }
        记录事件日志 ("browser_event", 事件类型, 浏览器ID, 事件包装.到可读文本 (YYJSON格式化选项.压缩))
        调试输出 ("[MCP] 浏览器事件:", 事件类型, "ID:", 浏览器ID)
    }
    # 通用浏览器事件记录 (SQLite)
    方法 记录浏览器事件 <公开 静态>
    参数 事件类型 <类型 = 文本型>
    参数 浏览器ID <类型 = 整数>
    参数 事件数据JSON <类型 = 文本型 @默认值 = "">
    {
        变量 事件包装 <类型 = YYJSON对象类>
        事件包装.创建自文本 ("{}")
        事件包装.加入文本成员 ("event", 事件类型)
        事件包装.加入整数成员 ("browser_id", 浏览器ID)
        事件包装.加入长整数成员 ("timestamp_ms", 取启动时间 ())
        如果 (事件数据JSON != "")
        {
            事件包装.加入文本成员 ("data", 事件数据JSON)
        }
        记录事件日志 ("browser_event", 事件类型, 浏览器ID, 事件包装.到可读文本 (YYJSON格式化选项.压缩))
    }
    # 应用级事件记录 (SQLite)
    方法 记录应用事件 <公开 静态>
    参数 事件类型 <类型 = 文本型>
    参数 事件数据JSON <类型 = 文本型 @默认值 = "">
    {
        变量 事件包装 <类型 = YYJSON对象类>
        事件包装.创建自文本 ("{}")
        事件包装.加入文本成员 ("event", 事件类型)
        事件包装.加入长整数成员 ("timestamp_ms", 取启动时间 ())
        如果 (事件数据JSON != "")
        {
            事件包装.加入文本成员 ("data", 事件数据JSON)
        }
        记录事件日志 ("app_event", 事件类型, 0, 事件包装.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== Console日志收集 ==========
    方法 记录控制台消息 <公开 静态>
    参数 日志级别 <类型 = 整数>
    参数 消息 <类型 = 文本型>
    参数 来源URL <类型 = 文本型>
    参数 行号 <类型 = 整数>
    {
        变量 级别文本 <类型 = 文本型>
        如果 (日志级别 == 日志级别.调试)
        {
            级别文本 = "debug"
        }
        否则 (日志级别 == 日志级别.信息)
        {
            级别文本 = "info"
        }
        否则 (日志级别 == 日志级别.警告)
        {
            级别文本 = "warn"
        }
        否则 (日志级别 == 日志级别.错误)
        {
            级别文本 = "error"
        }
        否则
        {
            级别文本 = "log"
        }
        // 用yyjson构建, 存入SQLite事件日志
        变量 日志项 <类型 = YYJSON对象类>
        日志项.创建自文本 ("{}")
        日志项.加入文本成员 ("type", "console")
        日志项.加入文本成员 ("level", 级别文本)
        日志项.加入文本成员 ("msg", 消息)
        日志项.加入文本成员 ("src", 来源URL)
        日志项.加入整数成员 ("line", 行号)
        记录事件日志 ("console", "", 0, 日志项.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== JS代码解码 ==========
    方法 解码JS代码 <公开 静态 类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 code <类型 = 文本型>
        code = yyjson取文本 (参数JSON, "code")
        如果 (code != "")
        {
            返回 (code)
        }
        code = yyjson取文本 (参数JSON, "file")
        如果 (code != "" && 验证安全路径 (code))
        {
            变量 文件字节 <类型 = 字节集类>
            文件字节 = 读入文件 (code)
            如果 (取字节集长度 (文件字节) > 0)
            {
                返回 (UTF8到文本 (文件字节))
            }
        }
        返回 ("")
    }
    # ======== URL规范化 ==========
    方法 规范化URL <公开 静态 类型 = 文本型>
    参数 输入URL <类型 = 文本型>
    参数 基础URL <类型 = 文本型 @默认值 = "">
    {
        如果 (输入URL == "")
        {
            返回 ("")
        }
        如果 (是否以 (输入URL, "//"))
        {
            返回 ("https:" + 输入URL)
        }
        如果 (是否以 (输入URL, "/"))
        {
            如果 (基础URL != "")
            {
                返回 (基础URL + 输入URL)
            }
            返回 (输入URL)
        }
        返回 (输入URL)
    }
    方法 是否以 <公开 静态 类型 = 逻辑型>
    参数 源文本 <类型 = 文本型>
    参数 前缀 <类型 = 文本型>
    {
        变量 前缀长度 <类型 = 整数>
        前缀长度 = 取文本长度 (前缀)
        如果 (取文本长度 (源文本) < 前缀长度)
        {
            返回 (假)
        }
        返回 (取文本左边 (源文本, 前缀长度) == 前缀)
    }
    方法 取浏览器ByID <公开 静态 类型 = 类_FBrowser_浏览器>
    参数 browserID <类型 = 整数>
    {
        变量 result <类型 = 类_FBrowser_浏览器>
        如果 (browserID <= 0)
        {
            返回 (result)
        }
        浏览器数组锁.加锁 ()
        变量 count <类型 = 整数>
        count = 浏览器容器.浏览器数组.取成员数 ()
        计次循环 (count)
        {
            变量 b <类型 = 类_FBrowser_浏览器>
            b = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 取循环索引 (), 类_FBrowser_浏览器)
            如果 (b.是否为空 () == 假 && b.是否已关闭 () == 假 && b.取ID () == browserID)
            {
                result = b
                跳出循环
            }
        }
        浏览器数组锁.解锁 ()
        返回 (result)
    }
    方法 取主浏览器 <公开 静态 类型 = 类_FBrowser_浏览器>
    {
        变量 result <类型 = 类_FBrowser_浏览器>
        如果 (目标浏览器ID > 0)
        {
            result = 取浏览器ByID (目标浏览器ID)
            如果 (result.是否为空 ())
            {
                调试输出 ("[MCP] 错误: 指定的浏览器ID=", 目标浏览器ID, " 未找到或已关闭")
            }
            返回 (result)
        }
        变量 非弹窗浏览器 <类型 = 类_FBrowser_浏览器>
        变量 弹窗浏览器 <类型 = 类_FBrowser_浏览器>
        变量 最小非弹窗ID <类型 = 整数 值 = 2147483647>
        变量 最小弹窗ID <类型 = 整数 值 = 2147483647>
        浏览器数组锁.加锁 ()
        变量 count <类型 = 整数>
        count = 浏览器容器.浏览器数组.取成员数 ()
        计次循环 (count)
        {
            变量 b <类型 = 类_FBrowser_浏览器>
            b = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 取循环索引 (), 类_FBrowser_浏览器)
            如果 (b.是否为空 () == 假 && b.是否已关闭 () == 假)
            {
                变量 bid <类型 = 整数>
                bid = b.取ID ()
                如果 (b.是否为弹窗 () == 假)
                {
                    如果 (bid < 最小非弹窗ID)
                    {
                        非弹窗浏览器 = b
                        最小非弹窗ID = bid
                    }
                }
                否则
                {
                    如果 (bid < 最小弹窗ID)
                    {
                        弹窗浏览器 = b
                        最小弹窗ID = bid
                    }
                }
            }
        }
        浏览器数组锁.解锁 ()
        如果 (非弹窗浏览器.是否为空 () == 假)
        {
            返回 (非弹窗浏览器)
        }
        返回 (弹窗浏览器)
    }
