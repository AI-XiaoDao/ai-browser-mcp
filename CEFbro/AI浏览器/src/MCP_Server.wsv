    # ======== URL 安全验证 (防协议注入) ==========
    方法 验证URL安全 <公开 静态 类型 = 逻辑型>
    参数 输入URL <类型 = 文本型>
    {
        如果 (输入URL == "")
        {
            返回 (假)
        }
        // 1. 删首尾空白, 防止空白符绕过 (如 "\tjavascript:...")
        变量 纯净URL <类型 = 文本型>
        纯净URL = 删首尾空 (输入URL)
        // 2. 去除null字节, 防止C字符串截断绕过 (如 "java\0script:")
        子文本替换 (纯净URL, "\0", "", , , 假)
        // 3. 提取 scheme 部分并 URL 解码, 防止编码绕过 (如 java%0ascript: → javascript:)
        变量 schemeEnd <类型 = 整数>
        schemeEnd = 寻找文本 (纯净URL, ":", , 假)
        如果 (schemeEnd > 0)
        {
            变量 rawScheme <类型 = 文本型>
            rawScheme = 取文本左边 (纯净URL, schemeEnd - 1)
            变量 decodedScheme <类型 = 文本型>
            decodedScheme = FBrowser_Parser_URI解码 (rawScheme, 真, 真)
            变量 decodedSchemeLower <类型 = 文本型>
            decodedSchemeLower = 到小写 (decodedScheme)
            如果 (decodedSchemeLower == "javascript" || decodedSchemeLower == "vbscript")
            {
                返回 (假)
            }
        }
        // 4. 转小写用于协议比较 (协议名大小写不敏感, RFC 3986)
        变量 小写检查 <类型 = 文本型>
        小写检查 = 到小写 (纯净URL)
        // 5. 拒绝危险的URL协议: javascript:, file:, data:(非image/png|jpeg|gif|webp)
        如果 (寻找文本 (小写检查, "JAVASCRIPT:", , 假) == 1)
        {
            返回 (假)
        }
        如果 (寻找文本 (小写检查, "FILE:", , 假) == 1 && 寻找文本 (小写检查, "://", , 假) > 0)
        {
            返回 (假)
        }
        // data: 仅允许安全的 image MIME (png/jpeg/gif/webp), 拒绝 svg+xml 等可执行类型
        如果 (寻找文本 (小写检查, "DATA:", , 假) == 1)
        {
            如果 (寻找文本 (小写检查, "IMAGE/SVG", , 假) > 0)
            {
                返回 (假)
            }
            如果 (寻找文本 (小写检查, "IMAGE/", , 假) == 0)
            {
                返回 (假)
            }
        }
        返回 (真)
    }
    方法 验证安全路径 <公开 静态 类型 = 逻辑型>
    参数 路径 <类型 = 文本型>
    参数 仅允许运行目录内 <类型 = 逻辑型 @默认值 = 假 注释 = "写操作应设真, 限制在取运行目录()子树内">
    {
        // 防止路径遍历攻击: 拒绝包含 ../ || ..\\ 的路径
        如果 (寻找文本 (路径, "..", , 假) != -1)
        {
            调试输出 ("[MCP] 安全拒绝(路径遍历):", 路径)
            返回 (假)
        }
        // 写操作: 仅允许 取运行目录() 子树内的路径, 防止污染系统目录
        如果 (仅允许运行目录内 && 是否以 (路径, 取运行目录 ()) == 假)
        {
            调试输出 ("[MCP] 安全拒绝(路径越界):", 路径, " 根目录:", 取运行目录 ())
            返回 (假)
        }
        // 读操作: 允许任意绝对/相对路径 (本地工具特性)
        返回 (真)
    }
