    # ======== 异步响应辅助 / UX sync-wait (helper 在前, 命令成功_异步 见本段末尾) ==========
    # ======== UX: 服务端 sync-wait (一次调用返回结果) ==========
    # 默认对轻量读/写工具内聚轮询; async_only:true 可恢复旧异步行为
    方法 规范化工具名 <公开 静态 类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    {
        变量 名 <类型 = 文本型>
        名 = 方法名
        如果 (名 == "")
        {
            返回 ("")
        }
        子文本替换 (名, "browser.", "browser_", , , 真)
        如果 (是否以 (名, "browser_") == 假)
        {
            名 = "browser_" + 名
        }
        返回 (名)
    }
    方法 应同步等待 <公开 静态 类型 = 逻辑型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        如果 (参数JSON.是否为空 () == 假)
        {
            如果 (yyjson取逻辑 (参数JSON, "async_only"))
            {
                返回 (假)
            }
            如果 (yyjson取逻辑 (参数JSON, "sync_wait"))
            {
                返回 (真)
            }
        }
        变量 规范名 <类型 = 文本型>
        规范名 = 规范化工具名 (方法名)
        如果 (规范名 == "browser_get_title" || 规范名 == "browser_evaluate" || 规范名 == "browser_console_eval")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_dom_query" || 规范名 == "browser_dom_set_value" || 规范名 == "browser_dom_click")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_get_frames" || 规范名 == "browser_frame_names")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_fill_exists" || 规范名 == "browser_fill_attr_get")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_debugger_wait_paused" || 规范名 == "browser_debugger_last_paused" || 规范名 == "browser_debugger_inspect" || 规范名 == "browser_debugger_flow" || 规范名 == "browser_debugger_script_source" || 规范名 == "browser_debugger_auto")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_debugger_enable" || 规范名 == "browser_debugger_set_breakpoint" || 规范名 == "browser_debugger_evaluate" || 规范名 == "browser_debugger_stack" || 规范名 == "browser_debugger_resume" || 规范名 == "browser_debugger_pause" || 规范名 == "browser_debugger_step_over" || 规范名 == "browser_debugger_step_into" || 规范名 == "browser_debugger_step_out" || 规范名 == "browser_debugger_script_source")
        {
            返回 (真)
        }
        如果 (规范名 == "browser_get_text" || 规范名 == "browser_dom_get_html")
        {
            如果 (参数JSON.是否为空 () == 假)
            {
                变量 sel <类型 = 文本型>
                sel = yyjson取文本 (参数JSON, "selector")
                如果 (sel != "")
                {
                    返回 (真)
                }
            }
            返回 (假)
        }
        返回 (假)
    }
    方法 取同步等待毫秒 <公开 静态 类型 = 整数>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        如果 (参数JSON.是否为空 () == 假)
        {
            变量 自定义 <类型 = 整数>
            自定义 = yyjson取整数 (参数JSON, "max_ms")
            如果 (自定义 > 0)
            {
                返回 (自定义)
            }
        }
        变量 规范名 <类型 = 文本型>
        规范名 = 规范化工具名 (方法名)
        如果 (规范名 == "browser_get_title" || 规范名 == "browser_evaluate" || 规范名 == "browser_console_eval")
        {
            返回 (同步等待_快读毫秒)
        }
        如果 (规范名 == "browser_dom_query" || 规范名 == "browser_dom_set_value" || 规范名 == "browser_dom_click")
        {
            返回 (同步等待_快读毫秒)
        }
        如果 (规范名 == "browser_fill_exists" || 规范名 == "browser_fill_attr_get")
        {
            返回 (同步等待_快读毫秒)
        }
        如果 (规范名 == "browser_debugger_flow")
        {
            返回 (60000)
        }
        如果 (规范名 == "browser_debugger_auto")
        {
            返回 (300000)
        }
        如果 (规范名 == "browser_debugger_wait_paused")
        {
            返回 (45000)
        }
        如果 (规范名 == "browser_debugger_inspect" || 规范名 == "browser_debugger_script_source" || 规范名 == "browser_debugger_enable" || 规范名 == "browser_debugger_set_breakpoint" || 规范名 == "browser_debugger_evaluate" || 规范名 == "browser_debugger_stack" || 规范名 == "browser_debugger_resume" || 规范名 == "browser_debugger_pause" || 规范名 == "browser_debugger_step_over" || 规范名 == "browser_debugger_step_into" || 规范名 == "browser_debugger_step_out")
        {
            返回 (20000)
        }
        返回 (同步等待_默认毫秒)
    }
    方法 取工具结果键名 <公开 静态 类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    {
        变量 规范名 <类型 = 文本型>
        规范名 = 规范化工具名 (方法名)
        如果 (规范名 == "browser_get_title")
        {
            返回 ("title")
        }
        如果 (规范名 == "browser_get_source")
        {
            返回 ("source")
        }
        如果 (规范名 == "browser_get_text")
        {
            返回 ("text")
        }
        如果 (规范名 == "browser_dom_get_html")
        {
            返回 ("html")
        }
        如果 (规范名 == "browser_get_frames")
        {
            返回 ("frames")
        }
        如果 (规范名 == "browser_frame_names")
        {
            返回 ("names")
        }
        如果 (规范名 == "browser_fill_exists")
        {
            返回 ("exists")
        }
        如果 (规范名 == "browser_fill_attr_get")
        {
            返回 ("value")
        }
        返回 ("result")
    }
    方法 同步等待异步任务 <公开 静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    参数 最大毫秒 <类型 = 整数>
    参数 轮询间隔毫秒 <类型 = 整数 @默认值 = 同步等待_轮询间隔>
    {
        如果 (任务ID == "")
        {
            返回 ("")
        }
        变量 截止 <类型 = 长整数>
        截止 = 取启动时间 () + 最大毫秒
        判断循环 (取启动时间 () < 截止)
        {
            如果 (MCP正在关闭)
            {
                返回 ("")
            }
            如果 (MCP_编排分派.工作流应停止)
            {
                返回 (构建标准失败JSON ("工作流已停止"))
            }
            变量 存储结果 <类型 = 文本型>
            MCP执行锁.解锁 ()
            存储结果 = 查询异步结果 (任务ID)
            MCP执行锁.加锁 ()
            如果 (存储结果 != "")
            {
                变量 结果解析 <类型 = YYJSON只读对象类>
                如果 (结果解析.创建自文本 (存储结果))
                {
                    如果 (结果解析.取逻辑值 ("_waiting") == 假)
                    {
                        返回 (存储结果)
                    }
                }
                否则
                {
                    返回 (存储结果)
                }
            }
            MCP执行锁.解锁 ()
            延时 (轮询间隔毫秒)
            MCP执行锁.加锁 ()
        }
        返回 ("")
    }
    # P0-3: JS 回调 message 语义失败检测 (dom_click / dom_set_value 等)
    方法 JS消息是否表示失败 <公开 静态 类型 = 逻辑型>
    参数 消息文本 <类型 = 文本型>
    参数 工具名 <类型 = 文本型 @默认值 = "">
    {
        如果 (消息文本 == "")
        {
            返回 (假)
        }
        变量 规范名 <类型 = 文本型>
        规范名 = 规范化工具名 (工具名)
        如果 (规范名 == "browser_fill_exists")
        {
            返回 (假)
        }
        如果 (是否以 (消息文本, "Error:") || 是否以 (消息文本, "Error: "))
        {
            返回 (真)
        }
        如果 (寻找文本 (消息文本, "element not found", 0, 假) != -1)
        {
            返回 (真)
        }
        如果 (消息文本 == "null" && (规范名 == "browser_dom_query" || 规范名 == "browser_dom_get_html"))
        {
            返回 (真)
        }
        如果 (是否以 (消息文本, "{"))
        {
            变量 inner <类型 = YYJSON只读对象类>
            如果 (inner.创建自文本 (消息文本))
            {
                如果 (inner.取逻辑值 ("ok") == 假)
                {
                    返回 (真)
                }
                如果 (inner.取逻辑值 ("found") == 假 && 规范名 == "browser_wait")
                {
                    返回 (假)
                }
            }
        }
        返回 (假)
    }
    # P0-1: 统一 async 等待 — 含 browser_wait(_waiting) 与 mcp_result 状态机推进
    方法 内容是否JSON结构 <公开 静态 类型 = 逻辑型>
    参数 文本 <类型 = 文本型>
    {
        如果 (文本 == "")
        {
            返回 (假)
        }
        变量 验证对象 <类型 = YYJSON只读对象类>
        如果 (是否以 (文本, "{"))
        {
            返回 (验证对象.创建自文本 (文本))
        }
        如果 (是否以 (文本, "["))
        {
            变量 包装 <类型 = 文本型>
            包装 = "{\"_a\":" + 文本 + "}"
            如果 (验证对象.创建自文本 (包装) == 假)
            {
                返回 (假)
            }
            返回 (验证对象.取数组 ("_a").是否为空对象 () == 假)
        }
        返回 (假)
    }
    方法 等待异步任务完成 <公开 静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    参数 最大毫秒 <类型 = 整数>
    参数 命令ID前缀 <类型 = 文本型>
    参数 工具名 <类型 = 文本型 @默认值 = "">
    参数 轮询间隔毫秒 <类型 = 整数 @默认值 = 同步等待_轮询间隔>
    {
        如果 (任务ID == "")
        {
            返回 ("")
        }
        变量 开始 <类型 = 长整数>
        开始 = 取启动时间 ()
        变量 截止 <类型 = 长整数>
        截止 = 开始 + 最大毫秒
        变量 轮询序 <类型 = 整数 值 = 0>
        判断循环 (取启动时间 () < 截止)
        {
            如果 (MCP正在关闭)
            {
                返回 ("")
            }
            如果 (MCP_编排分派.工作流应停止)
            {
                返回 (构建标准失败JSON ("工作流已停止"))
            }
            变量 存储结果 <类型 = 文本型>
            存储结果 = 查询异步结果 (任务ID)
            如果 (存储结果 != "")
            {
                变量 存储解析 <类型 = YYJSON只读对象类>
                如果 (存储解析.创建自文本 (存储结果))
                {
                    如果 (存储解析.取逻辑值 ("_waiting") == 假)
                    {
                        返回 (存储结果)
                    }
                }
                否则
                {
                    返回 (存储结果)
                }
            }
            轮询序 = 轮询序 + 1
            变量 pollParams <类型 = YYJSON对象类>
            pollParams.创建自文本 ("{}")
            pollParams.加入文本成员 ("request_id", 任务ID)
            pollParams.加入逻辑值成员 ("consume", 假)
            变量 pollParse <类型 = YYJSON只读对象类>
            pollParse.创建自文本 (pollParams.到可读文本 (YYJSON格式化选项.压缩))
            变量 pollResult <类型 = 文本型>
            pollResult = 执行浏览器命令 (命令ID前缀 + "_mr" + 到文本 (轮询序), "mcp_result", pollParse)
            变量 pollObj <类型 = YYJSON只读对象类>
            如果 (pollObj.创建自文本 (pollResult))
            {
                变量 pollSuccess <类型 = 逻辑型>
                pollSuccess = pollObj.取逻辑值 ("success")
                变量 pollErr <类型 = 文本型>
                pollErr = yyjson取文本 (pollObj, "error")
                如果 (pollSuccess == 假)
                {
                    如果 (寻找文本 (pollErr, "未找到任务结果", 0, 假) != -1)
                    {
                        延时 (轮询间隔毫秒)
                        到循环尾
                    }
                    返回 (pollResult)
                }
                如果 (pollObj.取逻辑值 ("_waiting"))
                {
                    延时 (轮询间隔毫秒)
                    到循环尾
                }
                变量 pollMsg <类型 = 文本型>
                pollMsg = yyjson取文本 (pollObj, "message")
                如果 (寻找文本 (pollMsg, "等待中", 0, 假) != -1)
                {
                    延时 (轮询间隔毫秒)
                    到循环尾
                }
                存储结果 = 查询异步结果 (任务ID)
                如果 (存储结果 != "")
                {
                    变量 再解析 <类型 = YYJSON只读对象类>
                    如果 (再解析.创建自文本 (存储结果) && 再解析.取逻辑值 ("_waiting") == 假)
                    {
                        返回 (存储结果)
                    }
                }
                返回 (pollResult)
            }
            延时 (轮询间隔毫秒)
        }
        返回 ("")
    }
    方法 将异步结果转为命令响应 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 存储JSON <类型 = 文本型>
    参数 结果键名 <类型 = 文本型>
    参数 已等待毫秒 <类型 = 整数 @默认值 = 0>
    参数 工具名 <类型 = 文本型 @默认值 = "">
    {
        变量 结果解析 <类型 = YYJSON只读对象类>
        如果 (结果解析.创建自文本 (存储JSON) == 假)
        {
            返回 (命令失败 (命令ID, "异步结果解析失败"))
        }
        如果 (结果解析.取逻辑值 ("success") == 假)
        {
            变量 err <类型 = 文本型>
            err = yyjson取文本 (结果解析, "error")
            如果 (err == "")
            {
                err = yyjson取文本 (结果解析, "result")
            }
            如果 (err == "")
            {
                err = yyjson取文本 (结果解析, "message")
            }
            如果 (err == "")
            {
                err = "异步任务失败"
            }
            变量 规范工具 <类型 = 文本型>
            规范工具 = 规范化工具名 (工具名)
            如果 (规范工具 == "")
            {
                规范工具 = 规范化工具名 (当前命令方法名)
            }
            如果 (规范工具 == "browser_debugger_set_breakpoint" && 寻找文本 (err, "already exists", 0, 假) != -1)
            {
                // 断点已存在视为成功
            }
            否则
            {
                返回 (命令失败 (命令ID, err))
            }
        }
        变量 内容 <类型 = 文本型>
        内容 = yyjson取文本 (结果解析, "message")
        如果 (内容 == "")
        {
            内容 = yyjson取文本 (结果解析, "result")
        }
        如果 (内容 == "")
        {
            内容 = yyjson取文本 (结果解析, "error")
        }
        变量 语义工具 <类型 = 文本型>
        语义工具 = 工具名
        如果 (语义工具 == "")
        {
            语义工具 = 当前命令方法名
        }
        如果 (JS消息是否表示失败 (内容, 语义工具))
        {
            返回 (命令失败 (命令ID, 内容))
        }
        如果 (内容是否JSON结构 (内容))
        {
            变量 响应头 <类型 = YYJSON对象类>
            响应头.创建自文本 ("{}")
            响应头.加入文本成员 ("id", 命令ID)
            响应头.加入逻辑值成员 ("success", 真)
            响应头.加入逻辑值成员 ("_sync_waited", 真)
            如果 (已等待毫秒 > 0)
            {
                响应头.加入整数成员 ("_elapsed_ms", 已等待毫秒)
            }
            变量 头JSON <类型 = 文本型>
            头JSON = 响应头.到可读文本 (YYJSON格式化选项.压缩)
            变量 响应JSON <类型 = 文本型>
            响应JSON = 取文本左边 (头JSON, 取文本长度 (头JSON) - 1)
            如果 (结果键名 != "")
            {
                响应JSON = 响应JSON + ",\"" + 结果键名 + "\":" + 内容
            }
            响应JSON = 响应JSON + ",\"message\":\"" + JSON转义文本 (内容) + "\""
            如果 (结果键名 == "result" || 结果键名 == "")
            {
                响应JSON = 响应JSON + ",\"result\":" + 内容
            }
            响应JSON = 响应JSON + "}"
            返回 (响应JSON)
        }
        变量 响应 <类型 = YYJSON对象类>
        响应.创建自文本 ("{}")
        响应.加入文本成员 ("id", 命令ID)
        响应.加入逻辑值成员 ("success", 真)
        响应.加入逻辑值成员 ("_sync_waited", 真)
        如果 (已等待毫秒 > 0)
        {
            响应.加入整数成员 ("_elapsed_ms", 已等待毫秒)
        }
        如果 (结果键名 != "")
        {
            响应.加入文本成员 (结果键名, 内容)
        }
        响应.加入文本成员 ("message", 内容)
        如果 (结果键名 == "result" || 结果键名 == "")
        {
            响应.加入文本成员 ("result", 内容)
        }
        返回 (响应.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 尝试同步跟随异步响应 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 响应JSON <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    参数 强制同步 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 响应解析 <类型 = YYJSON只读对象类>
        如果 (响应解析.创建自文本 (响应JSON) == 假)
        {
            返回 (响应JSON)
        }
        如果 (响应解析.取逻辑值 ("_async") == 假 || 响应解析.取逻辑值 ("_sync_waited"))
        {
            返回 (响应JSON)
        }
        如果 (强制同步 == 假)
        {
            如果 (参数JSON.是否为空 () == 假 && yyjson取逻辑 (参数JSON, "async_only"))
            {
                返回 (响应JSON)
            }
            如果 (应同步等待 (方法名, 参数JSON) == 假)
            {
                返回 (响应JSON)
            }
        }
        变量 任务ID <类型 = 文本型>
        任务ID = yyjson取文本 (响应解析, "task_id")
        如果 (任务ID == "")
        {
            返回 (响应JSON)
        }
        变量 开始 <类型 = 长整数>
        开始 = 取启动时间 ()
        变量 最大毫秒 <类型 = 整数>
        最大毫秒 = 取同步等待毫秒 (方法名, 参数JSON)
        变量 存储 <类型 = 文本型>
        MCP执行锁.解锁 ()
        存储 = 等待异步任务完成 (任务ID, 最大毫秒, 命令ID, 方法名)
        MCP执行锁.加锁 ()
        如果 (存储 == "")
        {
            如果 (MCP正在关闭)
            {
                返回 (命令失败 (命令ID, "MCP 服务正在关闭"))
            }
            返回 (命令失败 (命令ID, "操作超时(" + 到文本 (最大毫秒) + "ms) | task_id=" + 任务ID + " | 可设 async_only:true 改异步"))
        }
        返回 (将异步结果转为命令响应 (命令ID, 存储, 取工具结果键名 (方法名), (整数)(取启动时间 () - 开始), 方法名))
    }
    方法 命令成功_异步 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    参数 消息 <类型 = 文本型>
    参数 预估耗时毫秒 <类型 = 整数 @默认值 = 0>
    {
        如果 (应同步等待 (当前命令方法名, 当前命令参数JSON))
        {
            变量 开始 <类型 = 长整数>
            开始 = 取启动时间 ()
            变量 最大毫秒 <类型 = 整数>
            最大毫秒 = 取同步等待毫秒 (当前命令方法名, 当前命令参数JSON)
            变量 存储 <类型 = 文本型>
            MCP执行锁.解锁 ()
            存储 = 等待异步任务完成 (任务ID, 最大毫秒, 命令ID, 当前命令方法名)
            MCP执行锁.加锁 ()
            如果 (存储 != "")
            {
                返回 (将异步结果转为命令响应 (命令ID, 存储, 取工具结果键名 (当前命令方法名), (整数)(取启动时间 () - 开始), 当前命令方法名))
            }
            如果 (MCP正在关闭)
            {
                返回 (命令失败 (命令ID, "MCP 服务正在关闭"))
            }
            返回 (命令失败 (命令ID, "操作超时(" + 到文本 (最大毫秒) + "ms) | task_id=" + 任务ID + " | 可设 async_only:true 改异步"))
        }
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 真)
        对象.加入逻辑值成员 ("_async", 真)
        对象.加入文本成员 ("task_id", 任务ID)
        对象.加入文本成员 ("message", 消息)
        如果 (预估耗时毫秒 > 0)
        {
            对象.加入整数成员 ("estimated_ms", 预估耗时毫秒)
        }
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== 全部异步执行 — 永不阻塞, 结果存入磁盘缓存 ==========
    # 任务提交 → CEF回调触发 → 存储异步结果(内存+磁盘) → 客户端通过mcp_result查询
    方法 提交异步JS任务 <公开 静态 类型 = 文本型>
    参数 browser <类型 = 类_FBrowser_浏览器>
    参数 code <类型 = 文本型>
    参数 任务ID <类型 = 文本型 @默认值 = "">
    {
        变量 安全框架 <类型 = 类_FBrowser_框架>
        安全框架 = 取安全主框架 (browser)
        如果 (安全框架.是否为空 () || 安全框架.是否有效 () == 假)
        {
            返回 (构建简单错误JSON (错误_主框架无效))
        }
        // 全部异步: 自动生成taskID
        如果 (任务ID == "")
        {
            任务ID = 生成异步任务ID ()
        }
        异步执行JS (browser, code, 任务ID)
        返回 (构建异步提交JSON (任务ID))
    }
