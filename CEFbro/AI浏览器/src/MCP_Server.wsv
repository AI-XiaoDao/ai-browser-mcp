    # ======== 需要刷新生效的响应包装 ==========
    # 指纹/代理/内核开关等必须在页面刷新后生效
    # 给出明确的下一步操作提示
    常量 提示_需要刷新 <公开 类型 = 文本型 值 = "设置已应用! 注意: 指纹/代理/内核变更需要刷新页面才能生效, 请调用 browser_reload 或 browser_navigate">
    方法 响应_需要刷新 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("id", 命令ID)
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息 + " | " + 提示_需要刷新)
        对象.加入逻辑值成员 ("needs_reload", 真)
        对象.加入文本成员 ("_hint", "设置将在下次刷新/导航后生效")
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    # ======== 批量操作处理 ==========
    方法 处理_批量操作 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 命令数组 <类型 = YYJSON只读数组类>
        命令数组 = 参数JSON.取数组 ("commands")
        如果 (命令数组.是否为空对象 ())
        {
            命令数组 = 参数JSON.取数组 ("ops")
        }
        // 兼容: commands 为 JSON 字符串 || 整包数组文本
        如果 (命令数组.是否为空对象 ())
        {
            变量 批量JSON文本 <类型 = 文本型>
            批量JSON文本 = yyjson取JSON文本 (参数JSON, "commands")
            如果 (批量JSON文本 == "")
            {
                批量JSON文本 = yyjson取JSON文本 (参数JSON, "ops")
            }
            如果 (批量JSON文本 == "")
            {
                返回 (命令失败 (命令ID, "batch需要commands参数: [{name, arguments}, ...]"))
            }
            如果 (是否以 (批量JSON文本, "["))
            {
                批量JSON文本 = "{\"commands\":" + 批量JSON文本 + "}"
            }
            变量 批量解析 <类型 = YYJSON只读对象类>
            如果 (批量解析.创建自文本 (批量JSON文本) == 假)
            {
                返回 (命令失败 (命令ID, "commands JSON解析失败"))
            }
            命令数组 = 批量解析.取数组 ("commands")
            如果 (命令数组.是否为空对象 ())
            {
                命令数组 = 批量解析.取数组 ("ops")
            }
        }
        如果 (命令数组.是否为空对象 ())
        {
            返回 (命令失败 (命令ID, "commands解析失败,支持格式:[{name,arguments},...]或{commands:[...]}"))
        }
        变量 数组成员数 <类型 = 整数>
        数组成员数 = (整数)命令数组.取成员数 ()
        如果 (数组成员数 > 批量命令最大条数)
        {
            返回 (命令失败 (命令ID, "batch 命令过多: " + 到文本 (数组成员数) + " > 上限 " + 到文本 (批量命令最大条数)))
        }
        变量 总成功数 <类型 = 整数 值 = 0>
        变量 总失败数 <类型 = 整数 值 = 0>
        变量 批量跟随异步 <类型 = 逻辑型>
        批量跟随异步 = 真
        如果 (参数JSON.是否为空 () == 假 && yyjson取逻辑 (参数JSON, "async_only"))
        {
            批量跟随异步 = 假
        }
        计次循环 (数组成员数)
        {
            变量 当前命令 <类型 = YYJSON只读对象类>
            当前命令 = 命令数组.取成员 (取循环索引 ())
            如果 (当前命令.是否为空 () == 假)
            {
                变量 子命令名 <类型 = 文本型>
                子命令名 = yyjson取文本 (当前命令, "name")
                变量 子参数解析 <类型 = YYJSON只读对象类>
                子参数解析 = yyjson取对象成员 (当前命令, "arguments")
                如果 (子参数解析.是否为空 ())
                {
                    变量 子参数JSON文本 <类型 = 文本型>
                    子参数JSON文本 = yyjson取JSON文本 (当前命令, "arguments")
                    如果 (子参数JSON文本 == "")
                    {
                        子参数JSON文本 = "{}"
                    }
                    子参数解析.创建自文本 (子参数JSON文本)
                }
                变量 子结果 <类型 = 文本型>
                子结果 = 执行浏览器命令 (命令ID + "_" + 到文本 (取循环索引 ()), 子命令名, 子参数解析)
                如果 (批量跟随异步)
                {
                    变量 子预解析 <类型 = YYJSON只读对象类>
                    如果 (子预解析.创建自文本 (子结果) && 子预解析.取逻辑值 ("_sync_waited") == 假)
                    {
                        子结果 = 尝试同步跟随异步响应 (命令ID + "_" + 到文本 (取循环索引 ()), 子结果, 子命令名, 子参数解析, 真)
                    }
                }
                变量 子解析 <类型 = YYJSON只读对象类>
                如果 (子解析.创建自文本 (子结果))
                {
                    如果 (子解析.取逻辑值 ("success"))
                    {
                        总成功数 = 总成功数 + 1
                    }
                    否则
                    {
                        总失败数 = 总失败数 + 1
                    }
                }
                否则
                {
                    总失败数 = 总失败数 + 1
                }
            }
        }
        变量 汇总对象 <类型 = YYJSON对象类>
        汇总对象.创建自文本 ("{}")
        汇总对象.加入逻辑值成员 ("success", 总失败数 == 0)
        汇总对象.加入整数成员 ("total", 数组成员数)
        汇总对象.加入整数成员 ("success_count", 总成功数)
        汇总对象.加入整数成员 ("failure_count", 总失败数)
        返回 (命令成功_原始JSON (命令ID, 汇总对象.到可读文本 (YYJSON格式化选项.压缩), 总失败数 == 0))
    }
    常量 HTTP_JSON内容类型 <公开 类型 = 文本型 值 = "application/json; charset=utf-8">
    常量 错误_主框架无效 <公开 类型 = 文本型 值 = "主框架无效 | 页面可能尚未加载完成, 请先 navigate 并等待2-3秒后重试">
    # ======== JSON/UTF-8 统一辅助 (yyjson 转义, 禁止手工拼接未转义字符串) ========
    方法 是否为合法JSON文档 <公开 静态 类型 = 逻辑型>
    参数 文本 <类型 = 文本型>
    {
        如果 (文本 == "")
        {
            返回 (假)
        }
        变量 对象 <类型 = YYJSON只读对象类>
        如果 (对象.创建自文本 (文本))
        {
            返回 (真)
        }
        如果 (是否以 (文本, "["))
        {
            变量 包装 <类型 = 文本型>
            包装 = "{\"_a\":" + 文本 + "}"
            返回 (对象.创建自文本 (包装))
        }
        返回 (假)
    }
    方法 提取JSON对象体内 <公开 静态 类型 = 文本型>
    参数 对象JSON <类型 = 文本型>
    {
        变量 长度 <类型 = 整数>
        长度 = 取文本长度 (对象JSON)
        如果 (长度 < 2 || 取文本左边 (对象JSON, 1) != "{")
        {
            返回 (对象JSON)
        }
        返回 (取文本右边 (取文本左边 (对象JSON, 长度 - 1), 长度 - 2))
    }
    方法 构建JSONRPC头部前缀 <公开 静态 类型 = 文本型>
    参数 请求ID <类型 = 文本型>
    {
        变量 头对象 <类型 = YYJSON对象类>
        头对象.创建自文本 ("{}")
        如果 (紧凑响应模式 == 假)
        {
            头对象.加入文本成员 ("jsonrpc", "2.0")
        }
        如果 (请求ID != "")
        {
            头对象.加入文本成员 ("id", 请求ID)
        }
        变量 头JSON <类型 = 文本型>
        头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
        返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1))
    }
    方法 构建简单错误JSON <公开 静态 类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建标准失败JSON <公开 静态 类型 = 文本型>
    参数 错误消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 假)
        对象.加入文本成员 ("error", 错误消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建异步提交JSON <公开 静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("_async", 真)
        对象.加入文本成员 ("task_id", 任务ID)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建带数据字段JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 数据片段 <类型 = 文本型>
    {
        返回 (构建命令嵌套JSON (命令ID, 是否成功, "data", 数据片段))
    }
    方法 构建标准成功JSON <公开 静态 类型 = 文本型>
    参数 消息 <类型 = 文本型>
    {
        变量 对象 <类型 = YYJSON对象类>
        对象.创建自文本 ("{}")
        对象.加入逻辑值成员 ("success", 真)
        对象.加入文本成员 ("message", 消息)
        返回 (对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 构建命令嵌套JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型>
    参数 嵌套键名 <类型 = 文本型>
    参数 嵌套JSON片段 <类型 = 文本型>
    {
        变量 头对象 <类型 = YYJSON对象类>
        头对象.创建自文本 ("{}")
        头对象.加入文本成员 ("id", 命令ID)
        头对象.加入逻辑值成员 ("success", 是否成功)
        变量 头JSON <类型 = 文本型>
        头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
        如果 (是否为合法JSON文档 (嵌套JSON片段))
        {
            返回 (取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"" + 嵌套键名 + "\":" + 嵌套JSON片段 + "}")
        }
        变量 完整 <类型 = YYJSON对象类>
        完整.创建自文本 ("{}")
        完整.加入文本成员 ("id", 命令ID)
        完整.加入逻辑值成员 ("success", 是否成功)
        完整.加入文本成员 (嵌套键名, 嵌套JSON片段)
        返回 (完整.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 命令成功_原始JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 JSON片段 <类型 = 文本型>
    参数 是否成功 <类型 = 逻辑型 @默认值 = 真>
    {
        返回 (构建带数据字段JSON (命令ID, 是否成功, JSON片段))
    }
    # ======== CDP命令执行 ==========
    方法 执行CDP命令_带参数 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 cdpMethod <类型 = 文本型>
    参数 paramsJSON文本 <类型 = 文本型>
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器 ()
        如果 (browser.是否为空 () == 假)
        {
            变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
            vip_ctrl = browser.取VIP控制器 ()
            如果 (vip_ctrl.是否为空 () == 假)
            {
                变量 params_value <类型 = 类_FBrowser_值>
                params_value = FBrowser_Parser_解析JSON (paramsJSON文本, JSON解析.RFC)
                变量 params_dict <类型 = 类_FBrowser_字典值>
                params_dict.创建 ()
                如果 (params_value.是否为空 () == 假)
                {
                    params_dict = params_value.取字典值 ()
                }
                // 自动注册DevTools观察者(首次使用时)
                确保CDP观察者已注册 ()
                // 清除同 task_id 旧结果，避免同步等待误读上一轮 CDP 缓存
                删除异步结果 (命令ID)
                // 分配CDP消息ID并记录映射:CDP消息ID → MCP请求ID
                变量 cdpMsgId <类型 = 整数>
                cdpMsgId = 分配CDP消息ID ()
                记录CDP请求映射 (cdpMsgId, 命令ID, cdpMethod)
                vip_ctrl.开发者消息_执行方法 (cdpMsgId, cdpMethod, params_dict)
                变量 异步对象 <类型 = YYJSON对象类>
                异步对象.创建自文本 ("{}")
                异步对象.加入文本成员 ("id", 命令ID)
                异步对象.加入逻辑值成员 ("success", 真)
                异步对象.加入逻辑值成员 ("_async", 真)
                异步对象.加入文本成员 ("task_id", 命令ID)
                异步对象.加入文本成员 ("message", "CDP已提交:" + cdpMethod)
                返回 (异步对象.到可读文本 (YYJSON格式化选项.压缩))
            }
            返回 (命令失败 (命令ID, 错误_VIP不可用))
        }
        返回 (命令失败 (命令ID, 错误_无浏览器))
    }
    方法 执行CDP命令 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 cdpMethod <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 params_text <类型 = 文本型>
        params_text = yyjson取JSON文本 (参数JSON, "params")
        如果 (params_text == "")
        {
            params_text = "{}"
        }
        返回 (执行CDP命令_带参数 (命令ID, cdpMethod, params_text))
    }
    # ======== CDP请求映射 (解决CDP结果不回传问题, v2.4 TTL清理) ==========
    变量 CDP消息计数器 <公开 静态 类型 = 整数 值 = 0>
    变量 CDP请求映射表 <公开 静态 类型 = 类_FBrowser_字典值>
    变量 CDP观察者已注册 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 持久CDP观察者 <公开 静态 类型 = 类_FBrowser_事件智能指针>
    常量 CDP映射TTL毫秒 <公开 类型 = 整数 值 = 300000 注释 = "5分钟过期">
    变量 CDP映射清理计数 <公开 静态 类型 = 整数 值 = 0>
    方法 确保CDP观察者已注册 <公开 静态>
    {
        如果 (MCP正在关闭 || CDP观察者已注册)
        {
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器 ()
        如果 (browser.是否为空 () == 假)
        {
            变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
            vip_ctrl = browser.取VIP控制器 ()
            如果 (vip_ctrl.是否为空 () == 假)
            {
                持久CDP观察者.创建 (类_MCP_DevTools观察者)
                vip_ctrl.开发者消息_启用监管者事件 (持久CDP观察者)
                CDP观察者已注册 = 真
                CDP附着浏览器ID = browser.取ID ()
                调试输出 ("[MCP] CDP DevTools观察者已自动注册")
            }
        }
    }
    方法 注销CDP观察者 <公开 静态>
    {
        如果 (CDP观察者已注册 == 假)
        {
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取浏览器ByID (CDP附着浏览器ID)
        如果 (browser.是否为空 ())
        {
            browser = 取主浏览器 ()
        }
        如果 (browser.是否为空 () == 假 && browser.是否已关闭 () == 假)
        {
            变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
            vip_ctrl = browser.取VIP控制器 ()
            如果 (vip_ctrl.是否为空 () == 假)
            {
                vip_ctrl.开发者消息_关闭监管者事件 ()
            }
        }
        CDP观察者已注册 = 假
        CDP附着浏览器ID = 0
        调试输出 ("[MCP] CDP DevTools观察者已注销")
    }
    方法 等待MCP命令排空 <公开 静态 注释 = "关闭前阻塞直到当前浏览器命令执行完毕">
    {
        MCP执行锁.加锁 ()
        MCP执行锁.解锁 ()
    }
    方法 缓存数据库可用 <公开 静态 类型 = 逻辑型>
    {
        返回 (缓存数据库已打开 && MCP正在关闭 == 假)
    }
    方法 加入持久V8扩展 <公开 静态>
    参数 注入标识 <类型 = 文本型>
    参数 安全code <类型 = 文本型>
    参数 类型后缀 <类型 = 文本型>
    {
        变量 条目 <类型 = 文本型>
        条目 = 注入标识 + "|" + 安全code + "|" + 类型后缀
        变量 前缀长 <类型 = 整数>
        前缀长 = 取文本长度 (注入标识) + 1
        变量 idx <类型 = 整数>
        计次循环 (持久V8扩展列表.取成员数 ())
        {
            idx = 取循环索引 ()
            变量 现有项 <类型 = 文本型>
            现有项 = 持久V8扩展列表.取成员 (idx)
            如果 (取文本长度 (现有项) >= 前缀长 && 取文本左边 (现有项, 前缀长) == 注入标识 + "|")
            {
                持久V8扩展列表.删除成员 (idx)
                跳出循环
            }
        }
        持久V8扩展列表.加入成员 (条目)
        判断循环 (持久V8扩展列表.取成员数 () > 持久V8扩展上限)
        {
            持久V8扩展列表.删除成员 (0)
        }
    }
    方法 清空持久V8扩展 <公开 静态>
    {
        判断循环 (持久V8扩展列表.取成员数 () > 0)
        {
            持久V8扩展列表.删除成员 (0)
        }
    }
    方法 分配CDP消息ID <公开 静态 类型 = 整数>
    {
        CDP消息计数器 = CDP消息计数器 + 1
        // 防溢出: int 上限约21亿, 回绕到1（0保留为无效值）
        如果 (CDP消息计数器 <= 0)
        {
            CDP消息计数器 = 1
            清空CDP请求映射 ()
            调试输出 ("[MCP] CDP消息ID已回绕, 映射表已重置")
        }
        返回 (CDP消息计数器)
    }
    方法 记录CDP请求映射 <公开 静态>
    参数 cdpMsgId <类型 = 整数>
    参数 mcp请求ID <类型 = 文本型>
    参数 cdpMethod <类型 = 文本型>
    {
        异步缓存锁.加锁 ()
        如果 (CDP请求映射表.是否为空对象 () || CDP请求映射表.是否为空 ())
        {
            CDP请求映射表.创建 ()
        }
        CDP请求映射表.置文本值 (到文本 (cdpMsgId), mcp请求ID)
        CDP请求映射表.置文本值 ("method_" + 到文本 (cdpMsgId), cdpMethod)
        CDP请求映射表.置整数值 ("ts_" + 到文本 (cdpMsgId), (整数)取启动时间 ())
        异步缓存锁.解锁 ()
        // 每 N 次CDP请求触发一次过期清理
        CDP映射清理计数 = CDP映射清理计数 + 1
        如果 (CDP映射清理计数 >= CDP映射清理间隔)
        {
            清理过期CDP映射 ()
        }
    }
    方法 清空CDP请求映射 <公开 静态>
    {
        异步缓存锁.加锁 ()
        CDP请求映射表.创建 ()
        CDP映射清理计数 = 0
        异步缓存锁.解锁 ()
    }
    # 清理超过TTL的CDP映射(无响应的CDP请求会永久残留, 需定期清理)
    方法 清理过期CDP映射 <公开 静态>
    {
        异步缓存锁.加锁 ()
        CDP映射清理计数 = 0
        如果 (CDP请求映射表.是否为空对象 () == 假 && CDP请求映射表.是否为空 () == 假)
        {
            变量 当前时间 <类型 = 长整数>
            当前时间 = 取启动时间 ()
            变量 过期阈值 <类型 = 长整数>
            过期阈值 = 当前时间 - CDP映射TTL毫秒
            // 从最大消息ID向下扫描, 清理过期条目
            变量 maxID <类型 = 整数>
            maxID = CDP消息计数器
            如果 (maxID <= 0)
            {
                maxID = 0
            }
            变量 scanLimit <类型 = 整数>
            scanLimit = maxID + 1
            如果 (scanLimit <= 0 || scanLimit > 100000)
            {
                scanLimit = 100000  // 防溢出/死循环: 最多扫描10万条
            }
            变量 cleaned <类型 = 整数 值 = 0>
            计次循环 (scanLimit)
            {
                变量 cid <类型 = 整数>
                cid = maxID - 取循环索引 ()
                变量 ts <类型 = 整数>
                ts = CDP请求映射表.取整数值 ("ts_" + 到文本 (cid))
                如果 (ts > 0 && ts < (整数)过期阈值)
                {
                    CDP请求映射表.移除 (到文本 (cid))
                    CDP请求映射表.移除 ("method_" + 到文本 (cid))
                    CDP请求映射表.移除 ("ts_" + 到文本 (cid))
                    cleaned = cleaned + 1
                }
            }
            如果 (cleaned > 0)
            {
                调试输出 ("[MCP] CDP映射清理:", cleaned, "条过期")
            }
        }
        异步缓存锁.解锁 ()
    }
    # 将全局持久配置(代理/缩放/静音)应用到指定浏览器, 新浏览器创建时调用
    方法 应用持久配置到浏览器 <公开 静态>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        如果 (持久代理地址 != "")
        {
            浏览器.设置代理 (持久代理地址, 持久代理账号, 持久代理密码)
        }
        如果 (持久缩放级别 > 0)
        {
            浏览器.置缩放级别 (持久缩放级别)
        }
        浏览器.置页面静音 (持久静音状态)
    }
    # 持久 inject: 浏览器进程在框架载入时执行 (规避渲染进程静态列表不可见 + 火山跳过 mid-file 方法)
    方法 应用持久V8到框架 <公开 静态>
    参数 框架 <类型 = 类_FBrowser_框架>
    {
        如果 (框架.是否为空 () || 持久V8扩展列表.取成员数 () == 0)
        {
            返回
        }
        变量 已见标识 <类型 = 文本型 值 = "\n">
        变量 总数 <类型 = 整数>
        总数 = 持久V8扩展列表.取成员数 ()
        计次循环 (总数)
        {
            变量 idx <类型 = 整数>
            idx = 总数 - 1 - 取循环索引 ()
            变量 注入项 <类型 = 文本型>
            注入项 = 持久V8扩展列表.取成员 (idx)
            如果 (注入项 == "")
            {
                到循环尾
            }
            变量 parts <类型 = 文本数组类>
            分割文本 (注入项, "|", parts, 真, 假)
            如果 (parts.取成员数 () < 3)
            {
                到循环尾
            }
            变量 extName <类型 = 文本型>
            extName = parts.取成员 (0)
            如果 (寻找文本 (已见标识, "\n" + extName + "\n", , 假) != -1)
            {
                到循环尾
            }
            已见标识 = 已见标识 + extName + "\n"
            变量 extCode <类型 = 文本型>
            extCode = parts.取成员 (1)
            变量 extType <类型 = 文本型>
            extType = parts.取成员 (2)
            子文本替换 (extCode, "{PIPE}", "|", , , 假)
            子文本替换 (extCode, "{PIPE_ESC}", "{PIPE}", , , 假)
            如果 (extType == "js" || extType == "handler")
            {
                框架.执行JS代码 (extCode)
            }
        }
    }
    方法 处理CDP响应 <公开 静态>
    参数 消息ID <类型 = 整数>
    参数 成功 <类型 = 逻辑型>
    参数 结果指针 <类型 = 变整数>
    参数 结果大小 <类型 = 整数>
    {
        // 从CDP映射表提取请求信息(锁保护, 与记录CDP请求映射配对)
        // v2.4: 单次持锁完成提取+清理, 避免双重加锁
        变量 mcp请求ID <类型 = 文本型>
        变量 cdpMethod <类型 = 文本型>
        mcp请求ID = ""
        cdpMethod = ""
        异步缓存锁.加锁 ()
        如果 (CDP请求映射表.是否为空对象 () == 假 && CDP请求映射表.是否为空 () == 假)
        {
            mcp请求ID = CDP请求映射表.取文本值 (到文本 (消息ID))
            cdpMethod = CDP请求映射表.取文本值 ("method_" + 到文本 (消息ID))
            // 清理映射: 移除条目防止字典无限增长
            如果 (mcp请求ID != "")
            {
                CDP请求映射表.移除 (到文本 (消息ID))
                CDP请求映射表.移除 ("method_" + 到文本 (消息ID))
                CDP请求映射表.移除 ("ts_" + 到文本 (消息ID))
            }
        }
        异步缓存锁.解锁 ()
        如果 (mcp请求ID != "")
        {
            变量 结果对象 <类型 = YYJSON对象类>
            结果对象.创建自文本 ("{}")
            结果对象.加入逻辑值成员 ("success", 成功)
            结果对象.加入整数成员 ("messageId", 消息ID)
            如果 (cdpMethod != "")
            {
                结果对象.加入文本成员 ("method", cdpMethod)
            }
            变量 结果文本 <类型 = 文本型>
            结果文本 = ""
            如果 (结果指针 != 0 && 结果大小 > 0)
            {
                变量 结果UTF8 <类型 = 字节集类>
                结果UTF8 = 指针到字节集 (结果指针, 结果大小)
                结果文本 = UTF8到文本 (结果UTF8)
                如果 (取文本长度 (结果文本) > 截断_CDP结果最大字节)
                {
                    结果文本 = 取文本左边 (结果文本, 截断_CDP结果最大字节) + "...[CDP结果已截断]"
                }
            }
            如果 (成功)
            {
                如果 (结果文本 != "")
                {
                    结果对象.加入文本成员 ("result", 结果文本)
                }
            }
            否则
            {
                如果 (结果文本 != "")
                {
                    结果对象.加入文本成员 ("error", 结果文本)
                }
            }
            // 存储结果(不在锁内调用, 避免锁嵌套)
            存储异步结果 (mcp请求ID, 结果对象.到可读文本 (YYJSON格式化选项.压缩))
        }
    }
    方法 存储CDPDevTools事件 <公开 静态>
    参数 事件方法名 <类型 = 文本型>
    参数 参数JSON <类型 = 文本型>
    {
        如果 (事件方法名 == "")
        {
            返回
        }
        变量 参数字段 <类型 = 文本型>
        参数字段 = 参数JSON
        如果 (参数字段 == "")
        {
            参数字段 = "{}"
        }
        // 缓存存裸 params，避免 wrapper.message 二次解析失败
        存储异步结果 ("cdp_event:" + 事件方法名, 参数字段)
        // CDP 事件高频, 仅保留 async 缓存供 wait/event 查询, 不写 event_log 防膨胀
    }
    # 部分 FBrowser 版本仅走 OnDevToolsMessage，不走 OnDevToolsEvent
    方法 处理DevTools原始消息 <公开 静态>
    参数 消息JSON <类型 = 文本型>
    {
        如果 (消息JSON == "")
        {
            返回
        }
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (消息JSON) == 假)
        {
            返回
        }
        变量 事件Method <类型 = 文本型>
        事件Method = yyjson取文本 (包装, "method")
        如果 (事件Method == "")
        {
            返回
        }
        变量 响应ID <类型 = 文本型>
        响应ID = yyjson取文本 (包装, "id")
        如果 (响应ID != "")
        {
            返回
        }
        变量 paramsJSON <类型 = 文本型>
        paramsJSON = yyjson取JSON文本 (包装, "params")
        存储CDPDevTools事件 (事件Method, paramsJSON)
    }
    # ======== Debugger/CDP 事件辅助 (断点命中 → 帧求值 → 继续) ==========
    方法 取CDP事件数据JSON <公开 静态 类型 = 文本型>
    参数 事件名 <类型 = 文本型>
    {
        变量 cache <类型 = 文本型>
        cache = 查询任务结果 ("cdp_event:" + 事件名)
        如果 (cache != "")
        {
            返回 (解包CDPDevTools事件JSON (cache))
        }
        变量 logs <类型 = 文本型>
        logs = 查询事件日志 ("cdp_event", 事件名, 0, 1)
        如果 (logs != "" && logs != "[]" && 是否以 (logs, "["))
        {
            返回 (解包CDPDevTools事件JSON (取文本中间 (logs, 2, 取文本长度 (logs) - 2)))
        }
        返回 ("")
    }
    # 存储格式为 {success,message,cdpEvent} 时解出 params；已是 callFrames 则原样返回
    方法 解包CDPDevTools事件JSON <公开 静态 类型 = 文本型>
    参数 存储JSON <类型 = 文本型>
    {
        如果 (存储JSON == "")
        {
            返回 ("")
        }
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (存储JSON) == 假)
        {
            返回 (存储JSON)
        }
        变量 cfDirect <类型 = YYJSON只读数组类>
        cfDirect = 包装.取数组 ("callFrames")
        如果 (cfDirect.取成员数 () > 0)
        {
            返回 (存储JSON)
        }
        变量 msg <类型 = 文本型>
        msg = yyjson取文本 (包装, "message")
        如果 (msg == "")
        {
            msg = yyjson取JSON文本 (包装, "message")
        }
        如果 (msg != "")
        {
            变量 inner <类型 = YYJSON只读对象类>
            如果 (inner.创建自文本 (msg))
            {
                返回 (msg)
            }
            如果 (寻找文本 (msg, "\"callFrames\"", 0, 假) != -1)
            {
                返回 (msg)
            }
        }
        返回 (存储JSON)
    }
    方法 提取JSON文本字段值 <公开 静态 类型 = 文本型>
    参数 JSON文本 <类型 = 文本型>
    参数 字段名 <类型 = 文本型>
    {
        如果 (JSON文本 == "" || 字段名 == "")
        {
            返回 ("")
        }
        变量 键 <类型 = 文本型>
        键 = "\"" + 字段名 + "\":\""
        变量 pos <类型 = 整数>
        pos = 寻找文本 (JSON文本, 键, 0, 假)
        如果 (pos == -1)
        {
            返回 ("")
        }
        变量 start <类型 = 整数>
        start = pos + 取文本长度 (键)
        变量 endPos <类型 = 整数>
        endPos = 寻找文本 (JSON文本, "\"", start, 假)
        如果 (endPos == -1 || endPos <= start)
        {
            返回 ("")
        }
        返回 (取文本中间 (JSON文本, start, endPos - start))
    }
    方法 提取JSON整数字段值 <公开 静态 类型 = 整数>
    参数 JSON文本 <类型 = 文本型>
    参数 字段名 <类型 = 文本型>
    {
        如果 (JSON文本 == "" || 字段名 == "")
        {
            返回 (0)
        }
        变量 键 <类型 = 文本型>
        键 = "\"" + 字段名 + "\":"
        变量 pos <类型 = 整数>
        pos = 寻找文本 (JSON文本, 键, 0, 假)
        如果 (pos == -1)
        {
            返回 (0)
        }
        变量 start <类型 = 整数>
        start = pos + 取文本长度 (键)
        变量 numText <类型 = 文本型>
        numText = ""
        变量 i <类型 = 整数>
        计次循环 (16)
        {
            i = 取循环索引 ()
            变量 ch <类型 = 文本型>
            ch = 取文本中间 (JSON文本, start + i, 1)
            如果 (ch == "" || ch == "," || ch == "}" || ch == "]")
            {
                跳出循环
            }
            numText = numText + ch
        }
        如果 (numText == "")
        {
            返回 (0)
        }
        返回 (文本到整数 (numText))
    }
    方法 从Debugger暂停文本构建摘要 <公开 静态 类型 = 文本型>
    参数 源JSON <类型 = 文本型>
    {
        变量 text <类型 = 文本型>
        text = 解包CDPDevTools事件JSON (源JSON)
        如果 (text == "")
        {
            返回 ("{}")
        }
        变量 callFrameId <类型 = 文本型>
        callFrameId = 提取JSON文本字段值 (text, "callFrameId")
        如果 (callFrameId == "")
        {
            返回 ("{}")
        }
        变量 reason <类型 = 文本型>
        reason = 提取JSON文本字段值 (text, "reason")
        变量 funcName <类型 = 文本型>
        funcName = 提取JSON文本字段值 (text, "functionName")
        变量 url <类型 = 文本型>
        url = 提取JSON文本字段值 (text, "url")
        变量 scriptId <类型 = 文本型>
        scriptId = 提取JSON文本字段值 (text, "scriptId")
        变量 lineNo <类型 = 整数>
        lineNo = 提取JSON整数字段值 (text, "lineNumber")
        变量 colNo <类型 = 整数>
        colNo = 提取JSON整数字段值 (text, "columnNumber")
        变量 framesJSON <类型 = 文本型>
        framesJSON = "[{\"callFrameId\":\"" + JSON转义文本 (callFrameId) + "\",\"functionName\":\"" + JSON转义文本 (funcName) + "\",\"url\":\"" + JSON转义文本 (url) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\",\"lineNumber\":" + 到文本 (lineNo) + ",\"columnNumber\":" + 到文本 (colNo) + "}]"
        返回 ("{\"reason\":\"" + JSON转义文本 (reason) + "\",\"call_frame_id\":\"" + JSON转义文本 (callFrameId) + "\",\"functionName\":\"" + JSON转义文本 (funcName) + "\",\"url\":\"" + JSON转义文本 (url) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\",\"lineNumber\":" + 到文本 (lineNo) + ",\"columnNumber\":" + 到文本 (colNo) + ",\"scopes\":[],\"hitBreakpoints\":[],\"frames\":" + framesJSON + ",\"_fallback\":true}")
    }
    方法 等待CDP事件 <公开 静态 类型 = 文本型>
    参数 事件名 <类型 = 文本型>
    参数 最大毫秒 <类型 = 整数>
    参数 清除旧记录 <类型 = 逻辑型 @默认值 = 假>
    {
        如果 (事件名 == "")
        {
            返回 ("")
        }
        如果 (最大毫秒 <= 0)
        {
            最大毫秒 = 30000
        }
        如果 (清除旧记录)
        {
            清除CDP事件记录 (事件名)
        }
        变量 截止 <类型 = 长整数>
        截止 = 取启动时间 () + 最大毫秒
        判断循环 (取启动时间 () < 截止)
        {
            如果 (MCP正在关闭)
            {
                返回 ("")
            }
            变量 data <类型 = 文本型>
            // 释放 MCP 锁，让 CEF/VIP DevTools 回调与导航继续推进
            MCP执行锁.解锁 ()
            data = 取CDP事件数据JSON (事件名)
            MCP执行锁.加锁 ()
            如果 (data != "")
            {
                返回 (data)
            }
            MCP执行锁.解锁 ()
            延时 (100)
            MCP执行锁.加锁 ()
        }
        返回 ("")
    }
    # 释放 MCP 锁的短延时 — 避免 UI 线程 sleep 导致 CEF/CDP/Debugger 回调饿死
    方法 MCP可中断延时 <公开 静态>
    参数 毫秒 <类型 = 整数>
    参数 分片毫秒 <类型 = 整数 @默认值 = 50>
    {
        如果 (毫秒 <= 0)
        {
            返回
        }
        变量 截止 <类型 = 长整数>
        截止 = 取启动时间 () + 毫秒
        判断循环 (取启动时间 () < 截止)
        {
            如果 (MCP正在关闭)
            {
                返回
            }
            MCP执行锁.解锁 ()
            延时 (分片毫秒)
            MCP执行锁.加锁 ()
        }
    }
    方法 DebuggerFlow尝试Resume <公开 静态 类型 = 逻辑型>
    参数 命令ID前缀 <类型 = 文本型>
    {
        变量 i <类型 = 整数>
        i = 0
        判断循环 (i < 3)
        {
            变量 rsRaw <类型 = 文本型>
            rsRaw = 执行CDP并同步等待 (命令ID前缀 + "_rs" + 到文本 (i), "Debugger.resume", "{}", 8000)
            如果 (rsRaw != "" && CDP同步结果是否成功 (rsRaw))
            {
                返回 (真)
            }
            i = i + 1
        }
        返回 (假)
    }
    方法 DebuggerFlow失败返回 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 错误JSON <类型 = 文本型>
    {
        DebuggerFlow尝试Resume (命令ID + "_fail")
        返回 (错误JSON)
    }
    方法 构建Debugger帧列表JSON <公开 静态 类型 = 文本型>
    参数 frames <类型 = YYJSON只读数组类>
    参数 最大条数 <类型 = 整数 @默认值 = 8>
    {
        如果 (frames.是否为空对象 () || frames.取成员数 () == 0)
        {
            返回 ("[]")
        }
        变量 上限 <类型 = 整数>
        上限 = (整数)frames.取成员数 ()
        如果 (上限 > 最大条数)
        {
            上限 = 最大条数
        }
        变量 out <类型 = 文本型>
        out = "["
        计次循环 (上限)
        {
            如果 (取循环索引 () > 0)
            {
                out = out + ","
            }
            变量 fi <类型 = YYJSON只读对象类>
            fi = frames.取成员 (取循环索引 ())
            变量 locFi <类型 = YYJSON只读对象类>
            locFi = fi.取对象 ("location")
            变量 fnLine <类型 = 整数>
            fnLine = yyjson取整数 (fi, "lineNumber")
            如果 (fnLine == 0)
            {
                fnLine = yyjson取整数 (locFi, "lineNumber")
            }
            变量 fnCol <类型 = 整数>
            fnCol = yyjson取整数 (fi, "columnNumber")
            如果 (fnCol == 0)
            {
                fnCol = yyjson取整数 (locFi, "columnNumber")
            }
            变量 fnScript <类型 = 文本型>
            fnScript = yyjson取文本 (locFi, "scriptId")
            out = out + "{\"callFrameId\":\"" + JSON转义文本 (yyjson取文本 (fi, "callFrameId")) + "\",\"functionName\":\"" + JSON转义文本 (yyjson取文本 (fi, "functionName")) + "\",\"url\":\"" + JSON转义文本 (yyjson取文本 (fi, "url")) + "\",\"scriptId\":\"" + JSON转义文本 (fnScript) + "\",\"lineNumber\":" + 到文本 (fnLine) + ",\"columnNumber\":" + 到文本 (fnCol) + "}"
        }
        out = out + "]"
        返回 (out)
    }
    方法 构建Debugger作用域摘要JSON <公开 静态 类型 = 文本型>
    参数 scopeChain <类型 = YYJSON只读数组类>
    参数 最大条数 <类型 = 整数 @默认值 = 6>
    {
        如果 (scopeChain.是否为空对象 () || scopeChain.取成员数 () == 0)
        {
            返回 ("[]")
        }
        变量 上限 <类型 = 整数>
        上限 = (整数)scopeChain.取成员数 ()
        如果 (上限 > 最大条数)
        {
            上限 = 最大条数
        }
        变量 out <类型 = 文本型>
        out = "["
        计次循环 (上限)
        {
            如果 (取循环索引 () > 0)
            {
                out = out + ","
            }
            变量 sc <类型 = YYJSON只读对象类>
            sc = scopeChain.取成员 (取循环索引 ())
            变量 scObj <类型 = YYJSON只读对象类>
            scObj = sc.取对象 ("object")
            out = out + "{\"type\":\"" + JSON转义文本 (yyjson取文本 (sc, "type")) + "\",\"name\":\"" + JSON转义文本 (yyjson取文本 (sc, "name")) + "\",\"className\":\"" + JSON转义文本 (yyjson取文本 (scObj, "className")) + "\"}"
        }
        out = out + "]"
        返回 (out)
    }
    方法 解析Debugger暂停摘要 <公开 静态 类型 = 文本型>
    参数 包装JSON <类型 = 文本型>
    {
        包装JSON = 解包CDPDevTools事件JSON (包装JSON)
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (包装JSON) == 假)
        {
            返回 (从Debugger暂停文本构建摘要 (包装JSON))
        }
        变量 msg <类型 = 文本型>
        msg = yyjson取JSON文本 (包装, "message")
        如果 (msg == "")
        {
            msg = yyjson取文本 (包装, "message")
        }
        变量 暂停 <类型 = YYJSON只读对象类>
        变量 已解析 <类型 = 逻辑型 值 = 假>
        如果 (msg != "" && 暂停.创建自文本 (msg))
        {
            已解析 = 真
        }
        如果 (已解析 == 假)
        {
            变量 cfTry <类型 = YYJSON只读数组类>
            cfTry = 包装.取数组 ("callFrames")
            如果 (cfTry.取成员数 () > 0)
            {
                暂停 = 包装
                已解析 = 真
            }
        }
        如果 (已解析 == 假)
        {
            返回 (从Debugger暂停文本构建摘要 (包装JSON))
        }
        变量 reason <类型 = 文本型>
        reason = yyjson取文本 (暂停, "reason")
        变量 frames <类型 = YYJSON只读数组类>
        frames = 暂停.取数组 ("callFrames")
        变量 callFrameId <类型 = 文本型>
        callFrameId = ""
        变量 funcName <类型 = 文本型>
        funcName = ""
        变量 url <类型 = 文本型>
        url = ""
        变量 lineNo <类型 = 整数>
        lineNo = 0
        变量 colNo <类型 = 整数>
        colNo = 0
        变量 scriptId <类型 = 文本型>
        scriptId = ""
        变量 scopesJSON <类型 = 文本型>
        scopesJSON = "[]"
        如果 (frames.取成员数 () > 0)
        {
            变量 frame0 <类型 = YYJSON只读对象类>
            frame0 = frames.取成员 (0)
            callFrameId = yyjson取文本 (frame0, "callFrameId")
            funcName = yyjson取文本 (frame0, "functionName")
            url = yyjson取文本 (frame0, "url")
            变量 loc0 <类型 = YYJSON只读对象类>
            loc0 = frame0.取对象 ("location")
            lineNo = yyjson取整数 (frame0, "lineNumber")
            如果 (lineNo == 0)
            {
                lineNo = yyjson取整数 (loc0, "lineNumber")
            }
            colNo = yyjson取整数 (frame0, "columnNumber")
            如果 (colNo == 0)
            {
                colNo = yyjson取整数 (loc0, "columnNumber")
            }
            scriptId = yyjson取文本 (loc0, "scriptId")
            scopesJSON = 构建Debugger作用域摘要JSON (frame0.取数组 ("scopeChain"), 6)
        }
        变量 framesJSON <类型 = 文本型>
        framesJSON = 构建Debugger帧列表JSON (frames, 8)
        变量 hitJSON <类型 = 文本型>
        hitJSON = yyjson取JSON文本 (暂停, "hitBreakpoints")
        如果 (hitJSON == "")
        {
            hitJSON = "[]"
        }
        返回 ("{\"reason\":\"" + JSON转义文本 (reason) + "\",\"call_frame_id\":\"" + JSON转义文本 (callFrameId) + "\",\"functionName\":\"" + JSON转义文本 (funcName) + "\",\"url\":\"" + JSON转义文本 (url) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\",\"lineNumber\":" + 到文本 (lineNo) + ",\"columnNumber\":" + 到文本 (colNo) + ",\"scopes\":" + scopesJSON + ",\"hitBreakpoints\":" + hitJSON + ",\"frames\":" + framesJSON + "}")
    }
