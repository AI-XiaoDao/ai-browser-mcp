    方法 修剪浏览器数组 <公开 静态>
    {
        浏览器数组锁.加锁 ()
        变量 count <类型 = 整数>
        count = 浏览器容器.浏览器数组.取成员数 ()
        变量 idx <类型 = 整数>
        idx = count - 1
        判断循环 (idx >= 0)
        {
            变量 temp <类型 = 类_FBrowser_浏览器>
            temp = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, idx, 类_FBrowser_浏览器)
            如果 (temp.是否为空 () || temp.是否已关闭 ())
            {
                浏览器容器.浏览器数组.删除成员 (idx)
            }
            idx = idx - 1
        }
        浏览器数组锁.解锁 ()
    }
    方法 执行定期维护 <公开 静态 注释 = "由主窗口时钟调用, 清理缓存/CDP映射/浏览器数组/WAL checkpoint/过期下载">
    {
        如果 (MCP正在关闭 || 缓存数据库已打开 == 假)
        {
            返回
        }
        清理过期缓存 ()
        清理过期CDP映射 ()
        修剪浏览器数组 ()
        MCP_编排分派.强制终止超时工作流 ()
        // 定期触发 WAL checkpoint, 防止 WAL 文件无限增长 (每60s执行, 无性能影响)
        异步缓存锁.加锁 ()
        缓存数据库.执行SQL语句 ("PRAGMA wal_checkpoint(PASSIVE)", )
        异步缓存锁.解锁 ()
        // 检测粘滞的URL请求槽: 槽满后 5 分钟仍无释放 → 强制重置
        异步缓存锁.加锁 ()
        如果 (活动URL请求数 >= URL请求最大并发)
        {
            变量 粘滞起点 <类型 = 长整数>
            粘滞起点 = URL请求槽满起始毫秒
            如果 (粘滞起点 == 0 && 最后URL请求槽释放时间 > 0)
            {
                粘滞起点 = 最后URL请求槽释放时间
            }
            如果 (粘滞起点 > 0 && 取启动时间 () - 粘滞起点 > 300000)
            {
                调试输出 ("[MCP] 警告: URL请求槽全部粘滞 " + 到文本 (活动URL请求数) + "/" + 到文本 (URL请求最大并发) + ", 强制重置")
                活动URL请求数 = 0
                最后URL请求槽释放时间 = 0
                URL请求槽满起始毫秒 = 0
            }
        }
        异步缓存锁.解锁 ()
        // 清理过期下载文件 (每60秒检查一次, 实际删除为每天首次触发)
        清理过期下载 ()
    }
    方法 清理过期下载 <公开 静态 注释 = "删除Downloads目录中超过下载保留天数的文件">
    {
        变量 下载目录 <类型 = 文本型>
        下载目录 = 取运行目录 () + "\\Downloads"
        如果 (目录是否存在 (下载目录) == 假)
        {
            返回
        }
        // 取现行时间 / 取文件时间 返回 OLE 日期 (小数, 天为单位), 30天 = 30.0
        变量 当前OLE日期 <类型 = 小数>
        当前OLE日期 = 取现行时间 ()
        变量 截止OLE日期 <类型 = 小数>
        截止OLE日期 = 当前OLE日期 - 下载保留天数
        变量 查找器 <类型 = 文件查找类>
        变量 找到名 <类型 = 文本型>
        找到名 = 查找器.寻找文件 (下载目录 + "\\*.*", -1, 0)
        变量 清理计数 <类型 = 整数 值 = 0>
        判断循环 (找到名 != "")
        {
            变量 文件路径 <类型 = 文本型>
            文件路径 = 下载目录 + "\\" + 找到名
            变量 文件OLE时间 <类型 = 小数>
            文件OLE时间 = 取文件时间 (文件路径)
            如果 (文件OLE时间 > 0 && 文件OLE时间 < 截止OLE日期)
            {
                删除文件 (文件路径)
                清理计数 = 清理计数 + 1
            }
            找到名 = 查找器.寻找文件 ("", -1, 0)
        }
        如果 (清理计数 > 0)
        {
            调试输出 ("[MCP] 清理过期下载:", 清理计数, "个文件")
        }
    }
