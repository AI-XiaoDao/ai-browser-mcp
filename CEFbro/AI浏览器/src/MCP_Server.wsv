    方法 解析Debugger求值结果 <公开 静态 类型 = 文本型>
    参数 异步结果JSON <类型 = 文本型>
    参数 命令ID前缀 <类型 = 文本型 @默认值 = "">
    参数 callFrameId <类型 = 文本型 @默认值 = "">
    参数 expression <类型 = 文本型 @默认值 = "">
    参数 展开对象 <类型 = 逻辑型 @默认值 = 假>
    {
        如果 (异步结果JSON == "")
        {
            返回 ("{\"ok\":false,\"error\":\"empty\"}")
        }
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (异步结果JSON) == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"invalid_json\"}")
        }
        如果 (yyjson取逻辑 (包装, "success") == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"" + JSON转义文本 (yyjson取文本 (包装, "message")) + "\"}")
        }
        变量 cdpText <类型 = 文本型>
        cdpText = yyjson取文本 (包装, "result")
        如果 (cdpText == "")
        {
            返回 ("{\"ok\":false,\"error\":\"no_cdp_result\"}")
        }
        变量 cdp <类型 = YYJSON只读对象类>
        如果 (cdp.创建自文本 (cdpText) == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"cdp_parse\"}")
        }
        变量 remote <类型 = YYJSON只读对象类>
        remote = cdp.取对象 ("result")
        变量 exObj <类型 = YYJSON只读对象类>
        exObj = cdp.取对象 ("exceptionDetails")
        如果 (remote.是否为空对象 () || remote.是否为空 ())
        {
            变量 exAlt <类型 = YYJSON只读对象类>
            exAlt = exObj.取对象 ("result")
            如果 (yyjson取文本 (exAlt, "type") != "")
            {
                remote = exAlt
            }
        }
        如果 ((remote.是否为空对象 () || remote.是否为空 ()) && exObj.是否为空对象 () == 假 && exObj.是否为空 () == 假)
        {
            变量 exMsg <类型 = 文本型>
            exMsg = yyjson取文本 (exObj, "text")
            变量 exId <类型 = 整数>
            exId = yyjson取整数 (exObj, "exceptionId")
            如果 (exMsg != "" || exId != 0)
            {
                变量 exText <类型 = 文本型>
                exText = yyjson取JSON文本 (cdp, "exceptionDetails")
                返回 ("{\"ok\":false,\"exception\":" + 选择 (exText == "", "{}", exText) + "}")
            }
        }
        如果 (remote.是否为空对象 () || remote.是否为空 ())
        {
            返回 ("{\"ok\":true,\"raw\":" + 选择 (cdpText == "", "null", cdpText) + "}")
        }
        变量 valType <类型 = 文本型>
        valType = yyjson取文本 (remote, "type")
        变量 val <类型 = 文本型>
        val = yyjson取文本 (remote, "value")
        变量 desc <类型 = 文本型>
        desc = yyjson取文本 (remote, "description")
        变量 unser <类型 = 文本型>
        unser = yyjson取文本 (remote, "unserializableValue")
        变量 objId <类型 = 文本型>
        objId = yyjson取文本 (remote, "objectId")
        变量 cls <类型 = 文本型>
        cls = yyjson取文本 (remote, "className")
        如果 (val == "" && unser != "")
        {
            val = unser
        }
        变量 valPart <类型 = 文本型>
        valPart = yyjson取JSON文本 (remote, "value")
        如果 (valPart != "" && valType == "string" && 是否以 (valPart, "\"") == 假)
        {
            valPart = "\"" + JSON转义文本 (选择 (val != "", val, valPart)) + "\""
        }
        如果 (valPart == "")
        {
            如果 (valType == "number" || valType == "boolean")
            {
                valPart = val
                如果 (valPart == "" && desc != "")
                {
                    valPart = desc
                }
                如果 (valPart == "" && valType == "boolean")
                {
                    valPart = "false"
                }
                如果 (valPart == "" && valType == "number")
                {
                    valPart = "0"
                }
            }
            否则 (valType == "undefined")
            {
                valPart = "null"
            }
            否则
            {
                valPart = "\"" + JSON转义文本 (val) + "\""
            }
        }
        变量 out <类型 = 文本型>
        out = "{\"ok\":true,\"type\":\"" + JSON转义文本 (valType) + "\",\"value\":" + valPart + ",\"description\":\"" + JSON转义文本 (desc) + "\",\"className\":\"" + JSON转义文本 (cls) + "\",\"objectId\":\"" + JSON转义文本 (objId) + "\""
        如果 (展开对象 && objId != "" && (valType == "object" || valType == "function"))
        {
            out = out + ",\"properties\":" + Runtime取对象属性JSON (命令ID前缀, objId, 40)
        }
        如果 (展开对象 && valType == "function" && callFrameId != "" && expression != "")
        {
            变量 srcExpr <类型 = 文本型>
            srcExpr = "(function(){try{var __v=(" + expression + ");return typeof __v==='function'?__v.toString():''}catch(e){return ''}})()"
            变量 srcRaw <类型 = 文本型>
            srcRaw = 执行Debugger帧求值并等待 (命令ID前缀 + "_fn", callFrameId, srcExpr, 6000, 真)
            变量 srcParsed <类型 = YYJSON只读对象类>
            如果 (srcParsed.创建自文本 (解析Debugger求值结果 (srcRaw, "", "", "", 假)))
            {
                变量 srcText <类型 = 文本型>
                srcText = yyjson取文本 (srcParsed, "value")
                如果 (srcText != "")
                {
                    out = out + ",\"source\":\"" + JSON转义文本 (srcText) + "\""
                }
            }
        }
        out = out + "}"
        返回 (out)
    }
    方法 Debugger帧内批量求值JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 callFrameId <类型 = 文本型>
    参数 exprRaw <类型 = 文本型>
    参数 展开对象 <类型 = 逻辑型 @默认值 = 真>
    参数 returnByValue <类型 = 逻辑型 @默认值 = 真>
    {
        变量 evalOut <类型 = 文本型>
        evalOut = "["
        变量 evalCount <类型 = 整数 值 = 0>
        变量 effectiveRbV <类型 = 逻辑型>
        effectiveRbV = returnByValue
        如果 (展开对象)
        {
            effectiveRbV = 假
        }
        如果 (callFrameId == "" || exprRaw == "")
        {
            返回 ("[]")
        }
        如果 (是否以 (exprRaw, "["))
        {
            变量 exprArr <类型 = YYJSON只读数组类>
            exprArr = 取JSON数组自文本 (exprRaw, "expressions")
            如果 (exprArr.取成员数 () > 0)
            {
                计次循环 ((整数)exprArr.取成员数 ())
                {
                    变量 oneExpr <类型 = 文本型>
                    oneExpr = exprArr.取文本 (取循环索引 ())
                    如果 (oneExpr == "")
                    {
                        到循环尾
                    }
                    如果 (evalCount > 0)
                    {
                        evalOut = evalOut + ","
                    }
                    变量 evRaw <类型 = 文本型>
                    evRaw = 执行Debugger帧求值并等待 (命令ID + "_ev" + 到文本 (evalCount), callFrameId, oneExpr, 8000, effectiveRbV)
                    evalOut = evalOut + "{\"expression\":\"" + JSON转义文本 (oneExpr) + "\",\"eval\":" + 解析Debugger求值结果 (evRaw, 命令ID + "_ev" + 到文本 (evalCount), callFrameId, oneExpr, 展开对象) + "}"
                    evalCount = evalCount + 1
                }
            }
        }
        否则
        {
            变量 evRaw2 <类型 = 文本型>
            evRaw2 = 执行Debugger帧求值并等待 (命令ID + "_ev0", callFrameId, exprRaw, 8000, effectiveRbV)
            evalOut = evalOut + "{\"expression\":\"" + JSON转义文本 (exprRaw) + "\",\"eval\":" + 解析Debugger求值结果 (evRaw2, 命令ID + "_ev0", callFrameId, exprRaw, 展开对象) + "}"
            evalCount = 1
        }
        evalOut = evalOut + "]"
        返回 (evalOut)
    }
    方法 执行Debugger断点流程JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 bpRegex <类型 = 文本型>
        bpRegex = yyjson取文本 (参数JSON, "breakpoint")
        如果 (bpRegex == "")
        {
            bpRegex = yyjson取文本 (参数JSON, "url_regex")
        }
        如果 (bpRegex == "")
        {
            bpRegex = "example\\.com"
        }
        变量 navUrl <类型 = 文本型>
        navUrl = yyjson取文本 (参数JSON, "url")
        变量 maxMs <类型 = 整数>
        maxMs = yyjson取整数 (参数JSON, "max_ms")
        如果 (maxMs == 0)
        {
            maxMs = 45000
        }
        变量 应Resume <类型 = 逻辑型>
        应Resume = 取DebuggerFlow应Resume (参数JSON)
        // 若上次断点未 resume 或 tool_test 遗留 paused，先恢复再 enable
        确保Debugger已恢复 (命令ID + "_pre")
        变量 enRaw <类型 = 文本型>
        enRaw = 执行CDP并同步等待 (命令ID + "_en", "Debugger.enable", "{}", 20000)
        如果 (CDP同步结果是否成功 (enRaw) == 假)
        {
            确保Debugger已恢复 (命令ID + "_retry")
            enRaw = 执行CDP并同步等待 (命令ID + "_en2", "Debugger.enable", "{}", 20000)
        }
        如果 (CDP同步结果是否成功 (enRaw) == 假)
        {
            返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"enable\",\"error\":\"" + JSON转义文本 (取CDP同步结果错误 (enRaw)) + "\"}"))
        }
        MCP可中断延时 (200)
        变量 bpParams <类型 = YYJSON对象类>
        bpParams.创建自文本 ("{}")
        bpParams.加入文本成员 ("urlRegex", bpRegex)
        变量 flowLine <类型 = 整数>
        flowLine = yyjson取整数 (参数JSON, "line")
        如果 (flowLine == 0)
        {
            flowLine = yyjson取整数 (参数JSON, "line_number")
        }
        bpParams.加入整数成员 ("lineNumber", flowLine)
        变量 flowCol <类型 = 整数>
        flowCol = yyjson取整数 (参数JSON, "column")
        如果 (flowCol == 0)
        {
            flowCol = yyjson取整数 (参数JSON, "column_number")
        }
        变量 flowHasCol <类型 = 逻辑型 值 = 假>
        如果 (yyjson取文本 (参数JSON, "column") != "" || yyjson取文本 (参数JSON, "column_number") != "")
        {
            flowHasCol = 真
        }
        如果 (flowHasCol)
        {
            bpParams.加入整数成员 ("columnNumber", flowCol)
        }
        变量 bpRaw <类型 = 文本型>
        bpRaw = 执行CDP并同步等待 (命令ID + "_bp", "Debugger.setBreakpointByUrl", bpParams.到可读文本 (YYJSON格式化选项.压缩), 20000)
        如果 (CDP设置断点结果是否成功 (bpRaw) == 假)
        {
            返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"set_breakpoint\",\"error\":\"" + JSON转义文本 (取CDP同步结果错误 (bpRaw)) + "\",\"breakpoint\":\"" + JSON转义文本 (bpRegex) + "\"}"))
        }
        // 须在 navigate 之前清除，否则加载时命中断点的事件会被误删
        清除CDP事件记录 ("Debugger.paused")
        如果 (navUrl != "")
        {
            如果 (验证URL安全 (navUrl) == 假)
            {
                返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"navigate\",\"error\":\"unsafe_url\"}"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = 取主浏览器 ()
            如果 (browser.是否为空 ())
            {
                返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"navigate\",\"error\":\"no_browser\"}"))
            }
            变量 navFrame <类型 = 类_FBrowser_框架>
            navFrame = 取安全主框架 (browser)
            如果 (navFrame.是否为空 () || navFrame.是否有效 () == 假)
            {
                返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"navigate\",\"error\":\"no_frame\"}"))
            }
            navFrame.载入地址 (navUrl)
            MCP可中断延时 (800)
        }
        变量 pausedRaw <类型 = 文本型>
        pausedRaw = 等待CDP事件 ("Debugger.paused", maxMs, 假)
        如果 (pausedRaw == "")
        {
            返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"wait_paused\",\"error\":\"timeout\",\"breakpoint\":\"" + JSON转义文本 (bpRegex) + "\"}"))
        }
        变量 pausedSummary <类型 = 文本型>
        pausedSummary = 解析Debugger暂停摘要 (pausedRaw)
        变量 pausedObj <类型 = YYJSON只读对象类>
        变量 frameId <类型 = 文本型>
        frameId = ""
        如果 (pausedObj.创建自文本 (pausedSummary))
        {
            frameId = yyjson取文本 (pausedObj, "call_frame_id")
        }
        如果 (frameId == "")
        {
            frameId = 提取JSON文本字段值 (pausedSummary, "call_frame_id")
        }
        变量 exprRaw <类型 = 文本型>
        exprRaw = 取Debugger表达式Raw文本 (参数JSON)
        如果 (exprRaw == "")
        {
            exprRaw = "[\"location.href\",\"document.title\",\"typeof window\",\"window.__mcp_dbg\"]"
        }
        变量 flowExpand <类型 = 逻辑型>
        flowExpand = 取Debugger求值展开 (参数JSON)
        变量 flowRbV <类型 = 逻辑型>
        flowRbV = 取Debugger求值ReturnByValue (参数JSON)
        变量 evalOut <类型 = 文本型>
        evalOut = Debugger帧内批量求值JSON (命令ID, frameId, exprRaw, flowExpand, flowRbV)
        变量 resumed <类型 = 逻辑型 值 = 假>
        如果 (应Resume)
        {
            resumed = DebuggerFlow尝试Resume (命令ID + "_done")
        }
        如果 (resumed == 假 && 应Resume)
        {
            返回 (DebuggerFlow失败返回 (命令ID, "{\"ok\":false,\"step\":\"resume\",\"error\":\"resume_failed\",\"breakpoint\":\"" + JSON转义文本 (bpRegex) + "\",\"paused\":" + pausedSummary + ",\"evaluations\":" + evalOut + "}"))
        }
        返回 ("{\"ok\":true,\"breakpoint\":\"" + JSON转义文本 (bpRegex) + "\",\"url\":\"" + JSON转义文本 (navUrl) + "\",\"paused\":" + pausedSummary + ",\"evaluations\":" + evalOut + ",\"resumed\":" + 选择 (resumed, "true", "false") + "}")
    }
    方法 取CDP同步结果体文本 <公开 静态 类型 = 文本型>
    参数 存储JSON <类型 = 文本型>
    {
        如果 (存储JSON == "")
        {
            返回 ("")
        }
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (存储JSON) == 假)
        {
            返回 ("")
        }
        返回 (yyjson取文本 (包装, "result"))
    }
    方法 解析Debugger帧位置JSON <公开 静态 类型 = 文本型>
    参数 暂停摘要JSON <类型 = 文本型>
    参数 目标帧ID <类型 = 文本型 @默认值 = "">
    {
        变量 摘要 <类型 = YYJSON只读对象类>
        如果 (摘要.创建自文本 (暂停摘要JSON) == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"invalid_paused_summary\"}")
        }
        变量 frameId <类型 = 文本型>
        frameId = 目标帧ID
        如果 (frameId == "")
        {
            frameId = yyjson取文本 (摘要, "call_frame_id")
        }
        变量 scriptId <类型 = 文本型>
        scriptId = ""
        变量 url <类型 = 文本型>
        url = ""
        变量 lineNo <类型 = 整数>
        lineNo = 0
        变量 colNo <类型 = 整数>
        colNo = 0
        变量 已匹配 <类型 = 逻辑型 值 = 假>
        变量 frames <类型 = YYJSON只读数组类>
        frames = 摘要.取数组 ("frames")
        如果 (frames.取成员数 () > 0)
        {
            计次循环 ((整数)frames.取成员数 ())
            {
                变量 fi <类型 = YYJSON只读对象类>
                fi = frames.取成员 (取循环索引 ())
                变量 cfId <类型 = 文本型>
                cfId = yyjson取文本 (fi, "callFrameId")
                如果 (frameId != "" && cfId != frameId)
                {
                    到循环尾
                }
                变量 locFi <类型 = YYJSON只读对象类>
                locFi = fi.取对象 ("location")
                scriptId = yyjson取文本 (fi, "scriptId")
                如果 (scriptId == "")
                {
                    scriptId = yyjson取文本 (locFi, "scriptId")
                }
                url = yyjson取文本 (fi, "url")
                lineNo = yyjson取整数 (fi, "lineNumber")
                如果 (lineNo == 0)
                {
                    lineNo = yyjson取整数 (locFi, "lineNumber")
                }
                colNo = yyjson取整数 (fi, "columnNumber")
                如果 (colNo == 0)
                {
                    colNo = yyjson取整数 (locFi, "columnNumber")
                }
                如果 (frameId == "")
                {
                    frameId = cfId
                }
                已匹配 = 真
                跳出循环
            }
        }
        如果 (已匹配 == 假)
        {
            scriptId = yyjson取文本 (摘要, "scriptId")
            url = yyjson取文本 (摘要, "url")
            lineNo = yyjson取整数 (摘要, "lineNumber")
            colNo = yyjson取整数 (摘要, "columnNumber")
            如果 (frameId == "")
            {
                frameId = yyjson取文本 (摘要, "call_frame_id")
            }
        }
        如果 (scriptId == "")
        {
            返回 ("{\"ok\":false,\"error\":\"missing_script_id\",\"call_frame_id\":\"" + JSON转义文本 (frameId) + "\"}")
        }
        返回 ("{\"ok\":true,\"call_frame_id\":\"" + JSON转义文本 (frameId) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\",\"url\":\"" + JSON转义文本 (url) + "\",\"lineNumber\":" + 到文本 (lineNo) + ",\"columnNumber\":" + 到文本 (colNo) + "}")
    }
    方法 构建Debugger脚本行上下文JSON <公开 静态 类型 = 文本型>
    参数 scriptSource <类型 = 文本型>
    参数 lineNo <类型 = 整数>
    参数 contextLines <类型 = 整数 @默认值 = 3>
    {
        如果 (scriptSource == "")
        {
            返回 ("{\"currentLine\":\"\",\"contextSnippet\":\"\",\"lineCount\":0}")
        }
        变量 srcNorm <类型 = 文本型>
        srcNorm = scriptSource
        子文本替换 (srcNorm, "\r\n", "\n", , , 假)
        子文本替换 (srcNorm, "\r", "\n", , , 假)
        变量 lines <类型 = 文本数组类>
        分割文本 (srcNorm, "\n", lines, 真, 假)
        变量 total <类型 = 整数>
        total = (整数)lines.取成员数 ()
        变量 idx <类型 = 整数>
        idx = lineNo
        如果 (idx < 0)
        {
            idx = 0
        }
        如果 (idx >= total && total > 0)
        {
            idx = total - 1
        }
        变量 currentLine <类型 = 文本型>
        currentLine = ""
        如果 (total > 0)
        {
            currentLine = lines.取成员 (idx)
        }
        变量 ctx <类型 = 整数>
        ctx = contextLines
        如果 (ctx < 0)
        {
            ctx = 0
        }
        如果 (ctx > 20)
        {
            ctx = 20
        }
        变量 start <类型 = 整数>
        start = idx - ctx
        如果 (start < 0)
        {
            start = 0
        }
        变量 end <类型 = 整数>
        end = idx + ctx
        如果 (end >= total)
        {
            end = total - 1
        }
        变量 snippet <类型 = 文本型>
        snippet = ""
        如果 (total > 0 && end >= start)
        {
            变量 i <类型 = 整数>
            i = start
            判断循环 (i <= end)
            {
                如果 (snippet != "")
                {
                    snippet = snippet + "\n"
                }
                变量 ln <类型 = 文本型>
                ln = lines.取成员 (i)
                变量 prefix <类型 = 文本型>
                prefix = 选择 (i == idx, "> ", "  ")
                snippet = snippet + prefix + 到文本 (i + 1) + " | " + ln
                i = i + 1
            }
        }
        返回 ("{\"currentLine\":\"" + JSON转义文本 (currentLine) + "\",\"contextSnippet\":\"" + JSON转义文本 (snippet) + "\",\"lineCount\":" + 到文本 (total) + ",\"lineNumber\":" + 到文本 (idx) + "}")
    }
    方法 执行Debugger脚本源JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        变量 scriptId <类型 = 文本型>
        scriptId = yyjson取文本 (参数JSON, "script_id")
        如果 (scriptId == "")
        {
            scriptId = yyjson取文本 (参数JSON, "scriptId")
        }
        变量 lineNo <类型 = 整数>
        lineNo = -1
        变量 colNo <类型 = 整数>
        colNo = -1
        变量 url <类型 = 文本型>
        url = yyjson取文本 (参数JSON, "url")
        变量 frameId <类型 = 文本型>
        frameId = yyjson取文本 (参数JSON, "call_frame_id")
        变量 ctxLines <类型 = 整数>
        ctxLines = yyjson取整数 (参数JSON, "context_lines")
        如果 (ctxLines <= 0)
        {
            ctxLines = 3
        }
        变量 lineParam <类型 = 整数>
        lineParam = yyjson取整数 (参数JSON, "line")
        如果 (lineParam == 0 && yyjson取文本 (参数JSON, "line") == "")
        {
            lineParam = yyjson取整数 (参数JSON, "line_number")
        }
        如果 (lineParam == 0 && yyjson取文本 (参数JSON, "line_number") == "")
        {
            lineParam = yyjson取整数 (参数JSON, "lineNumber")
        }
        如果 (yyjson取文本 (参数JSON, "line") != "" || yyjson取文本 (参数JSON, "line_number") != "" || yyjson取文本 (参数JSON, "lineNumber") != "")
        {
            lineNo = lineParam
        }
        变量 colParam <类型 = 整数>
        colParam = yyjson取整数 (参数JSON, "column")
        如果 (colParam == 0 && yyjson取文本 (参数JSON, "column") == "")
        {
            colParam = yyjson取整数 (参数JSON, "column_number")
        }
        如果 (colParam == 0 && yyjson取文本 (参数JSON, "column_number") == "")
        {
            colParam = yyjson取整数 (参数JSON, "columnNumber")
        }
        如果 (yyjson取文本 (参数JSON, "column") != "" || yyjson取文本 (参数JSON, "column_number") != "" || yyjson取文本 (参数JSON, "columnNumber") != "")
        {
            colNo = colParam
        }
        如果 (scriptId == "" || lineNo < 0 || frameId == "")
        {
            变量 rawPaused <类型 = 文本型>
            rawPaused = 取CDP事件数据JSON ("Debugger.paused")
            如果 (rawPaused == "")
            {
                返回 ("{\"ok\":false,\"error\":\"no_paused_state | 请先 wait_paused 或 flow\"}")
            }
            变量 summary <类型 = 文本型>
            summary = 解析Debugger暂停摘要 (rawPaused)
            变量 posJSON <类型 = 文本型>
            posJSON = 解析Debugger帧位置JSON (summary, frameId)
            如果 (是否以 (posJSON, "{\"ok\":false"))
            {
                返回 (posJSON)
            }
            变量 posObj <类型 = YYJSON只读对象类>
            posObj.创建自文本 (posJSON)
            如果 (scriptId == "")
            {
                scriptId = yyjson取文本 (posObj, "scriptId")
            }
            如果 (lineNo < 0)
            {
                lineNo = yyjson取整数 (posObj, "lineNumber")
            }
            如果 (colNo < 0)
            {
                colNo = yyjson取整数 (posObj, "columnNumber")
            }
            如果 (url == "")
            {
                url = yyjson取文本 (posObj, "url")
            }
            如果 (frameId == "")
            {
                frameId = yyjson取文本 (posObj, "call_frame_id")
            }
        }
        如果 (scriptId == "")
        {
            返回 ("{\"ok\":false,\"error\":\"missing_script_id\"}")
        }
        如果 (lineNo < 0)
        {
            lineNo = 0
        }
        如果 (colNo < 0)
        {
            colNo = 0
        }
        变量 gpObj <类型 = YYJSON对象类>
        gpObj.创建自文本 ("{}")
        gpObj.加入文本成员 ("scriptId", scriptId)
        变量 syncRaw <类型 = 文本型>
        syncRaw = 执行CDP并同步等待 (命令ID + "_gs", "Debugger.getScriptSource", gpObj.到可读文本 (YYJSON格式化选项.压缩), 20000)
        如果 (syncRaw == "" || CDP同步结果是否成功 (syncRaw) == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"" + JSON转义文本 (取CDP同步结果错误 (syncRaw)) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\"}")
        }
        变量 cdpBody <类型 = 文本型>
        cdpBody = 取CDP同步结果体文本 (syncRaw)
        变量 cdpObj <类型 = YYJSON只读对象类>
        如果 (cdpObj.创建自文本 (cdpBody) == 假)
        {
            返回 ("{\"ok\":false,\"error\":\"cdp_parse\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\"}")
        }
        变量 scriptSource <类型 = 文本型>
        scriptSource = yyjson取文本 (cdpObj, "scriptSource")
        如果 (scriptSource == "")
        {
            返回 ("{\"ok\":false,\"error\":\"empty_script_source\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\"}")
        }
        变量 includeSource <类型 = 逻辑型>
        includeSource = 真
        如果 (参数JSON.是否为空 () == 假)
        {
            如果 (yyjson取文本 (参数JSON, "include_source") == "false" || yyjson取逻辑 (参数JSON, "include_source") == 假)
            {
                includeSource = 假
            }
        }
        变量 ctxJSON <类型 = 文本型>
        ctxJSON = 构建Debugger脚本行上下文JSON (scriptSource, lineNo, ctxLines)
        变量 ctxObj <类型 = YYJSON只读对象类>
        ctxObj.创建自文本 (ctxJSON)
        变量 currentLine <类型 = 文本型>
        currentLine = yyjson取文本 (ctxObj, "currentLine")
        变量 contextSnippet <类型 = 文本型>
        contextSnippet = yyjson取文本 (ctxObj, "contextSnippet")
        变量 lineCount <类型 = 整数>
        lineCount = yyjson取整数 (ctxObj, "lineCount")
        变量 srcPart <类型 = 文本型>
        srcPart = ""
        如果 (includeSource)
        {
            srcPart = ",\"scriptSource\":\"" + JSON转义文本 (scriptSource) + "\""
        }
        返回 ("{\"ok\":true,\"call_frame_id\":\"" + JSON转义文本 (frameId) + "\",\"scriptId\":\"" + JSON转义文本 (scriptId) + "\",\"url\":\"" + JSON转义文本 (url) + "\",\"lineNumber\":" + 到文本 (lineNo) + ",\"columnNumber\":" + 到文本 (colNo) + ",\"lineCount\":" + 到文本 (lineCount) + ",\"currentLine\":\"" + JSON转义文本 (currentLine) + "\",\"contextSnippet\":\"" + JSON转义文本 (contextSnippet) + "\"" + srcPart + "}")
    }
    # 从 JSON 数组文本解析只读数组 (只读数组类无 创建自文本, 须 object 包装)
    方法 取JSON数组自文本 <公开 静态 类型 = YYJSON只读数组类>
    参数 数组JSON <类型 = 文本型>
    参数 包装键名 <类型 = 文本型 @默认值 = "items">
    {
        变量 空数组 <类型 = YYJSON只读数组类>
        如果 (数组JSON == "" || 是否以 (数组JSON, "[") == 假)
        {
            返回 (空数组)
        }
        变量 wrapText <类型 = 文本型>
        wrapText = "{\"" + 包装键名 + "\":" + 数组JSON + "}"
        变量 wrapObj <类型 = YYJSON只读对象类>
        如果 (wrapObj.创建自文本 (wrapText) == 假)
        {
            返回 (空数组)
        }
        返回 (wrapObj.取数组 (包装键名))
    }
    # ======== SQLite 缓存数据库 (v2.3) ==========
    方法 打开缓存数据库 <公开 静态>
    {
        变量 dbPath <类型 = 文本型>
        dbPath = 取运行目录 () + "\\mcp_cache.db"
        如果 (缓存数据库.打开 (dbPath))
        {
            // WAL 模式: 并发读取 + 单写入, 性能最优
            缓存数据库.执行SQL语句 ("PRAGMA journal_mode=WAL", )
            缓存数据库.执行SQL语句 ("PRAGMA synchronous=NORMAL", )
            // 创建异步结果表
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS async_results (task_id TEXT PRIMARY KEY, result_json TEXT NOT NULL, is_waiting INTEGER DEFAULT 0, created_at INTEGER NOT NULL, poll_count INTEGER DEFAULT 0)", )
            缓存数据库.执行SQL语句 ("CREATE INDEX IF NOT EXISTS idx_async_created ON async_results(created_at)", )
            // 创建事件日志表
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS event_log (id INTEGER PRIMARY KEY AUTOINCREMENT, log_type TEXT NOT NULL, event_name TEXT, browser_id INTEGER, data_json TEXT NOT NULL, created_at INTEGER NOT NULL)", )
            缓存数据库.执行SQL语句 ("CREATE INDEX IF NOT EXISTS idx_log_type ON event_log(log_type, created_at)", )
            缓存数据库.执行SQL语句 ("CREATE INDEX IF NOT EXISTS idx_log_event ON event_log(event_name, browser_id)", )
            // 创建响应缓存表
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS response_cache (url TEXT PRIMARY KEY, mime_type TEXT, body BLOB, size INTEGER, created_at INTEGER NOT NULL)", )
            调试输出 ("[MCP] SQLite缓存数据库已打开:", dbPath)
        }
        否则
        {
            调试输出 ("[MCP] 警告: 无法打开缓存数据库, 使用内存模式降级")
            缓存数据库.打开 (":memory:")
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS async_results (task_id TEXT PRIMARY KEY, result_json TEXT NOT NULL, is_waiting INTEGER DEFAULT 0, created_at INTEGER NOT NULL, poll_count INTEGER DEFAULT 0)", )
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS event_log (id INTEGER PRIMARY KEY AUTOINCREMENT, log_type TEXT NOT NULL, event_name TEXT, browser_id INTEGER, data_json TEXT NOT NULL, created_at INTEGER NOT NULL)", )
            缓存数据库.执行SQL语句 ("CREATE TABLE IF NOT EXISTS response_cache (url TEXT PRIMARY KEY, mime_type TEXT, body BLOB, size INTEGER, created_at INTEGER NOT NULL)", )
        }
        // 启动时清理过期数据
        清理过期缓存 ()
        缓存数据库已打开 = 真
    }
    方法 关闭缓存数据库 <公开 静态>
    {
        如果 (缓存数据库已打开 == 假)
        {
            返回
        }
        缓存数据库已打开 = 假
        缓存数据库.关闭 ()
        调试输出 ("[MCP] SQLite缓存数据库已关闭")
    }
    # ======== 异步任务ID生成 ==========
    方法 生成异步任务ID <公开 静态 类型 = 文本型>
    {
        异步任务计数器 = 异步任务计数器 + 1
        变量 时间戳 <类型 = 长整数>
        时间戳 = 取启动时间 ()
        变量 随机盐 <类型 = 整数>
        随机盐 = 取随机数 (10000, 99999)
        返回 ("task_" + 到文本 (时间戳) + "_" + 到文本 (随机盐) + "_" + 到文本 (异步任务计数器))
    }
    # ======== 参数化SQL辅助 (防SQL注入, 替换旧 SQL转义 字符串拼接) ==========
    方法 执行参数化INSERT <公开 静态>
    参数 sql模板 <类型 = 文本型>
    参数 p1 <类型 = 文本型 @默认值 = "">
    参数 p2 <类型 = 文本型 @默认值 = "">
    参数 p3 <类型 = 整数 @默认值 = 0>
    参数 p4 <类型 = 长整数 @默认值 = 0>
    {
        变量 stmt <类型 = SQLite记录集类>
        stmt = 缓存数据库.取记录集 (sql模板, )
        如果 (p1 != "")
        {
            stmt.置文本参数数据 (1, p1)
        }
        如果 (p2 != "")
        {
            stmt.置文本参数数据 (2, p2)
        }
        如果 (p3 != -1)
        {
            stmt.置整数参数数据 (3, p3)
        }
        如果 (p4 != -1)
        {
            stmt.置长整数参数数据 (4, p4)
        }
        stmt.执行语句 ()
        stmt.释放 ()
    }
    方法 执行参数化DELETE <公开 静态>
    参数 sql模板 <类型 = 文本型>
    参数 p1 <类型 = 文本型 @默认值 = "">
    {
        变量 stmt <类型 = SQLite记录集类>
        stmt = 缓存数据库.取记录集 (sql模板, )
        如果 (p1 != "")
        {
            stmt.置文本参数数据 (1, p1)
        }
        stmt.执行语句 ()
        stmt.释放 ()
    }
    # ======== 异步结果存储 (SQLite) — v2.4 参数化查询 ==========
    方法 规范化异步结果JSON <公开 静态 类型 = 文本型>
    参数 结果JSON <类型 = 文本型>
    {
        如果 (结果JSON == "")
        {
            返回 (结果JSON)
        }
        变量 原始长度 <类型 = 整数>
        原始长度 = 取文本长度 (结果JSON)
        如果 (原始长度 <= 异步结果JSON最大字符)
        {
            返回 (结果JSON)
        }
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        包装对象.加入逻辑值成员 ("success", 假)
        包装对象.加入文本成员 ("error", "async结果过大(" + 到文本 (原始长度) + "字符), 已拒绝写入SQLite | 请缩小响应或使用 consume:true 及时读取")
        包装对象.加入整数成员 ("original_size", 原始长度)
        包装对象.加入整数成员 ("max_size", 异步结果JSON最大字符)
        返回 (包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 尝试占用URL请求槽 <公开 静态 类型 = 逻辑型>
    {
        异步缓存锁.加锁 ()
        如果 (活动URL请求数 >= URL请求最大并发)
        {
            异步缓存锁.解锁 ()
            返回 (假)
        }
        活动URL请求数 = 活动URL请求数 + 1
        如果 (活动URL请求数 >= URL请求最大并发 && URL请求槽满起始毫秒 == 0)
        {
            URL请求槽满起始毫秒 = 取启动时间 ()
        }
        异步缓存锁.解锁 ()
        返回 (真)
    }
    方法 释放URL请求槽 <公开 静态>
    {
        异步缓存锁.加锁 ()
        如果 (活动URL请求数 > 0)
        {
            活动URL请求数 = 活动URL请求数 - 1
            最后URL请求槽释放时间 = 取启动时间 ()
            如果 (活动URL请求数 < URL请求最大并发)
            {
                URL请求槽满起始毫秒 = 0
            }
        }
        异步缓存锁.解锁 ()
    }
    方法 构建Base64图片异步JSON <公开 静态 类型 = 文本型>
    参数 字节数据 <类型 = 字节集类>
    参数 mime类型 <类型 = 文本型>
    参数 原始字节数 <类型 = 整数 @默认值 = 0>
    {
        变量 实际大小 <类型 = 整数>
        实际大小 = 原始字节数
        如果 (实际大小 <= 0)
        {
            实际大小 = 取字节集长度 (字节数据)
        }
        如果 (实际大小 > 截图异步最大字节)
        {
            返回 (构建标准失败JSON ("图片过大(" + 到文本 (实际大小) + "字节), 上限=" + 到文本 (截图异步最大字节) + " | 请缩小截图区域或降低分辨率"))
        }
        变量 base64数据 <类型 = 文本型>
        base64数据 = FBrowser_Parser_Base64编码 (字节集到文本 (字节数据))
        变量 包装对象 <类型 = YYJSON对象类>
        包装对象.创建自文本 ("{}")
        包装对象.加入逻辑值成员 ("success", 真)
        包装对象.加入文本成员 ("message", "data:" + mime类型 + ";base64," + base64数据)
        包装对象.加入文本成员 ("mimeType", mime类型)
        包装对象.加入整数成员 ("data_size", 实际大小)
        返回 (包装对象.到可读文本 (YYJSON格式化选项.压缩))
    }
    方法 存储异步结果 <公开 静态>
    参数 任务ID <类型 = 文本型>
    参数 结果JSON <类型 = 文本型>
    {
        如果 (缓存数据库可用 () == 假)
        {
            返回
        }
        变量 存储JSON <类型 = 文本型>
        存储JSON = 规范化异步结果JSON (结果JSON)
        异步缓存锁.加锁 ()
        变量 是否等待 <类型 = 整数>
        是否等待 = 0
        变量 当前时间 <类型 = 长整数>
        当前时间 = 取启动时间 ()
        变量 pollCount <类型 = 整数>
        pollCount = 0
        变量 结果解析 <类型 = YYJSON只读对象类>
        如果 (结果解析.创建自文本 (存储JSON))
        {
            pollCount = yyjson取整数 (结果解析, "_poll_count")
            如果 (结果解析.取逻辑值 ("_waiting"))
            {
                是否等待 = 1
            }
        }
        否则 (寻找文本 (存储JSON, "\"_waiting\":true", 0, 假) != -1)
        {
            是否等待 = 1
        }
        变量 stmt <类型 = SQLite记录集类>
        stmt = 缓存数据库.取记录集 ("INSERT OR REPLACE INTO async_results (task_id, result_json, is_waiting, created_at, poll_count) VALUES (?, ?, ?, ?, ?)", )
        stmt.置文本参数数据 (1, 任务ID)
        stmt.置文本参数数据 (2, 存储JSON)
        stmt.置整数参数数据 (3, 是否等待)
        stmt.置长整数参数数据 (4, 当前时间)
        stmt.置整数参数数据 (5, pollCount)
        stmt.执行语句 ()
        stmt.释放 ()
        修剪异步结果表_已持锁 ()
        异步缓存锁.解锁 ()
    }
    方法 查询异步结果 <公开 静态 类型 = 文本型>
    参数 任务ID <类型 = 文本型>
    参数 取走后删除 <类型 = 逻辑型 @默认值 = 假>
    {
        变量 result <类型 = 文本型>
        result = ""
        如果 (缓存数据库可用 () == 假)
        {
            返回 ("")
        }
        异步缓存锁.加锁 ()
        变量 记录集 <类型 = SQLite记录集类>
        记录集 = 缓存数据库.取记录集 ("SELECT result_json, is_waiting FROM async_results WHERE task_id=?", )
        记录集.置文本参数数据 (1, 任务ID)
        如果 (记录集.执行语句 () == 100)  // SQLITE_ROW
        {
            result = 记录集.读文本数据 (0)
            变量 waiting <类型 = 整数>
            waiting = 记录集.读整数数据 (1)
            如果 (取走后删除 && waiting == 0)
            {
                执行参数化DELETE ("DELETE FROM async_results WHERE task_id=?", 任务ID)
            }
        }
        记录集.释放 ()
        异步缓存锁.解锁 ()
        返回 (result)
    }
    方法 删除异步结果 <公开 静态>
    参数 任务ID <类型 = 文本型>
    {
        如果 (任务ID == "")
        {
            返回
        }
        异步缓存锁.加锁 ()
        执行参数化DELETE ("DELETE FROM async_results WHERE task_id=?", 任务ID)
        异步缓存锁.解锁 ()
    }
    # 兼容旧接口: 存储任务结果 (SQLite 封装, v2.4 参数化)
    方法 存储任务结果 <公开 静态>
    参数 命令ID <类型 = 文本型>
    参数 结果JSON <类型 = 文本型>
    {
        如果 (缓存数据库可用 () == 假)
        {
            返回
        }
        异步缓存锁.加锁 ()
        变量 当前时间 <类型 = 长整数>
        当前时间 = 取启动时间 ()
