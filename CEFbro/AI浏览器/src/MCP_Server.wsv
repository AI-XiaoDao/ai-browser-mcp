    方法 Runtime取对象属性JSON <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 objectId <类型 = 文本型>
    参数 最大属性数 <类型 = 整数 @默认值 = 40>
    {
        如果 (objectId == "")
        {
            返回 ("[]")
        }
        变量 gpParams <类型 = YYJSON对象类>
        gpParams.创建自文本 ("{}")
        gpParams.加入文本成员 ("objectId", objectId)
        gpParams.加入逻辑值成员 ("ownProperties", 真)
        gpParams.加入逻辑值成员 ("generatePreview", 真)
        变量 raw <类型 = 文本型>
        raw = 执行CDP并同步等待 (命令ID + "_gp", "Runtime.getProperties", gpParams.到可读文本 (YYJSON格式化选项.压缩), 8000)
        如果 (CDP同步结果是否成功 (raw) == 假)
        {
            返回 ("[]")
        }
        变量 包装 <类型 = YYJSON只读对象类>
        如果 (包装.创建自文本 (raw) == 假)
        {
            返回 ("[]")
        }
        变量 cdpText <类型 = 文本型>
        cdpText = yyjson取文本 (包装, "result")
        变量 cdp <类型 = YYJSON只读对象类>
        如果 (cdpText == "" || cdp.创建自文本 (cdpText) == 假)
        {
            返回 ("[]")
        }
        变量 props <类型 = YYJSON只读数组类>
        props = cdp.取数组 ("result")
        如果 (props.是否为空对象 () || props.取成员数 () == 0)
        {
            返回 ("[]")
        }
        变量 上限 <类型 = 整数>
        上限 = (整数)props.取成员数 ()
        如果 (上限 > 最大属性数)
        {
            上限 = 最大属性数
        }
        变量 out <类型 = 文本型>
        out = "["
        计次循环 (上限)
        {
            如果 (取循环索引 () > 0)
            {
                out = out + ","
            }
            变量 pi <类型 = YYJSON只读对象类>
            pi = props.取成员 (取循环索引 ())
            变量 pval <类型 = YYJSON只读对象类>
            pval = pi.取对象 ("value")
            out = out + "{\"name\":\"" + JSON转义文本 (yyjson取文本 (pi, "name")) + "\",\"value\":" + RemoteObject摘要JSON (pval) + "}"
        }
        out = out + "]"
        返回 (out)
    }
