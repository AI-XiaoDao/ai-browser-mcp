<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
类 浏览器容器 <公开 折叠 @全局类 = 真>
{
    变量 最新地址 <公开 静态 类型 = 文本型>
    变量 地址编辑框 <公开 静态 类型 = 编辑框>
    变量 浏览器数组 <公开 静态 类型 = 对象数组类>
    变量 网页数据 <公开 静态 类型 = 文本型 注释 = "内置欢迎页完整HTML(编译时IDE自动嵌入资源)">
    变量 MCP服务已就绪 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 欢迎页已导航 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 欢迎页导航已发起 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "已调用载入地址, 等待load_end确认">
    变量 欢迎页导航发起毫秒 <公开 静态 类型 = 长整数 值 = 0>
    常量 欢迎页导航超时毫秒 <类型 = 整数 值 = 15000>
    变量 地址栏已绑定 <公开 静态 类型 = 逻辑型 值 = 假>
    方法 重置欢迎页导航状态 <公开 静态>
    {
        欢迎页已导航 = 假
        欢迎页导航已发起 = 假
        欢迎页导航发起毫秒 = 0
    }
    方法 标记欢迎页导航已发起 <公开 静态>
    {
        欢迎页导航已发起 = 真
        欢迎页导航发起毫秒 = 取启动时间 ()
    }
    方法 检查欢迎页导航超时 <公开 静态 类型 = 逻辑型>
    {
        如果 (欢迎页导航已发起 == 假 || 欢迎页已导航)
        {
            返回 (假)
        }
        如果 (欢迎页导航发起毫秒 <= 0)
        {
            返回 (假)
        }
        如果 (取启动时间 () - 欢迎页导航发起毫秒 < 欢迎页导航超时毫秒)
        {
            返回 (假)
        }
        重置欢迎页导航状态 ()
        调试输出 ("[MCP] 欢迎页导航超时, 已重置状态以便重试")
        返回 (真)
    }
    方法 尝试恢复欢迎页导航 <公开 静态>
    {
        检查欢迎页导航超时 ()
        如果 (欢迎页已导航 || 欢迎页导航已发起 || MCP服务已就绪 == 假)
        {
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = MCP命令服务器.取主浏览器 ()
        如果 (browser.是否为空 () || browser.是否已关闭 ())
        {
            返回
        }
        变量 frame <类型 = 类_FBrowser_框架>
        frame = MCP命令服务器.取安全主框架 (browser)
        如果 (frame.是否有效 () == 假)
        {
            返回
        }
        变量 当前URL <类型 = 文本型>
        当前URL = frame.取地址 ()
        如果 (当前URL == "about:blank" || 当前URL == "" || 当前URL == 取欢迎页地址 ())
        {
            尝试导航欢迎页 ()
        }
    }
    变量 需要重建浏览器 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "主浏览器被关闭后由UI线程重建">
    变量 需要恢复布局 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "MCP测试改乱布局/自动尺寸后由UI线程恢复">
    方法 标记需要重建浏览器 <公开 静态>
    {
        需要重建浏览器 = 真
    }
    方法 标记需要恢复布局 <公开 静态>
    {
        需要恢复布局 = 真
    }
    方法 恢复欢迎页 <公开 静态>
    {
        重置欢迎页导航状态 ()
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = MCP命令服务器.取主浏览器 ()
        如果 (browser.是否为空 () || browser.是否已关闭 ())
        {
            返回
        }
        变量 欢迎地址 <类型 = 文本型>
        欢迎地址 = 取欢迎页地址 ()
        变量 frame <类型 = 类_FBrowser_框架>
        frame = MCP命令服务器.取安全主框架 (browser)
        如果 (frame.是否有效 () == 假)
        {
            返回
        }
        frame.载入地址 (欢迎地址)
        最新地址 = 欢迎地址
        标记欢迎页导航已发起 ()
        如果 (地址栏已绑定)
        {
            地址编辑框.内容 = 欢迎地址
        }
    }
    方法 取欢迎页地址 <公开 静态 类型 = 文本型>
    {
        返回 ("http://" + MCP命令服务器.服务器绑定地址 + ":" + 到文本 (MCP命令服务器.服务器端口) + "/")
    }
    方法 尝试导航欢迎页 <公开 静态>
    {
        检查欢迎页导航超时 ()
        如果 (欢迎页已导航 || 欢迎页导航已发起 || MCP服务已就绪 == 假)
        {
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = MCP命令服务器.取主浏览器 ()
        如果 (browser.是否为空 () || browser.是否已关闭 ())
        {
            返回
        }
        变量 欢迎地址 <类型 = 文本型>
        欢迎地址 = 取欢迎页地址 ()
        变量 frame <类型 = 类_FBrowser_框架>
        frame = MCP命令服务器.取安全主框架 (browser)
        如果 (frame.是否有效 () == 假)
        {
            返回
        }
        frame.载入地址 (欢迎地址)
        最新地址 = 欢迎地址
        标记欢迎页导航已发起 ()
        如果 (地址栏已绑定)
        {
            地址编辑框.内容 = 欢迎地址
        }
    }
    # ── 返回欢迎页 HTML (替换版本占位符) ──
    方法 取欢迎页HTML <公开 静态 类型 = 文本型>
    {
        变量 结果HTML <类型 = 文本型>
        结果HTML = 网页数据
        如果 (结果HTML == "")
        {
            变量 HTML路径 <类型 = 文本型>
            HTML路径 = 取运行目录 () + "\\index.html"
            如果 (文件是否存在 (HTML路径))
            {
                变量 HTML字节 <类型 = 字节集类>
                HTML字节 = 读入文件 (HTML路径)
                如果 (取字节集长度 (HTML字节) > 0)
                {
                    结果HTML = UTF8到文本 (HTML字节)
                }
            }
        }
        子文本替换 (结果HTML, "{{MCP_VERSION}}", MCP命令服务器.MCP_版本号, , , 假)
        子文本替换 (结果HTML, "{{MCP_HTTP}}", MCP命令服务器.取MCP_HTTP地址 (), , , 假)
        子文本替换 (结果HTML, "{{MCP_WS}}", MCP命令服务器.取MCP_WS地址 (), , , 假)
        子文本替换 (结果HTML, "{{MCP_HOST}}", MCP命令服务器.服务器绑定地址, , , 假)
        子文本替换 (结果HTML, "{{MCP_PORT}}", 到文本 (MCP命令服务器.服务器端口), , , 假)
        返回 (结果HTML)
    }
}
# ================================================================
# CP 浏览器命令服务器 — HTTP + WebSocket 双协议
# 用 yyjson 构建/解析JSON，避免手写JSON字符串的转义错误
# ================================================================
类 MCP命令服务器 <公开 @全局类 = 真 @视窗.附属文件 = "..\\docs > docs" @视窗.附属文件 = "mcp_config.json" @视窗.附属文件 = "mcp_config.README.md" @视窗.附属文件 = "index.html" @视窗.附属文件 = "..\\mcp_bridge.js" @视窗.附属文件 = "..\\mcp_client.js" @视窗.附属文件 = "..\\mcp_check.js" @视窗.附属文件 = "..\\run_all_tests.js" @视窗.附属文件 = "..\\full_test.js" @视窗.附属文件 = "..\\regression_sync_wait.js" @视窗.附属文件 = "..\\scenario_test.js" @视窗.附属文件 = "..\\tool_test_all.js" @视窗.附属文件 = "..\\workflow_runner.js" @视窗.附属文件 = "..\\workflows > workflows" @视窗.附属文件 = "..\\scenarios > scenarios" @视窗.附属文件 = "..\\test_fixtures > test_fixtures">
{
    变量 服务器端口 <公开 静态 类型 = 整数 值 = 9222>
    变量 是否启用 <公开 静态 类型 = 逻辑型 值 = 真>
    变量 浏览器数组锁 <公开 静态 类型 = 互斥锁类 注释 = "保护浏览器数组的跨线程访问(UI线程 vs MCP server线程)">
    变量 MCP执行锁 <公开 静态 类型 = 互斥锁类 注释 = "序列化执行浏览器命令, 防止目标浏览器ID等静态上下文竞态">
    变量 异步缓存锁 <公开 静态 类型 = 互斥锁类 注释 = "保护SQLite数据库的跨线程访问(UI回调 vs MCP server)">
    变量 是否记录网络 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 是否记录控制台 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 是否缓存响应 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 是否详细记录网络 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 工具列表缓存 <公开 静态 类型 = 文本型 值 = "">
    变量 当前请求追踪ID <公开 静态 类型 = 文本型 值 = "">
    变量 目标浏览器ID <公开 静态 类型 = 整数 值 = 0>
    变量 紧凑响应模式 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 当前命令方法名 <公开 静态 类型 = 文本型 值 = "" 注释 = "执行浏览器命令时设置, 供 sync-wait 判定">
    变量 当前命令参数JSON <公开 静态 类型 = YYJSON只读对象类 注释 = "当前 tools/call arguments">
    # ======== 安全与配置 (v1.4) ==========
    变量 API密钥 <公开 静态 类型 = 文本型 值 = "">
    变量 是否启用认证 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 速率限制_每分钟 <公开 静态 类型 = 整数 值 = 300>
    变量 速率限制_计数器 <公开 静态 类型 = 整数 值 = 0>
    变量 速率限制_窗口开始 <公开 静态 类型 = 长整数 值 = 0>
    变量 配置已加载 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 VIP授权码 <公开 静态 类型 = 文本型 值 = "" 注释 = "VIP功能授权码, 启动时从mcp_config.json读取, 供启动类使用">
    变量 服务器绑定地址 <公开 静态 类型 = 文本型 值 = "127.0.0.1">
    变量 MCP服务器实例 <公开 静态 类型 = 类_FBrowser_服务器 注释 = "HTTP/WS 内嵌服务器, 退出时须关闭()">
    变量 MCP正在关闭 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 文档根目录缓存 <公开 静态 类型 = 文本型 值 = "" 注释 = "解析后的 docs 物理目录, 启动后缓存">
    # ======== 命令注册表(字典预查找) ==========
    变量 命令注册表 <公开 静态 类型 = 类_FBrowser_字典值>
    # ======== SQLite 持久缓存 (v2.3 替换 CEF Dict + 文件系统) ==========
    变量 缓存数据库 <公开 静态 类型 = SQLite数据库类>
    变量 异步任务计数器 <公开 静态 类型 = 长整数 值 = 0>
    常量 缓存保留天数 <公开 类型 = 整数 值 = 7>
    常量 缓存最大条目 <公开 类型 = 整数 值 = 10000>
    常量 同步等待_默认毫秒 <公开 类型 = 整数 值 = 5000 注释 = "服务端内聚等待默认超时">
    常量 同步等待_快读毫秒 <公开 类型 = 整数 值 = 3000 注释 = "标题/DOM/JS等轻量读">
    常量 同步等待_轮询间隔 <公开 类型 = 整数 值 = 50 注释 = "poll SQLite 间隔">
    # v2.4 统一魔法数字为命名常量
    常量 截断_源码默认字节 <公开 类型 = 整数 值 = 262144 注释 = "256KB">
    变量 网络日志最大字节 <公开 静态 类型 = 整数 值 = 262144 注释 = "event_log单条JSON最大字符数, 可由mcp_config.json覆盖">
    常量 截断_源码最大字节 <公开 类型 = 整数 值 = 1048576 注释 = "1MB">
    常量 截断_CDP结果最大字节 <公开 类型 = 整数 值 = 1048576 注释 = "1MB">
    常量 截断_VIP数据最大字节 <公开 类型 = 整数 值 = 262144 注释 = "256KB">
    常量 Cookie最大项数 <公开 类型 = 整数 值 = 200>
    常量 Cookie绝对上限 <公开 类型 = 整数 值 = 500>
    常量 URL请求默认超时 <公开 类型 = 整数 值 = 30000>
    常量 毫秒_每天 <公开 类型 = 长整数 值 = 86400000>
    常量 速率限制_衰减因子 <公开 类型 = 整数 值 = 2 注释 = "分钟边界计数÷2, 防突发重置">
    常量 日志清理间隔 <公开 类型 = 整数 值 = 1000>
    常量 缓存清理_保留缓冲 <公开 类型 = 整数 值 = 500 注释 = "清理时多保留的条数">
    常量 等待任务最大滞留毫秒 <公开 类型 = 整数 值 = 3600000 注释 = "abandoned _waiting 任务最长保留1小时">
    常量 事件日志最大条目 <公开 类型 = 整数 值 = 10000>
    常量 响应缓存最大条目 <公开 类型 = 整数 值 = 2000>
    常量 下载保留天数 <公开 类型 = 整数 值 = 30 注释 = "Downloads 自动清理: 超过此天数的文件将被删除">
    常量 响应缓存单条最大字节 <公开 类型 = 整数 值 = 10485760 注释 = "10MB, 超出则跳过写入">
    常量 CDP映射清理间隔 <公开 类型 = 整数 值 = 100>
    常量 拦截规则最大行数 <公开 类型 = 整数 值 = 200>
    常量 定期维护间隔毫秒 <公开 类型 = 整数 值 = 60000 注释 = "UI时钟触发后台清理间隔">
    常量 浏览器实例最大数量 <公开 类型 = 整数 值 = 16 注释 = "含主窗口+弹窗, 超出则拒绝新弹窗">
    常量 批量命令最大条数 <公开 类型 = 整数 值 = 50>
    常量 URL请求最大并发 <公开 类型 = 整数 值 = 8>
    常量 截图异步最大字节 <公开 类型 = 整数 值 = 524288 注释 = "512KB, 超出拒绝写入SQLite">
    常量 异步结果JSON最大字符 <公开 类型 = 整数 值 = 1048576 注释 = "1MB">
    常量 异步结果非等待保留毫秒 <公开 类型 = 整数 值 = 86400000 注释 = "24小时, 比7天TTL更积极">
    // TLS 版本映射常量 (FBrowser 指纹 API 枚举值, 用于 fingerprint ssl)
    常量 TLS指纹_1_0 <公开 类型 = 整数 值 = 769>
    常量 TLS指纹_1_1 <公开 类型 = 整数 值 = 790>
    常量 TLS指纹_1_2 <公开 类型 = 整数 值 = 791>
    常量 TLS指纹_1_3 <公开 类型 = 整数 值 = 792>
    常量 MCP_协议版本 <公开 类型 = 文本型 值 = "2026-06-21">
    常量 MCP_服务器名 <公开 类型 = 文本型 值 = "AI浏览器 MCP Server">
    常量 MCP_版本号 <公开 类型 = 文本型 值 = "2.6.0">
    常量 WS最大消息字节 <公开 类型 = 整数 值 = 5242880>
    常量 错误_无浏览器 <公开 类型 = 文本型 值 = "没有可用的浏览器 | 请启动AI浏览器GUI窗口(自动创建), 或确认 /health 返回 browsers>0">
    常量 错误_缺少参数 <公开 类型 = 文本型 值 = "参数不能为空 | 请查看工具描述补全必填参数">
    常量 错误_VIP不可用 <公开 类型 = 文本型 值 = "VIP控制器不可用,需要VIP授权 | 请在 mcp_config.json 配置 vip_code">
    变量 请求计数器 <公开 静态 类型 = 长整数 值 = 0>
    变量 服务器启动时间戳 <公开 静态 类型 = 长整数 值 = 0>
    变量 活动URL请求数 <公开 静态 类型 = 整数 值 = 0>
    变量 最后URL请求槽释放时间 <公开 静态 类型 = 长整数 值 = 0 注释 = "用于检测粘滞的URL请求槽(回调未触发)">
    变量 URL请求槽满起始毫秒 <公开 静态 类型 = 长整数 值 = 0 注释 = "并发槽首次打满的时刻, 用于无释放回调时的粘滞检测">
    # ======== 全局持久配置 (新浏览器创建时自动应用) ==========
    变量 持久代理地址 <公开 静态 类型 = 文本型 值 = "">
    变量 持久代理账号 <公开 静态 类型 = 文本型 值 = "">
    变量 持久代理密码 <公开 静态 类型 = 文本型 值 = "">
    变量 持久缩放级别 <公开 静态 类型 = 小数 值 = 0>
    变量 持久静音状态 <公开 静态 类型 = 逻辑型 值 = 假>
    变量 持久V8扩展列表 <公开 静态 类型 = 文本数组类>
    变量 缓存数据库已打开 <公开 静态 类型 = 逻辑型 值 = 假>
    常量 持久V8扩展上限 <公开 类型 = 整数 值 = 100 注释 = "persist inject 最大条目, 超出删最旧">
    # ======== Hook开关 (事件预注册 + 动态启用, 参照网络日志模式) ==========
    变量 是否Hook导航 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_即将导航中检查拦截规则">
    变量 是否Hook资源 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_获取资源处理器中检查替换规则">
    变量 是否Hook音频 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_获取音频参数中修改音频指纹">
    变量 是否Hook弹窗 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_即将打开新窗口中自定义弹窗属性">
    变量 导航拦截规则 <公开 静态 类型 = 文本型 值 = "" 注释 = "JSON: [{action:block|redirect,url:string,target:string}]">
    变量 资源替换规则 <公开 静态 类型 = 文本型 值 = "" 注释 = "JSON: [{action:block|replace_data|replace_file,url:string,...}]">
    变量 音频指纹配置 <公开 静态 类型 = 文本型 值 = "" 注释 = "JSON: {sample_rate:int,channels:int,...}">
    变量 弹窗配置 <公开 静态 类型 = 文本型 值 = "" 注释 = "JSON: {width:int,height:int,x:int,y:int,...}">
    # ======== 浏览器事件监控开关 (事件存入异步缓存, 可通过 browser_event 查询) ==========
    变量 是否监控载入事件 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_载入开始/载入结束/载入错误 → browser_event:load_start|load_end|load_error">
    变量 是否监控标题改变 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_标题被改变 → browser_event:title_changed">
    变量 是否监控加载进度 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_加载进度被改变 → browser_event:load_progress">
    变量 是否监控资源事件 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_即将加载资源/响应资源/重定向 → browser_event:resource_*">
    变量 是否监控对话框 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "JS alert/confirm/prompt/onbeforeunload → browser_event:js_dialog">
    变量 是否监控全屏 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_全屏模式被改变 → browser_event:fullscreen">
    变量 是否监控图标 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_网页图标被改变 → browser_event:favicon">
    变量 是否监控查找 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_查找返馈 → browser_event:find_result">
    变量 是否监控框架 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "创建/拆离/主框架变更 → browser_event:frame_*">
    变量 是否监控下载事件 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "浏览器_可下载/下载进度 → browser_event:download_*">
    变量 是否监控键盘焦点 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "键盘/焦点事件 → browser_event:key_focus_*">
    变量 是否监控生命周期 <公开 静态 类型 = 逻辑型 值 = 假
            注释 = "创建/关闭/地址变更/执行关闭 → browser_event:browser_created|browser_closing|url_changed|do_close">
    # ======== 应用级事件监控 (全局生命周期, 无特定浏览器ID) ==========
    变量 是否监控应用事件 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "渲染进程创建/销毁/V8释放/异常/焦点/载入状态 → app_event:*">
    变量 是否自动保存下载 <公开 静态 类型 = 逻辑型 值 = 真 注释 = "浏览器_即将下载时自动保存到Downloads目录">
    变量 是否自动关闭JS对话框 <公开 静态 类型 = 逻辑型 值 = 假 注释 = "自动化模式下自动确认alert/confirm/prompt">
    # ======== 启动服务器 ==========
    # ======== 加载配置文件 ==========
    方法 取MCP_WS地址 <公开 静态 类型 = 文本型>
    {
        返回 ("ws://" + 服务器绑定地址 + ":" + 到文本 (服务器端口))
    }
    方法 取MCP_HTTP地址 <公开 静态 类型 = 文本型>
    {
        返回 ("http://" + 服务器绑定地址 + ":" + 到文本 (服务器端口))
    }
    方法 加载MCP配置 <公开 静态>
    {
        如果真 (配置已加载)
        {
            返回
        }
        变量 配置路径 <类型 = 文本型>
        配置路径 = 取运行目录 () + "\\mcp_config.json"
        如果 (文件是否存在 (配置路径) == 假)
        {
            调试输出 ("[MCP] 配置文件不存在, 使用默认配置:", 配置路径)
            配置已加载 = 真
            是否启用认证 = 假
            返回
        }
        变量 配置字节 <类型 = 字节集类>
        配置字节 = 读入文件 (配置路径)
        如果 (取字节集长度 (配置字节) == 0)
        {
            调试输出 ("[MCP] 配置文件为空, 使用默认配置")
            配置已加载 = 真
            返回
        }
        变量 配置JSON <类型 = 文本型>
        配置JSON = UTF8到文本 (配置字节)
        变量 配置解析 <类型 = YYJSON只读对象类>
        如果 (配置解析.创建自文本 (配置JSON) == 假)
        {
            调试输出 ("[MCP] 配置文件JSON解析失败, 使用默认配置")
            配置已加载 = 真
            返回
        }
        // 读取并解析JSON配置
        // 端口
        变量 配置端口 <类型 = 整数>
        配置端口 = 配置解析.取整数 ("port")
        如果 (配置端口 > 0 && 配置端口 < 65536)
        {
            服务器端口 = 配置端口
        }
        // 绑定地址
        变量 配置地址 <类型 = 文本型>
        配置地址 = 配置解析.取文本 ("bind_address")
        如果 (配置地址 != "")
        {
            服务器绑定地址 = 配置地址
        }
        // API密钥
        变量 配置密钥 <类型 = 文本型>
        配置密钥 = 配置解析.取文本 ("api_key")
        变量 禁用认证 <类型 = 逻辑型>
        禁用认证 = 配置解析.取逻辑值 ("disable_auth")
        如果 (禁用认证)
        {
            是否启用认证 = 假
            调试输出 ("[MCP] API认证已通过配置禁用")
        }
        否则 (配置密钥 != "" && 配置密钥 != "YOUR_API_KEY_HERE")
        {
            API密钥 = 配置密钥
            是否启用认证 = 真
            调试输出 ("[MCP] API密钥认证已启用 (来自配置)")
        }
        否则
        {
            是否启用认证 = 假
            调试输出 ("[MCP] 未配置API密钥, 认证已禁用 (仅本地127.0.0.1)")
        }
        // 速率限制
        变量 配置速率 <类型 = 整数>
        配置速率 = 配置解析.取整数 ("rate_limit_per_minute")
        如果 (配置速率 >= 0)
        {
            速率限制_每分钟 = 配置速率
        }
        // 网络日志
        如果 (配置解析.取逻辑值 ("enable_network_log"))
        {
            是否记录网络 = 真
        }
        如果 (配置解析.取逻辑值 ("enable_console_log"))
        {
            是否记录控制台 = 真
        }
        如果 (配置解析.取逻辑值 ("enable_response_cache"))
        {
            是否缓存响应 = 真
            调试输出 ("[MCP] 响应缓存已启用 (SQLite)")
        }
        变量 配置网络字节 <类型 = 整数>
        配置网络字节 = 配置解析.取整数 ("network_log_max_bytes")
        如果 (配置网络字节 > 0)
        {
            网络日志最大字节 = 配置网络字节
        }
        // === VIP授权码 (供启动类使用, 需在FBrowser初始化前设置) ===
        变量 配置VIP码 <类型 = 文本型>
        配置VIP码 = 配置解析.取文本 ("vip_code")
        如果 (配置VIP码 != "")
        {
            VIP授权码 = 配置VIP码
        }
        如果 (配置解析.取逻辑值 ("auto_download_save") == 假)
        {
            是否自动保存下载 = 假
        }
        如果 (配置解析.取逻辑值 ("auto_dismiss_js_dialog"))
        {
            是否自动关闭JS对话框 = 真
        }
        配置已加载 = 真
        如果 (是否启用认证 == 假 && 服务器绑定地址 != "127.0.0.1" && 服务器绑定地址 != "::1" && 服务器绑定地址 != "localhost")
        {
            调试输出 ("[MCP] 警告: bind_address=" + 服务器绑定地址 + " 但未启用API认证, 建议配置 api_key 或保持本地绑定")
        }
        调试输出 ("[MCP] 配置已加载, 端口:", 服务器端口, " 绑定:", 服务器绑定地址, " 认证:", 是否启用认证, " 速率限制:", 速率限制_每分钟, "/min")
    }
    # ======== API密钥验证 ==========
    方法 验证API密钥 <公开 静态 类型 = 逻辑型>
    参数 请求参数 <类型 = YYJSON只读对象类>
    {
        如果 (是否启用认证 == 假)
        {
            返回 (真)  // 未启用认证, 全部放行
        }
        如果 (请求参数.是否为空 ())
        {
            返回 (假)  // 启用认证但无参数
        }
        变量 客户端密钥 <类型 = 文本型>
        客户端密钥 = 请求参数.取文本 ("_api_key")
        如果 (客户端密钥 == "")
        {
            客户端密钥 = 请求参数.取文本 ("api_key")
        }
        返回 (客户端密钥 == API密钥)
    }
    # ======== 速率限制检查 ==========
    # 全局速率限制(第二道防线)
    方法 检查速率限制 <公开 静态 类型 = 逻辑型>
    {
        如果 (速率限制_每分钟 <= 0)
        {
            返回 (真)  // 未启用速率限制
        }
        变量 当前时间 <类型 = 长整数>
        当前时间 = 取启动时间 ()
        // 滑动窗口: 每分钟重置
        如果 (当前时间 - 速率限制_窗口开始 >= 60000)
        {
            速率限制_窗口开始 = 当前时间
            速率限制_计数器 = 1
            返回 (真)
        }
        速率限制_计数器 = 速率限制_计数器 + 1
        返回 (速率限制_计数器 <= 速率限制_每分钟)
    }
    # 按IP速率限制(第一道防线, 每IP独立计数)
    变量 IP速率限制字典 <公开 静态 类型 = 类_FBrowser_字典值>
    变量 IP速率_当前分钟桶 <公开 静态 类型 = 整数 值 = 0>
    变量 应用事件节流字典 <公开 静态 类型 = 类_FBrowser_字典值 注释 = "应用级节流(如 focus_ts), 与 IP 速率限制分离">
    变量 CDP附着浏览器ID <公开 静态 类型 = 整数 值 = 0 注释 = "DevTools 观察者注册所在的 browser_id">
    方法 检查IP速率限制 <公开 静态 类型 = 逻辑型>
    参数 客户端地址 <类型 = 文本型 @默认值 = "">
    {
        如果 (速率限制_每分钟 <= 0)
        {
            返回 (真)
        }
        如果 (客户端地址 == "")
        {
            // 无法识别IP时回退到全局检查
            返回 (检查速率限制 ())
        }
        如果 (IP速率限制字典.是否为空对象 () || IP速率限制字典.是否为空 ())
        {
            IP速率限制字典.创建 ()
        }
        变量 当前时间 <类型 = 长整数>
        当前时间 = 取启动时间 ()
        // v2.4: 分钟桶切换 → 平滑衰减所有IP计数器(/衰减因子), 防脉冲攻击
        变量 当前分钟桶 <类型 = 整数>
        当前分钟桶 = 文本到整数 (到文本 (当前时间 / 60000))
        如果 (当前分钟桶 != IP速率_当前分钟桶)
        {
            // 遍历所有IP条目, 将计数/衰减因子 (最小衰减至0, 直接移除)
            变量 ipKeys <类型 = FBrowser_文本数组>
            ipKeys = IP速率限制字典.取关键字 ()
            变量 keyCount <类型 = 整数>
            keyCount = ipKeys.取个数 ()
            如果 (keyCount > 0)
            {
                计次循环 (keyCount)
                {
                    变量 k <类型 = 文本型>
                    k = ipKeys.取数据 (取循环索引 ())
                    变量 oldCount <类型 = 整数>
                    oldCount = IP速率限制字典.取整数值 (k)
                    如果 (oldCount > 速率限制_衰减因子)
                    {
                        IP速率限制字典.置整数值 (k, oldCount / 速率限制_衰减因子)
                    }
                    否则
                    {
                        IP速率限制字典.移除 (k)
                    }
                }
            }
            IP速率_当前分钟桶 = 当前分钟桶
        }
        // 获取当前IP计数
        变量 IP计数器 <类型 = 整数>
        IP计数器 = IP速率限制字典.取整数值 (客户端地址)
        IP计数器 = IP计数器 + 1
        IP速率限制字典.置整数值 (客户端地址, IP计数器)
        如果 (IP计数器 > 速率限制_每分钟)
        {
            调试输出 ("[MCP] IP速率限制触发:", 客户端地址, "计数器:", IP计数器)
            返回 (假)
        }
        返回 (真)
    }
    # ======== 构建命令注册表 (字典预查找, 避免线性if-else) ==========
