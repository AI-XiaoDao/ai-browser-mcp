            变量 stmt <类型 = SQLite记录集类>
            stmt = 缓存数据库.取记录集 ("DELETE FROM event_log WHERE log_type=? AND event_name=?", )
            stmt.置文本参数数据 (1, "cdp_event")
            stmt.置文本参数数据 (2, 事件名)
            stmt.执行语句 ()
            stmt.释放 ()
            异步缓存锁.解锁 ()
        }
        删除异步结果 ("cdp_event:" + 事件名)
    }
