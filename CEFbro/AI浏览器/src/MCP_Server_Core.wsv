        否则 (方法名 == "browser.debugger_set_breakpoint" || 方法名 == "browser_debugger_set_breakpoint")
        {
            变量 bpUrl <类型 = 文本型>
            bpUrl = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (bpUrl == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "url " + MCP命令服务器.错误_缺少参数))
            }
            变量 bpParams <类型 = YYJSON对象类>
            bpParams.创建自文本 ("{}")
            bpParams.加入文本成员 ("urlRegex", bpUrl)
            变量 bpLine <类型 = 整数>
            bpLine = MCP命令服务器.yyjson取整数 (参数JSON, "line")
            如果 (bpLine == 0)
            {
                bpLine = MCP命令服务器.yyjson取整数 (参数JSON, "line_number")
            }
            bpParams.加入整数成员 ("lineNumber", bpLine)
            变量 bpCol <类型 = 整数>
            bpCol = MCP命令服务器.yyjson取整数 (参数JSON, "column")
            如果 (bpCol == 0)
            {
                bpCol = MCP命令服务器.yyjson取整数 (参数JSON, "column_number")
            }
            变量 hasCol <类型 = 逻辑型 值 = 假>
            如果 (MCP命令服务器.yyjson取文本 (参数JSON, "column") != "" || MCP命令服务器.yyjson取文本 (参数JSON, "column_number") != "")
            {
                hasCol = 真
            }
            如果 (hasCol)
            {
                bpParams.加入整数成员 ("columnNumber", bpCol)
            }
            返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Debugger.setBreakpointByUrl", bpParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 调用栈 ===
        否则 (方法名 == "browser.debugger_stack" || 方法名 == "browser_debugger_stack")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.getStackTrace", 参数JSON))
        }
        // === 断点处查看变量 ===
        否则 (方法名 == "browser.debugger_evaluate" || 方法名 == "browser_debugger_evaluate")
        {
            变量 frameId <类型 = 文本型>
            frameId = MCP命令服务器.yyjson取文本 (参数JSON, "call_frame_id")
            变量 expr <类型 = 文本型>
            expr = MCP命令服务器.yyjson取文本 (参数JSON, "expression")
            如果 (frameId == "" || expr == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "call_frame_id和expression " + MCP命令服务器.错误_缺少参数))
            }
            变量 parseText <类型 = 文本型>
            parseText = MCP命令服务器.yyjson取文本 (参数JSON, "parse")
            如果 (parseText == "true" || parseText == "1")
            {
                变量 expandEv <类型 = 逻辑型>
                expandEv = MCP命令服务器.取Debugger求值展开 (参数JSON)
                变量 rbvEv <类型 = 逻辑型>
                rbvEv = MCP命令服务器.取Debugger求值ReturnByValue (参数JSON)
                变量 evRaw <类型 = 文本型>
                evRaw = MCP命令服务器.执行Debugger帧求值并等待 (命令ID, frameId, expr, 12000, rbvEv)
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, MCP命令服务器.解析Debugger求值结果 (evRaw, 命令ID, frameId, expr, expandEv)))
            }
            变量 evParams <类型 = YYJSON对象类>
            evParams.创建自文本 ("{}")
            evParams.加入文本成员 ("callFrameId", frameId)
            evParams.加入文本成员 ("expression", expr)
            如果 (MCP命令服务器.取Debugger求值ReturnByValue (参数JSON))
            {
                evParams.加入逻辑值成员 ("returnByValue", 真)
            }
            返回 (MCP命令服务器.执行CDP命令_带参数 (命令ID, "Debugger.evaluateOnCallFrame", evParams.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 断点调试: 等待暂停 / 最近暂停 / 批量帧内求值 ===
        否则 (方法名 == "browser.debugger_wait_paused" || 方法名 == "browser_debugger_wait_paused")
        {
            变量 maxMs <类型 = 整数>
            maxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (maxMs == 0)
            {
                maxMs = 30000
            }
            变量 清除旧 <类型 = 逻辑型 值 = 假>
            变量 freshText <类型 = 文本型>
            freshText = MCP命令服务器.yyjson取文本 (参数JSON, "fresh")
            如果 (freshText == "true" || freshText == "1")
            {
                清除旧 = 真
            }
            变量 rawPaused <类型 = 文本型>
            rawPaused = MCP命令服务器.等待CDP事件 ("Debugger.paused", maxMs, 清除旧)
            如果 (rawPaused == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "等待 Debugger.paused 超时(" + 到文本 (maxMs) + "ms) | 流程: debugger_enable → set_breakpoint → navigate"))
            }
            变量 摘要文本 <类型 = 文本型>
            摘要文本 = MCP命令服务器.解析Debugger暂停摘要 (rawPaused)
            变量 摘要对象 <类型 = YYJSON只读对象类>
            如果 (摘要对象.创建自文本 (摘要文本) == 假 || MCP命令服务器.yyjson取文本 (摘要对象, "call_frame_id") == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "Debugger.paused 事件无效或缺少 call_frame_id | 请检查 debugger_enable 与断点 URL"))
            }
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 摘要文本))
        }
        否则 (方法名 == "browser.debugger_last_paused" || 方法名 == "browser_debugger_last_paused")
        {
            变量 rawLast <类型 = 文本型>
            rawLast = MCP命令服务器.取CDP事件数据JSON ("Debugger.paused")
            如果 (rawLast == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "尚无 Debugger.paused 事件 | 请先 enable + 断点 + 触发暂停"))
            }
            变量 摘要最后 <类型 = 文本型>
            摘要最后 = MCP命令服务器.解析Debugger暂停摘要 (rawLast)
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 摘要最后))
        }
        否则 (方法名 == "browser.debugger_inspect" || 方法名 == "browser_debugger_inspect")
        {
            变量 frameId2 <类型 = 文本型>
            frameId2 = MCP命令服务器.yyjson取文本 (参数JSON, "call_frame_id")
            如果 (frameId2 == "")
            {
                变量 rawInspect <类型 = 文本型>
                rawInspect = MCP命令服务器.取CDP事件数据JSON ("Debugger.paused")
                如果 (rawInspect != "")
                {
                    变量 暂停摘要 <类型 = 文本型>
                    暂停摘要 = MCP命令服务器.解析Debugger暂停摘要 (rawInspect)
                    变量 暂停解析 <类型 = YYJSON只读对象类>
                    如果 (暂停解析.创建自文本 (暂停摘要))
                    {
                        frameId2 = MCP命令服务器.yyjson取文本 (暂停解析, "call_frame_id")
                    }
                }
            }
            如果 (frameId2 == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "缺少 call_frame_id | 请先 browser_debugger_wait_paused 或 browser_debugger_last_paused"))
            }
            变量 exprRaw <类型 = 文本型>
            exprRaw = MCP命令服务器.取Debugger表达式Raw文本 (参数JSON)
            如果 (exprRaw == "")
            {
                exprRaw = "typeof location!=='undefined'?location.href:'(no location)'"
            }
            变量 expandInsp <类型 = 逻辑型>
            expandInsp = MCP命令服务器.取Debugger求值展开 (参数JSON)
            变量 rbvInsp <类型 = 逻辑型>
            rbvInsp = MCP命令服务器.取Debugger求值ReturnByValue (参数JSON)
            变量 evalOut <类型 = 文本型>
            evalOut = MCP命令服务器.Debugger帧内批量求值JSON (命令ID, frameId2, exprRaw, expandInsp, rbvInsp)
            变量 exprCount <类型 = 整数 值 = 0>
            变量 evalObj <类型 = YYJSON只读数组类>
            evalObj = MCP命令服务器.取JSON数组自文本 (evalOut, "items")
            如果 (evalObj.是否为空对象 () == 假)
            {
                exprCount = (整数)evalObj.取成员数 ()
            }
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, "{\"call_frame_id\":\"" + MCP命令服务器.JSON转义文本 (frameId2) + "\",\"count\":" + 到文本 (exprCount) + ",\"evaluations\":" + evalOut + "}"))
        }
        否则 (方法名 == "browser.debugger_flow" || 方法名 == "browser_debugger_flow")
        {
            变量 flowJSON <类型 = 文本型>
            flowJSON = MCP命令服务器.执行Debugger断点流程JSON (命令ID, 参数JSON)
            如果 (flowJSON == "" || MCP命令服务器.是否以 (flowJSON, "{\"ok\":false"))
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "debugger_flow 失败: " + flowJSON))
            }
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, flowJSON))
        }
        否则 (方法名 == "browser.debugger_script_source" || 方法名 == "browser_debugger_script_source")
        {
            变量 srcJSON <类型 = 文本型>
            srcJSON = MCP命令服务器.执行Debugger脚本源JSON (命令ID, 参数JSON)
            如果 (srcJSON == "" || MCP命令服务器.是否以 (srcJSON, "{\"ok\":false"))
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "debugger_script_source 失败: " + srcJSON))
