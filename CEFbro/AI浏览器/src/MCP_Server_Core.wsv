            变量 autoHits <类型 = 整数 值 = 0>
            变量 autoResults <类型 = 文本数组类>
            判断循环 (autoHits < autoMaxHits)
            {
                如果 (MCP命令服务器.MCP正在关闭 || MCP_编排分派.工作流应停止)
                {
                    跳出循环
                }
                MCP命令服务器.清除CDP事件记录 ("Debugger.paused")
                变量 autoPausedRaw <类型 = 文本型>
                autoPausedRaw = MCP命令服务器.等待CDP事件 ("Debugger.paused", autoMaxMs, 假)
                如果 (autoPausedRaw == "")
                {
                    跳出循环
                }
                autoHits = autoHits + 1
                变量 autoSummary <类型 = 文本型>
                autoSummary = MCP命令服务器.解析Debugger暂停摘要 (autoPausedRaw)
                变量 autoObj <类型 = YYJSON只读对象类>
                变量 autoFrameId <类型 = 文本型>
                autoFrameId = ""
                如果 (autoObj.创建自文本 (autoSummary))
                {
                    autoFrameId = MCP命令服务器.yyjson取文本 (autoObj, "call_frame_id")
                }
                如果 (autoFrameId == "")
                {
                    autoFrameId = MCP命令服务器.提取JSON文本字段值 (autoSummary, "call_frame_id")
                }
                变量 autoEvalOut <类型 = 文本型>
                autoEvalOut = "[]"
                如果 (autoFrameId != "")
                {
                    autoEvalOut = MCP命令服务器.Debugger帧内批量求值JSON (命令ID + "_ah" + 到文本 (autoHits), autoFrameId, autoExprRaw, 真, 真)
                }
                MCP命令服务器.DebuggerFlow尝试Resume (命令ID + "_ar" + 到文本 (autoHits))
                变量 autoHitResult <类型 = YYJSON对象类>
                autoHitResult.创建自文本 ("{}")
                autoHitResult.加入整数成员 ("hit", autoHits)
                autoHitResult.加入文本成员 ("frame_id", autoFrameId)
                autoHitResult.加入文本成员 ("evaluations", autoEvalOut)
                autoHitResult.加入文本成员 ("paused", autoSummary)
                autoResults.加入成员 (autoHitResult.到可读文本 (YYJSON格式化选项.压缩))
            }
            MCP命令服务器.确保Debugger已恢复 (命令ID + "_done")
            变量 auto汇总 <类型 = YYJSON对象类>
            auto汇总.创建自文本 ("{}")
            auto汇总.加入逻辑值成员 ("success", 真)
            auto汇总.加入整数成员 ("hits", autoHits)
            auto汇总.加入文本成员 ("breakpoint", autoBpUrl)
            auto汇总.加入文本成员 ("results", MCP_编排分派.步骤JSON片段列表到数组文本 (autoResults))
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, auto汇总.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 启用调试器(开始断点调试前必须调用) ===
        否则 (方法名 == "browser.debugger_enable" || 方法名 == "browser_debugger_enable")
        {
            返回 (MCP命令服务器.执行CDP命令 (命令ID, "Debugger.enable", 参数JSON))
        }
        // === Base64编码/解码 (FBrowser官方API) ===
        否则 (方法名 == "browser.base64_encode" || 方法名 == "browser_base64_encode")
        {
            变量 data <类型 = 文本型>
            data = MCP命令服务器.yyjson取文本 (参数JSON, "data")
            如果 (data == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "data " + MCP命令服务器.错误_缺少参数))
            }
            变量 result <类型 = 文本型>
            result = FBrowser_Parser_Base64编码 (data)
            返回 (MCP命令服务器.构建简单JSON ("base64", result))
        }
        否则 (方法名 == "browser.base64_decode" || 方法名 == "browser_base64_decode")
        {
            变量 data <类型 = 文本型>
            data = MCP命令服务器.yyjson取文本 (参数JSON, "data")
            如果 (data == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "data " + MCP命令服务器.错误_缺少参数))
            }
            变量 字节结果 <类型 = 类_FBrowser_字节集>
            字节结果 = FBrowser_Parser_Base64解码 (data)
            如果 (字节结果.是否为空 () == 假)
            {
                变量 解码后文本 <类型 = 文本型>
                解码后文本 = 字节结果.取文本 ()
                返回 (MCP命令服务器.构建简单JSON ("decoded", 解码后文本))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "Base64解码失败"))
        }
        // === URI编码/解码 (FBrowser官方API) ===
        否则 (方法名 == "browser.uri_encode" || 方法名 == "browser_uri_encode")
        {
            变量 data <类型 = 文本型>
            data = MCP命令服务器.yyjson取文本 (参数JSON, "data")
            如果 (data == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "data " + MCP命令服务器.错误_缺少参数))
            }
            变量 result <类型 = 文本型>
            result = FBrowser_Parser_URI编码 (data, 假)
            返回 (MCP命令服务器.构建简单JSON ("encoded", result))
        }
        否则 (方法名 == "browser.uri_decode" || 方法名 == "browser_uri_decode")
        {
            变量 data <类型 = 文本型>
            data = MCP命令服务器.yyjson取文本 (参数JSON, "data")
            如果 (data == "")
            {
