            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url != "")
            {
                如果 (MCP命令服务器.验证URL安全 (url) == 假)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "不支持的URL协议, 仅允许 http/https"))
                }
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.开始下载 (url)
                    返回 (MCP命令服务器.命令成功 (命令ID, "下载已触发: " + url))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 url 不能为空"))
        }
        // === 编辑操作 ===
        否则 (方法名 == "browser.edit_undo" || 方法名 == "browser_edit_undo")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 undoFrame <类型 = 类_FBrowser_框架>
                undoFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (undoFrame.是否为空 () == 假 && undoFrame.是否有效 ())
                {
                    undoFrame.撤销 ()
                    返回 (MCP命令服务器.命令成功 (命令ID, "撤销成功"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.edit_redo" || 方法名 == "browser_edit_redo")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 redoFrame <类型 = 类_FBrowser_框架>
                redoFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (redoFrame.是否为空 () == 假 && redoFrame.是否有效 ())
