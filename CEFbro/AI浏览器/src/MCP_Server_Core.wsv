                        变量 framesPerBuffer <类型 = 整数>
                        framesPerBuffer = MCP命令服务器.yyjson取整数 (参数JSON, "frames_per_buffer")
                        如果 (sampleRate == 0 && channels == 0 && framesPerBuffer == 0)
                        {
                            返回 (MCP命令服务器.命令失败 (命令ID, "audio_param 需要 sample_rate/channels/frames_per_buffer 至少一项"))
                        }
                        变量 配置JSON <类型 = 文本型>
                        配置JSON = "{"
                        变量 首字段 <类型 = 逻辑型 值 = 真>
                        如果 (sampleRate > 0)
                        {
                            配置JSON = 配置JSON + "\"sample_rate\":" + 到文本 (sampleRate)
                            首字段 = 假
                        }
                        如果 (channels > 0)
                        {
                            如果 (首字段 == 假)
                            {
                                配置JSON = 配置JSON + ","
                            }
                            配置JSON = 配置JSON + "\"channels\":" + 到文本 (channels)
                            首字段 = 假
                        }
                        如果 (framesPerBuffer > 0)
                        {
                            如果 (首字段 == 假)
                            {
                                配置JSON = 配置JSON + ","
                            }
                            配置JSON = 配置JSON + "\"frames_per_buffer\":" + 到文本 (framesPerBuffer)
                        }
                        配置JSON = 配置JSON + "}"
                        MCP命令服务器.音频指纹配置 = 配置JSON
                        MCP命令服务器.是否Hook音频 = 真
                        返回 (MCP命令服务器.响应_需要刷新 (命令ID, "音频参数Hook已启用(事件通道), 刷新后生效: " + 配置JSON))
                    }
                    否则 (action == "webrtc")
                    {
                        vip_ctrl.指纹_虚拟WebrtcIP (MCP命令服务器.yyjson取文本 (参数JSON, "public_ip"), MCP命令服务器.yyjson取文本 (参数JSON, "local_ip"), MCP命令服务器.yyjson取文本 (参数JSON, "host"), MCP命令服务器.yyjson取逻辑 (参数JSON, "disable"))
                        返回 (MCP命令服务器.响应_需要刷新 (命令ID, "WebRTC已设置"))
                    }
                    否则 (action == "geolocation")
                    {
                        变量 lat <类型 = 小数>
                        lat = MCP命令服务器.yyjson取小数 (参数JSON, "latitude")
                        变量 lng <类型 = 小数>
                        lng = MCP命令服务器.yyjson取小数 (参数JSON, "longitude")
                        vip_ctrl.指纹_虚拟定位 (lng, lat, 10, -10000, -1, -1, -1)
                        返回 (MCP命令服务器.响应_需要刷新 (命令ID, "定位已设置"))
                    }
                    否则 (action == "timezone")
                    {
                        vip_ctrl.指纹_虚拟Date时区 (MCP命令服务器.yyjson取整数 (参数JSON, "offset_h"), MCP命令服务器.yyjson取整数 (参数JSON, "offset_m"), MCP命令服务器.yyjson取文本 (参数JSON, "name"), MCP命令服务器.yyjson取文本 (参数JSON, "iana"))
                        返回 (MCP命令服务器.响应_需要刷新 (命令ID, "时区已设置"))
                    }
                    否则 (action == "ssl")
                    {
                        // 整数→TLS版本枚举映射 (规避火山 @常量类 模板限制)
                        变量 tls_min_int <类型 = 整数>
                        变量 tls_max_int <类型 = 整数>
                        tls_min_int = MCP命令服务器.yyjson取整数 (参数JSON, "tls_min")
                        tls_max_int = MCP命令服务器.yyjson取整数 (参数JSON, "tls_max")
                        变量 tls_min_enum <类型 = TLS版本>
                        变量 tls_max_enum <类型 = TLS版本>
                        如果 (tls_min_int == MCP命令服务器.TLS指纹_1_0)
                        {
                            tls_min_enum = TLS版本.Version_1
                        }
                        否则 (tls_min_int == MCP命令服务器.TLS指纹_1_1)
                        {
                            tls_min_enum = TLS版本.Version_1_1
                        }
                        否则 (tls_min_int == MCP命令服务器.TLS指纹_1_2)
                        {
                            tls_min_enum = TLS版本.Version_1_2
                        }
                        否则 (tls_min_int == MCP命令服务器.TLS指纹_1_3)
                        {
                            tls_min_enum = TLS版本.Version_1_3
                        }
                        否则
                        {
                            tls_min_enum = TLS版本.Version_1_2
                        }
                        如果 (tls_max_int == MCP命令服务器.TLS指纹_1_0)
                        {
                            tls_max_enum = TLS版本.Version_1
                        }
                        否则 (tls_max_int == MCP命令服务器.TLS指纹_1_1)
                        {
                            tls_max_enum = TLS版本.Version_1_1
                        }
                        否则 (tls_max_int == MCP命令服务器.TLS指纹_1_2)
                        {
                            tls_max_enum = TLS版本.Version_1_2
                        }
                        否则 (tls_max_int == MCP命令服务器.TLS指纹_1_3)
                        {
                            tls_max_enum = TLS版本.Version_1_3
                        }
                        否则
                        {
                            tls_max_enum = TLS版本.Version_1_3
                        }
                        vip_ctrl.指纹_设置SSL加密套件 (tls_min_enum, tls_max_enum, MCP命令服务器.yyjson取文本 (参数JSON, "ciphers"))
                        返回 (MCP命令服务器.响应_需要刷新 (命令ID, "SSL加密套件已设置"))
                    }
                    否则 (action == "set_batch")
                    {
                        变量 config_text <类型 = 文本型>
                        config_text = MCP命令服务器.yyjson取JSON文本 (参数JSON, "config")
                        变量 配置解析 <类型 = YYJSON只读对象类>
                        如果 (config_text != "" && 配置解析.创建自文本 (config_text))
                        {
                            变量 val <类型 = 文本型>
                            val = MCP命令服务器.yyjson取文本 (配置解析, "user_agent")
                            如果 (val != "")
                            {
                                变量 ua <类型 = 类_FBrowserVIP_UA数据>
                                ua.创建 ()
                                ua.置UserAgent (val)
                                vip_ctrl.指纹_虚拟UserAgent (ua)
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "vendor")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Vendor (val)
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "product")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Product (val)
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "languages")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Languages (val)
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "webgl_vendor")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Webglvendor (val)
                            }
                            val = MCP命令服务器.yyjson取文本 (配置解析, "webgl_renderer")
                            如果 (val != "")
                            {
                                vip_ctrl.指纹_虚拟Webglrenderer (val)
                            }
                            变量 intVal <类型 = 整数>
                            intVal = MCP命令服务器.yyjson取整数 (配置解析, "hardware_concurrency")
                            如果 (intVal > 0)
                            {
                                vip_ctrl.指纹_虚拟HardwareConcurrency (intVal)
                            }
                            intVal = MCP命令服务器.yyjson取整数 (配置解析, "device_memory")
                            如果 (intVal > 0)
                            {
                                vip_ctrl.指纹_虚拟DeviceMemory (intVal)
                            }
                            vip_ctrl.指纹_虚拟Webdriver (MCP命令服务器.yyjson取逻辑 (配置解析, "webdriver"))
                            变量 w <类型 = 整数>
                            w = MCP命令服务器.yyjson取整数 (配置解析, "width")
                            变量 h <类型 = 整数>
                            h = MCP命令服务器.yyjson取整数 (配置解析, "height")
                            如果 (w > 0 && h > 0)
                            {
                                vip_ctrl.指纹_虚拟屏幕分辨率 (h, w)
                            }
                            w = MCP命令服务器.yyjson取整数 (配置解析, "avail_width")
                            h = MCP命令服务器.yyjson取整数 (配置解析, "avail_height")
                            如果 (w > 0 && h > 0)
                            {
                                vip_ctrl.指纹_虚拟屏幕可用高度和宽度 (h, w)
                            }
                            返回 (MCP命令服务器.响应_需要刷新 (命令ID, "指纹批量设置完成"))
                        }
                        返回 (MCP命令服务器.命令失败 (命令ID, "config JSON无效"))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "未知action: " + action + " | 支持: clear/count/canvas_random/webgl_random/audio_random/audio_param/webrtc/geolocation/timezone/ssl/set_batch"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 拦截 (双通道: VIP API + 事件Hook toggle) ===
        否则 (方法名 == "browser.intercept" || 方法名 == "browser_intercept")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            // -- 无需浏览器实例的操作 --
            如果 (action == "clear")
            {
                // 清除所有浏览器的VIP过滤器 (遍历, 不依赖取主浏览器)
                MCP命令服务器.浏览器数组锁.加锁 ()
                变量 clearCount <类型 = 整数>
                clearCount = 浏览器容器.浏览器数组.取成员数 ()
                计次循环 (clearCount)
                {
                    变量 clearB <类型 = 类_FBrowser_浏览器>
                    clearB = 对象数组类.取指定类型成员 (浏览器容器.浏览器数组, 取循环索引 (), 类_FBrowser_浏览器)
                    如果 (clearB.是否为空 () == 假 && clearB.是否已关闭 () == 假)
                    {
                        变量 clearVip <类型 = 类_FBrowserVIP_控制器>
                        clearVip = clearB.取VIP控制器 ()
                        如果 (clearVip.是否为空 () == 假)
                        {
                            clearVip.过滤器_取消全部修改内容 ()
                            clearVip.过滤器_取消全部替换资源 ()
                        }
                    }
                }
                MCP命令服务器.浏览器数组锁.解锁 ()
                // 清除所有事件Hook规则和开关
                MCP命令服务器.是否缓存响应 = 假
                MCP命令服务器.是否Hook资源 = 假
                MCP命令服务器.是否Hook导航 = 假
                MCP命令服务器.是否Hook音频 = 假
                MCP命令服务器.是否Hook弹窗 = 假
                MCP命令服务器.资源替换规则 = ""
                MCP命令服务器.导航拦截规则 = ""
                MCP命令服务器.音频指纹配置 = ""
                MCP命令服务器.弹窗配置 = ""
                返回 (MCP命令服务器.命令成功 (命令ID, "所有拦截规则已清除(VIP+事件Hook双通道)"))
            }
            否则 (action == "ws_hook")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                    vip_ctrl = browser.取VIP控制器 ()
                    如果 (vip_ctrl.是否为空 () == 假)
                    {
                        vip_ctrl.WebSocket_启用拦截 ()
                        返回 (MCP命令服务器.命令成功 (命令ID, "WebSocket拦截已启用"))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_VIP不可用))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            否则 (action == "cache")
            {
                MCP命令服务器.是否缓存响应 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "响应缓存已启用 (SQLite → response_cache表)"))
            }
            否则 (action == "uncache")
            {
                MCP命令服务器.是否缓存响应 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "响应缓存已禁用"))
            }
            否则 (action == "popup_config")
            {
                // 事件Hook通道: 自定义弹窗属性 (无需VIP, 无需浏览器实例)
                MCP命令服务器.是否Hook弹窗 = 真
                变量 弹窗宽度 <类型 = 文本型>
                弹窗宽度 = MCP命令服务器.yyjson取文本 (参数JSON, "width")
                变量 弹窗高度 <类型 = 文本型>
                弹窗高度 = MCP命令服务器.yyjson取文本 (参数JSON, "height")
                变量 弹窗X <类型 = 文本型>
                弹窗X = MCP命令服务器.yyjson取文本 (参数JSON, "x")
                变量 弹窗Y <类型 = 文本型>
                弹窗Y = MCP命令服务器.yyjson取文本 (参数JSON, "y")
                MCP命令服务器.弹窗配置 = "{\"width\":" + 弹窗宽度 + ",\"height\":" + 弹窗高度 + ",\"x\":" + 弹窗X + ",\"y\":" + 弹窗Y + "}"
                返回 (MCP命令服务器.命令成功 (命令ID, "弹窗配置已设置: " + 弹窗宽度 + "x" + 弹窗高度))
            }
            否则 (action == "popup_disable")
            {
                MCP命令服务器.是否Hook弹窗 = 假
                MCP命令服务器.弹窗配置 = ""
                返回 (MCP命令服务器.命令成功 (命令ID, "弹窗配置已禁用"))
            }
            // -- 需要浏览器实例的双通道操作 --
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                变量 url <类型 = 文本型>
                url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
                如果 (url == "")
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "参数 url 不能为空"))
                }
                变量 匹配模式 <类型 = 整数>
                匹配模式 = MCP命令服务器.解析匹配模式 (MCP命令服务器.yyjson取文本 (参数JSON, "match_mode"))
                // -- 导航拦截 (事件Hook通道, 无需VIP) --
                如果 (action == "navigate_block" || action == "navigate_redirect")
                {
                    变量 原始action <类型 = 文本型>
                    原始action = action  // 保存原始值, 子文本替换会原地修改action
                    变量 规则动作 <类型 = 文本型>
                    规则动作 = action
                    子文本替换 (规则动作, "navigate_", "", , , 假)
                    变量 新行 <类型 = 文本型>
                    新行 = 规则动作 + "|" + url
                    如果 (原始action == "navigate_redirect")
                    {
                        变量 重定向目标 <类型 = 文本型>
                        重定向目标 = MCP命令服务器.yyjson取文本 (参数JSON, "target")
                        新行 = 新行 + "|" + 重定向目标
                    }
                    MCP命令服务器.追加导航拦截规则 (新行)
                    MCP命令服务器.是否Hook导航 = 真
                    返回 (MCP命令服务器.命令成功 (命令ID, "导航拦截规则已添加(VIP可选): " + url))
                }
                // -- 资源拦截 (事件Hook通道 + VIP双保险) --
                // 先尝试VIP API (如果可用), 然后无条件存储事件Hook规则作fallback
                如果 (action == "modify")
                {
                    变量 search_text <类型 = 文本型>
                    search_text = MCP命令服务器.yyjson取文本 (参数JSON, "search_text")
                    变量 replace_text <类型 = 文本型>
                    replace_text = MCP命令服务器.yyjson取文本 (参数JSON, "replace_text")
                    如果 (search_text != "" && replace_text != "")
                    {
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            vip_ctrl.过滤器_修改内容 (匹配模式, url, VIP过滤器.修改全部匹配数据, search_text, replace_text)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, search_text, replace_text, "", "")
                        返回 (MCP命令服务器.命令成功 (命令ID, "内容修改已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "modify需要search_text和replace_text"))
                }
                否则 (action == "replace_data")
                {
                    变量 replace_data_text <类型 = 文本型>
                    replace_data_text = MCP命令服务器.yyjson取文本 (参数JSON, "replace_text")
                    如果 (replace_data_text != "")
                    {
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            变量 替换字节集 <类型 = 字节集类>
                            替换字节集 = 文本到UTF8 (replace_data_text, 假)
                            vip_ctrl.过滤器_替换资源_数据 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , 替换字节集)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, "", replace_data_text, "", "")
                        返回 (MCP命令服务器.命令成功 (命令ID, "资源替换已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "replace_data需要replace_text"))
                }
                否则 (action == "replace_file")
                {
                    变量 file_path <类型 = 文本型>
                    file_path = MCP命令服务器.yyjson取文本 (参数JSON, "file_path")
                    如果 (file_path != "")
                    {
                        如果 (vip_ctrl.是否为空 () == 假)
                        {
                            vip_ctrl.过滤器_替换资源_文件 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , file_path)
                        }
                        MCP命令服务器.是否Hook资源 = 真
                        MCP命令服务器.添加资源替换规则 (action, url, "", "", file_path, "")
                        返回 (MCP命令服务器.命令成功 (命令ID, "本地文件替换已设置" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + file_path))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "replace_file需要file_path"))
                }
                否则 (action == "block")
                {
                    如果 (vip_ctrl.是否为空 () == 假)
                    {
                        变量 空字节集 <类型 = 字节集类>
                        vip_ctrl.过滤器_替换资源_数据 (匹配模式, url, MCP命令服务器.yyjson取文本 (参数JSON, "mime_type"), , 空字节集)
                    }
                    MCP命令服务器.是否Hook资源 = 真
                    MCP命令服务器.添加资源替换规则 (action, url, "", "", "", "")
                    返回 (MCP命令服务器.命令成功 (命令ID, "资源已屏蔽" + 选择 (vip_ctrl.是否为空 () == 假, "(VIP+事件Hook)", "(事件Hook)") + ": " + url))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "未知action: " + action + " | 支持: modify/replace_data/replace_file/block/navigate_block/navigate_redirect/popup_config/popup_disable/cache/uncache/clear/ws_hook"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 截图 ===
        否则 (方法名 == "browser.screenshot" || 方法名 == "browser_screenshot")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 vip_ctrl <类型 = 类_FBrowserVIP_控制器>
                vip_ctrl = browser.取VIP控制器 ()
                如果 (vip_ctrl.是否为空 () == 假)
                {
                    变量 fmt <类型 = 文本型>
                    fmt = MCP命令服务器.yyjson取文本 (参数JSON, "format")
                    如果 (fmt == "")
                    {
                        fmt = "png"
                    }
                    变量 截图大小 <类型 = FBrowser_截图边框数据>
                    截图大小.横坐标 = 0
                    截图大小.纵坐标 = 0
                    截图大小.宽度 = 1920
                    截图大小.高度 = 1080
                    截图大小.缩放 = 1
                    // 全部异步: 生成task_id, 回调触发时存储结果
                    变量 异步截图ID <类型 = 文本型>
                    异步截图ID = MCP命令服务器.生成异步任务ID ()
                    变量 截图回调 <类型 = 类_FBrowser_事件智能指针>
                    截图回调.创建 (类_MCP_截图异步回调)
                    截图回调.取执行类 (类_MCP_截图异步回调).任务ID = 异步截图ID
                    截图回调.取执行类 (类_MCP_截图异步回调).图片格式 = fmt
                    vip_ctrl.高级_网页截图 (fmt, 80, 截图大小, 假, 假, 截图回调)
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步截图ID, "截图已提交, 通过mcp_result查询", 800))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_VIP不可用))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 等待(AI自动化) ===
        否则 (方法名 == "browser.wait" || 方法名 == "browser_wait")
        {
            变量 what <类型 = 文本型>
            what = MCP命令服务器.yyjson取文本 (参数JSON, "what")
            变量 value <类型 = 文本型>
            value = MCP命令服务器.yyjson取文本 (参数JSON, "value")
            变量 maxMs <类型 = 整数>
            maxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (maxMs == 0)
            {
                maxMs = 10000
            }
            如果 (maxMs > MCP命令服务器.URL请求默认超时)
            {
                maxMs = MCP命令服务器.URL请求默认超时  // 最多等30秒,防止阻塞过久
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                如果 (what == "timeout")
                {
                    变量 异步超时ID <类型 = 文本型>
                    异步超时ID = MCP命令服务器.生成异步任务ID ()
                    // 将等待规格存储为异步任务, 客户端通过mcp_result轮询
                    变量 超时存储 <类型 = YYJSON对象类>
                    超时存储.创建自文本 ("{}")
                    超时存储.加入逻辑值成员 ("_waiting", 真)
                    超时存储.加入文本成员 ("what", "timeout")
                    超时存储.加入整数成员 ("max_ms", maxMs)
                    超时存储.加入长整数成员 ("start_time", 取启动时间 ())
                    超时存储.加入整数成员 ("_poll_count", 0)
                    MCP命令服务器.存储异步结果 (异步超时ID, 超时存储.到可读文本 (YYJSON格式化选项.压缩))
                    返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步超时ID, "等待已提交, 通过mcp_result轮询结果"))
                }
                如果 (what != "selector" && what != "text" && what != "load_end" && what != "load_start" && what != "navigate")
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "未知what: " + what + " | 支持: selector/text/timeout/load_end/load_start/navigate"))
                }
                // load_end/load_start 不需要 value; navigate 无 value 时等同 load_end
                如果 (what != "load_end" && what != "load_start" && what != "navigate" && value == "")
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "value 不能为空: what=" + what + " 需要指定等待目标值"))
                }
                如果 (what == "navigate" && value == "")
                {
                    what = "load_end"
                }
                // === 异步轮询模式: 生成task_id, 每次mcp_result做一次检查, 避免阻塞MCP线程 ===
                变量 异步等待ID <类型 = 文本型>
                异步等待ID = MCP命令服务器.生成异步任务ID ()
                变量 checkCode <类型 = 文本型>
                如果 (what == "selector")
                {
                    checkCode = "(function(){var el=document.querySelector('" + MCP命令服务器.简单转义JS (value) + "');return JSON.stringify({found:!!el,text:el?el.innerText.substring(0,500):null,tag:el?el.tagName:null})})()"
                }
                否则 (what == "text")
                {
                    checkCode = "(function(){if(!document.body)return JSON.stringify({found:false,error:'document.body not ready'});var idx=document.body.innerText.indexOf('" + MCP命令服务器.简单转义JS (value) + "');return JSON.stringify({found:idx>=0,position:idx})})()"
                }
                否则 (what == "load_end")
                {
                    checkCode = "(function(){return JSON.stringify({found:document.readyState==='complete',readyState:document.readyState})})()"
                }
                否则 (what == "load_start")
                {
                    checkCode = "(function(){return JSON.stringify({found:document.readyState==='loading',readyState:document.readyState})})()"
                }
                否则 (what == "navigate")
                {
                    checkCode = "(function(){var t='" + MCP命令服务器.简单转义JS (value) + "';var h=window.location.href;var f=(h===t||(t.length>0&&h.indexOf(t)===0));return JSON.stringify({found:f,url:h,target:t})})()"
                }
                // 存储等待上下文, 客户端通过mcp_result轮询 — 每次轮询触发一次JS条件检查
                变量 等待存储 <类型 = YYJSON对象类>
                等待存储.创建自文本 ("{}")
                等待存储.加入逻辑值成员 ("_waiting", 真)
                等待存储.加入文本成员 ("what", what)
                等待存储.加入文本成员 ("value", value)
                等待存储.加入文本成员 ("check_code", checkCode)
                等待存储.加入整数成员 ("max_ms", maxMs)
                等待存储.加入长整数成员 ("start_time", 取启动时间 ())
                等待存储.加入整数成员 ("_poll_count", 0)
                如果 (what == "load_start")
                {
                    等待存储.加入整数成员 ("_load_phase", 0)
                }
                MCP命令服务器.存储异步结果 (异步等待ID, 等待存储.到可读文本 (YYJSON格式化选项.压缩))
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步等待ID, "等待已提交(what=" + what + " value=" + value + "), 请用mcp_result轮询, 每次轮询做一次条件检查"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 注入(AI自动化) ===
        否则 (方法名 == "browser.inject" || 方法名 == "browser_inject")
        {
            变量 injectType <类型 = 文本型>
            injectType = MCP命令服务器.yyjson取文本 (参数JSON, "type")
            变量 code <类型 = 文本型>
            code = MCP命令服务器.yyjson取文本 (参数JSON, "code")
            变量 persist <类型 = 逻辑型>
            persist = MCP命令服务器.yyjson取逻辑 (参数JSON, "persist")
            如果 (injectType != "" && code != "")
            {
                如果 (persist && injectType == "js")
                {
                    // 持久js模式: 存入持久V8扩展列表, 由 渲染_即将创建V8环境 → V8环境.执行JS代码 自动注入
                    变量 注入标识 <类型 = 文本型>
                    注入标识 = MCP命令服务器.yyjson取文本 (参数JSON, "inject_id")
                    如果 (注入标识 == "")
                    {
                        注入标识 = "mcp_inject_js_" + 到文本 (取启动时间 ())
                    }
                    // 转义code中的|防止分隔符冲突, 解析侧(MCP_BrowserEvents)会反向还原
                    变量 安全code_js <类型 = 文本型>
                    安全code_js = code
                    子文本替换 (安全code_js, "{PIPE}", "{PIPE_ESC}", , , 假)
                    子文本替换 (安全code_js, "|", "{PIPE}", , , 假)
                    MCP命令服务器.加入持久V8扩展 (注入标识, 安全code_js, "js")
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "V8 JS持久注入已排队 | 将在新页面/新iframe加载时自动生效"))
                }
                如果 (persist && injectType == "handler")
                {
                    // 持久handler模式: 存入持久V8扩展列表, 由 渲染_即将初始化WebKit → FBrowser_V8_注册JS扩展 自动注入
                    变量 注入标识 <类型 = 文本型>
                    注入标识 = MCP命令服务器.yyjson取文本 (参数JSON, "inject_id")
                    如果 (注入标识 == "")
                    {
                        注入标识 = "mcp_inject_handler_" + 到文本 (取启动时间 ())
                    }
                    // 转义code中的|防止分隔符冲突, 解析侧(MCP_BrowserEvents)会反向还原
                    变量 安全code_handler <类型 = 文本型>
                    安全code_handler = code
                    子文本替换 (安全code_handler, "{PIPE}", "{PIPE_ESC}", , , 假)
                    子文本替换 (安全code_handler, "|", "{PIPE}", , , 假)
                    MCP命令服务器.加入持久V8扩展 (注入标识, 安全code_handler, "handler")
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "V8 Handler持久注入已排队 | 将在新页面时自动注册 | 需要刷新/browser_reload"))
                }
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 injectCode <类型 = 文本型>
                    如果 (injectType == "js")
                    {
                        injectCode = "try{var s=document.createElement('script');s.textContent='" + MCP命令服务器.简单转义JS (code) + "';document.head.appendChild(s);'injected'}catch(e){'Error: '+e.message}"
                    }
                    否则 (injectType == "css")
                    {
                        injectCode = "try{var s=document.createElement('style');s.textContent='" + MCP命令服务器.简单转义JS (code) + "';document.head.appendChild(s);'injected'}catch(e){'Error: '+e.message}"
                    }
                    否则
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "未知type: " + injectType + ",支持: js/css"))
                    }
                    变量 injectFrame <类型 = 类_FBrowser_框架>
                    injectFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (injectFrame.是否为空 () == 假 && injectFrame.是否有效 ())
                    {
                        injectFrame.执行JS代码 (injectCode)
                        返回 (MCP命令服务器.命令成功 (命令ID, injectType + "已注入"))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 type/code 不能为空"))
        }
        // === 网络日志 ===
        否则 (方法名 == "browser.network" || 方法名 == "browser_network")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (action == "")
            {
                action = "list"
            }
            如果 (action == "enable" || action == "network_enable")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "网络日志已启用(基础模式)"))
            }
            如果 (action == "detail_enable" || action == "network_detail_enable")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "网络日志已启用(详细模式)"))
            }
            如果 (action == "disable" || action == "network_disable")
            {
                MCP命令服务器.是否记录网络 = 假
                MCP命令服务器.是否详细记录网络 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "网络日志已禁用"))
            }
            如果 (action == "clear" || action == "network_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='network' OR log_type='network_detail'")
                返回 (MCP命令服务器.命令成功 (命令ID, "已清空"))
            }
            如果 (action == "list" || action == "get" || action == "network_get")
            {
                如果 (MCP命令服务器.是否记录网络 == 假 && MCP命令服务器.yyjson取逻辑 (参数JSON, "auto_enable") != 假)
                {
                    MCP命令服务器.是否记录网络 = 真
                }
                变量 限制 <类型 = 整数>
                限制 = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
                如果 (限制 <= 0)
                {
                    限制 = 500
                }
                变量 日志数组 <类型 = 文本型>
                日志数组 = MCP命令服务器.查询网络日志 (限制)
                变量 头对象 <类型 = YYJSON对象类>
                头对象.创建自文本 ("{}")
                头对象.加入逻辑值成员 ("network_enabled", MCP命令服务器.是否记录网络)
                头对象.加入逻辑值成员 ("network_detail", MCP命令服务器.是否详细记录网络)
                如果 (日志数组 == "[]" || 日志数组 == "")
                {
                    如果 (MCP命令服务器.是否记录网络 == 假)
                    {
                        头对象.加入文本成员 ("hint", "网络日志未启用; 请 action=enable 或 config enable_network_log=true, navigate 后再 list")
                    }
                    否则
                    {
                        头对象.加入文本成员 ("hint", "尚无记录; 仅记录 enable 之后的新请求, 磁盘缓存命中可能无 req/res")
                    }
                }
                变量 头JSON <类型 = 文本型>
                头JSON = 头对象.到可读文本 (YYJSON格式化选项.压缩)
                变量 内层JSON <类型 = 文本型>
                内层JSON = 取文本左边 (头JSON, 取文本长度 (头JSON) - 1) + ",\"network_logs\":" + 日志数组 + "}"
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 内层JSON))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "未知action: " + action + " | 支持: list/get/enable/disable/clear/detail_enable (别名 network_*)"))
        }
        // === 收集 ===
        否则 (方法名 == "browser.collect" || 方法名 == "browser_collect")
        {
            变量 action <类型 = 文本型>
            action = MCP命令服务器.yyjson取文本 (参数JSON, "action")
            如果 (action == "network_enable" || action == "network_detail_enable" || action == "network_disable" || action == "network_get" || action == "network_clear" || action == "list" || action == "get" || action == "enable" || action == "disable" || action == "clear" || action == "detail_enable")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_network", 参数JSON))
            }
            否则 (action == "cache_enable")
            {
                MCP命令服务器.是否缓存响应 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "响应缓存已启用 (SQLite)"))
            }
            否则 (action == "cache_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM response_cache")
                MCP命令服务器.是否缓存响应 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "响应缓存已清空 (SQLite)"))
            }
            否则 (action == "console_enable")
            {
                MCP命令服务器.是否记录控制台 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "控制台日志已启用"))
            }
            // === 场景预备: 逆向分析 ===
            否则 (action == "reverse_prepare")
            {
                如果 (MCP命令服务器.yyjson取逻辑 (参数JSON, "clear") != 假)
                {
                    MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='network' OR log_type='network_detail'")
                }
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                MCP命令服务器.是否记录控制台 = 真
                变量 指南 <类型 = YYJSON对象类>
                指南.创建自文本 ("{}")
                指南.加入文本成员 ("scenario", "reverse_analyze")
                指南.加入文本成员 ("tip", "navigate 后 browser_network list + browser_evaluate 扫描 script")
                指南.加入文本成员 ("script", "node mcp_bridge.js --call browser_collect '{\"action\":\"reverse_prepare\"}'")
                指南.加入文本成员 ("workflow", "workflow_run name=reverse_analyze")
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 指南.到可读文本 (YYJSON格式化选项.压缩)))
            }
            // === 场景预备: 断点调试 ===
            否则 (action == "debug_prepare")
            {
                MCP命令服务器.是否记录网络 = 真
                MCP命令服务器.是否详细记录网络 = 真
                变量 指南1 <类型 = YYJSON对象类>
                指南1.创建自文本 ("{}")
                指南1.加入文本成员 ("scenario", "debugger")
                指南1.加入文本成员 ("tip", "VIP: debugger_flow 一键 | 或 enable→breakpoint→navigate→wait_paused→inspect→resume")
                指南1.加入文本成员 ("script", "browser_debugger_flow 或 mcp_bridge.js --call browser_debugger_flow")
                指南1.加入文本成员 ("workflow", "workflow_run name=debugger_full")
                指南1.加入文本成员 ("next_tools", "browser_debugger_flow {url,breakpoint,expressions} | wait_paused → inspect / script_source → resume")
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 指南1.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (action == "debug_wait_paused")
            {
                变量 wMs <类型 = 整数>
                wMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
                如果 (wMs == 0)
                {
                    wMs = 30000
                }
                变量 rawW <类型 = 文本型>
                rawW = MCP命令服务器.等待CDP事件 ("Debugger.paused", wMs)
                如果 (rawW == "")
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "等待 Debugger.paused 超时"))
                }
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, MCP命令服务器.解析Debugger暂停摘要 (rawW)))
            }
            否则 (action == "debug_inspect")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_inspect", 参数JSON))
            }
            否则 (action == "debug_resume")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_resume", 参数JSON))
            }
            否则 (action == "debug_flow")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_flow", 参数JSON))
            }
            否则 (action == "debug_script_source")
            {
                返回 (分类分派_核心操作 (命令ID, "browser_debugger_script_source", 参数JSON))
            }
            // === 场景预备: 自动化 ===
            否则 (action == "automation_prepare")
            {
                变量 指南2 <类型 = YYJSON对象类>
                指南2.创建自文本 ("{}")
                指南2.加入文本成员 ("scenario", "automation")
                指南2.加入文本成员 ("tip", "fill_* / dom_* / wait / batch / screenshot 组合使用")
                指南2.加入文本成员 ("script", "workflow_run name=automation_form 或 mcp_bridge.js --call")
                指南2.加入文本成员 ("workflow", "workflow_run name=automation_form")
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 指南2.到可读文本 (YYJSON格式化选项.压缩)))
            }
            否则 (action == "console_get")
            {
                返回 (MCP命令服务器.构建简单JSON ("console_logs", MCP命令服务器.查询事件日志 ("console", "", 0, 500)))
            }
            否则 (action == "console_clear")
            {
                MCP命令服务器.执行SQL ("DELETE FROM event_log WHERE log_type='console'")
                返回 (MCP命令服务器.命令成功 (命令ID, "已清空"))
            }
            // === v2.2 浏览器事件监控 ===
            否则 (action == "event_load_enable")
            {
                MCP命令服务器.是否监控载入事件 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "载入事件监控已启用 (load_start/load_end/load_error/navigate/popup/loading_state_change)"))
            }
            否则 (action == "event_title_enable")
            {
                MCP命令服务器.是否监控标题改变 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "标题改变监控已启用"))
            }
            否则 (action == "event_progress_enable")
            {
                MCP命令服务器.是否监控加载进度 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "加载进度监控已启用 (0/25/50/75/100里程碑)"))
            }
            否则 (action == "event_resource_enable")
            {
                MCP命令服务器.是否监控资源事件 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "资源事件监控已启用 (主框架request/response/redirect)"))
            }
            否则 (action == "event_dialog_enable")
            {
                MCP命令服务器.是否监控对话框 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "JS对话框监控已启用 (alert/confirm/prompt/before_unload/file_dialog)"))
            }
            否则 (action == "event_fullscreen_enable")
            {
                MCP命令服务器.是否监控全屏 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "全屏事件监控已启用"))
            }
            否则 (action == "event_lifecycle_enable")
            {
                MCP命令服务器.是否监控生命周期 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "生命周期事件监控已启用 (browser_created/closing/url_changed/do_close)"))
            }
            否则 (action == "event_favicon_enable")
            {
                MCP命令服务器.是否监控图标 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "网页图标事件监控已启用"))
            }
            否则 (action == "event_find_enable")
            {
                MCP命令服务器.是否监控查找 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "页内查找事件监控已启用"))
            }
            否则 (action == "event_frame_enable")
            {
                MCP命令服务器.是否监控框架 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "框架生命周期事件监控已启用"))
            }
            否则 (action == "event_download_enable")
            {
                MCP命令服务器.是否监控下载事件 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "下载事件监控已启用 (download_request/start/progress)"))
            }
            否则 (action == "event_focus_enable")
            {
                MCP命令服务器.是否监控键盘焦点 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "键盘/焦点事件监控已启用"))
            }
            否则 (action == "event_all_enable")
            {
                MCP命令服务器.是否监控载入事件 = 真
                MCP命令服务器.是否监控标题改变 = 真
                MCP命令服务器.是否监控加载进度 = 真
                MCP命令服务器.是否监控对话框 = 真
                MCP命令服务器.是否监控全屏 = 真
                MCP命令服务器.是否监控图标 = 真
                MCP命令服务器.是否监控查找 = 真
                MCP命令服务器.是否监控框架 = 真
                MCP命令服务器.是否监控下载事件 = 真
                MCP命令服务器.是否监控生命周期 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "浏览器事件监控已启用(已排除 resource/keyboard 高频噪音) | event_log 上限 50000 条"))
            }
            否则 (action == "event_app_enable")
            {
                MCP命令服务器.是否监控应用事件 = 真
                返回 (MCP命令服务器.命令成功 (命令ID, "应用事件监控已启用 (v8/异常/焦点/渲染载入/IPC)"))
            }
            否则 (action == "event_all_disable")
            {
                MCP命令服务器.是否监控载入事件 = 假
                MCP命令服务器.是否监控标题改变 = 假
                MCP命令服务器.是否监控加载进度 = 假
                MCP命令服务器.是否监控资源事件 = 假
                MCP命令服务器.是否监控对话框 = 假
                MCP命令服务器.是否监控全屏 = 假
                MCP命令服务器.是否监控图标 = 假
                MCP命令服务器.是否监控查找 = 假
                MCP命令服务器.是否监控框架 = 假
                MCP命令服务器.是否监控下载事件 = 假
                MCP命令服务器.是否监控键盘焦点 = 假
                MCP命令服务器.是否监控生命周期 = 假
                MCP命令服务器.是否监控应用事件 = 假
                返回 (MCP命令服务器.命令成功 (命令ID, "全部浏览器事件监控已禁用"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "未知action: " + action + " | 支持: network_enable/detail_enable/disable/get/clear, cache_set_dir/clear, console_enable/get/clear, event_*_enable/all_enable/all_disable"))
        }
        // === 浏览器完整状态 ===
        如果 (方法名 == "browser.status" || 方法名 == "browser_status")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 状态对象 <类型 = YYJSON对象类>
                状态对象.创建自文本 ("{}")
                状态对象.加入逻辑值成员 ("is_popup", browser.是否为弹窗 ())
                状态对象.加入逻辑值成员 ("has_document", browser.是否有文档 ())
                状态对象.加入逻辑值成员 ("can_go_back", browser.可否后退 ())
                状态对象.加入逻辑值成员 ("can_go_forward", browser.可否前进 ())
                状态对象.加入逻辑值成员 ("is_loading", browser.是否读取中 ())
                状态对象.加入逻辑值成员 ("is_muted", browser.是否页面静音 ())
                状态对象.加入整数成员 ("browser_id", browser.取ID ())
                状态对象.加入整数成员 ("zoom_level_pct", 取整 (四舍五入 (browser.取缩放级别 () * 100, 0)))
                变量 statusUrlFrame <类型 = 类_FBrowser_框架>
                statusUrlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (statusUrlFrame.是否为空 () == 假)
                {
                    状态对象.加入文本成员 ("url", statusUrlFrame.取地址 ())
                }
                否则
                {
                    状态对象.加入文本成员 ("url", "")
                }
                状态对象.加入文本成员 ("window_title", browser.取窗口标题 ())
                状态对象.加入文本成员 ("user_flag", browser.取用户标识 ())
                变量 hwnd <类型 = 变整数>
                hwnd = browser.取窗口句柄 ()
                状态对象.加入文本成员 ("hwnd", 到文本 (hwnd))
                状态对象.加入逻辑值成员 ("is_closed", browser.是否已关闭 ())
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 状态对象.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 尝试关闭 (已禁用) ===
        否则 (方法名 == "browser.close_try" || 方法名 == "browser_close_try")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "⛔ 远程关闭浏览器已禁用 | 浏览器生命周期由GUI管理"))
        }
        // === 源码视图 ===
        否则 (方法名 == "browser.view_source" || 方法名 == "browser_view_source")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 viewSrcFrame <类型 = 类_FBrowser_框架>
                viewSrcFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (viewSrcFrame.是否为空 () == 假 && viewSrcFrame.是否有效 ())
                {
                    viewSrcFrame.源码视图 ()
                    返回 (MCP命令服务器.命令成功 (命令ID, "源码视图已打开"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 焦点框架 ===
        否则 (方法名 == "browser.get_focused_frame" || 方法名 == "browser_get_focused_frame")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 focusFrame <类型 = 类_FBrowser_框架>
                focusFrame = browser.取当前焦点框架 ()
                如果 (focusFrame.是否为空 () == 假)
                {
                    变量 框架信息 <类型 = YYJSON对象类>
                    框架信息.创建自文本 ("{}")
                    框架信息.加入文本成员 ("url", focusFrame.取地址 ())
                    框架信息.加入文本成员 ("name", focusFrame.取框架名 ())
                    框架信息.加入文本成员 ("frame_id", focusFrame.取框架ID ())
                    框架信息.加入逻辑值成员 ("is_main", focusFrame.是否为主框架 ())
                    框架信息.加入逻辑值成员 ("is_focused", 真)
                    框架信息.加入逻辑值成员 ("is_valid", focusFrame.是否有效 ())
                    返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 框架信息.到可读文本 (YYJSON格式化选项.压缩)))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "没有焦点框架"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 下载图片 ===
        否则 (方法名 == "browser.download_image" || 方法名 == "browser_download_image")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "参数 url 不能为空"))
            }
            如果 (MCP命令服务器.是否以 (url, "http://") == 假 && MCP命令服务器.是否以 (url, "https://") == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "仅支持http/https URL"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 异步下载ID <类型 = 文本型>
                异步下载ID = MCP命令服务器.生成异步任务ID ()
                变量 下载回调 <类型 = 类_FBrowser_事件智能指针>
                下载回调.创建 (类_MCP_下载图片回调)
                下载回调.取执行类 (类_MCP_下载图片回调).任务ID = 异步下载ID
                browser.下载图片 (url, 假, 0, 假, 下载回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步下载ID, "图片下载已提交, 通过mcp_result查询"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 元数据 ===
        否则 (方法名 == "browser.meta" || 方法名 == "browser_meta")
        {
            变量 元数据对象 <类型 = YYJSON对象类>
            元数据对象.创建自文本 ("{}")
            元数据对象.加入文本成员 ("machine_code", FBrowserVIP注册.VIP注册_取机器码 ())
            元数据对象.加入文本成员 ("start_date", FBrowserVIP注册.VIP注册_取开始时间 ())
            元数据对象.加入文本成员 ("end_date", FBrowserVIP注册.VIP注册_取到期时间 ())
            元数据对象.加入文本成员 ("features", FBrowserVIP注册.VIP注册_取注册功能 ())
            元数据对象.加入文本成员 ("license_version", FBrowserVIP注册.VIP注册_取注册版本 ())
            元数据对象.加入文本成员 ("license_type", FBrowserVIP注册.VIP注册_取注册码类型 ())
            元数据对象.加入整数成员 ("browser_count", FBrowser_浏览器_取数量 ())
            元数据对象.加入文本成员 ("fbro_version", FBrowser_取版本号 ())
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 元数据对象.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 任务结果查询 ===
        否则 (方法名 == "mcp.result" || 方法名 == "mcp_result")
        {
            变量 request_id <类型 = 文本型>
            request_id = MCP命令服务器.yyjson取文本 (参数JSON, "request_id")
            变量 consume <类型 = 逻辑型>
            consume = MCP命令服务器.yyjson取逻辑 (参数JSON, "consume")
            变量 实际任务ID <类型 = 文本型>
            实际任务ID = request_id
            如果 (request_id != "")
            {
                变量 存储结果 <类型 = 文本型>
                存储结果 = MCP命令服务器.查询任务结果 (request_id)
                如果 (存储结果 == "")
                {
                    // 兼容: 客户端传入 task_id 而非 JSON-RPC request id
                    存储结果 = MCP命令服务器.查询异步结果 (request_id)
                }
                如果 (存储结果 != "")
                {
                    变量 结果解析 <类型 = YYJSON只读对象类>
                    如果 (结果解析.创建自文本 (存储结果))
                    {
                        // 异步 stub 含 task_id 时, 自动跟随到真实结果
                        如果 (结果解析.取逻辑值 ("_async") && 结果解析.取逻辑值 ("_waiting") == 假)
                        {
                            变量 linkedTaskID <类型 = 文本型>
                            linkedTaskID = MCP命令服务器.yyjson取文本 (结果解析, "task_id")
                            如果 (linkedTaskID != "" && linkedTaskID != request_id)
                            {
                                变量 真实结果 <类型 = 文本型>
                                真实结果 = MCP命令服务器.查询异步结果 (linkedTaskID)
                                如果 (真实结果 != "")
                                {
                                    存储结果 = 真实结果
                                    实际任务ID = linkedTaskID
                                    结果解析.创建自文本 (存储结果)
                                }
                            }
                        }
                        // ================================================================
                        //  等待轮询状态机 (browser_wait 的客户端侧推进引擎)
                        //
                        //  每次 mcp_result 调用推进一个状态:
                        //  ┌─ 已超时(max_ms) ──→ what=timeout → 成功完成
                        //  │                  ──→ what=selector/text/navigate → 失败(超时)
                        //  │
                        //  └─ 未超时:
                        //       ├─ what=timeout → 返回 "等待中..."
                        //       └─ what=selector/text:
                        //            ├─ 阶段1 (无 _check_task_id) → 提交JS检查
                        //            └─ 阶段2 (有 _check_task_id) → 查询JS结果
                        //                 ├─ found=true  → 成功
                        //                 └─ found=false → 重置，下一轮重试
                        // ================================================================
                        如果 (结果解析.取逻辑值 ("_waiting"))
                        {
                            变量 waitWhat <类型 = 文本型>
                            waitWhat = MCP命令服务器.yyjson取文本 (结果解析, "what")
                            变量 waitStartTime <类型 = 长整数>
                            waitStartTime = MCP命令服务器.yyjson取长整数 (结果解析, "start_time")
                            变量 waitMaxMs <类型 = 整数>
                            waitMaxMs = MCP命令服务器.yyjson取整数 (结果解析, "max_ms")
                            // _poll_count 仅作诊断; 超时以 max_ms 为准 (避免高频轮询早于 max_ms 误中止)
                            变量 pollCount <类型 = 整数>
                            pollCount = MCP命令服务器.yyjson取整数 (结果解析, "_poll_count")
                            pollCount = pollCount + 1
                            // 更新_poll_count到存储
                            变量 更新计数存储 <类型 = YYJSON对象类>
                            更新计数存储.创建自文本 (存储结果)
                            更新计数存储.加入整数成员 ("_poll_count", pollCount)
                            MCP命令服务器.存储异步结果 (request_id, 更新计数存储.到可读文本 (YYJSON格式化选项.压缩))
                            // 检查超时
                            如果 (取启动时间 () - waitStartTime >= waitMaxMs)
                            {
                                MCP命令服务器.清理等待检查子任务 (存储结果)
                                // timeout类型: 等待时间到达 = 成功完成
                                如果 (waitWhat == "timeout")
                                {
                                    变量 超时成功 <类型 = YYJSON对象类>
                                    超时成功.创建自文本 ("{}")
                                    超时成功.加入逻辑值成员 ("success", 真)
                                    超时成功.加入文本成员 ("message", "等待完成: timeout " + 到文本 (waitMaxMs) + "ms 已到达")
                                    MCP命令服务器.存储异步结果 (request_id, 超时成功.到可读文本 (YYJSON格式化选项.压缩))
                                    返回 (超时成功.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                // selector/text类型: 超时未匹配 = 失败
                                变量 超时结果 <类型 = YYJSON对象类>
                                超时结果.创建自文本 ("{}")
                                超时结果.加入逻辑值成员 ("success", 假)
                                超时结果.加入文本成员 ("error", "等待超时(" + 到文本 (waitMaxMs) + "ms): " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value"))
                                // 更新存储结果, 清除_waiting标记
                                MCP命令服务器.存储异步结果 (request_id, 超时结果.到可读文本 (YYJSON格式化选项.压缩))
                                返回 (超时结果.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            如果 (waitWhat == "timeout")
                            {
                                // timeout类型: 继续等待, 不更新状态
                                变量 继续等待 <类型 = YYJSON对象类>
                                继续等待.创建自文本 ("{}")
                                继续等待.加入逻辑值成员 ("success", 真)
                                继续等待.加入文本成员 ("message", "等待中... 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                继续等待.加入逻辑值成员 ("_waiting", 真)
                                继续等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                继续等待.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                返回 (继续等待.到可读文本 (YYJSON格式化选项.压缩))
                            }
                            否则
                            {
                                // selector/text类型: 两阶段异步检查
                                // 阶段1: 未提交检查 → 提交JS并存储check_task_id, 等待下一轮轮询
                                // 阶段2: 已有检查 → 查询异步缓存获取实际JS执行结果
                                变量 checkTaskID <类型 = 文本型>
                                checkTaskID = MCP命令服务器.yyjson取文本 (结果解析, "_check_task_id")
                                如果 (checkTaskID == "")
                                {
                                    // 阶段1: 提交新的JS条件检查
                                    变量 browser <类型 = 类_FBrowser_浏览器>
                                    browser = MCP命令服务器.取主浏览器 ()
                                    如果 (browser.是否为空 ())
                                    {
                                        MCP命令服务器.清理等待检查子任务 (存储结果)
                                        变量 浏览器不可用 <类型 = YYJSON对象类>
                                        浏览器不可用.创建自文本 ("{}")
                                        浏览器不可用.加入逻辑值成员 ("success", 假)
                                        浏览器不可用.加入文本成员 ("error", "等待中断: 浏览器已不可用")
                                        MCP命令服务器.存储异步结果 (request_id, 浏览器不可用.到可读文本 (YYJSON格式化选项.压缩))
                                        返回 (浏览器不可用.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                    变量 checkCode <类型 = 文本型>
                                    checkCode = MCP命令服务器.yyjson取文本 (结果解析, "check_code")
                                    如果 (checkCode != "")
                                    {
                                        变量 rawSubmit <类型 = 文本型>
                                        rawSubmit = MCP命令服务器.提交异步JS任务 (browser, checkCode)
                                        变量 submit解析 <类型 = YYJSON只读对象类>
                                        如果 (submit解析.创建自文本 (rawSubmit))
                                        {
                                            checkTaskID = submit解析.取文本 ("task_id")
                                            如果 (checkTaskID != "")
                                            {
                                                变量 更新等待存储 <类型 = YYJSON对象类>
                                                更新等待存储.创建自文本 (存储结果)
                                                更新等待存储.加入文本成员 ("_check_task_id", checkTaskID)
                                                更新等待存储.加入整数成员 ("_poll_count", pollCount)
                                                MCP命令服务器.存储异步结果 (request_id, 更新等待存储.到可读文本 (YYJSON格式化选项.压缩))
                                            }
                                        }
                                    }
                                    变量 等待提交 <类型 = YYJSON对象类>
                                    等待提交.创建自文本 ("{}")
                                    等待提交.加入逻辑值成员 ("success", 真)
                                    等待提交.加入逻辑值成员 ("_waiting", 真)
                                    等待提交.加入文本成员 ("message", "等待中... " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value") + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                    等待提交.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                    等待提交.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                    返回 (等待提交.到可读文本 (YYJSON格式化选项.压缩))
                                }
                                否则
                                {
                                    // 阶段2: 查询异步JS执行结果
                                    变量 checkResultJSON <类型 = 文本型>
                                    checkResultJSON = MCP命令服务器.查询异步结果 (checkTaskID, 真)
                                    如果 (checkResultJSON != "")
                                    {
                                        // JS结果已到达, 解析found字段
                                        变量 check解析 <类型 = YYJSON只读对象类>
                                        如果 (check解析.创建自文本 (checkResultJSON))
                                        {
                                            变量 checkMsg <类型 = 文本型>
                                            checkMsg = MCP命令服务器.yyjson取文本 (check解析, "message")
                                            变量 foundMatch <类型 = 逻辑型 值 = 假>
                                            // message 是 JS 回调包装的 JSON: {"found":true,...}
                                            如果 (checkMsg != "")
                                            {
                                                变量 innerParse <类型 = YYJSON只读对象类>
                                                如果 (innerParse.创建自文本 (checkMsg) && innerParse.取逻辑值 ("found"))
                                                {
                                                    foundMatch = 真
                                                }
                                            }
                                            如果 (foundMatch)
                                            {
                                                如果 (waitWhat == "load_start")
                                                {
                                                    变量 loadPhase <类型 = 整数>
                                                    loadPhase = MCP命令服务器.yyjson取整数 (结果解析, "_load_phase")
                                                    如果 (loadPhase == 0)
                                                    {
                                                        MCP命令服务器.清理等待检查子任务 (存储结果)
                                                        变量 阶段切换 <类型 = YYJSON对象类>
                                                        阶段切换.创建自文本 (存储结果)
                                                        阶段切换.加入整数成员 ("_load_phase", 1)
                                                        阶段切换.加入文本成员 ("check_code", "(function(){return JSON.stringify({found:document.readyState==='complete',readyState:document.readyState})})()")
                                                        阶段切换.删除成员 ("_check_task_id")
                                                        阶段切换.加入整数成员 ("_poll_count", pollCount)
                                                        MCP命令服务器.存储异步结果 (request_id, 阶段切换.到可读文本 (YYJSON格式化选项.压缩))
                                                        变量 阶段等待 <类型 = YYJSON对象类>
                                                        阶段等待.创建自文本 ("{}")
                                                        阶段等待.加入逻辑值成员 ("success", 真)
                                                        阶段等待.加入逻辑值成员 ("_waiting", 真)
                                                        阶段等待.加入文本成员 ("message", "load_start: 已检测到 loading, 等待 load_end... 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                                        阶段等待.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                                        阶段等待.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                                        返回 (阶段等待.到可读文本 (YYJSON格式化选项.压缩))
                                                    }
                                                }
                                                MCP命令服务器.清理等待检查子任务 (存储结果)
                                                变量 找到结果 <类型 = YYJSON对象类>
                                                找到结果.创建自文本 ("{}")
                                                找到结果.加入逻辑值成员 ("success", 真)
                                                找到结果.加入文本成员 ("message", "等待完成: " + waitWhat + " 匹配成功 (" + 到文本 (取启动时间 () - waitStartTime) + "ms)")
                                                找到结果.加入文本成员 ("result", checkMsg)
                                                MCP命令服务器.存储异步结果 (request_id, 找到结果.到可读文本 (YYJSON格式化选项.压缩))
                                                返回 (找到结果.到可读文本 (YYJSON格式化选项.压缩))
                                            }
                                        }
                                        // 条件未满足: 清除check_task_id, 下一轮重新提交检查
                                        变量 重置等待 <类型 = YYJSON对象类>
                                        重置等待.创建自文本 (存储结果)
                                        重置等待.删除成员 ("_check_task_id")
                                        重置等待.加入整数成员 ("_poll_count", pollCount)
                                        MCP命令服务器.存储异步结果 (request_id, 重置等待.到可读文本 (YYJSON格式化选项.压缩))
                                    }
                                    // 检查结果尚未到达: 继续等待
                                    变量 等待结果 <类型 = YYJSON对象类>
                                    等待结果.创建自文本 ("{}")
                                    等待结果.加入逻辑值成员 ("success", 真)
                                    等待结果.加入逻辑值成员 ("_waiting", 真)
                                    等待结果.加入文本成员 ("message", "等待中... " + waitWhat + "=" + MCP命令服务器.yyjson取文本 (结果解析, "value") + " 已过" + 到文本 ((取启动时间 () - waitStartTime) / 1000) + "s/" + 到文本 (waitMaxMs / 1000) + "s")
                                    等待结果.加入长整数成员 ("elapsed_ms", 取启动时间 () - waitStartTime)
                                    等待结果.加入长整数成员 ("remaining_ms", waitMaxMs - (取启动时间 () - waitStartTime))
                                    返回 (等待结果.到可读文本 (YYJSON格式化选项.压缩))
                                }
                            }
                        }
                        变量 是否成功 <类型 = 逻辑型>
                        是否成功 = 结果解析.取逻辑值 ("success")
                        变量 msg <类型 = 文本型>
                        如果 (是否成功 == 假)
                        {
                            msg = MCP命令服务器.yyjson取文本 (结果解析, "error")
                            如果 (msg != "")
                            {
                                msg = "[任务" + request_id + "] " + msg
                            }
                            否则
                            {
                                msg = "[任务" + request_id + "] 任务执行失败"
                            }
                        }
                        否则
                        {
                            msg = MCP命令服务器.yyjson取文本 (结果解析, "message")
                            如果 (msg == "")
                            {
                                msg = "success"
                            }
                        }
                        变量 原始数据JSON <类型 = 文本型>
                        原始数据JSON = MCP命令服务器.yyjson取JSON文本 (结果解析, "data")
                        如果 (原始数据JSON == "" && 是否成功)
                        {
                            变量 msgContent <类型 = 文本型>
                            msgContent = MCP命令服务器.yyjson取文本 (结果解析, "message")
                            变量 msgParse <类型 = YYJSON只读对象类>
                            如果 (msgContent != "" && msgParse.创建自文本 (msgContent))
                            {
                                原始数据JSON = msgContent
                            }
                        }
                        变量 响应JSON <类型 = 文本型>
                        响应JSON = MCP命令服务器.构建任务查询结果JSON (是否成功, msg, 原始数据JSON, 实际任务ID)
                        如果 (consume && 结果解析.取逻辑值 ("_waiting") == 假)
                        {
                            MCP命令服务器.删除异步结果 (实际任务ID)
                            如果 (实际任务ID != request_id)
                            {
                                MCP命令服务器.删除异步结果 (request_id)
                            }
                        }
                        返回 (响应JSON)
                    }
                }
                返回 (MCP命令服务器.命令失败 (request_id, "未找到任务结果: " + request_id + " | 可能原因: 任务尚未完成(稍后重试) 或 request_id 不正确 | 提示: 异步任务通常2-5秒内完成"))
            }
            返回 (MCP命令服务器.命令失败 ("", "参数 request_id 不能为空 | 异步任务请使用 task_id (tools/call 返回的 task_xxx)"))
        }
        // === MCP状态 ===
        否则 (方法名 == "mcp.status" || 方法名 == "mcp_status")
        {
            变量 状态对象 <类型 = YYJSON对象类>
            状态对象.创建自文本 ("{}")
            状态对象.加入文本成员 ("server", MCP命令服务器.MCP_服务器名)
            状态对象.加入文本成员 ("version", MCP命令服务器.MCP_版本号)
            状态对象.加入整数成员 ("port", MCP命令服务器.服务器端口)
            状态对象.加入整数成员 ("browser_count", FBrowser_浏览器_取数量 ())
            状态对象.加入文本成员 ("status", "running")
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 状态对象.到可读文本 (YYJSON格式化选项.压缩)))
        }
        // === 帮助 ===
        否则 (方法名 == "mcp.help" || 方法名 == "mcp_help")
        {
            变量 帮助文本 <类型 = 文本型>
            帮助文本 = "=== AI浏览器 MCP 工具列表 ===\r\n\r\n"
            帮助文本 = 帮助文本 + "导航: navigate, get_url, get_title, back, forward, reload, stop\r\n"
            帮助文本 = 帮助文本 + "JS执行: execute_js, evaluate, console_eval\r\n"
            帮助文本 = 帮助文本 + "内容: get_source, get_text\r\n"
            帮助文本 = 帮助文本 + "窗口: create, create_background, close, list, set_visibility, set_focus, get_window_handle\r\n"
            帮助文本 = 帮助文本 + "调试: open_devtools, close_devtools, set_zoom, get_zoom, screenshot\r\n"
            帮助文本 = 帮助文本 + "CDP: cdp, debugger_flow(一键), enable/pause/resume/step_*/stack/set_breakpoint/evaluate/wait_paused/last_paused/inspect\r\n"
            帮助文本 = 帮助文本 + "抓包: network_body(获取响应体,需VIP)\r\n"
            帮助文本 = 帮助文本 + "交互: mouse_click, mouse_move, mouse_wheel, key_event\r\n"
            帮助文本 = 帮助文本 + "编辑: edit_undo, edit_redo, edit_cut, edit_copy, edit_paste, edit_delete, edit_select_all\r\n"
            帮助文本 = 帮助文本 + "查找: find, stop_find\r\n"
            帮助文本 = 帮助文本 + "DOM: dom_query, dom_click, dom_set_value, dom_get_html\r\n"
            帮助文本 = 帮助文本 + "Cookie: get_cookies, set_cookie, delete_cookies\r\n"
            帮助文本 = 帮助文本 + "框架: get_frames\r\n"
            帮助文本 = 帮助文本 + "代理: set_proxy, clear_proxy\r\n"
            帮助文本 = 帮助文本 + "下载: start_download\r\n"
            帮助文本 = 帮助文本 + "网络: collect(REQ/RES采集), network(查看结构化的网络日志)\r\n"
            帮助文本 = 帮助文本 + "场景: collect reverse_prepare/debug_prepare/automation_prepare + workflow_run + mcp_bridge.js --call\r\n"
            帮助文本 = 帮助文本 + "拦截: intercept (modify/replace_data/replace_file/block/cache缓存响应到磁盘/uncache/clear/ws_hook)\r\n"
            帮助文本 = 帮助文本 + "自动化: wait(等待条件), inject(注入JS/CSS, persist=true使用V8预注入)\r\n"
            帮助文本 = 帮助文本 + "编码: base64_encode/decode, uri_encode/decode\r\n"
            帮助文本 = 帮助文本 + "其他: set_mute, is_muted, print, print_to_pdf, clear_cache, is_loading, can_navigate, get_id\r\n"
            帮助文本 = 帮助文本 + "内存: compress_memory\r\n"
            帮助文本 = 帮助文本 + "系统: mcp_status, mcp_help, mcp_result(异步查询), fbro_version, ping(连通检查)\r\n"
            帮助文本 = 帮助文本 + "效率: batch(批量执行多个命令), aliases(短名别名列表)\r\n"
            帮助文本 = 帮助文本 + "\r\n提示: 所有browser_xxx工具支持去掉前缀的短名, 如navigate=get_url=..."
            返回 (MCP命令服务器.构建简单JSON ("help", 帮助文本))
        }
        // === 别名列表 ===
        否则 (方法名 == "aliases" || 方法名 == "browser_aliases")
        {
            变量 别名列表 <类型 = 文本型>
            别名列表 = "快捷别名(browser_前缀可省略):\r\n"
            别名列表 = 别名列表 + "navigate get_url get_title back forward reload stop\r\n"
            别名列表 = 别名列表 + "evaluate execute_js get_source get_text screenshot\r\n"
            别名列表 = 别名列表 + "dom_query dom_click dom_set_value dom_get_html\r\n"
            别名列表 = 别名列表 + "create close list inject collect network intercept\r\n"
            别名列表 = 别名列表 + "wait cdp mouse_click mouse_move mouse_wheel key_event\r\n"
            别名列表 = 别名列表 + "get_cookies set_cookie delete_cookies set_proxy clear_proxy\r\n"
            别名列表 = 别名列表 + "set_mute print find fingerprint status set_zoom get_zoom\r\n"
            别名列表 = 别名列表 + "batch(批量) ping(连通检查) aliases(本列表)\r\n"
            返回 (MCP命令服务器.构建简单JSON ("aliases", 别名列表))
        }
        // === v1.8 CDP结果回传 (核心修复: 结果通过mcp_result返回) ===
        否则 (方法名 == "browser.cdp_call" || 方法名 == "browser_cdp_call")
        {
            变量 cdpMethod <类型 = 文本型>
            cdpMethod = MCP命令服务器.yyjson取文本 (参数JSON, "method")
            如果 (cdpMethod != "")
            {
                // 先确保观察者已注册
                MCP命令服务器.确保CDP观察者已注册 ()
                // MCP命令服务器.执行CDP命令(自动分配消息ID并记录映射)
                返回 (MCP命令服务器.执行CDP命令 (命令ID, cdpMethod, 参数JSON))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "CDP需要method参数"))
        }
        // === v1.8 浏览器事件查询 ===
        否则 (方法名 == "browser.event" || 方法名 == "browser_event")
        {
            变量 evtType <类型 = 文本型>
            evtType = MCP命令服务器.yyjson取文本 (参数JSON, "event_type")
            如果 (evtType != "")
            {
                // 应用事件: event_type 以 app_ 开头 → 查询 event_log
                如果 (MCP命令服务器.是否以 (evtType, "app_"))
                {
                    变量 appResult <类型 = 文本型>
                    appResult = MCP命令服务器.查询事件日志 ("app_event", evtType, 0, 1)
                    如果 (appResult != "[]")
                    {
                        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, appResult))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "未找到应用事件: " + evtType + " | 请先 browser_collect action=event_app_enable"))
                }
                // 浏览器事件: 需要浏览器ID → 查询 SQLite event_log
                变量 evtBrowser <类型 = 类_FBrowser_浏览器>
                evtBrowser = MCP命令服务器.取主浏览器 ()
                如果 (evtBrowser.是否为空 () == 假)
                {
                    变量 evtResult <类型 = 文本型>
                    evtResult = MCP命令服务器.查询事件日志 ("browser_event", evtType, evtBrowser.取ID (), 100)
                    如果 (evtResult != "[]")
                    {
                        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, evtResult))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "未找到事件: " + evtType + " | 支持: load_start/load_end/load_error/crash/navigate/popup/popup_failed/loading_state_change/url_changed/browser_created/browser_closing/do_close/title_changed/load_progress/resource_*/js_dialog/before_unload/file_dialog/fullscreen/favicon/find_result/frame_*/download_*/key_press/focus_* | 应用事件: app_*"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "需要event_type参数 | 浏览器事件: load_end/crash/... 应用事件: app_xxx"))
        }
        否则 (方法名 == "browser.cdp_event" || 方法名 == "browser_cdp_event")
        {
            变量 eventName <类型 = 文本型>
            eventName = MCP命令服务器.yyjson取文本 (参数JSON, "event_name")
            如果 (eventName == "")
            {
                eventName = MCP命令服务器.yyjson取文本 (参数JSON, "event")
            }
            如果 (eventName != "")
            {
                // 优先读 async 缓存 (CDP 事件不再写 event_log, 防 SQLite 膨胀)
                变量 eventKey <类型 = 文本型>
                eventKey = "cdp_event:" + eventName
                变量 eventResult <类型 = 文本型>
                eventResult = MCP命令服务器.查询异步结果 (eventKey)
                如果 (eventResult == "")
                {
                    eventResult = MCP命令服务器.查询任务结果 (eventKey)
                }
                如果 (eventResult != "")
                {
                    如果 (eventName == "Debugger.paused")
                    {
                        变量 摘要2 <类型 = 文本型>
                        摘要2 = MCP命令服务器.解析Debugger暂停摘要 (eventResult)
                        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, "{\"event\":\"" + eventName + "\",\"raw\":" + eventResult + ",\"paused\":" + 摘要2 + "}"))
                    }
                    返回 (MCP命令服务器.命令成功_原始JSON (命令ID, eventResult))
                }
                变量 legacyLog <类型 = 文本型>
                legacyLog = MCP命令服务器.查询事件日志 ("cdp_event", eventName, 0, 1)
                如果 (legacyLog != "[]" && legacyLog != "" && MCP命令服务器.是否以 (legacyLog, "["))
                {
                    变量 内层JSON <类型 = 文本型>
                    内层JSON = 取文本中间 (legacyLog, 2, 取文本长度 (legacyLog) - 2)
                    如果 (eventName == "Debugger.paused")
                    {
                        变量 摘要 <类型 = 文本型>
                        摘要 = MCP命令服务器.解析Debugger暂停摘要 (内层JSON)
                        返回 (MCP命令服务器.命令成功_原始JSON (命令ID, "{\"event\":\"" + eventName + "\",\"raw\":" + 内层JSON + ",\"paused\":" + 摘要 + "}"))
                    }
                    返回 (MCP命令服务器.命令成功_原始JSON (命令ID, 内层JSON))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "未找到CDP事件: " + eventName + " | 请先 debugger_enable，命中断点后会写入 async 缓存"))
            }
            // 无指定则返回通用的异步存储结果
            返回 (MCP命令服务器.命令失败 (命令ID, "指定 event_name 或 event 参数，例如 Debugger.paused"))
        }
        // === 旧版别名兼容 (CDP命令) ===
        否则 (方法名 == "browser.cdp" || 方法名 == "browser_cdp")
        {
            变量 cdpMethod <类型 = 文本型>
            cdpMethod = MCP命令服务器.yyjson取文本 (参数JSON, "method")
            如果 (cdpMethod != "")
            {
                返回 (MCP命令服务器.执行CDP命令 (命令ID, cdpMethod, 参数JSON))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "CDP需要method参数, 例如: {method: \"Page.navigate\", params: \"{...}\"}"))
        }
        // === 网络抓包: 获取响应体 ===
        否则 (方法名 == "browser.network_body" || 方法名 == "browser_network_body")
        {
            变量 requestId <类型 = 文本型>
            requestId = MCP命令服务器.yyjson取文本 (参数JSON, "request_id")
            如果 (requestId == "")
            {
