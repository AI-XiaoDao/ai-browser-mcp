<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# MCP_核心分派 — 从 MCP_Server.wsv 拆分 (L5)
类 MCP_核心分派 <公开 @全局类 = 真>
{
    # === 分类分派: 核心操作 (导航/内容/JS/DevTools/窗口管理) ===
    方法 分类分派_核心操作 <公开 静态 类型 = 文本型>
    参数 命令ID <类型 = 文本型>
    参数 方法名 <类型 = 文本型>
    参数 参数JSON <类型 = YYJSON只读对象类>
    {
        如果 (方法名 == "browser.navigate" || 方法名 == "browser_navigate")
        {
            变量 url <类型 = 文本型>
            url = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (url != "")
            {
                // 安全: 仅允许 http/https/about/data/ftp 协议
                如果 (MCP命令服务器.验证URL安全 (url) == 假)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "不支持的URL协议 | 仅允许 http/https/about/data/ftp | 示例: browser_navigate {url:'https://www.baidu.com/'}"))
                }
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 navFrame <类型 = 类_FBrowser_框架>
                    navFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (navFrame.是否为空 () == 假 && navFrame.是否有效 ())
                    {
                        navFrame.载入地址 (url)
                        返回 (MCP命令服务器.命令成功 (命令ID, "已导航到: " + url))
                    }
                    返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成, 请先 navigate 并等待2-3秒后重试"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 url 不能为空"))
        }
        否则 (方法名 == "browser.get_url" || 方法名 == "browser_get_url")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 urlFrame <类型 = 类_FBrowser_框架>
                urlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (urlFrame.是否为空 () == 假)
                {
                    返回 (MCP命令服务器.构建简单JSON ("url", urlFrame.取地址 ()))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成, 请先 navigate 并等待2-3秒后重试"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.get_title" || 方法名 == "browser_get_title")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 默认 sync-wait 返回 document.title (async_only:true 可改异步)
                变量 异步标题ID <类型 = 文本型>
                异步标题ID = MCP命令服务器.生成异步任务ID ()
                MCP命令服务器.提交异步JS任务 (browser, "document.title", 异步标题ID)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步标题ID, "标题获取已提交", 150))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 导航控制 ===
        否则 (方法名 == "browser.back" || 方法名 == "browser_back")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假 && browser.可否后退 ())
            {
                browser.后退 ()
                返回 (MCP命令服务器.命令成功 (命令ID, "已后退"))
            }
            如果 (browser.是否为空 () == 真)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "无法后退 — 无导航历史 | 当前页面没有可后退的历史记录"))
        }
        否则 (方法名 == "browser.forward" || 方法名 == "browser_forward")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假 && browser.可否前进 ())
            {
                browser.前进 ()
                返回 (MCP命令服务器.命令成功 (命令ID, "已前进"))
            }
            如果 (browser.是否为空 () == 真)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "无法前进 — 无导航历史 | 当前页面没有可前进的历史记录"))
        }
        否则 (方法名 == "browser.reload" || 方法名 == "browser_reload")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 忽略缓存 <类型 = 逻辑型>
                忽略缓存 = MCP命令服务器.yyjson取逻辑 (参数JSON, "ignore_cache")
                如果 (忽略缓存)
                {
                    browser.重新载入_忽略缓存 ()
                }
                否则
                {
                    browser.重新载入 ()
                }
                返回 (MCP命令服务器.命令成功 (命令ID, "页面已刷新"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.stop" || 方法名 == "browser_stop")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.停止载入 ()
                返回 (MCP命令服务器.命令成功 (命令ID, "加载已停止"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === JS执行 ===
        否则 (方法名 == "browser.execute_js" || 方法名 == "browser_execute_js")
        {
            变量 code <类型 = 文本型>
            code = MCP命令服务器.解码JS代码 (参数JSON)
            如果 (code == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "缺少参数: 请提供 code(JS代码字符串) 或 file(JS文件路径)"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 execFrame <类型 = 类_FBrowser_框架>
                execFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (execFrame.是否为空 () == 假 && execFrame.是否有效 ())
                {
                    execFrame.执行JS代码 (code)
                    返回 (MCP命令服务器.命令成功 (命令ID, "JS已执行"))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, "主框架无效 | 页面可能尚未加载完成"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.evaluate" || 方法名 == "browser_evaluate")
        {
            变量 code <类型 = 文本型>
            code = MCP命令服务器.解码JS代码 (参数JSON)
            如果 (code == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "缺少参数: 请提供 code(JS代码字符串) 或 file(JS文件路径)"))
            }
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 异步模式: 变量 result <类型 = 文本型>
                变量 rawResult <类型 = 文本型>
                rawResult = MCP命令服务器.提交异步JS任务 (browser, code)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, rawResult, "result", "JS执行已提交"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 页面内容 ===
        否则 (方法名 == "browser.get_source" || 方法名 == "browser_get_source")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 maxChars <类型 = 整数>
                maxChars = MCP命令服务器.yyjson取整数 (参数JSON, "max_chars")
                如果 (maxChars <= 0 || maxChars > MCP命令服务器.截断_源码最大字节)
                {
                    maxChars = MCP命令服务器.截断_源码默认字节
                }
                变量 source <类型 = 文本型>
                source = MCP命令服务器.提交异步取源码任务 (browser, , maxChars)
                返回 (MCP命令服务器.包装异步提交结果 (命令ID, source, "source", "源码获取已提交(max=" + 到文本 (maxChars) + ")"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.get_text" || 方法名 == "browser_get_text")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 selector <类型 = 文本型>
                selector = MCP命令服务器.yyjson取文本 (参数JSON, "selector")
                如果 (selector != "")
                {
                    // 只提取指定选择器的文本, 大幅减少token
                    变量 js <类型 = 文本型>
                    js = "try{var e=document.querySelector('" + MCP命令服务器.简单转义JS (selector) + "');e?e.innerText||e.textContent||'':'selector not found'}catch(e){e.message}"
                    变量 textResult <类型 = 文本型>
                    textResult = MCP命令服务器.提交异步JS任务 (browser, js)
                    返回 (MCP命令服务器.包装异步提交结果 (命令ID, textResult, "text", "文本获取已提交"))
                }
                否则
                {
                    // selector为空: 获取页面全部文本内容
                    变量 fullText <类型 = 文本型>
                    fullText = MCP命令服务器.提交异步取文本任务 (browser)
                    返回 (MCP命令服务器.包装异步提交结果 (命令ID, fullText, "text", "全文获取已提交"))
                }
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 开发者工具 ===
        否则 (方法名 == "browser.open_devtools" || 方法名 == "browser_open_devtools")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.打开开发者工具 ("AI调试工具", 0, 0, 0, 1024, 800)
                返回 (MCP命令服务器.命令成功 (命令ID, "DevTools已打开"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.close_devtools" || 方法名 == "browser_close_devtools")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.关闭开发者工具 ()
                返回 (MCP命令服务器.命令成功 (命令ID, "DevTools已关闭"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 窗口管理 (仅本地GUI可用, MCP远程调用已禁用) ===
        否则 (方法名 == "browser.create" || 方法名 == "browser_create")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "⛔ 远程创建浏览器已禁用 | 浏览器由GUI自动管理, 无需手动创建"))
        }
        否则 (方法名 == "browser.create_background" || 方法名 == "browser_create_background")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "⛔ 远程创建后台浏览器已禁用 | 浏览器由GUI自动管理"))
        }
        否则 (方法名 == "browser.close" || 方法名 == "browser_close")
        {
            返回 (MCP命令服务器.命令失败 (命令ID, "⛔ 远程关闭浏览器已禁用 | 浏览器生命周期由GUI管理"))
        }
        否则 (方法名 == "browser.list" || 方法名 == "browser_list")
        {
            MCP命令服务器.浏览器数组锁.加锁 ()
            变量 ID清单 <类型 = 类_FBrowser_列表值>
            ID清单 = FBrowser_浏览器_取ID清单 ()
            // 防御: ID清单可能为空
            如果 (ID清单.是否为空 () == 假)
            {
                变量 列表JSON <类型 = 文本型>
                列表JSON = "["
                变量 首项标志 <类型 = 逻辑型 值 = 真>
                变量 listSize <类型 = 整数>
                listSize = ID清单.取大小 ()
                计次循环 (listSize)
                {
                    变量 bid <类型 = 整数>
                    bid = ID清单.取整数值 (取循环索引 ())
                    变量 b <类型 = 类_FBrowser_浏览器>
                    b = FBrowser_浏览器_通过ID取浏览器 (bid)
                    如果 (b.是否为空 () == 假 && b.是否已关闭 () == 假)
                    {
                        如果 (首项标志)
                        {
                            首项标志 = 假
                        }
                        否则
                        {
                            列表JSON = 列表JSON + ","
                        }
                        变量 listUrlFrame <类型 = 类_FBrowser_框架>
                        listUrlFrame = MCP命令服务器.取安全主框架 (b)
                        变量 urlText <类型 = 文本型>
                        如果 (listUrlFrame.是否为空 () == 假)
                        {
                            urlText = listUrlFrame.取地址 ()
                        }
                        否则
                        {
                            urlText = ""
                        }
                        变量 浏览器项 <类型 = YYJSON对象类>
                        浏览器项.创建自文本 ("{}")
                        浏览器项.加入整数成员 ("id", bid)
                        浏览器项.加入文本成员 ("url", urlText)
                        列表JSON = 列表JSON + 浏览器项.到可读文本 (YYJSON格式化选项.压缩)
                    }
                }
                列表JSON = 列表JSON + "]"
                MCP命令服务器.浏览器数组锁.解锁 ()
                返回 (MCP命令服务器.构建命令嵌套JSON (命令ID, 真, "browsers", 列表JSON))
            }
            MCP命令服务器.浏览器数组锁.解锁 ()
            返回 (MCP命令服务器.命令失败 (命令ID, "无法获取浏览器ID清单"))
        }
        // === 缩放 ===
        否则 (方法名 == "browser.set_zoom" || 方法名 == "browser_set_zoom")
        {
            变量 level <类型 = 文本型>
            level = MCP命令服务器.yyjson取文本 (参数JSON, "level")
            如果 (level != "")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.置缩放级别 (文本到小数 (level))
                    MCP命令服务器.持久缩放级别 = 文本到小数 (level)
                    返回 (MCP命令服务器.命令成功 (命令ID, "缩放(持久): " + level))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 level 不能为空"))
        }
        // === 查找 ===
        否则 (方法名 == "browser.find" || 方法名 == "browser_find")
        {
            变量 text <类型 = 文本型>
            text = MCP命令服务器.yyjson取文本 (参数JSON, "text")
            如果 (text != "")
            {
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.查找 (text, 真, 假, 假)
                    返回 (MCP命令服务器.命令成功 (命令ID, "查找: " + text))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 text 不能为空"))
        }
        否则 (方法名 == "browser.stop_find" || 方法名 == "browser_stop_find")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.停止查找 (真)
                返回 (MCP命令服务器.命令成功 (命令ID, "查找已停止"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 鼠标 ===
        如果 (方法名 == "browser.mouse_click" || 方法名 == "browser_mouse_click")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 x <类型 = 整数>
                变量 y <类型 = 整数>
                x = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                变量 按钮文本 <类型 = 文本型>
                按钮文本 = MCP命令服务器.yyjson取文本 (参数JSON, "button")
                变量 按钮类型 <类型 = 整数>
                如果 (按钮文本 == "right")
                {
                    按钮类型 = 鼠标按键类型.右键
                }
                否则 (按钮文本 == "middle")
                {
                    按钮类型 = 鼠标按键类型.中键
                }
                否则
                {
                    按钮类型 = 鼠标按键类型.左键  // 默认左键
                }
                变量 鼠标事件 <类型 = FBrowser_鼠标事件>
                鼠标事件.横坐标 = x
                鼠标事件.纵坐标 = y
                鼠标事件.修饰键 = 事件标识.无
                browser.发送鼠标点击事件 (按钮类型, 鼠标事件, 假, 1)
                browser.发送鼠标点击事件 (按钮类型, 鼠标事件, 真, 1)
                返回 (MCP命令服务器.命令成功 (命令ID, "点击 (" + 到文本 (x) + "," + 到文本 (y) + ") 按钮:" + 按钮文本))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.mouse_move" || 方法名 == "browser_mouse_move")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 x <类型 = 整数>
                变量 y <类型 = 整数>
                x = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                变量 鼠标事件 <类型 = FBrowser_鼠标事件>
                鼠标事件.横坐标 = x
                鼠标事件.纵坐标 = y
                鼠标事件.修饰键 = 事件标识.无
                browser.发送鼠标移动事件 (鼠标事件, 假)
                返回 (MCP命令服务器.命令成功 (命令ID, "鼠标移动到 (" + 到文本 (x) + "," + 到文本 (y) + ")"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 键盘 ===
        否则 (方法名 == "browser.key_event" || 方法名 == "browser_key_event")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 key <类型 = 整数>
                key = MCP命令服务器.yyjson取整数 (参数JSON, "key_code")
                如果 (key <= 0)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "参数 key_code 必须为有效虚拟键码(>0)"))
                }
                变量 类型文本 <类型 = 文本型>
                类型文本 = MCP命令服务器.yyjson取文本 (参数JSON, "type")
                变量 按键事件 <类型 = FBrowser_按键事件>
                如果 (类型文本 == "keydown")
                {
                    按键事件.类型 = 按键事件.按下
                }
                否则 (类型文本 == "keyup")
                {
                    按键事件.类型 = 按键事件.放开
                }
                否则
                {
                    按键事件.类型 = 按键事件.单击
                }
                按键事件.系统按键 = key
                // 修饰键: 位标志组合 (1=Ctrl, 2=Alt, 4=Shift), 默认0=无
                变量 修饰位 <类型 = 整数>
                修饰位 = MCP命令服务器.yyjson取整数 (参数JSON, "modifiers")
                按键事件.修饰位 = 修饰位
                browser.发送按键事件 (按键事件)
                返回 (MCP命令服务器.命令成功 (命令ID, "按键已发送 key_code=" + 到文本 (key) + " type=" + 类型文本 + " modifiers=" + 到文本 (修饰位)))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 静音/打印/缓存 ===
        否则 (方法名 == "browser.set_mute" || 方法名 == "browser_set_mute")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 静音 <类型 = 逻辑型>
                静音 = MCP命令服务器.yyjson取逻辑 (参数JSON, "mute")
                browser.置页面静音 (静音)
                MCP命令服务器.持久静音状态 = 静音
                返回 (MCP命令服务器.命令成功 (命令ID, "静音(持久): " + 到文本 (静音)))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.print" || 方法名 == "browser_print")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.打印 ()
                返回 (MCP命令服务器.命令成功 (命令ID, "打印已触发"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.print_to_pdf" || 方法名 == "browser_print_to_pdf")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 路径 <类型 = 文本型>
                路径 = MCP命令服务器.yyjson取文本 (参数JSON, "path")
                // 安全: 先检查用户提供的路径, 再处理空路径默认值 (PDF写入仅允许运行目录内)
                如果 (路径 != "" && MCP命令服务器.验证安全路径 (路径, 真) == 假)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "路径不允许: " + 路径))
                }
                如果 (路径 == "")
                {
                    路径 = 取运行目录 () + "\\mcp_output.pdf"
                }
                // 文件覆盖保护: overwrite参数必须为true才能覆盖已存在的文件
                如果 (文件是否存在 (路径))
                {
                    变量 覆盖确认 <类型 = 逻辑型>
                    覆盖确认 = MCP命令服务器.yyjson取逻辑 (参数JSON, "overwrite")
                    如果 (覆盖确认 == 假)
                    {
                        返回 (MCP命令服务器.命令失败 (命令ID, "文件已存在: " + 路径 + " | 请设置 overwrite: true 确认覆盖, 或更换path参数"))
                    }
                }
                变量 PDF设置 <类型 = FBrowser_PDF打印设置>
                变量 异步PDFID <类型 = 文本型>
                异步PDFID = MCP命令服务器.生成异步任务ID ()
                变量 PDF回调 <类型 = 类_FBrowser_事件智能指针>
                PDF回调.创建 (类_MCP_打印PDF回调)
                PDF回调.取执行类 (类_MCP_打印PDF回调).任务ID = 异步PDFID
                browser.打印为PDF (路径, PDF设置, PDF回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步PDFID, "PDF打印已提交, 通过mcp_result查询结果", 2000))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === Cookie ===
        否则 (方法名 == "browser.get_cookies" || 方法名 == "browser_get_cookies")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                // 可配置上限
                变量 cookieLimit <类型 = 整数>
                cookieLimit = MCP命令服务器.yyjson取整数 (参数JSON, "limit")
                如果 (cookieLimit <= 0)
                {
                    cookieLimit = 200
                }
                如果 (cookieLimit > 500)
                {
                    cookieLimit = 500
                }
                // 使用官方 FBrowser Cookie管理器 回调 API (含HttpOnly)
                变量 异步CookieID <类型 = 文本型>
                异步CookieID = MCP命令服务器.生成异步任务ID ()
                变量 Cookie回调 <类型 = 类_FBrowser_事件智能指针>
                Cookie回调.创建 (类_MCP_Cookie收集回调)
                Cookie回调.取执行类 (类_MCP_Cookie收集回调).异步任务ID = 异步CookieID
                Cookie回调.取执行类 (类_MCP_Cookie收集回调).最大项数 = cookieLimit
                变量 urlFrame <类型 = 类_FBrowser_框架>
                urlFrame = MCP命令服务器.取安全主框架 (browser)
                如果 (urlFrame.是否为空 () == 假)
                {
                    FBrowser_Cookie管理器_取全局 ().取地址Cookie (urlFrame.取地址 (), 真, Cookie回调)
                }
                否则
                {
                    // 框架不可用时立即存储错误结果, 防止客户端无限轮询
                    MCP命令服务器.存储异步结果 (异步CookieID, MCP命令服务器.构建标准失败JSON ("主框架无效, 无法获取Cookie | 页面可能尚未加载完成, 请先 navigate 并等待2-3秒后重试"))
                }
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步CookieID, "Cookie获取已提交(含HttpOnly), 通过mcp_result查询", 300))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.set_cookie" || 方法名 == "browser_set_cookie")
        {
            变量 name <类型 = 文本型>
            变量 value <类型 = 文本型>
            变量 domain <类型 = 文本型>
            name = MCP命令服务器.yyjson取文本 (参数JSON, "name")
            value = MCP命令服务器.yyjson取文本 (参数JSON, "value")
            domain = MCP命令服务器.yyjson取文本 (参数JSON, "domain")
            如果 (name == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "参数 name 不能为空"))
            }
            如果 (domain == "")
            {
                // 从当前浏览器URL自动提取域名
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    变量 currentURL <类型 = 文本型>
                    变量 setCookieFrame <类型 = 类_FBrowser_框架>
                    setCookieFrame = MCP命令服务器.取安全主框架 (browser)
                    如果 (setCookieFrame.是否为空 () == 假)
                    {
                        currentURL = setCookieFrame.取地址 ()
                    }
                    // 简单提取: 取://后到第一个/之间的部分作为域名
                    变量 schemeEnd <类型 = 整数>
                    schemeEnd = 寻找文本 (currentURL, "://", , 假)
                    如果 (schemeEnd > 0)
                    {
                        变量 hostStart <类型 = 整数>
                        hostStart = schemeEnd + 3
                        变量 hostEnd <类型 = 整数>
                        hostEnd = 寻找文本 (currentURL, "/", hostStart, 假)
                        如果 (hostEnd < 0)
                        {
                            // 无路径斜杠, 域名到末尾: 取://之后全部文本
                            domain = 取文本中间 (currentURL, hostStart, 取文本长度 (currentURL) - hostStart + 1)
                        }
                        否则
                        {
                            // 提取 :// 和 / 之间的域名
                            domain = 取文本中间 (currentURL, hostStart, hostEnd - hostStart)
                        }
                        // 去除端口号 (如 example.com:8080 → example.com)
                        变量 冒号位置 <类型 = 整数>
                        冒号位置 = 寻找文本 (domain, ":", , 假)
                        如果 (冒号位置 > 0)
                        {
                            domain = 取文本左边 (domain, 冒号位置 - 1)
                        }
                        // 加前导点以匹配子域名, 同时去掉可能的尾随空白
                        domain = "." + domain
                    }
                }
                如果 (domain == "")
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "无法获取域名,请显式提供domain参数"))
                }
            }
            // 构建URL时去除域名的前导点(如.baidu.com → baidu.com)
            变量 urlDomain <类型 = 文本型>
            urlDomain = domain
            如果 (MCP命令服务器.是否以 (urlDomain, "."))
            {
                // 去除前导点: 已知以.开头(位置1), 从位置2取剩余全部
                urlDomain = 取文本中间 (urlDomain, 2, 取文本长度 (urlDomain) - 1)
            }
            变量 Cookie数据 <类型 = FBrowser_Cookie数据>
            Cookie数据.名 = name
            Cookie数据.值 = value
            Cookie数据.域 = domain
            Cookie数据.路径 = "/"
            Cookie数据.是否只有http = 假
            Cookie数据.是否有过期时间 = 假
            FBrowser_Cookie管理器_取全局 ().置Cookie ("http://" + urlDomain, Cookie数据)
            返回 (MCP命令服务器.命令成功 (命令ID, "Cookie已设置: " + name))
        }
        否则 (方法名 == "browser.delete_cookies" || 方法名 == "browser_delete_cookies")
        {
            变量 确认 <类型 = 逻辑型>
            确认 = MCP命令服务器.yyjson取逻辑 (参数JSON, "confirm")
            如果 (确认 == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "此操作将清除所有域名下所有Cookie, 请设置 confirm: true 以确认操作"))
            }
            FBrowser_Cookie管理器_取全局 ().删除Cookie ("", "")
            返回 (MCP命令服务器.命令成功 (命令ID, "Cookie已全部清除"))
        }
        否则 (方法名 == "browser.clear_cache" || 方法名 == "browser_clear_cache")
        {
            变量 异步清理ID <类型 = 文本型>
            异步清理ID = MCP命令服务器.生成异步任务ID ()
            变量 清理缓存回调 <类型 = 类_FBrowser_事件智能指针>
            清理缓存回调.创建 (类_MCP_清理缓存回调)
            清理缓存回调.取执行类 (类_MCP_清理缓存回调).任务ID = 异步清理ID
            FBrowser_清理全局缓存 (, , , 清理缓存回调)
            返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步清理ID, "全局缓存清理已提交, 通过mcp_result查询", 500))
        }
        // === 状态查询 ===
        否则 (方法名 == "browser.is_loading" || 方法名 == "browser_is_loading")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                返回 (MCP命令服务器.构建逻辑值JSON ("loading", browser.是否读取中 ()))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.can_navigate" || 方法名 == "browser_can_navigate")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                返回 (MCP命令服务器.构建双键JSON ("can_go_back", 到文本 (browser.可否后退 ()), "can_go_forward", 到文本 (browser.可否前进 ())))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.get_id" || 方法名 == "browser_get_id")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                返回 (MCP命令服务器.构建整数值JSON ("id", browser.取ID ()))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 鼠标滚轮 ===
        否则 (方法名 == "browser.mouse_wheel" || 方法名 == "browser_mouse_wheel")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 x <类型 = 整数>
                变量 y <类型 = 整数>
                变量 deltaX <类型 = 整数>
                变量 deltaY <类型 = 整数>
                x = MCP命令服务器.yyjson取整数 (参数JSON, "x")
                y = MCP命令服务器.yyjson取整数 (参数JSON, "y")
                deltaX = MCP命令服务器.yyjson取整数 (参数JSON, "delta_x")
                deltaY = MCP命令服务器.yyjson取整数 (参数JSON, "delta_y")
                变量 鼠标事件 <类型 = FBrowser_鼠标事件>
                鼠标事件.横坐标 = x
                鼠标事件.纵坐标 = y
                鼠标事件.修饰键 = 事件标识.无
                browser.发送鼠标滚轮事件 (鼠标事件, deltaX, deltaY)
                返回 (MCP命令服务器.命令成功 (命令ID, "滚轮 (" + 到文本 (x) + "," + 到文本 (y) + ") delta:" + 到文本 (deltaX) + "," + 到文本 (deltaY)))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 缩放获取 ===
        否则 (方法名 == "browser.get_zoom" || 方法名 == "browser_get_zoom")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                返回 (MCP命令服务器.构建简单JSON ("zoom_level", 到文本 (browser.取缩放级别 ())))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 代理 ===
        否则 (方法名 == "browser.set_proxy" || 方法名 == "browser_set_proxy")
        {
            变量 address <类型 = 文本型>
            变量 username <类型 = 文本型>
            变量 password <类型 = 文本型>
            address = MCP命令服务器.yyjson取文本 (参数JSON, "address")
            如果 (address != "")
            {
                username = MCP命令服务器.yyjson取文本 (参数JSON, "username")
                password = MCP命令服务器.yyjson取文本 (参数JSON, "password")
                变量 browser <类型 = 类_FBrowser_浏览器>
                browser = MCP命令服务器.取主浏览器 ()
                如果 (browser.是否为空 () == 假)
                {
                    browser.设置代理 (address, username, password)
                    // 持久化: 新浏览器自动应用
                    MCP命令服务器.持久代理地址 = address
                    MCP命令服务器.持久代理账号 = username
                    MCP命令服务器.持久代理密码 = password
                    返回 (MCP命令服务器.响应_需要刷新 (命令ID, "代理已设置(持久): " + address))
                }
                返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "参数 address 不能为空"))
        }
        否则 (方法名 == "browser.clear_proxy" || 方法名 == "browser_clear_proxy")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                browser.清空代理 ()
                MCP命令服务器.持久代理地址 = ""
                MCP命令服务器.持久代理账号 = ""
                MCP命令服务器.持久代理密码 = ""
                返回 (MCP命令服务器.响应_需要刷新 (命令ID, "代理已清除"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        // === 下载 ===
        否则 (方法名 == "browser.start_download" || 方法名 == "browser_start_download")
