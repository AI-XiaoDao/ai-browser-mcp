            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, srcJSON))
        }
        // === 自动断点求值: 断点命中→自动执行JS→自动resume→循环 (持续监控模式) ===
        否则 (方法名 == "browser.debugger_auto" || 方法名 == "browser_debugger_auto")
        {
            变量 autoBpUrl <类型 = 文本型>
            autoBpUrl = MCP命令服务器.yyjson取文本 (参数JSON, "breakpoint")
            如果 (autoBpUrl == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "breakpoint 不能为空 | URL正则, 如: example\\\\.com/main\\\\.js"))
            }
            变量 autoMaxHits <类型 = 整数>
            autoMaxHits = MCP命令服务器.yyjson取整数 (参数JSON, "max_hits")
            如果 (autoMaxHits <= 0)
            {
                autoMaxHits = 5
            }
            如果 (autoMaxHits > 100)
            {
                autoMaxHits = 100
            }
            变量 autoExprRaw <类型 = 文本型>
            autoExprRaw = MCP命令服务器.yyjson取文本 (参数JSON, "expressions")
            如果 (autoExprRaw == "")
            {
                autoExprRaw = "[\"location.href\"]"
            }
            变量 autoMaxMs <类型 = 整数>
            autoMaxMs = MCP命令服务器.yyjson取整数 (参数JSON, "max_ms")
            如果 (autoMaxMs == 0)
            {
                autoMaxMs = 60000
            }
            变量 autoNavUrl <类型 = 文本型>
            autoNavUrl = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            // 步骤1: 启用调试器
            MCP命令服务器.确保Debugger已恢复 (命令ID + "_pre")
            变量 autoEnRaw <类型 = 文本型>
            autoEnRaw = MCP命令服务器.执行CDP并同步等待 (命令ID + "_en", "Debugger.enable", "{}", 15000)
            如果 (MCP命令服务器.CDP同步结果是否成功 (autoEnRaw) == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "Debugger.enable 失败"))
            }
            MCP命令服务器.MCP可中断延时 (300)
            // 步骤2: 设置断点
            变量 autoBpParams <类型 = YYJSON对象类>
            autoBpParams.创建自文本 ("{}")
            autoBpParams.加入文本成员 ("urlRegex", autoBpUrl)
            变量 autoLine <类型 = 整数>
            autoLine = MCP命令服务器.yyjson取整数 (参数JSON, "line")
            autoBpParams.加入整数成员 ("lineNumber", autoLine)
            MCP命令服务器.清除CDP事件记录 ("Debugger.paused")
            变量 autoBpRaw <类型 = 文本型>
            autoBpRaw = MCP命令服务器.执行CDP并同步等待 (命令ID + "_bp", "Debugger.setBreakpointByUrl", autoBpParams.到可读文本 (YYJSON格式化选项.压缩), 15000)
            如果 (MCP命令服务器.CDP设置断点结果是否成功 (autoBpRaw) == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "断点设置失败: " + MCP命令服务器.取CDP同步结果错误 (autoBpRaw)))
            }
            // 步骤3: 导航 (可选)
            如果 (autoNavUrl != "")
            {
                如果 (MCP命令服务器.验证URL安全 (autoNavUrl) == 假)
                {
                    返回 (MCP命令服务器.命令失败 (命令ID, "URL 不安全: " + autoNavUrl))
                }
                变量 autoBrowser <类型 = 类_FBrowser_浏览器>
                autoBrowser = MCP命令服务器.取主浏览器 ()
                如果 (autoBrowser.是否为空 () == 假)
                {
                    变量 autoNavFrame <类型 = 类_FBrowser_框架>
                    autoNavFrame = MCP命令服务器.取安全主框架 (autoBrowser)
                    如果 (autoNavFrame.是否为空 () == 假 && autoNavFrame.是否有效 ())
                    {
                        autoNavFrame.载入地址 (autoNavUrl)
                        MCP命令服务器.MCP可中断延时 (1000)
                    }
                }
            }
