            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 清单 <类型 = 整数数组类>
                清单 = browser.进程间消息_取渲染进程ID清单 ()
                返回 (MCP命令服务器.构建整数值JSON ("count", 清单.取成员数 ()))
            }
            返回 (MCP命令服务器.构建整数值JSON ("count", 0))
        }
        否则 (方法名 == "browser.ipc_renderer_ids" || 方法名 == "browser_ipc_renderer_ids")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            变量 ids数组 <类型 = YYJSON数组类>
            ids数组.创建自文本数据 (取空文本数组 ())
            如果 (browser.是否为空 () == 假)
            {
                变量 清单 <类型 = 整数数组类>
                清单 = browser.进程间消息_取渲染进程ID清单 ()
                计次循环 (清单.取成员数 ())
                {
                    ids数组.加入整数成员 (清单.取成员 (取循环索引 ()))
                }
            }
            变量 ids头 <类型 = YYJSON对象类>
            ids头.创建自文本 ("{}")
            变量 ids头JSON <类型 = 文本型>
            ids头JSON = ids头.到可读文本 (YYJSON格式化选项.压缩)
            变量 ids包装 <类型 = 文本型>
            ids包装 = 取文本左边 (ids头JSON, 取文本长度 (ids头JSON) - 1) + ",\"ids\":" + ids数组.到可读文本 (YYJSON格式化选项.压缩) + "}"
            返回 (MCP命令服务器.命令成功_原始JSON (命令ID, ids包装))
        }
        // === v1.6 全局函数 ===
        否则 (方法名 == "browser.create_url_request" || 方法名 == "browser_create_url_request")
        {
            变量 reqURL <类型 = 文本型>
            reqURL = MCP命令服务器.yyjson取文本 (参数JSON, "url")
            如果 (reqURL == "")
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "url " + MCP命令服务器.错误_缺少参数))
            }
            如果 (MCP命令服务器.尝试占用URL请求槽 () == 假)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "URL请求并发已满(" + 到文本 (MCP命令服务器.URL请求最大并发) + "), 请稍后重试或 mcp_result consume 已完成的请求"))
            }
            变量 reqMethod <类型 = 文本型>
            reqMethod = MCP命令服务器.yyjson取文本 (参数JSON, "method")
            如果 (reqMethod == "")
            {
                reqMethod = "GET"
            }
            变量 请求 <类型 = 类_FBrowser_请求>
            请求.创建 ()
            请求.置地址 (reqURL)
            请求.置类型 (reqMethod)
            变量 异步URL请求ID <类型 = 文本型>
            异步URL请求ID = MCP命令服务器.生成异步任务ID ()
            变量 URL请求回调 <类型 = 类_FBrowser_事件智能指针>
            URL请求回调.创建 (类_MCP_URL请求回调)
            URL请求回调.取执行类 (类_MCP_URL请求回调).任务ID = 异步URL请求ID
            FBrowser_创建URL请求 (请求, , URL请求回调, MCP命令服务器.URL请求默认超时)
            返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步URL请求ID, "URL请求已提交, 通过mcp_result查询结果"))
        }
        否则 (方法名 == "browser.find_by_hwnd" || 方法名 == "browser_find_by_hwnd")
        {
            变量 hwnd <类型 = 整数>
            hwnd = MCP命令服务器.yyjson取整数 (参数JSON, "hwnd")
            如果 (hwnd == 0)
            {
                返回 (MCP命令服务器.命令失败 (命令ID, "hwnd " + MCP命令服务器.错误_缺少参数))
            }
            变量 found <类型 = 类_FBrowser_浏览器>
            found = FBrowser_浏览器_通过窗口句柄取浏览器 (hwnd)
            如果 (found.是否为空 () == 假 && found.是否已关闭 () == 假)
            {
                变量 info <类型 = YYJSON对象类>
                info.创建自文本 ("{}")
                info.加入整数成员 ("id", found.取ID ())
                变量 hwndFrame <类型 = 类_FBrowser_框架>
                hwndFrame = MCP命令服务器.取安全主框架 (found)
                如果 (hwndFrame.是否为空 () == 假)
                {
                    info.加入文本成员 ("url", hwndFrame.取地址 ())
                }
                返回 (MCP命令服务器.命令成功_原始JSON (命令ID, info.到可读文本 (YYJSON格式化选项.压缩)))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "未找到窗口句柄为 " + 到文本 (hwnd) + " 的浏览器"))
        }
        否则 (方法名 == "browser.user_tags" || 方法名 == "browser_user_tags")
        {
            变量 tag清单 <类型 = 类_FBrowser_列表值>
            tag清单 = FBrowser_浏览器_取用户标识清单 ()
            如果 (tag清单.是否为空 () == 假)
            {
                变量 JSON数组 <类型 = YYJSON数组类>
                JSON数组.创建自文本数据 (MCP命令服务器.取空文本数组 ())
                计次循环 (tag清单.取大小 ())
                {
                    JSON数组.加入文本成员 (tag清单.取文本值 (取循环索引 ()))
                }
                变量 结果对象 <类型 = YYJSON对象类>
                结果对象.创建自文本 ("{}")
                结果对象.加入文本成员 ("id", 命令ID)
                结果对象.加入逻辑值成员 ("success", 真)
                结果对象.加入数组成员 ("tags", JSON数组)
                返回 (结果对象.到可读文本 (YYJSON格式化选项.压缩))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, "无法获取用户标识清单"))
        }
        // === v1.6 缓存/清理 ===
        否则 (方法名 == "browser.clear_cache_browser" || 方法名 == "browser_clear_cache_browser")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 异步清理ID2 <类型 = 文本型>
                异步清理ID2 = MCP命令服务器.生成异步任务ID ()
                变量 清理回调 <类型 = 类_FBrowser_事件智能指针>
                清理回调.创建 (类_MCP_清理缓存回调)
                清理回调.取执行类 (类_MCP_清理缓存回调).任务ID = 异步清理ID2
                browser.清理缓存 (, , , 清理回调)
                返回 (MCP命令服务器.命令成功_异步 (命令ID, 异步清理ID2, "浏览器缓存清理已提交, 通过mcp_result查询"))
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        否则 (方法名 == "browser.cache_dir" || 方法名 == "browser_cache_dir")
        {
            变量 browser <类型 = 类_FBrowser_浏览器>
            browser = MCP命令服务器.取主浏览器 ()
            如果 (browser.是否为空 () == 假)
            {
                变量 reqCtx <类型 = 类_FBrowser_请求环境>
                reqCtx = browser.取请求环境 ()
                如果 (reqCtx.是否为空 () == 假)
                {
                    返回 (MCP命令服务器.构建简单JSON ("cache_dir", reqCtx.取缓存路径 ()))
                }
            }
            返回 (MCP命令服务器.命令失败 (命令ID, MCP命令服务器.错误_无浏览器))
        }
        返回 ("")  // 链末: 交给 分类分派_填表操作 / 分类分派_系统操作
    }
    #
}
