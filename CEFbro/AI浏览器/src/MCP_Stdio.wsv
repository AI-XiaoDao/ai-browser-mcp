<火山程序 类型 = "通常" 版本 = 1 />
包 火山.程序
# ================================================================
# MCP Stdio 传输层 — 纯火山实现
# stdin/stdout 读写 + MCP 主循环
# 复用 MCP命令服务器.处理MCP请求() 作为MCP引擎
# ================================================================
类 MCPStdio桥 <公开 @全局类 = 真>
{
    变量 Stdio线程实例 <公开 静态 类型 = 类_MCP_Stdio服务线程>
    变量 Stdio应退出 <公开 静态 类型 = 逻辑型 值 = 假>
    # ======== stdin 读取 (内联C++, 支持1MB大消息, 可响应线程停止) ========
    方法 读取一行 <公开 静态 类型 = 文本型>
    参数 线程句柄 <类型 = 变整数 @默认值 = 0 注释 = "非0时在等待stdin期间检查是否需要退出">
    {
        变量 行字节集 <类型 = 字节集类>
        @ // 可中断读取: PeekNamedPipe 轮询 + 线程退出检查, 避免退出时 ReadFile 永久阻塞
        @ HANDLE hStdin = GetStdHandle(STD_INPUT_HANDLE);
        @ if (hStdin == INVALID_HANDLE_VALUE || hStdin == NULL) return CVolString();
        @ std::vector<char> buf(4096);
        @ for (;;) {
        @     if (@<Stdio应退出>) return CVolString();
        @     if (@<线程句柄> != 0 && g_objVolApp.GetThreadPool().IsThreadNeedBreak((HVOLTHREAD)@<线程句柄>, 0))
        @         return CVolString();
        @     DWORD avail = 0;
        @     if (!PeekNamedPipe(hStdin, NULL, 0, NULL, &avail, NULL)) break;
        @     if (avail == 0) { Sleep(50); continue; }
        @     DWORD total = 0;
        @     while (total < 1048576) {
        @         if (@<Stdio应退出>) return CVolString();
        @         if (@<线程句柄> != 0 && g_objVolApp.GetThreadPool().IsThreadNeedBreak((HVOLTHREAD)@<线程句柄>, 0))
        @             return CVolString();
        @         DWORD n = 0;
        @         DWORD toRead = (DWORD)min((size_t)(buf.size() - total - 1), (size_t)4096);
        @         if (!ReadFile(hStdin, &buf[total], toRead, &n, NULL) || n == 0) break;
        @         DWORD newlineAt = 0;
        @         for (DWORD i = 0; i < n; i++) {
        @             if (buf[total + i] == '\n') { newlineAt = i + 1; break; }
        @         }
        @         total += n;
        @         if (newlineAt > 0) { total = total - n + newlineAt; break; }
        @         if (total + 128 >= (DWORD)buf.size()) buf.resize(buf.size() * 2);
        @     }
        @     if (total == 0) { Sleep(50); continue; }
        @     while (total > 0 && (buf[total-1]=='\n'||buf[total-1]=='\r')) total--;
        @     if (total > 0) {
        @         @<行字节集>.CopyFrom(buf.data(), (INT_P)total);
        @         break;
        @     }
        @ }
        @ return CVolString();
        如果 (取字节集长度 (行字节集) == 0)
        {
            返回 ("")
        }
        返回 (UTF8到文本 (行字节集))
    }
    # ======== stdout 写入 ========
    方法 写入一行 <公开 静态>
    参数 文本 <类型 = 文本型>
    {
        @ // WriteFile stdout, 自动处理UTF8, 检查失败
        @ std::string utf8 = CU8String(@<文本>.GetText()).GetText();
        @ utf8 += "\n";
        @ HANDLE hOut = GetStdHandle(STD_OUTPUT_HANDLE);
        @ if (hOut == INVALID_HANDLE_VALUE || hOut == NULL) return;
        @ DWORD written = 0;
        @ if (!WriteFile(hOut, utf8.c_str(), (DWORD)utf8.size(), &written, NULL))
        @ {
        @     // 写失败: 尝试stderr告知用户
        @     HANDLE hErr = GetStdHandle(STD_ERROR_HANDLE);
        @     if (hErr != INVALID_HANDLE_VALUE && hErr != NULL)
        @     {
        @         const char* err = "[MCP-Stdio] stdout写入失败\n";
        @         WriteFile(hErr, err, (DWORD)strlen(err), &written, NULL);
        @     }
        @ }
    }
    # ======== stderr 日志 (不影响stdout的MCP协议) ========
    方法 写日志 <公开 静态>
    参数 文本 <类型 = 文本型>
    {
        @ std::string msg = "[MCP-Stdio] ";
        @ msg += CU8String(@<文本>.GetText()).GetText();
        @ msg += "\n";
        @ HANDLE hErr = GetStdHandle(STD_ERROR_HANDLE);
        @ if (hErr == INVALID_HANDLE_VALUE || hErr == NULL) return;
        @ DWORD written = 0;
        @ WriteFile(hErr, msg.c_str(), (DWORD)msg.size(), &written, NULL);
    }
    # ======== 检测命令行 --mcp-stdio 参数 ========
    方法 是否为Stdio模式 <公开 静态 类型 = 逻辑型>
    {
        变量 命令行数组 <类型 = 文本数组类>
        环境存取类.取命令行 (命令行数组)
        变量 count <类型 = 整数>
        count = 命令行数组.取成员数 ()
        计次循环 (count)
        {
            变量 arg <类型 = 文本型>
            arg = 命令行数组.取成员 (取循环索引 ())
            如果 (arg == "--mcp-stdio" || arg == "--stdio" || arg == "--headless")
            {
                返回 (真)
            }
        }
        返回 (假)
    }
    # ======== MCP stdio 主循环 (阻塞, 可响应停止) ========
    方法 运行Stdio主循环 <公开 静态>
    参数 线程句柄 <类型 = 变整数 @默认值 = 0>
    {
        写日志 ("============================================")
        写日志 ("AI浏览器 MCP Stdio Server 启动")
        写日志 ("协议: JSON-RPC 2.0 over stdin/stdout")
        写日志 ("直连: Claude Desktop / Cursor / Trace 等任意AI工具")
        写日志 ("============================================")
        // 循环读取 stdin → 处理 → stdout
        循环判断首 ()
        {
            如果 (Stdio应退出)
            {
                跳出循环
            }
            如果 (线程句柄 != 0 && 缓存线程类.是否需要退出 (线程句柄))
            {
                跳出循环
            }
            变量 请求JSON <类型 = 文本型>
            请求JSON = 读取一行 (线程句柄)
            如果 (请求JSON == "")
            {
                如果 (Stdio应退出 || (线程句柄 != 0 && 缓存线程类.是否需要退出 (线程句柄)))
                {
                    跳出循环
                }
                到循环尾
            }
            // === 核心: 复用已有MCP引擎处理 ===
            变量 响应JSON <类型 = 文本型>
            响应JSON = MCP命令服务器.处理MCP请求 (请求JSON, "stdio")
            如果 (取文本长度 (请求JSON) > 200)
            {
                写日志 ("收到命令: " + 取文本左边 (请求JSON, 200) + "...(" + 到文本 (取文本长度 (请求JSON)) + "字符)")
            }
            否则
            {
                写日志 ("收到命令: " + 请求JSON)
            }
            // === 输出响应 ===
            如果 (响应JSON != "")
            {
                写入一行 (响应JSON)
            }
        }
        循环判断尾 (真)
        写日志 ("MCP Stdio Server 停止")
    }
    方法 启动并行Stdio服务 <公开 静态>
    {
        如果 (Stdio线程实例.是否正在运行 ())
        {
            返回
        }
        Stdio应退出 = 假
        Stdio线程实例.启动 ()
    }
    方法 停止Stdio服务 <公开 静态>
    {
        Stdio应退出 = 真
        如果 (Stdio线程实例.是否正在运行 ())
        {
            Stdio线程实例.停止 ()
        }
    }
    #
}
类 类_MCP_Stdio服务线程 <公开 基础类 = 缓存线程类>
{
    #
    方法 缓存线程类_线程运行 <接收事件 类型 = 整数 注释 = "用户需要接收并处理本事件以执行所需要的功能,该事件处理方法将在一个单独的线程中运行." 注释 = "注意:"
            注释 = "  1. 在本事件的接收处理方法中,必须尽可能快地频繁调用本对象的\"是否需要退出\"方法," 注释 = "一旦发现该方法返回真,则需要尽快结束执行并返回,否则将导致另一线程中的\"停止\"方法调用" 注释 = "进入死等状态;"
            注释 = "  2. 在本事件的接收处理方法中不允许对窗口界面直接进行操作,否则可能导致死锁.">
    参数 来源对象 <类型 = 缓存线程类 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 线程句柄 <类型 = 变整数 注释 = "提供所启动线程在线程池中的句柄值,必定不为0.">
    参数 用户参数 <类型 = 变整数 注释 = "提供启动时传递到线程函数的用户参数值">
    参数 退出事件 <类型 = 变整数 注释 = "本参数普通用户无需使用">
    {
        MCPStdio桥.运行Stdio主循环 (线程句柄)
        返回 (0)
    }
}
