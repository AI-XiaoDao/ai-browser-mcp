<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# ================================================================
# AI浏览器 — 启动入口 + 主窗口 + FBrowser 初始化
# ================================================================

类 启动类 <公开 基础类 = 窗口程序类>
{
    变量 主窗口对象 <公开 类型 = AI浏览器主窗口>

    方法 启动方法 <公开 类型 = 整数>
    {
        // 先加载配置 (VIP 授权码须在 FBrowser 初始化前设置)
        MCP命令服务器.加载MCP配置 ()
        如果 (MCP命令服务器.VIP授权码 == "")
        {
            MCP命令服务器.VIP授权码 = "xsmzas1"  // 使用免费授权码
        }
        FBrowserVIP注册.VIP注册_置授权码 (MCP命令服务器.VIP授权码)
        变量 设置 <类型 = FBrowser_初始化配置>
        设置.无沙箱 = 真
        设置.缓存目录 = 取运行目录 () + "\\CacheData\\GlobalData"
        设置.本地化语言 = "zh-CN"
        设置.接收语言清单 = "zh-CN,zh,en"
        设置.启用系统消息循环 = 真
        设置.保留Session = 真
        设置.日志目录 = 取运行目录 () + "\\log.txt"
        设置.日志模式 = 日志级别.致命
        设置.执行进程 = 取运行目录 () + "\\" + 取执行文件名 ()
        设置.启用自动多例模式 = 真
        变量 初始化事件 <类型 = 类_FBrowser_事件智能指针>
        初始化事件.创建 (类_MCP_初始化事件)
        如果真 (FBrowser_初始化 (设置, 初始化事件) == 假)
        {
            调试输出 ("[AI浏览器] FBrowser 初始化失败")
            返回 (0)
        }
        主窗口对象.创建主窗口 ()
        如果 (MCPStdio桥.是否为Stdio模式 ())
        {
            调试输出 ("[AI浏览器] Stdio模式")
        }

        返回 (1)
    }

    方法 即将退出 <公开 注释 = "用户的启动类可以覆盖此方法以在窗口程序退出前做一些清理工作" @虚拟方法 = 可覆盖>
    {
        父对象.即将退出 ()  // 调用基础类中的被覆盖虚拟方法
    }
}

# ── FBrowser 应用级初始化事件 ──

类 类_MCP_初始化事件 <公开 基础类 = 类_FBrowser_应用事件>
{
    方法 记录应用监控事件 <类型 = 逻辑型>
    参数 事件类型 <类型 = 文本型>
    参数 数据JSON <类型 = 文本型 @默认值 = "">
    {
        如果 (MCP命令服务器.是否监控应用事件)
        {
            MCP命令服务器.记录应用事件 (事件类型, 数据JSON)
        }
        返回 (MCP命令服务器.是否监控应用事件)
    }

    方法 浏览器_初始化完毕 <公开 @虚拟方法 = 可覆盖>
    {
        MCP命令服务器.启动MCP服务器 ()
        变量 端口文本 <类型 = 文本型>
        端口文本 = 到文本 (MCP命令服务器.服务器端口)
        变量 绑定地址 <类型 = 文本型>
        绑定地址 = MCP命令服务器.服务器绑定地址
        写环境变量 ("AI_BROWSER_MCP_URL", "ws://" + 绑定地址 + ":" + 端口文本)
        写环境变量 ("AI_BROWSER_MCP_PORT", 端口文本)
        写环境变量 ("AI_BROWSER_MCP_HEALTH", "http://" + 绑定地址 + ":" + 端口文本 + "/health")
        写环境变量 ("AI_BROWSER_MCP_HTTP_POST", "http://" + 绑定地址 + ":" + 端口文本 + "/mcp")
        调试输出 ("[AI浏览器] FBrowser 初始化完毕, MCP 服务已就绪")
        如果 (MCPStdio桥.是否为Stdio模式 ())
        {
            调试输出 ("[AI浏览器] 检测到 Stdio MCP 模式, 启动 stdin 并行服务")
            MCPStdio桥.启动并行Stdio服务 ()
        }
    }

    方法 执行关闭完毕 <公开 注释 = "FBrowser_关闭 完成后触发, 确保进程与子进程退出" @虚拟方法 = 可覆盖>
    参数 是否结束程序 <类型 = 逻辑型类>
    {
        调试输出 ("[AI浏览器] FBrowser 资源已释放, 结束进程")
        是否结束程序.值 = 真
    }

    方法 渲染_即将捕获异常 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 V8环境 <类型 = 类_FBrowser_V8环境>
    参数 V8异常 <类型 = 类_FBrowser_V8异常>
    参数 V8堆栈踪迹 <类型 = 类_FBrowser_V8堆栈踪迹>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        如果 (V8异常.是否为空 () == 假)
        {
            数据.加入文本成员 ("message", V8异常.取消息 ())
        }
        记录应用监控事件 ("app_v8_exception", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_焦点节点改变 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 DOM节点 <类型 = 类_FBrowser_DOM节点>
    {
        如果 (MCP命令服务器.是否监控应用事件 == 假)
        {
            返回
        }
        // 按浏览器ID分别节流, 防止跨浏览器事件互相抑制 (多弹窗场景)
        变量 当前毫秒 <类型 = 长整数>
        变量 上次毫秒 <类型 = 长整数 值 = 0>
        当前毫秒 = 取启动时间 ()
        变量 prevKey <类型 = 文本型>
        prevKey = "focus_ts_" + 到文本 (浏览器.取ID ())
        如果 (MCP命令服务器.应用事件节流字典.是否为空对象 () || MCP命令服务器.应用事件节流字典.是否为空 ())
        {
            MCP命令服务器.应用事件节流字典.创建 ()
        }
        上次毫秒 = MCP命令服务器.应用事件节流字典.取整数值 (prevKey)
        如果 (当前毫秒 - 上次毫秒 < 300)
        {
            返回
        }
        MCP命令服务器.应用事件节流字典.置整数值 (prevKey, (整数)当前毫秒)
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        如果 (DOM节点.是否为空 () == 假)
        {
            数据.加入文本成员 ("tag", DOM节点.取标签名 ())
        }
        记录应用监控事件 ("app_dom_focus_changed", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_即将释放V8环境 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 V8环境 <类型 = 类_FBrowser_V8环境>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入文本成员 ("url", 框架.取地址 ())
        记录应用监控事件 ("app_v8_released", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_载入错误 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 框架 <类型 = 类_FBrowser_框架>
    参数 错误代码 <类型 = 整数>
    参数 错误文本 <类型 = 文本型>
    参数 失败地址 <类型 = 文本型>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        数据.加入整数成员 ("error_code", 错误代码)
        数据.加入文本成员 ("error_text", 错误文本)
        数据.加入文本成员 ("failed_url", 失败地址)
        记录应用监控事件 ("app_render_load_error", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_浏览器创建 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    参数 额外信息 <类型 = 类_FBrowser_字典值>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        记录应用监控事件 ("app_render_browser_created", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    方法 渲染_即将销毁浏览器 <公开 @虚拟方法 = 可覆盖>
    参数 浏览器 <类型 = 类_FBrowser_浏览器>
    {
        变量 数据 <类型 = YYJSON对象类>
        数据.创建自文本 ("{}")
        数据.加入整数成员 ("browser_id", 浏览器.取ID ())
        记录应用监控事件 ("app_render_browser_destroyed", 数据.到可读文本 (YYJSON格式化选项.压缩))
    }

    # 持久 V8 inject 改由 MCP_BrowserEvents 载入/建框架时 应用持久V8到框架 (浏览器进程)
}

# ── 主窗口: 工具栏 + 地址栏 + MCP 状态 + 嵌入式浏览器 ──

类 AI浏览器主窗口 <基础类 = 窗口 注释 = "AI浏览器主窗口" @视窗.布局 = "client_size = \"1200, 800\"" 标题 = "AI浏览器-MCP" 最大化按钮 = 真 最小化按钮 = 真
        窗口边框 = 普通可调边框>
{
    常量 工具栏高度 <类型 = 整数 值 = 36>
    常量 状态栏高度 <类型 = 整数 值 = 28>

    变量 后退按钮 <类型 = 按钮 折叠 隐藏值属性 = "0" @视窗.布局 = "id = 101\r\npos = \"4, 4, 36, 28\"" 标题 = "<">
    变量 前进按钮 <类型 = 按钮 隐藏值属性 = "0" @视窗.布局 = "id = 102\r\npos = \"44, 4, 36, 28\"" 标题 = ">">
    变量 刷新按钮 <类型 = 按钮 隐藏值属性 = "0" @视窗.布局 = "id = 103\r\npos = \"84, 4, 36, 28\"" 标题 = "R">
    变量 地址编辑框 <类型 = 编辑框 隐藏值属性 = "0" @视窗.布局 = "id = 104\r\npos = \"124, 4, 1020, 28\"">
    变量 访问按钮 <类型 = 按钮 隐藏值属性 = "0" @视窗.布局 = "id = 105\r\npos = \"1148, 4, 48, 28\"" 标题 = "前往">
    变量 MCP状态标签 <类型 = 标签 隐藏值属性 = "0" @视窗.布局 = "id = 106\r\npos = \"4, 768, 1192, 24\"" 标题 = "MCP: 启动中...">
    变量 状态时钟 <类型 = 时钟 隐藏值属性 = "0" @视窗.布局 = "id = 107\r\npos = \"0, 0, 1, 1\"" 时钟周期 = 800>
    变量 托盘图标 <类型 = 图标对象类>
    变量 地址栏有焦点 <类型 = 逻辑型 值 = 假>
    变量 允许真关闭 <类型 = 逻辑型 值 = 假>
    变量 MCP就绪已通知 <类型 = 逻辑型 值 = 假>
    变量 正在退出 <类型 = 逻辑型 值 = 假>

    方法 显示隐藏窗口 <公开>
    参数 隐藏 <类型 = 逻辑型>
    {
        可视 = 隐藏 == 假
    }

    方法 AI浏览器主窗口_创建完毕 <接收事件 类型 = 整数 注释 = "当本组件及其中所有子组件均被创建完毕后发送此事件.">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        浏览器容器.地址编辑框 = 地址编辑框
        浏览器容器.地址栏已绑定 = 真
        浏览器容器.最新地址 = "about:blank"
        地址编辑框.内容 = ""
        托盘图标 = 图标对象类.载入图标文件 (取运行目录 () + "\\" + 取执行文件名 ())
        如果 (托盘图标.为空 () == 假)
        {
            置托盘图标对象 (托盘图标, "AI浏览器-MCP | " + MCP命令服务器.取MCP_WS地址 ())
        }
        创建嵌入式浏览器 ()
        调整布局 ()
        刷新MCP状态 ()
        状态时钟.时钟周期 = 800
        返回 (0)
    }

    方法 创建嵌入式浏览器 <公开>
    {
        如果 (MCP命令服务器.MCP正在关闭)
        {
            返回
        }
        如果 (FBrowser_浏览器_取数量 () > 0)
        {
            返回
        }
        变量 窗口信息 <类型 = FBrowser_窗口信息>
        变量 浏览器配置 <类型 = FBrowser_浏览器配置>
        变量 浏览器顶 <类型 = 整数>
        浏览器顶 = 工具栏高度
        窗口信息.父窗口句柄 = 取窗口句柄 ()
        窗口信息.横坐标 = 0
        窗口信息.纵坐标 = 浏览器顶
        窗口信息.宽度 = 取用户区宽度 ()
        窗口信息.高度 = 取用户区高度 () - 工具栏高度 - 状态栏高度
        变量 浏览器事件 <类型 = 类_FBrowser_事件智能指针>
        浏览器事件.创建 (类_MCP_浏览器事件)
        FBrowser_创建浏览器 ("about:blank", 窗口信息, 浏览器配置, , , 浏览器事件, , )
        浏览器容器.最新地址 = "about:blank"
        地址编辑框.内容 = "about:blank"
    }

    方法 恢复嵌入式布局 <公开>
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器实例 ()
        如果 (browser.是否为空 () == 假 && browser.是否已关闭 () == 假)
        {
            browser.置自动调整大小 (假, 0, 0, 0, 0)
            browser.显示隐藏窗口 (真)
            browser.移动窗口 (0, 工具栏高度, 取用户区宽度 (), 取用户区高度 () - 工具栏高度 - 状态栏高度, 真)
        }
        调整布局 ()
        浏览器容器.恢复欢迎页 ()
    }

    方法 确保主浏览器健康 <公开>
    {
        如果 (MCP命令服务器.MCP正在关闭)
        {
            返回
        }
        如果 (浏览器容器.需要重建浏览器)
        {
            浏览器容器.需要重建浏览器 = 假
            如果 (FBrowser_浏览器_取数量 () == 0)
            {
                创建嵌入式浏览器 ()
                调整布局 ()
            }
            否则
            {
                恢复嵌入式布局 ()
            }
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器实例 ()
        如果 (browser.是否为空 () || browser.是否已关闭 ())
        {
            如果 (FBrowser_浏览器_取数量 () == 0)
            {
                创建嵌入式浏览器 ()
                调整布局 ()
            }
            返回
        }
        如果 (浏览器容器.需要恢复布局)
        {
            浏览器容器.需要恢复布局 = 假
            恢复嵌入式布局 ()
        }
    }

    方法 取主浏览器实例 <公开 类型 = 类_FBrowser_浏览器>
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = MCP命令服务器.取主浏览器 ()
        返回 (browser)
    }

    方法 导航到地址栏 <公开>
    {
        变量 输入URL <类型 = 文本型>
        输入URL = 删首尾空 (地址编辑框.内容)
        如果 (输入URL == "")
        {
            返回
        }
        输入URL = MCP命令服务器.规范化URL (输入URL, "")
        如果 (MCP命令服务器.验证URL安全 (输入URL) == 假)
        {
            调试输出 ("[AI浏览器] 拒绝不安全 URL:", 输入URL)
            返回
        }
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器实例 ()
        如果 (browser.是否为空 () == 假 && browser.是否已关闭 () == 假)
        {
            变量 frame <类型 = 类_FBrowser_框架>
            frame = MCP命令服务器.取安全主框架 (browser)
            如果 (frame.是否有效 ())
            {
                frame.载入地址 (输入URL)
                浏览器容器.最新地址 = 输入URL
            }
        }
    }

    方法 调整布局 <公开>
    {
        变量 客户宽 <类型 = 整数>
        变量 客户高 <类型 = 整数>
        客户宽 = 取用户区宽度 ()
        客户高 = 取用户区高度 ()
        变量 地址宽 <类型 = 整数>
        地址宽 = 客户宽 - 124 - 52
        如果 (地址宽 < 100)
        {
            地址宽 = 100
        }
        地址编辑框.左边 = 124
        地址编辑框.顶边 = 4
        地址编辑框.宽度 = 地址宽
        地址编辑框.高度 = 28
        访问按钮.左边 = 客户宽 - 52
        访问按钮.顶边 = 4
        访问按钮.宽度 = 48
        访问按钮.高度 = 28
        MCP状态标签.左边 = 4
        MCP状态标签.顶边 = 客户高 - 状态栏高度
        MCP状态标签.宽度 = 客户宽 - 8
        MCP状态标签.高度 = 状态栏高度 - 4
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器实例 ()
        如果 (browser.是否为空 () == 假 && browser.是否已关闭 () == 假)
        {
            browser.移动窗口 (0, 工具栏高度, 客户宽, 客户高 - 工具栏高度 - 状态栏高度, 假)
        }
    }

    方法 同步地址栏 <公开>
    {
        如果 (地址栏有焦点)
        {
            返回
        }
        如果 (浏览器容器.最新地址 != "" && 浏览器容器.最新地址 != 地址编辑框.内容)
        {
            地址编辑框.内容 = 浏览器容器.最新地址
        }
    }

    方法 刷新MCP状态 <公开>
    {
        变量 状态文本 <类型 = 文本型>
        如果 (浏览器容器.MCP服务已就绪)
        {
            状态文本 = "MCP就绪 | POST " + MCP命令服务器.取MCP_HTTP地址 () + "/mcp"
            状态文本 = 状态文本 + " | WS " + MCP命令服务器.取MCP_WS地址 ()
        }
        否则
        {
            状态文本 = "MCP: 启动中..."
        }
        状态文本 = 状态文本 + " | 浏览器 " + 到文本 (FBrowser_浏览器_取数量 ())
        状态文本 = 状态文本 + " | v" + MCP命令服务器.MCP_版本号
        MCP状态标签.标题 = 状态文本
        如果 (浏览器容器.MCP服务已就绪 && MCP就绪已通知 == 假)
        {
            MCP就绪已通知 = 真
            显示托盘通知 ("AI浏览器 MCP 已就绪", "POST " + MCP命令服务器.取MCP_HTTP地址 () + "/mcp" + "\r\n桥接: node mcp_bridge.js --check" + "\r\n全量: node run_all_tests.js --quick", 0, 15)
        }
    }

    方法 AI浏览器主窗口_尺寸被改变 <接收事件 类型 = 整数 注释 = "当本组件的尺寸被改变后发送此事件">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        调整布局 ()
        返回 (0)
    }

    方法 AI浏览器主窗口_位置被改变 <接收事件 类型 = 整数 注释 = "当本组件的位置被改变后发送此事件">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
