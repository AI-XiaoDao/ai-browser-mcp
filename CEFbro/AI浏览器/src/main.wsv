    }

    方法 按钮_被单击 <接收事件 类型 = 整数 注释 = "当按钮被单击后发送此事件">
    参数 来源对象 <类型 = 按钮 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        变量 browser <类型 = 类_FBrowser_浏览器>
        browser = 取主浏览器实例 ()
        如果 (来源对象 == 后退按钮)
        {
            如果 (browser.是否为空 () == 假 && browser.可否后退 ())
            {
                browser.后退 ()
            }
        }
        否则 (来源对象 == 前进按钮)
        {
            如果 (browser.是否为空 () == 假 && browser.可否前进 ())
            {
                browser.前进 ()
            }
        }
        否则 (来源对象 == 刷新按钮)
        {
            如果 (browser.是否为空 () == 假)
            {
                browser.重新载入 ()
            }
        }
        否则 (来源对象 == 访问按钮)
        {
            导航到地址栏 ()
        }
        返回 (0)
    }

    方法 编辑框_获得焦点 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 编辑框>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 地址编辑框)
        {
            地址栏有焦点 = 真
        }
        返回 (0)
    }

    方法 编辑框_失去焦点 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 编辑框>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 地址编辑框)
        {
            地址栏有焦点 = 假
            同步地址栏 ()
        }
        返回 (0)
    }

    方法 编辑框_按下某键 <接收事件 类型 = 整数 注释 = "当编辑框中的按键被按下后发送此事件">
    参数 来源对象 <类型 = 编辑框 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 键代码 <类型 = 整数 注释 = "提供所按下键的键代码值">
    参数 辅助键状态 <类型 = 整数 注释 = "事件触发时的辅助键组合状态">
    {
        如果 (来源对象 == 地址编辑框 && 键代码 == 按键码.回车键)
        {
            导航到地址栏 ()
        }
        返回 (0)
    }

    方法 时钟_周期事件 <接收事件 类型 = 整数 注释 = "当时钟组件到达其时钟周期后发送此事件">
    参数 来源对象 <类型 = 时钟 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        如果 (来源对象 == 状态时钟)
        {
            变量 当前毫秒 <类型 = 长整数>
            变量 上次维护毫秒 <静态 类型 = 长整数 值 = 0>
            当前毫秒 = 取启动时间 ()
            如果 (上次维护毫秒 == 0 || 当前毫秒 - 上次维护毫秒 >= MCP命令服务器.定期维护间隔毫秒)
            {
                上次维护毫秒 = 当前毫秒
                MCP命令服务器.执行定期维护 ()
            }
            确保主浏览器健康 ()
            浏览器容器.尝试恢复欢迎页导航 ()
            同步地址栏 ()
            刷新MCP状态 ()
        }
        返回 (0)
    }

    方法 退出应用 <公开>
    {
        如果 (正在退出)
        {
            返回
        }
        正在退出 = 真
        允许真关闭 = 真
        // 1. 停 UI 时钟
        状态时钟.时钟周期 = 0
        // 2. 显示窗口 (FBrowser_关闭 需父窗口有效)
        如果 (可视 == 假)
        {
            可视 = 真
        }
        // 3. 快速停 MCP: 标记关闭 + 停止线程 + 关闭 SQLite, 不等待命令排空 (可能被 CDP 断点/URL 请求卡死)
        MCP命令服务器.MCP正在关闭 = 真
        MCP命令服务器.是否启用 = 假
        MCPStdio桥.停止Stdio服务 ()
        MCP命令服务器.注销CDP观察者 ()
        MCP命令服务器.关闭全部事件监控 ()
        MCP命令服务器.关闭缓存数据库 ()
        // 4. 按官方模式: FBrowser_关闭() 触发浏览器清理 → 执行关闭完毕(单独线程) → 是否结束程序.值=真 → 进程退出
        FBrowser_关闭 ()
        // 5. 兜底: 若执行关闭完毕未触发或延时, 5秒后强制结束
        延时 (5000)
        结束 ()
    }

    方法 AI浏览器主窗口_可否被关闭 <接收事件 类型 = 整数 注释 = "关闭时最小化到托盘, 保持 MCP 服务运行">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        如果 (允许真关闭)
        {
            返回 (0)
        }
        可视 = 假
        返回 (1)
    }

    方法 AI浏览器主窗口_托盘事件 <接收事件 类型 = 整数 注释 = "当本窗口的系统托盘图标被操作时发送此事件">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    参数 操作类型 <类型 = 整数 注释 = "1=单击左键 2=双击左键 3=单击右键">
    {
        如果 (操作类型 == 1 || 操作类型 == 2)
        {
            可视 = 真
            置为前台窗口 ()
        }
        否则 (操作类型 == 3)
        {
            如果 (询问信息框 ("确定要退出 AI浏览器 并停止 MCP 服务吗？", "退出确认"))
            {
                退出应用 ()
            }
        }
        返回 (0)
    }

    方法 AI浏览器主窗口_已被销毁 <接收事件 类型 = 整数 注释 = "当本组件被销毁后发送此事件">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        状态时钟.时钟周期 = 0
        如果 (正在退出 == 假)
        {
            MCP命令服务器.MCP正在关闭 = 真
            MCP命令服务器.是否启用 = 假
            MCPStdio桥.停止Stdio服务 ()
            MCP命令服务器.注销CDP观察者 ()
            MCP命令服务器.关闭全部事件监控 ()
            MCP命令服务器.关闭缓存数据库 ()
            FBrowser_关闭 (真)
            结束 ()
        }
        返回 (0)
    }

    方法 AI浏览器主窗口_将被销毁 <接收事件 类型 = 整数 注释 = "当本组件被销毁前发送此事件 — 窗口句柄仍有效, 在此完成资源预清理">
    参数 来源对象 <类型 = AI浏览器主窗口 注释 = "提供事件产生的具体来源对象">
    参数 标记值 <类型 = 整数 注释 = "用户调用\"挂接事件\"命令时所提供的\"标记值\"参数值,非此方式挂接事件则本参数值固定为0.">
    {
        // 仅在意外销毁路径触发 (正常退出路径已在 退出应用() 中完成全部清理, 正在退出==真 时跳过)
        如果 (正在退出)
        {
            返回 (0)
        }
        正在退出 = 真
        允许真关闭 = 真
        状态时钟.时钟周期 = 0
        如果 (可视 == 假)
        {
            可视 = 真
        }
        MCP命令服务器.MCP正在关闭 = 真
        MCP命令服务器.是否启用 = 假
        MCPStdio桥.停止Stdio服务 ()
        MCP命令服务器.注销CDP观察者 ()
        MCP命令服务器.关闭全部事件监控 ()
        MCP命令服务器.关闭缓存数据库 ()
        FBrowser_关闭 (真)
        结束 ()
        返回 (0)
    }
}
