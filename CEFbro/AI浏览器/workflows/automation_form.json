{
  "name": "automation_form",
  "description": "自动化: 预备 → 注入迷你表单 → 填表点击 → 截图",
  "version": "1.0",
  "on_error": "stop",
  "steps": [
    { "tool": "browser_collect", "args": { "action": "automation_prepare" } },
    { "tool": "browser_navigate", "args": { "url": "about:blank" } },
    { "delay_ms": 300 },
    {
      "tool": "browser_evaluate",
      "args": {
        "code": "document.open();document.write('<!DOCTYPE html><html><body><input id=\"mcp-test-input\" value=\"\"/><select id=\"mcp-test-select\"><option value=\"a\">A</option></select><button id=\"mcp-test-btn\" type=\"button\">Go</button><div id=\"mcp-click-count\">0</div><script>document.getElementById(\"mcp-test-btn\").onclick=function(){var e=document.getElementById(\"mcp-click-count\");e.textContent=String((+e.textContent||0)+1)};</script></body></html>');document.close();'ok'"
      }
    },
    { "delay_ms": 400 },
    { "tool": "browser_fill_set_value", "args": { "selector": "#mcp-test-input", "value": "workflow-auto" } },
    { "tool": "browser_fill_click", "args": { "selector": "#mcp-test-btn" } },
    { "tool": "browser_screenshot", "args": { "format": "png" }, "wait_async": true, "max_ms": 20000 }
  ]
}
