{
  "name": "debugger_full",
  "description": "断点完整流程: enable → 断点 → 导航 → 等待暂停 → 帧内求值 → resume",
  "version": "1.0",
  "on_error": "continue",
  "steps": [
    { "tool": "browser_collect", "args": { "action": "debug_prepare" } },
    { "tool": "browser_debugger_enable", "args": {}, "wait_async": true, "max_ms": 45000 },
    { "delay_ms": 500 },
    { "tool": "browser_debugger_set_breakpoint", "args": { "url": "example\\.com" }, "wait_async": true, "max_ms": 45000 },
    { "tool": "browser_navigate", "args": { "url": "https://example.com/" } },
    { "delay_ms": 1500 },
    {
      "tool": "browser_debugger_wait_paused",
      "args": { "max_ms": 45000 },
      "wait_async": true,
      "max_ms": 50000
    },
    {
      "tool": "browser_debugger_inspect",
      "args": {
        "expressions": "[\"location.href\",\"document.title\",\"typeof window\"]"
      },
      "wait_async": true,
      "max_ms": 25000
    },
    { "tool": "browser_debugger_resume", "args": {}, "wait_async": true, "max_ms": 15000 },
    { "tool": "browser_get_url", "args": {} }
  ]
}
