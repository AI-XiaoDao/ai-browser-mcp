{
  "name": "reverse_analyze",
  "description": "逆向分析: 预备抓包 → 导航百度 → 等待 → 网络日志",
  "version": "1.0",
  "on_error": "stop",
  "steps": [
    { "tool": "browser_collect", "args": { "action": "reverse_prepare", "clear": true } },
    { "tool": "browser_navigate", "args": { "url": "https://www.baidu.com/" } },
    { "delay_ms": 3500 },
    { "tool": "browser_network", "args": { "action": "list", "limit": 800 } },
    { "tool": "browser_get_title", "args": {} }
  ]
}
